"{\"uid\": \"voanews.com-a-terror-attacks-headline-threats-to-upcoming-paris-olympics-7642276.html\", \"noun_phrases\": [{\"sentence\": \"Share Share Print There are new warnings about potential attacks aimed at disrupting the upcoming Summer Olympic Games in Paris, including the potential for more terror plots like the one disrupted last week by French officials.\", \"from\": 0, \"to\": 231, \"entities\": [{\"begin\": 125, \"end\": 130, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999904503, \"rank\": 9.342336455922179e-12, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 214, \"end\": 220, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9882522558998798, \"rank\": 0.006325976812826897, \"text\": \"French\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"new warnings\", \"from\": 28, \"to\": 40}, {\"ngram\": \"potential attacks\", \"from\": 47, \"to\": 64}, {\"ngram\": \"the upcoming Summer Olympic Games\", \"from\": 85, \"to\": 118}, {\"ngram\": \"the potential\", \"from\": 139, \"to\": 152}, {\"ngram\": \"more terror plots\", \"from\": 157, \"to\": 174}, {\"ngram\": \"the one\", \"from\": 180, \"to\": 187}]}, {\"sentence\": \"Areport released Tuesdayby the cybersecurity firm Recorded Future states that despite a high likelihood of cyberattacks, the greatest risk to the Paris Games will come from in-person threats instead of from cyberspace.\", \"from\": 233, \"to\": 451, \"entities\": [{\"begin\": 283, \"end\": 298, \"title\": \"http://dbpedia.org/resource/Recorded_Future\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Recorded Future\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Recorded_Future\", \"dbpedia\": \"http://dbpedia.org/resource/Recorded_Future\"}], \"noun_phrases\": [{\"ngram\": \"Areport\", \"from\": 233, \"to\": 240}, {\"ngram\": \"Tuesdayby\", \"from\": 250, \"to\": 259}, {\"ngram\": \"the cybersecurity firm\", \"from\": 260, \"to\": 282}, {\"ngram\": \"a high likelihood\", \"from\": 319, \"to\": 336}, {\"ngram\": \"cyberattacks\", \"from\": 340, \"to\": 352}, {\"ngram\": \"the greatest risk\", \"from\": 354, \"to\": 371}, {\"ngram\": \"the Paris Games\", \"from\": 375, \"to\": 390}, {\"ngram\": \"person\", \"from\": 409, \"to\": 415}, {\"ngram\": \"cyberspace\", \"from\": 440, \"to\": 450}]}, {\"sentence\": \"\\\"We assess that physical security threats - including terrorism, violent extremism, civil unrest and disruptive protests - pose the greatest risk of harm and disruption,\\\" the report from Recorded Future's Insikt Group said.\", \"from\": 453, \"to\": 676, \"entities\": [{\"begin\": 640, \"end\": 655, \"title\": \"http://dbpedia.org/resource/Recorded_Future\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Recorded Future\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Recorded_Future\", \"dbpedia\": \"http://dbpedia.org/resource/Recorded_Future\"}], \"noun_phrases\": [{\"ngram\": \"physical security threats\", \"from\": 469, \"to\": 494}, {\"ngram\": \"terrorism\", \"from\": 507, \"to\": 516}, {\"ngram\": \"violent extremism\", \"from\": 518, \"to\": 535}, {\"ngram\": \"civil unrest\", \"from\": 537, \"to\": 549}, {\"ngram\": \"disruptive protests\", \"from\": 554, \"to\": 573}, {\"ngram\": \"the greatest risk\", \"from\": 581, \"to\": 598}, {\"ngram\": \"harm\", \"from\": 602, \"to\": 606}, {\"ngram\": \"disruption\", \"from\": 611, \"to\": 621}, {\"ngram\": \"the report\", \"from\": 624, \"to\": 634}]}, {\"sentence\": \"\\\"Terrorists and violent extremists - particularly IS [Islamic State] and al-Qaida supporters in France and neighboring European countries - will almost certainly continue to plot and incite violent attacks targeting the Paris Olympics,\\\" the report added.\", \"from\": 678, \"to\": 932, \"entities\": [{\"begin\": 732, \"end\": 745, \"title\": \"http://dbpedia.org/resource/Islamic_State\", \"score\": 1.0, \"rank\": 1.475890527757457e-14, \"text\": \"Islamic State\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Islamic_State\", \"dbpedia\": \"http://dbpedia.org/resource/Islamic_State\"}, {\"begin\": 751, \"end\": 759, \"title\": \"http://dbpedia.org/resource/Al-Qaeda\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"al-Qaida\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Al-Qaeda\", \"dbpedia\": \"http://dbpedia.org/resource/Al-Qaeda\"}, {\"begin\": 774, \"end\": 780, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9994304591821124, \"rank\": 0.00043086501367833586, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"Terrorists\", \"from\": 679, \"to\": 689}, {\"ngram\": \"violent extremists\", \"from\": 694, \"to\": 712}, {\"ngram\": \"neighboring European countries\", \"from\": 785, \"to\": 815}, {\"ngram\": \"violent attacks\", \"from\": 868, \"to\": 883}, {\"ngram\": \"the Paris Olympics\", \"from\": 894, \"to\": 912}, {\"ngram\": \"the report\", \"from\": 915, \"to\": 925}]}, {\"sentence\": \"\\\"Though extensive security infrastructure in place for the event will make a successful mass-casualty attack very unlikely.\\\"\", \"from\": 933, \"to\": 1057, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"extensive security infrastructure\", \"from\": 941, \"to\": 974}, {\"ngram\": \"place\", \"from\": 978, \"to\": 983}, {\"ngram\": \"the event\", \"from\": 988, \"to\": 997}, {\"ngram\": \"a successful mass-casualty attack\", \"from\": 1008, \"to\": 1041}]}, {\"sentence\": \"The warning from Insikt Group comes as French authorities have already announced the disruption of at least two terror plots targeting the upcoming Games.\", \"from\": 1059, \"to\": 1213, \"entities\": [{\"begin\": 1098, \"end\": 1104, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9882522558998798, \"rank\": 0.006325976812826897, \"text\": \"French\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"The warning\", \"from\": 1059, \"to\": 1070}, {\"ngram\": \"Insikt Group\", \"from\": 1076, \"to\": 1088}, {\"ngram\": \"the disruption\", \"from\": 1140, \"to\": 1154}, {\"ngram\": \"at least two terror plots\", \"from\": 1158, \"to\": 1183}, {\"ngram\": \"the upcoming Games\", \"from\": 1194, \"to\": 1212}]}, {\"sentence\": \"In late April, French anti-terrorism forces arrested a 16-year-old from the town of Marignier after he announced on social media that he planned to build an explosive belt and die as a suicide bomber at an Olympic venue.\", \"from\": 1215, \"to\": 1435, \"entities\": [{\"begin\": 1230, \"end\": 1236, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9882522558998798, \"rank\": 0.006325976812826897, \"text\": \"French\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 1299, \"end\": 1308, \"title\": \"http://dbpedia.org/resource/Marignier\", \"score\": 0.9999999962046786, \"rank\": 0.0, \"text\": \"Marignier\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Marignier\", \"dbpedia\": \"http://dbpedia.org/resource/Marignier\"}], \"noun_phrases\": [{\"ngram\": \"late April\", \"from\": 1218, \"to\": 1228}, {\"ngram\": \"the town\", \"from\": 1287, \"to\": 1295}, {\"ngram\": \"social media\", \"from\": 1331, \"to\": 1343}, {\"ngram\": \"an explosive belt\", \"from\": 1369, \"to\": 1386}, {\"ngram\": \"a suicide bomber\", \"from\": 1398, \"to\": 1414}, {\"ngram\": \"an Olympic venue\", \"from\": 1418, \"to\": 1434}]}, {\"sentence\": \"And just last week, French security officials arrested an 18-year-old, charging him of planning an attack in the name of IS at the Geoffroy-Guichard Stadium in Saint-Etienne.\", \"from\": 1437, \"to\": 1611, \"entities\": [{\"begin\": 1457, \"end\": 1463, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9882522558998798, \"rank\": 0.006325976812826897, \"text\": \"French\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 1597, \"end\": 1610, \"title\": \"http://dbpedia.org/resource/Metz_Cathedral\", \"score\": 1.0, \"rank\": 2.2309235882693267e-18, \"text\": \"Saint-Etienne\", \"types\": [\"Q41176\", \"Q1370598\"], \"wikid\": \"http://dbpedia.org/resource/Metz_Cathedral\", \"dbpedia\": \"http://dbpedia.org/resource/Metz_Cathedral\"}], \"noun_phrases\": [{\"ngram\": \"an attack\", \"from\": 1533, \"to\": 1542}, {\"ngram\": \"the name\", \"from\": 1546, \"to\": 1554}, {\"ngram\": \"the Geoffroy-Guichard Stadium\", \"from\": 1564, \"to\": 1593}]}, {\"sentence\": \"Additionally, Insikt Group warns that IS has been pumping out propaganda, \\\"urging its supporters to recreate the November 2015 series of terrorist attacks in Paris that included a suicide bombing at the Stade de France - the main venue for the 2024 Paris Olympic Games.\\\"\", \"from\": 1613, \"to\": 1883, \"entities\": [{\"begin\": 1771, \"end\": 1776, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999904503, \"rank\": 9.342336455922179e-12, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Insikt Group\", \"from\": 1627, \"to\": 1639}, {\"ngram\": \"propaganda\", \"from\": 1675, \"to\": 1685}, {\"ngram\": \"its supporters\", \"from\": 1695, \"to\": 1709}, {\"ngram\": \"the November 2015 series\", \"from\": 1722, \"to\": 1746}, {\"ngram\": \"terrorist attacks\", \"from\": 1750, \"to\": 1767}, {\"ngram\": \"a suicide bombing\", \"from\": 1791, \"to\": 1808}, {\"ngram\": \"the Stade de France\", \"from\": 1812, \"to\": 1831}, {\"ngram\": \"the main venue\", \"from\": 1834, \"to\": 1848}, {\"ngram\": \"the 2024 Paris Olympic Games\", \"from\": 1853, \"to\": 1881}]}, {\"sentence\": \"And while there is no convincing evidence yet of any large-scale plot against the upcoming Olympics, the terror group has been inciting supporters across Western Europe to carry out attacks by leveraging connections through the internet and social media.\", \"from\": 1885, \"to\": 2139, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"no convincing evidence\", \"from\": 1904, \"to\": 1926}, {\"ngram\": \"any large-scale plot\", \"from\": 1934, \"to\": 1954}, {\"ngram\": \"the upcoming Olympics\", \"from\": 1963, \"to\": 1984}, {\"ngram\": \"the terror group\", \"from\": 1986, \"to\": 2002}, {\"ngram\": \"supporters\", \"from\": 2021, \"to\": 2031}, {\"ngram\": \"Western Europe\", \"from\": 2039, \"to\": 2053}, {\"ngram\": \"attacks\", \"from\": 2067, \"to\": 2074}, {\"ngram\": \"connections\", \"from\": 2089, \"to\": 2100}, {\"ngram\": \"the internet\", \"from\": 2109, \"to\": 2121}, {\"ngram\": \"social media\", \"from\": 2126, \"to\": 2138}]}, {\"sentence\": \"U.S. officials further warn the IS group's Afghan affiliate, known as IS-Khorasan or ISIS-K, has been building momentum from its deadly attacks on Kerman, Iran, in January and on a Moscow concert hall in March.\", \"from\": 2141, \"to\": 2351, \"entities\": [{\"begin\": 2184, \"end\": 2190, \"title\": \"http://dbpedia.org/resource/Afghanistan\", \"score\": 0.9999998907242176, \"rank\": 1.08628866152984e-07, \"text\": \"Afghan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Afghanistan\", \"dbpedia\": \"http://dbpedia.org/resource/Afghanistan\"}, {\"begin\": 2288, \"end\": 2294, \"title\": \"http://dbpedia.org/resource/Kerman\", \"score\": 0.99999999043348, \"rank\": 8.232158762035978e-09, \"text\": \"Kerman\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Kerman\", \"dbpedia\": \"http://dbpedia.org/resource/Kerman\"}, {\"begin\": 2296, \"end\": 2300, \"title\": \"http://dbpedia.org/resource/Iran\", \"score\": 0.9999999985957402, \"rank\": 1.4036965240926862e-09, \"text\": \"Iran\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Iran\", \"dbpedia\": \"http://dbpedia.org/resource/Iran\"}, {\"begin\": 2322, \"end\": 2328, \"title\": \"http://dbpedia.org/resource/Moscow\", \"score\": 0.9999999870651665, \"rank\": 9.420980134664429e-09, \"text\": \"Moscow\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Moscow\", \"dbpedia\": \"http://dbpedia.org/resource/Moscow\"}], \"noun_phrases\": [{\"ngram\": \"U.S. officials\", \"from\": 2141, \"to\": 2155}, {\"ngram\": \"IS-Khorasan\", \"from\": 2211, \"to\": 2222}, {\"ngram\": \"ISIS-K\", \"from\": 2226, \"to\": 2232}, {\"ngram\": \"momentum\", \"from\": 2252, \"to\": 2260}, {\"ngram\": \"its deadly attacks\", \"from\": 2266, \"to\": 2284}, {\"ngram\": \"January\", \"from\": 2305, \"to\": 2312}, {\"ngram\": \"March\", \"from\": 2345, \"to\": 2350}]}, {\"sentence\": \"\\\"We see the ISIS network sort of resettling after a period of disquiet,\\\" National Counterterrorism Center Director Christine Abizaid warned during a security forum last month in Doha.\", \"from\": 2353, \"to\": 2536, \"entities\": [{\"begin\": 2365, \"end\": 2369, \"title\": \"http://dbpedia.org/resource/Islamic_State\", \"score\": 1.0, \"rank\": 2.8563839525971983e-38, \"text\": \"ISIS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Islamic_State\", \"dbpedia\": \"http://dbpedia.org/resource/Islamic_State\"}, {\"begin\": 2468, \"end\": 2485, \"title\": \"http://dbpedia.org/resource/Christine_Abizaid\", \"score\": 0.9999981769468169, \"rank\": 0.0, \"text\": \"Christine Abizaid\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Christine_Abizaid\", \"dbpedia\": \"http://dbpedia.org/resource/Christine_Abizaid\"}, {\"begin\": 2531, \"end\": 2535, \"title\": \"http://dbpedia.org/resource/Doha\", \"score\": 1.0, \"rank\": 1.1210538113505218e-15, \"text\": \"Doha\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Doha\", \"dbpedia\": \"http://dbpedia.org/resource/Doha\"}], \"noun_phrases\": [{\"ngram\": \"a period\", \"from\": 2403, \"to\": 2411}, {\"ngram\": \"disquiet\", \"from\": 2415, \"to\": 2423}, {\"ngram\": \"a security forum\", \"from\": 2500, \"to\": 2516}]}, {\"sentence\": \"\\\"This ability of the global ISIS enterprise, even without territorial solidity, the ability to reach out virtually to a network of supporters, some of whom are going to conduct attacks, is quite concerning,\\\" she said, calling ISIS-K's ability to reestablish itself in Afghanistan \\\"probably the most significant additive capability we have seen to the global ISIS network in the last three years.\\\"\", \"from\": 2538, \"to\": 2934, \"entities\": [{\"begin\": 2566, \"end\": 2570, \"title\": \"http://dbpedia.org/resource/Islamic_State\", \"score\": 1.0, \"rank\": 2.8563839525971983e-38, \"text\": \"ISIS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Islamic_State\", \"dbpedia\": \"http://dbpedia.org/resource/Islamic_State\"}, {\"begin\": 2764, \"end\": 2770, \"title\": \"http://dbpedia.org/resource/Islamic_State_\\u2013_Khorasan_Province\", \"score\": 0.9965712144988736, \"rank\": 0.0, \"text\": \"ISIS-K\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Islamic_State_\\u2013_Khorasan_Province\", \"dbpedia\": \"http://dbpedia.org/resource/Islamic_State_\\u2013_Khorasan_Province\"}, {\"begin\": 2806, \"end\": 2817, \"title\": \"http://dbpedia.org/resource/Afghanistan\", \"score\": 0.6292017917357884, \"rank\": 0.5893152453361593, \"text\": \"Afghanistan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Afghanistan\", \"dbpedia\": \"http://dbpedia.org/resource/Afghanistan\"}, {\"begin\": 2896, \"end\": 2900, \"title\": \"http://dbpedia.org/resource/Islamic_State\", \"score\": 1.0, \"rank\": 2.8563839525971983e-38, \"text\": \"ISIS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Islamic_State\", \"dbpedia\": \"http://dbpedia.org/resource/Islamic_State\"}], \"noun_phrases\": [{\"ngram\": \"This ability\", \"from\": 2539, \"to\": 2551}, {\"ngram\": \"territorial solidity\", \"from\": 2596, \"to\": 2616}, {\"ngram\": \"the ability\", \"from\": 2618, \"to\": 2629}, {\"ngram\": \"a network\", \"from\": 2656, \"to\": 2665}, {\"ngram\": \"supporters\", \"from\": 2669, \"to\": 2679}, {\"ngram\": \"attacks\", \"from\": 2715, \"to\": 2722}, {\"ngram\": \"probably the most significant additive capability\", \"from\": 2819, \"to\": 2868}, {\"ngram\": \"the last three years\", \"from\": 2912, \"to\": 2932}]}, {\"sentence\": \"There are also concerns that other extremists could be motivated by the ongoing war in Gaza between Israel and Hamas, a U.S. designated terror group that has controlled Gaza since 2006.\", \"from\": 2936, \"to\": 3121, \"entities\": [{\"begin\": 3023, \"end\": 3027, \"title\": \"http://dbpedia.org/resource/Gaza_Strip\", \"score\": 0.9999320108235015, \"rank\": 6.799379953012909e-05, \"text\": \"Gaza\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Gaza_Strip\", \"dbpedia\": \"http://dbpedia.org/resource/Gaza_Strip\"}, {\"begin\": 3036, \"end\": 3042, \"title\": \"http://dbpedia.org/resource/Israel\", \"score\": 1.0, \"rank\": 1.5732604714409188e-20, \"text\": \"Israel\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Israel\", \"dbpedia\": \"http://dbpedia.org/resource/Israel\"}, {\"begin\": 3047, \"end\": 3052, \"title\": \"http://dbpedia.org/resource/Hamas\", \"score\": 1.0, \"rank\": 1.1224335004646221e-23, \"text\": \"Hamas\", \"types\": [\"Q7278\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Hamas\", \"dbpedia\": \"http://dbpedia.org/resource/Hamas\"}, {\"begin\": 3105, \"end\": 3109, \"title\": \"http://dbpedia.org/resource/Gaza_Strip\", \"score\": 0.9999320108235015, \"rank\": 6.799379953012909e-05, \"text\": \"Gaza\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Gaza_Strip\", \"dbpedia\": \"http://dbpedia.org/resource/Gaza_Strip\"}], \"noun_phrases\": [{\"ngram\": \"concerns\", \"from\": 2951, \"to\": 2959}, {\"ngram\": \"other extremists\", \"from\": 2965, \"to\": 2981}, {\"ngram\": \"the ongoing war\", \"from\": 3004, \"to\": 3019}, {\"ngram\": \"a U.S. designated terror group\", \"from\": 3054, \"to\": 3084}]}, {\"sentence\": \"Tuesday's report by Insikt Group calls potential attacks targeting Israelis or Americans due to the war in Gaza \\\"very unlikely but within the realm of possibility.\\\"\", \"from\": 3123, \"to\": 3287, \"entities\": [{\"begin\": 3190, \"end\": 3198, \"title\": \"http://dbpedia.org/resource/Israelis\", \"score\": 1.0, \"rank\": 7.008426852579086e-15, \"text\": \"Israelis\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Israelis\", \"dbpedia\": \"http://dbpedia.org/resource/Israelis\"}, {\"begin\": 3230, \"end\": 3234, \"title\": \"http://dbpedia.org/resource/Gaza_Strip\", \"score\": 0.9999320108235015, \"rank\": 6.799379953012909e-05, \"text\": \"Gaza\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Gaza_Strip\", \"dbpedia\": \"http://dbpedia.org/resource/Gaza_Strip\"}], \"noun_phrases\": [{\"ngram\": \"Tuesday's report\", \"from\": 3123, \"to\": 3139}, {\"ngram\": \"Insikt Group\", \"from\": 3143, \"to\": 3155}, {\"ngram\": \"potential attacks\", \"from\": 3162, \"to\": 3179}, {\"ngram\": \"Americans\", \"from\": 3202, \"to\": 3211}, {\"ngram\": \"the war\", \"from\": 3219, \"to\": 3226}, {\"ngram\": \"the realm\", \"from\": 3261, \"to\": 3270}, {\"ngram\": \"possibility\", \"from\": 3274, \"to\": 3285}]}, {\"sentence\": \"Groups con