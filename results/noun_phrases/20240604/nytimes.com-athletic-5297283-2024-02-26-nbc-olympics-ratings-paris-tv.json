om\": 9639, \"to\": 9757, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the best things\", \"from\": 9646, \"to\": 9661}, {\"ngram\": \"someone\", \"from\": 9680, \"to\": 9687}, {\"ngram\": \"sports media\", \"from\": 9691, \"to\": 9703}]}, {\"sentence\": \"If you are reading this column, there is a significant likelihood that you have heard of Peter King, the iconic NFL writer who covered the league for 40 years and announced on Monday thathe was stepping away from his job.\", \"from\": 9758, \"to\": 9979, \"entities\": [{\"begin\": 9847, \"end\": 9857, \"title\": \"http://dbpedia.org/resource/Peter_T._King\", \"score\": 1.0, \"rank\": 3.0644089267991123e-42, \"text\": \"Peter King\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Peter_T._King\", \"dbpedia\": \"http://dbpedia.org/resource/Peter_T._King\"}, {\"begin\": 9870, \"end\": 9873, \"title\": \"http://dbpedia.org/resource/NFL_on_CBS\", \"score\": 0.932364463845994, \"rank\": 0.06856973113558865, \"text\": \"NFL\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/NFL_on_CBS\", \"dbpedia\": \"http://dbpedia.org/resource/NFL_on_CBS\"}], \"noun_phrases\": [{\"ngram\": \"this column\", \"from\": 9777, \"to\": 9788}, {\"ngram\": \"a significant likelihood\", \"from\": 9799, \"to\": 9823}, {\"ngram\": \"the league\", \"from\": 9893, \"to\": 9903}, {\"ngram\": \"40 years\", \"from\": 9908, \"to\": 9916}, {\"ngram\": \"Monday\", \"from\": 9934, \"to\": 9940}, {\"ngram\": \"thathe\", \"from\": 9941, \"to\": 9947}, {\"ngram\": \"his job\", \"from\": 9971, \"to\": 9978}]}, {\"sentence\": \"What some of you do not know is how impactful King has been on the professional lives of many of the people you read today.\", \"from\": 9980, \"to\": 10103, \"entities\": [{\"begin\": 10026, \"end\": 10030, \"title\": \"http://dbpedia.org/resource/Monarch\", \"score\": 0.8947778184404, \"rank\": 0.05871029473808811, \"text\": \"King\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Monarch\", \"dbpedia\": \"http://dbpedia.org/resource/Monarch\"}], \"noun_phrases\": [{\"ngram\": \"the professional lives\", \"from\": 10043, \"to\": 10065}, {\"ngram\": \"the people\", \"from\": 10077, \"to\": 10087}]}, {\"sentence\": \"When King was at the height of his popularity at Sports Illustrated, where I was fortunate to work alongside him,he used his fame in 2013to launch a standalone football website, The MMQB.\", \"from\": 10105, \"to\": 10292, \"entities\": [{\"begin\": 10110, \"end\": 10114, \"title\": \"http://dbpedia.org/resource/Monarch\", \"score\": 0.8947778184404, \"rank\": 0.05871029473808811, \"text\": \"King\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Monarch\", \"dbpedia\": \"http://dbpedia.org/resource/Monarch\"}, {\"begin\": 10154, \"end\": 10172, \"title\": \"http://dbpedia.org/resource/Sports_Illustrated\", \"score\": 1.0, \"rank\": 5.414261304700702e-60, \"text\": \"Sports Illustrated\", \"types\": [\"Q41298\", \"Q386724\", \"Q234460\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/Sports_Illustrated\", \"dbpedia\": \"http://dbpedia.org/resource/Sports_Illustrated\"}], \"noun_phrases\": [{\"ngram\": \"the height\", \"from\": 10122, \"to\": 10132}, {\"ngram\": \"his popularity\", \"from\": 10136, \"to\": 10150}, {\"ngram\": \"his fame\", \"from\": 10226, \"to\": 10234}, {\"ngram\": \"2013to launch\", \"from\": 10238, \"to\": 10251}, {\"ngram\": \"a standalone football website\", \"from\": 10252, \"to\": 10281}, {\"ngram\": \"The MMQB\", \"from\": 10283, \"to\": 10291}]}, {\"sentence\": \"There were more talented writers at SI at the time, but no other staffer had his popularity (or web traffic), and by understanding the leverage he had, he became a sports digital trailblazer.\", \"from\": 10293, \"to\": 10484, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"more talented writers\", \"from\": 10304, \"to\": 10325}, {\"ngram\": \"SI\", \"from\": 10329, \"to\