 \"noun_phrases\": [{\"ngram\": \"(KF\", \"from\": 14456, \"to\": 14459}, {\"ngram\": \"The opening week\", \"from\": 14461, \"to\": 14477}, {\"ngram\": \"place\", \"from\": 14536, \"to\": 14541}, {\"ngram\": \"Red Bull-Bora-Hansgrohe\", \"from\": 14546, \"to\": 14569}, {\"ngram\": \"racing\", \"from\": 14604, \"to\": 14610}, {\"ngram\": \"the red jersey\", \"from\": 14654, \"to\": 14668}, {\"ngram\": \"stage\", \"from\": 14672, \"to\": 14677}]}, {\"sentence\": \"That was until, in their directeur sportif Patxi Vila's words,\\\"things got out of hand.\\\"\", \"from\": 14687, \"to\": 14774, \"entities\": [{\"begin\": 14730, \"end\": 14740, \"title\": \"http://dbpedia.org/resource/Patxi_Vila\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Patxi Vila\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Patxi_Vila\", \"dbpedia\": \"http://dbpedia.org/resource/Patxi_Vila\"}], \"noun_phrases\": [{\"ngram\": \"their directeur\", \"from\": 14706, \"to\": 14721}, {\"ngram\": \"hand\", \"from\": 14768, \"to\": 14772}]}, {\"sentence\": \"'Things' specifically being Ben O'Connor, with the Australian putting six minutes into GC rivals on stage six after soloing to victory from the break.\", \"from\": 14776, \"to\": 14926, \"entities\": [{\"begin\": 14804, \"end\": 14816, \"title\": \"http://dbpedia.org/resource/Ben_O'Connor_(hurler)\", \"score\": 0.910513111011931, \"rank\": 0.08169533169529136, \"text\": \"Ben O'Connor\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Ben_O'Connor_(hurler)\", \"dbpedia\": \"http://dbpedia.org/resource/Ben_O'Connor_(hurler)\"}, {\"begin\": 14827, \"end\": 14837, \"title\": \"http://dbpedia.org/resource/Australia_national_cricket_team\", \"score\": 0.9999999633328123, \"rank\": 2.3914090127359418e-08, \"text\": \"Australian\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/Australia_national_cricket_team\