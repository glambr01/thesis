edia.org/resource/Grand_Tour\", \"score\": 1.0, \"rank\": 5.207167636990729e-14, \"text\": \"Grand Tour\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Grand_Tour\", \"dbpedia\": \"http://dbpedia.org/resource/Grand_Tour\"}], \"noun_phrases\": [{\"ngram\": \"O'Connor\", \"from\": 15395, \"to\": 15403}, {\"ngram\": \"second place\", \"from\": 15416, \"to\": 15428}, {\"ngram\": \"the result\", \"from\": 15441, \"to\": 15451}, {\"ngram\": \"first podium\", \"from\": 15493, \"to\": 15505}, {\"ngram\": \"a bit\", \"from\": 15511, \"to\": 15516}, {\"ngram\": \"a dream\", \"from\": 15520, \"to\": 15527}, {\"ngram\": \"such an amazing thing\", \"from\": 15575, \"to\": 15596}]}, {\"sentence\": \"Three weeks later, he'd add a road race World Championships runner-up spot to his palmar\\u00e8s too, to cap off his best season to date.\", \"from\": 15600, \"to\": 15731, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a road race\", \"from\": 15628, \"to\": 15639}, {\"ngram\": \"World Championships runner-up spot\", \"from\": 15640, \"to\": 15674}, {\"ngram\": \"his palmar\\u00e8s\", \"from\": 15678, \"to\": 15690}, {\"ngram\": \"his best season\", \"from\": 15707, \"to\": 15722}, {\"ngram\": \"date\", \"from\": 15726, \"to\": 15730}]}, {\"sentence\": \"The Perth native played his role in the chasing group to perfection, behind an unassailable Tadej Poga\\u010dar.\", \"from\": 15733, \"to\": 15839, \"entities\": [{\"begin\": 15737, \"end\": 15742, \"title\": \"http://dbpedia.org/resource/Perth\", \"score\": 1.0, \"rank\": 2.0107589044274236e-15, \"text\": \"Perth\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Perth\", \"dbpedia\": \"http://dbpedia.org/resource/Perth\"}, {\"begin\": 15825, \"end\": 15838, \"title\": \"http://dbpedia.org/resource/Tadej_Poga\\u010dar\", \"score\": 0.9999999996089173, \"rank\": 0.0, \"text\": \"Tadej Poga\\u010dar\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/re