\": 2712, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the end\", \"from\": 2581, \"to\": 2588}, {\"ngram\": \"this series\", \"from\": 2592, \"to\": 2603}, {\"ngram\": \"the eight kiters\", \"from\": 2646, \"to\": 2662}, {\"ngram\": \"the semi\", \"from\": 2696, \"to\": 2704}, {\"ngram\": \"finals\", \"from\": 2705, \"to\": 2711}]}, {\"sentence\": \"In the semi-finals, explains the International Kiteboarding Association, the goal is to pick up three race wins.\", \"from\": 2714, \"to\": 2826, \"entities\": [{\"begin\": 2747, \"end\": 2785, \"title\": \"http://dbpedia.org/resource/International_Kiteboarding_Association\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Kiteboarding Association\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Kiteboarding_Association\", \"dbpedia\": \"http://dbpedia.org/resource/International_Kiteboarding_Association\"}], \"noun_phrases\": [{\"ngram\": \"the semi\", \"from\": 2717, \"to\": 2725}, {\"ngram\": \"finals\", \"from\": 2726, \"to\": 2732}, {\"ngram\": \"the goal\", \"from\": 2787, \"to\": 2795}, {\"ngram\": \"three race wins\", \"from\": 2810, \"to\": 2825}]}, {\"sentence\": \"The higher-ranked in each semi-final carries over two race wins, while the second in each carries over one race win.\", \"from\": 2827, \"to\": 2943, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"each semi-final carries\", \"from\": 2848, \"to\": 2871}, {\"ngram\": \"over two race wins\", \"from\": 2872, \"to\": 2890}, {\"ngram\": \"over one race win\", \"from\": 2925, \"to\": 2942}]}, {\"sentence\": \"The final can be anywhere from a single race to six.\", \"from\": 2945, \"to\": 2997, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a single race\", \"from\": 2976, \"to\": 2989}]}, {\"sentence\": \"This is because the leader from the opening starts with two race wins, with the kiteboarder in second has one.\", \"from\": 2999, \"to\": 3109, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the leader\", \"from\": 3015, \"to\": 3025}, {\"ngram\": \"the opening\", \"from\": 3031, \"to\": 3042}, {\"ngram\": \"two race wins\", \"from\": 3055, \"to\": 3068}, {\"ngram\": \"the kiteboarder\", \"from\": 3075, \"to\": 3090}, {\"ngram\": \"second\", \"from\": 3094, \"to\": 3100}]}, {\"sentence\": \"The goal is to secure three race wins, with the competition ending as soon as one of the athletes achieves this.\", \"from\": 3110, \"to\": 3222, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The goal\", \"from\": 3110, \"to\": 3118}, {\"ngram\": \"three race wins\", \"from\": 3132, \"to\": 3147}, {\"ngram\": \"the competition\", \"from\": 3154, \"to\": 3169}, {\"ngram\": \"the athletes\", \"from\": 3195, \"to\": 3207}]}]}"