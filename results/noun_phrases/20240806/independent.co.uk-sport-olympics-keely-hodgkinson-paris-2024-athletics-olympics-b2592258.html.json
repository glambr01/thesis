n honour\", \"from\": 422, \"to\": 431}, {\"ngram\": \"her coach\", \"from\": 436, \"to\": 445}, {\"ngram\": \"a \\\"superstar\", \"from\": 457, \"to\": 469}, {\"ngram\": \"golden girl status\", \"from\": 495, \"to\": 513}]}, {\"sentence\": \"The 22-year-oldbecame an Olympic champion in the women's 800 metresin Paris on Monday evening, shrugging off the weight of enormous expectations to claim the gold.\", \"from\": 517, \"to\": 680, \"entities\": [{\"begin\": 587, \"end\": 592, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999997612576, \"rank\": 2.389470994412807e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"The 22-year-oldbecame\", \"from\": 517, \"to\": 538}, {\"ngram\": \"an Olympic champion\", \"from\": 539, \"to\": 558}, {\"ngram\": \"Monday evening\", \"from\": 596, \"to\": 610}, {\"ngram\": \"the weight\", \"from\": 626, \"to\": 636}, {\"ngram\": \"enormous expectations\", \"from\": 640, \"to\": 661}, {\"ngram\": \"the gold\", \"from\": 671, \"to\": 679}]}, {\"sentence\": \"It makes her the first British woman to claim Olympic 800-metre gold since DameKelly Holmesin Athens in 2004, and the third going back to Ann Packer in 1964.\", \"from\": 682, \"to\": 839, \"entities\": [{\"begin\": 820, \"end\": 830, \"title\": \"http://dbpedia.org/resource/Ann_Packer\", \"score\": 1.0, \"rank\": 6.5359858553975735e-31, \"text\": \"Ann Packer\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Ann_Packer\", \"dbpedia\": \"http://dbpedia.org/resource/Ann_Packer\"}], \"noun_phrases\": [{\"ngram\": \"Olympic 800-metre gold\", \"from\": 728, \"to\": 750}, {\"ngram\": \"DameKelly Holmesin Athens\", \"from\": 757, \"to\": 782}]}, {\"sentence\": \"On TuesdayTeam GBfought for more medals, with silver forJosh Kerrin the men's 1500 metres and silver at the velodrome for cyclists Jack Carlin, Ed Lowe and Hamish Turnbull in the men's team sprint.\", \"from\": 841, \"to\": 1038, \"entities\": [{\"begin\": 902, \"end\": 908, \"title\": \"http://dbpedia.org/resource/British_National_Keirin_Championships\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Kerrin\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/British_National_Keirin_Championships\", \"dbpedia\": \"http://dbpedia.org/resource/British_National_Keirin_Championships\"}, {\"begin\": 972, \"end\": 976, \"title\": \"http://dbpedia.org/resource/Jack_Shephard\", \"score\": 0.9982227858285151, \"rank\": 0.001479056752322772, \"text\": \"Jack\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Jack_Shephard\", \"dbpedia\": \"http://dbpedia.org/resource/Jack_Shephard\"}, {\"begin\": 977, \"end\": 983, \"title\": \"http://dbpedia.org/resource/George_Carlin\", \"score\": 0.9999999796864361, \"rank\": 2.031349438779647e-08, \"text\": \"Carlin\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/George_Carlin\", \"dbpedia\": \"http://dbpedia.org/resource/George_Carlin\"}, {\"begin\": 985, \"end\": 992, \"title\": \"http://dbpedia.org/resource/Ed_Lowe_(businessman)\", \"score\": 0.7159090621732908, \"rank\": 0.39682539682535223, \"text\": \"Ed Lowe\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ed_Lowe_(businessman)\", \"dbpedia\": \"http://dbpedia.org/resource/Ed_Lowe_(businessman)\"}, {\"begin\": 997, \"end\": 1012, \"title\": \"http://dbpedia.org/resource/Hamish_Turnbull\", \"score\": 0.9999996070519818, \"rank\": 0.0, \"text\": \"Hamish Turnbull\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Hamish_Turnbull\", \"dbpedia\": \"http://dbpedia.org/resource/Hamish_Turnbull\"}], \"noun_phrases\": [{\"ngram\": \"TuesdayTeam GBfought\", \"from\": 844, \"to\": 864}, {\"ngram\": \"more medals\", \"from\": 869, \"to\": 880}, {\"ngram\": \"silver\", \"from\": 887, \"to\": 893}, {\"ngram\": 