tities\": [], \"noun_phrases\": [{\"ngram\": \"\\u00e2\\u0080\\u009cdifferent energy systems\", \"from\": 359, \"to\": 386}, {\"ngram\": \"the 100,\\u00e2\\u0080\\u009d\", \"from\": 392, \"to\": 403}, {\"ngram\": \"more endurance work\", \"from\": 428, \"to\": 447}, {\"ngram\": \"training\", \"from\": 451, \"to\": 459}, {\"ngram\": \"speed\", \"from\": 464, \"to\": 469}]}, {\"sentence\": \"The 200 is precision.\", \"from\": 494, \"to\": 515, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"precision\", \"from\": 505, \"to\": 514}]}, {\"sentence\": \"It involves form, technique, horsepower and split-second decisions made at top speed.\", \"from\": 516, \"to\": 601, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"form, technique, horsepower and split-second decisions\", \"from\": 528, \"to\": 582}, {\"ngram\": \"top speed\", \"from\": 591, \"to\": 600}]}, {\"sentence\": \"The strategy can change depending on which lane a competitor is in.\", \"from\": 602, \"to\": 669, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The strategy\", \"from\": 602, \"to\": 614}, {\"ngram\": \"which lane\", \"from\": 639, \"to\": 649}, {\"ngram\": \"a competitor\", \"from\": 650, \"to\": 662}]}, {\"sentence\": \"The 200-meter race is part 100, part 400; brains and muscle equally important.\\u00c2 Before he broke the world record in the 200, Johnson primarily trained for the 400-meter run.\", \"from\": 670, \"to\": 844, \"entities\": [{\"begin\": 796, \"end\": 803, \"title\": \"http://dbpedia.org/resource/Lyndon_B._Johnson\", \"score\": 0.9998689349936742, \"rank\": 0.00012570664320421266, \"text\": \"Johnson\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Lyndon_B._Johnson\", \"dbpedia\": \"http://dbpedia.org/resource/Lyndon_B._Johnson\"}], \"noun_phrases\": [{\"ngram\": \"The 200-meter race\", \"from\": 670, \"to\": 688}, {\"ngram\": \"part\", \"from\": 692, \"to\": 696}, {\"ngram\": \"part\", \"from\": 702, \"to\":