rom\": 1865, \"to\": 1886}, {\"ngram\": \"silver\", \"from\": 1917, \"to\": 1923}]}, {\"sentence\": \"Khelif's eligibility was challenged only after she beat a Russian opponent to advance to the World Championship quarterfinal round in 2023.\", \"from\": 1934, \"to\": 2073, \"entities\": [{\"begin\": 1992, \"end\": 1999, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9995189940146, \"rank\": 0.000455436972625559, \"text\": \"Russian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}], \"noun_phrases\": [{\"ngram\": \"Khelif's eligibility\", \"from\": 1934, \"to\": 1954}, {\"ngram\": \"the World Championship quarterfinal round\", \"from\": 2023, \"to\": 2064}]}, {\"sentence\": \"The IBA was once recognized by the IOC as the official governing body for boxing - but that title wasrescindedin April 2023 following, among other things, allegations of corruption and ties toRussian money.\", \"from\": 2074, \"to\": 2280, \"entities\": [{\"begin\": 2078, \"end\": 2081, \"title\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\", \"score\": 0.9999919593124499, \"rank\": 8.040752591057154e-06, \"text\": \"IBA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\", \"dbpedia\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\"}, {\"begin\": 2109, \"end\": 2112, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 9.423962823393067e-40, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"the official governing body\", \"from\": 2116, \"to\": 2143}, {\"ngram\": \"boxing\", \"from\": 2148, \"to\": 2154}, {\"ngram\": \"that title\", \"from\": 2161, \"to\": 2171}, {\"ngram\": \"other things\", \"from\": 2215, \"to\": 2227}, {\"ngram\": \"corruption\", \"from\": 2244, \"to\": 2254}, {\"ngram\": \"toRussian money\", \"from\": 2264, \"to\": 2279}]}, {\"sentence\": \"As a result, the IOC, not the IBA, sets the rules for Olympic women's boxing.\", \"from\": 2281, \"to\": 2358, \"entities\": [{\"begin\": 2298, \"end\": 2301, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 9.423962823393067e-40, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 2311, \"end\": 2314, \"title\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\", \"score\": 0.9999919593124499, \"rank\": 8.040752591057154e-06, \"text\": \"IBA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\", \"dbpedia\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\"}], \"noun_phrases\": [{\"ngram\": \"a result\", \"from\": 2284, \"to\": 2292}, {\"ngram\": \"the rules\", \"from\": 2321, \"to\": 2330}, {\"ngram\": \"Olympic women's boxing\", \"from\": 2335, \"to\": 2357}]}, {\"sentence\": \"Khelif is an Algerian boxer who has competed, as a woman, at the international level for years.\", \"from\": 2360, \"to\": 2455, \"entities\": [{\"begin\": 2373, \"end\": 2381, \"title\": \"http://dbpedia.org/resource/Algeria\", \"score\": 0.9995820646932478, \"rank\": 0.0004178340803908443, \"text\": \"Algerian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Algeria\", \"dbpedia\": \"http://dbpedia.org/resource/Algeria\"}], \"noun_phrases\": [{\"ngram\": \"Khelif\", \"from\": 2360, \"to\": 2366}, {\"ngram\": \"a woman\", \"from\": 2409, \"to\": 2416}, {\"ngram\": \"the international level\", \"from\": 2421, \"to\": 2444}, {\"ngram\"