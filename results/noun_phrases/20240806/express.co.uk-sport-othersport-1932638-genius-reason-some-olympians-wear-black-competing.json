"{\"uid\": \"express.co.uk-sport-othersport-1932638-genius-reason-some-olympians-wear-black-competing\", \"noun_phrases\": [{\"sentence\": \"If you have been wondering why some athletes are choosing to wear all black at the ParisOlympics, then wonder no more.\", \"from\": 0, \"to\": 120, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"some athletes\", \"from\": 31, \"to\": 44}, {\"ngram\": \"the ParisOlympics\", \"from\": 79, \"to\": 96}]}, {\"sentence\": \"It's all down to Bandit Running, who are \\\"making waves\\\" with their subtle outfits which actually have a deeper meaning.\", \"from\": 122, \"to\": 241, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Bandit Running\", \"from\": 139, \"to\": 153}, {\"ngram\": \"waves\", \"from\": 171, \"to\": 176}, {\"ngram\": \"their subtle outfits\", \"from\": 183, \"to\": 203}, {\"ngram\": \"a deeper meaning\", \"from\": 224, \"to\": 240}]}, {\"sentence\": \"@JakeHeyenexplained on YouTube Shorts that often, athletes will \\\"dress head to toe in branded gear\\\" at Olympic trials - but the athletes choosing all black are doing so because of Bandit Running \\\"and their campaign, the Unsponsored Project.\\\"\", \"from\": 243, \"to\": 484, \"entities\": [{\"begin\": 266, \"end\": 280, \"title\": \"http://dbpedia.org/resource/YouTube_Shorts\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"YouTube Shorts\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/YouTube_Shorts\", \"dbpedia\": \"http://dbpedia.org/resource/YouTube_Shorts\"}], \"noun_phrases\": [{\"ngram\": \"athletes\", \"from\": 293, \"to\": 301}, {\"ngram\": \"head\", \"from\": 314, \"to\": 318}, {\"ngram\": \"toe\", \"from\": 322, \"to\": 325}, {\"ngram\": \"branded gear\", \"from\": 329, \"to\": 341}, {\"ngram\": \"Olympic trials\", \"from\": 346, \"to\": 360}, {\"ngram\": \"the athletes\", \"from\": 367, \"to\": 379}, {\"ngram\": \"their campaign\", \"from\": 443, \"to\": 457}, {\"ngram\": \"the Unsponsored Project\", \"from\": 459, \"to\": 482}]}, {\"s