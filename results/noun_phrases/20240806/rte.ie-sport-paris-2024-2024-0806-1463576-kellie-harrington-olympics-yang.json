}, {\"ngram\": \"the Asian Games\", \"from\": 1100, \"to\": 1115}, {\"ngram\": \"the Olympic Games\", \"from\": 1149, \"to\": 1166}]}, {\"sentence\": \"The Kildare man described Yang as a \\\"tall, southpaw, counterpuncher\\\" who uses her reach advantage against opponents.\", \"from\": 1170, \"to\": 1286, \"entities\": [{\"begin\": 1174, \"end\": 1181, \"title\": \"http://dbpedia.org/resource/Kildare_GAA\", \"score\": 0.9982558625692889, \"rank\": 0.001740973259241842, \"text\": \"Kildare\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Kildare_GAA\", \"dbpedia\": \"http://dbpedia.org/resource/Kildare_GAA\"}], \"noun_phrases\": [{\"ngram\": \"Yang\", \"from\": 1196, \"to\": 1200}, {\"ngram\": \"a \\\"tall, southpaw, counterpuncher\", \"from\": 1204, \"to\": 1237}, {\"ngram\": \"advantage\", \"from\": 1258, \"to\": 1267}, {\"ngram\": \"opponents\", \"from\": 1276, \"to\": 1285}]}, {\"sentence\": \"\\\"She's back with a bang and is going to be a difficult opponent.\", \"from\": 1288, \"to\": 1352, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a bang\", \"from\": 1305, \"to\": 1311}, {\"ngram\": \"a difficult opponent\", \"from\": 1331, \"to\": 1351}]}, {\"sentence\": \"She's 5'8\\\", she's a southpaw, so she's going to present a challenge,\\\" he said.\", \"from\": 1353, \"to\": 1431, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a southpaw\", \"from\": 1371, \"to\": 1381}, {\"ngram\": \"a challenge\", \"from\": 1409, \"to\": 1420}]}, {\"sentence\": \"However, Donovan believes Harrington has displayed in her previous fights that she has what it takes to come out on top once again.\", \"from\": 1433, \"to\": 1564, \"entities\": [{\"begin\": 1442, \"end\": 1449, \"title\": \"http://dbpedia.org/resource/Donovan\", \"score\": 0.9999987811234557, \"rank\": 1.1982022449297249e-06, \"text\": \"Donovan\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Donovan\", \"dbpedia\": \"http://dbpedia.org/resource/D