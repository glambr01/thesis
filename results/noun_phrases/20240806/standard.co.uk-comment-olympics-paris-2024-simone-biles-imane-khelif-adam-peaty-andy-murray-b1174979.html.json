"score\": 0.6654948171555344, \"rank\": 0.5026412988148469, \"text\": \"Britain\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"a tear\", \"from\": 3465, \"to\": 3471}, {\"ngram\": \"the two-time Olympic champion\", \"from\": 3481, \"to\": 3510}, {\"ngram\": \"three-time Grand Slam champion\", \"from\": 3512, \"to\": 3542}]}, {\"sentence\": \"\\\"Dreams do come true, if only we wish hard enough.\", \"from\": 3652, \"to\": 3702, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Dreams\", \"from\": 3653, \"to\": 3659}]}, {\"sentence\": \"You can have anything in life if you will sacrifice everything else for it,\\\" said JM Barrie.\", \"from\": 3703, \"to\": 3795, \"entities\": [{\"begin\": 3785, \"end\": 3794, \"title\": \"http://dbpedia.org/resource/J._M._Barrie\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"JM Barrie\", \"types\": [\"Q729\", \"Q5\", \"Q36180\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/J._M._Barrie\", \"dbpedia\": \"http://dbpedia.org/resource/J._M._Barrie\"}], \"noun_phrases\": [{\"ngram\": \"anything\", \"from\": 3716, \"to\": 3724}, {\"ngram\": \"life\", \"from\": 3728, \"to\": 3732}, {\"ngram\": \"everything\", \"from\": 3755, \"to\": 3765}]}, {\"sentence\": \"For me, that's what the Olympics celebrates.\", \"from\": 3797, \"to\": 3841, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the Olympics\", \"from\": 3817, \"to\": 3829}]}, {\"sentence\": \"The decision to dedicate everything in your entire life to that one three-minute swimming race.\", \"from\": 3842, \"to\": 3937, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The decision\", \"from\": 3842, \"to\": 3854}, {\"ngram\": \"everything\", \"from\": 3867, \"to\": 3877}, {\"ngram\": \"your entire life\", \"from\": 3881, \"to\": 3897}, {\"ngram\": \"that one three-minute swimming race\", \"from\": 3901, \"to\": 3936}]}, {\"sente