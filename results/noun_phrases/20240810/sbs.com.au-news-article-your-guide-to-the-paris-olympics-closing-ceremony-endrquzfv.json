50, \"to\": 365}, {\"ngram\": \"the River Seine\", \"from\": 378, \"to\": 393}, {\"ngram\": \"Getty/Quinn Rooney/Pool/AFP\", \"from\": 401, \"to\": 428}, {\"ngram\": \"the Paris 2024 Olympic Games\", \"from\": 468, \"to\": 496}, {\"ngram\": \"a close\", \"from\": 510, \"to\": 517}]}, {\"sentence\": \"More than 10,000 athletes representing 206 nations have competed in 32 sports during the Games, winning hundreds of medals and countless hearts along the way.\", \"from\": 521, \"to\": 679, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"More than 10,000 athletes\", \"from\": 521, \"to\": 546}, {\"ngram\": \"206 nations\", \"from\": 560, \"to\": 571}, {\"ngram\": \"32 sports\", \"from\": 589, \"to\": 598}, {\"ngram\": \"the Games\", \"from\": 606, \"to\": 615}, {\"ngram\": \"hundreds\", \"from\": 625, \"to\": 633}, {\"ngram\": \"medals\", \"from\": 637, \"to\": 643}, {\"ngram\": \"countless hearts\", \"from\": 648, \"to\": 664}, {\"ngram\": \"the way\", \"from\": 671, \"to\": 678}]}, {\"sentence\": \"For Australia, it's beena history-making Olympics, with the women and men in the green and gold breaking records and bringing home our largest-ever gold medal haul.\", \"from\": 681, \"to\": 845, \"entities\": [{\"begin\": 685, \"end\": 694, \"title\": \"http://dbpedia.org/resource/Australia\", \"score\": 0.9999157529643032, \"rank\": 8.425125498326251e-05, \"text\": \"Australia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Australia\", \"dbpedia\": \"http://dbpedia.org/resource/Australia\"}], \"noun_phrases\": [{\"ngram\": \"beena history-making Olympics\", \"from\": 701, \"to\": 730}, {\"ngram\": \"the women\", \"from\": 737, \"to\": 746}, {\"ngram\": \"men\", \"from\": 751, \"to\": 754}, {\"ngram\": \"the green and gold breaking records\", \"from\": 758, \"to\": 793}, {\"ngram\": \"our largest-ever gold medal haul\", \"from\": 812, \"to\": 844}]}, {\"sentence\": \"Here's what to expect at the closing ceremony.\", \"from\": 847, \"to\": 893, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the closing ceremony\", \"from\": 872, \"to\": 892}]}, {\"sentence\": \"The closing ceremony will start at 8pm (local time) on Sunday 11 August in Paris.\", \"from\": 895, \"to\": 976, \"entities\": [{\"begin\": 970, \"end\": 975, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 3.8995462716964885e-17, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"The closing ceremony\", \"from\": 895, \"to\": 915}, {\"ngram\": \"8pm\", \"from\": 930, \"to\": 933}, {\"ngram\": \"local time\", \"from\": 935, \"to\": 945}, {\"ngram\": \"Sunday\", \"from\": 950, \"to\": 956}, {\"ngram\": \"August\", \"from\": 960, \"to\": 966}]}, {\"sentence\": \"That means anyone in Australia wanting to watch it live will have to be up early on Monday 12 August: The Nine Network is the official Australian broadcaster of the Olympics, meaning you can watch the closing ceremony for free on Channel 9 and 9Gem.\", \"from\": 978, \"to\": 1228, \"entities\": [{\"begin\": 999, \"end\": 1008, \"title\": \"http://dbpedia.org/resource/Australia\", \"score\": 0.9999157529643032, \"rank\": 8.425125498326251e-05, \"text\": \"Australia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Australia\", \"dbpedia\": \"http://dbpedia.org/resource/Australia\"}, {\"begin\": 1081, \"end\": 1089, \"title\": \"http://dbpedia.org/resource/The_Nine_(TV_series)\", \"score\": 0.853699940391492, \"rank\": 0.1703629032258672, \"text\": \"The Nine\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/The_Nine_(TV_series)\", \"dbpedia\": \"http://dbpedia.org/resource/The_Nine_(TV_series)\"}, {\"begin\": 1085, \"end\": 1097, \"title\": \"http://dbpedia.org/resource/Nine_Network\", \"score\": 1.0, \"rank\": 5.320311939228004e-23, \"text\": \"Nine Network\", \"types\": [\"Q43229\", \"Q