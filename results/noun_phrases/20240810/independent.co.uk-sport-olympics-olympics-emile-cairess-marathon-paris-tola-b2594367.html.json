\"ngram\": \"bookmarks\", \"from\": 352, \"to\": 361}, {\"ngram\": \"offers\", \"from\": 395, \"to\": 401}, {\"ngram\": \"events\", \"from\": 403, \"to\": 409}, {\"ngram\": \"updates\", \"from\": 414, \"to\": 421}, {\"ngram\": \"The Independent\", \"from\": 427, \"to\": 442}]}, {\"sentence\": \"Read ourPrivacy notice \\\"That's nuts,\\\"Emile Cairessremarked afterfinishing fourth in the men's marathonat the ParisOlympics.\", \"from\": 448, \"to\": 572, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"ourPrivacy notice\", \"from\": 453, \"to\": 470}, {\"ngram\": \"the men's marathonat\", \"from\": 532, \"to\": 552}, {\"ngram\": \"the ParisOlympics\", \"from\": 553, \"to\": 570}]}, {\"sentence\": \"He was not talking about his own performance, but instead the new champion and gold medallist Tamirat Tola and, specifically, the Ethiopian's scorching splits.\", \"from\": 573, \"to\": 732, \"entities\": [{\"begin\": 667, \"end\": 679, \"title\": \"http://dbpedia.org/resource/Tamirat_Tola\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Tamirat Tola\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tamirat_Tola\", \"dbpedia\": \"http://dbpedia.org/resource/Tamirat_Tola\"}, {\"begin\": 703, \"end\": 712, \"title\": \"http://dbpedia.org/resource/Ethiopians\", \"score\": 0.9835278000610039, \"rank\": 0.016748077621765414, \"text\": \"Ethiopian\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Ethiopians\", \"dbpedia\": \"http://dbpedia.org/resource/Ethiopians\"}], \"noun_phrases\": [{\"ngram\": \"his own performance\", \"from\": 598, \"to\": 617}, {\"ngram\": \"instead the new champion\", \"from\": 623, \"to\": 647}, {\"ngram\": \"gold medallist\", \"from\": 652, \"to\": 666}]}, {\"sentence\": \"The 32-year-old stormed home on a sweltering day in Paris, clocking 2hr 6min 26sec thanks to a staggering second half of 61min 35sec to clinch a new Olympic record.\", \"from\": 733, \"to\": 897, \"entities\": [{\"begin\": 785, \"end\": 790, \"title\": \"htt