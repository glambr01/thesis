92}]}, {\"sentence\": \"Going into the Olympics final day, China led the U.S. in gold medals 39 to 38.\", \"from\": 896, \"to\": 974, \"entities\": [{\"begin\": 931, \"end\": 936, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.6423152505064272, \"rank\": 0.45973027441230235, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}], \"noun_phrases\": [{\"ngram\": \"the Olympics\", \"from\": 907, \"to\": 919}, {\"ngram\": \"the U.S.\", \"from\": 941, \"to\": 949}, {\"ngram\": \"gold medals\", \"from\": 953, \"to\": 964}]}, {\"sentence\": \"If McEwen accepted a tie for gold, the two superpowers would be even.\", \"from\": 975, \"to\": 1044, \"entities\": [{\"begin\": 978, \"end\": 984, \"title\": \"http://dbpedia.org/resource/Robbie_McEwen\", \"score\": 0.999999987066076, \"rank\": 1.2934003943511358e-08, \"text\": \"McEwen\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Robbie_McEwen\", \"dbpedia\": \"http://dbpedia.org/resource/Robbie_McEwen\"}], \"noun_phrases\": [{\"ngram\": \"a tie\", \"from\": 994, \"to\": 999}, {\"ngram\": \"gold\", \"from\": 1004, \"to\": 1008}, {\"ngram\": \"the two superpowers\", \"from\": 1010, \"to\": 1029}]}, {\"sentence\": \"At the Tokyo Olympics, a similar scenario played out and Mutaz Barshim of Qatar and Gianmarco Tamberi of Italy decided to accept the tie.\", \"from\": 1046, \"to\": 1183, \"entities\": [{\"begin\": 1103, \"end\": 1116, \"title\": \"http://dbpedia.org/resource/Mutaz_Essa_Barshim\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Mutaz Barshim\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Mutaz_Essa_Barshim\", \"dbpedia\": \"http://dbpedia.org/resource/Mutaz_Essa_Barshim\"}, {\"begin\": 1120, \"end\": 1125, \"title\": \"http://dbpedia.org/resource/Qatar\", \"score\": 0.9996430101346317, \"rank\": 0.00035709875544501