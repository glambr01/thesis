un_phrases\": [{\"ngram\": \"her love\", \"from\": 276, \"to\": 284}, {\"ngram\": \"the city\", \"from\": 305, \"to\": 313}, {\"ngram\": \"a \\\"never-give-up attitude\", \"from\": 323, \"to\": 348}, {\"ngram\": \"her first Olympic medal\", \"from\": 365, \"to\": 388}]}, {\"sentence\": \"The Liverpudlian took silver in the heptathlon on Friday inParis, coming second toBelgianrival Nafissatou Thiam.\", \"from\": 392, \"to\": 504, \"entities\": [{\"begin\": 396, \"end\": 408, \"title\": \"http://dbpedia.org/resource/Liverpool\", \"score\": 0.9999945848218169, \"rank\": 5.4152074264428744e-06, \"text\": \"Liverpudlian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Liverpool\", \"dbpedia\": \"http://dbpedia.org/resource/Liverpool\"}, {\"begin\": 487, \"end\": 503, \"title\": \"http://dbpedia.org/resource/Nafissatou_Thiam\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Nafissatou Thiam\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Nafissatou_Thiam\", \"dbpedia\": \"http://dbpedia.org/resource/Nafissatou_Thiam\"}], \"noun_phrases\": [{\"ngram\": \"silver\", \"from\": 414, \"to\": 420}, {\"ngram\": \"the heptathlon\", \"from\": 424, \"to\": 438}, {\"ngram\": \"Friday inParis\", \"from\": 442, \"to\": 456}]}, {\"sentence\": \"Johnson-Thompson, 31, on Saturday spoke about her love for Liverpool and how it shaped her as a person.\", \"from\": 506, \"to\": 609, \"entities\": [{\"begin\": 565, \"end\": 574, \"title\": \"http://dbpedia.org/resource/Liverpool_F.C.\", \"score\": 0.9999999976641902, \"rank\": 2.3341948566003174e-09, \"text\": \"Liverpool\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Liverpool_F.C.\", \"dbpedia\": \"http://dbpedia.org/resource/Liverpool_F.C.\"}], \"noun_phrases\": [{\"ngram\": \"Johnson-Thompson\", \"from\": 506, \"to\": 522}, {\"ngram\": \"Saturday\", \"from\": 531, \"to\": 539}, {\"ngram\": \"her love\", \"from\": 552, \"to\": 560}, {\"ngram\": \"a person\", \"from\": 600, \"to\": 608}]}, {\"sentence\": \"I love the people of Liverpool and I love what they stand for and that shapes my character, of that never-give-up attitude, and that underdog attitude and yes, it means the world Katarina Johnson-Thompson She said: \\\"Liverpool is my home, it always is my home even if I train and live elsewhere.\", \"from\": 611, \"to\": 907, \"entities\": [{\"begin\": 632, \"end\": 641, \"title\": \"http://dbpedia.org/resource/Liverpool_F.C.\", \"score\": 0.9999999976641902, \"rank\": 2.3341948566003174e-09, \"text\": \"Liverpool\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Liverpool_F.C.\", \"dbpedia\": \"http://dbpedia.org/resource/Liverpool_F.C.\"}, {\"begin\": 829, \"end\": 838, \"title\": \"http://dbpedia.org/resource/Liverpool_F.C.\", \"score\": 0.9999999976641902, \"rank\": 2.3341948566003174e-09, \"text\": \"Liverpool\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Liverpool_F.C.\", \"dbpedia\": \"http://dbpedia.org/resource/Liverpool_F.C.\"}], \"noun_phrases\": [{\"ngram\": \"the people\", \"from\": 618, \"to\": 628}, {\"ngram\": \"my character\", \"from\": 689, \"to\": 701}, {\"ngram\": \"that never-give-up attitude\", \"from\": 706, \"to\": 733}, {\"ngram\": \"the world\", \"from\": 780, \"to\": 789}, {\"ngram\": \"Katarina Johnson-Thompson\", \"from\": 790, \"to\": 815}, {\"ngram\": \"my home\", \"from\": 840, \"to\": 847}, {\"ngram\": \"my home\", \"from\": 862, \"to\": 869}]}, {\"sentence\": \"\\\"I love the people of Liverpool and I love what they stand for and that shapes my character, of that never-give-up attitude, and that underdog attitude and yes, it means the world.\", \"from\": 909, \"to\": 1089, \"entities\": [{\"begin\": 931, \"end\": 940, \"title\": \"http://dbpedia.org/resource/Liverpool_F.C.\", \"score\": 0.9999999976641902, \"rank\": 2.3341948566003174e-09, \"text\": \"Liverpool\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Liverpool_F.C.\", \"dbpedia\": \"http://dbpedia.org/resource/Liverpool_F.C.\"}], \"noun_phrases\": [{\"ngram\": \"the people\", \"from\": 917, \"to\": 927}, {\"ngram\": \"my character\", \"from\": 988, \"to\": 1000}, {\"ngram\": \"that never-give-up attitude\", \"from\": 1005, \"to\": 1032}, {\"ngram\": \"the world\", \"from\": 1079, \"to\": 1088}]}, {\"sentence\": \"\\\"I started my career at Liverpool Harriers and I am indebted to them as well.\\\"\", \"from\": 1091, \"to\": 1169, \"entities\": [{\"begin\": 1115, \"end\": 1124, \"title\": \"http://dbpedia.org/resource/Liverpool_F.C.\", \"score\": 0.9999999976641902, \"rank\": 2.3341948566003174e-09, \"text\": \"Liverpool\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Liverpool_F.C.\", \"dbpedia\": \"http://dbpedia.org/resource/Liverpool_F.C.\"}], \"noun_phrases\": [{\"ngram\": \"my career\", \"from\": 1102, \"to\": 1111}]}, {\"sentence\": \"Johnson-Thompson said the silver medal was \\\"a long time coming\\\".\", \"from\": 1171, \"to\": 1235, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Johnson-Thompson\", \"from\": 1171, \"to\": 1187}, {\"ngram\": \"the silver medal\", \"from\": 1193, \"to\": 1209}, {\"ngram\": \"a long time\", \"from\": 1215, \"to\": 1226}]}, {\"sentence\": \"\\\"It feels incredible that you know we got one over the line.\", \"from\": 1237, \"to\": 1297, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the line\", \"from\": 1288, \"to\": 1296}]}, {\"sentence\": \"It's been a long time coming, it's been a very short cycle but it's my fourthOlympicsand I am really happy to add that medal to my collection,\\\" she said.\", \"from\": 1298, \"to\": 1451, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a long time\", \"from\": 1308, \"to\": 1319}, {\"ngram\": \"a very short cycle\", \"from\": 1338, \"to\": 1356}, {\"ngram\": \"that medal\", \"from\": 1412, \"to\": 1422}, {\"ngram\": \"my collection\", \"from\": 1426, \"to\": 1439}]}, {\"sentence\": \"Johnson-Thompson said: \\\"I have got absolutely no regrets.\", \"from\": 1453, \"to\": 1510, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Johnson-Thompson\", \"from\": 1453, \"to\": 1469}, {\"ngram\": \"absolutely no regrets\", \"from\": 1488, \"to\": 1509}]}, {\"sentence\": \"I tried my absolute best and my best on that day was second place by about 30 points, so you know I was very close to an Olympic gold medal and to me that's just validated our team's belief that it was possible.\\\"\", \"from\": 1511, \"to\": 1723, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"that day\", \"from\": 1551, \"to\": 1559}, {\"ngram\": \"second place\", \"from\": 1564, \"to\": 1576}, {\"ngram\": \"about 30 points\", \"from\": 1580, \"to\": 1595}, {\"ngram\": \"an Olympic gold medal\", \"from\": 1629, \"to\": 1650}, {\"ngram\": \"our team's belief\", \"from\": 1683, \"to\": 1700}]}, {\"sentence\": \"Asked if there were times she doubted she would get there, she said: \\\"I have had doubts all the time, every athlete I feel like, even if they do not admit it, always has doubts - crippling doubts, but luckily I have got a team around me that has the belief in me that I sometimes do not have in myself, and that leads me to do great things and I am so grateful to them.\\\"\", \"from\": 1725, \"to\": 2095, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"times\", \"from\": 1745, \"to\": 1750}, {\"ngram\": \"doubts\", \"from\": 1806, \"to\": 1812}, {\"ngram\": \"doubts - crippling doubts\", \"from\": 1895, \"to\": 1920}, {\"ngram\": \"a team\", \"from\": 1945, \"to\": 1951}, {\"ngram\": \"the belief\", \"from\": 1971, \"to\": 1981}, {\"ngram\": \"great things\", \"from\": 2052, \"to\": 2064}]}, {\"sentence\": \"Asked about her plans for the future, she said: \\\"I feel like as long as I am competitive I will continue to do heptathlon.\", \"from\": 2097, \"to\": 2219, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her plans\", \"from\": 2109, \"to\": 2118}, {\"ngram\": \"the future\", \"from\": 2123, \"to\": 2133}, {\"ngram\": \"heptathlon\", \"from\": 2208, \"to\": 2218}]}, {\"sentence\": \"\\\"I am really happy that I am able to put together my heptathlon in a different way now and it's given me such longevity in the sport.\", \"from\": 2221, \"to\": 2354, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my heptathlon\", \"from\": 2271, \"to\": 2284}, {\"ngram\": \"a different way\", \"from\": 2288, \"to\": 2303}, {\"ngram\": \"such longevity\", \"from\": 2326, \"to\": 2340}, {\"ngram\": \"the sport\", \"from\": 2344, \"to\": 2353}]}, {\"sentence\": \"\\\"I am really really excited for the next couple of years.\\\"\", \"from\": 2356, \"to\": 2414, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the next couple\", \"from\": 2388, \"to\": 2403}, {\"ngram\": \"years\", \"from\": 2407, \"to\": 2412}]}, {\"sentence\": \"MORE ABOUT 1 Crime Fight breaks out on Elizabeth line train after youths told to stop vaping by middle-aged passenger Fight breaks out on Elizabeth line after youths told to stop vaping 2 Football Liverpool XI vs Brighton: Starting lineup, confirmed team news, injury latest for Premier League today Liverpool XI vs Brighton: Starting lineup and confirmed team news 3 UK Flights alert: UK issues global travel disruption warning over Donald Trump's Iran war Flights alert: UK issues global travel disruption warning on Iran war 4 Lifestyle Horoscope today: Your daily guide for Saturday, March 21, 2026 Horoscope today: Your daily guide for Saturday, March 21, 2026 5 Football Arsenal XI vs Man City: Confirmed team news, predicted lineup, injury latest for Carabao Cup final Arsenal XI vs Man City: Confirmed team news and predicted lineup\", \"from\": 2416, \"to\": 3276, \"entities\": [{\"begin\": 2458, \"end\": 2467, \"title\": \"http://dbpedia.org/resource/Elizabeth_II\", \"score\": 0.9254338665587827, \"rank\": 0.07573