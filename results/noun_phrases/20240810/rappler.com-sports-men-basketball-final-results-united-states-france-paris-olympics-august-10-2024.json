: [{\"ngram\": \"their incredible talent\", \"from\": 1222, \"to\": 1245}, {\"ngram\": \"the difference\", \"from\": 1268, \"to\": 1282}]}, {\"sentence\": \"\\\"It's a final against the Americans, in Paris, you can say it as much as you want, each player has his emotions, we tried to use them but it wasn't possible here.\\\"\", \"from\": 1319, \"to\": 1482, \"entities\": [{\"begin\": 1359, \"end\": 1364, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 5.788436892738256e-16, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"a final\", \"from\": 1325, \"to\": 1332}, {\"ngram\": \"the Americans\", \"from\": 1341, \"to\": 1354}, {\"ngram\": \"each player\", \"from\": 1402, \"to\": 1413}, {\"ngram\": \"his emotions\", \"from\": 1418, \"to\": 1430}]}, {\"sentence\": \"Steph Curry would finish with 24 points, all coming from three-pointers on an 8-of-12 clip, while a defiant, scowling James had 14 points, 10 assists, and 6 rebounds.\", \"from\": 1484, \"to\": 1650, \"entities\": [{\"begin\": 1484, \"end\": 1495, \"title\": \"http://dbpedia.org/resource/Stephen_Curry\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Steph Curry\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Stephen_Curry\", \"dbpedia\": \"http://dbpedia.org/resource/Stephen_Curry\"}, {\"begin\": 1602, \"end\": 1607, \"title\": \"http://dbpedia.org/resource/LeBron_James\", \"score\": 0.9999999979781933, \"rank\": 1.2833204132750089e-09, \"text\": \"James\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/LeBron_James\", \"dbpedia\": \"http://dbpedia.org/resource/LeBron_James\"}], \"noun_phrases\": [{\"ngram\": \"24 points\", \"from\": 1514, \"to\": 1523}, {\"ngram\": \"three-pointers\", \"from\": 1541, \"to\": 1555}, {\"ngram