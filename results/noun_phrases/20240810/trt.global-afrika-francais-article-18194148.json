: 165}, {\"ngram\": \"a \\u00e9t\\u00e9 couronn\\u00e9e championne apr\\u00e8s avoir battu\", \"from\": 167, \"to\": 211}, {\"ngram\": \"la Chinoise Yang Liu\", \"from\": 212, \"to\": 232}, {\"ngram\": \"5-0 dans\", \"from\": 233, \"to\": 241}, {\"ngram\": \"66 kg\", \"from\": 256, \"to\": 261}]}, {\"sentence\": \"La boxeuse alg\\u00e9rienne avait \\u00e9t\\u00e9 disqualifi\\u00e9e des Championnats du monde 2023 apr\\u00e8s avoir \\u00e9chou\\u00e9 \\u00e0 un test d'\\u00e9ligibilit\\u00e9 de genre.\", \"from\": 287, \"to\": 415, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"La\", \"from\": 287, \"to\": 289}, {\"ngram\": \"alg\\u00e9rienne avait \\u00e9t\\u00e9 disqualifi\\u00e9e des Championnats\", \"from\": 298, \"to\": 348}, {\"ngram\": \"2023 apr\\u00e8s avoir \\u00e9chou\\u00e9\", \"from\": 358, \"to\": 381}, {\"ngram\": \"\\u00e0 un test d'\\u00e9ligibilit\\u00e9 de genre\", \"from\": 382, \"to\": 414}]}, {\"sentence\": \"Il s'agit de la premi\\u00e8re m\\u00e9daille d'or de l'Alg\\u00e9rie en boxe f\\u00e9minine.\", \"from\": 417, \"to\": 486, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"de la\", \"from\": 427, \"to\": 432}, {\"ngram\": \"premi\\u00e8re\", \"from\": 433, \"to\": 441}]}, {\"sentence\": \"\\u00ab Je suis tr\\u00e8s heureuse.\", \"from\": 488, \"to\": 512, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"\\u00ab Je suis tr\\u00e8s heureuse\", \"from\": 488, \"to\": 511}]}, {\"sentence\": \"Depuis huit ans, c'est mon r\\u00eave et je suis maintenant championne olympique et m\\u00e9daill\\u00e9e d'or \\u00bb, a d\\u00e9clar\\u00e9 Khelif.\", \"from\": 513, \"to\": 626, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Depuis\", \"from\": 513, \"to\": 519}, {\"ngram\": \"ans\", \"from\": 525, \"to\": 528}, {\"ngram\": \"c'est mon r\\u00eave et je suis maintenant championne olympique\", \"from\": 530, \"to\": 587}, {\"ngram\": \"et m\\u00e9daill\\u00e9e d'or \\u00bb\", \"from\": 588, \"to\": 607}, {\"ngram\": \"a d\\u00e9clar\\u00e9 Kh