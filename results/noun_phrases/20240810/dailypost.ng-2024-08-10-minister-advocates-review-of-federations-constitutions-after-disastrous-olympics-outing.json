"{\"uid\": \"dailypost.ng-2024-08-10-minister-advocates-review-of-federations-constitutions-after-disastrous-olympics-outing\", \"noun_phrases\": [{\"sentence\": \"Published on By The Minister of Sports Development, John Enoh, has stated that there will be stiffer scrutiny of the constitutions governing Nigeria's sporting federations in advance of the forthcoming elections.\", \"from\": 0, \"to\": 215, \"entities\": [{\"begin\": 55, \"end\": 64, \"title\": \"http://dbpedia.org/resource/John_Owan_Enoh\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"John Enoh\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/John_Owan_Enoh\", \"dbpedia\": \"http://dbpedia.org/resource/John_Owan_Enoh\"}, {\"begin\": 144, \"end\": 151, \"title\": \"http://dbpedia.org/resource/Nigeria\", \"score\": 0.9999998339319656, \"rank\": 1.660636781805268e-07, \"text\": \"Nigeria\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Nigeria\", \"dbpedia\": \"http://dbpedia.org/resource/Nigeria\"}], \"noun_phrases\": [{\"ngram\": \"The Minister\", \"from\": 16, \"to\": 28}, {\"ngram\": \"Sports Development\", \"from\": 32, \"to\": 50}, {\"ngram\": \"stiffer scrutiny\", \"from\": 93, \"to\": 109}, {\"ngram\": \"the constitutions\", \"from\": 113, \"to\": 130}, {\"ngram\": \"advance\", \"from\": 175, \"to\": 182}, {\"ngram\": \"the forthcoming elections\", \"from\": 186, \"to\": 211}]}, {\"sentence\": \"This announcement follows Team Nigeria's disappointing performance at the 2024 Paris Olympics, where the country did not secure any medal.\", \"from\": 217, \"to\": 355, \"entities\": [{\"begin\": 248, \"end\": 255, \"title\": \"http://dbpedia.org/resource/Nigeria\", \"score\": 0.9999998339319656, \"rank\": 1.660636781805268e-07, \"text\": \"Nigeria\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Nigeria\", \"dbpedia\": \"http://dbpedia.org/resource/Nigeria\"}], \"noun_phrases\": [{\"ngram\": \"This announcement\", \"from\": 217, \"to\": 234}, {\"ngram\": \"the 2024 Paris Olympics\", \"from\": 287, \"to\": 310}, {\"ngram\": \"the country\", \"from\": 318, \"to\": 329}, {\"ngram\": \"any medal\", \"from\": 345, \"to\": 354}]}, {\"sentence\": \"Enoh, speaking from Paris, stated, \\\"We did everything as a Ministry to prepare the athletes adequately and provide them with every financial support, unfortunately the performance has not produced any podium finish.\", \"from\": 357, \"to\": 572, \"entities\": [{\"begin\": 377, \"end\": 382, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999594856577916, \"rank\": 4.051598363334018e-05, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Enoh\", \"from\": 357, \"to\": 361}, {\"ngram\": \"everything\", \"from\": 400, \"to\": 410}, {\"ngram\": \"a Ministry\", \"from\": 414, \"to\": 424}, {\"ngram\": \"the athletes\", \"from\": 436, \"to\": 448}, {\"ngram\": \"every financial support\", \"from\": 482, \"to\": 505}, {\"ngram\": \"the performance\", \"from\": 521, \"to\": 536}, {\"ngram\": \"any podium finish\", \"from\": 554, \"to\": 571}]}, {\"sentence\": \"\\\"As we go back home, we must do everything to prevent future occurrence of the Paris disaster and if this will entail the review of how people are elected to lead our sporting Federations, it will be done.\\\"\", \"from\": 574, \"to\": 780, \"entities\": [{\"begin\": 653, \"end\": 658, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999594856577916, \"rank\": 4.051598363334018e-05, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"everything\", \"from\": 606, \"to\": 616}, {\"ngram\": \"future occurrence\", \"from\": 628, \"to\": 645}, {\"ngram\": \"the review\", \"from\": 692, \"to\": 702}, {\"ngram\": \"people\", \"from\": 710, \"to\": 716}, {\"ngram\": \"our sporting Federations\", \"from\": 737, \"to\": 761}]}, {\"sentence\": \"This was disclosed in a statement by Diana-Mary Nsan, S.A. Media to the Minister, on Friday.\", \"from\": 782, \"to\": 874, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a statement\", \"from\": 804, \"to\": 815}, {\"ngram\": \"Diana-Mary Nsan\", \"from\": 819, \"to\": 834}, {\"ngram\": \"S.A. Media\", \"from\": 836, \"to\": 846}, {\"ngram\": \"the Minister\", \"from\": 850, \"to\": 862}, {\"ngram\": \"Friday\", \"from\": 867, \"to\": 873}]}, {\"sentence\": \"Emphasizing the importance of upcoming federations' elections, Enoh noted, \\\"I know that elections into the Federations are coming and it will be the perfect platform to get only those who have something to offer to lead the various sports.\\\"\", \"from\": 876, \"to\": 1116, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the importance\", \"from\": 888, \"to\": 902}, {\"ngram\": \"upcoming federations' elections\", \"from\": 906, \"to\": 937}, {\"ngram\": \"Enoh\", \"from\": 939, \"to\": 943}, {\"ngram\": \"elections\", \"from\": 964, \"to\": 973}, {\"ngram\": \"the Federations\", \"from\": 979, \"to\": 994}, {\"ngram\": \"the perfect platform\", \"from\": 1021, \"to\": 1041}, {\"ngram\": \"something\", \"from\": 1069, \"to\": 1078}, {\"ngram\": \"the various sports\", \"from\": 1096, \"to\": 1114}]}, {\"sentence\": \"Reflecting on the complexity of the elections, he added, \\\"I am aware that the Sports Federations Elections in Nigeria are even tougher than our National Elections and you will begin to ask yourself why is it so?\", \"from\": 1118, \"to\": 1329, \"entities\": [{\"begin\": 1228, \"end\": 1235, \"title\": \"http://dbpedia.org/resource/Nigeria\", \"score\": 0.9999998339319656, \"rank\": 1.660636781805268e-07, \"text\": \"Nigeria\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Nigeria\", \"dbpedia\": \"http://dbpedia.