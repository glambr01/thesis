"{\"uid\": \"salon.com-2024-08-10-sports-cheating-penalty-olympics\", \"noun_phrases\": [{\"sentence\": \"There is a competition with a longer history in the Olympics than almost any other sport: the race between cheaters and authorities to outsmart the other in the hopes of obtaining a prize, or safeguarding its dignity.\", \"from\": 0, \"to\": 217, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a competition\", \"from\": 9, \"to\": 22}, {\"ngram\": \"a longer history\", \"from\": 28, \"to\": 44}, {\"ngram\": \"the Olympics\", \"from\": 48, \"to\": 60}, {\"ngram\": \"almost any other sport\", \"from\": 66, \"to\": 88}, {\"ngram\": \"the race\", \"from\": 90, \"to\": 98}, {\"ngram\": \"cheaters\", \"from\": 107, \"to\": 115}, {\"ngram\": \"authorities\", \"from\": 120, \"to\": 131}, {\"ngram\": \"the hopes\", \"from\": 157, \"to\": 166}, {\"ngram\": \"a prize\", \"from\": 180, \"to\": 187}, {\"ngram\": \"its dignity\", \"from\": 205, \"to\": 216}]}, {\"sentence\": \"The 2024 Summer Olympics in Paris, the latest flashpoint, has featured familiar controversies like reports of doping by 23 Chinese swimmers, but also some more innovative tactics, such as the alleged use of drones by the Canadian women's soccer team staff to spy on their rivals' practice sessions.\", \"from\": 218, \"to\": 516, \"entities\": [{\"begin\": 246, \"end\": 251, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 4.913450015278001e-19, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 341, \"end\": 348, \"title\": \"http://dbpedia.org/resource/Chinese_language\", \"score\": 0.7889033626853789, \"rank\": 0.2675695583479561, \"text\": \"Chinese\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Chinese_language\", \"dbpedia\": \"http://dbpedia.org/resource/Chinese_language\"}, {\"begin\": 439, \"end\": 447, \"title\": \"http://dbpedia.org/res