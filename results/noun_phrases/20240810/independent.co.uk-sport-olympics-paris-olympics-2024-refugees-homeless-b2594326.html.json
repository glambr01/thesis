], \"noun_phrases\": [{\"ngram\": \"people\", \"from\": 11915, \"to\": 11921}]}, {\"sentence\": \"We hear about a war or a coup, and soon they come.\", \"from\": 11946, \"to\": 11996, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a war\", \"from\": 11960, \"to\": 11965}, {\"ngram\": \"a coup\", \"from\": 11969, \"to\": 11975}]}, {\"sentence\": \"It is like the crossroads of the world.\\\"\", \"from\": 11997, \"to\": 12037, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the crossroads\", \"from\": 12008, \"to\": 12022}, {\"ngram\": \"the world\", \"from\": 12026, \"to\": 12035}]}, {\"sentence\": \"That is how the Olympics sees itself, too.\", \"from\": 12039, \"to\": 12081, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the Olympics\", \"from\": 12051, \"to\": 12063}]}, {\"sentence\": \"\\\"Games wide open,\\\" says the slogan for Paris 2024.\", \"from\": 12082, \"to\": 12132, \"entities\": [{\"begin\": 12121, \"end\": 12131, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 2.0935536426735683e-26, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"the slogan\", \"from\": 12106, \"to\": 12116}]}, {\"sentence\": \"But on the ground, what inevitably develops is a battle over space, over how it is used and who it is for.\", \"from\": 12133, \"to\": 12239, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the ground\", \"from\": 12140, \"to\": 12150}, {\"ngram\": \"a battle\", \"from\": 12180, \"to\": 12188}, {\"ngram\": \"space\", \"from\": 12194, \"to\": 12199}]}, {\"sentence\": \"The Olympics is a $10bn stage-managed spectacle, and nothing was going to get in its way.\", \"from\": 12240, \"to\": 12329, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The Olympics\", \"from\": 12240, \"to\": 12252}, {\"ngram\": \"a $10bn stage-managed spectacle\",