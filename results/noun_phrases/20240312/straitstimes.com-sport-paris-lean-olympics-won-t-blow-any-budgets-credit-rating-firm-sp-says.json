//dbpedia.org/resource/S&P_Global_Ratings\"}], \"noun_phrases\": [{\"ngram\": \"the Games\", \"from\": 1787, \"to\": 1796}, {\"ngram\": \"the state and local and regional authorities\", \"from\": 1811, \"to\": 1855}, {\"ngram\": \"only 28 per cent\", \"from\": 1876, \"to\": 1892}]}, {\"sentence\": \"Ticket sales and TV and marketing deals should bring in around \\u20ac4.2 billion which could cover up to 96 per cent of total operating costs, according to the International Olympic Committee (IOC).\", \"from\": 1929, \"to\": 2122, \"entities\": [{\"begin\": 2084, \"end\": 2121, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee (IOC)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"Ticket sales\", \"from\": 1929, \"to\": 1941}, {\"ngram\": \"TV and marketing deals\", \"from\": 1946, \"to\": 1968}, {\"ngram\": \"up to 96 per cent\", \"from\": 2023, \"to\": 2040}, {\"ngram\": \"total operating costs\", \"from\": 2044, \"to\": 2065}]}, {\"sentence\": \"France's government has agreed to provide the IOC with a \\u20ac3 billion guarantee, which equates to 0.1 per cent of its gross domestic product.\", \"from\": 2124, \"to\": 2263, \"entities\": [{\"begin\": 2124, \"end\": 2130, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9997159157426937, \"rank\": 0.00021131481214296956, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 2170, \"end\": 2173, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 6.76514467354644e-14, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"a \\u20ac3 billion guarantee\", \"from\": 2179, \"to\": 2201}, {\"ngram\": \"0.1 per cent\", \"from\": 2220, \"to\": 2232}, {\"ngram\": \"its gross domestic product\", \"from\": 2236, \"to\": 2262}]}, {\"sentence\": \"The tax windfall from full hotels and restaurants and other visitor-related spending should also help cover the bill, with the government saying the economic benefits could be as high as \\u20ac10 billion.\", \"from\": 2265, \"to\": 2464, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The tax windfall\", \"from\": 2265, \"to\": 2281}, {\"ngram\": \"full hotels\", \"from\": 2287, \"to\": 2298}, {\"ngram\": \"restaurants\", \"from\": 2303, \"to\": 2314}, {\"ngram\": \"other visitor-related spending\", \"from\": 2319, \"to\": 2349}, {\"ngram\": \"the bill\", \"from\": 2373, \"to\": 2381}, {\"ngram\": \"the government\", \"from\": 2388, \"to\": 2402}, {\"ngram\": \"the economic benefits\", \"from\": 2410, \"to\": 2431}]}, {\"sentence\": \"Cost overruns remain a risk, however, if past Games are anything to go by.\", \"from\": 2466, \"to\": 2540, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Cost overruns\", \"from\": 2466, \"to\": 2479}, {\"ngram\": \"a risk\", \"from\": 2487, \"to\": 2493}, {\"ngram\": \"Games\", \"from\": 2512, \"to\": 2517}, {\"ngram\": \"anything\", \"from\": 2522, \"to\": 2530}]}, {\"sentence\": \"London's 2012 Olympics overspent by more than US$5 billion.\", \"from\": 2542, \"to\": 2601, \"entities\": [{\"begin\": 2542, \"end\": 2548, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9999914878056498, \"rank\": 6.1020526273447574e-06, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}], \"noun_phrases\": []}, {\"sentence\": \"Tokyo overran by nearly US$26 billion