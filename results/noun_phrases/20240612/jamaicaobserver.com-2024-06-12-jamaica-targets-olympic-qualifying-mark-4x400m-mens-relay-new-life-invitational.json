\": 722, \"to\": 743}, {\"ngram\": \"December\", \"from\": 759, \"to\": 767}, {\"ngram\": \"minutes\", \"from\": 802, \"to\": 809}]}, {\"sentence\": \"The Jamaicans are currently third with a time of 2:59.34, achieved last year at the World Athletics Championships in Budapest, Hungary.\", \"from\": 846, \"to\": 981, \"entities\": [{\"begin\": 930, \"end\": 959, \"title\": \"http://dbpedia.org/resource/World_Athletics_Championships\", \"score\": 0.9999998992361776, \"rank\": 8.802251434112783e-08, \"text\": \"World Athletics Championships\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics_Championships\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics_Championships\"}, {\"begin\": 963, \"end\": 971, \"title\": \"http://dbpedia.org/resource/Budapest\", \"score\": 0.9999999844499144, \"rank\": 1.512984508403331e-08, \"text\": \"Budapest\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Budapest\", \"dbpedia\": \"http://dbpedia.org/resource/Budapest\"}, {\"begin\": 973, \"end\": 980, \"title\": \"http://dbpedia.org/resource/Hungary_national_football_team\", \"score\": 0.9936419323056148, \"rank\": 0.0063572792607915814, \"text\": \"Hungary\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Hungary_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Hungary_national_football_team\"}], \"noun_phrases\": [{\"ngram\": \"The Jamaicans\", \"from\": 846, \"to\": 859}, {\"ngram\": \"a time\", \"from\": 885, \"to\": 891}, {\"ngram\": \"2:59.34\", \"from\": 895, \"to\": 902}]}, {\"sentence\": \"They must surpass France and Zambia's times in order to secure their qualification for the Olympic Games.\", \"from\": 982, \"to\": 1087, \"entities\": [{\"begin\": 1000, \"end\": 1006, \"title\": \"http://dbpedia.org/resource/France_national_football_team\", \"score\": 0.9591748617077911, \"rank\": 0.038805816544863946, \"text\": \"France\", \"types\