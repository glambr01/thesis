ities\": [], \"noun_phrases\": [{\"ngram\": \"10 May\", \"from\": 241, \"to\": 247}]}, {\"sentence\": \"There was a great news2day report to tell us all about it too - press play on the image above to watch it!\", \"from\": 297, \"to\": 403, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a great news2day report\", \"from\": 307, \"to\": 330}, {\"ngram\": \"us\", \"from\": 339, \"to\": 341}, {\"ngram\": \"too - press play\", \"from\": 355, \"to\": 371}, {\"ngram\": \"the image\", \"from\": 375, \"to\": 384}]}, {\"sentence\": \"But now, let us find out how things are going in the Garden County!\", \"from\": 407, \"to\": 474, \"entities\": [{\"begin\": 460, \"end\": 473, \"title\": \"http://dbpedia.org/resource/Garden_County,_Nebraska\", \"score\": 0.9999964612858405, \"rank\": 0.0, \"text\": \"Garden County\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Garden_County,_Nebraska\", \"dbpedia\": \"http://dbpedia.org/resource/Garden_County,_Nebraska\"}], \"noun_phrases\": [{\"ngram\": \"us\", \"from\": 420, \"to\": 422}, {\"ngram\": \"things\", \"from\": 436, \"to\": 442}]}, {\"sentence\": \"What a fantastic week it's been for Team Ireland!\", \"from\": 476, \"to\": 525, \"entities\": [{\"begin\": 512, \"end\": 524, \"title\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\", \"score\": 1.0, \"rank\": 3.199268075409968e-18, \"text\": \"Team Ireland\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\"}], \"noun_phrases\": []}, {\"sentence\": \"and for us as we watch more of our athletes, living their dreams and qualifying for Paris 2024, relay races have never been so popular in the school yard!\", \"from\": 526, \"to\": 680, \"entities\": [{\"begin\": 610, \"end\": 620, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 4.47209579964367e-14, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wi