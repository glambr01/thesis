"noun_phrases\": [{\"ngram\": \"the Saturday\", \"from\": 1544, \"to\": 1556}]}, {\"sentence\": \"\\\"The biggest concern was my knee.\", \"from\": 1605, \"to\": 1638, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The biggest concern\", \"from\": 1606, \"to\": 1625}, {\"ngram\": \"my knee\", \"from\": 1630, \"to\": 1637}]}, {\"sentence\": \"My knee hit the car and I had bruising on the bone so I just had to ice that on a regular basis.\", \"from\": 1639, \"to\": 1735, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My knee\", \"from\": 1639, \"to\": 1646}, {\"ngram\": \"the car\", \"from\": 1651, \"to\": 1658}, {\"ngram\": \"the bone\", \"from\": 1681, \"to\": 1689}, {\"ngram\": \"a regular basis\", \"from\": 1719, \"to\": 1734}]}, {\"sentence\": \"\\\"It wasn't a hit and run.\", \"from\": 1737, \"to\": 1762, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a hit\", \"from\": 1748, \"to\": 1753}]}, {\"sentence\": \"The gentleman stopped, he got out and he helped me.\", \"from\": 1763, \"to\": 1814, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The gentleman\", \"from\": 1763, \"to\": 1776}]}, {\"sentence\": \"There was an ambulance very quickly on the scene.\\\"\", \"from\": 1815, \"to\": 1865, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an ambulance\", \"from\": 1825, \"to\": 1837}, {\"ngram\": \"the scene\", \"from\": 1854, \"to\": 1863}]}, {\"sentence\": \"Team-mate Graham took the world record in the heats before Van Gass, who lost his left arm at the elbow after being hit by a rocket-propelled grenade while serving with the Parachute Regiment in 2009, quickly snatched it back, with a time of 3:15.488.\", \"from\": 1867, \"to\": 2118, \"entities\": [{\"begin\": 1877, \"end\": 1883, \"title\": \"http://dbpedia.org/resource/Benjamin_Graham\", \"score\": 0.9994157872345336, \"rank\": 0.0005126716980772453, \"text\": \"Graham\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q188094\"], \"wikid\": \"http://dbpedia.org/resource/Benjami