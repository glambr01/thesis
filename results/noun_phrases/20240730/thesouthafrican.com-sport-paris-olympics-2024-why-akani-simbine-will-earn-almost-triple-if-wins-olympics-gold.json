uth_Africa\"}], \"noun_phrases\": [{\"ngram\": \"a division\", \"from\": 88, \"to\": 98}, {\"ngram\": \"permission\", \"from\": 150, \"to\": 160}, {\"ngram\": \"Home\\u00bbSport\\u00bbParis Olympics\", \"from\": 172, \"to\": 197}, {\"ngram\": \"2024\\u00bbWhy Simbine\", \"from\": 198, \"to\": 214}, {\"ngram\": \"more than triple the amount\", \"from\": 289, \"to\": 316}, {\"ngram\": \"a gold medal\", \"from\": 321, \"to\": 333}, {\"ngram\": \"the Paris Olympics\", \"from\": 372, \"to\": 390}]}, {\"sentence\": \"Here is why.\", \"from\": 394, \"to\": 406, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"As reported this week, Tatjana Smith isset to pocketR400 000after claiming gold at the Paris Olympics on Monday, thanks to the financial incentives guaranteed by theSouth African Sports Confederation and Olympic Committee (Sascoc).\", \"from\": 408, \"to\": 639, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Tatjana Smith\", \"from\": 431, \"to\": 444}, {\"ngram\": \"pocketR400 000after\", \"from\": 454, \"to\": 473}, {\"ngram\": \"gold\", \"from\": 483, \"to\": 487}, {\"ngram\": \"the Paris Olympics\", \"from\": 491, \"to\": 509}, {\"ngram\": \"Monday\", \"from\": 513, \"to\": 519}, {\"ngram\": \"the financial incentives\", \"from\": 531, \"to\": 555}, {\"ngram\": \"theSouth African Sports Confederation\", \"from\": 570, \"to\": 607}, {\"ngram\": \"Olympic Committee\", \"from\": 612, \"to\": 629}, {\"ngram\": \"Sascoc\", \"from\": 631, \"to\": 637}]}, {\"sentence\": \"Smith, formerly known as Schoenmaker, will be back in action in thewomen's 200m breaststroke, and so she could quite possibly double those earnings as she will once again be the favourite for gold in that event.\", \"from\": 641, \"to\": 852, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Smith\", \"from\": 641, \"to\": 646}, {\"ngram\": \"Schoenmaker\", \"from\": 666, \"to\": 677}, {\"ngram\": \"action\", \"from\": 695, \"to\": 701}, {\"ngram\": \"thewomen's 200m breaststroke\", \"from