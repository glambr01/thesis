 180, \"to\": 206}, {\"ngram\": \"the uniforms\", \"from\": 229, \"to\": 241}, {\"ngram\": \"Australians\", \"from\": 242, \"to\": 253}, {\"ngram\": \"the opening ceremony\", \"from\": 267, \"to\": 287}, {\"ngram\": \"the Paris 2024 Olympic Games\", \"from\": 291, \"to\": 319}]}, {\"sentence\": \"The lining of the green blazer the team will be wear on the night contains the names of all 301 Australians who have been crowned summer Olympic champions.\", \"from\": 322, \"to\": 477, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The lining\", \"from\": 322, \"to\": 332}, {\"ngram\": \"the green blazer\", \"from\": 336, \"to\": 352}, {\"ngram\": \"the team\", \"from\": 353, \"to\": 361}, {\"ngram\": \"the night\", \"from\": 378, \"to\": 387}, {\"ngram\": \"the names\", \"from\": 397, \"to\": 406}, {\"ngram\": \"all 301 Australians\", \"from\": 410, \"to\": 429}, {\"ngram\": \"summer Olympic champions\", \"from\": 452, \"to\": 476}]}, {\"sentence\": \"The Australian Olympians' Oath has also been inscribed on the inside jacket pocket of the blazer, which has been created by Sportscraft and will be worn by close to 500 athletes.\", \"from\": 479, \"to\": 657, \"entities\": [{\"begin\": 479, \"end\": 493, \"title\": \"http://dbpedia.org/resource/The_Australian\", \"score\": 1.0, \"rank\": 2.3390793153207513e-16, \"text\": \"The Australian\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Australian\", \"dbpedia\": \"http://dbpedia.org/resource/The_Australian\"}], \"noun_phrases\": [{\"ngram\": \"the inside jacket pocket\", \"from\": 537, \"to\": 561}, {\"ngram\": \"the blazer\", \"from\": 565, \"to\": 575}, {\"ngram\": \"Sportscraft\", \"from\": 603, \"to\": 614}, {\"ngram\": \"close to 500 athletes\", \"from\": 635, \"to\": 656}]}, {\"sentence\": \"The uniforms were unveiled on Wednesday, 100 days out from the opening ceremony which is set to be held outside a stadium for the first time in summer Olympic hi