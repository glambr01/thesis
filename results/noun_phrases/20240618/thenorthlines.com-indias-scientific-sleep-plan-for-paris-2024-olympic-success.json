"{\"uid\": \"thenorthlines.com-indias-scientific-sleep-plan-for-paris-2024-olympic-success\", \"noun_phrases\": [{\"sentence\": \"A Good Night's Sleep is Crucial for Paris Success With the Paris Olympics only a few months away, the Indian contingent is leaving no stone unturned in their preparations.\", \"from\": 0, \"to\": 172, \"entities\": [{\"begin\": 103, \"end\": 109, \"title\": \"http://dbpedia.org/resource/Indian_people\", \"score\": 0.9842075877590508, \"rank\": 0.015474544405128472, \"text\": \"Indian\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Indian_people\", \"dbpedia\": \"http://dbpedia.org/resource/Indian_people\"}], \"noun_phrases\": [{\"ngram\": \"A Good Night's Sleep\", \"from\": 0, \"to\": 20}, {\"ngram\": \"Paris Success\", \"from\": 36, \"to\": 49}, {\"ngram\": \"the Paris Olympics\", \"from\": 55, \"to\": 73}, {\"ngram\": \"no stone\", \"from\": 131, \"to\": 139}, {\"ngram\": \"their preparations\", \"from\": 152, \"to\": 170}]}, {\"sentence\": \"For the first time ever, they will have an expert sleep advisor accompanying them to help optimize their sleep schedules.\", \"from\": 173, \"to\": 294, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the first time\", \"from\": 177, \"to\": 191}, {\"ngram\": \"an expert sleep advisor\", \"from\": 213, \"to\": 236}, {\"ngram\": \"their sleep schedules\", \"from\": 272, \"to\": 293}]}, {\"sentence\": \"Dr. Monika Sharma, an experienced sleep consultant, will analyze the challenges athletes face in sleeping well during such a high-pressure event and design customized strategies.\", \"from\": 295, \"to\": 473, \"entities\": [{\"begin\": 299, \"end\": 305, \"title\": \"http://dbpedia.org/resource/Monika_Mann\", \"score\": 0.9038399371068606, \"rank\": 0.10576608067475081, \"text\": \"Monika\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Monika_Mann\", \"dbpedia\": \"http://dbpedia.org/resource/Monika_Mann\"}], \"noun_phrases\": [{\"ngram\": \"an experienced sleep con