"{\"uid\": \"metro.co.uk-2024-07-23-team-gb-legend-pulls-paris-olympics-shameful-error-21282299\", \"noun_phrases\": [{\"sentence\": \"Team GB legend Charlotte Dujardin has been provisionally suspended for six months after a video emerged showing her 'engaging in conduct contrary to the principles of horse welfare'.\", \"from\": 0, \"to\": 182, \"entities\": [{\"begin\": 0, \"end\": 7, \"title\": \"http://dbpedia.org/resource/Team_GB\", \"score\": 0.9975867406838215, \"rank\": 0.0024190971968582925, \"text\": \"Team GB\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Team_GB\", \"dbpedia\": \"http://dbpedia.org/resource/Team_GB\"}, {\"begin\": 15, \"end\": 33, \"title\": \"http://dbpedia.org/resource/Charlotte_Dujardin\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Charlotte Dujardin\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Charlotte_Dujardin\", \"dbpedia\": \"http://dbpedia.org/resource/Charlotte_Dujardin\"}], \"noun_phrases\": [{\"ngram\": \"six months\", \"from\": 71, \"to\": 81}, {\"ngram\": \"a video\", \"from\": 88, \"to\": 95}, {\"ngram\": \"conduct\", \"from\": 129, \"to\": 136}, {\"ngram\": \"the principles\", \"from\": 149, \"to\": 163}, {\"ngram\": \"horse welfare\", \"from\": 167, \"to\": 180}]}, {\"sentence\": \"Equestrian star Dujardin, Britain'sjoint-most decorated female Olympian, pulled out of theParis Olympicson Tuesday afternoon, just days away from the start of competition in the French capital.\", \"from\": 184, \"to\": 377, \"entities\": [{\"begin\": 247, \"end\": 255, \"title\": \"http://dbpedia.org/resource/Olympic_Games\", \"score\": 1.0, \"rank\": 1.5116025141541635e-14, \"text\": \"Olympian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games\"}, {\"begin\": 362, \"end\": 368, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.933383816541294, \"rank\": 0.04129892304589575, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"Equestrian star\", \"from\": 184, \"to\": 199}, {\"ngram\": \"theParis Olympicson\", \"from\": 271, \"to\": 290}, {\"ngram\": \"the start\", \"from\": 330, \"to\": 339}, {\"ngram\": \"competition\", \"from\": 343, \"to\": 354}]}, {\"sentence\": \"The 39-year-old announced her decision to withdraw after a video, taken four years ago, emerged in which she made an 'error of judgement'.\", \"from\": 379, \"to\": 517, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her decision\", \"from\": 405, \"to\": 417}, {\"ngram\": \"a video\", \"from\": 436, \"to\": 443}, {\"ngram\": \"an 'error\", \"from\": 493, \"to\": 502}, {\"ngram\": \"judgement\", \"from\": 506, \"to\": 515}]}, {\"sentence\": \"The International Federation for Equestrian Sports [FEI] has now confirmed they received the footage on Monday, immediately launching an investigation during which Dujardin confirmed she was the individual depicted in the video.\", \"from\": 519, \"to\": 747, \"entities\": [{\"begin\": 571, \"end\": 574, \"title\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\", \"score\": 1.0, \"rank\": 5.867578608008434e-46, \"text\": \"FEI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\"}], \"noun_phrases\": [{\"ngram\": \"The International Federation\", \"from\": 519, \"to\": 547}, {\"ngram\": \"Equestrian Sports\", \"from\": 552, \"to\": 569}, {\"ngram\": \"the footage\", \"from\": 608, \"to\": 619}, {\"ngram\": \"Monday\", \"from\": 623, \"to\": 629}, {\"ngram\": \"an investigation\", \"from\": 653, \"to\": 669}, {\"ngram\": \"Dujardin\", \"from\": 683, \"to\": 691}, {\"ngram\": \"the individual\", \"from\": 710, \"to\": 724}, {\"ngram\": \"the video\", \"from\": 737, \"to\": 746}]}, {\"sentence\": \"The FEI's announcement comes amid claimsDujardin was recorded repeatedly hitting a horse on the legs.\", \"from\": 749, \"to\": 850, \"entities\": [{\"begin\": 753, \"end\": 756, \"title\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\", \"score\": 1.0, \"rank\": 5.867578608008434e-46, \"text\": \"FEI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\"}], \"noun_phrases\": [{\"ngram\": \"claimsDujardin\", \"from\": 783, \"to\": 797}, {\"ngram\": \"a horse\", \"from\": 830, \"to\": 837}, {\"ngram\": \"the legs\", \"from\": 841, \"to\": 849}]}, {\"sentence\": \"A statement from equestrian's governing body said: 'The FEI has officially announced the provisional suspension of British Dressage athlete Charlotte Dujardin for a period of six months, effective immediately from the date of notification, 23 July 2024.\", \"from\": 852, \"to\": 1105, \"entities\": [{\"begin\": 869, \"end\": 879, \"title\": \"http://dbpedia.org/resource/Equestrian_at_the_Summer_Olympics\", \"score\": 0.9999033994726831, \"rank\": 9.66092917996756e-05, \"text\": \"equestrian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Equestrian_at_the_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Equestrian_at_the_Summer_Olympics\"}, {\"begin\": 908, \"end\": 911, \"title\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\", \"score\": 1.0, \"rank\": 5.867578608008434e-46, \"text\": \"FEI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\"}, {\"begin\": 967, \"end\": 983, \"title\": \"http://dbpedia.org/resource/British_Dressage\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"British Dressage\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/British_Dressage\", \"dbpedia\": \"http://dbpedia.org/resource/British_Dressage\"}], \"noun_phrases\": [{\"ngram\": \"A statement\", \"from\": 852, \"to\": 863}, {\"ngram\": \"the provisional suspension\", \"from\": 937, \"to\": 963}, {\"ngram\": \"Charlotte\", \"from\": 992, \"to\": 1001}, {\"ngram\": \"a period\", \"from\": 1015, \"to\": 1023}, {\"ngram\": \"six months\", \"from\": 1027, \"to\": 1037}, {\"ngram\": \"the date\", \"from\": 1066, \"to\": 1074}, {\"ngram\": \"notification\", \"from\": 1078, \"to\": 1090}]}, {\"sentence\": \"'This decision renders her ineligible to participate in the upcoming Paris 2024 Olympic Games or any other events under the jurisdiction of the FEI.\", \"from\": 1107, \"to\": 1255, \"entities\": [{\"begin\": 1251, \"end\": 1254, \"title\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\", \"score\": 1.0, \"rank\": 5.867578608008434e-46, \"text\": \"FEI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\"}], \"noun_phrases\": [{\"ngram\": \"This decision\", \"from\": 1108, \"to\": 1121}, {\"ngram\": \"the upcoming Paris 2024 Olympic Games\", \"from\": 1163, \"to\": 1200}, {\"ngram\": \"any other events\", \"from\": 1204, \"to\": 1220}, {\"ngram\": \"the jurisdiction\", \"from\": 1227, \"to\": 1243}]}, {\"sentence\": \"'During this period of suspension, she is prohibited from participating in any activities related to competitions or events under the jurisdiction of the FEI or any competition or event under the jurisdiction of a National Federation (NF).\", \"from\": 1257, \"to\": 1496, \"entities\": [{\"begin\": 1411, \"end\": 1414, \"title\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\", \"score\": 1.0, \"rank\": 5.867578608008434e-46, \"text\": \"FEI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\"}], \"noun_phrases\": [{\"ngram\": \"this period\", \"from\": 1265, \"to\": 1276}, {\"ngram\": \"suspension\", \"from\": 1280, \"to\": 1290}, {\"ngram\": \"any activities\", \"from\": 1332, \"to\": 1346}, {\"ngram\": \"competitions\", \"from\": 1358, \"to\": 1370}, {\"ngram\": \"events\", \"from\": 1374, \"to\": 1380}, {\"ngram\": \"the jurisdiction\", \"from\": 1387, \"to\": 1403}, {\"ngram\": \"any competition\", \"from\": 1418, \"to\": 1433}, {\"ngram\": \"event\", \"from\": 1437, \"to\": 1442}, {\"ngram\": \"the jurisdiction\", \"from\": 1449, \"to\": 1465}, {\"ngram\": \"a National Federation\", \"from\": 1469, \"to\": 1490}, {\"ngram\": \"NF\", \"from\": 1492, \"to\": 1494}]}, {\"sentence\": \"'This also includes any FEI or NF-related activities.\", \"from\": 1498, \"to\": 1551, \"entities\": [{\"begin\": 1522, \"end\": 1525, \"title\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\", \"score\": 1.0, \"rank\": 5.867578608008434e-46, \"text\": \"FEI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\"}], \"noun_phrases\": [{\"ngram\": \"NF-related activities\", \"from\": 1529, \"to\": 1550}]}, {\"sentence\": \"In addition, the British Equestrian Federation has mirrored this provisional suspension, which also makes Ms. Dujardin ineligible to compete in any national events during this period.\", \"from\": 1552, \"to\": 1735, \"entities\": [{\"begin\": 1569, \"end\": 1598, \"title\": \"http://dbpedia.org/resource/British_Equestrian_Federation\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"British Equestrian Federation\", \"types\