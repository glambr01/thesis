phrases\": []}, {\"sentence\": \"Or you can park at Woodward to come to the event.\", \"from\": 916, \"to\": 965, \"entities\": [{\"begin\": 935, \"end\": 943, \"title\": \"http://dbpedia.org/resource/Lower_Woodward_Avenue_Historic_District\", \"score\": 0.8081798227392196, \"rank\": 0.2276422918889137, \"text\": \"Woodward\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Lower_Woodward_Avenue_Historic_District\", \"dbpedia\": \"http://dbpedia.org/resource/Lower_Woodward_Avenue_Historic_District\"}], \"noun_phrases\": [{\"ngram\": \"the event\", \"from\": 955, \"to\": 964}]}, {\"sentence\": \"And from there, they will be running shuttles up to the UOP.\\\"\", \"from\": 966, \"to\": 1027, \"entities\": [{\"begin\": 1022, \"end\": 1025, \"title\": \"http://dbpedia.org/resource/University_of_Portsmouth\", \"score\": 0.9997661735214821, \"rank\": 0.00023388116551231904, \"text\": \"UOP\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/University_of_Portsmouth\", \"dbpedia\": \"http://dbpedia.org/resource/University_of_Portsmouth\"}], \"noun_phrases\": [{\"ngram\": \"shuttles\", \"from\": 1003, \"to\": 1011}]}, {\"sentence\": \"Buses will run from 3 p.m. to 10 p.m. Rideshares and hotel shuttles will drop riders at the Skullcandy building.\", \"from\": 1029, \"to\": 1142, \"entities\": [{\"begin\": 1122, \"end\": 1132, \"title\": \"http://dbpedia.org/resource/Skullcandy\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Skullcandy\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Skullcandy\", \"dbpedia\": \"http://dbpedia.org/resource/Skullcandy\"}], \"noun_phrases\": [{\"ngram\": \"Buses\", \"from\": 1029, \"to\": 1034}, {\"ngram\": \"3 p.m.\", \"from\": 1049, \"to\": 1055}, {\"ngram\": \"Rideshares\", \"from\": 1067, \"to\": 1077}, {\"ngram\": \"hotel shuttles\", \"from\": 1082, \"to\": 1096}, {\"ngram\": \"riders\", \"from\": 1107, \"to\": 1113}]}, {\"senten