verseas veterans and young talent.\", \"from\": 8081, \"to\": 8440, \"entities\": [{\"begin\": 8167, \"end\": 8180, \"title\": \"http://dbpedia.org/resource/Jos\\u00e9_Calder\\u00f3n_(basketball)\", \"score\": 0.9999999623269111, \"rank\": 0.0, \"text\": \"Jose Calderon\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jos\\u00e9_Calder\\u00f3n_(basketball)\", \"dbpedia\": \"http://dbpedia.org/resource/Jos\\u00e9_Calder\\u00f3n_(basketball)\"}, {\"begin\": 8182, \"end\": 8187, \"title\": \"http://dbpedia.org/resource/Ricky_Nelson\", \"score\": 0.9999742397784014, \"rank\": 2.576088584593722e-05, \"text\": \"Ricky\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Ricky_Nelson\", \"dbpedia\": \"http://dbpedia.org/resource/Ricky_Nelson\"}, {\"begin\": 8188, \"end\": 8193, \"title\": \"http://dbpedia.org/resource/Ricky_Rubio\", \"score\": 1.0, \"rank\": 4.7231374608750577e-67, \"text\": \"Rubio\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Ricky_Rubio\", \"dbpedia\": \"http://dbpedia.org/resource/Ricky_Rubio\"}, {\"begin\": 8226, \"end\": 8242, \"title\": \"http://dbpedia.org/resource/Sergio_Rodr\\u00edguez\", \"score\": 0.9999999753272281, \"rank\": 0.0, \"text\": \"Sergio Rodriguez\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Sergio_Rodr\\u00edguez\", \"dbpedia\": \"http://dbpedia.org/resource/Sergio_Rodr\\u00edguez\"}, {\"begin\": 8369, \"end\": 8379, \"title\": \"http://dbpedia.org/resource/EuroLeague\", \"score\": 1.0, \"rank\": 7.598751052863857e-65, \"text\": \"EuroLeague\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/EuroLeague\", \"dbpedia\": \"http://dbpedia.org/resource/EuroLeague\"}], \"noun_phrases\": [{\"ngram\": \"the golden generation\", \"from\": 8096, \"to\": 8117}, {\"ngram\": \"t