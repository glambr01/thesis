am\"}, {\"begin\": 203, \"end\": 218, \"title\": \"http://dbpedia.org/resource/Chellsie_Memmel\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Chellsie Memmel\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Chellsie_Memmel\", \"dbpedia\": \"http://dbpedia.org/resource/Chellsie_Memmel\"}], \"noun_phrases\": [{\"ngram\": \"Biles\", \"from\": 224, \"to\": 229}, {\"ngram\": \"the option\", \"from\": 282, \"to\": 292}, {\"ngram\": \"all four apparatus\", \"from\": 313, \"to\": 331}, {\"ngram\": \"the women's team\", \"from\": 335, \"to\": 351}]}, {\"sentence\": \"\\\"I do not say, 'You are keeping us all together, we are relying on you and you alone',\\\" Memmel told journalists days before the Games begin in the French capital.\", \"from\": 360, \"to\": 522, \"entities\": [{\"begin\": 507, \"end\": 513, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.4149814256255951, \"rank\": 0.7949331617840217, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"us\", \"from\": 392, \"to\": 394}, {\"ngram\": \"Memmel\", \"from\": 448, \"to\": 454}, {\"ngram\": \"journalists\", \"from\": 460, \"to\": 471}, {\"ngram\": \"the Games\", \"from\": 484, \"to\": 493}]}, {\"sentence\": \"Biles's coach Cecile Landi approached coaching staff to discuss expectations on the four-time Olympic champion, who disclosed her mental health struggles during the Tokyo Olympics.\", \"from\": 524, \"to\": 704, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Biles's coach\", \"from\": 524, \"to\": 537}, {\"ngram\": \"Cecile Landi\", \"from\": 538, \"to\": 550}, {\"ngram\": \"coaching staff\", \"from\": 562, \"to\": 576}, {\"ngram\": \"expectations\", \"from\": 588, \"to\": 600}, {\"ngram\": \"the four-time Olympic champion\", \"from\": 604, \"to\": 634}, {\"ngram\": \"her mental health struggles\", \"from\": 650, \"to\": 677}, {\"ngram\": \"the Tokyo Olympics\", \"from\": 685, \"to\": 703}]}, {\"sentence\": \"\\\"If she does not feel like it's going to be in her best interest to do all four events that day, is that an option for her?\\\"\", \"from\": 706, \"to\": 830, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her best interest\", \"from\": 753, \"to\": 770}, {\"ngram\": \"all four events\", \"from\": 777, \"to\": 792}, {\"ngram\": \"an option\", \"from\": 811, \"to\": 820}]}, {\"sentence\": \"Memmel said Landi asked.\", \"from\": 831, \"to\": 855, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Memmel\", \"from\": 831, \"to\": 837}, {\"ngram\": \"Landi\", \"from\": 843, \"to\": 848}]}, {\"sentence\": \"\\\"And we said: absolutely.\", \"from\": 857, \"to\": 882, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"\\\"If that's what she needs to continue to be at her best for her team and for herself, then that's what we are going to do because there are still four other members on our team.\\\"\", \"from\": 884, \"to\": 1062, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her team\", \"from\": 944, \"to\": 952}, {\"ngram\": \"four other members\", \"from\": 1030, \"to\": 1048}, {\"ngram\": \"our team\", \"from\": 1052, \"to\": 1060}]}, {\"sentence\": \"Biles, 27, returns to the glare of the Olympic spotlight in women's qualifying on Sunday with the team final on Tuesday, three years after struggling with the disorienting mental block that gymnasts call the \\\"twisties\\\".\", \"from\": 1064, \"to\": 1283, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Biles\", \"from\": 1064, \"to\": 1069}, {\"ngram\": \"the glare\", \"from\": 1086, \"to\": 1095}, {\"ngram\": \"the Olympic spotlight\", \"from\": 1099, \"to\": 1120}, {\"ngram\": \"women's qualifying\", \"from\": 1124, \"to\": 1142}, {\"ngram\": \"Sunday\", \"from\": 1146, \"to\": 1152}, {\"ngram\": \"the team\", \"from\": 1158, \"to\": 1166}, {\"ngram\": \"Tuesday\", \"f