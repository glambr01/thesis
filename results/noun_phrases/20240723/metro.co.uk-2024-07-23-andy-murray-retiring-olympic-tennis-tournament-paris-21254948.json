\"entities\": [{\"begin\": 7796, \"end\": 7802, \"title\": \"http://dbpedia.org/resource/Andy_Murray\", \"score\": 1.0, \"rank\": 3.345634456647623e-35, \"text\": \"Murray\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Andy_Murray\", \"dbpedia\": \"http://dbpedia.org/resource/Andy_Murray\"}], \"noun_phrases\": [{\"ngram\": \"a favour\", \"from\": 7785, \"to\": 7793}]}, {\"sentence\": \"'I am in a terrible moment right now I will give you that.\", \"from\": 7809, \"to\": 7867, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a terrible moment\", \"from\": 7818, \"to\": 7835}]}, {\"sentence\": \"Most people would quit and give up in my situation right now.\", \"from\": 7868, \"to\": 7929, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Most people\", \"from\": 7868, \"to\": 7879}, {\"ngram\": \"my situation\", \"from\": 7906, \"to\": 7918}]}, {\"sentence\": \"But I am not most people and my mind works differently.\", \"from\": 7930, \"to\": 7985, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"most people\", \"from\": 7943, \"to\": 7954}, {\"ngram\": \"my mind\", \"from\": 7959, \"to\": 7966}]}, {\"sentence\": \"'I will not quit.\", \"from\": 7987, \"to\": 8004, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I will keep fighting and working to produce the performances I know I am capable of.\", \"from\": 8005, \"to\": 8089, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the performances\", \"from\": 8049, \"to\": 8065}]}, {\"sentence\": \"The only way to find solutions [is] to win matches.\", \"from\": 8090, \"to\": 8141, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The only way\", \"from\": 8090, \"to\": 8102}, {\"ngram\": \"solutions\", \"from\": 8111, \"to\": 8120}, {\"ngram\": \"matches\", \"from\": 8133, \"to\": 8140}]}, {\"sentence\": \"It can also be played out in training, working on your game and sensations.\", \"from\": 8142, \"to\": 8217, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"training\", \"from\": 8171, \"to\": 8179}, {\"ngram\": \"your game\", \"from\": 8192, \"to\": 8201}, {\"ngram\": \"sensations\", \"from\": 8206, \"to\": 8216}]}, {\"sentence\": \"'At the moment, without a doubt, it is not easy to compete.\", \"from\": 8219, \"to\": 8278, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the moment\", \"from\": 8223, \"to\": 8233}, {\"ngram\": \"a doubt\", \"from\": 8243, \"to\": 8250}]}, {\"sentence\": \"But what is happening now does not affect my career.\", \"from\": 8279, \"to\": 8331, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my career\", \"from\": 8321, \"to\": 8330}]}, {\"sentence\": \"No number of defeats will change what I achieved when I was in shape and with two hips.\", \"from\": 8332, \"to\": 8419, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"No number\", \"from\": 8332, \"to\": 8341}, {\"ngram\": \"defeats\", \"from\": 8345, \"to\": 8352}, {\"ngram\": \"shape\", \"from\": 8395, \"to\": 8400}, {\"ngram\": \"two hips\", \"from\": 8410, \"to\": 8418}]}, {\"sentence\": \"But when you can not win, you also lose confidence.\", \"from\": 8420, \"to\": 8471, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"confidence\", \"from\": 8460, \"to\": 8470}]}, {\"sentence\": \"I have never experienced that in my career.'\", \"from\": 8472, \"to\": 8516, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my career\", \"from\": 8505, \"to\": 8514}]}, {\"sentence\": \"Speaking after he lost in the first round of theAustralianOpen in January, Andy Murray said: 'It's definitely a possibility that is the last time I play here.\", \"from\": 8518, \"to\": 8676, \"entities\": [{\"begin\": 8593, \"end\": 8604, \"title\": \"http://dbpedia.org/resource/Andy_Murray\", \"score\": 1.0, \"rank\": 5.442892702357007e-66, \"text\": \"Andy Murray\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Andy_Murray\", \"dbpedia\": \"http://dbpedia.org/resource/Andy_Murray\"}], \"noun_phrases\": [{\"ngram\": \"the first round\", \"from\": 8544, \"to\": 8559}, {\"ngram\": \"January\", \"from\": 8584, \"to\": 8591}, {\"ngram\": \"a possibility\", \"from\": 8628, \"to\": 8641}, {\"ngram\": \"the last time\", \"from\": 8650, \"to\": 8663}]}, {\"sentence\": \"'I have an idea when I would like to finish playing.\", \"from\": 8678, \"to\": 8730, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an idea\", \"from\": 8686, \"to\": 8693}]}, {\"sentence\": \"But so much of that depends on how you are playing.\", \"from\": 8731, \"to\": 8782, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"'The time frame for that narrows when you play and have results like [that].\", \"from\": 8784, \"to\": 8860, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The time frame\", \"from\": 8785, \"to\": 8799}, {\"ngram\": \"results\", \"from\": 8840, \"to\": 8847}]}, {\"sentence\": \"It's the nature of the performances that make you question things.'\", \"from\": 8861, \"to\": 8928, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the nature\", \"from\": 8866, \"to\": 8876}, {\"ngram\": \"the performances\", \"from\": 8880, \"to\": 8896}, {\"ngram\": \"things\", \"from\": 8920, \"to\": 8926}]}, {\"sentence\": \"Speaking in the summer of 2023, Andy Murray said: 'I have heard stories from ex-players and other athletes who have made no plans for retiring, and they finish and all of a sudden, it's, 'What am I going to do with myself?'\", \"from\": 8930, \"to\": 9153, \"entities\": [{\"begin\": 8962, \"end\": 8973, \"title\": \"http://dbpedia.org/resource/Andy_Murray\", \"score\": 1.0, \"rank\": 5.442892702357007e-66, \"text\": \"Andy Murray\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Andy_Murray\", \"dbpedia\": \"http://dbpedia.org/resource/Andy_Murray\"}], \"noun_phrases\": [{\"ngram\": \"the summer\", \"from\": 8942, \"to\": 8952}, {\"ngram\": \"stories\", \"from\": 8994, \"to\": 9001}, {\"ngram\": \"ex\", \"from\": 9007, \"to\": 9009}, {\"ngram\": \"players\", \"from\": 9010, \"to\": 9017}, {\"ngram\": \"other athletes\", \"from\": 9022, \"to\": 9036}, {\"ngram\": \"no plans\", \"from\": 9051, \"to\": 9059}]}, {\"sentence\": \"'I was chatting to them about things that I might want to get involved in or really do not want to get involved in, just starting to get a few ideas together.\", \"from\": 9155, \"to\": 9313, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"things\", \"from\": 9185, \"to\": 9191}, {\"ngram\": \"a few ideas\", \"from\": 9292, \"to\": 9303}]}, {\"sentence\": \"I am looking for something I am really passionate about and that I want to work really hard at to achieve a specific goal.\", \"from\": 9314, \"to\": 9436, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"something\", \"from\": 9331, \"to\": 9340}, {\"ngram\": \"a specific goal\", \"from\": 9420, \"to\": 9435}]}, {\"sentence\": \"'One area that ticks that box is coaching, but not necessarily in tennis.\", \"from\": 9438, \"to\": 9511, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"One area\", \"from\": 9439, \"to\": 9447}, {\"ngram\": \"that box\", \"from\": 9459, \"to\": 9467}, {\"ngram\": \"tennis\", \"from\": 9504, \"to\": 9510}]}, {\"sentence\": \"I will definitely want to keep busy.'\", \"from\": 9512, \"to\": 9549, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Murray, in aMetro.co.ukexclusive interview in July 2024, was quizzed specifically if he wanted to enter tennis coaching and added: 'It's something that I will consider, for sure.\", \"from\": 9551, \"to\": 9729, \"entities\": [{\"begin\": 9551, \"end\": 9557, \"title\": \"http://dbpedia.org/resource/Andy_Murray\", \"score\": 1.0, \"rank\": 3.345634456647623e-35, \"text\": \"Murray\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Andy_Murray\", \"dbpedia\": \"http://dbpedia.org/resource/Andy_Murray\"}], \"noun_phrases\": [{\"ngram\": \"aMetro.co.ukexclusive interview\", \"from\": 9562, \"to\": 9593}, {\"ngram\": \"July\", \"from\": 9597, \"to\": 9601}, {\"ngram\": \"tennis coaching\", \"from\": 9655, \"to\": 9670}, {\"ngram\": \"something\", \"from\": 9688, \"to\": 9697}]}, {\"sentence\": \"I have not made any plans yet past this summer.\", \"from\": 9730, \"to\": 9777, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"any plans\", \"from\": 9746, \"to\": 9755}, {\"ngram\": \"this summer\", \"from\": 9765, \"to\": 9776}]}, {\"sentence\": \"Once I have finished my tennis, that's when I will start to think about what comes next.'\", \"from\": 9778, \"to\": 9867, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my tennis\", \"from\": 9799, \"to\": 9808}]}, {\"sentence\": \"Speaking to CNN later in July, Murray said: 'I am going to go home and I am going to spend time with my family and be around my kids.\", \"from\": 9869, \"to\": 10002, \"entities\": [{\"begin\": 9881, \"end\": 9884, \"title\": \"http://dbpedia.org/resource/CNN\", \"score\": 0.9999999999836291, \"rank\": 1.6482571576086447e-11, \"text\": \"CNN\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/CNN\", \"dbpedia\": \"http://dbpedia.org/resource/CNN\"}, {\"begin\": 9900, \"end\": 9906, \"title\": \"http://dbpedia.org/resource/Andy_Murray\", \"score\": 1.0, \"rank\": 3.345634456647623e-35, \"text\": \"Murray\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Andy_Murray\", \"dbpedia\": \"http://dbpedia.org/resource/Andy_Murray\"}], \"noun_phrases\": [{\"ngram\": \"July\", \"from\": 9894, \"to\": 9898}, {\"ngram\": \"time\", \"from\": 9960, \"to\": 9964}, {\"ngram\": \"my family\", \"from\": 9970, \"to\": 9979}, {\"ngram\": \"my kids\", \"from\": 9994, \"to\": 10001}]}, {\"sentence\": \"I have four young children which, I want to be at home for them and I want to avoid the long weeks of traveling and being away from that.\", \"from\": 10003, \"to\": 10140, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"four young children\", \"from\": 10010, \"to\": 10029}, {\"ngram\": \"home\", \"from\": 10053, \"to\": 10057}, {\"ngram\": \"the long weeks\", \"from\": 10087, \"to\": 10101}]}, {\"sentence\": \"I found that hard the last few years.\", \"from\": 10141, \"to\": 10178, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"'I want to be home with them and take some time to relax and recover and have a think about what it is that I want to do, what it is that I want to do next.\", \"from\": 10180, \"to\": 10336, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"some time\", \"from\": 10218, \"to\": 10227}, {\"ngram\": \"a think\", \"from\": 10258, \"to\": 10265}]}, {\"sentence\": \"I definitely still see myself having some involvement in tennis.\", \"from\": 10337, \"to\": 10401, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"some involvement\", \"from\": 10374, \"to\": 10390}, {\"ngram\": \"tennis\", \"from\": 10394, \"to\": 10400}]}, {\"sentence\": \"And I am looking forward to something new now.\", \"from\": 10402, \"to\": 10448, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"something\", \"from\": 10430, \"to\": 10439}]}, {\"sentence\": \"But I am not entirely sure of what that new is yet.'\", \"from\": 10449, \"to\": 10501, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"ArrowMORE:Team GB star claims Andy Murray has 'unfair advantage' at Paris Olympics ArrowMORE:Why is not Emma Raducanu playing at the Olympics Games in Paris?\", \"from\": 10503, \"to\": 10661, \"entities\": [{\"begin\": 10533, \"end\": 10544, \"title\": \"http://dbpedia.org/resource/Andy_Murray\", \"score\": 1.0, \"rank\": 5.442892702357007e-66, \"text\": \"Andy Murray\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Andy_Murray\", \"dbpedia\": \"http://dbpedia.org/resource/Andy_Murray\"}, {\