ities\": [], \"noun_phrases\": [{\"ngram\": \"my work\", \"from\": 5681, \"to\": 5688}, {\"ngram\": \"training\", \"from\": 5693, \"to\": 5701}, {\"ngram\": \"preparation\", \"from\": 5706, \"to\": 5717}]}, {\"sentence\": \"I love the city.'\", \"from\": 5724, \"to\": 5741, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the city\", \"from\": 5731, \"to\": 5739}]}, {\"sentence\": \"'Yeah, I mean, I am likely not going to play past this summer,' Andy Murray said in February.\", \"from\": 5743, \"to\": 5836, \"entities\": [{\"begin\": 5807, \"end\": 5818, \"title\": \"http://dbpedia.org/resource/Andy_Murray\", \"score\": 1.0, \"rank\": 5.442892702357007e-66, \"text\": \"Andy Murray\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Andy_Murray\", \"dbpedia\": \"http://dbpedia.org/resource/Andy_Murray\"}], \"noun_phrases\": [{\"ngram\": \"February\", \"from\": 5827, \"to\": 5835}]}, {\"sentence\": \"'I get asked about it after every single match that I play, every single tournament that I play.\", \"from\": 5838, \"to\": 5934, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"every single match\", \"from\": 5866, \"to\": 5884}, {\"ngram\": \"every single tournament\", \"from\": 5898, \"to\": 5921}]}, {\"sentence\": \"I am bored of the question, to be honest.\", \"from\": 5935, \"to\": 5976, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the question\", \"from\": 5949, \"to\": 5961}]}, {\"sentence\": \"'Yeah, I am not going to talk more about that between now and whenever the time comes for me to stop.\", \"from\": 5978, \"to\": 6079, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the time\", \"from\": 6049, \"to\": 6057}]}, {\"sentence\": \"But yeah, I do not plan on playing much past this summer.'\", \"from\": 6080, \"to\": 6138, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Speaking about his chances of featuring at the Games in Paris earlier this year, Andy Murray said: 'I would 