"{\"uid\": \"jamaicaobserver.com-2024-03-26-migrant-transfers-paris-ahead-olympics-anger-mayors\", \"noun_phrases\": [{\"sentence\": \"PARIS, France (AFP) - Mayors in rural and small-town France are increasingly angry over the transfer of migrants from the capital to their communities, which they believe is linked to clean-up efforts ahead of the Paris Olympics.\", \"from\": 0, \"to\": 229, \"entities\": [{\"begin\": 53, \"end\": 59, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9691239822272258, \"rank\": 0.01987964705866485, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"AFP\", \"from\": 15, \"to\": 18}, {\"ngram\": \"the transfer\", \"from\": 88, \"to\": 100}, {\"ngram\": \"migrants\", \"from\": 104, \"to\": 112}, {\"ngram\": \"the capital\", \"from\": 118, \"to\": 129}, {\"ngram\": \"their communities\", \"from\": 133, \"to\": 150}, {\"ngram\": \"clean-up efforts\", \"from\": 184, \"to\": 200}, {\"ngram\": \"the Paris Olympics\", \"from\": 210, \"to\": 228}]}, {\"sentence\": \"Serge Grouard, the right-wing mayor of Orleans in central France, went public Monday with his complaints over the arrival of up to 500 homeless migrants in his town of 100,000 people without his prior knowledge.\", \"from\": 231, \"to\": 442, \"entities\": [{\"begin\": 231, \"end\": 244, \"title\": \"http://dbpedia.org/resource/Serge_Grouard\", \"score\": 0.9999991514884148, \"rank\": 0.0, \"text\": \"Serge Grouard\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Serge_Grouard\", \"dbpedia\": \"http://dbpedia.org/resource/Serge_Grouard\"}, {\"begin\": 289, \"end\": 295, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9691239822272258, \"rank\": 0.01987964705866485, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"the right-wing mayor\", \"from\": 246, \"to\": 266}, {\"ngram\": \"Orleans\", \"from\": 270, \"to\": 277}, {\"ngram\": \"his complaints\", \"from\": 321, \"to\": 335}, {\"ngram\": \"the arrival\", \"from\": 341, \"to\": 352}, {\"ngram\": \"up to 500 homeless migrants\", \"from\": 356, \"to\": 383}, {\"ngram\": \"his town\", \"from\": 387, \"to\": 395}, {\"ngram\": \"100,000 people\", \"from\": 399, \"to\": 413}, {\"ngram\": \"his prior knowledge\", \"from\": 422, \"to\": 441}]}, {\"sentence\": \"\\\"It has been proved that every three weeks, a coach arrives in Orleans from Paris, with between 35-50 people on board,\\\" he told reporters, adding that it was to \\\"clean the deck\\\" in the capital ahead of the Olympics in July and August.\", \"from\": 444, \"to\": 678, \"entities\": [{\"begin\": 520, \"end\": 525, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999999415618902, \"rank\": 5.843813591222293e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"a coach\", \"from\": 488, \"to\": 495}, {\"ngram\": \"Orleans\", \"from\": 507, \"to\": 514}, {\"ngram\": \"between 35-50 people\", \"from\": 532, \"to\": 552}, {\"ngram\": \"board\", \"from\": 556, \"to\": 561}, {\"ngram\": \"reporters\", \"from\": 572, \"to\": 581}, {\"ngram\": \"the deck\", \"from\": 612, \"to\": 620}, {\"ngram\": \"the capital\", \"from\": 625, \"to\": 636}, {\"ngram\": \"the Olympics\", \"from\": 646, \"to\": 658}, {\"ngram\": \"July\", \"from\": 662, \"to\": 666}, {\"ngram\": \"August\", \"from\": 671, \"to\": 677}]}, {\"sentence\": \"Each new arrival is offered three weeks in a hotel at the state's expense, but is thereafter left to fend for themselves, Grouard explained.\", \"from\": 680, \"to\": 820, \"entities\": [{\"begin\": 802, \"end\": 809, \"title\": \"http://dbpedia.org/resource/Grouard\", \"score\": 1.0, \"rank\": 5.121662879207379e-20, \"text\": \"Grouard\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Grouard\", \"dbpedia\": \"http://dbpedia.org/resource/Grouard\"}], \"noun_phrases\": [{\"ngram\": \"Each new arrival\", \"from\": 680, \"to\": 696}, {\"ngram\": \"a hotel\", \"from\": 723, \"to\": 730}, {\"ngram\": \"the state's expense\", \"from\": 734, \"to\": 753}]}, {\"sentence\": \"Paris has long been a magnet for asylum seekers and migrants, mostly from Africa, South Asia or the Middle East, with demand for short-term emergency accommodation far exceeding supply.\", \"from\": 822, \"to\": 1007, \"entities\": [{\"begin\": 822, \"end\": 827, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999999415618902, \"rank\": 5.843813591222293e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"a magnet\", \"from\": 842, \"to\": 850}, {\"ngram\": \"asylum seekers\", \"from\": 855, \"to\": 869}, {\"ngram\": \"migrants\", \"from\": 874, \"to\": 882}, {\"ngram\": \"Africa\", \"from\": 896, \"to\": 902}, {\"ngram\": \"South Asia\", \"from\": 904, \"to\": 914}, {\"ngram\": \"the Middle East\", \"from\": 918, \"to\": 933}, {\"ngram\": \"demand\", \"from\": 940, \"to\": 946}, {\"ngram\": \"short-term emergency accommodation\", \"from\": 951, \"to\": 985}, {\"ngram\": \"far exceeding supply\", \"from\": 986, \"to\": 1006}]}, {\"sentence\": \"As a result, informal camps under bridges or on unoccupied land spring up regularly around the capital, which are periodically torn down by police.\", \"from\": 1009, \"to\": 1156, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a result\", \"from\": 1012, \"to\": 1020}, {\"ngram\": \"informal camps\", \"from\": 1022, \"to\": 1036}, {\"ngram\": \"bridges\", \"from\": 1043, \"to\": 1050}, {\"ngram\": \"unoccupied land\", \"from\": 1057, \"to\": 1072}, {\"ngram\": \"the capital\", \"from\": 1100, \"to\": 1111}, {\"ngram\": \"police\", \"from\": 1149, \"to\": 1155}]}, {\"sentence\": \"Occupants are offered the chance to apply for asylum and the government's policy is to move many of them out of Paris and into facilities elsewhere in the country.\", \"from\": 1158, \"to\": 1321, \"entities\": [{\"begin\": 1270, \"end\": 1275, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999999415618902, \"rank\": 5.843813591222293e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Occupants\", \"from\": 1158, \"to\": 1167}, {\"ngram\": \"the chance\", \"from\": 1180, \"to\": 1190}, {\"ngram\": \"asylum\", \"from\": 1204, \"to\": 1210}, {\"ngram\": \"the government's policy\", \"from\": 1215, \"to\": 1238}, {\"ngram\": \"facilities\", \"from\": 1285, \"to\": 1295}, {\"ngram\": \"the country\", \"from\": 1309, \"to\": 1320}]}, {\"sentence\": \"\\\"We have not been consulted, either about the creation or about the people who will go there,\\\" the deputy mayor of Strasbourg, Floriane Varieras, told AFP when asked about a new facility near her city in eastern France.\", \"from\": 1323, \"to\": 1542, \"entities\": [{\"begin\": 1438, \"end\": 1448, \"title\": \"http://dbpedia.org/resource/Strasbourg\", \"score\": 0.9996644362329598, \"rank\": 0.0003356671899408472, \"text\": \"Strasbourg\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Strasbourg\", \"dbpedia\": \"http://dbpedia.org/resource/Strasbourg\"}, {\"begin\": 1474, \"end\": 1477, \"title\": \"http://dbpedia.org/resource/Agence_France-Presse\", \"score\": 0.9999770238864326, \"rank\": 1.9261345954207397e-05, \"text\": \"AFP\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Agence_France-Presse\", \"dbpedia\": \"http://