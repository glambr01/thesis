102}, {\"ngram\": \"athletes\", \"from\": 1107, \"to\": 1115}, {\"ngram\": \"the science\", \"from\": 1126, \"to\": 1137}, {\"ngram\": \"the dire warnings\", \"from\": 1147, \"to\": 1164}, {\"ngram\": \"climate scientists\", \"from\": 1170, \"to\": 1188}, {\"ngram\": \"our proximity\", \"from\": 1195, \"to\": 1208}, {\"ngram\": \"environmental catastrophe\", \"from\": 1212, \"to\": 1237}, {\"ngram\": \"the sober design\", \"from\": 1242, \"to\": 1258}, {\"ngram\": \"buildings\", \"from\": 1262, \"to\": 1271}, {\"ngram\": \"air conditioning\", \"from\": 1282, \"to\": 1298}]}, {\"sentence\": \"This innovative approach has not been widely accepted.\", \"from\": 1313, \"to\": 1367, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"This innovative approach\", \"from\": 1313, \"to\": 1337}]}, {\"sentence\": \"Some Olympic Committees, such as Australia, Brazil, Canada, and Norway, are still skeptical.\", \"from\": 1368, \"to\": 1460, \"entities\": [{\"begin\": 1401, \"end\": 1410, \"title\": \"http://dbpedia.org/resource/Australia\", \"score\": 0.999881069237883, \"rank\": 0.00011894311226204345, \"text\": \"Australia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Australia\", \"dbpedia\": \"http://dbpedia.org/resource/Australia\"}, {\"begin\": 1412, \"end\": 1418, \"title\": \"http://dbpedia.org/resource/Brazil\", \"score\": 0.9993435212226525, \"rank\": 0.0006527068104345286, \"text\": \"Brazil\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Brazil\", \"dbpedia\": \"http://dbpedia.org/resource/Brazil\"}, {\"begin\": 1420, \"end\": 1426, \"title\": \"http://dbpedia.org/resource/Canada\", \"score\": 0.9999999990977813, \"rank\": 4.236750497462922e-10, \"text\": \"Canada\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Canada\", \"dbpedia\": \"http://dbpedia.org/resource/Canada\"}, {\"begin\": 1432, \"end\": 1438, \"title\": \"http://dbpedia.org/resource/Norway\", \"score\": 0.9995560239027131, \"rank\": 0.0004439