54}]}, {\"sentence\": \"The boat, moored between the Grand Palais and the Place de la Concorde in the city center, is meant to be a safe space for LGBTQ athletes and visitors during the Olympics and Paralympics.\", \"from\": 458, \"to\": 645, \"entities\": [{\"begin\": 508, \"end\": 528, \"title\": \"http://dbpedia.org/resource/Place_de_la_Concorde\", \"score\": 0.9999999993901838, \"rank\": 6.098722279156092e-10, \"text\": \"Place de la Concorde\", \"types\": [\"Q34442\"], \"wikid\": \"http://dbpedia.org/resource/Place_de_la_Concorde\", \"dbpedia\": \"http://dbpedia.org/resource/Place_de_la_Concorde\"}, {\"begin\": 581, \"end\": 586, \"title\": \"http://dbpedia.org/resource/LGBT\", \"score\": 0.9976106644904054, \"rank\": 0.002357453222670316, \"text\": \"LGBTQ\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/LGBT\", \"dbpedia\": \"http://dbpedia.org/resource/LGBT\"}], \"noun_phrases\": [{\"ngram\": \"The boat\", \"from\": 458, \"to\": 466}, {\"ngram\": \"the Grand Palais\", \"from\": 483, \"to\": 499}, {\"ngram\": \"the city center\", \"from\": 532, \"to\": 547}, {\"ngram\": \"a safe space\", \"from\": 564, \"to\": 576}, {\"ngram\": \"visitors\", \"from\": 600, \"to\": 608}, {\"ngram\": \"the Olympics\", \"from\": 616, \"to\": 628}, {\"ngram\": \"Paralympics\", \"from\": 633, \"to\": 644}]}, {\"sentence\": \"\\\"Francewill guarantee that everyone feels like they belong in the celebration,\\\" French Equality Minister Aurore Berg\\u00e9 said at the inauguration.\", \"from\": 647, \"to\": 790, \"entities\": [{\"begin\": 727, \"end\": 733, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9976641290728867, \"rank\": 0.0020928969352092233, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 752, \"end\": 764, \"title\": \"http://dbpedia.org/resource/Aurore_Berg\\u00e9\", \"score\": 0.9999999682509048, \"rank\"