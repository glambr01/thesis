ities\": [{\"begin\": 14865, \"end\": 14870, \"title\": \"http://dbpedia.org/resource/United_States_Anti-Doping_Agency\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"USADA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_States_Anti-Doping_Agency\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_Anti-Doping_Agency\"}, {\"begin\": 14921, \"end\": 14938, \"title\": \"http://dbpedia.org/resource/Paralympic_sports\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Paralympic sports\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Paralympic_sports\", \"dbpedia\": \"http://dbpedia.org/resource/Paralympic_sports\"}], \"noun_phrases\": [{\"ngram\": \"anti-doping rules\", \"from\": 14883, \"to\": 14900}, {\"ngram\": \"prescription painkillers\", \"from\": 14950, \"to\": 14974}, {\"ngram\": \"antihistamines\", \"from\": 14979, \"to\": 14993}, {\"ngram\": \"Marks\", \"from\": 15003, \"to\": 15008}, {\"ngram\": \"her symptoms\", \"from\": 15019, \"to\": 15031}, {\"ngram\": \"the-counter\", \"from\": 15051, \"to\": 15062}, {\"ngram\": \"holistic treatment\", \"from\": 15078, \"to\": 15096}]}, {\"sentence\": \"Those methods didn\\u00e2\\u0080\\u0099t do much.\", \"from\": 15098, \"to\": 15129, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Those methods\", \"from\": 15098, \"to\": 15111}]}, {\"sentence\": \"Nevertheless, she finished the Sunset event by placing second on her 21st birthday, telling reporters she just had a minor ear infection\\u00e2\\u0080\\u0094but she was suffering.\", \"from\": 15130, \"to\": 15291, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the Sunset event\", \"from\": 15157, \"to\": 15173}, {\"ngram\": \"her 21st birthday\", \"from\": 15195, \"to\": 15212}, {\"ngram\": \"reporters\", \"from\": 15222, \"to\": 15231}, {\"ngram\": \"a minor ear\", \"from\": 15245, \"to\": 15256}]}, {\"sentence\": \"Throughout the season she postponed multiple flights, spent entire days in bed and went virtuall