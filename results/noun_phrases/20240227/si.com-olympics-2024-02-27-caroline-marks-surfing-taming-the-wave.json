urn.\", \"from\": 3505, \"to\": 3537, \"entities\": [{\"begin\": 3509, \"end\": 3517, \"title\": \"http://dbpedia.org/resource/Caroline_Kennedy\", \"score\": 0.9992203555896915, \"rank\": 0.0007789552874557228, \"text\": \"Caroline\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Caroline_Kennedy\", \"dbpedia\": \"http://dbpedia.org/resource/Caroline_Kennedy\"}], \"noun_phrases\": [{\"ngram\": \"energy\", \"from\": 3522, \"to\": 3528}]}, {\"sentence\": \"When Sarah went for walks on the beach, Caroline \\u00e2\\u0080\\u009cran laps around me,\\u00e2\\u0080\\u009d Sarah says, \\u00e2\\u0080\\u009cfor miles and miles.\\u00e2\\u0080\\u009d At 8, Caroline\\u00e2\\u0080\\u0099s love of horses gave way to passion for the waves.\", \"from\": 3538, \"to\": 3721, \"entities\": [{\"begin\": 3543, \"end\": 3548, \"title\": \"http://dbpedia.org/resource/Sarah_Jane_Smith\", \"score\": 0.9741641969566801, \"rank\": 0.026449972968817494, \"text\": \"Sarah\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Sarah_Jane_Smith\", \"dbpedia\": \"http://dbpedia.org/resource/Sarah_Jane_Smith\"}, {\"begin\": 3578, \"end\": 3586, \"title\": \"http://dbpedia.org/resource/Caroline_Kennedy\", \"score\": 0.9992203555896915, \"rank\": 0.0007789552874557228, \"text\": \"Caroline\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Caroline_Kennedy\", \"dbpedia\": \"http://dbpedia.org/resource/Caroline_Kennedy\"}, {\"begin\": 3613, \"end\": 3618, \"title\": \"http://dbpedia.org/resource/Sarah_Jane_Smith\", \"score\": 0.9741641969566801, \"rank\": 0.026449972968817494, \"text\": \"Sarah\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Sarah_Jane_Smith\", \"dbpedia\": \"http://dbpedia.org/resource/Sarah_Jane_Smith\"}], \"noun_phrases\": [{\"ngram\": \"walks\", \"from\": 3558, \"to\": 3563}, {\"ngram\": \"the beac