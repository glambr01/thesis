 {\"sentence\": \"Most of it was good.\", \"from\": 8266, \"to\": 8286, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"But some of it wasn\\u00e2\\u0080\\u0099t.\", \"from\": 8287, \"to\": 8311, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"And what wasn\\u00e2\\u0080\\u0099t good got to her.\", \"from\": 8312, \"to\": 8346, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"what wasn\\u00e2\\u0080\\u0099t good\", \"from\": 8316, \"to\": 8334}]}, {\"sentence\": \"\\u00e2\\u0080\\u009cYou have people that love you, and you have people that hate you,\\u00e2\\u0080\\u009d Marks says.\", \"from\": 8348, \"to\": 8431, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"\\u00e2\\u0080\\u009cYou\", \"from\": 8348, \"to\": 8354}, {\"ngram\": \"people\", \"from\": 8360, \"to\": 8366}, {\"ngram\": \"people\", \"from\": 8395, \"to\": 8401}, {\"ngram\": \"Marks\", \"from\": 8420, \"to\": 8425}]}, {\"sentence\": \"\\u00e2\\u0080\\u009cAnd you have people that think you look good, and you know, people that think you don\\u00e2\\u0080\\u0099t look good.\", \"from\": 8432, \"to\": 8535, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"people\", \"from\": 8448, \"to\": 8454}]}, {\"sentence\": \"And that\\u00e2\\u0080\\u0099s hard, because to me, there could be 99 positive comments, but it\\u00e2\\u0080\\u0099s so easy to fixate on the negative one.\\u00e2\\u0080\\u009d Then there was Instagram.\", \"from\": 8536, \"to\": 8686, \"entities\": [{\"begin\": 8676, \"end\": 8685, \"title\": \"http://dbpedia.org/resource/Instagram\", \"score\": 1.0, \"rank\": 6.0313099763339795e-78, \"text\": \"Instagram\", \"types\": [\"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Instagram\", \"dbpedia\": \"http://dbpedia.org/resource/Instagram\"}], \"noun_phrases\": [{\"ngram\": \"99 positive comments\", \"from\": 8585, \"to\": 8605}, {\"ngram\": \"it\\u00e2\\u0080\\u0099s\", \"from\": 8611, \"to\": 8617}, {\"ngram\": \"the negative one.\\u00e2\\u0080\\u009d\",