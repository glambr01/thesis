"{\"uid\": \"rte.ie-sport-paris-2024-2024-0311-1437273-four-countries-face-stringent-testing-ahead-of-olympics\", \"noun_phrases\": [{\"sentence\": \"Athletes from Brazil, Ecuador, Peru and Portugal will face more stringent out-of-competition (OOC) testing to be eligible for the Paris Olympics as their national testing programmes are not sufficient, the Athletics Integrity Unit (AIU) said.\", \"from\": 0, \"to\": 242, \"entities\": [{\"begin\": 14, \"end\": 20, \"title\": \"http://dbpedia.org/resource/Brazil\", \"score\": 0.8907703044712278, \"rank\": 0.12185887634678934, \"text\": \"Brazil\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Brazil\", \"dbpedia\": \"http://dbpedia.org/resource/Brazil\"}, {\"begin\": 22, \"end\": 29, \"title\": \"http://dbpedia.org/resource/Ecuador\", \"score\": 0.9837612418398467, \"rank\": 0.01644337093868912, \"text\": \"Ecuador\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ecuador\", \"dbpedia\": \"http://dbpedia.org/resource/Ecuador\"}, {\"begin\": 31, \"end\": 35, \"title\": \"http://dbpedia.org/resource/Peru_national_football_team\", \"score\": 0.6055413711949255, \"rank\": 0.6514117047487309, \"text\": \"Peru\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Peru_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Peru_national_football_team\"}, {\"begin\": 40, \"end\": 48, \"title\": \"http://dbpedia.org/resource/Portugal_national_football_team\", \"score\": 0.8442755349523927, \"rank\": 0.18247518586839462, \"text\": \"Portugal\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Portugal_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Portugal_national_football_team\"}, {\"begin\": 206, \"end\": 230, \"title\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Athletics Integrity Unit\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\", \"dbpedia\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\"}, {\"begin\": 232, \"end\": 235, \"title\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\", \"score\": 0.6818959149198167, \"rank\": 0.4664984013194535, \"text\": \"AIU\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\", \"dbpedia\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\"}], \"noun_phrases\": [{\"ngram\": \"Athletes\", \"from\": 0, \"to\": 8}, {\"ngram\": \"competition\", \"from\": 81, \"to\": 92}, {\"ngram\": \"the Paris Olympics\", \"from\": 126, \"to\": 144}, {\"ngram\": \"their national testing programmes\", \"from\": 148, \"to\": 181}]}, {\"sentence\": \"The decision comes after the World Athletics Council approved the recommendations from the AIU board to impose \\\"tougher testing requirements on those federations\\\" before the Olympics begin on 26 July.\", \"from\": 244, \"to\": 444, \"entities\": [{\"begin\": 273, \"end\": 288, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 1.0, \"rank\": 9.791732313501036e-16, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}, {\"begin\": 335, \"end\": 338, \"title\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\", \"score\": 0.6818959149198167, \"rank\": 0.4664984013194535, \"text\": \"AIU\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\", \"dbpedia\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\"}], \"noun_phrases\": [{\"ngram\": \"The decision\", \"from\": 244, \"to\": 256}, {\"ngram\": \"the recommendations\", \"from\": 306, \"to\": 325}, {\"ngram\": \"\\\"tougher testing requirements\", \"from\": 355, \"to\": 384}, {\"ngram\": \"those federations\", \"from\": 388, \"to\": 405}, {\"ngram\": \"the Olympics\", \"from\": 414, \"to\": 426}, {\"ngram\": \"26 July\", \"from\": 436, \"to\": 443}]}, {\"sentence\": \"\\\"The four federations received clear warnings from the AIU about the insufficiency of their national testing programmes after the World Athletics Championships 2022 in Eugene,\\\" the AIU said in a statement.\", \"from\": 446, \"to\": 651, \"entities\": [{\"begin\": 501, \"end\": 504, \"title\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\", \"score\": 0.6818959149198167, \"rank\": 0.4664984013194535, \"text\": \"AIU\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\", \"dbpedia\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\"}, {\"begin\": 627, \"end\": 630, \"title\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\", \"score\": 0.6818959149198167, \"rank\": 0.4664984013194535, \"text\": \"AIU\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\", \"dbpedia\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\"}], \"noun_phrases\": [{\"ngram\": \"The four federations\", \"from\": 447, \"to\": 467}, {\"ngram\": \"clear warnings\", \"from\": 477, \"to\": 491}, {\"ngram\": \"the insufficiency\", \"from\": 511, \"to\": 528}, {\"ngram\": \"their national testing programmes\", \"from\": 532, \"to\": 565}, {\"ngram\": \"the World Athletics Championships\", \"from\": 572, \"to\": 605}, {\"ngram\": \"Eugene\", \"from\": 614, \"to\": 620}, {\"ngram\": \"a statement\", \"from\": 639, \"to\": 650}]}, {\"sentence\": \"\\\"All four failed to ensure that there was proportionate OOC testing for their teams at the following World Athletics Championships in Budapest 2023.\\\"\", \"from\": 653, \"to\": 802, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"proportionate OOC testing\", \"from\": 695, \"to\": 720}, {\"ngram\": \"their teams\", \"from\": 725, \"to\": 736}, {\"ngram\": \"the following World Athletics Championships\", \"from\": 740, \"to\": 783}, {\"ngram\": \"Budapest\", \"from\": 787, \"to\": 795}]}, {\"sentence\": \"\\\"The Council has subsequently accepted the AIU's call for all four federations to have testing eligibility conditions imposed on their athletes in order to participate in Paris 2024.\\\"\", \"from\": 804, \"to\": 987, \"entities\": [{\"begin\": 847, \"end\": 850, \"title\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\", \"score\": 0.6818959149198167, \"rank\": 0.4664984013194535, \"text\": \"AIU\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\", \"dbpedia\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\"}, {\"begin\": 975, \"end\": 985, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.6701461812279897e-14, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"The Council\", \"from\": 805, \"to\": 816}, {\"ngram\": \"all four federations\", \"from\": 862, \"to\": 882}, {\"ngram\": \"eligibility conditions\", \"from\": 899, \"to\": 921}, {\"ngram\": \"their athletes\", \"from\": 933, \"to\": 947}, {\"ngram\": \"order\", \"from\": 951, \"to\": 956}]}, {\"sentence\": \"The stringent conditions include athletes having undergone at least three no notice out-of-competition tests before 4 July while each of those tests should have been conducted at least three weeks apart.\", \"from\": 989, \"to\": 1192, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The stringent conditions\", \"from\": 989, \"to\": 1013}, {\"ngram\": \"athletes\", \"from\": 1022, \"to\": 1030}, {\"ngram\": \"competition\", \"from\": 1080, \"to\": 1091}, {\"ngram\": \"4 July\", \"from\": 1105, \"to\": 1111}, {\"ngram\": \"those tests\", \"from\": 1126, \"to\": 1137}]}, {\"sentence\": \"\\\"We are pleased with the council's decision to support the AIU recommendations,\\\" AIU Chair David Howman said.\", \"from\": 1194, \"to\": 1303, \"entities\": [{\"begin\": 1253, \"end\": 1256, \"title\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\", \"score\": 0.6818959149198167, \"rank\": 0.4664984013194535, \"text\": \"AIU\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\", \"dbpedia\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\"}], \"noun_phrases\": [{\"ngram\": \"the council's decision\", \"from\": 1215, \"to\": 1237}, {\"ngram\": \"AIU Chair David Howman\", \"from\": 1275, \"to\": 1297}]}, {\"sentence\": \"\\\"This action is tough, but necessary as we did not receive an adequate response from these federations to clear warnings we gave in the lead up to the World Athletics Championships last year.\", \"from\": 1305, \"to\": 1496, \"entities\": [{\"begin\": 1456, \"end\": 1485, \"title\": \"http://dbpedia.org/resource/World_Athletics_Championships\", \"score\": 0.9937402563198576, \"rank\": 0.005939233957208591, \"text\": \"World Athletics Championships\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics_Championships\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics_Championships\"}], \"noun_phrases\": [{\"ngram\": \"This action\", \"from\": 1306, \"to\": 1317}, {\"ngram\": \"an adequate response\", \"from\": 1364, \"to\": 1384}, {\"ngram\": \"these federations\", \"from\": 1390, \"to\": 1407}, {\"ngram\": \"clear warnings\", \"from\": 1411, \"to\": 1425}, {\"ngram\": \"the lead\", \"from\": 1437, \"to\": 1445}]}, {\"sentence\": \"\\\"In this Olympic year, we trust this will be a reminder to all member federations that the AIU and World Athletics are extremely serious about ensuring a level-playing field for athletes.\\\"\", \"from\": 1498, \"to\": 1686, \"entities\": [{\"begin\": 1589, \"end\": 1592, \"title\": \"http://dbpedia.org/resource/Athletics_Integrity_Unit\", \"score\": 0.6818959149198167, \"rank\": 0.4664984013194535, \"text\": \"AIU\", \