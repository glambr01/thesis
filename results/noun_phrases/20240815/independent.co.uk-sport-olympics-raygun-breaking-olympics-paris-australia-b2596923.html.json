hrases\": [{\"ngram\": \"fun\", \"from\": 1029, \"to\": 1032}]}, {\"sentence\": \"I worked my butt off preparing for the Olympics and I gave my all.\", \"from\": 1065, \"to\": 1131, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my butt\", \"from\": 1074, \"to\": 1081}, {\"ngram\": \"the Olympics\", \"from\": 1100, \"to\": 1112}]}, {\"sentence\": \"Truly.\", \"from\": 1132, \"to\": 1138, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"\\\"And I am honoured to have been a part of the Australian Olympic team; to be a part of breaking's Olympic debut.\\\"\", \"from\": 1140, \"to\": 1253, \"entities\": [{\"begin\": 1186, \"end\": 1209, \"title\": \"http://dbpedia.org/resource/Australia_at_the_Olympics\", \"score\": 0.9873651690715508, \"rank\": 0.012796512702918091, \"text\": \"Australian Olympic team\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Australia_at_the_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Australia_at_the_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"a part\", \"from\": 1172, \"to\": 1178}, {\"ngram\": \"a part\", \"from\": 1217, \"to\": 1223}, {\"ngram\": \"breaking's Olympic debut\", \"from\": 1227, \"to\": 1251}]}, {\"sentence\": \"After Gunn's performance, a petition was created calling for an apology from the athlete and Australia's Olympic chef de mission Anna Meares.\", \"from\": 1255, \"to\": 1396, \"entities\": [{\"begin\": 1261, \"end\": 1265, \"title\": \"http://dbpedia.org/resource/Clan_Gunn\", \"score\": 0.9978790782758802, \"rank\": 0.0020410441003911733, \"text\": \"Gunn\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Clan_Gunn\", \"dbpedia\": \"http://dbpedia.org/resource/Clan_Gunn\"}, {\"begin\": 1348, \"end\": 1357, \"title\": \"http://dbpedia.org/resource/Australia\", \"score\": 0.9947316287029154, \"rank\": 0.0017594869601661677, \"text\": \"Australia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Australia\", \"dbpedia\": \"http://dbpedia.org/resource/Australia\