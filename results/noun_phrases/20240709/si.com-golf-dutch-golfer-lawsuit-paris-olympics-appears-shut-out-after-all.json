\": 568}, {\"ngram\": \"someone\", \"from\": 605, \"to\": 612}, {\"ngram\": \"another country\", \"from\": 623, \"to\": 638}]}, {\"sentence\": \"\\u00e2\\u0080\\u009cWhen the International Golf Federation (IGF) received notification of Joost Luiten's court ruling in the Netherlands and his entry from the Netherlands\\u00e2\\u0080\\u0099 National Olympic Committee (NOC*NSF), his unused quota spot had already been reallocated pursuant to the IGF\\u00e2\\u0080\\u0099s published qualification procedures,\\u00e2\\u0080\\u009d the IGF said Tuesday in a statement.\", \"from\": 641, \"to\": 987, \"entities\": [{\"begin\": 653, \"end\": 682, \"title\": \"http://dbpedia.org/resource/International_Golf_Federation\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Golf Federation\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/International_Golf_Federation\", \"dbpedia\": \"http://dbpedia.org/resource/International_Golf_Federation\"}, {\"begin\": 714, \"end\": 726, \"title\": \"http://dbpedia.org/resource/Joost_Luiten\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Joost Luiten\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q13156709\"], \"wikid\": \"http://dbpedia.org/resource/Joost_Luiten\", \"dbpedia\": \"http://dbpedia.org/resource/Joost_Luiten\"}, {\"begin\": 749, \"end\": 760, \"title\": \"http://dbpedia.org/resource/Netherlands\", \"score\": 0.9968107947644275, \"rank\": 0.003056073519386678, \"text\": \"Netherlands\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Netherlands\", \"dbpedia\": \"http://dbpedia.org/resource/Netherlands\"}, {\"begin\": 799, \"end\": 825, \"title\": \"http://dbpedia.org/resource/National_Olympic_Committee\", \"score\": 1.0, \"rank\": 5.342799806994686e-16, \"text\": \"National Olympic Committee\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/National_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/National_Olympic_Committee\"}, {\"begin\": 955, \"end\": 958, \"title\