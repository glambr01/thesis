"{\"uid\": \"si.com-golf-dutch-golfer-lawsuit-paris-olympics-appears-shut-out-after-all\", \"noun_phrases\": [{\"sentence\": \"The wild journey that a Dutch golfer took to try to play in the Olympics looks as if it won\\u00e2\\u0080\\u0099t end in Paris after all.\", \"from\": 0, \"to\": 119, \"entities\": [{\"begin\": 24, \"end\": 29, \"title\": \"http://dbpedia.org/resource/Dutch_language\", \"score\": 0.7383356638692999, \"rank\": 0.31910323612059777, \"text\": \"Dutch\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Dutch_language\", \"dbpedia\": \"http://dbpedia.org/resource/Dutch_language\"}, {\"begin\": 103, \"end\": 108, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999896024373212, \"rank\": 1.0397670863242461e-05, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"The wild journey\", \"from\": 0, \"to\": 16}, {\"ngram\": \"the Olympics\", \"from\": 60, \"to\": 72}]}, {\"sentence\": \"Joost Luiten, 38 and a six-time winner on the DP World Tour, was originally not going to compete in Paris for the Netherlands despite meeting Olympic ranking criteria.\", \"from\": 121, \"to\": 288, \"entities\": [{\"begin\": 167, \"end\": 175, \"title\": \"http://dbpedia.org/resource/DP_World\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"DP World\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/DP_World\", \"dbpedia\": \"http://dbpedia.org/resource/DP_World\"}, {\"begin\": 221, \"end\": 226, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999896024373212, \"rank\": 1.0397670863242461e-05, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 235, \"end\": 246, \"title\": \"http://dbpedia.org/resource/Netherlands\", \"score\": 0.996810794764