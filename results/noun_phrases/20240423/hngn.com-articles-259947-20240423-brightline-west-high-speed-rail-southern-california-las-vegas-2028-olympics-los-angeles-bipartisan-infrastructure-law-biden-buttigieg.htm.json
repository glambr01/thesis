link\"}], \"noun_phrases\": [{\"ngram\": \"218 miles\", \"from\": 672, \"to\": 681}, {\"ngram\": \"track\", \"from\": 685, \"to\": 690}, {\"ngram\": \"the median\", \"from\": 694, \"to\": 704}, {\"ngram\": \"Interstate\", \"from\": 708, \"to\": 718}]}, {\"sentence\": \"The Brightline trains are expected to operate at speeds of up to 200 mph, which is about the same as high-speed trains in Europe and Japan.\", \"from\": 845, \"to\": 984, \"entities\": [{\"begin\": 849, \"end\": 859, \"title\": \"http://dbpedia.org/resource/Brightline\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Brightline\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Brightline\", \"dbpedia\": \"http://dbpedia.org/resource/Brightline\"}, {\"begin\": 978, \"end\": 983, \"title\": \"http://dbpedia.org/resource/Japan\", \"score\": 0.8575860678923991, \"rank\": 0.165044061044411, \"text\": \"Japan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Japan\", \"dbpedia\": \"http://dbpedia.org/resource/Japan\"}], \"noun_phrases\": [{\"ngram\": \"speeds\", \"from\": 894, \"to\": 900}, {\"ngram\": \"up to 200 mph\", \"from\": 904, \"to\": 917}, {\"ngram\": \"high-speed trains\", \"from\": 946, \"to\": 963}, {\"ngram\": \"Europe\", \"from\": 967, \"to\": 973}]}, {\"sentence\": \"It's also one-third faster than Amtrak's Acela trains, which run between Washington, D.C., and Boston, and are America's speediest.\", \"from\": 986, \"to\": 1117, \"entities\": [{\"begin\": 1018, \"end\": 1024, \"title\": \"http://dbpedia.org/resource/Amtrak\", \"score\": 0.9999999999813554, \"rank\": 1.825823532017534e-11, \"text\": \"Amtrak\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Amtrak\", \"dbpedia\": \"http://dbpedia.org/resource/Amtrak\"}, {\"begin\": 1027, \"end\": 1032, \"title\": \"http://dbpedia.org/resource/Acela\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Acela\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Acela\", \"dbped