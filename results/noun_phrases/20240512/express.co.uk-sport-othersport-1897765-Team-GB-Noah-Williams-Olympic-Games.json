"to\": 2527, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"everyone\", \"from\": 2513, \"to\": 2521}]}, {\"sentence\": \"\\\"Anything can happen on the day and we have done really well this year so I hope I can help him out.\", \"from\": 2529, \"to\": 2629, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Anything\", \"from\": 2530, \"to\": 2538}, {\"ngram\": \"the day\", \"from\": 2553, \"to\": 2560}]}, {\"sentence\": \"\\\"Individually it's quite lonely, synchro is the closest we can get to a team sport and it's a lot more enjoyable, sharing the whole event with someone,\\\" he said.\", \"from\": 2631, \"to\": 2792, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"synchro\", \"from\": 2664, \"to\": 2671}, {\"ngram\": \"a team sport\", \"from\": 2701, \"to\": 2713}, {\"ngram\": \"the whole event\", \"from\": 2753, \"to\": 2768}, {\"ngram\": \"someone\", \"from\": 2774, \"to\": 2781}]}, {\"sentence\": \"\\\"You get to share the pressure, it does not feel as daunting, especially when it's Tom.\", \"from\": 2794, \"to\": 2881, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the pressure\", \"from\": 2812, \"to\": 2824}, {\"ngram\": \"Tom\", \"from\": 2877, \"to\": 2880}]}, {\"sentence\": \"I get to just be there so I like it so far.\", \"from\": 2882, \"to\": 2925, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"\\\"Tom is a massive name and the pressure is on him - that's good for me and how I compete.\", \"from\": 2927, \"to\": 3016, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Tom\", \"from\": 2928, \"to\": 2931}, {\"ngram\": \"a massive name\", \"from\": 2935, \"to\": 2949}, {\"ngram\": \"the pressure\", \"from\": 2954, \"to\": 2966}]}, {\"sentence\": \"\\\"At that first Olympics, I had to wait until the last day to compete so it was literally just me and Tom.\", \"from\": 3018, \"to\": 3123, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"that first Olympics\", \"from\": 3022, \"to\": 3041}, {\"ngram\": \"the last day\", \"from\": 3