"{\"uid\": \"rte.ie-sport-paralympics-2024-0901-1467750-paris-2024-triathlons-postponed-over-water-quality\", \"noun_phrases\": [{\"sentence\": \"The Paralympic triathlon events scheduled for Sunday have been postponed due to fresh concerns about the quality of water in the River Seine.\", \"from\": 0, \"to\": 141, \"entities\": [{\"begin\": 129, \"end\": 140, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"River Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"The Paralympic triathlon events\", \"from\": 0, \"to\": 31}, {\"ngram\": \"Sunday\", \"from\": 46, \"to\": 52}, {\"ngram\": \"fresh concerns\", \"from\": 80, \"to\": 94}, {\"ngram\": \"the quality\", \"from\": 101, \"to\": 112}, {\"ngram\": \"water\", \"from\": 116, \"to\": 121}]}, {\"sentence\": \"Eleven events were due to start with a swim leg in the river on Sunday morning, but organisers said they had been delayed due to a decrease in water quality following rain in the previous two days.\", \"from\": 143, \"to\": 340, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Eleven events\", \"from\": 143, \"to\": 156}, {\"ngram\": \"a swim leg\", \"from\": 180, \"to\": 190}, {\"ngram\": \"the river\", \"from\": 194, \"to\": 203}, {\"ngram\": \"Sunday morning\", \"from\": 207, \"to\": 221}, {\"ngram\": \"organisers\", \"from\": 227, \"to\": 237}, {\"ngram\": \"a decrease\", \"from\": 272, \"to\": 282}, {\"ngram\": \"water quality\", \"from\": 286, \"to\": 299}, {\"ngram\": \"rain\", \"from\": 310, \"to\": 314}, {\"ngram\": \"the previous two days\", \"from\": 318, \"to\": 339}]}, {\"sentence\": \"Chloe MacCombeand her twin sisterJudithhad been due to represent Team Ireland in the PTVI para triathlon, along with their guides, whileCassie Cavahad also been due to compete in the PTS4 race.\", \"from\": 342, \"to\": 535, \"entities\": [{\"begin\": 342, \"end\": 347, \"title\": \"http://dbpedia.org/resource/Chloe_O'Brian\", \"score\": 0.9257742671529706, \"rank\": 0.0656549045986673, \"text\": \"Chloe\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Chloe_O'Brian\", \"dbpedia\": \"http://dbpedia.org/resource/Chloe_O'Brian\"}, {\"begin\": 407, \"end\": 419, \"title\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\", \"score\": 1.0, \"rank\": 1.2148182814979085e-14, \"text\": \"Team Ireland\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"her twin\", \"from\": 360, \"to\": 368}, {\"ngram\": \"the PTVI para triathlon\", \"from\": 423, \"to\": 446}, {\"ngram\": \"their guides\", \"from\": 459, \"to\": 471}, {\"ngram\": \"whileCassie Cavahad\", \"from\": 473, \"to\": 492}, {\"ngram\": \"the PTS4 race\", \"from\": 521, \"to\": 534}]}, {\"sentence\": \"But they will all have to wait an extra 24 hours before getting their Paralympic Games underway.\", \"from\": 536, \"to\": 632, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an extra 24 hours\", \"from\": 567, \"to\": 584}, {\"ngram\": \"their Paralympic Games\", \"from\": 600, \"to\": 622}]}, {\"sentence\": \"The triathlon events have been rescheduled for Monday if continued testing shows an improvement in the water quality.\", \"from\": 634, \"to\": 751, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The triathlon events\", \"from\": 634, \"to\": 654}, {\"ngram\": \"Monday\", \"from\": 681, \"to\": 687}, {\"ngram\": \"continued testing\", \"from\": 691, \"to\": 708}, {\"ngram\": \"an improvement\", \"from\": 715, \"to\": 729}, {\"ngram\": \"the water quality\", \"from\": 733, \"to\": 750}]}, {\"sentence\": \"A statement from World Triathlon confirmed the postponement after a meeting with Paris 2024 representatives and French authorities at 3.30am on Sunday.\", \"from\": 753, \"to\": 904, \"entities\": [{\"begin\": 770, \"end\": 785, \"title\": \"http://dbpedia.org/resource/World_Triathlon\", \"score\": 0.9999999843012121, \"rank\": 1.569887707742188e-08, \"text\": \"World Triathlon\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/World_Triathlon\", \"dbpedia\": \"http://dbpedia.org/resource/World_Triathlon\"}, {\"begin\": 865, \"end\": 871, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9467765232567785, \"rank\": 0.04270546536315937, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"A statement\", \"from\": 753, \"to\": 764}, {\"ngram\": \"the postponement\", \"from\": 796, \"to\": 812}, {\"ngram\": \"a meeting\", \"from\": 819, \"to\": 828}, {\"ngram\": \"Paris\", \"from\": 834, \"to\": 839}, {\"ngram\": \"representatives\", \"from\": 845, \"to\": 860}, {\"ngram\": \"Sunday\", \"from\": 897, \"to\": 903}]}, {\"sentence\": \"pic.twitter.com/jMl0aX2p0C \\\"The latest tests show a decrease in water quality in the river following the rain episodes over the last two days,\\\" the statement read, saying the events would go ahead on Monday if the water tests complied with \\\"established World Triathlon thresholds\\\".\", \"from\": 908, \"to\": 1192, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The latest tests\", \"from\": 936, \"to\": 952}, {\"ngram\": \"a decrease\", \"from\": 958, \"to\": 968}, {\"ngram\": \"water quality\", \"from\": 972, \"to\": 985}, {\"ngram\": \"the river\", \"from\": 989, \"to\": 998}, {\"ngram\": \"the last two days\", \"from\": 1032, \"to\": 1049}, {\"ngram\": \"the statement\", \"from\": 1052, \"to\": 1065}, {\"ngram\": \"the events\", \"from\": 1079, \"to\": 1089}, {\"ngram\": \"Monday\", \"from\": 1108, \"to\": 1114}, {\"ngram\": \"the water tests\", \"from\": 1118, \"to\": 1133}]}, {\"sentence\": \"\\\"Paris 2024 and World Triathlon rei