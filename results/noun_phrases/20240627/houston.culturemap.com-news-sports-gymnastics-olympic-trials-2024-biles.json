\": 4281, \"title\": \"http://dbpedia.org/resource/Houston_Rockets\", \"score\": 1.0, \"rank\": 7.244487687776986e-52, \"text\": \"Houston Rockets\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/Houston_Rockets\", \"dbpedia\": \"http://dbpedia.org/resource/Houston_Rockets\"}, {\"begin\": 4301, \"end\": 4308, \"title\": \"http://dbpedia.org/resource/Google_Play\", \"score\": 1.0, \"rank\": 7.444420804454277e-15, \"text\": \"Android\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Google_Play\", \"dbpedia\": \"http://dbpedia.org/resource/Google_Play\"}], \"noun_phrases\": [{\"ngram\": \"December\", \"from\": 4161, \"to\": 4169}, {\"ngram\": \"consumers\", \"from\": 4224, \"to\": 4233}]}, {\"sentence\": \"Available atSCHNPLUS.com, a subscription to SCHN+ allows sports fans to watch all Astros and Rockets games as well as behind-the-scenes features and other on-demand content.\", \"from\": 4343, \"to\": 4516, \"entities\": [{\"begin\": 4425, \"end\": 4431, \"title\": \"http://dbpedia.org/resource/Houston_Astros\", \"score\": 0.9999016703421006, \"rank\": 9.833932587499975e-05, \"text\": \"Astros\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/Houston_Astros\", \"dbpedia\": \"http://dbpedia.org/resource/Houston_Astros\"}], \"noun_phrases\": [{\"ngram\": \"Available atSCHNPLUS.com\", \"from\": 4343, \"to\": 4367}, {\"ngram\": \"a subscription\", \"from\": 4369, \"to\": 4383}, {\"ngram\": \"SCHN+\", \"from\": 4387, \"to\": 4392}, {\"ngram\": \"sports fans\", \"from\": 4400, \"to\": 4411}, {\"ngram\": \"the-scenes\", \"from\": 4468, \"to\": 4478}, {\"ngram\": \"-demand\", \"from\": 4500, \"to\": 4507}]}, {\"sentence\": \"It's priced at $19.99 per month or $199.99 annually (plus tax).\", \"from\": 4517, \"to\": 4580, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"month\", \"from\": 4543, \"to\": 4548}]}, {\"sentence\": \"People who watch Space City Network Network via their existing cable or satellite service will be able to access SCHN+ at no additional charge.\", \"from\": 4581, \"to\": 4724, \"entities\": [{\"begin\": 4598, \"end\": 4608, \"title\": \"http://dbpedia.org/resource/Space_City_(newspaper)\", \"score\": 0.9999999999949978, \"rank\": 0.0, \"text\": \"Space City\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/Space_City_(newspaper)\", \"dbpedia\": \"http://dbpedia.org/resource/Space_City_(newspaper)\"}], \"noun_phrases\": [{\"ngram\": \"People\", \"from\": 4581, \"to\": 4587}, {\"ngram\": \"their existing cable\", \"from\": 4629, \"to\": 4649}, {\"ngram\": \"satellite service\", \"from\": 4653, \"to\": 4670}, {\"ngram\": \"no additional charge\", \"from\": 4703, \"to\": 4723}]}, {\"sentence\": \"As the Houston Chroniclenotes, the Astros and Rockets were the only MLB and NBA teams not to offer a direct-to-consumer streaming option.\", \"from\": 4728, \"to\": 4865, \"entities\": [{\"begin\": 4735, \"end\": 4742, \"title\": \"http://dbpedia.org/resource/Houston\", \"score\": 0.999839526317117, \"rank\": 0.0001604970877510137, \"text\": \"Houston\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Houston\", \"dbpedia\": \"http://dbpedia.org/resource/Houston\"}, {\"begin\": 4763, \"end\": 4769, \"title\": \"http://dbpedia.org/resource/Houston_Astros\", \"score\": 0.9999016703421006, \"rank\": 9.833932587499975e-05, \"text\": \"Astros\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/Houston_Astros\", \"dbpedia\": \"http://dbpedia.org/resource/Houston_Astros\"}, {\"begin\": 4796, \"end\": 4799, \"title\": \"http://dbpedia.org/resource/MLB_Network\", \"score\": 0.9999256874344596, \"rank\": 6.889925931978989e-05, \"text\": \"MLB\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/MLB_Network\", \"dbpedia\": \"http://dbpedia.org/resource/MLB_Network\"}, {\"begin\": 4804, \"end\": 4807, \"title\": \"http://dbpedia.org/resource/National_Basketball_Association\", \"score\": 1.0, \"rank\": 5.65810350302824e-20, \"text\": \"NBA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/National_Basketball_Association\", \"dbpedia\": \"http://dbpedia.org/resource/National_Basketball_Association\"}], \"noun_phrases\": [{\"ngram\": \"Rockets\", \"from\": 4774, \"to\": 4781}, {\"ngram\": \"consumer\", \"from\": 4839, \"to\": 4847}]}, {\"sentence\": \"\\\"We are thrilled to offer another great option to ensure fans have access to watch games, and the SCHN+ streaming app makes it easier than ever to cheer on the Rockets,\\\" Rockets alternate governor Patrick Fertitta said in a statement.\", \"from\": 4867, \"to\": 5101, \"entities\": [{\"begin\": 5064, \"end\": 5071, \"title\": \"http://dbpedia.org/resource/Danica_Patrick\", \"score\": 0.9995763822881887, \"rank\": 0.00042377520080170197, \"text\": \"Patrick\", \"types\": [\"Q729\", \"Q5\", \"Q378622\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Danica_Patrick\", \"dbpedia\": \"http://dbpedia.org/resource/Danica_Patrick\"}], \"noun_phrases\": [{\"ngram\": \"another great option\", \"from\": 4893, \"to\": 4913}, {\"ngram\": \"fans\", \"from\": 4924, \"to\": 4928}, {\"ngram\": \"access\", \"from\": 4934, \"to\": 4940}, {\"ngram\": \"watch games\", \"from\": 4944, \"to\": 4955}, {\"ngram\": \"the SCHN+ streaming app\", \"from\": 4961, \"to\": 4984}, {\"ngram\": \"the Rockets\", \"from\": 5023, \"to\": 5034}, {\"ngram\": \"a statement\", \"from\": 5089, \"to\": 5100}]}, {\"sentence\": \"\\\"Providing fans with a convenient way to watch their favorite teams, along with our network's award-winning programming, was an essential addition.\", \"from\": 5102, \"to\": 5249, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"fans\", \"from\": 5113, \"to\": 5117}, {\"ngram\": \"a convenient way\", \"from\": 5123, \"to\": 5139}, {\"ngram\": \"th