"{\"uid\": \"rte.ie-sport-paris-2024-2024-0627-1456937-double-sprint-champion-thompson-herah-to-miss-olympics\", \"noun_phrases\": [{\"sentence\": \"Double Olympic sprint champion Elaine Thompson-Herah has withdrawn from the Jamaican trials due to an Achilles injury and will not defend her 100m and 200m titles at the Paris Games in August.\", \"from\": 0, \"to\": 192, \"entities\": [{\"begin\": 31, \"end\": 52, \"title\": \"http://dbpedia.org/resource/Elaine_Thompson-Herah\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Elaine Thompson-Herah\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Elaine_Thompson-Herah\", \"dbpedia\": \"http://dbpedia.org/resource/Elaine_Thompson-Herah\"}, {\"begin\": 76, \"end\": 84, \"title\": \"http://dbpedia.org/resource/Jamaicans\", \"score\": 0.9999998715784468, \"rank\": 1.2840599111036833e-07, \"text\": \"Jamaican\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Jamaicans\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaicans\"}, {\"begin\": 102, \"end\": 110, \"title\": \"http://dbpedia.org/resource/Achilles_tendon\", \"score\": 0.9999999902697709, \"rank\": 9.730308233366162e-09, \"text\": \"Achilles\", \"types\": [\"Q4936952\"], \"wikid\": \"http://dbpedia.org/resource/Achilles_tendon\", \"dbpedia\": \"http://dbpedia.org/resource/Achilles_tendon\"}], \"noun_phrases\": [{\"ngram\": \"Double Olympic sprint champion\", \"from\": 0, \"to\": 30}, {\"ngram\": \"her 100m\", \"from\": 138, \"to\": 146}, {\"ngram\": \"200m titles\", \"from\": 151, \"to\": 162}, {\"ngram\": \"the Paris Games\", \"from\": 166, \"to\": 181}, {\"ngram\": \"August\", \"from\": 185, \"to\": 191}]}, {\"sentence\": \"The Jamaican, who will celebrate her 32nd birthday on Friday, is one of the greatest sprinters of all time and was the first woman to win a back-to-back Olympic sprint double when she retained both titles in Tokyo three years ago.\", \"from\": 194, \"to\": 424, \"entities\": [{\"begin\": 198, \"end\": 206, \"title\": \"http://dbpedia.org/resource/Jamaicans\", \"score\": 0.9999998715784468, \"rank\": 1.2840599111036833e-07, \"text\": \"Jamaican\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Jamaicans\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaicans\"}, {\"begin\": 402, \"end\": 407, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.9999673897331279, \"rank\": 3.261131568163005e-05, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"her 32nd birthday\", \"from\": 227, \"to\": 244}, {\"ngram\": \"Friday\", \"from\": 248, \"to\": 254}, {\"ngram\": \"the greatest sprinters\", \"from\": 266, \"to\": 288}, {\"ngram\": \"all time\", \"from\": 292, \"to\": 300}, {\"ngram\": \"the first woman\", \"from\": 309, \"to\": 324}, {\"ngram\": \"back\", \"from\": 342, \"to\": 346}, {\"ngram\": \"both titles\", \"from\": 387, \"to\": 398}]}, {\"sentence\": \"Thompson-Herah last competed in the 200m in April 2023 and sustained the injury during the 100m at the New York Grand Prix earlier this month as she finished in 11.48 seconds.\", \"from\": 426, \"to\": 601, \"entities\": [{\"begin\": 529, \"end\": 537, \"title\": \"http://dbpedia.org/resource/New_York_GAA\", \"score\": 0.8874865306350579, \"rank\": 0.1267746933851456, \"text\": \"New York\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/New_York_GAA\", \"dbpedia\": \"http://dbpedia.org/resource/New_York_GAA\"}, {\"begin\": 538, \"end\": 548, \"title\": \"http://dbpedia.org/resource/ISU_Grand_Prix_of_Figure_Skating\", \"score\": 0.8604321763763592, \"rank\": 0.16192739859850216, \"text\": \"Grand Prix\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/ISU_Grand_Prix_of_Figure_Skating\", \"dbpedia\": \"http://dbpedia.org/resource/ISU_Grand_Prix_of_Figure_Skating\"}], \"noun_phrases\": [{\"ngram\": \"Thompson-Herah\", \"from\": 426, \"to\": 440}, {\"ngram\": \"the 200m\", \"from\": 458, \"to\": 466}, {\"ngram\": \"April\", \"from\": 470, \"to\": 475}, {\"ngram\": \"the injury\", \"from\": 495, \"to\": 505}, {\"ngram\": \"the 100m\", \"from\": 513, \"to\": 521}, {\"ngram\": \"11.48 seconds\", \"from\": 587, \"to\": 600}]}, {\"sentence\": \"\\\"It's never fun sharing news like this but at the New York Grand Prix, I felt something in the race and still insist to push, couple steps to the line I realise something is really wrong,\\\" the Jamaican wrote in an Instagram post\\\"I sat on the ground because I could not apply any pressure to the leg whatsoever as I was carried off the track.\", \"from\": 603, \"to\": 944, \"entities\": [{\"begin\": 796, \"end\": 804, \"title\": \"http://dbpedia.org/resource/Jamaicans\", \"score\": 0.9999998715784468, \"rank\": 1.2840599111036833e-07, \"text\": \"Jamaican\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Jamaicans\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaicans\"}], \"noun_phrases\": [{\"ngram\": \"fun sharing news\", \"from\": 615, \"to\": 631}, {\"ngram\": \"the New York Grand Prix\", \"from\": 649, \"to\": 672}, {\"ngram\": \"something\", \"from\": 681, \"to\": 690}, {\"ngram\": \"the race\", \"from\": 694, \"to\": 702}, {\"ngram\": \"the line\", \"from\": 745, \"to\": 753}, {\"ngram\": \"something\", \"from\": 764, \"to\": 773}, {\"ngram\": \"the ground\", \"from\": 841, \"to\": 851}, {\"ngram\": \"any pressure\", \"from\": 878, \"to\": 890}, {\"ngram\": \"the leg\", \"from\": 894, \"to\": 901}, {\"ngram\": \"the track\", \"from\": 934, \"to\": 943}]}, {\"sentence\": \"I went quickly to get (a) medical check-up, and to find out that I have a small tear on my Achilles tendon.\", \"from\": 945, \"to\": 1052, \"entities\": [{\"begin\": 1036, \"end\": 1044, \"title\": \"http://dbpedia.org/resource/Achilles_tendon\", \"score\": 0.9999999902697709, \"rank\": 9.730308233366162e-09, \"text\": \"Achilles\", \"types\": [\"Q4936952\"], \"wikid\": \"http://dbpedia.org/resource/Achilles_tendon\", \"dbpedia\": \"http://dbpedia.org/resource/Achilles_tendon\"}], \"noun_phrases\": [{\"ngram\": \"(a) medical check-up\", \"from\": 967, \"to\": 987}, {\"ngram\": \"a small tear\", \"from\": 1017, \"to\": 1029}]}, {\"sentence\": \"\\\"I got back home with a strong mindset to keep pushing and prepare for my national trials ... but the leg would not allow me to.\\\"\", \"from\": 1054, \"to\": 1183, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a strong mindset\", \"from\": 1076, \"to\": 1092}, {\"ngram\": \"my national trials\", \"from\": 1125, \"to\": 1143}, {\"ngram\": \"the leg\", \"from\": 1152, \"to\": 1159}]}, {\"sentence\": \"Thompson-Herah was also dogged by an Achilles injury after her astonishing sprint double at the 2016 Rio Olympics and she missed out on medals at the 2017 and 2019 world championships.\", \"from\": 1185, \"to\": 1369, \"entities\": [{\"begin\": 1222, \"end\": 1230, \"title\": \"http://dbpedia.org/resource/Achilles_tendon\", \"score\": 0.9999999902697709, \"rank\": 9.730308233366162e-09, \"text\": \"Achilles\", \"types\": [\"Q4936952\"], \"wikid\": \"http://dbpedia.org/resource/Achilles_tendon\", \"dbpedia\": \"http://dbpedia.org/resource/Achilles_tendon\"}], \"noun_phrases\": [{\"ngram\": \"Thompson-Herah\", \"from\": 1185, \"to\": 1199}, {\"ngram\": \"her astonishing sprint\", \"from\": 1244, \"to\": 1266}, {\"ngram\": \"the 2016 Rio Olympics\", \"from\": 1277, \"to\": 1298}, {\"ngram\": \"medals\", \"from\": 1321, \"to\": 1327}, {\"ngram\": \"the 2017 and 2019 world championships\", \"from\": 1331, \"to\": 1368}]}, {\"sentence\": \"The three-times Diamond League winner stormed back with her second double in Tokyo, also claiming a relay gold to take her tally to five.\", \"from\": 1371, \"to\": 1508, \"entities\": [{\"begin\": 1387, \"end\": 1401, \"title\": \"http://dbpedia.org/resource/Diamond_League\", \"score\": 0.8520795626894125, \"rank\": 0.14729374986277977, \"text\": \"Diamond League\", \"types\": [\"Q623109\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Diamond_League\", \"dbpedia\": \"http://dbpedia.org/resource/Diamond_League\"}, {\"begin\": 1448, \"end\": 1453, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.9999673897331279, \"rank\": 3.261131568163005e-05, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"a relay gold\", \"from\": 1469, \"to\": 1481}, {\"ngram\": \"her tally\", \"from\": 1490, \"to\": 1499}]}, {\"sentence\": \"Thompson-Herah said she would be cheering on her compatriots in Paris - hopefully on site - and was not giving up on her sprint career.\", \"from\": 1510, \"to\": 1645, \"entities\": [{\"begin\": 1574, \"end\": 1579, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999989229309, \"rank\": 1.0769710093177214e-09, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Thompson-Herah\", \"from\": 1510, \"to\": 1524}, {\"ngram\": \"her compatriots\", \"from\": 1555, \"to\": 1570}, {\"ngram\": \"site\", \"from\": 1595, \"to\": 1599}, {\"ngram\": \"her sprint career\", \"from\": 1627, \"to\": 1644}]}, {\"sentence\": \"\\\"It's a long road but I am willing to start over and keep working and to make full recovery and resume my track career,\\\" she wrote.\", \"from\": 1647, \"to\": 1778, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a long road\", \"from\": 1653, \"to\": 1664}, {\"ngram\": \"full recovery\", \"from\": 1725, \"to\": 1738}, {\"ngram\": \"my track career\", \"from\": 1750, \"to\": 1765}]}, {\"sentence\": \"\\\"I am hurt and devastated to be missing the Olympics this year but at the end of the day, it's sports and my health comes first.\", \"from\": 1780, \"to\": 1908, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the Olympics\", \"from\": 1820, \"to\": 1832}, {\"ngram\": \"the end\", \"from\": 1850, \"to\": 1857}, {\"ngram\": \"the day\", \"from\": 1861, \"to\": 1868}, {\"ngram\": \"sports\", \"from\": 1875, \"to\": 1881}, {\"ngram\": \"my health\", \"from\": 1886, \"to\": 1895}]}, {\"sentence\": \"I will be back.\\\"\", \"from\": 1909, \"to\": 1925, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Thompson-Herah had already decided not to defend her 200m title having missed the deadline to compete at the Jamaican Athletics Championships.\", \"from\": 1927, \"to\": 2069, \"entities\": [{\"begin\": 2036, \"end\": 2068, \"title\": \"http://dbpedia.org/resource/Jamaican_Athletics_Championships\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Jamaican Athletics Championships\", \"types\": [\"Q623109\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Jamaican_Athletics_Championships\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaican_Athletics_Championships\"}], \"noun_phrases\": [{\"ngram\": \"Thompson-Herah\", \"from\": 1927, \"to\": 1941}, {\"ngram\": \"her 200m title\", \"from\": 1976, \"to\": 1990}, {\"ngram\": \"the deadline\", \"from\": 2005, \"to\": 2017}]}, {\"sentence\": \"The athletics competition at the Paris Olympics takes place from 1-11 August at the Stade de France.\", \"from\": 2071, \"to\": 2171, \"entities\": [{\"begin\": 2155, \"end\": 2170, \"title\": \"http://dbpedia.org/resource/Stade_de_France\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Stade de France\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Stade_de_France\", \"dbpedia\": \"http://dbpedia.org/resource/Stade_de_France\"}], \"noun_phrases\": [{\"ngram\": \"The athletics competition\", \"from\": 2071, \"to\": 2096},