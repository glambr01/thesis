}, {\"ngram\": \"Maps\", \"from\": 1483, \"to\": 1487}, {\"ngram\": \"Gemini\", \"from\": 1492, \"to\": 1498}, {\"ngram\": \"the advancements\", \"from\": 1511, \"to\": 1527}, {\"ngram\": \"\\u25cf\", \"from\": 1537, \"to\": 1538}, {\"ngram\": \"the Games\", \"from\": 1546, \"to\": 1555}, {\"ngram\": \"Google\", \"from\": 1561, \"to\": 1567}, {\"ngram\": \"NBCUniversal\", \"from\": 1569, \"to\": 1581}, {\"ngram\": \"the Games\", \"from\": 1603, \"to\": 1612}, {\"ngram\": \"commentators\", \"from\": 1728, \"to\": 1740}, {\"ngram\": \"daytime and primetime coverage\", \"from\": 1748, \"to\": 1778}]}, {\"sentence\": \"NBCUniversal commentators will demonstrate how AI Overviews in Google Search can help viewers explore and understand their questions about the Olympic and Paralympic Games in a single search, like the importance of lane assignments in swimming.\", \"from\": 1848, \"to\": 2092, \"entities\": [{\"begin\": 1895, \"end\": 1897, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 1.0, \"rank\": 3.1807318370479396e-17, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}, {\"begin\": 1911, \"end\": 1924, \"title\": \"http://dbpedia.org/resource/Google_Search\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Google Search\", \"types\": [\"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Google_Search\", \"dbpedia\": \"http://dbpedia.org/resource/Google_Search\"}], \"noun_phrases\": [{\"ngram\": \"NBCUniversal commentators\", \"from\": 1848, \"to\": 1873}, {\"ngram\": \"viewers\", \"from\": 1934, \"to\": 1941}, {\"ngram\": \"their questions\", \"from\": 1965, \"to\": 1980}, {\"ngram\": \"the Olympic and Paralympic Games\", \"from\": 1987, \"to\": 2019}, {\"ngram\": \"a single search\", \"from\": 2023, \"to\": 2038}, {\"ngram\": \"the importance\", \"from\": 2045, \"to\": 2059}, {\"ngram\": \"lane assignments\", \"from\": 2063, \"to\": 2079}, {\"ngram\": \"swimming\", \"from\": 2083, \"to\": 2091}]}, {\"sentence\": \"Explain the Games will extend to NBCUniversal's social media accounts, further amplifying its reach while anticipating Olympic and Paralympic enthusiasts' most pressing questions.\", \"from\": 2093, \"to\": 2272, \"entities\": [{\"begin\": 2126, \"end\": 2138, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 0.9999999766150725, \"rank\": 2.3385035329060483e-08, \"text\": \"NBCUniversal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}], \"noun_phrases\": [{\"ngram\": \"the Games\", \"from\": 2101, \"to\": 2110}, {\"ngram\": \"its reach\", \"from\": 2183, \"to\": 2192}, {\"ngram\": \"Olympic and Paralympic enthusiasts' most pressing questions\", \"from\": 2212, \"to\": 2271}]}, {\"sentence\": \"\\u25cfTry it with Google Gemini: During NBCUniversal's coverage of the Paris Games, viewers will be able to follow Leslie Jones, Chief Superfan Commentator, as she follows the Olympic Games with the help of Gemini, Google's creative collaborator and AI Assistant.\", \"from\": 2276, \"to\": 2534, \"entities\": [{\"begin\": 2289, \"end\": 2295, \"title\": \"http://dbpedia.org/resource/Google\", \"score\": 1.0, \"rank\": 2.0038734897500667e-16, \"text\": \"Google\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Google\", \"dbpedia\": \"http://dbpedia.org/resource/Google\"}, {\"begin\": 2296, \"end\": 2302, \"title\": \"http://dbpedia.org/resource/Gemini_Awards\", \"score\": 0.9998214768848627, \"rank\": 0.00017855499139104815, \"text\": \"Gemini\", \"types\": [\"Q618779\"], \"wikid\": \"http://dbpedia.org/resource/Gemini_Awards\", \"dbpedia\": \"http://dbpedia.org/resource/Gemini_Awards\"}, {\"begin\": 2311, \"end\": 2323, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 0.999