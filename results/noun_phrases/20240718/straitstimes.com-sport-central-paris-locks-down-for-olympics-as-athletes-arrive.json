ir performances.\", \"from\": 3386, \"to\": 3607, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"air-conditioning\", \"from\": 3416, \"to\": 3432}, {\"ngram\": \"Olympic delegations\", \"from\": 3443, \"to\": 3462}, {\"ngram\": \"around 2,500 portable cooling units\", \"from\": 3476, \"to\": 3511}, {\"ngram\": \"their athletes\", \"from\": 3516, \"to\": 3530}, {\"ngram\": \"fear\", \"from\": 3538, \"to\": 3542}, {\"ngram\": \"the impact\", \"from\": 3546, \"to\": 3556}, {\"ngram\": \"high summer temperatures\", \"from\": 3560, \"to\": 3584}, {\"ngram\": \"their performances\", \"from\": 3588, \"to\": 3606}]}, {\"sentence\": \"\\\"The major countries are going to arrive on the first day... so Britain, the United States, New Zealand, Brazil, Switzerland,\\\" said the deputy head of the French delegation, Andre-Pierre Goubert.\", \"from\": 3609, \"to\": 3804, \"entities\": [{\"begin\": 3673, \"end\": 3680, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9999957312184214, \"rank\": 2.9312351071425882e-06, \"text\": \"Britain\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}, {\"begin\": 3686, \"end\": 3699, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999917671377831, \"rank\": 8.23293009314025e-06, \"text\": \"United States\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 3701, \"end\": 3712, \"title\": \"http://dbpedia.org/resource/New_Zealand_national_rugby_league_team\", \"score\": 0.9958238975979723, \"rank\": 0.0024527450574801154, \"text\": \"New Zealand\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/New_Zealand_national_rugby_league_team\", \"dbpedia\": \"http://dbpedia.org/resource/New_Zealand_national_rugby_league_team\"}, {\"begin\": 3714, \"end\": 3720, \"title\": \