\": \"http://dbpedia.org/resource/Thoracic_spinal_nerve_11\"}], \"noun_phrases\": [{\"ngram\": \"her ready smile\", \"from\": 2284, \"to\": 2299}, {\"ngram\": \"spirit\", \"from\": 2315, \"to\": 2321}, {\"ngram\": \"F11 marathon runner\", \"from\": 2349, \"to\": 2368}, {\"ngram\": \"an inspiration\", \"from\": 2373, \"to\": 2387}]}, {\"sentence\": \"She, in turn, is inspired by friends and family who support her in her journey.\", \"from\": 2397, \"to\": 2476, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"turn\", \"from\": 2405, \"to\": 2409}, {\"ngram\": \"friends\", \"from\": 2426, \"to\": 2433}, {\"ngram\": \"family\", \"from\": 2438, \"to\": 2444}, {\"ngram\": \"her journey\", \"from\": 2464, \"to\": 2475}]}, {\"sentence\": \"\\\"I love running, so it's not a sacrifice for me to do it every day,\\\" she says of her hectic training schedule.\", \"from\": 2478, \"to\": 2588, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a sacrifice\", \"from\": 2507, \"to\": 2518}, {\"ngram\": \"her hectic training schedule\", \"from\": 2559, \"to\": 2587}]}, {\"sentence\": \"\\\"Travelling and getting the opportunity to see the world is also amazing,\\\" she adds.\", \"from\": 2589, \"to\": 2673, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the opportunity\", \"from\": 2613, \"to\": 2628}, {\"ngram\": \"the world\", \"from\": 2636, \"to\": 2645}]}, {\"sentence\": \"Pieter, who has qualified for the 100m and 200m backstroke, is proof of what dedication and passion for the sport can do.\", \"from\": 2675, \"to\": 2796, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Pieter\", \"from\": 2675, \"to\": 2681}, {\"ngram\": \"the 100m\", \"from\": 2705, \"to\": 2713}, {\"ngram\": \"200m backstroke\", \"from\": 2718, \"to\": 2733}, {\"ngram\": \"proof\", \"from\": 2738, \"to\": 2743}, {\"ngram\": \"what dedication\", \"from\": 2747, \"to\": 2762}, {\"ngram\": \"passion\", \"from\": 2767, \"to\": 2774}, {\"ngram\": \"the sport\", \"from\": 2779, \"to\": 2788}]}, {\"sente