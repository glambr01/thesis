"{\"uid\": \"jamaicaobserver.com-2024-07-18-entertainers-union-plans-strike-olympics-opening-ceremony\", \"noun_phrases\": [{\"sentence\": \"PARIS, France (AFP) - A French performing artists union announced plans for a strike coinciding with the opening ceremony of the Olympic Games in Paris, protesting \\\"outrageous disparities in treatment\\\" between performers recruited for the spectacle.\", \"from\": 0, \"to\": 249, \"entities\": [{\"begin\": 24, \"end\": 30, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.689444614609674, \"rank\": 0.3763951413999159, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 146, \"end\": 151, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999994740847, \"rank\": 5.259277142576873e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"PARIS\", \"from\": 0, \"to\": 5}, {\"ngram\": \"France\", \"from\": 7, \"to\": 13}, {\"ngram\": \"AFP\", \"from\": 15, \"to\": 18}, {\"ngram\": \"plans\", \"from\": 66, \"to\": 71}, {\"ngram\": \"a strike\", \"from\": 76, \"to\": 84}, {\"ngram\": \"the opening ceremony\", \"from\": 101, \"to\": 121}, {\"ngram\": \"the Olympic Games\", \"from\": 125, \"to\": 142}, {\"ngram\": \"\\\"outrageous disparities\", \"from\": 164, \"to\": 187}, {\"ngram\": \"treatment\", \"from\": 191, \"to\": 200}, {\"ngram\": \"performers\", \"from\": 210, \"to\": 220}, {\"ngram\": \"the spectacle\", \"from\": 235, \"to\": 248}]}, {\"sentence\": \"\\\"We regret to have to announce filing a strike notice for the show on July 26 as well as for the upcoming rehearsals for the opening ceremony for the Paralympic Games\\\" on August 28, the union said in a statement.\", \"from\": 251, \"to\": 463, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a strike notice\", \"from\": 289, \"to\": 304}, {\"ngram\": \"the show\", \"from\": 309, \"to\": 317}, {\"ngram\": \"July\", \"from\": 321, \"to\": 325}, {\"ngram\": \"the upcoming rehearsals\", \"from\": 344, \"to\": 367}, {\"ngram\": \"the opening ceremony\", \"from\": 372, \"to\": 392}, {\"ngram\": \"the Paralympic Games\", \"from\": 397, \"to\": 417}, {\"ngram\": \"August\", \"from\": 422, \"to\": 428}, {\"ngram\": \"the union\", \"from\": 433, \"to\": 442}, {\"ngram\": \"a statement\", \"from\": 451, \"to\": 462}]}, {\"sentence\": \"It said it had \\\"alerted\\\" Paname24, the executive producer of the ceremonies, several times about contractual practices not in accordance with the collective agreement.\", \"from\": 465, \"to\": 632, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"\\\" Paname24\", \"from\": 488, \"to\": 498}, {\"ngram\": \"the executive producer\", \"from\": 500, \"to\": 522}, {\"ngram\": \"the ceremonies\", \"from\": 526, \"to\": 540}, {\"ngram\": \"several times\", \"from\": 542, \"to\": 555}, {\"ngram\": \"contractual practices\", \"from\": 562, \"to\": 583}, {\"ngram\": \"accordance\", \"from\": 591, \"to\": 601}, {\"ngram\": \"the collective agreement\", \"from\": 607, \"to\": 631}]}, {\"sentence\": \"\\\"We also highlighted outrageous disparities in treatment as well as an absence of social dialogue during preparations for the ceremonies,\\\" the union added.\", \"from\": 634, \"to\": 789, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"outrageous disparities\", \"from\": 655, \"to\": 677}, {\"ngram\": \"treatment\", \"from\": 681, \"to\": 690}, {\"ngram\": \"an absence\", \"from\": 702, \"to\": 712}, {\"ngram\": \"social dialogue\", \"from\": 716, \"to\": 731}, {\"ngram\": \"preparations\", \"from\": 739, \"to\": 751}, {\"ngram\": \"the ceremonies\", \"from\": 756, \"to\": 770}, {\"ngram\": \"the union\", \"from\": 773, \"to\": 782}]}, {\"sentence\": \"Asked byAFP, a member of the SFA-CGT union suggested that around \\\"250 to 300 professional dancers\\\" of the 3,000 signed up for the Olympics \\\"were recruited under shameful (financial) conditions\\\".\", \"from\": 791, \"to\": 985, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Asked byAFP\", \"from\": 791, \"to\": 802}, {\"ngram\": \"a member\", \"from\": 804, \"to\": 812}, {\"ngram\": \"the SFA-CGT union\", \"from\": 816, \"to\": 833}, {\"ngram\": \"\\\"250 to 300 professional dancers\", \"from\": 856, \"to\": 888}, {\"ngram\": \"the Olympics\", \"from\": 917, \"to\": 929}, {\"ngram\": \"shameful (financial) conditions\", \"from\": 952, \"to\": 983}]}, {\"sentence\": \"\\\"Why are some non-Parisian artistes being paid and housed, when the majority of them - the most precarious - will not be, even though they have the same employment contracts,\\\" the union said.\", \"from\": 987, \"to\": 1178, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"some non-Parisian artistes\", \"from\": 996, \"to\": 1022}, {\"ngram\": \"the majority\", \"from\": 1051, \"to\": 1063}, {\"ngram\": \"the same employment contracts\", \"from\": 1131, \"to\": 1160}, {\"ngram\": \"the union\", \"from\": 1163, \"to\": 1172}]}, {\"sentence\": \"Some 3,000 dancers, musicians and actors will take to the banks of the river Seine and its bridges as part of the ceremony which will carry athletes along a six-kilometre (four-mile) route, the first time a summer Games has begun outside the main stadium.\", \"from\": 1180, \"to\": 1435, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Some 3,000 dancers\", \"from\": 1180, \"to\": 1198}, {\"ngram\": \"musicians\", \"from\": 1200, \"to\": 1209}, {\"ngram\": \"actors\", \"from\": 1214, \"to\": 1220}, {\"ngram\": \"the banks\", \"from\": 1234, \"to\": 1243}, {\"ngram\": \"the river Seine\", \"from\": 1247, \"to\": 1262}, {\"ngram\": \"its bridges\", \"from\": 1267, \"to\": 1278}, {\"ngram\": \"part\", \"from\": 1282, \"to\": 1286}, {\"ngram\": \"the ceremony\", \"from\": 1290, \"to\": 1302}, {\"ngram\": 