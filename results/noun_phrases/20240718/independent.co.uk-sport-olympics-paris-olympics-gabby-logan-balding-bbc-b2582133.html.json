22}, {\"ngram\": \"events\", \"from\": 754, \"to\": 760}, {\"ngram\": \"the day\", \"from\": 775, \"to\": 782}]}, {\"sentence\": \"Broadcasters are reportedly concerned that employees could be stopped from working if the rules are not followed.\", \"from\": 825, \"to\": 938, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Broadcasters\", \"from\": 825, \"to\": 837}, {\"ngram\": \"employees\", \"from\": 868, \"to\": 877}, {\"ngram\": \"the rules\", \"from\": 911, \"to\": 920}]}, {\"sentence\": \"\\\"Because of the French working directive, we are not allowed to do the morning session and the evening session,\\\" said Logan.\", \"from\": 940, \"to\": 1064, \"entities\": [{\"begin\": 956, \"end\": 962, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9949460136579332, \"rank\": 0.0045998978488629395, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"the morning session\", \"from\": 1007, \"to\": 1026}, {\"ngram\": \"the evening session\", \"from\": 1031, \"to\": 1050}, {\"ngram\": \"Logan\", \"from\": 1058, \"to\": 1063}]}, {\"sentence\": \"\\\"They are really strict about it apparently.\", \"from\": 1065, \"to\": 1109, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"It's not just a kind of box-ticking exercise.\", \"from\": 1110, \"to\": 1155, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"just a kind\", \"from\": 1119, \"to\": 1130}, {\"ngram\": \"box-ticking exercise\", \"from\": 1134, \"to\": 1154}]}, {\"sentence\": \"It's quite a change for all of us because we are used to these really early sessions in the morning.\\\"\", \"from\": 1156, \"to\": 1257, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"quite a change\", \"from\": 1161, \"to\": 1175}, {\"ngram\": \"us\", \"from\": 1187, \"to\": 1189}, {\"ngram\": \"these really early sessions\", \"from\": 1213, \"to\": 1240},