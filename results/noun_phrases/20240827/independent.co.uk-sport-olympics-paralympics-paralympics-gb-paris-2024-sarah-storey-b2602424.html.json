m\": 1204, \"to\": 1410, \"entities\": [{\"begin\": 1234, \"end\": 1239, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.9730781910509038, \"rank\": 0.027312136975004123, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}], \"noun_phrases\": [{\"ngram\": \"her son\", \"from\": 1214, \"to\": 1221}, {\"ngram\": \"theParalympics\", \"from\": 1265, \"to\": 1279}, {\"ngram\": \"Mum\", \"from\": 1281, \"to\": 1284}, {\"ngram\": \"the rollercoaster\", \"from\": 1336, \"to\": 1353}, {\"ngram\": \"a 17-time gold medallist\", \"from\": 1385, \"to\": 1409}]}, {\"sentence\": \"\\\"That was a huge motivation.\", \"from\": 1412, \"to\": 1440, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a huge motivation\", \"from\": 1422, \"to\": 1439}]}, {\"sentence\": \"Obviously, I would not have said yes if I did not think my body and mind were up to it, because there is a huge amount of work that goes into getting there.\\\"\", \"from\": 1441, \"to\": 1598, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my body\", \"from\": 1497, \"to\": 1504}, {\"ngram\": \"mind\", \"from\": 1509, \"to\": 1513}, {\"ngram\": \"a huge amount\", \"from\": 1546, \"to\": 1559}, {\"ngram\": \"work\", \"from\": 1563, \"to\": 1567}]}, {\"sentence\": \"Canoeist Jeanette Chippington, 54, will feature at her eighth Paralympics.\", \"from\": 1600, \"to\": 1674, \"entities\": [{\"begin\": 1609, \"end\": 1629, \"title\": \"http://dbpedia.org/resource/Jeanette_Chippington\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Jeanette Chippington\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jeanette_Chippington\", \"dbpedia\": \"http://dbpedia.org/resource/Jeanette_Chippington\"}], \"noun_phrases\": [{\"ngram\": \"her eighth Paralympics\", \"from\": 1651, \"to\": 1673}]}, {\"sentence\": \"She has followed a similar arc and competed five times as a swimmer starting all the way back at Seoul 1988.\", \"from\": 1675, \"to\": 1783, \"entities\": [{\"begin\": 1772, \"end\": 1782, \"title\": \"http://dbpedia.org/resource/1988_Summer_Paralympics\", \"score\": 0.9999994101269215, \"rank\": 5.898735038552276e-07, \"text\": \"Seoul 1988\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/1988_Summer_Paralympics\", \"dbpedia\": \"http://dbpedia.org/resource/1988_Summer_Paralympics\"}], \"noun_phrases\": [{\"ngram\": \"a similar arc\", \"from\": 1692, \"to\": 1705}, {\"ngram\": \"a swimmer\", \"from\": 1733, \"to\": 1742}]}, {\"sentence\": \"These Games will take on extra significance for Chippington as the first without either of her parents.\", \"from\": 1784, \"to\": 1887, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"These Games\", \"from\": 1784, \"to\": 1795}, {\"ngram\": \"extra significance\", \"from\": 1809, \"to\": 1827}, {\"ngram\": \"Chippington\", \"from\": 1832, \"to\": 1843}, {\"ngram\": \"either\", \"from\": 1865, \"to\": 1871}, {\"ngram\": \"her parents\", \"from\": 1875, \"to\": 1886}]}, {\"sentence\": \"\\\"My career has spanned such a long period of time, and this is one of the challenges that has been thrown at me,\\\" she said.\", \"from\": 1889, \"to\": 2012, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My career\", \"from\": 1890, \"to\": 1899}, {\"ngram\": \"such a long period\", \"from\": 1912, \"to\": 1930}, {\"ngram\": \"time\", \"from\": 1934, \"to\": 1938}, {\"ngram\": \"the challenges\", \"from\": 1959, \"to\": 1973}]}, {\"sentence\": \"\\\"You have just got to be patient and keep trying.\", \"from\": 2013, \"to\": 2062, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"That's one thing that I hope my own children have taken away from watching me and I get that from my mum - never giving up.\\\"\", \"from\": 2063, \"to\": 2187, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"one thing\", \"from\": 2070, \"to\": 2079}, {\"ngram\": \"my own children\", \"from\": 2092, \"to\": 2107}, {\"ngram\": \"my mum\", \"from\": 2161, \"to\": 2167}]}, {\"sentence\": \"At 45, Jody Cundy believes his short-lived stint onStrictly Come Dancinghas made him stronger than ever as he winds up for an eighth Games and fifth as a cyclist.\", \"from\": 2189, \"to\": 2351, \"entities\": [{\"begin\": 2196, \"end\": 2206, \"title\": \"http://dbpedia.org/resource/Jody_Cundy\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Jody Cundy\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jody_Cundy\", \"dbpedia\": \"http://dbpedia.org/resource/Jody_Cundy\"}], \"noun_phrases\": [{\"ngram\": \"his short-lived stint\", \"from\": 2216, \"to\": 2237}, {\"ngram\": \"Dancinghas\", \"from\": 2254, \"to\": 2264}, {\"ngram\": \"an eighth Games\", \"from\": 2312, \"to\": 2327}, {\"ngram\": \"a cyclist\", \"from\": 2341, \"to\": 2350}]}, {\"sentence\": \"\\\"There were bits from the dance that actually transferred over, mainly in the gym, with balance and coordination,\\\" said Cundy.\", \"from\": 2353, \"to\": 2479, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"bits\", \"from\": 2365, \"to\": 2369}, {\"ngram\": \"the dance\", \"from\": 2375, \"to\": 2384}, {\"ngram\": \"the gym\", \"from\": 2427, \"to\": 2434}, {\"ngram\": \"balance\", \"from\": 2441, \"to\": 2448}, {\"ngram\": \"coordination\", \"from\": 2453, \"to\": 2465}, {\"ngram\": \"Cundy\", \"from\": 2473, \"to\": 2478}]}, {\"sentence\": \"\\\"I came back to the gym, and I was stronger, even though I'd not lifted for a few weeks, from doing the dancing.\", \"from\": 2481, \"to\": 2593, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the gym\", \"from\": 2497, \"to\": 2504}, {\"ngram\": \"a few weeks\", \"from\": 2557, \"to\": 2568}, {\"ngram\": \"the dancing\", \"from\": 2581, \"to\": 2592}]}, {\"sentence\": \"I had more core stability.\", \"from\": 2594, \"to\": 2620, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"more core stability\", \"from\": 2600, \"to\": 2619}]}, {\"sentence\": \"That was a real nice gain.\\\"\", \"from\": 2621, \"to\": 2648, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a real nice gain\", \"from\": 2630, \"to\": 2646}]}, {\"sentence\": \"These stories leave you feeling warm and fuzzy but the cold, hard numbers show a dearth of new talent in British disability sport.\", \"from\": 2650, \"to\": 2780, \"entities\": [{\"begin\": 2755, \"end\": 2762, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.8819052838782014, \"rank\": 0.1331412469119169, \"text\": \"British\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"These stories\", \"from\": 2650, \"to\": 2663}, {\"ngram\": \"the cold, hard numbers\", \"from\": 2701, \"to\": 2723}, {\"ngram\": \"a dearth\", \"from\": 2729, \"to\": 2737}, {\"ngram\": \"new talent\", \"from\": 2741, \"to\": 2751}]}, {\"sentence\": \"Of the 215 GB athletes that will compete for medals in Paris, there are only 81 debutants.\", \"from\": 2782, \"to\": 2872, \"entities\": [{\"begin\": 2837, \"end\": 2842, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999413376, \"rank\": 5.869844819482939e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"the 215 GB athletes\", \"from\": 2785, \"to\": 2804}, {\"ngram\": \"medals\", \"from\": 2827, \"to\": 2833}, {\"ngram\": \"only 81 debutants\", \"from\": 2854, \"to\": 2871}]}, {\"sentence\": \"There are 49 Paralympic champions in their ranks.\", \"from\": 2873, \"to\": 2922, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"49 Paralympic champions\", \"from\": 2883, \"to\": 2906}, {\"ngram\": \"their ranks\", \"from\": 2910, \"to\": 2921}]}, {\"sentence\": \"The picture on the Olympic side looks radic