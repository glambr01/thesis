 2219}, {\"ngram\": \"all rooms\", \"from\": 2223, \"to\": 2232}, {\"ngram\": \"the heat forecast\", \"from\": 2293, \"to\": 2310}, {\"ngram\": \"air conditioning units\", \"from\": 2352, \"to\": 2374}, {\"ngram\": \"the entire delegation\", \"from\": 2379, \"to\": 2400}]}, {\"sentence\": \"Australia's Chef de Mission Anna Meares said they were \\\"looking at portable air conditioners to offer the athletes should they choose to if it gets hot, if it's uncomfortable.\\\"\", \"from\": 2404, \"to\": 2580, \"entities\": [{\"begin\": 2404, \"end\": 2413, \"title\": \"http://dbpedia.org/resource/Australia\", \"score\": 0.9999773247688336, \"rank\": 2.263926668393174e-05, \"text\": \"Australia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Australia\", \"dbpedia\": \"http://dbpedia.org/resource/Australia\"}, {\"begin\": 2416, \"end\": 2431, \"title\": \"http://dbpedia.org/resource/Head_of_mission\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Chef de Mission\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Head_of_mission\", \"dbpedia\": \"http://dbpedia.org/resource/Head_of_mission\"}, {\"begin\": 2432, \"end\": 2443, \"title\": \"http://dbpedia.org/resource/Anna_Meares\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Anna Meares\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Anna_Meares\", \"dbpedia\": \"http://dbpedia.org/resource/Anna_Meares\"}], \"noun_phrases\": [{\"ngram\": \"portable air conditioners\", \"from\": 2471, \"to\": 2496}, {\"ngram\": \"the athletes\", \"from\": 2506, \"to\": 2518}]}, {\"sentence\": \"The Canadian Olympic Committee told Reuters it had \\\"implemented a number of heat mitigation strategies in Paris to complement the measures put in place by the Paris 2024 Organizing Committee, including air conditioning units in some athlete rooms in case of extreme heat.\\\"\", \"from\": 2582, \"to\": 2854, \"entities\": [{\"begin\": 2586, \"end\": 2612, \"title\": \"http://d