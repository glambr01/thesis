{\"ngram\": \"Valieva\", \"from\": 1539, \"to\": 1546}, {\"ngram\": \"trimetazidine\", \"from\": 1587, \"to\": 1600}, {\"ngram\": \"her lawyers\", \"from\": 1606, \"to\": 1617}, {\"ngram\": \"traces\", \"from\": 1654, \"to\": 1660}, {\"ngram\": \"the medication\", \"from\": 1664, \"to\": 1678}, {\"ngram\": \"her grandfather\", \"from\": 1687, \"to\": 1702}]}, {\"sentence\": \"Her sample was taken six weeks earlier at the Russian national championships but not flagged by a Swedish lab until hours after she skated in the Olympic team event on Feb. 7, 2022.\", \"from\": 1704, \"to\": 1885, \"entities\": [{\"begin\": 1750, \"end\": 1780, \"title\": \"http://dbpedia.org/resource/Russian_Figure_Skating_Championships\", \"score\": 0.9999862154329207, \"rank\": 1.3784757115302944e-05, \"text\": \"Russian national championships\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Russian_Figure_Skating_Championships\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_Figure_Skating_Championships\"}, {\"begin\": 1802, \"end\": 1809, \"title\": \"http://dbpedia.org/resource/Sweden\", \"score\": 0.9998936710313929, \"rank\": 9.819233753096121e-05, \"text\": \"Swedish\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Sweden\", \"dbpedia\": \"http://dbpedia.org/resource/Sweden\"}, {\"begin\": 1850, \"end\": 1868, \"title\": \"http://dbpedia.org/resource/Figure_skating_at_the_2022_Winter_Olympics_\\u2013_Team_event\", \"score\": 0.9796033952338553, \"rank\": 0.02082128397918026, \"text\": \"Olympic team event\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/Figure_skating_at_the_2022_Winter_Olympics_\\u2013_Team_event\", \"dbpedia\": \"http://dbpedia.org/resource/Figure_skating_at_the_2022_Winter_Olympics_\\u2013_Team_event\"}], \"noun_phrases\": [{\"ngram\": \"Her sample\", \"from\": 1704, \"to\": 1714}, {\"ngram\": \"hours\", \"from\": 1820, \"to\": 1825}, {\"ngram\": \"Feb.\", \"from\": 1872, \"to\": 1876}]}, {\"sentence\": \"CAS 