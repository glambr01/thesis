edia.org/resource/Diamond_League\", \"score\": 1.0, \"rank\": 1.336027708873402e-25, \"text\": \"Diamond League\", \"types\": [\"Q623109\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Diamond_League\", \"dbpedia\": \"http://dbpedia.org/resource/Diamond_League\"}], \"noun_phrases\": [{\"ngram\": \"the first time\", \"from\": 756, \"to\": 770}, {\"ngram\": \"all 32 track & field disciplines\", \"from\": 823, \"to\": 855}, {\"ngram\": \"100 Olympic medalists\", \"from\": 873, \"to\": 894}]}, {\"sentence\": \"The entire Paris Olympic podium is expected to compete in nine different events.\", \"from\": 896, \"to\": 976, \"entities\": [{\"begin\": 907, \"end\": 912, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999996311999, \"rank\": 3.690161914691186e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"nine different events\", \"from\": 954, \"to\": 975}]}, {\"sentence\": \"McLaughlin-Levrone, coming off a historic Paris Olympic campaign that saw her win her second consecutive 400m hurdles and 4x400m relay gold medals and lower her own world record to 50.37 in the former, is expected to double in the 400m and 200m this weekend, with the former at 1:50 p.m.\", \"from\": 978, \"to\": 1265, \"entities\": [{\"begin\": 1020, \"end\": 1025, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999996311999, \"rank\": 3.690161914691186e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"McLaughlin-Levrone\", \"from\": 978, \"to\": 996}, {\"ngram\": \"her second consecutive 400m hurdles\", \"from\": 1060, \"to\": 1095}, {\"ngram\": \"relay gold medals\", \"from\": 1107, \"to\": 1124}, {\"ngram\": \"her own world record\", \"from\": 1135, \"to\": 1155}, {\"ngram\": \"the 400m\", \"from\": 1205, \"to\": 1213}, {\"ngram\": \"1:50 p.m.\", \"from\": 1256, \"to\": 1265}]}, {\"sentence\": \"ET Friday and the latter at 1:50 p.m.\", \"from\": 1266, \"to\": 1303, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"ET Friday\", \"from\": 1266, \"to\": 1275}, {\"ngram\": \"1:50 p.m.\", \"from\": 1294, \"to\": 1303}]}, {\"sentence\": \"ET Saturday.\", \"from\": 1304, \"to\": 1316, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"ET Saturday\", \"from\": 1304, \"to\": 1315}]}, {\"sentence\": \"Although not her signature events, McLaughlin-Levrone's 400m time of 48.75 and 200m time of 22.07 make her the fourth-fastest woman in the 400m this year and eighth-fastest woman in the 200m this year.\", \"from\": 1317, \"to\": 1518, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"not her signature events\", \"from\": 1326, \"to\": 1350}, {\"ngram\": \"McLaughlin-Levrone's 400m time\", \"from\": 1352, \"to\": 1382}, {\"ngram\": \"time\", \"from\": 1401, \"to\": 1405}, {\"ngram\": \"the 400m\", \"from\": 1452, \"to\": 1460}, {\"ngram\": \"the 200m\", \"from\": 1499, \"to\": 1507}]}, {\"sentence\": \"Richardson, who won the silver medal in the 100m and gold in the 4x100m relay, is expected to face gold medalistJulien Alfred(Saint Lucia) in a rematch of the Paris Olympic 100m final.\", \"from\": 1520, \"to\": 1704, \"entities\": [{\"begin\": 1520, \"end\": 1530, \"title\": \"http://dbpedia.org/resource/Samuel_Richardson\", \"score\": 0.9999231733363648, \"rank\": 7.674660987357039e-05, \"text\": \"Richardson\", \"types\": [\"Q729\", \"Q5\", \"Q36180\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Samuel_Richardson\", \"dbpedia\": \"http://dbpedia.org/resource/Samuel_Richardson\"}, {\"begin\": 1646, \"end\": 1657, \"title\": \"http://dbpedia.org/resource/Saint_Lucia\", \"score\": 0.9999999892215784, \"rank\": 9.58376207039767e-09, \"text\": \"Saint Lucia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/re