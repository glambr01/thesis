ases\": [{\"ngram\": \"the deputy director general\", \"from\": 383, \"to\": 410}, {\"ngram\": \"the Olympic Council\", \"from\": 414, \"to\": 433}, {\"ngram\": \"Asia\", \"from\": 437, \"to\": 441}]}, {\"sentence\": \"The article reflects the author's opinions and not necessarily the views of CGTN.\", \"from\": 443, \"to\": 524, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The article\", \"from\": 443, \"to\": 454}, {\"ngram\": \"the author's opinions\", \"from\": 464, \"to\": 485}, {\"ngram\": \"not necessarily the views\", \"from\": 490, \"to\": 515}, {\"ngram\": \"CGTN\", \"from\": 519, \"to\": 523}]}, {\"sentence\": \"The Olympic Games has long since outgrown its original purpose to find the best athletes in the world.\", \"from\": 526, \"to\": 628, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The Olympic Games\", \"from\": 526, \"to\": 543}, {\"ngram\": \"its original purpose\", \"from\": 568, \"to\": 588}, {\"ngram\": \"the best athletes\", \"from\": 597, \"to\": 614}, {\"ngram\": \"the world\", \"from\": 618, \"to\": 627}]}, {\"sentence\": \"It is now a global celebration of humanity, hope and dreams, and peace and unity.\", \"from\": 629, \"to\": 710, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a global celebration\", \"from\": 639, \"to\": 659}, {\"ngram\": \"humanity\", \"from\": 663, \"to\": 671}, {\"ngram\": \"hope\", \"from\": 673, \"to\": 677}, {\"ngram\": \"dreams\", \"from\": 682, \"to\": 688}, {\"ngram\": \"peace\", \"from\": 694, \"to\": 699}, {\"ngram\": \"unity\", \"from\": 704, \"to\": 709}]}, {\"sentence\": \"Sport in general, and the Olympic Games in particular, brings people together like no other gathering of leaders from around the world.\", \"from\": 712, \"to\": 847, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Sport\", \"from\": 712, \"to\": 717}, {\"ngram\": \"the Olympic Games\", \"from\": 734, \"to\": 751}, {\"ngram\": \"people\", \"from\": 774, \"to\": 780}, {\"ngram\": \"no other gathering\", \"from\": 795, \"to\": 813}, {\"ngram\": \"leaders\", \"from\": 817, \"to\": 824}, {\"ngram\": \"the world\", \"from\": 837, \"to\": 846}]}, {\"sentence\": \"Not at the government level, not in politics, not in religion, and not even in the United Nations.\", \"from\": 848, \"to\": 946, \"entities\": [{\"begin\": 931, \"end\": 945, \"title\": \"http://dbpedia.org/resource/United_Nations\", \"score\": 0.9999997611139692, \"rank\": 2.388860068804119e-07, \"text\": \"United Nations\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Nations\", \"dbpedia\": \"http://dbpedia.org/resource/United_Nations\"}], \"noun_phrases\": [{\"ngram\": \"the government level\", \"from\": 855, \"to\": 875}, {\"ngram\": \"politics\", \"from\": 884, \"to\": 892}, {\"ngram\": \"religion\", \"from\": 901, \"to\": 909}]}, {\"sentence\": \"Two examples of this can be witnessed at every Olympic Games: The athletes' village and the opening ceremony.\", \"from\": 948, \"to\": 1057, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Two examples\", \"from\": 948, \"to\": 960}, {\"ngram\": \"every Olympic Games\", \"from\": 989, \"to\": 1008}, {\"ngram\": \"The athletes' village\", \"from\": 1010, \"to\": 1031}, {\"ngram\": \"the opening ceremony\", \"from\": 1036, \"to\": 1056}]}, {\"sentence\": \"Both are very much a part of the Games tradition but have nothing to do with elite competition or with gold, silver and bronze medals.\", \"from\": 1058, \"to\": 1192, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a part\", \"from\": 1077, \"to\": 1083}, {\"ngram\": \"the Games tradition\", \"from\": 1087, \"to\": 1106}, {\"ngram\": \"nothing\", \"from\": 1116, \"to\": 1123}, {\"ngram\": \"elite competition\", \"from\": 1135, \"to\": 1152}, {\"ngram\": \"gold, silver and bronze medals\", \"from\": 1161, \"to\": 1191}]}, {\"sentence\": \"The athletes have been checking into the Olympic Village in Paris and all of them receive the same welcome and the same treatment, no matter whether they c