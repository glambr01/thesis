"}], \"noun_phrases\": [{\"ngram\": \"The athletes\", \"from\": 1194, \"to\": 1206}, {\"ngram\": \"the same welcome\", \"from\": 1284, \"to\": 1300}, {\"ngram\": \"the same treatment\", \"from\": 1305, \"to\": 1323}, {\"ngram\": \"a big Olympic Games player\", \"from\": 1358, \"to\": 1384}, {\"ngram\": \"a smaller nation\", \"from\": 1416, \"to\": 1432}]}, {\"sentence\": \"In the eyes of the Olympic Movement, they are all the same \\u00e2\\u0080\\u0093 and this philosophy makes everyone feel welcome and everyone feel on equal footing.\", \"from\": 1464, \"to\": 1610, \"entities\": [{\"begin\": 1483, \"end\": 1499, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 0.9942715435167496, \"rank\": 0.005761460760560373, \"text\": \"Olympic Movement\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"the eyes\", \"from\": 1467, \"to\": 1475}, {\"ngram\": \"all the same \\u00e2\\u0080\\u0093\", \"from\": 1510, \"to\": 1526}, {\"ngram\": \"this philosophy\", \"from\": 1531, \"to\": 1546}, {\"ngram\": \"everyone\", \"from\": 1553, \"to\": 1561}, {\"ngram\": \"everyone\", \"from\": 1579, \"to\": 1587}, {\"ngram\": \"equal footing\", \"from\": 1596, \"to\": 1609}]}, {\"sentence\": \"Personally, I love to visit the athletes' village at an Olympic Games.\", \"from\": 1612, \"to\": 1682, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the athletes' village\", \"from\": 1640, \"to\": 1661}, {\"ngram\": \"an Olympic Games\", \"from\": 1665, \"to\": 1681}]}, {\"sentence\": \"There is a buzz of excitement in the air as athletes come and go; a powerful sense of identity and pride as the delegations hang their national flag over the balcony of their apartment.\", \"from\": 1683, \"to\": 1868, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a buzz\", \"from\": 1692, \"to\": 1698}, {\"ngram\": \"excitement\", \"from\": 1702, \"to\": 1712}, {\"ngram\": \"the air\", \"from\": 1716, \"to\": 1723}, {\"ngram\": \"athletes\", \"from\": 1727, \"to\": 1735}, {\"ngram\": \"; a powerful sense\", \"from\": 1747, \"to\": 1765}, {\"ngram\": \"identity\", \"from\": 1769, \"to\": 1777}, {\"ngram\": \"pride\", \"from\": 1782, \"to\": 1787}, {\"ngram\": \"the delegations\", \"from\": 1791, \"to\": 1806}, {\"ngram\": \"their national flag\", \"from\": 1812, \"to\": 1831}, {\"ngram\": \"the balcony\", \"from\": 1837, \"to\": 1848}, {\"ngram\": \"their apartment\", \"from\": 1852, \"to\": 1867}]}, {\"sentence\": \"Even though they all have busy schedules, for training and competition, they always find time to stop for a chat with an athlete they have met previously, and happily take photos and swap contact details.\", \"from\": 1870, \"to\": 2074, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"busy schedules\", \"from\": 1896, \"to\": 1910}, {\"ngram\": \"training\", \"from\": 1916, \"to\": 1924}, {\"ngram\": \"competition\", \"from\": 1929, \"to\": 1940}, {\"ngram\": \"time\", \"from\": 1959, \"to\": 1963}, {\"ngram\": \"a chat\", \"from\": 1976, \"to\": 1982}, {\"ngram\": \"an athlete\", \"from\": 1988, \"to\": 1998}, {\"ngram\": \"photos\", \"from\": 2042, \"to\": 2048}, {\"ngram\": \"contact details\", \"from\": 2058, \"to\": 2073}]}, {\"sentence\": \"These athletes become friends for life and can contribute to peace and understanding between countries in the future.\", \"from\": 2075, \"to\": 2192, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"These athletes\", \"from\": 2075, \"to\": 2089}, {\"ngram\": \"friends\", \"from\": 2097, \"to\": 2104}, {\"ngram\": \"life\", \"from\": 2109, \"to\": 2113}, {\"ngram\": \"peace\", \"from\": 2136, \"to\": 2141}, {\"ngram\": \"understanding\", \"from\": 2146, \"to\": 2159}, {\"ngram\": \"countries\", \"from\": 2168, \"to\": 2177}, {\"ngram\": \"the future\", \"from\": 2181, \"to\": 2191}]}, {\"sentence\": \"In Paris, for example, athletes from Palestine and Israel live side by side, as do athletes from Ukraine and from Russia and Belarus competing as Individual Neutral Athletes due to the war taking place in Ukraine.\", \"from\": 2194, \"to\": 2407, \"entities\": [{\"begin\": 2197, \"end\": 2202, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999999999998181, \"rank\": 1.658092938877678e-12, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 2231, \"end\": 2240, \"title\": \"http://dbpedia.org/resource/State_of_Palestine\", \"score\": 0.999999968498742, \"rank\": 2.1720178784035013e-08, \"text\": \"Palestine\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/State_of_Palestine\", \"dbpedia\": \"http://dbpedia.org/resource/State_of_Palestine\"}, {\"begin\": 2245, \"end\": 2251, \"title\": \"http://dbpedia.org/resource/Israel\", \"score\": 0.9999994089081994, \"rank\": 5.872881879057479e-07, \"text\": \"Israel\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Israel\", \"dbpedia\": \"http://dbpedia.org/resource/Israel\"}, {\"begin\": 2291, \"end\": 2298, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 0.9993116402205963, \"rank\": 0.0006888300215476369, \"text\": \"Ukraine\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Ukraine\"}, {\"begin\": 2308, \"end\": 2314, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999998800308348, \"rank\": 6.851160283737047e-08, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}, {\"begin\": 2319, \"end\": 2326, \"title\": \"http://dbpedia.org/resource/Belarus\", \"score\": 0.9999999999058673, \"rank\": 9.325437903040738e-11, \"text\": \"Belarus\", \"types\": [\"Q6256\"