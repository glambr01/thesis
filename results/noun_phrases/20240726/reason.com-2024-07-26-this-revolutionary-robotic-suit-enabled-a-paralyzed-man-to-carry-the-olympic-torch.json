82, \"entities\": [{\"begin\": 1693, \"end\": 1702, \"title\": \"http://dbpedia.org/resource/Constan\\u021ba\", \"score\": 0.881383199962492, \"rank\": 0.1308980213089845, \"text\": \"Constanza\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Constan\\u021ba\", \"dbpedia\": \"http://dbpedia.org/resource/Constan\\u021ba\"}], \"noun_phrases\": [{\"ngram\": \"The company\", \"from\": 1652, \"to\": 1663}, {\"ngram\": \"whose son\", \"from\": 1704, \"to\": 1713}, {\"ngram\": \"the ability\", \"from\": 1762, \"to\": 1773}]}, {\"sentence\": \"\\\"When he was five years old, I gave him his first wheelchair and told him I was a robotics engineer and he said I should make a robot that would allow him to walk,\\\" Constanzatolde-Magazine, which covers medical innovation, in 2022.\", \"from\": 1784, \"to\": 2015, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"his first wheelchair\", \"from\": 1824, \"to\": 1844}, {\"ngram\": \"a robotics engineer\", \"from\": 1864, \"to\": 1883}, {\"ngram\": \"a robot\", \"from\": 1910, \"to\": 1917}, {\"ngram\": \"\\\" Constanzatolde-Magazine\", \"from\": 1947, \"to\": 1972}, {\"ngram\": \"medical innovation\", \"from\": 1987, \"to\": 2005}]}, {\"sentence\": \"If that does not hit you right in the feels, then check out how Constanzadescribesusers' reactions to wearing his device for the first time: \\\"It is the moment of standing up with nothing in front of them to stop them falling that makes them laugh or cry-it is always a shock.\", \"from\": 2017, \"to\": 2292, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the feels\", \"from\": 2051, \"to\": 2060}, {\"ngram\": \"how Constanzadescribesusers' reactions\", \"from\": 2077, \"to\": 2115}, {\"ngram\": \"his device\", \"from\": 2127, \"to\": 2137}, {\"ngram\": \"the first time\", \"from\": 2142, \"to\": 2156}, {\"ngram\": \"the moment\", \"from\": 2165, \"to\": 2175}, {\"ngram\": \"nothing\", \"from\": 2196, \"to\": 2203}, {\"ngram\": \"front\", \"from\": 2207, \"t