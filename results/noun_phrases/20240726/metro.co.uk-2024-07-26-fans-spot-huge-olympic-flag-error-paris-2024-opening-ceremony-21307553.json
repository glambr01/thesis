, \"to\": 1053}, {\"ngram\": \"60 choristers\", \"from\": 1071, \"to\": 1084}, {\"ngram\": \"the flag\", \"from\": 1119, \"to\": 1127}]}, {\"sentence\": \"However, none of the officials spotted that the flag was raised incorrectly with the green and yellow rings appeared at the top - meaning that it was upside down.\", \"from\": 1141, \"to\": 1303, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"none\", \"from\": 1150, \"to\": 1154}, {\"ngram\": \"the officials\", \"from\": 1158, \"to\": 1171}, {\"ngram\": \"the flag\", \"from\": 1185, \"to\": 1193}, {\"ngram\": \"the green and yellow rings\", \"from\": 1222, \"to\": 1248}, {\"ngram\": \"the top\", \"from\": 1261, \"to\": 1268}]}, {\"sentence\": \"Unperturbed by the error with the Olympic flag, Tony Estanguet, the president of Paris 2024, stepped on stage to deliver his speech.\", \"from\": 1305, \"to\": 1437, \"entities\": [{\"begin\": 1353, \"end\": 1367, \"title\": \"http://dbpedia.org/resource/Tony_Estanguet\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Tony Estanguet\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Tony_Estanguet\", \"dbpedia\": \"http://dbpedia.org/resource/Tony_Estanguet\"}, {\"begin\": 1386, \"end\": 1396, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 3.0298603836025145e-17, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"the error\", \"from\": 1320, \"to\": 1329}, {\"ngram\": \"the Olympic flag\", \"from\": 1335, \"to\": 1351}, {\"ngram\": \"the president\", \"from\": 1369, \"to\": 1382}, {\"ngram\": \"stage\", \"from\": 1409, \"to\": 1414}, {\"ngram\": \"his speech\", \"from\": 1426, \"to\": 1436}]}, {\"sentence\": \"'France is often said to be the country of love.\", \"from\": 1439, \"to\": 1487, \"entities\": [{\"begin\":