ople\", \"from\": 1002, \"to\": 1014}]}, {\"sentence\": \"This modest introduction at a bustling bar laid the foundation for their enduring romance, making their connection to the Olympics all the more special.\", \"from\": 1022, \"to\": 1174, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"This modest introduction\", \"from\": 1022, \"to\": 1046}, {\"ngram\": \"a bustling bar\", \"from\": 1050, \"to\": 1064}, {\"ngram\": \"the foundation\", \"from\": 1070, \"to\": 1084}, {\"ngram\": \"their enduring romance\", \"from\": 1089, \"to\": 1111}, {\"ngram\": \"their connection\", \"from\": 1120, \"to\": 1136}, {\"ngram\": \"the Olympics\", \"from\": 1140, \"to\": 1152}]}, {\"sentence\": \"Copyright \\u00a9 2025.\", \"from\": 1176, \"to\": 1193, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Copyright \\u00a9\", \"from\": 1176, \"to\": 1187}]}, {\"sentence\": \"The News International, All Rights Reserved\", \"from\": 1194, \"to\": 1237, \"entities\": [{\"begin\": 1194, \"end\": 1216, \"title\": \"http://dbpedia.org/resource/The_News_International\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"The News International\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_News_International\", \"dbpedia\": \"http://dbpedia.org/resource/The_News_International\"}], \"noun_phrases\": []}]}"