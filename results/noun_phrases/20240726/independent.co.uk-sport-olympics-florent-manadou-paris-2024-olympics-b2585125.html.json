8, \"to\": 1148, \"entities\": [{\"begin\": 1027, \"end\": 1038, \"title\": \"http://dbpedia.org/resource/2012_Summer_Olympics\", \"score\": 0.9999999909923645, \"rank\": 9.007757628530057e-09, \"text\": \"London 2012\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2012_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2012_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"12 years\", \"from\": 968, \"to\": 976}, {\"ngram\": \"the scene\", \"from\": 1014, \"to\": 1023}, {\"ngram\": \"the so-called \\\"splash\", \"from\": 1063, \"to\": 1084}, {\"ngram\": \"dash\", \"from\": 1089, \"to\": 1093}, {\"ngram\": \"the wallfirst\", \"from\": 1104, \"to\": 1117}, {\"ngram\": \"50m freestyle gold\", \"from\": 1129, \"to\": 1147}]}, {\"sentence\": \"If you were to sculpt an ideal swimmer, it would probably look a lot like Manaudou.\", \"from\": 1150, \"to\": 1233, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an ideal swimmer\", \"from\": 1172, \"to\": 1188}, {\"ngram\": \"Manaudou\", \"from\": 1224, \"to\": 1232}]}, {\"sentence\": \"Broad shouldered and long-limbed at six-foot-six, he was born to a French father and Dutch mother in the south of France and is the second of two Olympic gold-medal winning siblings.\", \"from\": 1234, \"to\": 1416, \"entities\": [{\"begin\": 1301, \"end\": 1307, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.507411212467218, \"rank\": 0.7121340055801245, \"text\": \"French\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 1319, \"end\": 1324, \"title\": \"http://dbpedia.org/resource/Netherlands\", \"score\": 0.9265156767766155, \"rank\": 0.0775692938126939, \"text\": \"Dutch\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Netherlands\", \"dbpedia\": \"http://dbpedia.org/resource/Netherlands\"}, {\"begin\": 1348, \"end\": 1354, \"title\": \"http://dbpedia.org/resource/France\