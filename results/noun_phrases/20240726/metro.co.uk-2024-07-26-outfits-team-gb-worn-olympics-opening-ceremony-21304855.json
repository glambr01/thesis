], \"noun_phrases\": [{\"ngram\": \"this day\", \"from\": 3352, \"to\": 3360}, {\"ngram\": \"Pearly Kings\", \"from\": 3362, \"to\": 3374}, {\"ngram\": \"Queens\", \"from\": 3379, \"to\": 3385}, {\"ngram\": \"money\", \"from\": 3404, \"to\": 3409}, {\"ngram\": \"causes\", \"from\": 3414, \"to\": 3420}, {\"ngram\": \"the capital\", \"from\": 3428, \"to\": 3439}, {\"ngram\": \"around 30 Pearly families\", \"from\": 3459, \"to\": 3484}]}, {\"sentence\": \"Would not a bit of embellishment have looked fun on Team GB?\", \"from\": 3487, \"to\": 3547, \"entities\": [{\"begin\": 3539, \"end\": 3546, \"title\": \"http://dbpedia.org/resource/Team_GB\", \"score\": 0.9523612425868827, \"rank\": 0.0500213128300985, \"text\": \"Team GB\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Team_GB\", \"dbpedia\": \"http://dbpedia.org/resource/Team_GB\"}], \"noun_phrases\": [{\"ngram\": \"a bit\", \"from\": 3497, \"to\": 3502}, {\"ngram\": \"embellishment\", \"from\": 3506, \"to\": 3519}]}, {\"sentence\": \"UK designer Ashish would have knocked a bedazzled Opening Ceremony look out of the park.\", \"from\": 3548, \"to\": 3636, \"entities\": [{\"begin\": 3548, \"end\": 3550, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.999458489629007, \"rank\": 0.0005418033694830526, \"text\": \"UK\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}, {\"begin\": 3560, \"end\": 3566, \"title\": \"http://dbpedia.org/resource/Asish_Rai\", \"score\": 0.9999999997703526, \"rank\": 2.2985688511702987e-10, \"text\": \"Ashish\", \"types\": [\"Q937857\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Asish_Rai\", \"dbpedia\": \"http://dbpedia.org/resource/Asish_Rai\"}], \"noun_phrases\": [{\"ngram\": \"a bedazzled Opening Ceremony\", \"from\": 3586, \"to\": 3614}, {\"ngram\": \"the park\", \"from\": 3627, \"to\": 3635}]}, {\"sentence\": \"With Team GB hailing from so many places across the country, the designers might've decided to kit them out in choices specific to where they are from.\", \"from\": 3638, \"to\": 3789, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Team GB\", \"from\": 3643, \"to\": 3650}, {\"ngram\": \"so many places\", \"from\": 3664, \"to\": 3678}, {\"ngram\": \"the country\", \"from\": 3686, \"to\": 3697}, {\"ngram\": \"the designers\", \"from\": 3699, \"to\": 3712}, {\"ngram\": \"choices\", \"from\": 3749, \"to\": 3756}]}, {\"sentence\": \"Yes, we know this would have entailed much more work - but it's fun in principle, right?\", \"from\": 3790, \"to\": 3878, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"much more work\", \"from\": 3828, \"to\": 3842}, {\"ngram\": \"fun\", \"from\": 3854, \"to\": 3857}, {\"ngram\": \"principle\", \"from\": 3861, \"to\": 3870}]}, {\"sentence\": \"The very image of Scotland itself, a kilt - or even just a tartan-inspired look - would have looked so fresh on Team GB.\", \"from\": 3880, \"to\": 4000, \"entities\": [{\"begin\": 3898, \"end\": 3906, \"title\": \"http://dbpedia.org/resource/Scotland\", \"score\": 0.9999981270765861, \"rank\": 1.474622648183735e-06, \"text\": \"Scotland\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Scotland\", \"dbpedia\": \"http://dbpedia.org/resource/Scotland\"}, {\"begin\": 3992, \"end\": 3999, \"title\": \"http://dbpedia.org/resource/Team_GB\", \"score\": 0.9523612425868827, \"rank\": 0.0500213128300985, \"text\": \"Team GB\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Team_GB\", \"dbpedia\": \"http://dbpedia.org/resource/Team_GB\"}], \"noun_phrases\": [{\"ngram\": \"The very image\", \"from\": 3880, \"to\": 3894}, {\"ngram\": \"a kilt - or even just a tartan-inspired look\", \"from\": 3915, \"to\": 3959}]}, {\"sentence\": \"They have been around since the 16th century, so it's not exactly radical.\", \"from\": 4001, \"to\": 4075, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the 16th century\", \"from\": 4029, \"to\": 4045}]}, {\"sentence\": \"Athletes from Northern Ireland are allowed to choose who they compete for (between Team GB and Ireland) and tartan trousers have been seen in traditional Northern Irish dress too.\", \"from\": 4076, \"to\": 4255, \"entities\": [{\"begin\": 4090, \"end\": 4106, \"title\": \"http://dbpedia.org/resource/Northern_Ireland\", \"score\": 0.9999997723712372, \"rank\": 2.2762863040378663e-07, \"text\": \"Northern Ireland\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Northern_Ireland\", \"dbpedia\": \"http://dbpedia.org/resource/Northern_Ireland\"}, {\"begin\": 4159, \"end\": 4166, \"title\": \"http://dbpedia.org/resource/Team_GB\", \"score\": 0.9523612425868827, \"rank\": 0.0500213128300985, \"text\": \"Team GB\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Team_GB\", \"dbpedia\": \"http://dbpedia.org/resource/Team_GB\"}, {\"begin\": 4171, \"end\": 4178, \"title\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"score\": 0.8882626803886479, \"rank\": 0.12577430898136427, \"text\": \"Ireland\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"dbpedia\": \"http://dbpedia.org/resource/Republic_of_Ireland\"}, {\"begin\": 4230, \"end\": 4244, \"title\": \"http://dbpedia.org/resource/Irish_people\", \"score\": 0.9892765519730984, \"rank\": 0.010839673434685509, \"text\": \"Northern Irish\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Irish_people\", \"dbpedia\": \"http://dbpedia.org/resource/Irish_people\"}], \"noun_phrases\": [{\"ngram\": \"Athletes\", \"from\": 4076, \"to\": 4084}, {\"ngram\": \"tartan trousers\", \"from\": 4184, \"to\": 4199}]}, {\"sentence\": \"Meanwhile, the rural women of Wales have a long history with Welsh traditional costume.\", \"from\": 4257, \"to\": 4344, \"entities\": [{\"begin\": 4287, \"end\": 4292, \"title\": \"http://dbpedia.org/resource/Wales\", \"score\": 0.9999766089388678, \"rank\": 2.3