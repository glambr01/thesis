nce\", \"from\": 3594, \"to\": 3602}, {\"ngram\": \"the source\", \"from\": 3604, \"to\": 3614}, {\"ngram\": \"the case\", \"from\": 3626, \"to\": 3634}, {\"ngram\": \"an attack\", \"from\": 3688, \"to\": 3697}]}, {\"sentence\": \"The source said the man was acting under instruction from ISIS-K handlers based abroad.\", \"from\": 3713, \"to\": 3800, \"entities\": [{\"begin\": 3771, \"end\": 3777, \"title\": \"http://dbpedia.org/resource/Islamic_State_\\u2013_Khorasan_Province\", \"score\": 0.9965712144984205, \"rank\": 0.0, \"text\": \"ISIS-K\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Islamic_State_\\u2013_Khorasan_Province\", \"dbpedia\": \"http://dbpedia.org/resource/Islamic_State_\\u2013_Khorasan_Province\"}], \"noun_phrases\": [{\"ngram\": \"The source\", \"from\": 3713, \"to\": 3723}, {\"ngram\": \"the man\", \"from\": 3729, \"to\": 3736}, {\"ngram\": \"instruction\", \"from\": 3754, \"to\": 3765}]}, {\"sentence\": \"A second security source said France had identified a dozen ISIS-K handlers, based in countries around Afghanistan who have a strong online presence and try to convince young men in European countries who are interested in joining up with the group overseas to instead carry out domestic attacks.\", \"from\": 3802, \"to\": 4098, \"entities\": [{\"begin\": 3832, \"end\": 3838, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9992406731491928, \"rank\": 0.0007598634540600774, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 3862, \"end\": 3868, \"title\": \"http://dbpedia.org/resource/Islamic_State_\\u2013_Khorasan_Province\", \"score\": 0.9965712144984205, \"rank\": 0.0, \"text\": \"ISIS-K\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Islamic_State_\\u2013_Khorasan_Province\", \"dbpedia\": \"http://dbpedia.org/resource/Islamic_State_\\u2013_Khorasan_Province\"}, {\"begin\": 3905, \"end\": 3916, 