om\": 8374, \"to\": 8391}]}, {\"sentence\": \"France has passed laws allowing the temporary deployment of AI technology which will sift footage from CCTV cameras in real time to detect pre-determined \\\"events\\\" such as crowd surges, an individual dropping or leaving a bag, the identification of weapons or even a speeding vehicle that could signal a ramming attack.\", \"from\": 8394, \"to\": 8712, \"entities\": [{\"begin\": 8394, \"end\": 8400, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9997052605007668, \"rank\": 0.0002179393856925317, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 8454, \"end\": 8456, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 1.0, \"rank\": 9.214577942038182e-15, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}, {\"begin\": 8497, \"end\": 8501, \"title\": \"http://dbpedia.org/resource/Closed-circuit_television\", \"score\": 1.0, \"rank\": 3.693716536151487e-16, \"text\": \"CCTV\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Closed-circuit_television\", \"dbpedia\": \"http://dbpedia.org/resource/Closed-circuit_television\"}], \"noun_phrases\": [{\"ngram\": \"laws\", \"from\": 8412, \"to\": 8416}, {\"ngram\": \"the temporary deployment\", \"from\": 8426, \"to\": 8450}, {\"ngram\": \"footage\", \"from\": 8484, \"to\": 8491}, {\"ngram\": \"real time\", \"from\": 8513, \"to\": 8522}, {\"ngram\": \"-determined \\\"events\", \"from\": 8536, \"to\": 8555}, {\"ngram\": \"crowd surges\", \"from\": 8565, \"to\": 8577}, {\"ngram\": \"a bag\", \"from\": 8613, \"to\": 8618}, {\"ngram\": \"the identification\", \"from\": 8620, \"to\": 8638}, {\"ngram\": \"weapons\", \"from\": 8642, \"to\": 8649}, {\"ngram\": \"even a speeding vehicle\", \"from\": 8653, \"to