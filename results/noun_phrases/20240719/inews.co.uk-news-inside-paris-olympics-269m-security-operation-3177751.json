om\": 1720, \"to\": 1730}, {\"ngram\": \"the four-week extravaganza\", \"from\": 1734, \"to\": 1760}, {\"ngram\": \"some distance\", \"from\": 1765, \"to\": 1778}, {\"ngram\": \"the world's largest sporting event\", \"from\": 1779, \"to\": 1813}, {\"ngram\": \"between 30,000 and 45,000 police\", \"from\": 1815, \"to\": 1847}, {\"ngram\": \"soldiers\", \"from\": 1852, \"to\": 1860}, {\"ngram\": \"duty\", \"from\": 1872, \"to\": 1876}]}, {\"sentence\": \"By way of comparison, the total number of police on the streets of London during the2012 Olympicswas 9,500.\", \"from\": 1887, \"to\": 1994, \"entities\": [{\"begin\": 1954, \"end\": 1960, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9999999999763531, \"rank\": 2.33126454317484e-11, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}], \"noun_phrases\": [{\"ngram\": \"way\", \"from\": 1890, \"to\": 1893}, {\"ngram\": \"comparison\", \"from\": 1897, \"to\": 1907}, {\"ngram\": \"the total number\", \"from\": 1909, \"to\": 1925}, {\"ngram\": \"police\", \"from\": 1929, \"to\": 1935}, {\"ngram\": \"the streets\", \"from\": 1939, \"to\": 1950}, {\"ngram\": \"the2012\", \"from\": 1968, \"to\": 1975}]}, {\"sentence\": \"The French operation will be bolstered by an array of AI-supported surveillance technology and foreign security specialists, including nearly 250 British law enforcement and military personnel which will include search dog teams and a contingent of Royal Air Force counter-drone experts and equipment.\", \"from\": 1996, \"to\": 2297, \"entities\": [{\"begin\": 2000, \"end\": 2006, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9969834902429977, \"rank\": 0.0025021586657926103, \"text\": \"French\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 2142, \"end\": 2149, \"title\"