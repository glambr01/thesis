egin\": 31457, \"end\": 31465, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9997533726320204, \"rank\": 0.0002180454394115011, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"The 200-meter sprint\", \"from\": 31398, \"to\": 31418}, {\"ngram\": \"specialty\\u00e2\\u0080\\u0094he\", \"from\": 31432, \"to\": 31446}, {\"ngram\": \"19.31 seconds\\u00e2\\u0080\\u0094so\", \"from\": 31476, \"to\": 31494}, {\"ngram\": \"a surprise\", \"from\": 31507, \"to\": 31517}, {\"ngram\": \"his gold medal\", \"from\": 31535, \"to\": 31549}, {\"ngram\": \"the event\", \"from\": 31553, \"to\": 31562}, {\"ngram\": \"worlds\", \"from\": 31566, \"to\": 31572}, {\"ngram\": \"the comparisons\", \"from\": 31616, \"to\": 31631}, {\"ngram\": \"Bolt\", \"from\": 31635, \"to\": 31639}, {\"ngram\": \"spades\", \"from\": 31659, \"to\": 31665}]}, {\"sentence\": \"But Lyles\\u00e2\\u0080\\u0099s isn\\u00e2\\u0080\\u0099t just looking for two or three gold medals in Paris like Bolt regularly won\\u00e2\\u0080\\u0094he wants four.\", \"from\": 31667, \"to\": 31780, \"entities\": [{\"begin\": 31734, \"end\": 31739, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999788722186896, \"rank\": 2.1128227701111775e-05, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"isn\\u00e2\\u0080\\u0099t\", \"from\": 31681, \"to\": 31688}, {\"ngram\": \"two or three gold medals\", \"from\": 31706, \"to\": 31730}, {\"ngram\": \"Bolt\", \"from\": 31745, \"to\": 31749}]}, {\"sentence\": \"The sprinter, who already runs the 4X100 relay, is also adding the 4X400 to his busy schedule as the U.S. men look to redeem their Olympic relay woes this summer.\", \"from\": 31781, \"to\": 31943, \"entities\": [{\"