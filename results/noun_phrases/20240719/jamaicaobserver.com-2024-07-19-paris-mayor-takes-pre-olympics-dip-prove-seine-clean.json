"{\"uid\": \"jamaicaobserver.com-2024-07-19-paris-mayor-takes-pre-olympics-dip-prove-seine-clean\", \"noun_phrases\": [{\"sentence\": \"PARIS, France (AFP) - Paris Mayor Anne Hidalgo took a long-awaited swim in the murky waters of the Seine on Wednesday amid joy and relief that the river is finally clean enough for outdoor Olympic swimming events later this month.\", \"from\": 0, \"to\": 230, \"entities\": [{\"begin\": 99, \"end\": 104, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999999999995453, \"rank\": 2.9702774316021276e-13, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"AFP\", \"from\": 15, \"to\": 18}, {\"ngram\": \"a long-awaited swim\", \"from\": 52, \"to\": 71}, {\"ngram\": \"the murky waters\", \"from\": 75, \"to\": 91}, {\"ngram\": \"Wednesday\", \"from\": 108, \"to\": 117}, {\"ngram\": \"joy\", \"from\": 123, \"to\": 126}, {\"ngram\": \"relief\", \"from\": 131, \"to\": 137}, {\"ngram\": \"the river\", \"from\": 143, \"to\": 152}, {\"ngram\": \"outdoor Olympic swimming events\", \"from\": 181, \"to\": 212}]}, {\"sentence\": \"Wearing goggles and a wet suit, the 65-year-old city leader swam breaststroke under bright sunshine before immersing her face and switching to front crawl, covering around 100 metres (yards) downstream.\", \"from\": 232, \"to\": 434, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"goggles\", \"from\": 240, \"to\": 247}, {\"ngram\": \"a wet suit\", \"from\": 252, \"to\": 262}, {\"ngram\": \"bright sunshine\", \"from\": 316, \"to\": 331}, {\"ngram\": \"her face\", \"from\": 349, \"to\": 357}, {\"ngram\": \"front crawl\", \"from\": 375, \"to\": 386}, {\"ngram\": \"around 100 metres (yards) downstream\", \"from\": 397, \"to\": 433}]}, {\"sentence\": \"\\\"It's wonderful, very, very pleasant,\\\" Hidalgo told reporters of the greenish water.\", \"from\": 436, \"to\": 520, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Hidalgo\", \"from\": 475, \"to\": 482}, {\"ngram\": \"reporters\", \"from\": 488, \"to\": 497}, {\"ngram\": \"the greenish water\", \"from\": 501, \"to\": 519}]}, {\"sentence\": \"\\\"It's fresh but not cold.\\\"\", \"from\": 521, \"to\": 547, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"She was joined by senior local officials and chief organiser of the Paris Games, Tony Estanguet, a gold medal-winning canoeist who has been sweating on the state of the Seine ahead of the opening ceremony next week.\", \"from\": 549, \"to\": 764, \"entities\": [{\"begin\": 630, \"end\": 644, \"title\": \"http://dbpedia.org/resource/Tony_Estanguet\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Tony Estanguet\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Tony_Estanguet\", \"dbpedia\": \"http://dbpedia.org/resource/Tony_Estanguet\"}, {\"begin\": 718, \"end\": 723, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999999999995453, \"rank\": 2.9702774316021276e-13, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"senior local officials\", \"from\": 567, \"to\": 589}, {\"ngram\": \"chief organiser\", \"from\": 594, \"to\": 609}, {\"ngram\": \"the Paris Games\", \"from\": 613, \"to\": 628}, {\"ngram\": \"a gold medal-winning canoeist\", \"from\": 646, \"to\": 675}, {\"ngram\": \"the state\", \"from\": 701, \"to\": 710}, {\"ngram\": \"the opening ceremony\", \"from\": 733, \"to\": 753}]}, {\"sentence\": \"\\\"Today is a confirmation that we are exactly where we are meant to be,\\\" Estanguet said.\", \"from\": 766, \"to\": 853, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Today\", \"from\": 767, \"to\": 772}, {\"ngram\": \"a confirmation\", \"from\": 776, \"to\": 790}, {\"ngram\": \"Estanguet\", \"from\": 838, \"to\": 847}]}, {\"sentence\": \"\\\"We are now ready to organise the Games in the Seine.\\\"\", \"from\": 854, \"to\": 908, \"entities\": [{\"begin\": 901, \"end\": 906, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999999999995453, \"rank\": 2.9702774316021276e-13, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"the Games\", \"from\": 884, \"to\": 893}]}, {\"sentence\": \"The swimming leg of the Olympics triathlon is set to take place in its waters on July 30-31 and August 5, followed by the open-water swimming on August 8-9.\", \"from\": 910, \"to\": 1066, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The swimming leg\", \"from\": 910, \"to\": 926}, {\"ngram\": \"the Olympics triathlon\", \"from\": 930, \"to\": 952}, {\"ngram\": \"place\", \"from\": 968, \"to\": 973}, {\"ngram\": \"its waters\", \"from\": 977, \"to\": 987}, {\"ngram\": \"July\", \"from\": 991, \"to\": 995}, {\"ngram\": \"August\", \"from\": 1006, \"to\": 1012}, {\"ngram\": \"the open-water swimming\", \"from\": 1028, \"to\": 1051}, {\"ngram\": \"August\", \"from\": 1055, \"to\": 1061}]}, {\"sentence\": \"Despite an investment of 1.4 billion euros ($1.5 billion) to prevent sewage leaks into the waterway, the river had been continually failing water quality tests until the start of this month.\", \"from\": 1068, \"to\": 1258, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an investment\", \"from\": 1076, \"to\": 1089}, {\"ngram\": \"1.4 billion euros\", \"from\": 1093, \"to\": 1110}, {\"ngram\": \"sewage leaks\", \"from\": 1137, \"to\": 1149}, {\"ngram\": \"the waterway\", \"from\": 1155, \"to\": 1167}, {\"ngram\": \"the river\", \"from\": 1169, \"to\": 1178}, {\"ngram\": \"water quality tests\", \"from\": 1208, \"to\": 1227}, {\"ngram\": \"the start\", \"from\": 1234, \"to\": 1243}, {\"ngram\": \"this month\", \"from\": 1247, \"to\": 1257}]}, {\"sentence\": \"Wednesday's dip in front of more than 150 journalists was intended to demonstrate that the river was ready, but also to underline what is meant to be one of the key legacy achievements of Paris 2024.\", \"from\": 1260, \"to\": 1459, \"entities\": [{\"begin\": 1448, \"end\": 1458, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 2.1532356840159385e-30, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"Wednesday's dip\", \"from\": 1260, \"to\": 1275}, {\"ngram\": \"front\", \"from\": 1279, \"to\": 1284}, {\"ngram\": \"more than 150 journalists\", \"from\": 1288, \"to\": 1313}, {\"ngram\": \"the river\", \"from\": 1347, \"to\": 1356}, {\"ngram\": \"the key legacy achievements\", \"from\": 1417, \"to\": 1444}]}, {\"sentence\": \"Hidalgo plans to create three public bathing areas in the Seine for the city's residents next year - a century after swimming was banned - while fish and other organisms are also returning to the waterway in greater numbers.\", \"from\": 1461, \"to\": 1685, \"entities\": [{\"begin\": 1519, \"end\": 1524, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999999999995453, \"rank\": 2.9702774316021276e-13, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"Hidalgo\", \"from\": 1461, \"to\": 1468}, {\"ngram\": \"three public bathing areas\", \"from\": 1485, \"to\": 1511}, {\"ngram\": \"the city's residents\", \"from\": 1529, \"to\": 1549}, {\"ngram\": \"swimming\", \"from\": 1578, \"to\": 1586}, {\"ngram\": \"fish\", \"from\": 1606, \"to\": 1610}, {\"ngram\": \"other organisms\", \"from\": 1615, \"to\": 1630}, {\"ngram\": \"the waterway\", \"from\": 1653, \"to\": 1665}, {\"ngram\": \"greater numbers\", \"from\": 1669, \"to\": 1684}]}, {\"sentence\": \"Hidalgo had originally planned to swim last month, but had to delay because water tests showed that E coli bacteria - a key indicator of faecal matter - were sometimes up to 10 times higher than authorised limits.\", \"from\": 1687, \"to\": 1900, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Hidalgo\", \"from\": 1687, \"to\": 1694}, {\"ngram\": \"water tests\", \"from\": 1763, \"to\": 1774}, {\"ngram\": \"E\", \"from\": 1787, \"to\": 1788}, {\"ngram\": \"bacteria\", \"from\": 1794, \"to\": 1802}, {\"ngram\": \"a key indicator\", \"from\": 1805, \"to\": 1820}, {\"ngram\": \"faecal matter\", \"from\": 1824, \"to\": 1837}, {\"ngram\": \"authorised limits\", \"from\": 1882, \"to\": 1899}]}, {\"sentence\": \"Her swim had sparked jokes and memes on social media, with one viral AI-generated image showing her looking like the wrinkled Gollum character from the \\\"Lord of the Rings\\\" movies after emerging from the water.\", \"from\": 1902, \"to\": 2111, \"entities\": [{\"begin\": 2028, \"end\": 2034, \"title\": \"http://dbpedia.org/resource/Gollum\", \"score\": 1.0, \"rank\": 1.0737840639379458e-28, \"text\": \"Gollum\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Gollum\", \"dbpedia\": \"http://dbpedia.org/resource/Gollum\"}], \"noun_phrases\": [{\"ngram\": \"Her swim\", \"from\": 1902, \"to\": 1910}, {\"ngram\": \"jokes\", \"from\": 1923, \"to\": 1928}, {\"ngram\": \"memes\", \"from\": 1933, \"to\": 1938}, {\"ngram\": \"social media\", \"from\": 1942, \"to\": 1954}, {\"ngram\": \"one viral AI-generated image\", \"from\": 1961, \"to\": 1989}, {\"ngram\": \"the Rings\", \"from\": 2063, \"to\": 2072}, {\"ngram\": \"the water\", \"from\": 2101, \"to\": 2110}]}, {\"sentence\": \"A short-lived protest group posting under the hashtag #jechiedanslaSeine (#IshitintheSeine) had also encouraged people to empty their bowels in the river upstream.\", \"from\": 2113, \"to\": 2276, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A short-lived protest group\", \"from\": 2113, \"to\": 2140}, {\"ngram\": \"the hashtag\", \"from\": 2155, \"to\": 2166}, {\"ngram\": \"jechiedanslaSeine\", \"from\": 2168, \"to\": 2185}, {\"ngram\": \"#IshitintheSeine\", \"from\": 2187, \"to\": 2203}, {\"ngram\": \"people\", \"from\": 2225, \"to\": 2231}, {\"ngram\": \"their bowels\", \"from\": 2241, \"to\": 2253}, {\"ngram\": \"the river upstream\", \"from\": 2257, \"to\": 2275}]}, {\"sentence\": \"President Emmanuel Macron, who had promised to join the Seine bathers, was a notable absentee on Wednesday as he is occupied by a political crisis caused by his decision to call snap parliamentary elections last month.\", \"from\": 2278, \"to\": 2496, \"entities\": [{\"begin\": 2288, \"end\": 2303, \"title\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Emmanuel Macron\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"dbpedia\": \"http://dbpedia.org/resource/Emmanuel_Macron\"}, {\"begin\": 2334, \"end\": 2339, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999999999995453, \"rank\": 2.9702774316021276e-13, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"a notable absentee\", \"from\": 2353, \"to\": 2371}, {\"ngram\": \"Wednesday\", \"from\": 2375, \"to\": 2384}, {\"ngram\": \"a political crisis\", \"from\": 2406, \"to\": 2424}, {\"ngram\": \"his decision\", \"from\": 2435, \"to\": 2447}, {\"ngram\": \"snap parliamentary elections\", \"from\": 2456, \"to\": 2484}]}, {\"sentence\": \"The locations chosen for outdoor swimming at the Olympics have caused difficulties in the past, notably ahead of the 2016 Rio de Janeiro Games and those in Tokyo in 2021.\", \"from\": 2498, \"to\": 2668, \"entities\": [{\"begin\": 2654, \"end\": 2659, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.9999999997999112, \"rank\": 1.9315729079611347e-10, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"The locations\", \"from\": 2498, \"to\": 2511}, {\"ngram\": \"outdoor swimming\", \"from\": 2523, \"to\": 2539}, {\"ngram\": \"the Olympics\", \"from\": 2543, \"to\": 2555}, {\"ngram\": \"difficulties\", \"from\": 2568, \"to\": 2580}, {\"ngram\": \"the past\", \"from\": 2584, \"to\": 2592}, {\"ngram\": \"the 2016 Rio de Janeiro Games\", \"from\": 2611, \"to\": 2640}]}, {\"sentence\": \"French authorities have invested in new water treatment and storage facilities in and around Paris, as well as ensuring that thousands of homes and canal boats without waste water connections are linked up to the sewerage system.\", \"from\": 2670, \"to\": 2899, \"entities\": [{\"begin\": 2670, \"end\": 2676, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.7980022699646974, \"rank\": 0.2505444902013491, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 2763, \"end\": 2768, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 2.6056461179762636e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"new water treatment and storage facilities\", \"from\": 2706, \"to\": 2748}, {\"ngram\": \"thousands\", \"from\": 2795, \"to\": 2804}, {\"ngram\": \"homes\", \"from\": 2808, \"to\": 2813}, {\"ngram\": \"canal boats\", \"fro