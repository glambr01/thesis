"{\"uid\": \"thelocal.fr-20240712-where-and-when-you-can-see-the-olympic-torch-relay-in-paris-this-weekend\", \"noun_phrases\": [{\"sentence\": \"The Local Europe ABV\\u00e4stmannagatan 43113 25 StockholmSweden The Olympic Torch will arrive in Paris in time for France's F\\u00eate Nationale celebrations.\", \"from\": 0, \"to\": 148, \"entities\": [{\"begin\": 64, \"end\": 77, \"title\": \"http://dbpedia.org/resource/Olympic_flame\", \"score\": 0.9999999999668034, \"rank\": 3.304470814094127e-11, \"text\": \"Olympic Torch\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_flame\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_flame\"}, {\"begin\": 93, \"end\": 98, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 2.741225877927292e-33, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 111, \"end\": 117, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 1.0, \"rank\": 2.6290867074165843e-14, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"The Local Europe ABV\\u00e4stmannagatan\", \"from\": 0, \"to\": 33}, {\"ngram\": \"time\", \"from\": 101, \"to\": 105}]}, {\"sentence\": \"Here is where to go to see it pass through the capital city.\", \"from\": 149, \"to\": 209, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the capital city\", \"from\": 192, \"to\": 208}]}, {\"sentence\": \"It arrived in France on May 8th, aboard the Belem, after a 12-day journey across the Mediterranean from Greece.\", \"from\": 211, \"to\": 322, \"entities\": [{\"begin\": 225, \"end\": 231, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 1.0, \"rank\": 2.6290867074165843e-14, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 255, \"end\": 260, \"title\": \"http://dbpedia.org/resource/Bel\\u00e9m\", \"score\": 0.9903282791598326, \"rank\": 0.00799898425596817, \"text\": \"Belem\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Bel\\u00e9m\", \"dbpedia\": \"http://dbpedia.org/resource/Bel\\u00e9m\"}, {\"begin\": 315, \"end\": 321, \"title\": \"http://dbpedia.org/resource/Greece\", \"score\": 0.8977271709148811, \"rank\": 0.11387626254443128, \"text\": \"Greece\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Greece\", \"dbpedia\": \"http://dbpedia.org/resource/Greece\"}], \"noun_phrases\": [{\"ngram\": \"May 8th\", \"from\": 235, \"to\": 242}, {\"ngram\": \"a 12-day journey\", \"from\": 268, \"to\": 284}, {\"ngram\": \"the Mediterranean\", \"from\": 292, \"to\": 309}]}, {\"sentence\": \"Since then it has travelled to the Lascaux caves, the Al\\u00e9sia archaeological site, the medieval city of Carcassonne, the Palace of Versailles, Mont Saint-Michel, and the ch\\u00e2teaux of the Loire Valley.\", \"from\": 323, \"to\": 521, \"entities\": [{\"begin\": 358, \"end\": 365, \"title\": \"http://dbpedia.org/resource/Lascaux\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Lascaux\", \"types\": [\"Q9259\"], \"wikid\": \"http://dbpedia.org/resource/Lascaux\", \"dbpedia\": \"http://dbpedia.org/resource/Lascaux\"}, {\"begin\": 377, \"end\": 383, \"title\": \"http://dbpedia.org/resource/Alise-Sainte-Reine\", \"score\": 1.0, \"rank\": 8.997003865536194e-29, \"text\": \"Al\\u00e9sia\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Alise-Sainte-Reine\", \"dbpedia\": \"http://dbpedia.org/resource/Alise-Sainte-Reine\"}, {\"begin\": 426, \"end\": 437, \"title\": \"http://dbpedia.org/resource/Carcassonne\", \"score\": 1.0, \"rank\": 1.1002076817176955e-25, \"text\": \"Carcassonne\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Carcassonne\", \"dbpedia\": \"http://dbpedia.org/resource/Carcassonne\"}, {\"begin\": 465, \"end\": 482, \"title\": \"http://dbpedia.org/resource/Mont-Saint-Michel\", \"score\": 1.0, \"rank\": 1.02103856992104e-46, \"text\": \"Mont Saint-Michel\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Mont-Saint-Michel\", \"dbpedia\": \"http://dbpedia.org/resource/Mont-Saint-Michel\"}], \"noun_phrases\": [{\"ngram\": \"the medieval city\", \"from\": 405, \"to\": 422}, {\"ngram\": \"the Palace\", \"from\": 439, \"to\": 449}, {\"ngram\": \"Versailles\", \"from\": 453, \"to\": 463}, {\"ngram\": \"the ch\\u00e2teaux\", \"from\": 488, \"to\": 500}, {\"ngram\": \"the Loire Valley\", \"from\": 504, \"to\": 520}]}, {\"sentence\": \"To honour the history of France, the flame has also been to places of remembrance, such as the Verdun Memorial and the D-Day Landing Beaches.\", \"from\": 523, \"to\": 664, \"entities\": [{\"begin\": 548, \"end\": 554, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 1.0, \"rank\": 2.6290867074165843e-14, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"the history\", \"from\": 533, \"to\": 544}, {\"ngram\": \"the flame\", \"from\": 556, \"to\": 565}, {\"ngram\": \"places\", \"from\": 583, \"to\": 589}, {\"ngram\": \"remembrance\", \"from\": 593, \"to\": 604}, {\"ngram\": \"the Verdun Memorial\", \"from\": 614, \"to\": 633}, {\"ngram\": \"the D-Day Landing Beaches\", \"from\": 638, \"to\": 663}]}, {\"sentence\": \"It has crossed the Atlantic, Indian and Pacific Oceans to take in Guadeloupe, Guyana, Martinique, French Polynesia, New Caledonia and Reunion.\", \"from\": 666, \"to\": 808, \"entities\": [{\"begin\": 695, \"end\": 701, \"title\": \"http://dbpedia.org/resource/Indian_Ocean\", \"score\": 0.9999311751514467, \"rank\": 3.7213756131325986e-05, \"text\": \"Indian\", \"types\": [], \"wikid\": \"http://dbpedia.org/re