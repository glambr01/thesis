om\": 1605, \"to\": 1611}, {\"ngram\": \"last season\", \"from\": 1646, \"to\": 1657}]}, {\"sentence\": \"We would throw caution at the Fournier signing, he can still shoot, but his burst is all but gone and he struggles to create any separation for himself.\", \"from\": 1683, \"to\": 1835, \"entities\": [{\"begin\": 1713, \"end\": 1721, \"title\": \"http://dbpedia.org/resource/Michael_Fournier\", \"score\": 0.9781100927341715, \"rank\": 0.016753847961041696, \"text\": \"Fournier\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Michael_Fournier\", \"dbpedia\": \"http://dbpedia.org/resource/Michael_Fournier\"}], \"noun_phrases\": [{\"ngram\": \"caution\", \"from\": 1698, \"to\": 1705}, {\"ngram\": \"his burst\", \"from\": 1755, \"to\": 1764}, {\"ngram\": \"any separation\", \"from\": 1808, \"to\": 1822}]}, {\"sentence\": \"There was zero genuine interest in the French guard from NBA teams in any role beyond locker room veteran presence this summer and for good reason.\", \"from\": 1836, \"to\": 1983, \"entities\": [{\"begin\": 1875, \"end\": 1881, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.7987043256647869, \"rank\": 0.2508583987077997, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 1893, \"end\": 1896, \"title\": \"http://dbpedia.org/resource/National_Basketball_Association\", \"score\": 1.0, \"rank\": 1.4721686062023245e-31, \"text\": \"NBA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/National_Basketball_Association\", \"dbpedia\": \"http://dbpedia.org/resource/National_Basketball_Association\"}], \"noun_phrases\": [{\"ngram\": \"zero genuine interest\", \"from\": 1846, \"to\": 1867}, {\"ngram\": \"any role\", \"from\": 1906, \"to\": 1914}, {\"ngram\": \"locker room veteran presence\", \"from\": 1922, \"to\": 1950}, {\"ngram\": \"good reason\", \"from\": 1971, \"to\": 1982}]}, {\"sentence\": \"Fournier can help you win at this level, but Luca Vildoza, Tyler Dorsey, and eventually Keenan Evans will likely be better sources of the offensive verve the Reds lacked last season.\\u00c2 This is one of the deepest and most talented EuroLeague rosters in recent memory.\", \"from\": 1984, \"to\": 2250, \"entities\": [{\"begin\": 1984, \"end\": 1992, \"title\": \"http://dbpedia.org/resource/Michael_Fournier\", \"score\": 0.9781100927341715, \"rank\": 0.016753847961041696, \"text\": \"Fournier\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Michael_Fournier\", \"dbpedia\": \"http://dbpedia.org/resource/Michael_Fournier\"}, {\"begin\": 2029, \"end\": 2041, \"title\": \"http://dbpedia.org/resource/Luca_Vildoza\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Luca Vildoza\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Luca_Vildoza\", \"dbpedia\": \"http://dbpedia.org/resource/Luca_Vildoza\"}, {\"begin\": 2043, \"end\": 2055, \"title\": \"http://dbpedia.org/resource/Tyler_Dorsey\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Tyler Dorsey\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Tyler_Dorsey\", \"dbpedia\": \"http://dbpedia.org/resource/Tyler_Dorsey\"}, {\"begin\": 2072, \"end\": 2084, \"title\": \"http://dbpedia.org/resource/Keenan_Evans\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Keenan Evans\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Keenan_Evans\", \"dbpedia\": \"http://dbpedia.org/resource/Keenan_Evans\"}, {\"begin\": 2142, \"end\": 2146, \"title\": \"http://dbpedia.org/resource/Cincinnati_Reds\", \"score\": 0.9890181536865983, \"rank\": 0.011103532438194076, \"text\": \"Reds\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Cincinnati_Reds\", \"dbp