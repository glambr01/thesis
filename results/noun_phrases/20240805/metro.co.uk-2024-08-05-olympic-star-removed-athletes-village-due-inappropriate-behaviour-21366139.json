"{\"uid\": \"metro.co.uk-2024-08-05-olympic-star-removed-athletes-village-due-inappropriate-behaviour-21366139\", \"noun_phrases\": [{\"sentence\": \"ParaguayanswimmerLuana Alonsohas been expelled from the athletes' village at theParisOlympics after allegedly creating an 'inappropriate environment'.\", \"from\": 0, \"to\": 150, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"ParaguayanswimmerLuana Alonsohas\", \"from\": 0, \"to\": 32}, {\"ngram\": \"the athletes' village\", \"from\": 52, \"to\": 73}, {\"ngram\": \"theParisOlympics\", \"from\": 77, \"to\": 93}, {\"ngram\": \"an 'inappropriate environment\", \"from\": 119, \"to\": 148}]}, {\"sentence\": \"Alonso competed for Paraguay in the women's 100m butterfly but failed to make it beyond the heats, finishing sixth with a time of 1:03.09 last weekend.\", \"from\": 152, \"to\": 303, \"entities\": [{\"begin\": 172, \"end\": 180, \"title\": \"http://dbpedia.org/resource/Paraguay\", \"score\": 0.9533506583195646, \"rank\": 0.0489319568875741, \"text\": \"Paraguay\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Paraguay\", \"dbpedia\": \"http://dbpedia.org/resource/Paraguay\"}], \"noun_phrases\": [{\"ngram\": \"Alonso\", \"from\": 152, \"to\": 158}, {\"ngram\": \"the women's 100m\", \"from\": 184, \"to\": 200}, {\"ngram\": \"the heats\", \"from\": 240, \"to\": 249}, {\"ngram\": \"a time\", \"from\": 272, \"to\": 278}, {\"ngram\": \"1:03.09\", \"from\": 282, \"to\": 289}]}, {\"sentence\": \"Torri Huske and Gretchen Walsh, representing theUnited States, would go on to claim gold and silver respectively in the event, withChina's Zhang Yufei finishing third in Sunday's final to clinch bronze.\", \"from\": 305, \"to\": 507, \"entities\": [{\"begin\": 305, \"end\": 316, \"title\": \"http://dbpedia.org/resource/Torri_Huske\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Torri Huske\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Torri_Huske\", \"dbpedia\": \"http://dbpedia.org/resource/Torri_Huske\"}, {\"begin\": 321, \"end\": 335, \"title\": \"http://dbpedia.org/resource/Gretchen_Walsh\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Gretchen Walsh\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Gretchen_Walsh\", \"dbpedia\": \"http://dbpedia.org/resource/Gretchen_Walsh\"}, {\"begin\": 444, \"end\": 455, \"title\": \"http://dbpedia.org/resource/Zhang_Yufei_(swimmer)\", \"score\": 0.9727864122994488, \"rank\": 0.027972027972030022, \"text\": \"Zhang Yufei\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Zhang_Yufei_(swimmer)\", \"dbpedia\": \"http://dbpedia.org/resource/Zhang_Yufei_(swimmer)\"}], \"noun_phrases\": [{\"ngram\": \"theUnited States\", \"from\": 350, \"to\": 366}, {\"ngram\": \"gold\", \"from\": 389, \"to\": 393}, {\"ngram\": \"silver\", \"from\": 398, \"to\": 404}, {\"ngram\": \"the event\", \"from\": 421, \"to\": 430}, {\"ngram\": \"bronze\", \"from\": 500, \"to\": 506}]}, {\"sentence\": \"And while Alonso did not take part in any other disciplines in the pool, she decided to continue her stay in the official athletes' village in the French capital before announcing her shock retirement from the sport at the age of just 20.\", \"from\": 509, \"to\": 747, \"entities\": [{\"begin\": 656, \"end\": 662, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.8426675200856448, \"rank\": 0.16708467924888648, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"Alonso\", \"from\": 519, \"to\": 525}, {\"ngram\": \"part\", \"from\": 539, \"to\": 543}, {\"ngram\": \"any other disciplines\", \"from\": 547, \"to\": 568}, {\"ngram\": \"the pool\", \"from\": 572, \"to\": 580}, {\"ngram\": \"her stay\", \"from\": 606, \"to\": 614}, {\"ngram\": \"the official athletes' village\", \"from\": 618, \"to\": 648}, {\"ngram\": \"her shock retirement\", \"from\": 689, \"to\": 709}, {\"ngram\": \"the sport\", \"from\": 715, \"to\": 724}, {\"ngram\": \"the age\", \"from\": 728, \"to\": 735}]}, {\"sentence\": \"Follow Metro.co.uk's live blog for updates from the Paris Olympics 2024 'Swimming: thank you for allowing me to dream, you taught me to fight, to try, perseverance, sacrifice, discipline and many more,' Alonso announced on her Instagram page, which has more than 500k followers.\", \"from\": 749, \"to\": 1028, \"entities\": [{\"begin\": 977, \"end\": 986, \"title\": \"http://dbpedia.org/resource/Instagram\", \"score\": 1.0, \"rank\": 2.927036964409825e-23, \"text\": \"Instagram\", \"types\": [\"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Instagram\", \"dbpedia\": \"http://dbpedia.org/resource/Instagram\"}], \"noun_phrases\": [{\"ngram\": \"Follow Metro.co.uk's live blog\", \"from\": 749, \"to\": 779}, {\"ngram\": \"updates\", \"from\": 784, \"to\": 791}, {\"ngram\": \"the Paris Olympics\", \"from\": 797, \"to\": 815}, {\"ngram\": \"Alonso\", \"from\": 952, \"to\": 958}, {\"ngram\": \"more than 500k followers\", \"from\": 1002, \"to\": 1026}]}, {\"sentence\": \"'I gave you part of my life and I do not change it for anything in the world because I lived the best experiences of my life, you gave me thousands of joys, friends from other countries that I will always carry them in my heart, unique opportunities.\", \"from\": 1030, \"to\": 1280, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"part\", \"from\": 1042, \"to\": 1046}, {\"ngram\": \"my life\", \"from\": 1050, \"to\": 1057}, {\"ngram\": \"anything\", \"from\": 1085, \"to\": 1093}, {\"ngram\": \"the world\", \"from\": 1097, \"to\": 1106}, {\"ngram\": \"the best experiences\", \"from\": 1123, \"to\": 1143}, {\"ngram\": \"my life\", \"from\": 1147, \"to\": 1154}, {\"ngram\": \"thousands\", \"from\": 1168, \"to\": 1177}, {\"ngram\": \"joys\", \"from\": 1181, \"to\": 1185}, {\"ngram\": \"friends\", \"from\": 1187, \"to\": 1194}, {\"ngram\": \"other countries\", \"from\": 1200, \"to\": 1215}, {\"ngram\": \"my heart\", \"from\": 1249, \"to\": 1257}, {\"ngram\": \"unique opportunities\", \"from\": 1259, \"to\": 1279}]}, {\"sentence\": \"'It's not goodbye, it's see you soon.'\", \"from\": 1282, \"to\": 1320, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"However, the Paraguayan team went on to issue a statement of their own, confirming that Alonso had been removed from the athletes' living quarters, just days out from the closing ceremony.\", \"from\": 1322, \"to\": 1510, \"entities\": [{\"begin\": 1335, \"end\": 1345, \"title\": \"http://dbpedia.org/resource/Paraguay\", \"score\": 0.957093249551516, \"rank\": 0.044828127455238086, \"text\": \"Paraguayan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Paraguay\", \"dbpedia\": \"http://dbpedia.org/resource/Paraguay\"}], \"noun_phrases\": [{\"ngram\": \"a statement\", \"from\": 1368, \"to\": 1379}, {\"ngram\": \"Alonso\", \"from\": 1410, \"to\": 1416}, {\"ngram\": \"the athletes' living quarters\", \"from\": 1439, \"to\": 1468}, {\"ngram\": \"the closing ceremony\", \"from\": 1489, \"to\": 1509}]}, {\"sentence\": \"'Her presence is creating an inappropriate atmosphere within Team Paraguay,' a statement from Larissa Schaerer, the head of the COP mission, read.\", \"from\": 1512, \"to\": 1658, \"entities\": [{\"begin\": 1578, \"end\": 1586, \"title\": \"http://dbpedia.org/resource/Paraguay\", \"score\": 0.9533506583195646, \"rank\": 0.0489319568875741, \"text\": \"Paraguay\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Paraguay\", \"dbpedia\": \"http://dbpedia.org/resource/Paraguay\"}, {\"begin\": 1606, \"end\": 1622, \"title\": \"http://dbpedia.org/resource/Larissa_Schaerer\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Larissa Schaerer\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Larissa_Schaerer\", \"dbpedia\": \"http://dbpedia.org/resource/Larissa_Schaerer\"}, {\"begin\": 1640, \"end\": 1643, \"title\": \"http://dbpedia.org/resource/Conference_of_the_parties\", \"score\": 0.9772247483579425, \"rank\": 0.012040165128913028, \"text\": \"COP\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Conference_of_the_parties\", \"dbpedia\": \"http://dbpedia.org/resource/Conference_of_the_parties\"}], \"noun_phrases\": [{\"ngram\": \"Her presence\", \"from\": 1513, \"to\": 1525}, {\"ngram\": \"an inappropriate atmosphere\", \"from\": 1538, \"to\": 1565}, {\"ngram\": \"a statement\", \"from\": 1589, \"to\": 1600}, {\"ngram\": \"the head\", \"from\": 1624, \"to\": 1632}]}, {\"sentence\": \"'We thank her for proceeding as instructed, as it was of her own free will that she did not spend the night in the athletes' village.'\", \"from\": 1660, \"to\": 1794, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"proceeding\", \"from\": 1678, \"to\": 1688}, {\"ngram\": \"her own free will\", \"from\": 1717, \"to\": 1734}, {\"ngram\": \"the night\", \"from\": 1758, \"to\": 1767}, {\"ngram\": \"the athletes' village\", \"from\": 1771, \"to\": 1792}]}, {\"sentence\": \"It appears Alonso has since travelled to the United States, with the youngster sharing a short video on her Instagram page showing her driving towards a border control crossing.. Alonso made her Olympic debut in Tokyo three years ago as a 17 year old and also represented Paraguay at the World Aquatics Championships and the South American Games, both held in 2022.\", \"from\": 1796, \"to\": 2162, \"entities\": [{\"begin\": 1841, \"end\": 1854, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.7462090084396106, \"rank\": 0.33565325540466057, \"text\": \"United States\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 1904, \"end\": 1913, \"title\": \"http://dbpedia.org/resource/Instagram\", \"score\": 1.0, \"rank\": 2.927036964409825e-23, \"text\": \"Instagram\", \"types\": [\"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Instagram\", \"dbpedia\": \"http://dbpedia.org/resource/Instagram\"}, {\"begin\": 2009, \"end\": 2014, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.999911191337941, \"rank\": 8.881632098939961e-05, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}, {\"begin\": 2069, \"end\": 2077, \"title\": \"http://dbpedia.org/resource/Paraguay\", \"score\": 0.9533506583195646, \"rank\": 0.0489319568875741, \"text\": \"Paraguay\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Paraguay\", \"dbpedia\": \"http://dbpedia.org/resource/Paraguay\"}, {\"begin\": 2122, \"end\": 2142, \"title\": \"http://dbpedia.org/resource/South_American_Games\", \"score\": 0.9999999820390714, \"rank\": 1.7948396613774033e-08, \"text\": \"South American Games\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/South_American_Games\", \"dbpedia\": \"http://dbpedia.org/resource/South_American_Games\"}], \"noun_phrases\": [{\"ngram\": \"Alonso\", \"from\": 1807, \"to\": 1813}, {\"ngram\": \"the youngster\", \"from\": 1861, \"to\": 1874}, {\"ngram\": \"a short video\", \"from\": 1883, \"to\": 1896}, {\"ngram\": \"a border control crossing\", \"from\": 1947, \"to\": 1972}, {\"ngram\": \"Alonso\", \"from\": 1975, \"to\": 1981}, {\"ngram\": \"her Olympic debut\", \"from\": 1987, \"to\": 2004}, {\"ngram\": \"the World Aquatics Championships\", \"from\": 2080, \"to\": 2112}]}, {\"sentence\": \"After failing to make it out of the heats in the 100m butterfly, Alonso sent her apologies to her supporters back home in Paraguay.\", \"from\": 216