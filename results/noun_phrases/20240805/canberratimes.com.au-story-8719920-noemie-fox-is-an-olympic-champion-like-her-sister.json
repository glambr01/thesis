.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 2158, \"end\": 2165, \"title\": \"http://dbpedia.org/resource/Jessica_Simpson\", \"score\": 0.9999768058498885, \"rank\": 2.2414171052529643e-05, \"text\": \"Jessica\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jessica_Simpson\", \"dbpedia\": \"http://dbpedia.org/resource/Jessica_Simpson\"}], \"noun_phrases\": [{\"ngram\": \"the addition\", \"from\": 2052, \"to\": 2064}, {\"ngram\": \"the splash and dash event\", \"from\": 2068, \"to\": 2093}, {\"ngram\": \"another spot\", \"from\": 2113, \"to\": 2125}, {\"ngram\": \"Noemie\", \"from\": 2130, \"to\": 2136}, {\"ngram\": \"the selection regatta\", \"from\": 2194, \"to\": 2215}]}, {\"sentence\": \"\\\"I am her biggest cheerleader, just like she's mine,\\\" Noemie said.\", \"from\": 2218, \"to\": 2284, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her biggest cheerleader\", \"from\": 2224, \"to\": 2247}, {\"ngram\": \"mine\", \"from\": 2265, \"to\": 2269}, {\"ngram\": \"Noemie\", \"from\": 2272, \"to\": 2278}]}, {\"sentence\": \"\\\"To watch her win two golds and then to have her as my biggest cheerleader, it's a fairytale ending.\", \"from\": 2286, \"to\": 2386, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"two golds\", \"from\": 2304, \"to\": 2313}, {\"ngram\": \"my biggest cheerleader\", \"from\": 2338, \"to\": 2360}, {\"ngram\": \"a fairytale ending\", \"from\": 2367, \"to\": 2385}]}, {\"sentence\": \"\\\"She's the greatest of all time in our sport ... watching her win, it's just such a privilege and inspiration and it really fuelled me.\", \"from\": 2388, \"to\": 2523, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"all time\", \"from\": 2411, \"to\": 2419}, {\"ngram\": \"our sport\", \"from\": 2423, \"to\": 2432}, {\"ngram\": \"her win\", \"from\": 2446, \"to\": 2453}, {\"ngram\": \"just such a privilege\", \"from\": 2460, \"to\": 2481}, {\"ngram\": \"inspirati