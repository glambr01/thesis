 \"score\": 0.999999977311177, \"rank\": 1.1228267338021422e-08, \"text\": \"Budapest\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Budapest\", \"dbpedia\": \"http://dbpedia.org/resource/Budapest\"}], \"noun_phrases\": [{\"ngram\": \"Lyles\", \"from\": 72937, \"to\": 72942}, {\"ngram\": \"six golds\", \"from\": 72958, \"to\": 72967}, {\"ngram\": \"worlds\", \"from\": 72971, \"to\": 72977}, {\"ngram\": \"three last year\", \"from\": 72989, \"to\": 73004}, {\"ngram\": \"100-meter, 200-meter and 4x100-meter relay\", \"from\": 73018, \"to\": 73060}]}, {\"sentence\": \"Understandably, he's confident in what he can do in Paris.\", \"from\": 73063, \"to\": 73121, \"entities\": [{\"begin\": 73115, \"end\": 73120, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999906755993365, \"rank\": 9.324487621112302e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": []}, {\"sentence\": \"So, prior to heading out on Team USA's boat for the opening ceremony, he put one word on his fingernails: \\\"ICON.\\\"\", \"from\": 73123, \"to\": 73236, \"entities\": [{\"begin\": 73151, \"end\": 73159, \"title\": \"http://dbpedia.org/resource/United_States_national_team\", \"score\": 0.9978699777485998, \"rank\": 0.002131926727114689, \"text\": \"Team USA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_national_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_national_team\"}], \"noun_phrases\": [{\"ngram\": \"the opening ceremony\", \"from\": 73171, \"to\": 73191}, {\"ngram\": \"one word\", \"from\": 73200, \"to\": 73208}, {\"ngram\": \"his fingernails\", \"from\": 73212, \"to\": 73227}, {\"ngram\": \"ICON\", \"from\": 73230, \"to\": 73234}]}, {\"sentence\": \"This is an excerpt from an article by Fox News' Ryan Morik.\", \"from\": 73238, \"to\": 73297, \"entities\": [{\"begin\": 73276, \