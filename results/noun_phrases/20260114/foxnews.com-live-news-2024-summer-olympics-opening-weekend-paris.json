\"sentence\": \"\\\"You have come to Paris as athletes, now you are Olympians.\", \"from\": 71855, \"to\": 71914, \"entities\": [{\"begin\": 71873, \"end\": 71878, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999997137365, \"rank\": 2.862375627646064e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"athletes\", \"from\": 71882, \"to\": 71890}, {\"ngram\": \"Olympians\", \"from\": 71904, \"to\": 71913}]}, {\"sentence\": \"Stepping into the Olympic village like generations of athletes before you: now I am part of something bigger than myself.\", \"from\": 71915, \"to\": 72036, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the Olympic village\", \"from\": 71929, \"to\": 71948}, {\"ngram\": \"generations\", \"from\": 71954, \"to\": 71965}, {\"ngram\": \"athletes\", \"from\": 71969, \"to\": 71977}, {\"ngram\": \"part\", \"from\": 71999, \"to\": 72003}, {\"ngram\": \"something\", \"from\": 72007, \"to\": 72016}]}, {\"sentence\": \"Now we all are part of an event that unites the world,\\\" he said.\", \"from\": 72037, \"to\": 72101, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"part\", \"from\": 72052, \"to\": 72056}, {\"ngram\": \"an event\", \"from\": 72060, \"to\": 72068}, {\"ngram\": \"the world\", \"from\": 72081, \"to\": 72090}]}, {\"sentence\": \"\\\"As olympians we care for each other.\", \"from\": 72103, \"to\": 72140, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"olympians\", \"from\": 72107, \"to\": 72116}]}, {\"sentence\": \"We not only respect each other, we live in solidarity with each other.\\\"\", \"from\": 72141, \"to\": 72212, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"solidarity\", \"from\": 72184, \"to\": 72194}]}, {\"sentence\": \"\\\"In a world torn apart by wars and conflicts, it is thanks to this solidarity that we can all come together tonight.\\\"\", \"from\": 72214, \"to\": 72331, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a world\", \"from\": 72218, \"to\": 72225}, {\"ngram\": \"wars\", \"from\": 72240, \"to\": 72244}, {\"ngram\": \"conflicts\", \"from\": 72249, \"to\": 72258}, {\"ngram\": \"thanks\", \"from\": 72266, \"to\": 72272}, {\"ngram\": \"this solidarity\", \"from\": 72276, \"to\": 72291}]}, {\"sentence\": \"There are 205 National Olympic Committees (NOCs) participating in the Paris Olympics.\", \"from\": 72333, \"to\": 72418, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"205 National Olympic Committees\", \"from\": 72343, \"to\": 72374}, {\"ngram\": \"NOCs\", \"from\": 72376, \"to\": 72380}, {\"ngram\": \"the Paris Olympics\", \"from\": 72399, \"to\": 72417}]}, {\"sentence\": \"The face of U.S. men's track and field is reminding everyone that that is still the case.\", \"from\": 72422, \"to\": 72511, \"entities\": [{\"begin\": 72434, \"end\": 72438, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9980624396920752, \"rank\": 0.0008959141175939854, \"text\": \"U.S.\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"The face\", \"from\": 72422, \"to\": 72430}, {\"ngram\": \"field\", \"from\": 72455, \"to\": 72460}, {\"ngram\": \"everyone\", \"from\": 72474, \"to\": 72482}, {\"ngram\": \"the case\", \"from\": 72502, \"to\": 72510}]}, {\"sentence\": \"Noah Lyles is the overwhelming favorite to win the 200-meter race at the2024 Summer Olympicsin Paris (he's even going for the world record), and he's very likely to medal in the 100-meter, as well.\", \"from\": 72513, \"to\": 72710, \"entities\": [{\"begin\": 72513, \"end\": 72523, \"title\": \"http://dbpedia.org/resource/Noah_Lyles\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Noah Lyles\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Noah_Lyles\", \"dbpedia\"