1}]}, {\"sentence\": \"The crowdat the home of the Indianapolis Coltswas the largest for any swim meet in history, and Dressel's long arms swept them up in a mutual, meaty embrace.\", \"from\": 3057, \"to\": 3214, \"entities\": [{\"begin\": 3085, \"end\": 3097, \"title\": \"http://dbpedia.org/resource/Indianapolis\", \"score\": 0.9990957963521523, \"rank\": 0.0007675979465564997, \"text\": \"Indianapolis\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Indianapolis\", \"dbpedia\": \"http://dbpedia.org/resource/Indianapolis\"}], \"noun_phrases\": [{\"ngram\": \"The crowdat\", \"from\": 3057, \"to\": 3068}, {\"ngram\": \"the home\", \"from\": 3069, \"to\": 3077}, {\"ngram\": \"any swim meet\", \"from\": 3123, \"to\": 3136}, {\"ngram\": \"history\", \"from\": 3140, \"to\": 3147}, {\"ngram\": \"Dressel's long arms\", \"from\": 3153, \"to\": 3172}, {\"ngram\": \"meaty\", \"from\": 3200, \"to\": 3205}]}, {\"sentence\": \"After victory at the US trials, he will defend his 100m butterfly and 50m freestyle titles in Paris, no longer feeling the weight of the world on his broad shoulders but with afreedom that might well bring yet more success.\", \"from\": 3215, \"to\": 3438, \"entities\": [{\"begin\": 3236, \"end\": 3245, \"title\": \"http://dbpedia.org/resource/2020_United_States_Olympic_trials_(track_and_field)\", \"score\": 0.9999999933070285, \"rank\": 0.0, \"text\": \"US trials\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/2020_United_States_Olympic_trials_(track_and_field)\", \"dbpedia\": \"http://dbpedia.org/resource/2020_United_States_Olympic_trials_(track_and_field)\"}, {\"begin\": 3309, \"end\": 3314, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999877077245, \"rank\": 1.2292501012471137e-08, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"victory\", \"from\": 3221,