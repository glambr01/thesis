nts\", \"from\": 6975, \"to\": 6991}]}, {\"sentence\": \"The form contains a commitment to respect the Olympic Charter, including 'the peace mission of the Olympic Movement.'\\\"\", \"from\": 6993, \"to\": 7111, \"entities\": [{\"begin\": 7092, \"end\": 7108, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 0.9999999935062078, \"rank\": 6.4941719730289435e-09, \"text\": \"Olympic Movement\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"The form\", \"from\": 6993, \"to\": 7001}, {\"ngram\": \"a commitment\", \"from\": 7011, \"to\": 7023}, {\"ngram\": \"the Olympic Charter\", \"from\": 7035, \"to\": 7054}, {\"ngram\": \"the peace mission\", \"from\": 7067, \"to\": 7084}]}, {\"sentence\": \"\\u00c2 \\\"The Olympic Movement is united in its sense of fairness not to punish athletes for the decisions of their government if they are not actively participating in them,\\\" the IOC said in February of 2022, around the time Russia launched its invasion.\\u00c2 \\\"We are committed to fair competitions for everybody without any discrimination.\\\"\", \"from\": 7113, \"to\": 7445, \"entities\": [{\"begin\": 7121, \"end\": 7137, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 0.9999999935062078, \"rank\": 6.4941719730289435e-09, \"text\": \"Olympic Movement\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 7287, \"end\": 7290, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.0521982543513966e-49, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Oly