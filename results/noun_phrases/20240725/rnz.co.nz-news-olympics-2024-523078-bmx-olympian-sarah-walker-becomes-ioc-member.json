es\": [{\"ngram\": \"the IOC Session\", \"from\": 143, \"to\": 158}]}, {\"sentence\": \"The role will see Walker become part of the governing body responsible for overseeing the Olympic Movement, with IOC members key figures in ensuring the promotion and protection of the Olympic Games and values.\", \"from\": 171, \"to\": 381, \"entities\": [{\"begin\": 261, \"end\": 277, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 0.9998742088537188, \"rank\": 0.00012580697161119402, \"text\": \"Olympic Movement\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 284, \"end\": 287, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.7810887629956972e-24, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"The role\", \"from\": 171, \"to\": 179}, {\"ngram\": \"Walker\", \"from\": 189, \"to\": 195}, {\"ngram\": \"part\", \"from\": 203, \"to\": 207}, {\"ngram\": \"the governing body\", \"from\": 211, \"to\": 229}, {\"ngram\": \"the promotion\", \"from\": 320, \"to\": 333}, {\"ngram\": \"protection\", \"from\": 338, \"to\": 348}, {\"ngram\": \"the Olympic Games\", \"from\": 352, \"to\": 369}, {\"ngram\": \"values\", \"from\": 374, \"to\": 380}]}, {\"sentence\": \"Walker had served on the IOC Athlete's Commission since 2016, with her hard work and dedication earning her this prestigious membership.\", \"from\": 383, \"to\": 519, \"entities\": [{\"begin\": 408, \"end\": 411, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.7810887629956972e-24, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24