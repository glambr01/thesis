"{\"uid\": \"nbcbayarea.com-paris-2024-summer-olympics-paris-olympics-security-3603478\", \"noun_phrases\": [{\"sentence\": \"Security in Paris and across France has ramped up as the Olympics get underway.\", \"from\": 0, \"to\": 79, \"entities\": [{\"begin\": 12, \"end\": 17, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999991401290631, \"rank\": 8.598717032173103e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 29, \"end\": 35, \"title\": \"http://dbpedia.org/resource/Kingdom_of_France\", \"score\": 0.7890857535266532, \"rank\": 0.26434282701791545, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Kingdom_of_France\", \"dbpedia\": \"http://dbpedia.org/resource/Kingdom_of_France\"}], \"noun_phrases\": [{\"ngram\": \"Security\", \"from\": 0, \"to\": 8}, {\"ngram\": \"the Olympics\", \"from\": 53, \"to\": 65}]}, {\"sentence\": \"At the Joint Operations Center inside the U.S. Embassy in Paris, special agents and data analysts with the state department's Diplomatic Security Service (DSS) scan the web, take in information from agents embedded at all 40 Olympic venues and listen to chatter to ward off trouble.\", \"from\": 81, \"to\": 363, \"entities\": [{\"begin\": 128, \"end\": 135, \"title\": \"http://dbpedia.org/resource/Diplomatic_mission\", \"score\": 1.0, \"rank\": 4.1140728602153997e-26, \"text\": \"Embassy\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Diplomatic_mission\", \"dbpedia\": \"http://dbpedia.org/resource/Diplomatic_mission\"}, {\"begin\": 139, \"end\": 144, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999991401290631, \"rank\": 8.598717032173103e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 207, \"end\": 240, \"title\": \"http://