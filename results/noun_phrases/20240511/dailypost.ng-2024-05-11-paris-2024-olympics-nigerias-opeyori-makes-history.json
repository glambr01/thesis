"{\"uid\": \"dailypost.ng-2024-05-11-paris-2024-olympics-nigerias-opeyori-makes-history\", \"noun_phrases\": [{\"sentence\": \"Published on By Multiple African Men's singles Badminton Champion, Anuoluwapo Opeyori has qualified for the Paris 2024 Olympic Games, according to the Badminton World Federation (BWF).\", \"from\": 0, \"to\": 187, \"entities\": [{\"begin\": 154, \"end\": 180, \"title\": \"http://dbpedia.org/resource/Badminton_World_Federation\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Badminton World Federation\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Badminton_World_Federation\", \"dbpedia\": \"http://dbpedia.org/resource/Badminton_World_Federation\"}], \"noun_phrases\": [{\"ngram\": \"Multiple African Men's singles\", \"from\": 16, \"to\": 46}, {\"ngram\": \"Badminton Champion\", \"from\": 47, \"to\": 65}, {\"ngram\": \"Anuoluwapo Opeyori\", \"from\": 67, \"to\": 85}, {\"ngram\": \"the Paris 2024 Olympic Games\", \"from\": 104, \"to\": 132}]}, {\"sentence\": \"Opeyori, who is a two-time African Games Champion made history by becoming the first Nigerian badminton player to make it to the Olympics back to back (2020 and 2024).\", \"from\": 189, \"to\": 356, \"entities\": [{\"begin\": 274, \"end\": 282, \"title\": \"http://dbpedia.org/resource/Nigerians\", \"score\": 0.9999997893717358, \"rank\": 2.1062832275988139e-07, \"text\": \"Nigerian\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Nigerians\", \"dbpedia\": \"http://dbpedia.org/resource/Nigerians\"}], \"noun_phrases\": [{\"ngram\": \"Opeyori\", \"from\": 189, \"to\": 196}, {\"ngram\": \"a two-time African Games Champion\", \"from\": 205, \"to\": 238}, {\"ngram\": \"history\", \"from\": 244, \"to\": 251}, {\"ngram\": \"the Olympics\", \"from\": 314, \"to\": 326}, {\"ngram\": \"back\", \"from\": 335, \"to\": 339}]}, {\"sentence\": \"Opeyori dominated Africa in the men's singles from 2019 till date winning four African Championship titles and two African Games titles.\", \"from\": 358, \"to\": 494, \"entities\": [{\"begin\": 437, \"end\": 457, \"title\": \"http://dbpedia.org/resource/AfroBasket\", \"score\": 0.7777769387420717, \"rank\": 0.28103025944723725, \"text\": \"African Championship\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/AfroBasket\", \"dbpedia\": \"http://dbpedia.org/resource/AfroBasket\"}, {\"begin\": 473, \"end\": 486, \"title\": \"http://dbpedia.org/resource/African_Games\", \"score\": 0.9999867475728959, \"rank\": 1.3188914343797724e-05, \"text\": \"African Games\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/African_Games\", \"dbpedia\": \"http://dbpedia.org/resource/African_Games\"}], \"noun_phrases\": [{\"ngram\": \"Opeyori\", \"from\": 358, \"to\": 365}, {\"ngram\": \"Africa\", \"from\": 376, \"to\": 382}, {\"ngram\": \"the men's singles\", \"from\": 386, \"to\": 403}, {\"ngram\": \"date\", \"from\": 419, \"to\": 423}]}, {\"sentence\": \"An elated Francis Orbih, President of the Badminton Federation of Nigeria, BFN, told newsmen on Saturday that Anuoluwapo Opeyori has broken the jinx in Nigeria badminton by making it to the Olympic Games in Paris.\", \"from\": 496, \"to\": 709, \"entities\": [{\"begin\": 506, \"end\": 513, \"title\": \"http://dbpedia.org/resource/Pope_Francis\", \"score\": 0.9987072848919042, \"rank\": 0.0012503007886979839, \"text\": \"Francis\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19546\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Pope_Francis\", \"dbpedia\": \"http://dbpedia.org/resource/Pope_Francis\"}, {\"begin\": 571, \"end\": 574, \"title\": \"http://dbpedia.org/resource/British_Forces_Broadcasting_Service\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"BFN\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\", \"Q141683\"], \"wikid\": \"http://dbpedia.org/resource/British_Forces_Broadcasting_Service\", \"dbpedia\": \"http://dbpedia.org/resource/British_Forces_Broadcasting_Service\"}, {\"begin\": 648, \"end\