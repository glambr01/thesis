_phrases\": [{\"ngram\": \"The savory museum\", \"from\": 961, \"to\": 978}, {\"ngram\": \"cheese\", \"from\": 986, \"to\": 992}, {\"ngram\": \"a 17th-century stone building\", \"from\": 1021, \"to\": 1050}, {\"ngram\": \"\\u00cele Saint-Louis\", \"from\": 1054, \"to\": 1069}, {\"ngram\": \"a short walk\", \"from\": 1071, \"to\": 1083}, {\"ngram\": \"Notre Dame Cathedral\", \"from\": 1089, \"to\": 1109}]}, {\"sentence\": \"Entry costs about $21.75 for adults, and children 11 and younger get in for $11.96.\", \"from\": 1112, \"to\": 1195, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Entry\", \"from\": 1112, \"to\": 1117}, {\"ngram\": \"adults\", \"from\": 1141, \"to\": 1147}, {\"ngram\": \"children\", \"from\": 1153, \"to\": 1161}]}, {\"sentence\": \"Admission is free for farmers and agriculture students.\", \"from\": 1196, \"to\": 1251, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Admission\", \"from\": 1196, \"to\": 1205}, {\"ngram\": \"farmers\", \"from\": 1218, \"to\": 1225}, {\"ngram\": \"agriculture students\", \"from\": 1230, \"to\": 1250}]}, {\"sentence\": \"With the admission price, guests can view a cheese-making demonstration, participate in a tasting and learn the history of cheese through the museum's interactive displays.\", \"from\": 1253, \"to\": 1425, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the admission price\", \"from\": 1258, \"to\": 1277}, {\"ngram\": \"guests\", \"from\": 1279, \"to\": 1285}, {\"ngram\": \"a cheese-making demonstration\", \"from\": 1295, \"to\": 1324}, {\"ngram\": \"a tasting\", \"from\": 1341, \"to\": 1350}, {\"ngram\": \"the history\", \"from\": 1361, \"to\": 1372}, {\"ngram\": \"cheese\", \"from\": 1376, \"to\": 1382}, {\"ngram\": \"the museum's interactive displays\", \"from\": 1391, \"to\": 1424}]}, {\"sentence\": \"Cheese guides are also available to provide information on things like the history of cheese and its production.\", \"from\": 1427, \"to\": 1539, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Cheese guides\", \"from\": 1427, \"to\": 1440}, {\"ngram\": \"information\", \"from\": 1471, \"to\": 1482}, {\"ngram\": \"things\", \"from\": 1486, \"to\": 1492}, {\"ngram\": \"the history\", \"from\": 1498, \"to\": 1509}, {\"ngram\": \"cheese\", \"from\": 1513, \"to\": 1519}, {\"ngram\": \"its production\", \"from\": 1524, \"to\": 1538}]}, {\"sentence\": \"Courses and workshops are also offered.\", \"from\": 1540, \"to\": 1579, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Courses\", \"from\": 1540, \"to\": 1547}, {\"ngram\": \"workshops\", \"from\": 1552, \"to\": 1561}]}, {\"sentence\": \"One of the museum's cheese experts, Agathe de Saint-Exup\\u00e9ry, explained the nuisances in the production of cheese, which is a close to $10 billion dollar industry in the country.\", \"from\": 1581, \"to\": 1758, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the museum's cheese experts\", \"from\": 1588, \"to\": 1615}, {\"ngram\": \"Agathe de Saint-Exup\\u00e9ry\", \"from\": 1617, \"to\": 1640}, {\"ngram\": \"the nuisances\", \"from\": 1652, \"to\": 1665}, {\"ngram\": \"the production\", \"from\": 1669, \"to\": 1683}, {\"ngram\": \"cheese\", \"from\": 1687, \"to\": 1693}, {\"ngram\": \"a close to $10 billion dollar industry\", \"from\": 1704, \"to\": 1742}, {\"ngram\": \"the country\", \"from\": 1746, \"to\": 1757}]}, {\"sentence\": \"\\\"It's a very individual process that depends on so many things, even the humor of the animals whose milk is being used.\", \"from\": 1760, \"to\": 1879, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a very individual process\", \"from\": 1766, \"to\": 1791}, {\"ngram\": \"so many things\", \"from\": 1808, \"to\": 1822}, {\"ngram\": \"even the humor\", \"from\": 1824, \"to\": 1838}, {\"ngram\": \"the animals\", \"from\": 1842, \"to\": 1853}, {\"ngram\": \"whose milk\", \"from\": 1854, \"to\": 1864}]}, {\"sentence\": \"You can make the same good cheese every day, and every day it will taste different.\", \"from\": 1880, \"to\": 1963, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the same good cheese\", \"from\": 1893, \"to\": 1913}]}, {\"sentence\": \"It just cannot be done industrially,\\\" she told the outlet.\", \"from\": 1964, \"to\": 2022, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the outlet\", \"from\": 2011, \"to\": 2021}]}, {\"sentence\": \"Brisson, 38, whose parents are winemakers, planned the museum for a decade, and said his passion for cheese started when he was young.\", \"from\": 2024, \"to\": 2158, \"entities\": [{\"begin\": 2024, \"end\": 2031, \"title\": \"http://dbpedia.org/resource/Mathurin_Jacques_Brisson\", \"score\": 0.9990059657715817, \"rank\": 0.0009950229130370274, \"text\": \"Brisson\", \"types\": [\"Q901\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Mathurin_Jacques_Brisson\", \"dbpedia\": \"http://dbpedia.org/resource/Mathurin_Jacques_Brisson\"}], \"noun_phrases\": [{\"ngram\": \"whose parents\", \"from\": 2037, \"to\": 2050}, {\"ngram\": \"winemakers\", \"from\": 2055, \"to\": 2065}, {\"ngram\": \"the museum\", \"from\": 2075, \"to\": 2085}, {\"ngram\": \"a decade\", \"from\": 2090, \"to\": 2098}, {\"ngram\": \"his passion\", \"from\": 2109, \"to\": 2120}, {\"ngram\": \"cheese\", \"from\": 2125, \"to\": 2131}]}, {\"sentence\": \"\\\"My father would take me to the cheesemonger every Sunday after mass; I was at the height of the display and would look at all the marvelous cheeses in front of my eyes,\\\" he told the outlet.\", \"from\": 2160, \"to\": 2350, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My father\", \"from\": 2161, \"to\": 2170}, {\"ngram\": \"the cheesemonger\", \"from\": 2188, \"to\": 2204}, {\"ngram\": \"mass\", \"from\": 2224, \"to\": 2228}, {\"ngram\": \"the height\", \"from\": 2239, \"to\": 2249}, {\"ngram\": \"the display\", \"from\": 2253, \"to\": 2264}, {\"ngram\": \"all the marvelous cheeses\", \"from\": 2283, \"to\": 2308}, {\"ngram\": \"front\", \"from\": 2312, \"to\"