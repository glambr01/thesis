es\": [], \"noun_phrases\": [{\"ngram\": \"a great field\", \"from\": 2237, \"to\": 2250}, {\"ngram\": \"bottom\", \"from\": 2259, \"to\": 2265}, {\"ngram\": \"lots\", \"from\": 2276, \"to\": 2280}, {\"ngram\": \"people\", \"from\": 2284, \"to\": 2290}, {\"ngram\": \"a chance\", \"from\": 2301, \"to\": 2309}]}, {\"sentence\": \"Ledecky certainly lacks the air of invincibility she once had and admits to recalibrating her ambitions for the days ahead, while steadfastly refusing to share what they are.\", \"from\": 2313, \"to\": 2487, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Ledecky\", \"from\": 2313, \"to\": 2320}, {\"ngram\": \"the air\", \"from\": 2337, \"to\": 2344}, {\"ngram\": \"invincibility\", \"from\": 2348, \"to\": 2361}, {\"ngram\": \"her ambitions\", \"from\": 2403, \"to\": 2416}, {\"ngram\": \"the days\", \"from\": 2421, \"to\": 2429}]}, {\"sentence\": \"\\\"When you get older, whatever you do, you set new goals for yourself,\\\" she added.\", \"from\": 2489, \"to\": 2570, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"whatever\", \"from\": 2510, \"to\": 2518}, {\"ngram\": \"new goals\", \"from\": 2535, \"to\": 2544}]}, {\"sentence\": \"\\\"I never thought I'd make oneOlympics, so just to be here at a fourth is something to be celebrated.\", \"from\": 2571, \"to\": 2671, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"oneOlympics\", \"from\": 2597, \"to\": 2608}, {\"ngram\": \"something\", \"from\": 2644, \"to\": 2653}]}, {\"sentence\": \"\\\"When I think about my career the thing that makes me most proud is probably how consistent that I have been.\", \"from\": 2673, \"to\": 2782, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my career\", \"from\": 2693, \"to\": 2702}, {\"ngram\": \"the thing\", \"from\": 2703, \"to\": 2712}]}, {\"sentence\": \"It helps that I enjoy training and I am at a stage when I am just grateful and appreciative for what I have.\", \"from\": 2783, \"to\": 2891, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"training\", \"from\": 2805, \"to\": 2813}, {\"ngram\": \"a stage\", \"from\": 2826, \"to\": 2833}]}, {\"sentence\": \"I have been doing this a long-time and I have stayed pretty healthy and injury-free.\\\"\", \"from\": 2892, \"to\": 2977, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Three years on from Tokyo, Ledecky's battles look more fierce, while her sport is facing a more existential crisis.\", \"from\": 2979, \"to\": 3094, \"entities\": [{\"begin\": 2999, \"end\": 3004, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.9964929705712096, \"rank\": 0.0035193408079647634, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"Ledecky's battles\", \"from\": 3006, \"to\": 3023}, {\"ngram\": \"her sport\", \"from\": 3048, \"to\": 3057}, {\"ngram\": \"a more existential crisis\", \"from\": 3068, \"to\": 3093}]}, {\"sentence\": \"Chinese swimmers will be drug-tested twice as much as other nations, after reports that 23 swimmers tested positive for a banned heart medication trimetazidine in Tokyo but were still controversially cleared to compete.\", \"from\": 3096, \"to\": 3315, \"entities\": [{\"begin\": 3096, \"end\": 3103, \"title\": \"http://dbpedia.org/resource/Chinese_language\", \"score\": 0.5586635985221521, \"rank\": 0.787740624242955, \"text\": \"Chinese\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Chinese_language\", \"dbpedia\": \"http://dbpedia.org/resource/Chinese_language\"}, {\"begin\": 3259, \"end\": 3264, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.9964929705712096, \"rank\": 0.0035193408079647634, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"other nations\", \"from\": 3150, \"to\": 3163}, {\"ngram\": \"reports\", \"from\": 3171, \"to\": 3178}, {\"ngram\": \"23 swimmers\", \"from\": 3184, \"to\": 3195}, {\"ngram\": \"a banned heart medication trimetazidine\", \"from\": 3216, \"to\": 3255}]}, {\"sentence\": \"Phelps - the greatest swimmer of all time - has been a vocal critic of the failure of authorities to enforce their own polices and the row simmers beneath the azure blue pool at La Defense Arena.\", \"from\": 3317, \"to\": 3512, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Phelps\", \"from\": 3317, \"to\": 3323}, {\"ngram\": \"the greatest swimmer\", \"from\": 3326, \"to\": 3346}, {\"ngram\": \"all time\", \"from\": 3350, \"to\": 3358}, {\"ngram\": \"a vocal critic\", \"from\": 3370, \"to\": 3384}, {\"ngram\": \"the failure\", \"from\": 3388, \"to\": 3399}, {\"ngram\": \"authorities\", \"from\": 3403, \"to\": 3414}, {\"ngram\": \"their own polices\", \"from\": 3426, \"to\": 3443}, {\"ngram\": \"the row simmers\", \"from\": 3448, \"to\": 3463}, {\"ngram\": \"the azure blue pool\", \"from\": 3472, \"to\": 3491}, {\"ngram\": \"La Defense Arena\", \"from\": 3495, \"to\": 3511}]}, {\"sentence\": \"What's clear is there is a leadership vacuum in the roles designed to keep sport clean, if Ledecky - a famous 'planner' - was thinking long-term, she may consider putting her name forward.\", \"from\": 3514, \"to\": 3702, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a leadership vacuum\", \"from\": 3539, \"to\": 3558}, {\"ngram\": \"the roles\", \"from\": 3562, \"to\": 3571}, {\"ngram\": \"sport\", \"from\": 3589, \"to\": 3594}, {\"ngram\": \"Ledecky\", \"from\": 3605, \"to\": 3612}, {\"ngram\": \"a famous 'planner\", \"from\": 3615, \"to\": 3632}, {\"ngram\": \"her name\", \"from\": 3685, \"to\": 3693}]}, {\"sentence\": \"\\\"I hope everyone here is going to be competing clean this week.\", \"from\": 3704, \"to\": 3767, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"everyone\", \"from\": 3712, \"to\": 3720}]}, {\"sentence\": \"But what really matters is, are they training clean?\", \"from\": 3768, \"to\": 3820, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Everyone's heard what the athletes think, they want transparency,\\\" added Ledecky.\", \"from\": 3821, \"to\": 3902, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Everyone\", \"from\": 3821, \"to\": 3829}, {\"ngram\": \"the athletes\", \"from\": 3843, \"to\": 3855}, {\"ngram\": \"transparency\", \"from\": 3873, \"to\": 3885}, {\"ngram\": \"Ledecky\", \"from\": 3894, \"to\": 3901}]}, {\"sentence\": \"\\\"Athletes want answers to the questions that still remain but, right now, we are here to race whoever is next to us.\", \"from\": 3904, \"to\": 4020, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Athletes\", \"from\": 3905, \"to\": 3913}, {\"ngram\": \"answers\", \"from\": 3919, \"to\": 3926}, {\"ngram\": \"the questions\", \"from\": 3930, \"to\": 3943}, {\"ngram\": \"whoever\", \"from\": 3998, \"to\": 4005}, {\"ngram\": \"us\", \"from\": 4017, \"to\": 4019}]}, {\"sentence\": \"We are not the ones paid to do testing; we have just got to hope those people are following the rules.\", \"from\": 4021, \"to\": 4123, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the ones\", \"from\": 4032, \"to\": 4040}, {\"ngram\": \"testing\", \"from\": 4052, \"to\": 4059}, {\"ngram\": \"those people\", \"from\": 4086, \"to\": 4098}, {\"ngram\": \"the rules\", \"from\": 4113, \"to\": 4122}]}, {\"sentence\": \"We all want to see some change for the future so that you do not have to ask us the questions.\\\"\", \"from\": 4124, \"to\": 4219, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"some change\", \"from\": 4143, \"to\": 4154}, {\"ngram\": \"the future\", \"from\": 4159, \"to\": 4169}, {\"ngram\": \"us\", \"from\": 4201, \"to\": 4203}, {\"ngram\": \"the questions\", \"from\": 4204, \"to\": 4217}]},