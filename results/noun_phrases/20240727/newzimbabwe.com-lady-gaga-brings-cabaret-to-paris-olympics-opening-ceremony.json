oun_phrases\": [{\"ngram\": \"its highest level\", \"from\": 49252, \"to\": 49269}, {\"ngram\": \"security\", \"from\": 49273, \"to\": 49281}, {\"ngram\": \"officials\", \"from\": 49290, \"to\": 49299}, {\"ngram\": \"no specific threat\", \"from\": 49330, \"to\": 49348}, {\"ngram\": \"the opening ceremony\", \"from\": 49352, \"to\": 49372}, {\"ngram\": \"the Games\", \"from\": 49376, \"to\": 49385}, {\"ngram\": \"Israeli competitors\", \"from\": 49386, \"to\": 49405}, {\"ngram\": \"elite tactical units\", \"from\": 49428, \"to\": 49448}, {\"ngram\": \"events\", \"from\": 49461, \"to\": 49467}, {\"ngram\": \"24-hour protection\", \"from\": 49478, \"to\": 49496}, {\"ngram\": \"the Olympics\", \"from\": 49508, \"to\": 49520}, {\"ngram\": \"the war\", \"from\": 49528, \"to\": 49535}, {\"ngram\": \"officials\", \"from\": 49545, \"to\": 49554}, {\"ngram\": \"Scores\", \"from\": 49559, \"to\": 49565}, {\"ngram\": \"world leaders\", \"from\": 49569, \"to\": 49582}, {\"ngram\": \"the opening ceremony\", \"from\": 49600, \"to\": 49620}, {\"ngram\": \"snipers\", \"from\": 49654, \"to\": 49661}, {\"ngram\": \"rooftops\", \"from\": 49665, \"to\": 49673}]}, {\"sentence\": \"The Seine's riverbed has been swept for bombs, and Paris' airspace is closed.For the Games more generally, radar-surveillance planes and Reaper drones will monitor sensitive sites from above, and Mirage 2000 fighter jets will be on standby to intercept aircraft straying into restricted airspace.French President Emmanuel Macron, who won a second mandate two years ago, had hoped the Olympics would cement his legacy.\", \"from\": 49675, \"to\": 50092, \"entities\": [{\"begin\": 49679, \"end\": 49684, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999967062724082, \"rank\": 3.179667762482693e-06, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}, {\"begin\": 49726, \"end\": 49731, \"title\"