ony\", \"from\": 11144, \"to\": 11156}, {\"ngram\": \"bars\", \"from\": 11160, \"to\": 11164}, {\"ngram\": \"the world\", \"from\": 11217, \"to\": 11226}, {\"ngram\": \"a row\", \"from\": 11282, \"to\": 11287}]}, {\"sentence\": \"Supporters said she represented the vibrancy of modern-day France while her detractors said her music owes more to foreign influence than French and that her colloquial use of the French language was unfitting.Dancers and flame bearers took to the roofs of Paris as rain fell.\", \"from\": 11310, \"to\": 11586, \"entities\": [{\"begin\": 11369, \"end\": 11375, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9995073740262935, \"rank\": 0.0004915505902505328, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 11448, \"end\": 11454, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9875993720081407, \"rank\": 0.011774041677950063, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 11490, \"end\": 11505, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9999988275033099, \"rank\": 1.172313450346177e-06, \"text\": \"French language\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 11567, \"end\": 11572, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999999704241689, \"rank\": 2.9575839207639987e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Supporters\", \"from\": 11310, \"to\": 11320}, {\"ngram\": \"the vibrancy\", \"from\": 11342, \"to\": 11354}, {\"ngram\": \"her detractors\", \"fro