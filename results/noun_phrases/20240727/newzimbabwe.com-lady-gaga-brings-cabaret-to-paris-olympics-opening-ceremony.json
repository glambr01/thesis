", \"from\": 19398, \"to\": 19405}, {\"ngram\": \"her biggest hits\", \"from\": 19458, \"to\": 19474}, {\"ngram\": \"Nakamura's performance\", \"from\": 19565, \"to\": 19587}, {\"ngram\": \"the biggest cheers\", \"from\": 19601, \"to\": 19619}, {\"ngram\": \"the river\", \"from\": 19641, \"to\": 19650}, {\"ngram\": \"the ceremony\", \"from\": 19664, \"to\": 19676}, {\"ngram\": \"bars\", \"from\": 19680, \"to\": 19684}, {\"ngram\": \"the world\", \"from\": 19737, \"to\": 19746}, {\"ngram\": \"a row\", \"from\": 19802, \"to\": 19807}]}, {\"sentence\": \"Supporters said she represented the vibrancy of modern-day France while her detractors said her music owes more to foreign influence than French and that her colloquial use of the French language was unfitting.Dancers and flame bearers took to the roofs of Paris as rain fell.\", \"from\": 19830, \"to\": 20106, \"entities\": [{\"begin\": 19889, \"end\": 19895, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9995073740262935, \"rank\": 0.0004915505902505328, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 19968, \"end\": 19974, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9875993720081407, \"rank\": 0.011774041677950063, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 20010, \"end\": 20025, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9999988275033099, \"rank\": 1.172313450346177e-06, \"text\": \"French language\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 20087, \"end\": 20092, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999999704241689, \"rank\": 2.9575839207639987e-07, \"t