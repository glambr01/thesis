23}, {\"ngram\": \"the Games' history\", \"from\": 45627, \"to\": 45645}, {\"ngram\": \"the gold, silver and bronze medals\", \"from\": 45692, \"to\": 45726}, {\"ngram\": \"45,000 police\", \"from\": 45750, \"to\": 45763}, {\"ngram\": \"thousands\", \"from\": 45768, \"to\": 45777}, {\"ngram\": \"soldiers\", \"from\": 45781, \"to\": 45789}, {\"ngram\": \"a huge security operation\", \"from\": 45812, \"to\": 45837}, {\"ngram\": \"the opening show\", \"from\": 45851, \"to\": 45867}]}, {\"sentence\": \"Armed police patrolled along the river in inflatable boats as the armada made its passage along the Seine.It was the first time that an opening ceremony has taken place outside a stadium.Since the last Games - the Winter Olympics held in Beijing in 2022 - wars have erupted in Ukraine and Gaza, providing a tense international backdrop.\", \"from\": 45869, \"to\": 46205, \"entities\": [{\"begin\": 46107, \"end\": 46114, \"title\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"score\": 0.9988974476271942, \"rank\": 0.0011037661793753578, \"text\": \"Beijing\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2008_Summer_Olympics\"}, {\"begin\": 46146, \"end\": 46153, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 0.9155900213402516, \"rank\": 0.08887048522240555, \"text\": \"Ukraine\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Ukraine\"}, {\"begin\": 46158, \"end\": 46162, \"title\": \"http://dbpedia.org/resource/Gaza_City\", \"score\": 0.9726123306796914, \"rank\": 0.028157451500940588, \"text\": \"Gaza\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Gaza_City\", \"dbpedia\": \"http://dbpedia.org/resource/Gaza_City\"}], \"noun_phrases\": [{\"ngram\": \"Armed police\", \"from\": 45869, \"to\": 45881}, {\"ngram\": \"the river\", \"from\": 45898, \"to\": 45907}, {\"ngra