om\": 27850, \"to\": 28491, \"entities\": [{\"begin\": 28048, \"end\": 28056, \"title\": \"http://dbpedia.org/resource/Canadians\", \"score\": 0.9990503057705944, \"rank\": 0.0009120665610780087, \"text\": \"Canadian\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Canadians\", \"dbpedia\": \"http://dbpedia.org/resource/Canadians\"}, {\"begin\": 28064, \"end\": 28075, \"title\": \"http://dbpedia.org/resource/Celine_Dion\", \"score\": 1.0, \"rank\": 2.0604906353230894e-24, \"text\": \"Celine Dion\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Celine_Dion\", \"dbpedia\": \"http://dbpedia.org/resource/Celine_Dion\"}, {\"begin\": 28126, \"end\": 28134, \"title\": \"http://dbpedia.org/resource/Beauvais_Cathedral\", \"score\": 0.8801724778011281, \"rank\": 0.13595488677305412, \"text\": \"Beauvais\", \"types\": [\"Q41176\", \"Q1370598\"], \"wikid\": \"http://dbpedia.org/resource/Beauvais_Cathedral\", \"dbpedia\": \"http://dbpedia.org/resource/Beauvais_Cathedral\"}], \"noun_phrases\": [{\"ngram\": \"The rain\", \"from\": 27851, \"to\": 27859}, {\"ngram\": \"the Olympics - sport\", \"from\": 27894, \"to\": 27914}, {\"ngram\": \"everything\", \"from\": 27918, \"to\": 27928}, {\"ngram\": \"whatever\", \"from\": 27946, \"to\": 27954}, {\"ngram\": \"Flavia Merluzzi\", \"from\": 27985, \"to\": 28000}, {\"ngram\": \"an architecture student\", \"from\": 28006, \"to\": 28029}, {\"ngram\": \"rumours\", \"from\": 28035, \"to\": 28042}, {\"ngram\": \"part\", \"from\": 28090, \"to\": 28094}, {\"ngram\": \"the show\", \"from\": 28098, \"to\": 28106}, {\"ngram\": \"The ceremony\", \"from\": 28175, \"to\": 28187}, {\"ngram\": \"other recorded footage\", \"from\": 28197, \"to\": 28219}, {\"ngram\": \"rhythmic sounds\", \"from\": 28231, \"to\": 28246}, {\"ngram\": \"stone chisels\", \"from\": 28250, \"to\": 28263}, {\"ngram\": \"wood saws\", \"from\": 28268, \"to\": 28277}, {\"ngram\": \"images\", \"from\": 28281, \"to\": 28287}, {\"ngram\": \"the restoration\", \"from\": 28291, \"to\": 28306}, {\"ngram\": \"Notre-Dame\", \"from\": 28310, \"to\": 28320}, {\"ngram\": \"the fire\", \"from\": 28327, \"to\": 28335}, {\"ngram\": \"2019Many details\", \"from\": 28339, \"to\": 28355}, {\"ngram\": \"the torch\", \"from\": 28419, \"to\": 28428}, {\"ngram\": \"the Olympic cauldron\", \"from\": 28439, \"to\": 28459}, {\"ngram\": \"the start\", \"from\": 28468, \"to\": 28477}, {\"ngram\": \"the Games\", \"from\": 28481, \"to\": 28490}]}, {\"sentence\": \"The torchbearer - their face hidden and identity concealed - was shown jumping on the roofs of Paris.The two most decorated athletes in the Games' history, Michael Phelps and Martin Fourcade, unveiled the gold, silver and bronze medals.SECURITY OPERATIONSome 45,000 police and thousands of soldiers have been deployed in a huge security operation in Paris for the opening show.\", \"from\": 28492, \"to\": 28869, \"entities\": [{\"begin\": 28648, \"end\": 28662, \"title\": \"http://dbpedia.org/resource/Michael_Phelps\", \"score\": 1.0, \"rank\": 8.654875002194761e-17, \"text\": \"Michael Phelps\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Michael_Phelps\", \"dbpedia\": \"http://dbpedia.org/resource/Michael_Phelps\"}, {\"begin\": 28667, \"end\": 28682, \"title\": \"http://dbpedia.org/resource/Martin_Fourcade\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Martin Fourcade\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Martin_Fourcade\", \"dbpedia\": \"http://dbpedia.org/resource/Martin_Fourcade\"}, {\"begin\": 28842, \"end\": 28847, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999996481392, \"rank\": 3.5185590489228203e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"The torchbearer\", \"from\": 28492, \"to\": 28507}, {\"ngram\": \"their face\", \"from\": 28510, \"to\": 28520}, {\"ngram\": \"the roofs\", \"from\": 28574, \"to\": 28583}, {\"ngram\": \"Paris\", \"from\": 28587, \"to\": 28592}, {\"ngram\": \"The two most decorated athletes\", \"from\": 28593, \"to\": 28624}, {\"ngram\": \"the Games' history\", \"from\": 28628, \"to\": 28646}, {\"ngram\": \"the gold, silver and bronze medals\", \"from\": 28693, \"to\": 28727}, {\"ngram\": \"45,000 police\", \"from\": 28751, \"to\": 28764}, {\"ngram\": \"thousands\", \"from\": 28769, \"to\": 28778}, {\"ngram\": \"soldiers\", \"from\": 28782, \"to\": 28790}, {\"ngram\": \"a huge security operation\", \"from\": 28813, \"to\": 28838}, {\"ngram\": \"the opening show\", \"from\": 28852, \"to\": 28868}]}, {\"sentence\": \"Armed police patrolled along the river in inflatable boats as the armada made its passage along the Seine.It was the first time that an opening ceremony has taken place outside a stadium.Since the last Games - the Winter Olympics held in Beijing in 2022 - wars have erupted in Ukraine and Gaza, providing a tense international backdrop.\", \"from\": 28870, \"to\": 29206, \"entities\": [{\"begin\": 29147, \"end\": 29154, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 0.996504051886789, \"rank\": 0.0031245421409433396, \"text\": \"Ukraine\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Ukraine\"}, {\"begin\": 29159, \"end\": 29163, \"title\": \"http://dbpedia.org/resource/Gaza_City\", \"score\": 0.961573600280017, \"rank\": 0.03996199429383569, \"text\": \"Gaza\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Gaza_City\", \"dbpedia\": \"http://dbpedia.org/resource/Gaza_City\"}], \"noun_phrases\": [{\"ngram\": \"Armed police\", \"from\": 28870, \"to\": 28882}, {\"ngram\": \"the river\", \"from\": 28899, \"to\": 28908}, {\"ngram\": \"inflatable boats\", \"from\": 28912, \"to\": 28928}, {\"ngram\": \"the armada\", \"from\": 28932, \"to\": 28942}, {\"ngram\": \"its passage\", \"from\": 28948, \"to\": 28959}, {\"ngram\": \"the Seine\", \"from\": 28966, \"to\": 28975}, {\"ngram\": \"the first time\", \"from\": 28983, \"to\": 28997}, {\"ngram\": \"an opening ceremony\", \"from\": 29003, \"to\": 29022}, {\"ngram\": \"place\", \"from\": 29033, \"to\": 29038}, {\"ngram\": \"a stadium\", \"from\": 29047, \"to\": 29056}, {\"ngram\": \"the last Games\", \"from\": 29063, \"to\": 29077}, {\"ngram\": \"the Winter Olympics\", \"from\": 29080, \"to\": 29099}, {\"ngram\": \"Beijing\", \"from\": 29108, \"to\": 29115}, {\"ngram\": \"2022 - wars\", \"from\": 29119, \"to\": 29130}, {\"ngram\": \"a tense international backdrop\", \"from\": 29175, \"to\": 29205}]}, {\"sentence\": \"France is at its highest level of security, though officials have repeatedly said there is no specific threat to the opening ceremony or the Games.Israeli competitors are being escorted by elite tactical units to and from events and given 24-hour protection throughout the Olympics due to the war in Gaza, officials say.Scores of world leaders are in Paris for the opening ceremony, which will also be protected by snipers on rooftops.\", \"from\": 29207, \"to\": 29642, \"entities\": [{\"begin\": 29207, \"end\": 29213, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.742772808375164, \"rank\": 0.30011500974378913, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 29507, \"end\": 29511, \"title\": \"http://dbpedia.org/resource/Gaza_City\", \"score\": 0.961573600280017, \"rank\": 0.03996199429383569, \"text\": \"Gaza\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Gaza_City\", \"dbpedia\": \"http://dbpedia.org/resource/Gaza_City\"}, {\"begin\": 29558, \"end\": 29563, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999993449516622, \"rank\": 6.550487949704093e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"its highest level\", \"from\": 29220, \"to\": 29237}, {\"ngram\": \"security\", \"from\": 29241, \"to\": 29249}, {\"ngram\": \"officials\", \"from\": 29258, \"to\": 29267}, {\"ngram\": \"no specific threat\", \"from\": 29298, \"to\": 29316}, {\"ngram\": \"the opening ceremony\", \"from\": 29320, \"to\": 29340}, {\"ngram\": \"the Games\", \"from\": 29344, \"to\": 29353}, {\"ngram\": \"Israeli competitors\", \"from\": 29354, \"to\": 29373}, {\"ngram\": \"elite tactical units\", \"from\": 29396, \"to\": 29416}, {\"ngram\": \"events\", \"from\": 29429, \"to\": 29435}, {\"ngram\": \"24-hour protection\", \"from\": 29446, \"to\": 29464}, {\"ngram\": \"the Olympics\", \"from\": 29476, \"to\": 29488}, {\"ngram\": \"the war\", \"from\": 29496, \"to\": 29503}, {\"ngram\": \"officials\", \"from\": 29513, \"to\": 29522}, {\"ngram\": \"Scores\", \"from\": 29527, \"to\": 29533}, {\"ngram\": \"world leaders\", \"from\": 29537, \"to\": 29550}, {\"ngram\": \"the opening ceremony\", \"from\": 29568, \"to\": 29588}, {\"ngram\": \"snipers\", \"from\": 29622, \"to\": 29629}, {\"ngram\": \"rooftops\", \"from\": 29633, \"to\": 29641}]}, {\"sentence\": \"The Seine's riverbed has been swept for bombs, and Paris' airspace is closed.For the Games more generally, radar-surveillance planes and Reaper drones will monitor sensitive sites from above, and Mirage 2000 fighter jets will be on standby to intercept aircraft straying into restricted airspace.French President Emmanuel Macron, who won a second mandate two years ago, had hoped the Olympics would cement his legacy.\", \"from\": 29643, \"to\": 30060, \"entities\": [{\"begin\": 29647, \"end\": 29652, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.999999825603383, \"rank\": 1.5808697226923957e-07, \"text\": \"Seine\", \"types\": [\"Q47521\", \