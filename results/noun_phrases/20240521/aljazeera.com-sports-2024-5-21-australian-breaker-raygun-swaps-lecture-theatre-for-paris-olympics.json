entities\": [{\"begin\": 528, \"end\": 548, \"title\": \"http://dbpedia.org/resource/Macquarie_University\", \"score\": 1.0, \"rank\": 1.9851037212467226e-22, \"text\": \"Macquarie University\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/Macquarie_University\", \"dbpedia\": \"http://dbpedia.org/resource/Macquarie_University\"}, {\"begin\": 614, \"end\": 634, \"title\": \"http://dbpedia.org/resource/Place_de_la_Concorde\", \"score\": 0.9999999999126885, \"rank\": 8.752514617637167e-11, \"text\": \"Place de la Concorde\", \"types\": [\"Q34442\"], \"wikid\": \"http://dbpedia.org/resource/Place_de_la_Concorde\", \"dbpedia\": \"http://dbpedia.org/resource/Place_de_la_Concorde\"}, {\"begin\": 732, \"end\": 737, \"title\": \"http://dbpedia.org/resource/The_Bronx\", \"score\": 0.9999999881670193, \"rank\": 8.726396071571848e-09, \"text\": \"Bronx\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/The_Bronx\", \"dbpedia\": \"http://dbpedia.org/resource/The_Bronx\"}], \"noun_phrases\": [{\"ngram\": \"time\", \"from\": 573, \"to\": 577}, {\"ngram\": \"academia\", \"from\": 587, \"to\": 595}, {\"ngram\": \"breaking\", \"from\": 642, \"to\": 650}, {\"ngram\": \"the streets\", \"from\": 713, \"to\": 724}]}, {\"sentence\": \"A university faculty office may seem an unlikely habitat for a breaking champion, and Gunn laughs when confirming she is unaware of any other academics moonlighting in the sport.\", \"from\": 740, \"to\": 918, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A university faculty office\", \"from\": 740, \"to\": 767}, {\"ngram\": \"an unlikely habitat\", \"from\": 777, \"to\": 796}, {\"ngram\": \"a breaking champion\", \"from\": 801, \"to\": 820}, {\"ngram\": \"any other academics\", \"from\": 872, \"to\": 891}, {\"ngram\": \"the sport\", \"from\": 908, \"to\": 917}]}, {\"sentence\": \"\\\"People certainly think it's cool and interesting, but it's also really different to the classic academic path,\\\" she told Reuters in an interview.\", \"from\": 920, \"to\": 1066, \"entities\": [{\"begin\": 1042, \"end\": 1049, \"title\": \"http://dbpedia.org/resource/Reuters\", \"score\": 0.9999999981600922, \"rank\": 1.8185591875779617e-09, \"text\": \"Reuters\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Reuters\", \"dbpedia\": \"http://dbpedia.org/resource/Reuters\"}], \"noun_phrases\": [{\"ngram\": \"People\", \"from\": 921, \"to\": 927}, {\"ngram\": \"the classic academic path\", \"from\": 1005, \"to\": 1030}, {\"ngram\": \"an interview\", \"from\": 1053, \"to\": 1065}]}, {\"sentence\": \"\\\"So you do get a few different reactions depending on which department or faculty people are from.\", \"from\": 1068, \"to\": 1166, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a few different reactions\", \"from\": 1083, \"to\": 1108}, {\"ngram\": \"which department or faculty people\", \"from\": 1122, \"to\": 1156}]}, {\"sentence\": \"But by and large, the response has been really positive.\\\"\", \"from\": 1167, \"to\": 1224, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the response\", \"from\": 1185, \"to\": 1197}]}, {\"sentence\": \"Gunn did not take up breaking until her mid-20s and stands out among the teenagers qualified to date, who include Lithuanian world champion Dominika Banevic, a 16-year-old who competes as \\\"B-girl Nicka\\\".\", \"from\": 1226, \"to\": 1429, \"entities\": [{\"begin\": 1226, \"end\": 1230, \"title\": \"http://dbpedia.org/resource/Trey_Gunn\", \"score\": 0.9378915979022769, \"rank\": 0.05962529370360896, \"text\": \"Gunn\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Trey_Gunn\", \"dbpedia\": \"http://dbpedia.org/resource/Trey_Gunn\"}, {\"begin\": 1340, \"end\": 1350, \"title\": \"http://dbpedia.org/resource/Lithuanian_language\", \"score\": 0.965567589616364, \"rank\": 0.012757415644821753, \"text\": \"Lithuanian\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Lithuanian_language\", \"dbpedia\": \"http://dbpedia.org/resource/Lithuanian_language\"}], \"noun_phrases\": [{\"ngram\": \"the teenagers\", \"from\": 1295, \"to\": 1308}, {\"ngram\": \"date\", \"from\": 1322, \"to\": 1326}, {\"ngram\": \"B-girl Nicka\", \"from\": 1415, \"to\": 1427}]}, {\"sentence\": \"Australia's male qualifier Jeff \\\"J-Attack\\\" Dunne is also 16.\", \"from\": 1431, \"to\": 1491, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Jeff \\\"J-Attack\", \"from\": 1458, \"to\": 1472}, {\"ngram\": \"Dunne\", \"from\": 1474, \"to\": 1479}]}, {\"sentence\": \"Yet Gunn is far from an anomaly, with American rival Sunny Choi also set to fly the flag for mid-30s breakers at Paris after giving up a corporate career.\", \"from\": 1493, \"to\": 1647, \"entities\": [{\"begin\": 1497, \"end\": 1501, \"title\": \"http://dbpedia.org/resource/Trey_Gunn\", \"score\": 0.9378915979022769, \"rank\": 0.05962529370360896, \"text\": \"Gunn\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Trey_Gunn\", \"dbpedia\": \"http://dbpedia.org/resource/Trey_Gunn\"}, {\"begin\": 1531, \"end\": 1539, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.999984843291981, \"rank\": 8.36420421374478e-06, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 1552, \"end\": 1556, \"title\": \"http://dbpedia.org/resource/Ada_Choi\", \"score\": 0.9999996906995444, \"rank\": 3.0930043825583185e-07, \"text\": \"Choi\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Ada_Choi\", \"dbpedia\": \"http://dbpedia.org/resource/Ada_Choi\"}, {\"begin\": 1606, \"end\": 1611, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999964012314376, \"rank\": 3.598