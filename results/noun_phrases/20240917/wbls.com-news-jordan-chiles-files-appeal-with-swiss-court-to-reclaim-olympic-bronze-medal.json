"{\"uid\": \"wbls.com-news-jordan-chiles-files-appeal-with-swiss-court-to-reclaim-olympic-bronze-medal\", \"noun_phrases\": [{\"sentence\": \"By Jordan Chilesisn't done trying to get her bronze medal back from the Paris Olympics.\", \"from\": 0, \"to\": 88, \"entities\": [{\"begin\": 4, \"end\": 10, \"title\": \"http://dbpedia.org/resource/Jordan\", \"score\": 0.9986454588449515, \"rank\": 0.0012696536358252984, \"text\": \"Jordan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jordan\", \"dbpedia\": \"http://dbpedia.org/resource/Jordan\"}], \"noun_phrases\": [{\"ngram\": \"her bronze medal\", \"from\": 41, \"to\": 57}, {\"ngram\": \"the Paris Olympics\", \"from\": 68, \"to\": 86}]}, {\"sentence\": \"The American gymnast filed a formal appeal with the Swiss Federal Tribunal on Monday in an attempt to overturn an earlier ruling by the Court of Arbitration for Sport that took away the bronze medal she won in the individual floor exercise in Paris earlier this summer.\", \"from\": 90, \"to\": 359, \"entities\": [{\"begin\": 94, \"end\": 102, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999999470258004, \"rank\": 5.1165426160086427e-08, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 142, \"end\": 164, \"title\": \"http://dbpedia.org/resource/Federal_Supreme_Court_of_Switzerland\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Swiss Federal Tribunal\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Federal_Supreme_Court_of_Switzerland\", \"dbpedia\": \"http://dbpedia.org/resource/Federal_Supreme_Court_of_Switzerland\"}, {\"begin\": 333, \"end\": 338, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9998385986329147, \"rank\": 0.00016142742165950908, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.o