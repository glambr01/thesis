\": 8637}, {\"ngram\": \"discovery\", \"from\": 8642, \"to\": 8651}, {\"ngram\": \"the resources\", \"from\": 8666, \"to\": 8679}, {\"ngram\": \"the decisions\", \"from\": 8693, \"to\": 8706}, {\"ngram\": \"labs\", \"from\": 8721, \"to\": 8725}, {\"ngram\": \"the U.S.\", \"from\": 8733, \"to\": 8741}, {\"ngram\": \"both budding and working scientists\", \"from\": 8763, \"to\": 8798}, {\"ngram\": \"a time\", \"from\": 8802, \"to\": 8808}, {\"ngram\": \"the value\", \"from\": 8814, \"to\": 8823}, {\"ngram\": \"science\", \"from\": 8827, \"to\": 8834}]}, {\"sentence\": \"In return, you get essential news,captivating podcasts, brilliant infographics,can not-miss newsletters, must-watch videos,challenging games, and the science world's best writing and reporting.\", \"from\": 8872, \"to\": 9065, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"return\", \"from\": 8875, \"to\": 8881}, {\"ngram\": \"essential news\", \"from\": 8891, \"to\": 8905}, {\"ngram\": \"captivating podcasts\", \"from\": 8906, \"to\": 8926}, {\"ngram\": \"brilliant infographics\", \"from\": 8928, \"to\": 8950}, {\"ngram\": \"can not-miss newsletters\", \"from\": 8951, \"to\": 8975}, {\"ngram\": \"videos\", \"from\": 8988, \"to\": 8994}, {\"ngram\": \"challenging games\", \"from\": 8995, \"to\": 9012}, {\"ngram\": \"the science world's best writing\", \"from\": 9018, \"to\": 9050}, {\"ngram\": \"reporting\", \"from\": 9055, \"to\": 9064}]}, {\"sentence\": \"You can evengift someone a subscription.\", \"from\": 9066, \"to\": 9106, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"someone\", \"from\": 9083, \"to\": 9090}]}, {\"sentence\": \"There has never been a more important time for us to stand up and show why science matters.\", \"from\": 9108, \"to\": 9199, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a more important time\", \"from\": 9129, \"to\": 9150}, {\"ngram\": \"us\", \"from\": 9155, \"to\": 9157}]}, {\"sentence\": \"I hope you will support us in that mission.\", \"from\": 9200, 