, {\"sentence\": \"Herrero, whose series about a Parisian talent agency has been one of France's biggest cultural exports of recent years, said she had been invited to develop a plot for the 26 July ceremony on the river Seine.\", \"from\": 225, \"to\": 433, \"entities\": [{\"begin\": 294, \"end\": 300, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9927190842518033, \"rank\": 0.00720992429739183, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"Herrero\", \"from\": 225, \"to\": 232}, {\"ngram\": \"whose series\", \"from\": 234, \"to\": 246}, {\"ngram\": \"a Parisian talent agency\", \"from\": 253, \"to\": 277}, {\"ngram\": \"recent years\", \"from\": 331, \"to\": 343}, {\"ngram\": \"a plot\", \"from\": 382, \"to\": 388}, {\"ngram\": \"the 26 July ceremony\", \"from\": 393, \"to\": 413}, {\"ngram\": \"the river Seine\", \"from\": 417, \"to\": 432}]}, {\"sentence\": \"\\\"My first reflex was that the job was too big and too beautiful for me.\", \"from\": 435, \"to\": 506, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My first reflex\", \"from\": 436, \"to\": 451}, {\"ngram\": \"the job\", \"from\": 461, \"to\": 468}]}, {\"sentence\": \"I was scared,\\\" Herrero toldLe Mondeof the invitation from Paris 2024 ceremony director Thomas Jolly.\", \"from\": 507, \"to\": 607, \"entities\": [{\"begin\": 565, \"end\": 575, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 0.999999999979309, \"rank\": 2.0700986964110328e-11, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 594, \"end\": 600, \"title\": \"http://dbpedia.org/resource/Thomas_the_Tank_Engine\", \"score\": 0.9995479234639565, \"rank\": 0.0004509464591868847, \"text\": \"Thomas\", \"types\"