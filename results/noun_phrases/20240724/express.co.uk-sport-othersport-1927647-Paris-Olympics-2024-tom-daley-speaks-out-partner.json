noun_phrases\": [{\"ngram\": \"secrecy\", \"from\": 765, \"to\": 772}]}, {\"sentence\": \"The first person I called was my husband Lance, because I wanted to tell him,\\\" said Daley, who will join theDiscovery+commentary team after competing in the 10m synchro event next Monday.\", \"from\": 799, \"to\": 986, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The first person\", \"from\": 799, \"to\": 815}, {\"ngram\": \"my husband\", \"from\": 829, \"to\": 839}, {\"ngram\": \"Lance\", \"from\": 840, \"to\": 845}, {\"ngram\": \"Daley\", \"from\": 883, \"to\": 888}, {\"ngram\": \"theDiscovery+commentary team\", \"from\": 904, \"to\": 932}, {\"ngram\": \"the 10m synchro event\", \"from\": 952, \"to\": 973}]}, {\"sentence\": \"\\\"It has been really tough, we moved to America and then I decided I wanted to go back to training, and it has been hard with the travel.\", \"from\": 988, \"to\": 1124, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"America\", \"from\": 1027, \"to\": 1034}, {\"ngram\": \"training\", \"from\": 1077, \"to\": 1085}, {\"ngram\": \"the travel\", \"from\": 1113, \"to\": 1123}]}, {\"sentence\": \"\\\"It has been a real journey.\", \"from\": 1126, \"to\": 1154, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a real journey\", \"from\": 1139, \"to\": 1153}]}, {\"sentence\": \"I feel really proud to have committed to going on another Olympic journey, against all odds.\", \"from\": 1155, \"to\": 1247, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"another Olympic journey\", \"from\": 1205, \"to\": 1228}, {\"ngram\": \"all odds\", \"from\": 1238, \"to\": 1246}]}, {\"sentence\": \"I really went for it, and he was so happy for me.\", \"from\": 1248, \"to\": 1297, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Discovery+is the new home of the Olympics.\", \"from\": 1299, \"to\": 1341, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Discovery+is\", \"from\": 1299, \"to\": 1311}, {\"ngram\": \"the new home\", \"from\": 1312, \"to\": 1324}, {\"ngram\": \"the Olympics\", \"from\": 1328, \"to\": 1340}]}, {\"sentence\": \"The streamer is set to broadcast 3,800 hours of sport live from Paris.\", \"from\": 1342, \"to\": 1412, \"entities\": [{\"begin\": 1406, \"end\": 1411, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999998008207, \"rank\": 1.9924130631986554e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"The streamer\", \"from\": 1342, \"to\": 1354}, {\"ngram\": \"3,800 hours\", \"from\": 1375, \"to\": 1386}, {\"ngram\": \"sport\", \"from\": 1390, \"to\": 1395}]}, {\"sentence\": \"Sports fans can getDiscovery+ for \\u00a33.99a month until the end of 2024 via Amazon Prime's video channels.\", \"from\": 1414, \"to\": 1517, \"entities\": [{\"begin\": 1487, \"end\": 1499, \"title\": \"http://dbpedia.org/resource/Amazon_Prime\", \"score\": 0.9997497647079302, \"rank\": 0.0002502962467144605, \"text\": \"Amazon Prime\", \"types\": [\"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Amazon_Prime\", \"dbpedia\": \"http://dbpedia.org/resource/Amazon_Prime\"}], \"noun_phrases\": [{\"ngram\": \"Sports fans\", \"from\": 1414, \"to\": 1425}, {\"ngram\": \"\\u00a33.99a month\", \"from\": 1448, \"to\": 1460}, {\"ngram\": \"the end\", \"from\": 1467, \"to\": 1474}]}, {\"sentence\": \"This also comes with anAmazon Prime 30-day free trial.\", \"from\": 1518, \"to\": 1572, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"anAmazon Prime 30-day free trial\", \"from\": 1539, \"to\": 1571}]}, {\"sentence\": \"\\\"My youngest son [Phoenix] will not remember but Robbie, who has just turned six, is going to.\", \"from\": 1574, \"to\": 1668, \"entities\": [{\"begin\": 1592, \"end\": 1599, \"title\": \"http://dbpedia.org/resource/Phoenix_Raceway\", \"score\": 0.9563649456774675, \"rank\": 0.04551995382044847, \"text\": \"Phoenix\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Phoenix_Raceway\", \"dbpedia\": \"http://dbpedia.org/resource/Phoenix_Raceway\"}, {\"begin\": 1623, \"end\": 1629, \"title\": \"http://dbpedia.org/resource/Clan_Donnachaidh\", \"score\": 0.9822476629991398, \"rank\": 0.018067846384287475, \"text\": \"Robbie\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Clan_Donnachaidh\", \"dbpedia\": \"http://dbpedia.org/resource/Clan_Donnachaidh\"}], \"noun_phrases\": [{\"ngram\": \"My youngest son\", \"from\": 1575, \"to\": 1590}]}, {\"sentence\": \"He is very excited; he has been learning a lot about the Olympics at school and it is going to be really special to look back at photos and say they were there.\", \"from\": 1669, \"to\": 1829, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a lot\", \"from\": 1710, \"to\": 1715}, {\"ngram\": \"the Olympics\", \"from\": 1722, \"to\": 1734}, {\"ngram\": \"school\", \"from\": 1738, \"to\": 1744}, {\"ngram\": \"photos\", \"from\": 1798, \"to\": 1804}]}, {\"sentence\": \"\\\"I am looking forward to sharing the moment with Helen too, she is such an inspiration.\\\"\", \"from\": 1831, \"to\": 1919, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the moment\", \"from\": 1864, \"to\": 1874}, {\"ngram\": \"Helen\", \"from\": 1880, \"to\": 1885}, {\"ngram\": \"such an inspiration\", \"from\": 1898, \"to\": 1917}]}, {\"sentence\": \"At different points in this Olympic cycle, it's fair to say that both Daley and Glover were uncertain to be in Paris.\", \"from\": 1921, \"to\": 2038, \"entities\": [{\"begin\": 2001, \"end\": 2007, \"title\": \"http://dbpedia.org/resource/Roger_Glover\", \"score\": 0.9999999232213698, \"rank\": 7.674589723681878e-08, \"text\": \"Glover\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Roger_Glover\", \"dbpedia\": \"http://dbpedia.org/resource/Roger_Glover\"}, {\"begin\": 2032, \"end\": 2037, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.99999