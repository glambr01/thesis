: 181}]}, {\"sentence\": \"It is the City of Light and the city of sights.\", \"from\": 206, \"to\": 253, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the City\", \"from\": 212, \"to\": 220}, {\"ngram\": \"Light\", \"from\": 224, \"to\": 229}, {\"ngram\": \"the city\", \"from\": 234, \"to\": 242}, {\"ngram\": \"sights\", \"from\": 246, \"to\": 252}]}, {\"sentence\": \"No matter who\\u00e2\\u0080\\u0099s judging the competition, it takes its place on the medal stand for the mythical title of World\\u00e2\\u0080\\u0099s Most Visually Beautiful City.\", \"from\": 254, \"to\": 400, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the competition\", \"from\": 280, \"to\": 295}, {\"ngram\": \"its place\", \"from\": 306, \"to\": 315}, {\"ngram\": \"the medal stand\", \"from\": 319, \"to\": 334}, {\"ngram\": \"the mythical title\", \"from\": 339, \"to\": 357}, {\"ngram\": \"World\\u00e2\\u0080\\u0099s\", \"from\": 361, \"to\": 370}, {\"ngram\": \"Most Visually Beautiful City\", \"from\": 371, \"to\": 399}]}, {\"sentence\": \"But this spring, Paris has been a city for the ears as much as for the eyes.\", \"from\": 401, \"to\": 477, \"entities\": [{\"begin\": 418, \"end\": 423, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 4.0547288765635774e-35, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"a city\", \"from\": 433, \"to\": 439}, {\"ngram\": \"the ears\", \"from\": 444, \"to\": 452}, {\"ngram\": \"the eyes\", \"from\": 468, \"to\": 476}]}, {\"sentence\": \"Drowning out the accordions, the soundtrack is one of clanging, the hum of construction.\", \"from\": 478, \"to\": 566, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the accordions\", \"from\": 491, \"to\": 505}, {\"ngram\": \"the soundtrack\", \"from\": 507, \"to\": 521}, {\"ngram\": \"clanging\", \"from\": 532, \"to\": 540}, {\"ngram\": \"the hum\", \"from\": 542, \"to\": 549}, {\"ngram\": \"construction\", \"from\": 553, \"to\": 565}]}, {\"sentence\": \"Yes, some of this audio comes from Notre-Dame, where renovations are happily\\u00e2\\u0080\\u0094and uncharacteristically for the French\\u00e2\\u0080\\u0094proceeding on schedule, repairing the damage caused by a 2019 fire to the world\\u00e2\\u0080\\u0099s most famous cathedral.\", \"from\": 568, \"to\": 795, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this audio\", \"from\": 581, \"to\": 591}, {\"ngram\": \"Notre-Dame\", \"from\": 603, \"to\": 613}, {\"ngram\": \"renovations\", \"from\": 621, \"to\": 632}, {\"ngram\": \"happily\\u00e2\\u0080\\u0094and\", \"from\": 637, \"to\": 650}, {\"ngram\": \"the French\\u00e2\\u0080\\u0094proceeding\", \"from\": 676, \"to\": 699}, {\"ngram\": \"schedule\", \"from\": 703, \"to\": 711}, {\"ngram\": \"the damage\", \"from\": 723, \"to\": 733}, {\"ngram\": \"a 2019 fire\", \"from\": 744, \"to\": 755}, {\"ngram\": \"the world\\u00e2\\u0080\\u0099s\", \"from\": 759, \"to\": 772}, {\"ngram\": \"most famous cathedral\", \"from\": 773, \"to\": 794}]}, {\"sentence\": \"Most of Paris\\u00e2\\u0080\\u0099s noise, though, emanates from the structures being jerry-built for the 2024 Summer Olympics.\\u00c2 On the lawns behind the Eiffel Tower, along the banks of the Seine, finishing touches are being applied to a temporary 13,000-seat structure that will host the beach volleyball competition.\", \"from\": 796, \"to\": 1097, \"entities\": [{\"begin\": 969, \"end\": 974, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 1.0, \"rank\": 1.618495409143208e-26, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"Paris\\u00e2\\u0080\\u0099s noise\", \"from\": 804, \"to\": 819}, {\"ngram\": \"though, emanates\", \"from\": 821, \"to\": 837}, {\"ngram\": \"the structures\", \"from\": 843, \"to\": 857}, {\"ngram\": \"the 2024 Summer Olympics\", \"from\": 880, \"to\": 904}, {\"ngram\": \"the lawns\", \"from\": 910, \"to\": 919}, {\"ngram\": \"the Eiffel Tower\", \"from\": 927, \"to\": 943}, {\"ngram\": \"the banks\", \"from\": 951, \"to\": 960}, {\"ngram\": \"finishing touches\", \"from\": 975, \"to\": 992}, {\"ngram\": \"a temporary 13,000-seat structure\", \"from\": 1014, \"to\": 1047}, {\"ngram\": \"the beach volleyball competition\", \"from\": 1063, \"to\": 1095}]}, {\"sentence\": \"Not far away, on the other side of the river, bleachers are being installed at Place de la Concorde for the venue to host urban sports like BMX freestyle, skateboarding and (zut alors!)\", \"from\": 1098, \"to\": 1283, \"entities\": [{\"begin\": 1177, \"end\": 1197, \"title\": \"http://dbpedia.org/resource/Place_de_la_Concorde\", \"score\": 1.0, \"rank\": 1.971550785942805e-40, \"text\": \"Place de la Concorde\", \"types\": [\"Q34442\"], \"wikid\": \"http://dbpedia.org/resource/Place_de_la_Concorde\", \"dbpedia\": \"http://dbpedia.org/resource/Place_de_la_Concorde\"}, {\"begin\": 1238, \"end\": 1251, \"title\": \"http://dbpedia.org/resource/Freestyle_BMX\", \"score\": 0.99999997525174, \"rank\": 2.474856929655488e-08, \"text\": \"BMX freestyle\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Freestyle_BMX\", \"dbpedia\": \"http://dbpedia.org/resource/Freestyle_BMX\"}], \"noun_phrases\": [{\"ngram\": \"the other side\", \"from\": 1115, \"to\": 1129}, {\"ngram\": \"the river\", \"from\": 1133, \"to\": 1142}, {\"ngram\": \"bleachers\", \"from\": 1144, \"to\": 1153}, {\"ngram\": \"the venue\", \"from\": 1202, \"to\": 1211}, {\"ngram\": \"urban sports\", \"from\": 1220, \"to\": 1232}]}, {\"sentence\": \"the first Olympic breakdancing (officially known as breaking) competition.\", \"from\": 1284, \"to\": 1358, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the first Olympic breakdancing\", \"from\": 1284, \"to\": 1314}, {\"ngram\": \"breaking\", \"from\": 1336, \"to\": 1344}, {\"ngram\": \"competition\", \"from\": 1346, \"to\": 1357}]}, {\"sentence\": \"In the suburbs of Seine-Saint-Denis, work is afoot on the Olympic Village for some 15,000 athletes, which will be used for low-income housing after the Games.\", \"from\": 1359, \"to\": 1517, \"entities\": [{\"begin\": 1417, \"end\": 1432, \"title\": \"http://dbpedia.org/resource/Olympic_Village\", \"score\": 1.0, \"rank\": 6.3998446528212836e-46, \"text\": \"Olympic Village\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Village\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Village\"}], \"noun_phrases\": [{\"ngram\": \"the suburbs\", \"from\": 1362, \"to\": 1373}, {\"ngram\": \"Seine-Saint-Denis\", \"from\": 1377, \"to\": 1394}, {\"ngram\": \"work\", \"from\": 1396, \"to\": 1400}, {\"ngram\": \"some 15,000 athletes\", \"from\": 1437, \"to\": 1457}, {\"ngram\": \"low-income housing\", \"from\": 1482, \"to\": 1500}, {\"ngram\": \"the Games\", \"from\": 1507, \"to\": 1516}]}, {\"sentence\": \"About 10 miles outside of town in the other direction, the grounds at the Palace of Versailles are framed by bleachers to accommodate 40,000 fans for the equestrian events.\", \"from\": 1518, \"to\": 1690, \"entities\": [{\"begin\": 1672, \"end\": 1682, \"title\": \"http://dbpedia.org/resource/Equestrianism\", \"score\": 1.0, \"rank\": 2.751062653683974e-14, \"text\": \"equestrian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Equestrianism\", \"dbpedia\": \"http://dbpedia.org/resource/Equestrianism\"}], \"noun_phrases\": [{\"ngram\": \"town\", \"from\": 1544, \"to\": 1548}, {\"ngram\": \"the other direction\", \"from\": 1552, \"to\": 1571}, {\"ngram\": \"the grounds\", \"from\": 1573, \"to\": 1584}, {\"ngram\": \"the Palace\", \"from\": 1588, \"to\": 1598}, {\"ngram\": \"Versailles\", \"from\": 1602, \"to\": 1612}, {\"ngram\": \"bleachers\", \"from\": 1627, \"to\": 1636}, {\"ngram\": \"40,000 fans\", \"from\": 1652, \"to\": 1663}]}, {\"sentence\": \"A year ago, you could\\u00e2\\u0080\\u0099ve spent time in Paris and heard nary a bulldozer, scarcely realizing the next Olympics were coming to town.\", \"from\": 1692, \"to\": 1824, \"entities\": [{\"begin\": 1733, \"end\": 1738, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 4.0547288765635774e-35, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"could\\u00e2\\u0080\\u0099ve\", \"from\": 1708, \"to\": 1718}, {\"ngram\": \"time\", \"from\": 1725, \"to\": 1729}, {\"ngram\": \"nary a bulldozer\", \"from\": 1749, \"to\": 1765}, {\"ngram\": \"the next Olympics\", \"from\": 1786, \"to\": 1803}, {\"ngram\": \"town\", \"from\": 1819, \"to\": 1823}]}, {\"sentence\": \"We are, after all, talking Paris.\", \"from\": 1825, \"to\": 1858, \"entities\": [{\"begin\": 1852, \"end\": 1857, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 4.0547288765635774e-35, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": []}, {\"sentence\": \"Not exactly the kind of place that needs 16 days of global sports to justify itself as a city of the world.\", \"from\": 1859, \"to\": 1966, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Not exactly the kind\", \"from\": 1859, \"to\": 1879}, {\"ngram\": \"place\", \"from\": 1883, \"to\": 1888}, {\"ngram\": \"16 days\", \"from\": 1900, \"to\": 1907}, {\"ngram\": \"global sports\", \"from\": 1911, \"to\": 1924}, {\"ngram\": \"a city\", \"from\": 1946, \"to\": 1952}, {\"ngram\": \"the world\", \"from\": 1956, \"to\": 1965}]}, {\"sentence\": \"If other hosts perceived the Games as a seminal moment in their city\\u00e2\\u0080\\u0099s history, Paris seemed to be taking one for the team.\", \"from\": 1967, \"to\": 2092, \"entities\": [{\"begin\": 2049, \"end\": 2054, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 4.0547288765635774e-35, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"other hosts\", \"from\": 1970, \"to\": 1981}, {\"ngram\": \"the Games\", \"from\": 1992, \"to\": 2001}, {\"ngram\": \"a seminal moment\", \"from\": 2005, \"to\": 2021}, {\"ngram\": \"their city\\u00e2\\u0080\\u0099s history\", \"from\": 2025, \"to\": 2047}, {\"ngram\": \"the team\", \"from\": 2083, \"to\": 2091}]}, {\"sentence\": \"The Olympic movement, that is.\", \"from\": 2093, \"to\": 2123, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The Olympic movement\", \"from\": 2093, \"to\": 2113}]}, {\"sentence\": \"After the systematic Russian doping scandal in Sochi and cost overruns in Rio, the absence of fans (and one-year COVID-19 delay) in Tokyo, followed by a buzz-deprived Winter Games in authoritarian China, here was Paris to restore dignity and stability to the proceedings.\", \"from\": 2124, \"to\": 2395, \"entities\": [{\"begin\": 2145, \"end\": 2167, \"title\": \"http://dbpedia.org/resource/Doping_in_Russia\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Russian doping scandal\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Doping_in_Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Doping_in_Russia\"}, {\"begin\": 2171, \"end\": 2176, \"title\": \"http://dbpedia.org/resource/Sochi\", \"score\": 0.7874815028336234, \"rank\": 0.26987109716445146, \"text\": \"Sochi\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Sochi\", \"dbpedia\": \"http://dbpedia.org/resource/Sochi\"}, {\"begin\": 2198, \"end\": 2201, \"title\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"score\": 0.9999999990177457, \"rank\": 9.819849171183355e-10, \"text\": \"Rio\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2016_Summer_Olympics\"}, {\"begin\": 2256, \"end\": 2261, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.9999998150624549, \"rank\": 1.8377331728027476e-07, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}, {\"begin\": 2321, \"end\": 2326, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9999999847741493, \"rank\": 1.5222203853711042e-08, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}, {\"begin\": 2337, \"end\": 2342, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 4.0547288765635774e-35, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"cost overruns\", \"from\": 2181, \"to\": 2194}, {\"ngram\": \"the absence\", \"from\": 2203, \"to\": 2214}, {\"ngram\": \"fans\", \"from\": 2218, \"to\": 2222}, {\"ngram\": \"one-year COVID-19 delay\", \"from\": 2228, \"to\": 2251}, {\"ngram\": \"a buzz-deprived Winter Games\", \"from\": 2275, \"to\": 2303}, {\"ngram\": \"dignity\", \"from\": 2354, \"to\": 2361}, {\"ngram\": \"stability\", \"from\": 2366, \"to\": 2375}, {\"ngram\": \"the proceedings\", \"from\": 2379, \"to\": 2394}]}, {\"sentence\": \"It was met with the famous Gallic pfft.\", \"from\": 2397, \"to\": 2436, \"entities\": [{\"begin\": 2424, \"end\": 2430, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 1.0, \"rank\": 1.2149956545209855e-22, \"text\": \"Gallic\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": []}, {\"sentence\": \"The overall vibe was perhaps akin to Jimmy Kimmel hosting the Oscars: They need me more than I need the gig.\", \"from\": 2437, \"to\": 2545, \"entities\": [{\"begin\": 2474, \"end\": 2486, \"title\": \"http://dbpedia.org/resource/Jimmy_Kimmel\", \"score\": 1.0, \"rank\": 2.457481742120042e-54, \"text\": \"Jimmy Kimmel\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jimmy_Kimmel\", \"dbpedia\": \"http://dbpedia.org/resource/Jimmy_Kimmel\"}], \"noun_phrases\": [{\"ngram\": \"The overall vibe\", \"from\": 2437, \"to\": 2453}, {\"ngram\": \"the Oscars\", \"from\": 2495, \"to\": 2505}, {\"ngram\": \"the gig\", \"from\": 2537, \"to\": 2544}]}, {\"sentence\": \"But I\\u00e2\\u0080\\u0099ll do it for the sake of the institution.\", \"from\": 2546, \"to\": 2595, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the sake\", \"from\": 2567, \"to\": 2575}, {\"ngram\": \"the institution\", \"from\": 2579, \"to\": 2594}]}, {\"sentence\": \"Locals made vacation plans for late July and early August of 2024, listing their flats on Airbnb and predicting traffic and strikes and general chaos.\", \"from\": 2596, \"to\": 2746, \"entities\": [{\"begin\": 2686, \"end\": 2692, \"title\": \"http://dbpedia.org/resource/Airbnb\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Airbnb\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Airbnb\", \"dbpedia\": \"http://dbpedia.org/resource/Airbnb\"}], \"noun_phrases\": [{\"ngram\": \"Locals\", \"from\": 2596, \"to\": 2602}, {\"ngram\": \"vacation plans\", \"from\": 2608, \"to\": 2622}, {\"ngram\": \"late July\", \"from\": 2627, \"to\": 2636}, {\"ngram\": \"early August\", \"from\": 2641, \"to\": 2653}, {\"ngram\": \"their flats\", \"from\": 2671, \"to\": 2682}, {\"ngram\": \"traffic\", \"from\": 2708, \"to\": 2715}, {\"ngram\": \"strikes\", \"from\": 2720, \"to\": 2727}, {\"ngram\": \"general chaos\", \"from\": 2732, \"to\": 2745}]}, {\"sentence\": \"Even politicians abandoned cheerleading to adopt a defensive posture: Let\\u00e2\\u0080\\u0099s try to stay on budget and avoid a terror attack.\\u00c2 But this spring, in lockstep with the venue construction, Olympic enthusiasm undeniably ramped up.\", \"from\": 2747, \"to\": 2974, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Even politicians\", \"from\": 2747, \"to\": 2763}, {\"ngram\": \"cheerleading\", \"from\": 2774, \"to\": 2786}, {\"ngram\": \"a defensive posture\", \"from\": 2796, \"to\": 2815}, {\"ngram\": \"Let\\u00e2\\u0080\\u0099s\", \"from\": 2817, \"to\": 2824}, {\"ngram\": \"budget\", \"from\": 2840, \"to\": 2846}, {\"ngram\": \"a terror attack\", \"from\": 2857, \"to\": 2872}, {\"ngram\": \"\\u00c2\", \"from\": 2873, \"to\": 2874}, {\"ngram\": \"lockstep\", \"from\": 2895, \"to\": 2903}, {\"ngram\": \"the venue construction\", \"from\": 2909, \"to\": 2931}, {\"ngram\": \"Olympic enthusiasm\", \"from\": 2933, \"to\": 2951}]}, {\"sentence\": \"Large rings adorn Paris\\u00e2\\u0080\\u0099s city hall.\", \"from\": 2975, \"to\": 3013, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Large rings\", \"from\": 2975, \"to\": 2986}, {\"ngram\": \"Paris\\u00e2\\u0080\\u0099s city hall\", \"from\": 2993, \"to\": 3012}]}, {\"sentence\": \"There are pop-up souvenir shops.\", \"from\": 3014, \"to\": 3046, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"pop-up souvenir shops\", \"from\": 3024, \"to\": 3045}]}, {\"sentence\": \"Athletes\\u00e2\\u0080\\u0094French ones, in particular\\u00e2\\u0080\\u0094are featured on billboards and ads in the M\\u00c3\\u00a9tro.\", \"from\": 3047, \"to\": 3136, \"entities\": [{\"begin\": 3129, \"end\": 3131, \"title\": \"http://dbpedia.org/resource/M\\u00e3_River\", \"score\": 0.5748508811812769, \"rank\": 0.7066666666668318, \"text\": \"M\\u00c3\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/M\\u00e3_River\", \"dbpedia\": \"http://dbpedia.org/resource/M\\u00e3_River\"}], \"noun_phrases\": [{\"ngram\": \"ones\", \"from\": 3065, \"to\": 3069}, {\"ngram\": \"particular\\u00e2\\u0080\\u0094are\", \"from\": 3074, \"to\": 3090}, {\"ngram\": \"billboards\", \"from\": 3103, \"to\": 3113}, {\"ngram\": \"ads\", \"from\": 3118, \"to\": 3121}]}, {\"sentence\": \"From hotels to nail salons, businesses are anticipating the premium prices they will charge.\", \"from\": 3137, \"to\": 3229, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"hotels\", \"from\": 3142, \"to\": 3148}, {\"ngram\": \"nail salons\", \"from\": 3152, \"to\": 3163}, {\"ngram\": \"businesses\", \"from\": 3165, \"to\": 3175}, {\"ngram\": \"the premium prices\", \"from\": 3193, \"to\": 3211}]}, {\"sentence\": \"Paris 2024 chief Tony Estanguet (a three-time Olympic gold medalist in canoe slalom) is a media fixture, alternately lifting morale (\\u00e2\\u0080\\u009cpreparations are in good shape!\\u00e2\\u0080\\u009d) and reassuring minds (the security apparatus will be \\u00e2\\u0080\\u009cunprecedented\\u00e2\\u0080\\u009d).\", \"from\": 3230, \"to\": 3476, \"entities\": [{\"begin\": 3230, \"end\": 3240, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.191112487718344e-50, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 3247, \"end\": 3261, \"title\": \"http://dbpedia.org/resource/Tony_Estanguet\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Tony Estanguet\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Tony_Estanguet\", \"dbpedia\": \"http://dbpedia.org/resource/Tony_Estanguet\"}], \"noun_phrases\": [{\"ngram\": \"a three-time Olympic gold medalist\", \"from\": 3263, \"to\": 3297}, {\"ngram\": \"canoe slalom\", \"from\": 3301, \"to\": 3313}, {\"ngram\": \"a media fixture\", \"from\": 3318, \"to\": 3333}, {\"ngram\": \"morale\", \"from\": 3355, \"to\": 3361}, {\"ngram\": \"\\u00e2\\u0080\\u009cpreparations\", \"from\": 3363, \"to\": 3378}, {\"ngram\": \"good shape!\\u00e2\\u0080\\u009d\", \"from\": 3386, \"to\": 3400}, {\"ngram\": \"reassuring minds\", \"from\": 3406, \"to\": 3422}, {\"ngram\": \"the security apparatus\", \"from\": 3424, \"to\": 3446}]}, {\"sentence\": \"Paris, of course, has done this drill before.\", \"from\": 3478, \"to\": 3523, \"entities\": [{\"begin\": 3478, \"end\": 3483, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 4.0547288765635774e-35, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"course\", \"from\": 3488, \"to\": 3494}, {\"ngram\": \"this drill\", \"from\": 3505, \"to\": 3515}]}, {\"sentence\": \"Twice actually.\", \"from\": 3524, \"to\": 3539, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"It hosted the second modern Olympics in 1900.\", \"from\": 3540, \"to\": 3585, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the second modern Olympics\", \"from\": 3550, \"to\": 3576}]}, {\"sentence\": \"Then, in 1924, the French capital again staged Games that were considered remarkable at the time, and, in retrospect, marked a hinge point in the Olympic movement.\", \"from\": 3586, \"to\": 3749, \"entities\": [{\"begin\": 3605, \"end\": 3611, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9986901719809552, \"rank\": 0.0013111476804398966, \"text\": \"French\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"Games\", \"from\": 3633, \"to\": 3638}, {\"ngram\": \"the time\", \"from\": 3674, \"to\": 3682}, {\"ngram\": \"retrospect\", \"from\": 3692, \"to\": 3702}, {\"ngram\": \"a hinge point\", \"from\": 3711, \"to\": 3724}, {\"ngram\": \"the Olympic movement\", \"from\": 3728, \"to\": 3748}]}, {\"sentence\": \"Pierre de Coubertin, father of the modern Games as the founder of the IOC, was also a proud Frenchman.\", \"from\": 3750, \"to\": 3852, \"entities\": [{\"begin\": 3750, \"end\": 3769, \"title\": \"http://dbpedia.org/resource/Pierre_de_Coubertin\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Pierre de Coubertin\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Pierre_de_Coubertin\", \"dbpedia\": \"http://dbpedia.org/resource/Pierre_de_Coubertin\"}, {\"begin\": 3820, \"end\": 3823, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 4.0207249124259653e-48, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"father\", \"from\": 3771, \"to\": 3777}, {\"ngram\": \"the modern Games\", \"from\": 3781, \"to\": 3797}, {\"ngram\": \"the founder\", \"from\": 3801, \"to\": 3812}, {\"ngram\": \"a proud Frenchman\", \"from\": 3834, \"to\": 3851}]}, {\"sentence\": \"And, in a benign prelude to sportswashing, he envisioned the 1924 Olympics as a way to show off Paris\\u00e2\\u0080\\u0099s beauty and innovation while also projecting France\\u00e2\\u0080\\u0099s robustness after World War I.\", \"from\": 3853, \"to\": 4043, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a benign prelude\", \"from\": 3861, \"to\": 3877}, {\"ngram\": \"sportswashing\", \"from\": 3881, \"to\": 3894}, {\"ngram\": \"the 1924 Olympics\", \"from\": 3910, \"to\": 3927}, {\"ngram\": \"a way\", \"from\": 3931, \"to\": 3936}, {\"ngram\": \"Paris\\u00e2\\u0080\\u0099s beauty\", \"from\": 3949, \"to\": 3965}, {\"ngram\": \"innovation\", \"from\": 3970, \"to\": 3980}, {\"ngram\": \"robustness\", \"from\": 4014, \"to\": 4024}, {\"ngram\": \"World War I.\", \"from\": 4031, \"to\": 4043}]}, {\"sentence\": \"An even century ago, the Paris Games featured the first elaborate parade-of-nations opening ceremony, held at the main venue, the Stadium of Colombes, in the northwestern suburbs.\", \"from\": 4045, \"to\": 4224, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the Paris Games\", \"from\": 4066, \"to\": 4081}, {\"ngram\": \"nations\", \"from\": 4121, \"to\": 4128}, {\"ngram\": \"the main venue\", \"from\": 4155, \"to\": 4169}, {\"ngram\": \"the Stadium\", \"from\": 4171, \"to\": 4182}, {\"ngram\": \"Colombes\", \"from\": 4186, \"to\": 4194}, {\"ngram\": \"the northwestern suburbs\", \"from\": 4199, \"to\": 4223}]}, {\"sentence\": \"There was a velodrome with stands designed by Gustave Eiffel (he of the eponymous tower), and the first athletes\\u00e2\\u0080\\u0099 village, where most of the 3,000-plus competitors stayed for the duration, enjoying the free hairdresser and catered meals, before returning home on trains and steamers.\", \"from\": 4225, \"to\": 4510, \"entities\": [{\"begin\": 4271, \"end\": 4285, \"title\": \"http://dbpedia.org/resource/Gustave_Eiffel\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Gustave Eiffel\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Gustave_Eiffel\", \"dbpedia\": \"http://dbpedia.org/resource/Gustave_Eiffel\"}], \"noun_phrases\": [{\"ngram\": \"a velodrome\", \"from\": 4235, \"to\": 4246}, {\"ngram\": \"stands\", \"from\": 4252, \"to\": 4258}, {\"ngram\": \"the eponymous tower\", \"from\": 4293, \"to\": 4312}, {\"ngram\": \"the first athletes\\u00e2\\u0080\\u0099 village\", \"from\": 4319, \"to\": 4348}, {\"ngram\": \"the 3,000-plus competitors\", \"from\": 4364, \"to\": 4390}, {\"ngram\": \"the duration\", \"from\": 4402, \"to\": 4414}, {\"ngram\": \"the free hairdresser\", \"from\": 4425, \"to\": 4445}, {\"ngram\": \"catered meals\", \"from\": 4450, \"to\": 4463}, {\"ngram\": \"trains\", \"from\": 4490, \"to\": 4496}, {\"ngram\": \"steamers\", \"from\": 4501, \"to\": 4509}]}, {\"sentence\": \"Though Coubertin liked to declare the Olympics \\u00e2\\u0080\\u009ca display of manly virtue,\\u00e2\\u0080\\u009d these Games were open to 135 female athletes in three events (swimming, diving and tennis), a notable, progressive increase from previous Olympiads.\", \"from\": 4511, \"to\": 4739, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Coubertin\", \"from\": 4518, \"to\": 4527}, {\"ngram\": \"the Olympics\", \"from\": 4545, \"to\": 4557}, {\"ngram\": \"manly virtue\", \"from\": 4574, \"to\": 4586}, {\"ngram\": \"these Games\", \"from\": 4591, \"to\": 4602}, {\"ngram\": \"135 female athletes\", \"from\": 4616, \"to\": 4635}, {\"ngram\": \"three events\", \"from\": 4639, \"to\": 4651}, {\"ngram\": \"swimming\", \"from\": 4653, \"to\": 4661}, {\"ngram\": \"diving\", \"from\": 4663, \"to\": 4669}, {\"ngram\": \"tennis\", \"from\": 4674, \"to\": 4680}, {\"ngram\": \"a notable, progressive increase\", \"from\": 4683, \"to\": 4714}, {\"ngram\": \"previous Olympiads\", \"from\": 4720, \"to\": 4738}]}, {\"sentence\": \"Assorted records were smashed in 1924, albeit in times that would not even make qualifying thresholds today.\", \"from\": 4741, \"to\": 4849, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Assorted records\", \"from\": 4741, \"to\": 4757}, {\"ngram\": \"times\", \"from\": 4790, \"to\": 4795}, {\"ngram\": \"qualifying thresholds\", \"from\": 4821, \"to\": 4842}]}, {\"sentence\": \"The heroes included \\u00e2\\u0080\\u009cFlying Finn\\u00e2\\u0080\\u009d Paavo Nurmi, who won gold in the 1,500 meters, and then, an hour later, in the 5,000.\", \"from\": 4850, \"to\": 4973, \"entities\": [{\"begin\": 4888, \"end\": 4899, \"title\": \"http://dbpedia.org/resource/Paavo_Nurmi\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Paavo Nurmi\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Paavo_Nurmi\", \"dbpedia\": \"http://dbpedia.org/resource/Paavo_Nurmi\"}], \"noun_phrases\": [{\"ngram\": \"The heroes\", \"from\": 4850, \"to\": 4860}, {\"ngram\": \"gold\", \"from\": 4909, \"to\": 4913}, {\"ngram\": \"the 1,500 meters\", \"from\": 4917, \"to\": 4933}]}, {\"sentence\": \"British runners Harold Abrahams and Eric Liddell, a Jew and a Protestant, won track golds, their unlikely feats memorialized in the filmChariots of Fire.\", \"from\": 4974, \"to\": 5127, \"entities\": [{\"begin\": 4974, \"end\": 4981, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9999105526465106, \"rank\": 8.945411425267016e-05, \"text\": \"British\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}, {\"begin\": 4990, \"end\": 5005, \"title\": \"http://dbpedia.org/resource/Harold_Abrahams\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Harold Abrahams\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Harold_Abrahams\", \"dbpedia\": \"http://dbpedia.org/resource/Harold_Abrahams\"}, {\"begin\": 5010, \"end\": 5022, \"title\": \"http://dbpedia.org/resource/Eric_Liddell\", \"score\": 1.0, \"rank\": 4.077761657506908e-58, \"text\": \"Eric Liddell\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Eric_Liddell\", \"dbpedia\": \"http://dbpedia.org/resource/Eric_Liddell\"}, {\"begin\": 5026, \"end\": 5029, \"title\": \"http://dbpedia.org/resource/Jews\", \"score\": 0.9999992832629527, \"rank\": 7.122632146585148e-07, \"text\": \"Jew\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Jews\", \"dbpedia\": \"http://dbpedia.org/resource/Jews\"}], \"noun_phrases\": [{\"ngram\": \"a Protestant\", \"from\": 5034, \"to\": 5046}, {\"ngram\": \"track golds\", \"from\": 5052, \"to\": 5063}, {\"ngram\": \"their unlikely feats\", \"from\": 5065, \"to\": 5085}, {\"ngram\": \"the filmChariots\", \"from\": 5102, \"to\": 5118}, {\"ngram\": \"Fire\", \"from\": 5122, \"to\": 5126}]}, {\"sentence\": \"Before becoming a Hollywood star portraying Tarzan, American swimmer Johnny Weissmuller won three golds in swimming and a bronze in water polo.\", \"from\": 5128, \"to\": 5271, \"entities\": [{\"begin\": 5146, \"end\": 5155, \"title\": \"http://dbpedia.org/resource/Cinema_of_the_United_States\", \"score\": 1.0, \"rank\": 2.3458116646965868e-20, \"text\": \"Hollywood\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Cinema_of_the_United_States\", \"dbpedia\": \"http://dbpedia.org/resource/Cinema_of_the_United_States\"}, {\"begin\": 5172, \"end\": 5178, \"title\": \"http://dbpedia.org/resource/Tarzan\", \"score\": 1.0, \"rank\": 1.0904161259055094e-20, \"text\": \"Tarzan\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Tarzan\", \"dbpedia\": \"http://dbpedia.org/resource/Tarzan\"}, {\"begin\": 5180, \"end\": 5188, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 1.0, \"rank\": 1.9541222844073788e-15, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 5197, \"end\": 5215, \"title\": \"http://dbpedia.org/resource/Johnny_Weissmuller\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Johnny Weissmuller\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Johnny_Weissmuller\", \"dbpedia\": \"http://dbpedia.org/resource/Johnny_Weissmuller\"}], \"noun_phrases\": [{\"ngram\": \"three golds\", \"from\": 5220, \"to\": 5231}, {\"ngram\": \"swimming\", \"from\": 5235, \"to\": 5243}, {\"ngram\": \"a bronze\", \"from\": 5248, \"to\": 5256}, {\"ngram\": \"water polo\", \"from\": 5260, \"to\": 5270}]}, {\"sentence\": \"In a battle between nostalgia and practicality, there will be only modest overlap between Paris 1924 and Paris 2024.\", \"from\": 5273, \"to\": 5389, \"entities\": [{\"begin\": 5378, \"end\": 5388, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.191112487718344e-50, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"a battle\", \"from\": 5276, \"to\": 5284}, {\"ngram\": \"nostalgia\", \"from\": 5293, \"to\": 5302}, {\"ngram\": \"practicality\", \"from\": 5307, \"to\": 5319}, {\"ngram\": \"only modest overlap\", \"from\": 5335, \"to\": 5354}, {\"ngram\": \"Paris\", \"from\": 5363, \"to\": 5368}]}, {\"sentence\": \"Both inside of France and outside to the IOC, one of the great selling points of the Paris bid was the abundance of preexisting venues, the few temporary structures being assembled now notwithstanding.\", \"from\": 5390, \"to\": 5591, \"entities\": [{\"begin\": 5405, \"end\": 5411, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 1.0, \"rank\": 2.944469643490759e-14, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 5431, \"end\": 5434, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 4.0207249124259653e-48, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 5475, \"end\": 5480, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 4.0547288765635774e-35, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"the great selling points\", \"from\": 5443, \"to\": 5467}, {\"ngram\": \"the abundance\", \"from\": 5489, \"to\": 5502}, {\"ngram\": \"preexisting venues\", \"from\": 5506, \"to\": 5524}, {\"ngram\": \"the few temporary structures\", \"from\": 5526, \"to\": 5554}]}, {\"sentence\": \"(With so many stadiums and arenas already built, the Paris 2024 overall budget of roughly $10 billion is a fifth of what the Russians spent on Sochi.)\", \"from\": 5592, \"to\": 5742, \"entities\": [{\"begin\": 5645, \"end\": 5655, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.191112487718344e-50, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 5717, \"end\": 5725, \"title\": \"http://dbpedia.org/resource/Soviet_Union\", \"score\": 0.9982461706025042, \"rank\": 0.001756908318834525, \"text\": \"Russians\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Soviet_Union\", \"dbpedia\": \"http://dbpedia.org/resource/Soviet_Union\"}, {\"begin\": 5735, \"end\": 5740, \"title\": \"http://dbpedia.org/resource/Sochi\", \"score\": 0.7874815028336234, \"rank\": 0.26987109716445146, \"text\": \"Sochi\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Sochi\", \"dbpedia\": \"http://dbpedia.org/resource/Sochi\"}], \"noun_phrases\": [{\"ngram\": \"so many stadiums\", \"from\": 5598, \"to\": 5614}, {\"ngram\": \"arenas\", \"from\": 5619, \"to\": 5625}]}, {\"sentence\": \"But only a few are older than a century.\", \"from\": 5743, \"to\": 5783, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a century\", \"from\": 5773, \"to\": 5782}]}, {\"sentence\": \"The stadium in Colombes, which hosted everything from track to soccer in 1924, was renamed the Stade Yves-du-Manoir shortly after those Games and was recently renovated to host field hockey this summer.\", \"from\": 5784, \"to\": 5986, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The stadium\", \"from\": 5784, \"to\": 5795}, {\"ngram\": \"Colombes\", \"from\": 5799, \"to\": 5807}, {\"ngram\": \"everything\", \"from\": 5822, \"to\": 5832}, {\"ngram\": \"track\", \"from\": 5838, \"to\": 5843}, {\"ngram\": \"soccer\", \"from\": 5847, \"to\": 5853}, {\"ngram\": \"the Stade Yves\", \"from\": 5875, \"to\": 5889}, {\"ngram\": \"du\", \"from\": 5890, \"to\": 5892}, {\"ngram\": \"Manoir\", \"from\": 5893, \"to\": 5899}, {\"ngram\": \"those Games\", \"from\": 5914, \"to\": 5925}, {\"ngram\": \"host field hockey\", \"from\": 5956, \"to\": 5973}]}, {\"sentence\": \"The Tourelle Pool, grandiose when it was inaugurated that summer a century ago as the first dedicated Olympic aquatic facility, will be used only as a practice pool.\", \"from\": 5987, \"to\": 6152, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The Tourelle Pool\", \"from\": 5987, \"to\": 6004}, {\"ngram\": \"summer\", \"from\": 6045, \"to\": 6051}, {\"ngram\": \"the first dedicated Olympic aquatic facility\", \"from\": 6069, \"to\": 6113}, {\"ngram\": \"a practice pool\", \"from\": 6136, \"to\": 6151}]}, {\"sentence\": \"In addition to the athletes\\u00e2\\u0080\\u0099 village, only two new, permanent venues were constructed for these Games\\u00e2\\u0080\\u0094the Aquatics Centre in Saint-Denis and the Le Bourget Climbing Venue.\", \"from\": 6153, \"to\": 6328, \"entities\": [{\"begin\": 6282, \"end\": 6293, \"title\": \"http://dbpedia.org/resource/Stade_de_France\", \"score\": 0.9980515562694063, \"rank\": 0.0019021635193432064, \"text\": \"Saint-Denis\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Stade_de_France\", \"dbpedia\": \"http://dbpedia.org/resource/Stade_de_France\"}, {\"begin\": 6302, \"end\": 6312, \"title\": \"http://dbpedia.org/resource/Le_Bourget\", \"score\": 0.9988534419765545, \"rank\": 0.0011478741278856607, \"text\": \"Le Bourget\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Le_Bourget\", \"dbpedia\": \"http://dbpedia.org/resource/Le_Bourget\"}], \"noun_phrases\": [{\"ngram\": \"addition\", \"from\": 6156, \"to\": 6164}, {\"ngram\": \"the athletes\\u00e2\\u0080\\u0099 village\", \"from\": 6168, \"to\": 6191}, {\"ngram\": \"only two new, permanent venues\", \"from\": 6193, \"to\": 6223}, {\"ngram\": \"these Games\\u00e2\\u0080\\u0094the Aquatics Centre\", \"from\": 6245, \"to\": 6278}]}, {\"sentence\": \"Organizers are also hopeful the Seine will play a much different role in 2024 than it did 100 years ago.\", \"from\": 6330, \"to\": 6434, \"entities\": [{\"begin\": 6362, \"end\": 6367, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 1.0, \"rank\": 1.618495409143208e-26, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"Organizers\", \"from\": 6330, \"to\": 6340}, {\"ngram\": \"a much different role\", \"from\": 6378, \"to\": 6399}]}, {\"sentence\": \"Before the 1924 Games, there was talk of holding some swimming and rowing events in the serpentine river that wraps itself around the city.\", \"from\": 6435, \"to\": 6574, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the 1924 Games\", \"from\": 6442, \"to\": 6456}, {\"ngram\": \"talk\", \"from\": 6468, \"to\": 6472}, {\"ngram\": \"some swimming and rowing events\", \"from\": 6484, \"to\": 6515}, {\"ngram\": \"the serpentine river\", \"from\": 6519, \"to\": 6539}, {\"ngram\": \"the city\", \"from\": 6565, \"to\": 6573}]}, {\"sentence\": \"But in 1923, French authorities banned public swimming in the river due to its pollution.\", \"from\": 6575, \"to\": 6664, \"entities\": [{\"begin\": 6588, \"end\": 6594, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9986901719809552, \"rank\": 0.0013111476804398966, \"text\": \"French\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"public swimming\", \"from\": 6614, \"to\": 6629}, {\"ngram\": \"the river\", \"from\": 6633, \"to\": 6642}, {\"ngram\": \"its pollution\", \"from\": 6650, \"to\": 6663}]}, {\"sentence\": \"Even rowing was held at the Argenteuil Basin, located northwest of Paris on the banks of the Seine.\\u00c2 Like an athlete listed as day-to-day, the Seine\\u00e2\\u0080\\u0099s status for 2024 remains uncertain.\", \"from\": 6665, \"to\": 6853, \"entities\": [{\"begin\": 6732, \"end\": 6737, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 4.0547288765635774e-35, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"the Argenteuil Basin\", \"from\": 6689, \"to\": 6709}, {\"ngram\": \"northwest\", \"from\": 6719, \"to\": 6728}, {\"ngram\": \"the banks\", \"from\": 6741, \"to\": 6750}, {\"ngram\": \"the Seine\", \"from\": 6754, \"to\": 6763}, {\"ngram\": \"an athlete\", \"from\": 6771, \"to\": 6781}, {\"ngram\": \"day\", \"from\": 6792, \"to\": 6795}, {\"ngram\": \"day\", \"from\": 6799, \"to\": 6802}, {\"ngram\": \"the Seine\\u00e2\\u0080\\u0099s status\", \"from\": 6804, \"to\": 6824}]}, {\"sentence\": \"When Paris\\u00e2\\u0080\\u0099s initial hosting bid was prepared, one of the big selling points for winning over the locals was that the Olympics would provide the catalyst\\u00e2\\u0080\\u0094and funding\\u00e2\\u0080\\u0094for cleaning up the river, even making it swimmable for the public during summer months.\", \"from\": 6854, \"to\": 7114, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Paris\\u00e2\\u0080\\u0099s initial hosting bid\", \"from\": 6859, \"to\": 6888}, {\"ngram\": \"the big selling points\", \"from\": 6910, \"to\": 6932}, {\"ngram\": \"the locals\", \"from\": 6950, \"to\": 6960}, {\"ngram\": \"the Olympics\", \"from\": 6970, \"to\": 6982}, {\"ngram\": \"the catalyst\\u00e2\\u0080\\u0094and\", \"from\": 6997, \"to\": 7015}, {\"ngram\": \"the river\", \"from\": 7042, \"to\": 7051}, {\"ngram\": \"the public\", \"from\": 7082, \"to\": 7092}, {\"ngram\": \"summer months\", \"from\": 7100, \"to\": 7113}]}, {\"sentence\": \"Roughly $1.5 billion has been invested in a filtration system, rainwater storage tanks and the extraction of bikes and scooters from the river bottom.\", \"from\": 7115, \"to\": 7265, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a filtration system\", \"from\": 7157, \"to\": 7176}, {\"ngram\": \"rainwater storage tanks\", \"from\": 7178, \"to\": 7201}, {\"ngram\": \"the extraction\", \"from\": 7206, \"to\": 7220}, {\"ngram\": \"bikes\", \"from\": 7224, \"to\": 7229}, {\"ngram\": \"scooters\", \"from\": 7234, \"to\": 7242}, {\"ngram\": \"the river bottom\", \"from\": 7248, \"to\": 7264}]}, {\"sentence\": \"The opening ceremony would, for the first time in modern Olympic history, move out of a conventional stadium and be staged flotilla-style along the river.\", \"from\": 7267, \"to\": 7421, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The opening ceremony\", \"from\": 7267, \"to\": 7287}, {\"ngram\": \"the first time\", \"from\": 7299, \"to\": 7313}, {\"ngram\": \"modern Olympic history\", \"from\": 7317, \"to\": 7339}, {\"ngram\": \"a conventional stadium\", \"from\": 7353, \"to\": 7375}, {\"ngram\": \"flotilla-style\", \"from\": 7390, \"to\": 7404}, {\"ngram\": \"the river\", \"from\": 7411, \"to\": 7420}]}, {\"sentence\": \"More than 600,000 fans\\u00e2\\u0080\\u0094roughly the entire attendance of the 1924 Games, eight times the capacity of any Parisian stadium\\u00e2\\u0080\\u0094would line the embankments for six kilometers to watch.\", \"from\": 7422, \"to\": 7602, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"More than 600,000 fans\\u00e2\\u0080\\u0094roughly the entire attendance\", \"from\": 7422, \"to\": 7476}, {\"ngram\": \"the 1924 Games\", \"from\": 7480, \"to\": 7494}, {\"ngram\": \"eight times\", \"from\": 7496, \"to\": 7507}, {\"ngram\": \"the capacity\", \"from\": 7508, \"to\": 7520}, {\"ngram\": \"the embankments\", \"from\": 7558, \"to\": 7573}, {\"ngram\": \"six kilometers\", \"from\": 7578, \"to\": 7592}]}, {\"sentence\": \"Those ambitions have been scaled back considerably.\", \"from\": 7604, \"to\": 7655, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Those ambitions\", \"from\": 7604, \"to\": 7619}]}, {\"sentence\": \"Owing to security concerns and expenses, the crowd of 600,000 for the opening ceremony has been pared down to 325,000\\u00e2\\u0080\\u0094about 105,000 paid and 220,000 given free tickets via lottery.\", \"from\": 7656, \"to\": 7838, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"security concerns\", \"from\": 7665, \"to\": 7682}, {\"ngram\": \"expenses\", \"from\": 7687, \"to\": 7695}, {\"ngram\": \"the crowd\", \"from\": 7697, \"to\": 7706}, {\"ngram\": \"the opening ceremony\", \"from\": 7722, \"to\": 7742}, {\"ngram\": \"free tickets\", \"from\": 7813, \"to\": 7825}, {\"ngram\": \"lottery\", \"from\": 7830, \"to\": 7837}]}, {\"sentence\": \"In the spring, there were talks of a Plan B, a literal course correction, whereby the ceremony ends up at the Trocad\\u00c3\\u00a9ro or in the main stadium, the Stade de France in Saint-Denis.\", \"from\": 7839, \"to\": 8019, \"entities\": [{\"begin\": 8007, \"end\": 8018, \"title\": \"http://dbpedia.org/resource/Stade_de_France\", \"score\": 0.9980515562694063, \"rank\": 0.0019021635193432064, \"text\": \"Saint-Denis\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Stade_de_France\", \"dbpedia\": \"http://dbpedia.org/resource/Stade_de_France\"}], \"noun_phrases\": [{\"ngram\": \"the spring\", \"from\": 7842, \"to\": 7852}, {\"ngram\": \"talks\", \"from\": 7865, \"to\": 7870}, {\"ngram\": \"a Plan B\", \"from\": 7874, \"to\": 7882}, {\"ngram\": \"a literal course correction\", \"from\": 7884, \"to\": 7911}, {\"ngram\": \"the ceremony\", \"from\": 7921, \"to\": 7933}, {\"ngram\": \"the Trocad\\u00c3\\u00a9ro\", \"from\": 7945, \"to\": 7959}, {\"ngram\": \"the main stadium\", \"from\": 7966, \"to\": 7982}, {\"ngram\": \"the Stade de France\", \"from\": 7984, \"to\": 8003}]}, {\"sentence\": \"(In fairness, the bid was prepared before the wars in Ukraine and Gaza.)\", \"from\": 8020, \"to\": 8092, \"entities\": [{\"begin\": 8074, \"end\": 8081, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 0.999999974299499, \"rank\": 2.5698869816189485e-08, \"text\": \"Ukraine\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Ukraine\"}, {\"begin\": 8086, \"end\": 8090, \"title\": \"http://dbpedia.org/resource/Gaza_Strip\", \"score\": 0.9420670731244171, \"rank\": 0.0614955437129723, \"text\": \"Gaza\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Gaza_Strip\", \"dbpedia\": \"http://dbpedia.org/resource/Gaza_Strip\"}], \"noun_phrases\": [{\"ngram\": \"fairness\", \"from\": 8024, \"to\": 8032}, {\"ngram\": \"the bid\", \"from\": 8034, \"to\": 8041}, {\"ngram\": \"the wars\", \"from\": 8062, \"to\": 8070}]}, {\"sentence\": \"What\\u00e2\\u0080\\u0099s more, the contaminants that have tainted the river for more than a century have proven stubborn to remove.\\u00c2 With the Games fast approaching, French officials were feeling \\u00e2\\u0080\\u009cvery confident\\u00e2\\u0080\\u009d after unveiling an underground reservoir near the city\\u00e2\\u0080\\u0099s Gare d\\u00e2\\u0080\\u0099Austerlitz station that can collect as much as 20 Olympic-size swimming pools\\u00e2\\u0080\\u0099 worth of rain and wastewater, as a way of preventing sewage from overflowing into the river.\\u00c2 No matter La Seine\\u00e2\\u0080\\u0099s status, Paris as host of this summer\\u00e2\\u0080\\u0099s Olympics is likely to be music to the ears of many.\", \"from\": 8093, \"to\": 8654, \"entities\": [{\"begin\": 8244, \"end\": 8250, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9986901719809552, \"rank\": 0.0013111476804398966, \"text\": \"French\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 8354, \"end\": 8358, \"title\": \"http://dbpedia.org/resource/Train_station\", \"score\": 1.0, \"rank\": 5.798511685085478e-31, \"text\": \"Gare\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Train_station\", \"dbpedia\": \"http://dbpedia.org/resource/Train_station\"}, {\"begin\": 8363, \"end\": 8373, \"title\": \"http://dbpedia.org/resource/Gare_d'Austerlitz\", \"score\": 0.925303257576645, \"rank\": 0.080726769098722, \"text\": \"Austerlitz\", \"types\": [\"Q719456\"], \"wikid\": \"http://dbpedia.org/resource/Gare_d'Austerlitz\", \"dbpedia\": \"http://dbpedia.org/resource/Gare_d'Austerlitz\"}], \"noun_phrases\": [{\"ngram\": \"the contaminants\", \"from\": 8108, \"to\": 8124}, {\"ngram\": \"the river\", \"from\": 8143, \"to\": 8152}, {\"ngram\": \"more than a century\", \"from\": 8157, \"to\": 8176}, {\"ngram\": \"the Games\", \"from\": 8215, \"to\": 8224}, {\"ngram\": \"\\u00e2\\u0080\\u009cvery confident\\u00e2\\u0080\\u009d\", \"from\": 8273, \"to\": 8293}, {\"ngram\": \"an underground reservoir\", \"from\": 8310, \"to\": 8334}, {\"ngram\": \"as much as 20 Olympic-size swimming pools\\u00e2\\u0080\\u0099 worth\", \"from\": 8398, \"to\": 8448}, {\"ngram\": \"rain\", \"from\": 8452, \"to\": 8456}, {\"ngram\": \"wastewater\", \"from\": 8461, \"to\": 8471}, {\"ngram\": \"a way\", \"from\": 8476, \"to\": 8481}, {\"ngram\": \"sewage\", \"from\": 8496, \"to\": 8502}, {\"ngram\": \"the river\", \"from\": 8525, \"to\": 8534}, {\"ngram\": \"\\u00c2\", \"from\": 8535, \"to\": 8536}, {\"ngram\": \"No matter La Seine\\u00e2\\u0080\\u0099s status\", \"from\": 8537, \"to\": 8566}, {\"ngram\": \"host\", \"from\": 8577, \"to\": 8581}, {\"ngram\": \"Olympics\", \"from\": 8601, \"to\": 8609}, {\"ngram\": \"music\", \"from\": 8626, \"to\": 8631}, {\"ngram\": \"the ears\", \"from\": 8635, \"to\": 8643}]}, {\"sentence\": \"Loading recommendations...\", \"from\": 8656, \"to\": 8682, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Loading recommendations\", \"from\": 8656, \"to\": 8679}]}, {\"sentence\": \"Please wait while we load personalized content recommendations Jon Wertheim is a senior writer for Sports Illustrated and has been part of the full-time SI writing staff since 1997, largely focusing on the tennis beat, sports business and social issues, and enterprise journalism.\", \"from\": 8683, \"to\": 8964, \"entities\": [{\"begin\": 8747, \"end\": 8759, \"title\": \"http://dbpedia.org/resource/Jon_Wertheim\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Jon Wertheim\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Jon_Wertheim\", \"dbpedia\": \"http://dbpedia.org/resource/Jon_Wertheim\"}, {\"begin\": 8783, \"end\": 8801, \"title\": \"http://dbpedia.org/resource/Sports_Illustrated\", \"score\": 1.0, \"rank\": 3.176127727435574e-31, \"text\": \"Sports Illustrated\", \"types\": [\"Q41298\", \"Q386724\", \"Q234460\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/Sports_Illustrated\", \"dbpedia\": \"http://dbpedia.org/resource/Sports_Illustrated\"}], \"noun_phrases\": [{\"ngram\": \"personalized content recommendations\", \"from\": 8709, \"to\": 8745}, {\"ngram\": \"a senior writer\", \"from\": 8762, \"to\": 8777}, {\"ngram\": \"part\", \"from\": 8814, \"to\": 8818}, {\"ngram\": \"the full-time SI writing staff\", \"from\": 8822, \"to\": 8852}, {\"ngram\": \"the tennis beat\", \"from\": 8885, \"to\": 8900}, {\"ngram\": \"sports business\", \"from\": 8902, \"to\": 8917}, {\"ngram\": \"social issues\", \"from\": 8922, \"to\": 8935}, {\"ngram\": \"enterprise journalism\", \"from\": 8941, \"to\": 8962}]}, {\"sentence\": \"In addition to his work at SI, he is a correspondent for \\u00e2\\u0080\\u009c60 Minutes\\u00e2\\u0080\\u009d and a commentator for The Tennis Channel.\", \"from\": 8965, \"to\": 9080, \"entities\": [], \"noun_phrases\": [{\"n