"{\"uid\": \"jamaicaobserver.com-2024-07-24-olympic-doping-agency-says-90-paris-entrants-tested-2024\", \"noun_phrases\": [{\"sentence\": \"PARIS, France (AFP)- Nearly 90 per cent of all entrants in the Paris Olympics have been tested this year as part of a pre-Games anti-doping program, the International Testing Agency (ITA) said on Wednesday.\", \"from\": 0, \"to\": 206, \"entities\": [{\"begin\": 7, \"end\": 13, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9845018153749283, \"rank\": 0.005658290844428583, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 153, \"end\": 181, \"title\": \"http://dbpedia.org/resource/International_Testing_Agency\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Testing Agency\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Testing_Agency\", \"dbpedia\": \"http://dbpedia.org/resource/International_Testing_Agency\"}, {\"begin\": 183, \"end\": 186, \"title\": \"http://dbpedia.org/resource/Italy\", \"score\": 0.5376527411614767, \"rank\": 0.8314357384551827, \"text\": \"ITA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Italy\", \"dbpedia\": \"http://dbpedia.org/resource/Italy\"}], \"noun_phrases\": [{\"ngram\": \"PARIS\", \"from\": 0, \"to\": 5}, {\"ngram\": \"Nearly 90 per cent\", \"from\": 21, \"to\": 39}, {\"ngram\": \"all entrants\", \"from\": 43, \"to\": 55}, {\"ngram\": \"the Paris Olympics\", \"from\": 59, \"to\": 77}, {\"ngram\": \"part\", \"from\": 108, \"to\": 112}, {\"ngram\": \"a pre-Games anti-doping program\", \"from\": 116, \"to\": 147}, {\"ngram\": \"Wednesday\", \"from\": 196, \"to\": 205}]}, {\"sentence\": \"ITA said it had conducted more than 32,600 doping controls this year, an increase of around 45 per cent on tests of athletes in the previous six months.\", \"from\": 208, \"to\": 360, \"entities\": [{\"beg