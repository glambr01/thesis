: [], \"noun_phrases\": [{\"ngram\": \"Snoop\", \"from\": 16263, \"to\": 16268}, {\"ngram\": \"every team\", \"from\": 16275, \"to\": 16285}, {\"ngram\": \"an international player\", \"from\": 16290, \"to\": 16313}, {\"ngram\": \"their roster\", \"from\": 16317, \"to\": 16329}]}, {\"sentence\": \"Most of them are significant contributors.\", \"from\": 16331, \"to\": 16373, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"significant contributors\", \"from\": 16348, \"to\": 16372}]}, {\"sentence\": \"You look at the Canadian roster, they are very good.\", \"from\": 16374, \"to\": 16426, \"entities\": [{\"begin\": 16390, \"end\": 16405, \"title\": \"http://dbpedia.org/resource/Canada_men's_national_ice_hockey_team\", \"score\": 0.9999994949222494, \"rank\": 5.025342831401853e-07, \"text\": \"Canadian roster\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Canada_men's_national_ice_hockey_team\", \"dbpedia\": \"http://dbpedia.org/resource/Canada_men's_national_ice_hockey_team\"}], \"noun_phrases\": []}, {\"sentence\": \"To your point, I am sure basketball will tell its own story in terms of ratings and everyone watching, but no guaranteed big victory part of this is something that will keep everyone watching when Team USA plays in men's basketball.\", \"from\": 16428, \"to\": 16660, \"entities\": [{\"begin\": 16625, \"end\": 16633, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 0.6056732451816427, \"rank\": 0.581056905764099, \"text\": \"Team USA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\"}], \"noun_phrases\": [{\"ngram\": \"your point\", \"from\": 16431, \"to\": 16441}, {\"ngram\": \"basketball\", \"from\": 16453, \"to\": 16463}, {\"ngram\": \"its own story\", \"from\": 16474, \"to\": 16487}, {\"ngram\": \"terms\", \"from\": 16491, \"to\": 16496}, {\"ngram\": \"ratings\", \"from\": 16500, \"to\": 16507}, {\"ngram\": \"everyone\", \"from\": 16512, \"to\": 16520}, {\"ngram\": \"no guaranteed big victory part\", \"from\": 16535, \"to\": 16565}, {\"ngram\": \"something\", \"from\": 16577, \"to\": 16586}, {\"ngram\": \"everyone\", \"from\": 16602, \"to\": 16610}, {\"ngram\": \"men's basketball\", \"from\": 16643, \"to\": 16659}]}, {\"sentence\": \"SNOOP DOGG: One thing about a gold medal, you have got to earn it.\", \"from\": 16662, \"to\": 16728, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a gold medal\", \"from\": 16690, \"to\": 16702}]}, {\"sentence\": \"They do not give you those.\", \"from\": 16729, \"to\": 16756, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I tried to get one, they would not give it to me.\", \"from\": 16757, \"to\": 16806, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Q.This question is for Snoop.\", \"from\": 16808, \"to\": 16837, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Q.This question\", \"from\": 16808, \"to\": 16823}, {\"ngram\": \"Snoop\", \"from\": 16831, \"to\": 16836}]}, {\"sentence\": \"I might be asking something that might have been asked already, but I was wondering, I spoke with you a few months ago before your junket for Underdog, and I remember I asked you about representation for the Olympics.\", \"from\": 16838, \"to\": 17055, \"entities\": [{\"begin\": 16980, \"end\": 16988, \"title\": \"http://dbpedia.org/resource/Underdog\", \"score\": 0.9999999999999432, \"rank\": 6.466261891518248e-14, \"text\": \"Underdog\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Underdog\", \"dbpedia\": \"http://dbpedia.org/resource/Underdog\"}], \"noun_phrases\": [{\"ngram\": \"something\", \"from\": 16856, \"to\": 16865}, {\"ngram\": \"your junket\", \"from\": 16964, \"to\": 16975}, {\"ngram\": \"representation\", \"from\": 17023, \"to\": 17037}, {\"ngram\": \"the Olympics\", \"from\": 17042, \"to\": 17054}]}, {\"sentence\": \"I am wondering, with you being the torch bearer, what does that mean for you when it comes to representation, and what does it mean for you to really -- to be out there in the forefront for the United States and being the face for it?\", \"from\": 17056, \"to\": 17290, \"entities\": [{\"begin\": 17250, \"end\": 17263, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9294358135116323, \"rank\": 0.04613169720941283, \"text\": \"United States\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"the torch bearer\", \"from\": 17087, \"to\": 17103}, {\"ngram\": \"representation\", \"from\": 17150, \"to\": 17164}, {\"ngram\": \"the forefront\", \"from\": 17228, \"to\": 17241}, {\"ngram\": \"the face\", \"from\": 17274, \"to\": 17282}]}, {\"sentence\": \"SNOOP DOGG: First of all, what's crackalackin'?\", \"from\": 17292, \"to\": 17339, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"crackalackin\", \"from\": 17325, \"to\": 17337}]}, {\"sentence\": \"It says a whole lot about America, man, about as far as where we are at in this world, like what do we want to present?\", \"from\": 17340, \"to\": 17459, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a whole lot\", \"from\": 17348, \"to\": 17359}, {\"ngram\": \"America\", \"from\": 17366, \"to\": 17373}, {\"ngram\": \"man\", \"from\": 17375, \"to\": 17378}, {\"ngram\": \"this world\", \"from\": 17415, \"to\": 17425}]}, {\"sentence\": \"And then at the same time, it says a lot about France as far as connecting the dots and allowing me to do it.\", \"from\": 17460, \"to\": 17569, \"entities\": [{\"begin\": 17507, \"end\": 17513, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.99898215658343, \"rank\": 0.00042398101690056773, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"n