.org/resource/London\", \"score\": 0.998840235994232, \"rank\": 0.00045664104965826484, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}, {\"begin\": 4924, \"end\": 4933, \"title\": \"http://dbpedia.org/resource/Barcelona\", \"score\": 0.9642980502811818, \"rank\": 0.03619467487235594, \"text\": \"Barcelona\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Barcelona\", \"dbpedia\": \"http://dbpedia.org/resource/Barcelona\"}], \"noun_phrases\": [{\"ngram\": \"some Games\", \"from\": 4820, \"to\": 4830}, {\"ngram\": \"the host city\", \"from\": 4954, \"to\": 4967}, {\"ngram\": \"the co\", \"from\": 4979, \"to\": 4985}, {\"ngram\": \"star\", \"from\": 4986, \"to\": 4990}]}, {\"sentence\": \"That's where we are elevating Paris, back to that point, and we just can not wait.\", \"from\": 4992, \"to\": 5074, \"entities\": [{\"begin\": 5022, \"end\": 5027, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999982448342039, \"rank\": 1.7551965508022133e-05, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"that point\", \"from\": 5037, \"to\": 5047}]}, {\"sentence\": \"This job is everything I hoped for in 2019, and I just can not wait for the audience to experience what NBC Olympics has planned.\", \"from\": 5076, \"to\": 5205, \"entities\": [{\"begin\": 5180, \"end\": 5192, \"title\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"NBC Olympics\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\"}], \"noun_phrases\": [{\"ngram\": \"This job\", \"from\": 5076, \"to\": 5084}, {\"ngram\": \"everything\", \"from\": 5088, \