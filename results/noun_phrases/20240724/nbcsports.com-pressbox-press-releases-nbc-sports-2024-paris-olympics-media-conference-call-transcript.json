"{\"uid\": \"nbcsports.com-pressbox-press-releases-nbc-sports-2024-paris-olympics-media-conference-call-transcript\", \"noun_phrases\": [{\"sentence\": \"NBC SPORTS 2024 PARIS OLYMPICS MEDIA CONFERENCE CALL TRANSCRIPT Wednesday, July 24, 2024 MODERATOR: Thank you.\", \"from\": 0, \"to\": 112, \"entities\": [{\"begin\": 0, \"end\": 10, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.998872658120767, \"rank\": 0.0006668537675577213, \"text\": \"NBC SPORTS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}], \"noun_phrases\": [{\"ngram\": \"PARIS OLYMPICS MEDIA CONFERENCE CALL TRANSCRIPT\", \"from\": 16, \"to\": 63}, {\"ngram\": \"July\", \"from\": 75, \"to\": 79}, {\"ngram\": \"2024 MODERATOR\", \"from\": 84, \"to\": 98}]}, {\"sentence\": \"Depending upon where you are, good morning, good afternoon, and good evening, and thank you for joining us today.\", \"from\": 113, \"to\": 226, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"us\", \"from\": 217, \"to\": 219}]}, {\"sentence\": \"In a moment, we will hear from our three speakers, NBC Olympics and Paralympics executive producer Molly Solomon, our prime time in Paris and daytime host Mike Tirico, and our prime-time correspondent, Snoop Dogg.\", \"from\": 227, \"to\": 440, \"entities\": [{\"begin\": 278, \"end\": 290, \"title\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"NBC Olympics\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\"}, {\"begin\": 326, \"end\": 331, \"title\": \"http://dbpedia.org/resource/Molly_Hayes\", \"score\": 0.9624638830284854, \"rank\": 0.03899894384530974, \"text\": \"Molly\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Molly_Hayes\", \"dbpedia\": \"http://dbpedia.org/resource/Molly_Hayes\"}, {\"begin\": 359, \"end\": 364, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999988891226426, \"rank\": 1.1108786120302873e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 382, \"end\": 393, \"title\": \"http://dbpedia.org/resource/Mike_Tirico\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Mike Tirico\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Mike_Tirico\", \"dbpedia\": \"http://dbpedia.org/resource/Mike_Tirico\"}, {\"begin\": 429, \"end\": 439, \"title\": \"http://dbpedia.org/resource/Snoop_Dogg\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Snoop Dogg\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Snoop_Dogg\", \"dbpedia\": \"http://dbpedia.org/resource/Snoop_Dogg\"}], \"noun_phrases\": [{\"ngram\": \"a moment\", \"from\": 230, \"to\": 238}, {\"ngram\": \"our three speakers\", \"from\": 258, \"to\": 276}, {\"ngram\": \"our prime time\", \"from\": 341, \"to\": 355}, {\"ngram\": \"our prime-time correspondent\", \"from\": 399, \"to\": 427}]}, {\"sentence\": \"Molly will make opening remarks, and then we will open it up for questions.\", \"from\": 442, \"to\": 517, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"opening remarks\", \"from\": 458, \"to\": 473}, {\"ngram\": \"questions\", \"from\": 507, \"to\": 516}]}, {\"sentence\": \"Now I will turn it over to Molly Solomon.\", \"from\": 518, \"to\": 559, \"entities\": [{\"begin\": 545, \"end\": 550, \"title\": \"http://dbpedia.org/resource/Molly_Hayes\", \"score\": 0.9624638830284854, \"rank\": 0.03899894384530974, \"text\": \"Molly\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Molly_Hayes\", \"dbpedia\": \"http://dbpedia.org/resource/Molly_Hayes\"}], \"noun_phrases\": []}, {\"sentence\": \"MOLLY SOLOMON: Thanks, Chris.\", \"from\": 561, \"to\": 590, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"MOLLY SOLOMON\", \"from\": 561, \"to\": 574}, {\"ngram\": \"Thanks\", \"from\": 576, \"to\": 582}]}, {\"sentence\": \"Hello from Paris.\", \"from\": 591, \"to\": 608, \"entities\": [{\"begin\": 602, \"end\": 607, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999988891226426, \"rank\": 1.1108786120302873e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": []}, {\"sentence\": \"After years of planning, it's just so amazing to think that the Opening Ceremony is just two days away and that the Olympic competition is actually already happening right now.\", \"from\": 609, \"to\": 785, \"entities\": [{\"begin\": 673, \"end\": 689, \"title\": \"http://dbpedia.org/resource/Olympic_Games_ceremony\", \"score\": 0.9685977326399653, \"rank\": 0.03201837747202212, \"text\": \"Opening Ceremony\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games_ceremony\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games_ceremony\"}], \"noun_phrases\": [{\"ngram\": \"years\", \"from\": 615, \"to\": 620}, {\"ngram\": \"planning\", \"from\": 624, \"to\": 632}, {\"ngram\": \"the Olympic competition\", \"from\": 721, \"to\": 744}]}, {\"sentence\": \"Mike Tirico, who is here with us, took us on the air two hours ago on USA Network and Peacock, and we welcomed viewers to really what promises to be one of the most spectacular Olympic Games ever, and we are here to showcase all of it for the American audience with more than 7,000 hours of coverage.\", \"from\": 787, \"to\": 1087, \"entities\": [{\"begin\": 787, \"end\": 798, \"title\": \"http://dbpedia.org/resource/Mike_Tirico\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Mike Tirico\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Mike_Tirico\", \"dbpedia\": \"http://dbpedia.org/resource/Mike_Tirico\"}, {\"begin\": 857, \"end\": 868, \"title\": \"http://dbpedia.org/resource/USA_Network\", \"score\": 0.55699160869125, \"rank\": 0.7953591825098848, \"text\": \"USA Network\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/USA_Network\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Network\"}, {\"begin\": 873, \"end\": 880, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.9997484822474999, \"rank\": 0.00025157946854395834, \"text\": \"Peacock\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Peafowl\", \"dbpedia\": \"http://dbpedia.org/resource/Peafowl\"}, {\"begin\": 1030, \"end\": 1038, \"title\": \"http://dbpedia.org/resource/Television_in_the_United_States\", \"score\": 0.9999831133492485, \"rank\": 1.6886267631110396e-05, \"text\": \"American\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Television_in_the_United_States\", \"dbpedia\": \"http://dbpedia.org/resource/Television_in_the_United_States\"}], \"noun_phrases\": [{\"ngram\": \"us\", \"from\": 817, \"to\": 819}, {\"ngram\": \"us\", \"from\": 826, \"to\": 828}, {\"ngram\": \"the air\", \"from\": 832, \"to\": 839}, {\"ngram\": \"viewers\", \"from\": 898, \"to\": 905}, {\"ngram\": \"the most spectacular Olympic Games\", \"from\": 943, \"to\": 977}, {\"ngram\": \"more than 7,000 hours\", \"from\": 1053, \"to\": 1074}, {\"ngram\": \"coverage\", \"from\": 1078, \"to\": 1086}]}, {\"sentence\": \"As we have been saying for more than a year, all the best content will be live across the country on NBC in daytime, and we are re-imagining the prime-time show to provide the in-depth storytelling about the best events of the day, and Peacock has everything, all 329 medal events, plus replays and all the original programming we have been talking about and so much more.\", \"from\": 1089, \"to\": 1461, \"entities\": [{\"begin\": 1190, \"end\": 1193, \"title\": \"http://dbpedia.org/resource/NBC\", \"score\": 0.9986860936791093, \"rank\": 0.0012488547706709136, \"text\": \"NBC\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/NBC\", \"dbpedia\": \"http://dbpedia.org/resource/NBC\"}, {\"begin\": 1325, \"end\": 1332, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.9891517422902012, \"rank\": 0.010965650888292202, \"text\": \"Peacock\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Peafowl\", \"dbpedia\": \"http://dbpedia.org/resource/Peafowl\"}], \"noun_phrases\": [{\"ngram\": \"more than a year\", \"from\": 1116, \"to\": 1132}, {\"ngram\": \"all the best content\", \"from\": 1134, \"to\": 1154}, {\"ngram\": \"the country\", \"from\": 1175, \"to\": 1186}, {\"ngram\": \"daytime\", \"from\": 1197, \"to\": 1204}, {\"ngram\": \"the prime-time show\", \"from\": 1230, \"to\": 1249}, {\"ngram\": \"the in-depth storytelling\", \"from\": 1261, \"to\": 1286}, {\"ngram\": \"the best events\", \"from\": 1293, \"to\": 1308}, {\"ngram\": \"the day\", \"from\": 1312, \"to\": 1319}, {\"ngram\": \"everything\", \"from\": 1337, \"to\": 1347}, {\"ngram\": \"all 329 medal events\", \"from\": 1349, \"to\": 1369}, {\"ngram\": \"replays\", \"from\": 1376, \"to\": 1383}, {\"ngram\": \"all the original programming\", \"from\": 1388, \"to\": 1416}]}, {\"sentence\": \"As we have also said, we have taken a [very] different approach to these Games by bringing in some nontraditional voices with expert communicators to provide their perspective on Paris 2024: Kelly Clarkson and Peyton Manning on the Opening Ceremony, Jimmy Fallon on the closing, watch parties with podcaster Alex Cooper, and the most comprehensive whip-around show ever in Olympic history with \\\"Gold Zone\\\" anchored by Scott Hanson and company.\", \"from\": 1463, \"to\": 1906, \"entities\": [{\"begin\": 1642, \"end\": 1652, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 0.9999999737888178, \"rank\": 2.6211212906906