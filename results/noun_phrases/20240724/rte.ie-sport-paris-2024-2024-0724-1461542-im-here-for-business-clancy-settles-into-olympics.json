 \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"dbpedia\": \"http://dbpedia.org/resource/Republic_of_Ireland\"}], \"noun_phrases\": [{\"ngram\": \"RT\\u00c9.ie\", \"from\": 4159, \"to\": 4165}, {\"ngram\": \"the website\", \"from\": 4169, \"to\": 4180}]}, {\"sentence\": \"RT\\u00c9 is not responsible for the content of external internet sites.\", \"from\": 4250, \"to\": 4316, \"entities\": [{\"begin\": 4250, \"end\": 4253, \"title\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\", \"score\": 0.9835396432123026, \"rank\": 0.013767790549921992, \"text\": \"RT\\u00c9\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\", \"dbpedia\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\"}], \"noun_phrases\": [{\"ngram\": \"the content\", \"from\": 4277, \"to\": 4288}, {\"ngram\": \"external internet sites\", \"from\": 4292, \"to\": 4315}]}, {\"sentence\": \"Images Courtesy of Getty Images.\", \"from\": 4318, \"to\": 4350, \"entities\": [{\"begin\": 4337, \"end\": 4342, \"title\": \"http://dbpedia.org/resource/Getty_Images\", \"score\": 0.9999508156679049, \"rank\": 2.688912489728515e-05, \"text\": \"Getty\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Getty_Images\", \"dbpedia\": \"http://dbpedia.org/resource/Getty_Images\"}], \"noun_phrases\": [{\"ngram\": \"Images Courtesy\", \"from\": 4318, \"to\": 4333}]}]}"