ia.org/resource/Amna_Nawaz\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"AMNA NAWAZ\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Amna_Nawaz\", \"dbpedia\": \"http://dbpedia.org/resource/Amna_Nawaz\"}], \"noun_phrases\": [{\"ngram\": \"this game\", \"from\": 2320, \"to\": 2329}, {\"ngram\": \"some Olympics-related news\", \"from\": 2360, \"to\": 2386}]}, {\"sentence\": \"The International Olympic Committee announced that the 2034 Winter Games will be hosted by Salt Lake City, but there is been some controversy around that decision.\", \"from\": 2399, \"to\": 2562, \"entities\": [{\"begin\": 2403, \"end\": 2434, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 2490, \"end\": 2504, \"title\": \"http://dbpedia.org/resource/2002_Winter_Olympics\", \"score\": 0.9943073277480312, \"rank\": 0.005725264304275231, \"text\": \"Salt Lake City\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2002_Winter_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2002_Winter_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"the 2034 Winter Games\", \"from\": 2450, \"to\": 2471}, {\"ngram\": \"some controversy\", \"from\": 2524, \"to\": 2540}, {\"ngram\": \"that decision\", \"from\": 2548, \"to\": 2561}]}, {\"sentence\": \"Explain that to us.\", \"from\": 2564, \"to\": 2583, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"us\", \"from\": 2580, \"to\": 2582}]}, {\"sentence\": \"CHRISTINE BRENNAN: Exactly.\", \"from\": 2585, \"to\": 2612, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"CHRISTINE BRENNAN\", \"from\": 2585, \"to\": 2602}]}, {\"sentence\": \"Salt Lake City is really the only city that wanted the 2034 Games.\", \"from\": 2614, \"to\": 2680, \"entities\": [{\"begin\": 2614, \"end\": 2628, \"title\": \"http://dbpedia.org/resource/2002_Winter_Olympics\", \"score\": 0.9943073277480312, \"rank\": 0.005725264304275231, \"text\": \"Salt Lake City\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2002_Winter_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2002_Winter_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"the only city\", \"from\": 2639, \"to\": 2652}, {\"ngram\": \"the 2034 Games\", \"from\": 2665, \"to\": 2679}]}, {\"sentence\": \"They are very controversial.\", \"from\": 2682, \"to\": 2710, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"It costs a lot of money.\", \"from\": 2712, \"to\": 2736, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a lot\", \"from\": 2721, \"to\": 2726}, {\"ngram\": \"money\", \"from\": 2730, \"to\": 2735}]}, {\"sentence\": \"We expected this, Amna, to just be a slam dunk.\", \"from\": 2738, \"to\": 2785, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Amna\", \"from\": 2756, \"to\": 2760}, {\"ngram\": \"a slam dunk\", \"from\": 2773, \"to\": 2784}]}, {\"sentence\": \"Instead, the IOC, several members brought up basically a demand, demanding the local officials in Utah, in Salt Lake City, including the governor, accede to their wishes to shut down the federal investigation that's going on involving the Chinese doping controversy that I am sure many remember and have heard of involving swimming.\", \"from\": 2787, \"to\": 3119, \"entities\": [{\"begin\": 2800, \"end\": 2803, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.142043200191447e-43, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 2885, \"end\": 2889, \"title\": \"http://dbpedia.org/resource/Utah\", \"score\": 0.9999854212563569, \"rank\": 1.457748864433596e-05, \"text\": \"Utah\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Utah\", \"dbpedia\": \"http://dbpedia.org/resource/Utah\"}, {\"begin\": 2894, \"end\": 2908, \"title\": \"http://dbpedia.org/resource/2002_Winter_Olympics\", \"score\": 0.9943073277480312, \"rank\": 0.005725264304275231, \"text\": \"Salt Lake City\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2002_Winter_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2002_Winter_Olympics\"}, {\"begin\": 3026, \"end\": 3033, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9999786989350897, \"rank\": 1.8989390499511905e-05, \"text\": \"Chinese\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}], \"noun_phrases\": [{\"ngram\": \"several members\", \"from\": 2805, \"to\": 2820}, {\"ngram\": \"basically a demand\", \"from\": 2832, \"to\": 2850}, {\"ngram\": \"the local officials\", \"from\": 2862, \"to\": 2881}, {\"ngram\": \"the governor\", \"from\": 2920, \"to\": 2932}, {\"ngram\": \"their wishes\", \"from\": 2944, \"to\": 2956}, {\"ngram\": \"the federal investigation\", \"from\": 2970, \"to\": 2995}, {\"ngram\": \"swimming\", \"from\": 3110, \"to\": 3118}]}, {\"sentence\": \"The U.S., the FBI's investigating.\", \"from\": 3121, \"to\": 3155, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The U.S.\", \"from\": 3121, \"to\": 3129}]}, {\"sentence\": \"There is a law called the Rodchenkov Act that actually allows the United States to investigate doping schemes that affect U.S. athletes, which this one certainly does, and maybe deprive some of medals.\", \"from\": 3157, \"to\": 3358, \"entities\": [{\"begin\": 3223, \"end\": 3236, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.8168231308636589, \"rank\": 0.22412331170069016, \"text\": \"United States\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"a law\", \"from\": 3166, \"to\": 3171}, {\"ngram\": \"the Rodchenkov Act\", \"from\": 3179, \"to\": 3197}, {\"ngram\": \"doping schemes\", \"from\": 3252, \"to\": 3266}, {\"ngram\": \"U.S. athletes\", \"from\": 3279, \"to\": 3292}, {\"ngram\": \"this one\", \"from\": 3300, \"to\": 3308}, {\"ngram\": \"medals\", \"from\": 3351, \"to\": 3357}]}, {\"sentence\": \"And so, surprisingly, shockingly, the U.S. officials said, yes, we will sign this agreement with the knowledge that we have now been told by the IOC that we should try to shut down an investigation that would impact the IOC, because if they come into the country, as has been the case with one official, where they get subpoenaed when they land in the United State -- and these International Olympic Committee people on it, they think they are royalty.\", \"from\": 3360, \"to\": 3812, \"entities\": [{\"begin\": 3505, \"end\": 3508, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.142043200191447e-43, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 3580, \"end\": 3583, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.142043200191447e-43, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 3738, \"end\": 3769, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"the U.S. officials\", \"from\": 3394, \"to\": 3412}, {\"ngram\": \"this agreement\", \"from\": 3437, \"to\": 3451}, {\"ngram\": \"the knowledge\", \"from\": 3457, \"to\": 3470}, {\"ngram\": \"an investigation\", \"from\": 3541, \"to\": 3557}, {\"ngram\": \"the country\", \"from\": 3611, \"to\": 3622}, {\"ngram\": \"the case\", \"from\": 3636, \"to\": 3644}, {\"ngram\": \"one official\", \"from\": 3650, \"to\": 3662}, {\"ngram\": \"the United State\", \"from\": 3708, \"to\": 3724}, {\"ngram\": \"royalty\", \"from\": 3804, \"to\": 3811}]}, {\"sentence\": \"And they think they are untouchable, and they do not want to deal with us laws.\", \"from\": 3814, \"to\": 3893, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"us laws\", \"from\": 3885, \"to\": 3892}]}, {\"sentence\": \"Truly stunning development that they caved in to the IOC in this manner.\", \"from\": 3895, \"to\": 3967, \"entities\": [{\"begin\": 3948, \"end\": 3951, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.142043200191447e-43, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"Truly stunning development\", \"from\": 3895, \"to\": 3921}, {\"ngram\": \"this manner\", \"from\": 3955, \"to\": 3966}]}, {\"sentence\": \"AMNA NAWAZ: Not the headline they wanted to kick off these Games.\", \"from\": 3969, \"to\": 4034, \"entities\": [{\"begin\": 3969, \"end\": 3979, \"title\": \"http://dbpedia.org/resource/Amna_Nawaz\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"AMNA NAWAZ\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Amna_Nawaz\", \"dbpedia\": \"http://dbpedia.org/resource/Amna_Nawaz\"}], \"noun_phrases\": [{\"ngram\": \"Not the headline\", \"from\": 3981, \"to\": 3997}, {\"ngram\": \"these Games\", \"from\": 4022, \"to\": 4033}]}, {\"sentence\": \"But let us turn to these summer events ahead now.\", \"from\": 4036, \"to\": 4085, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"us\", \"from\": 4044, \"to\": 4046}, {\"ngram\": \"these summer events\", \"from\": 4055, \"to\": 4074}]}, {\"sentence\": \"They are featuring some of the biggest us stars folks will know, including gymnast Simone Biles, truly the GOAT.\", \"from\": 4087, \"to\": 4199, \"entities\": [{\"begin\": 4170, \"end\": 4182, \"title\": \"http://dbpedia.org/resource/Simone_Biles\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Simone Biles\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Simone_Biles\", \"dbpedia\": \"http://dbpedia.org/resource/Simone_Biles\"}], \"noun_phrases\": [{\"ngram\": \"the biggest us stars\", \"from\": 4114, \"to\": 4134}, {\"ngram\": \"folks\", \"from\": 4135, \"to\": 4140}, {\"ngram\": \"truly the GOAT\", \"from\": 4184, \"to\": 4198}]}, {\"sentence\": \"Now, we have to remind folks, Team USA took the silver last Olympics.\", \"from\": 4201, \"to\": 4270, \"entities\": [{\"begin\": 4231, \"end\": 4239, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 0.9982727535595611, \"rank\": 0.0017302268072457972, \"text\": \"Team USA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\"}], \"noun_phrases\": [{\"ngram\": \"folks\", \"from\": 4224, \"to\": 4229}, {\"ngram\": \"the silver\", \"from\": 4245, \"to\": 4255}]}, {\"sentence\": \"Remember, Biles had to pull out and made extreme stress that was actually putting her in physical risk.\", \"from\": 4272, \"to\": 4375, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Biles\", \"from\": 4282, \"to\": 4287}, {\"ngram\": \"extreme stress\", \"from\": 4313, \"to\": 4327}, {\"ngram\": \"physical risk\", \"from\": 4361, \"to\": 4374}]}, {\"sentence\": \"How do we expect her to do and the team this year?\", \"from\": 4377, \"to\": 4427, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"CHRISTINE BRENNAN: This is the story of the Olympics, at least for U.S. fans, for sure, and gymnastics fans.\", \"from\": 4429, \"to\": 4537, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"CHRISTINE BRENNAN\", \"from\": 4429, \"to\": 4446}, {\"ngram\": \"the story\", \"from\": 4456, \"to\": 4465}, {\"ngram\": \"the Olympics\", \"from\": 4469, \"to\": 4481}, {\"ngram\": \"U.S. fans\", \"from\": 4496, \"to\": 4505}, {\"ngram\": \"gymnastics fans\", \"from\": 4521, \"to\": 4536}]}, {\"sentence\": \"And Simone Biles, of course, is a survivor of the worst sexual abuse case and scandal in Olympic history and in sports history, the Larry Nassar saga.\", \"from\": 4539, \"to\": 4689, \"entities\": [{\"begin\": 4543, \"end\": 4555, \"title\": \"http://dbpedia.org/resource/Simone_Biles\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Simone Biles\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Simone_Biles\", \"dbpedia\": \"http://dbpedia.org/resource/Simone_Biles\"}, {\"begin\": 4671, \"end\": 4683, \"title\": \"http://dbpedia.org/resource/USA_Gymnastics_sex_abuse_scandal\", \"score\": 0.9999985139185938, \"rank\": 1.4860837546143966e-06, \"text\": \"Larry Nassar\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/USA_Gymnastics_sex_abuse_scandal\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Gymnastics_sex_abuse_scandal\"}], \"noun_phrases\": [{\"ngram\": \"course\", \"from\": 4560, \"to\": 4566}, {\"ngram\": \"a survivor\", \"from\": 4571, \"to\": 4581}, {\"ngram\": \"the worst sexual abuse case\", \"from\": 4585, \"to\": 4612}, {\"ngram\": \"scandal\", \"from\": 4617, \"to\": 4624}, {\"ngram\": \"Olympic history\", \"from\": 4628, \"to\": 4643}, {\"ngram\": \"sports history\", \"from\": 4651, \"to\": 4665}]}, {\"sentence\": \"And she's been so vocal as a survivor and supporting others, those hundreds of women who were just horrifically abused.\", \"from\": 4691, \"to\": 4810, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a survivor\", \"from\": 4718, \"to\": 4728}, {\"ngram\": \"others\", \"from\": 4744, \"to\": 4750}, {\"ngram\": \"women\", \"from\": 4770, \"to\": 4775}]}, {\"sentence\": \"And so she's a survivor.\", \"from\": 4812, \"to\": 4836, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a survivor\", \"from\": 4825, \"to\": 4835}]}, {\"sentence\": \"She's the greatest of all time, as you said.\", \"from\": 4838, \"to\": 4882, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"all time\", \"from\": 4860, \"to\": 4868}]}, {\"sentence\": \"She is coming back after terrific Olympics in Rio eight years ago and then, of course, a difficult Olympics three years ago in Tokyo.\", \"from\": 4884, \"to\": 5017, \"entities\": [{\"begin\": 4930, \"end\": 4933, \"title\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.5912280621929333e-15, \"text\": \"Rio\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2016_Summer_Olympics\"}, {\"begin\": 5011, \"end\": 5016, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.0334560380215926e-15, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"terrific Olympics\", \"from\": 4909, \"to\": 4926}, {\"ngram\": \"course\", \"from\": 4963, \"to\": 4969}]}, {\"sentence\": \"She had the twisties, the word we all did not know, and then we all knew.\", \"from\": 5019, \"to\": 5092, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the twisties\", \"from\": 5027, \"to\": 5039}, {\"ngram\": \"the word\", \"from\": 5041, \"to\": 5049}]}, {\"sentence\": \"And she withdrew to take care of that physically, mentally, came back when the bronze medal in the balance beam.\", \"from\": 5094, \"to\": 5206, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"care\", \"from\": 5119, \"to\": 5123}, {\"ngram\": \"the balance beam\", \"from\": 5189, \"to\": 5205}]}, {\"sentence\": \"And here she is now.\", \"from\": 5208, \"to\": 5228, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I would not be surprised at all if she wins the gold in the individual all-around, the U.S. gets that team gold back, and she's able to win gold in several of the events, including floor exercise, balance beam, maybe -- and vault as well.\", \"from\": 5230, \"to\": 5468, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the gold\", \"from\": 5274, \"to\": 5282}, {\"ngram\": \"the U.S.\", \"from\": 5313, \"to\": 5321}, {\"ngram\": \"that team\", \"from\": 5327, \"to\": 5336}, {\"ngram\": \"gold\", \"from\": 5370, \"to\": 5374}, {\"ngram\": \"the events\", \"from\": 5389, \"to\": 5399}, {\"ngram\": \"floor exercise\", \"from\": 5411, \"to\": 5425}, {\"ngram\": \"balance beam\", \"from\": 5427, \"to\": 5439}]}, {\"sentence\": \"She's 27, but she's on top of her game, Amna.\", \"from\": 5470, \"to\": 5515, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"top\", \"from\": 5493, \"to\": 5496}, {\"ngram\": \"her game\", \"from\": 5500, \"to\": 5508}, {\"ngram\": \"Amna\", \"from\": 5510, \"to\": 5514}]}, {\"sentence\": \"And she really feels great coming into these Olympics and obviously is going to be the one to watch over the next 10 days or so.\", \"from\": 5517, \"to\": 5645, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"these Olympics\", \"from\": 5556, \"to\": 5570}, {\"ngram\": \"the next 10 days\", \"from\": 5622, \"to\": 5638}]}, {\"sentence\": \"AMNA NAWAZ: Also one to watch, if we head over to the pool now, is Katie Ledecky.\", \"from\": 5647, \"to\": 5728, \"entities\": [{\"begin\": 5647, \"end\": 5657, \"title\": \"http://dbpedia.org/resource/Amna_Nawaz\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"AMNA NAWAZ\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Amna_Nawaz\", \"dbpedia\": \"http://dbpedia.org/resource/Amna_Nawaz\"}, {\"begin\": 5714, \"end\": 5727, \"title\": \"http://dbpedia.org/resource/Katie_Ledecky\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Katie Ledecky\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Katie_Ledecky\", \"dbpedia\": \"http://dbpedia.org/resource/Katie_Ledecky\"}], \"noun_phrases\": [{\"ngram\": \"the pool\", \"from\": 5697, \"to\": 5705}]}, {\"sentence\": \"She's swimming in her fourth Olympic Games, looking to add to her six individual gold medals.\", \"from\": 5730, \"to\": 5823, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her fourth Olympic Games\", \"from\": 5748, \"to\": 5772}, {\"ngram\": \"her six individual gold medals\", \"from\": 5792, \"to\": 5822}]}, {\"sentence\": \"What should we watch for here?\", \"from\": 5825, \"to\": 5855, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"CHRISTINE BRENNAN: Yes, I think she's going to win two more individual gold medals in the 800 and the 1,500.\", \"from\": 5857, \"to\": 5965, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"CHRISTINE BRENNAN\", \"from\": 5857, \"to\": 5874}, {\"ngram\": \"two more individual gold medals\", \"from\": 5908, \"to\": 5939}]}, {\"sentence\": \"The longer she swims, the better she does.\", \"from\": 5967, \"to\": 6009, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"And she's great, of course, at those distances, and has dominated the mile, the 1,500 and also the 800.\", \"from\": 6011,