"{\"uid\": \"swissinfo.ch-eng-olympics-france-conditionally-confirmed-as-2030-winter-games-hosts,-ioc-says-84825634\", \"noun_phrases\": [{\"sentence\": \"Follow us By Karolos Grohmann PARIS (Reuters) -France was conditionally picked as the host of the 2030 Winter Games on Wednesday and must now deliver key financial guarantees in the coming months, the International Olympic Committee said.\", \"from\": 0, \"to\": 240, \"entities\": [{\"begin\": 39, \"end\": 46, \"title\": \"http://dbpedia.org/resource/Reuters\", \"score\": 0.9999999830172329, \"rank\": 1.6982750155173938e-08, \"text\": \"Reuters\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Reuters\", \"dbpedia\": \"http://dbpedia.org/resource/Reuters\"}, {\"begin\": 203, \"end\": 234, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"us\", \"from\": 7, \"to\": 9}, {\"ngram\": \"the host\", \"from\": 82, \"to\": 90}, {\"ngram\": \"the 2030 Winter Games\", \"from\": 94, \"to\": 115}, {\"ngram\": \"Wednesday\", \"from\": 119, \"to\": 128}, {\"ngram\": \"key financial guarantees\", \"from\": 150, \"to\": 174}, {\"ngram\": \"the coming months\", \"from\": 178, \"to\": 195}]}, {\"sentence\": \"The French Alps bid was the preferred choice since June but due to elections and a current caretaker government had been unable to deliver the necessary state and regional financial guarantees in time.\", \"from\": 242, \"to\": 443, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The French Alps\", \"from\": 242, \"to\": 257}, {\"ngram\": \"the preferred choice\", \"from\": 266, \"to\": 286}, {\"ngram\": \"June\", \"from\": 293, \"to\": 297}, {\"ngram\": \"elections\", \"from\": 309, \"to\": 318}, {\"ngram\": \"a current caretaker government\", \"from\": 323, \"to\": 353}, {\"ngram\": \"the necessary state and regional financial guarantees\", \"from\": 381, \"to\": 434}, {\"ngram\": \"time\", \"from\": 438, \"to\": 442}]}, {\"sentence\": \"France must have the guarantees signed by its prime minister by Oct. 1 and have them ratified by parliament no later than March 1 2025, the IOC said.\", \"from\": 445, \"to\": 594, \"entities\": [{\"begin\": 445, \"end\": 451, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9999999895858309, \"rank\": 1.0093397499629452e-08, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 585, \"end\": 588, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 3.314953644261136e-24, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"the guarantees\", \"from\": 462, \"to\": 476}, {\"ngram\": \"its prime minister\", \"from\": 487, \"to\": 505}, {\"ngram\": \"Oct.\", \"from\": 509, \"to\": 513}, {\"ngram\": \"parliament\", \"from\": 542, \"to\": 552}, {\"ngram\": \"March\", \"from\": 567, \"to\": 572}]}, {\"sentence\": \"French President Emmanuel Macron spoke to the IOC session prior to the vote on Wednesday in a bid to ease any concerns and show his support for the candidacy.\", \"from\": 596, \"to\": 754, \"entities\": [{\"begin\": 596, \"end\": 612, \"title\": \"http://dbpedia.org/resource/President_of_France\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"French President\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/President_of_France\", \"dbpedia\": \"http://dbpedia.org/resource/President_of_France\"}, {\"beg