}, {\"begin\": 880, \"end\": 886, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9976388651413411, \"rank\": 0.0022555859871058533, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 958, \"end\": 963, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999988631, \"rank\": 1.1060445229388416e-12, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"The strike threat\", \"from\": 792, \"to\": 809}, {\"ngram\": \"an unwelcome development\", \"from\": 813, \"to\": 837}, {\"ngram\": \"risks\", \"from\": 864, \"to\": 869}, {\"ngram\": \"labour disputes\", \"from\": 904, \"to\": 919}, {\"ngram\": \"the eyes\", \"from\": 928, \"to\": 936}, {\"ngram\": \"the world\", \"from\": 940, \"to\": 949}, {\"ngram\": \"the start\", \"from\": 968, \"to\": 977}, {\"ngram\": \"the games\", \"from\": 981, \"to\": 990}]}, {\"sentence\": \"A whole host of French public sector workers have threatened strikes or have stopped work ahead of the Olympics to demand bonuses for working over the July 26-August 11 event, which coincides with the summer holidays.\", \"from\": 1005, \"to\": 1222, \"entities\": [{\"begin\": 1021, \"end\": 1027, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.608485163484559, \"rank\": 0.6067723579593005, \"text\": \"French\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"A whole host\", \"from\": 1005, \"to\": 1017}, {\"ngram\": \"strikes\", \"from\": 1066, \"to\": 1073}, {\"ngram\": \"the Olympics\", \"from\": 1104, \"to\": 1116}, {\"ngram\": \"bonuses\", \"from\": 1127, \"to\": 1134}, {\"ngram\": \"-August\", \"from\": 1163, \"to\": 1170}, {\"ngram\": \"the summ