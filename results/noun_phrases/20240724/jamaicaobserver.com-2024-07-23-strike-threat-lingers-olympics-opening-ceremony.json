"{\"uid\": \"jamaicaobserver.com-2024-07-23-strike-threat-lingers-olympics-opening-ceremony\", \"noun_phrases\": [{\"sentence\": \"PARIS, France (AFP) - Negotiations to end a strike threat from several hundred dancers involved in the Paris Olympics opening ceremony failed to reach an agreement Tuesday, meaning the event still faces the risk of disruption.\", \"from\": 0, \"to\": 226, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"AFP\", \"from\": 15, \"to\": 18}, {\"ngram\": \"a strike threat\", \"from\": 42, \"to\": 57}, {\"ngram\": \"several hundred dancers\", \"from\": 63, \"to\": 86}, {\"ngram\": \"the Paris Olympics opening ceremony\", \"from\": 99, \"to\": 134}, {\"ngram\": \"an agreement\", \"from\": 151, \"to\": 163}, {\"ngram\": \"the event\", \"from\": 181, \"to\": 190}, {\"ngram\": \"the risk\", \"from\": 203, \"to\": 211}, {\"ngram\": \"disruption\", \"from\": 215, \"to\": 225}]}, {\"sentence\": \"The SFA-CGT union, which says it represents roughly 10 per cent of the 3,000 performers involved in the opening ceremony, filed a strike notice last week over what it said were \\\"outrageous disparities\\\" in pay between dancers.\", \"from\": 228, \"to\": 453, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The SFA-CGT union\", \"from\": 228, \"to\": 245}, {\"ngram\": \"roughly 10 per cent\", \"from\": 272, \"to\": 291}, {\"ngram\": \"the 3,000 performers\", \"from\": 295, \"to\": 315}, {\"ngram\": \"the opening ceremony\", \"from\": 328, \"to\": 348}, {\"ngram\": \"a strike notice\", \"from\": 356, \"to\": 371}, {\"ngram\": \"\\\"outrageous disparities\", \"from\": 405, \"to\": 428}, {\"ngram\": \"pay\", \"from\": 433, \"to\": 436}, {\"ngram\": \"dancers\", \"from\": 445, \"to\": 452}]}, {\"sentence\": \"A meeting Tuesday between the union and the organising committee for the games resulted in an offer of 120 euros (US$130) extra for the lowest paid performers, which was rejected.\", \"from\": 455, \"to\": 634, \"entities\": [], \"noun_phrases\": [{\"