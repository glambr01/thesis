rom\": 1266, \"to\": 1284}, {\"ngram\": \"an incredible year\", \"from\": 1288, \"to\": 1306}, {\"ngram\": \"Grand Slam Track decision\", \"from\": 1332, \"to\": 1357}, {\"ngram\": \"2025 ambitions\", \"from\": 1362, \"to\": 1376}, {\"ngram\": \"the year\", \"from\": 1414, \"to\": 1422}, {\"ngram\": \"style\", \"from\": 1426, \"to\": 1431}, {\"ngram\": \"order\", \"from\": 1474, \"to\": 1479}, {\"ngram\": \"a family\", \"from\": 1489, \"to\": 1497}, {\"ngram\": \"history\", \"from\": 1538, \"to\": 1545}, {\"ngram\": \"the Tokyo Olympics\", \"from\": 1591, \"to\": 1609}]}, {\"sentence\": \"Glover, 38, is a three-time world champion and five-time European champion who was ranked as the No1 female rower in the world back in 2015.\", \"from\": 1616, \"to\": 1756, \"entities\": [{\"begin\": 1673, \"end\": 1690, \"title\": \"http://dbpedia.org/resource/LEN_European_Aquatics_Championships\", \"score\": 1.0, \"rank\": 2.0121307087217504e-13, \"text\": \"European champion\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/LEN_European_Aquatics_Championships\", \"dbpedia\": \"http://dbpedia.org/resource/LEN_European_Aquatics_Championships\"}], \"noun_phrases\": [{\"ngram\": \"Glover\", \"from\": 1616, \"to\": 1622}, {\"ngram\": \"a three-time world champion\", \"from\": 1631, \"to\": 1658}, {\"ngram\": \"the No1 female rower\", \"from\": 1709, \"to\": 1729}, {\"ngram\": \"the world\", \"from\": 1733, \"to\": 1742}]}, {\"sentence\": \"Daley said before Friday's opening ceremony down the River Seine that is expected to last for four hours: \\\"To be asked to be flag bearer is one of the greatest honours in my Olympic diving career.\", \"from\": 1758, \"to\": 1954, \"entities\": [{\"begin\": 1811, \"end\": 1822, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"River Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"Daley\", \"from\": 1758, \"to\": 1763}, {\"ngram\": \"Friday's opening ceremony\", \"from\": 1776, \"to\": 1801}, {\"ngram\": \"four hours\", \"from\": 1852, \"to\": 1862}, {\"ngram\": \"flag bearer\", \"from\": 1883, \"to\": 1894}, {\"ngram\": \"the greatest honours\", \"from\": 1905, \"to\": 1925}, {\"ngram\": \"my Olympic diving career\", \"from\": 1929, \"to\": 1953}]}, {\"sentence\": \"To be able to do it in my fifth Olympic Games and have my family here is a very special thing.\", \"from\": 1955, \"to\": 2049, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my fifth Olympic Games\", \"from\": 1978, \"to\": 2000}, {\"ngram\": \"my family\", \"from\": 2010, \"to\": 2019}, {\"ngram\": \"a very special thing\", \"from\": 2028, \"to\": 2048}]}, {\"sentence\": \"\\\"It has always been a dream of mine, since I was a little kid.\", \"from\": 2051, \"to\": 2113, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a dream\", \"from\": 2071, \"to\": 2078}, {\"ngram\": \"mine\", \"from\": 2082, \"to\": 2086}, {\"ngram\": \"a little kid\", \"from\": 2100, \"to\": 2112}]}, {\"sentence\": \"I remember in 2008 walking out behind the flag bearer right in the front line, because we were the smallest group of people, and to now be one of the two people to lead out the team is such a huge honour.\", \"from\": 2114, \"to\": 2318, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the flag bearer\", \"from\": 2152, \"to\": 2167}, {\"ngram\": \"the front line\", \"from\": 2177, \"to\": 2191}, {\"ngram\": \"the smallest group\", \"from\": 2209, \"to\": 2227}, {\"ngram\": \"people\", \"from\": 2231, \"to\": 2237}, {\"ngram\": \"the two people\", \"from\": 2260, \"to\": 2274}, {\"ngram\": \"the team\", \"from\": 2287, \"to\": 2295}, {\"ngram\": \"such a huge honour\", \"from\": 2299, \"to\": 2317}]}, {\"sentence\": \"\\\"If my dad was around now, he would be so incredibly proud, because he always said that you would know you have cemented your Olympic legacy if you are asked to be a flag bearer at an Olympic Games.\\\"\", \"from\": 2320, \"to\": 2519, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my dad\", \"from\": 2324, \"to\": 2330}, {\"ngram\": \"your Olympic legacy\", \"from\": 2441, \"to\": 2460}, {\"ngram\": \"a flag bearer\", \"from\": 2484, \"to\": 2497}, {\"ngram\": \"an Olympic Games\", \"from\": 2501, \"to\": 2517}]}, {\"sentence\": \"Glover said: \\\"This is probably the biggest honour of my life.\", \"from\": 2521, \"to\": 2582, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Glover\", \"from\": 2521, \"to\": 2527}, {\"ngram\": \"the biggest honour\", \"from\": 2552, \"to\": 2570}, {\"ngram\": \"my life\", \"from\": 2574, \"to\": 2581}]}, {\"sentence\": \"I just love the Olympics and have always loved what it stood for.\", \"from\": 2583, \"to\": 2648, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the Olympics\", \"from\": 2595, \"to\": 2607}]}, {\"sentence\": \"I still pinch myself that I am an Olympian, being a flagbearer and going down in history.\", \"from\": 2649, \"to\": 2738, \"entities\": [{\"begin\": 2683, \"end\": 2691, \"title\": \"http://dbpedia.org/resource/Olympic_Games\", \"score\": 0.9999995162608035, \"rank\": 4.837396345445231e-07, \"text\": \"Olympian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games\"}], \"noun_phrases\": [{\"ngram\": \"a flagbearer\", \"from\": 2699, \"to\": 2711}, {\"ngram\": \"history\", \"from\": 2730, \"to\": 2737}]}, {\"sentence\": \"\\\"I have never been to an opening ceremony before and I will be carrying the flag at my first one..\", \"from\": 2740, \"to\": 2838, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an opening ceremony\", \"from\": 2762, \"to\": 2781}, {\"ngram\": \"the flag\", \"from\": 2812, \"to\": 2820}]}, {\"sentence\": \"It's unbelievable to be in this position.\", \"from\": 2839, \"to\": 2880, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this position\", \"from\": 2866, \"to\": 2879}]}, {\"sentence\": \"\\\"The team is full of amazing stories and inspirational people, so to be representing every athlete's individual story when I stand there is really important to me.\\\"\", \"from\": 2882, \"to\": 3046, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The team\", \"from\": 2883, \"to\": 2891}, {\"ngram\": \"amazing stories\", \"from\": 2903, \"to\": 2918}, {\"ngram\": \"inspirational people\", \"from\": 2923, \"to\": 2943}, {\"ngram\": \"every athlete's individual story\", \"from\": 2967, \"to\": 2999}]}, {\"sentence\": \"Daley is the first diver ever to be a flag bearer for Team GB at the Olympics, while Glover is the first female rower to do it.\", \"from\": 3048, \"to\": 3175, \"entities\": [{\"begin\": 3102, \"end\": 3109, \"title\": \"http://dbpedia.org/resource/Team_GB\", \"score\": 1.0, \"rank\": 3.2795228042588984e-24, \"text\": \"Team GB\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Team_GB\", \"dbpedia\": \"http://dbpedia.org/resource/Team_GB\"}, {\"begin\": 3133, \"end\": 3139, \"title\": \"http://dbpedia.org/resource/Roger_Glover\", \"score\": 0.9999994488822876, \"rank\": 5.51118201187234e-07, \"text\": \"Glover\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Roger_Glover\", \"dbpedia\": \"http://dbpedia.org/resource/Roger_Glover\"}], \"noun_phrases\": [{\"ngram\": \"Daley\", \"from\": 3048, \"to\": 3053}, {\"ngram\": \"the first diver\", \"from\": 3057, \"to\": 3072}, {\"ngram\": \"a flag bearer\", \"from\": 3084, \"to\": 3097}, {\"ngram\": \"the Olympics\", \"from\": 3113, \"to\": 3125}, {\"ngram\": \"the first female rower\", \"from\": 3143, \"to\": 3165}]}, {\"sentence\": \"In Tokyo, male rower Moe Sbihi performed the honours along with sailor Hannah Mills, while in Rio the flag was carried by Andy Murray.\", \"from\": 3177, \"to\": 3311, \"entities\": [{\"begin\": 3180, \"end\": 3185, \"title\": \"ht