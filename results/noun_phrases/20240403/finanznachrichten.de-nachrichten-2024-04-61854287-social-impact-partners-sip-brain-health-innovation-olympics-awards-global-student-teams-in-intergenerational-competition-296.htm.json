\", \"from\": 1975, \"to\": 1987}, {\"ngram\": \"an enhanced version\", \"from\": 1996, \"to\": 2015}, {\"ngram\": \"\\\"This season's focus\", \"from\": 2108, \"to\": 2128}, {\"ngram\": \"the design\", \"from\": 2132, \"to\": 2142}, {\"ngram\": \"implementation\", \"from\": 2147, \"to\": 2161}, {\"ngram\": \"Brain Health Centers\", \"from\": 2165, \"to\": 2185}, {\"ngram\": \"Excellence\", \"from\": 2189, \"to\": 2199}, {\"ngram\": \"Senior Living facilities\", \"from\": 2203, \"to\": 2227}, {\"ngram\": \"Academic institutions\", \"from\": 2232, \"to\": 2253}, {\"ngram\": \"a cohesive platform\", \"from\": 2262, \"to\": 2281}, {\"ngram\": \"the lack\", \"from\": 2300, \"to\": 2308}, {\"ngram\": \"brain care\", \"from\": 2312, \"to\": 2322}, {\"ngram\": \"the lifespan\", \"from\": 2330, \"to\": 2342}]}, {\"sentence\": \"The diverse perspectives and expertise brought by the participating teams and judges have laid a solid foundation for future advances,\\\" said Dr. Gene Bowman, Instructor in Neurology at Harvard Medical School and Director of the McCance Center for Brain Health Clinical Trials Unit at Massachusetts General Hospital.\", \"from\": 2345, \"to\": 2660, \"entities\": [{\"begin\": 2495, \"end\": 2501, \"title\": \"http://dbpedia.org/resource/Division_of_Bowman\", \"score\": 0.636073744458788, \"rank\": 0.5720673898491591, \"text\": \"Bowman\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Division_of_Bowman\", \"dbpedia\": \"http://dbpedia.org/resource/Division_of_Bowman\"}, {\"begin\": 2530, \"end\": 2552, \"title\": \"http://dbpedia.org/resource/Harvard_Medical_School\", \"score\": 0.9999999485894491, \"rank\": 5.141037180532949e-08, \"text\": \"Harvard Medical School\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/Harvard_Medical_School\", \"dbpedia\": \"http://dbpedia.org/resource/Harvard_Medical_School\"}, {\"begin\": 2629, \"end\": 2659, \"title\": \"http://dbpedia.org/resource/M