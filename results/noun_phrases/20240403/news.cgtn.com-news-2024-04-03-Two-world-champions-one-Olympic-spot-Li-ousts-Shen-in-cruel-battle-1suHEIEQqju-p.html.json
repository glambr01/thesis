/Paris\"}], \"noun_phrases\": [{\"ngram\": \"the 31-year-old veteran\", \"from\": 726, \"to\": 749}, {\"ngram\": \"a daunting decision\", \"from\": 762, \"to\": 781}, {\"ngram\": \"the 73kg category\", \"from\": 805, \"to\": 822}, {\"ngram\": \"the 61kg category\", \"from\": 837, \"to\": 854}, {\"ngram\": \"the chance\", \"from\": 866, \"to\": 876}]}, {\"sentence\": \"After careful contemplation, he made the bold choice to embark on an extreme weight-cutting journey, determined to transition to the 61kg division.\", \"from\": 918, \"to\": 1065, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"careful contemplation\", \"from\": 924, \"to\": 945}, {\"ngram\": \"the bold choice\", \"from\": 955, \"to\": 970}, {\"ngram\": \"an extreme weight-cutting journey\", \"from\": 984, \"to\": 1017}, {\"ngram\": \"the 61kg division\", \"from\": 1047, \"to\": 1064}]}, {\"sentence\": \"China's Shen Lijun during the men's 61 kg final at the IWF World Cup in Phuket, Thailand, April 2, 2024.\", \"from\": 1067, \"to\": 1171, \"entities\": [{\"begin\": 1067, \"end\": 1072, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.809236077935269, \"rank\": 0.23573333697954077, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}, {\"begin\": 1139, \"end\": 1145, \"title\": \"http://dbpedia.org/resource/Phuket_province\", \"score\": 0.9999999999995453, \"rank\": 4.1581770529944364e-13, \"text\": \"Phuket\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Phuket_province\", \"dbpedia\": \"http://dbpedia.org/resource/Phuket_province\"}, {\"begin\": 1147, \"end\": 1155, \"title\": \"http://dbpedia.org/resource/Thailand_national_football_team\", \"score\": 0.9971135437408711, \"rank\": 0.00289447846956287, \"text\": \"Thailand\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Thailand_national_football_team\", \"dbpedia\": \"ht