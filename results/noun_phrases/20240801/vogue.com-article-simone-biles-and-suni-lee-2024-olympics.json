\": \"http://dbpedia.org/resource/Czechoslovakia_men's_national_ice_hockey_team\", \"score\": 0.8627302337326105, \"rank\": 0.1238318186302872, \"text\": \"Czechoslovakia\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Czechoslovakia_men's_national_ice_hockey_team\", \"dbpedia\": \"http://dbpedia.org/resource/Czechoslovakia_men's_national_ice_hockey_team\"}, {\"begin\": 783, \"end\": 787, \"title\": \"http://dbpedia.org/resource/Vera_Duckworth\", \"score\": 1.0, \"rank\": 3.699996563526345e-23, \"text\": \"Vera\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Vera_Duckworth\", \"dbpedia\": \"http://dbpedia.org/resource/Vera_Duckworth\"}], \"noun_phrases\": [{\"ngram\": \"today's result\", \"from\": 581, \"to\": 595}, {\"ngram\": \"Biles\", \"from\": 597, \"to\": 602}, {\"ngram\": \"only the third woman\", \"from\": 610, \"to\": 630}, {\"ngram\": \"history\", \"from\": 634, \"to\": 641}, {\"ngram\": \"two individual all-around golds\", \"from\": 649, \"to\": 680}, {\"ngram\": \"the Olympics\", \"from\": 684, \"to\": 696}]}, {\"sentence\": \"During the individual all-around, competitors wear their own leotards.\", \"from\": 819, \"to\": 889, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"competitors\", \"from\": 853, \"to\": 864}, {\"ngram\": \"their own leotards\", \"from\": 870, \"to\": 888}]}, {\"sentence\": \"Biles's had a blue base with dazzling allover embellishments, while Lee's had more of an ombr\\u00e9 scheme, blending blue and red with an almost Art Deco-style filigree.\", \"from\": 890, \"to\": 1054, \"entities\": [{\"begin\": 958, \"end\": 961, \"title\": \"http://dbpedia.org/resource/Cliff_Lee\", \"score\": 0.9972545901043365, \"rank\": 0.002752955346521458, \"text\": \"Lee\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Cliff_Lee\", \"dbpedia\": \"http://dbpedia.org/resource/Cliff_Lee\"}], \"noun_phrases\": [{\"ngram\": \"Biles\", \"from\