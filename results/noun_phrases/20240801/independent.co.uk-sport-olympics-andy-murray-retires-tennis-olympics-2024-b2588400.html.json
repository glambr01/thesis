yer,Andy Murraydeveloped a new obsession.\", \"from\": 488, \"to\": 599, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"ourPrivacy notice\", \"from\": 493, \"to\": 510}, {\"ngram\": \"his final days\", \"from\": 514, \"to\": 528}, {\"ngram\": \"a professional tennis player\", \"from\": 532, \"to\": 560}, {\"ngram\": \"a new obsession\", \"from\": 582, \"to\": 597}]}, {\"sentence\": \"Keen to soak in every moment he could as he arrived at his fifthOlympicsin Paris and last ever tennis tournament, Murray set out with the objective of gathering the largest collection of Olympic pins within Team GB, taking the opportunity to trade with as many athletes from as many different nations as he could to build the largest set.\", \"from\": 600, \"to\": 938, \"entities\": [{\"begin\": 675, \"end\": 680, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999968168, \"rank\": 3.0266492446508486e-12, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 714, \"end\": 720, \"title\": \"http://dbpedia.org/resource/Andy_Murray\", \"score\": 1.0, \"rank\": 2.067881527086622e-40, \"text\": \"Murray\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Andy_Murray\", \"dbpedia\": \"http://dbpedia.org/resource/Andy_Murray\"}, {\"begin\": 807, \"end\": 814, \"title\": \"http://dbpedia.org/resource/Team_GB\", \"score\": 0.9997419905575231, \"rank\": 0.00018665086938378343, \"text\": \"Team GB\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Team_GB\", \"dbpedia\": \"http://dbpedia.org/resource/Team_GB\"}], \"noun_phrases\": [{\"ngram\": \"Keen\", \"from\": 600, \"to\": 604}, {\"ngram\": \"every moment\", \"from\": 616, \"to\": 628}, {\"ngram\": \"the objective\", \"from\": 734, \"to\": 747}, {\"ngram\": \"the largest collection\", \"from\": 761, \"to\": 783}, {\"ngram\": \"Olympic pins\", \"