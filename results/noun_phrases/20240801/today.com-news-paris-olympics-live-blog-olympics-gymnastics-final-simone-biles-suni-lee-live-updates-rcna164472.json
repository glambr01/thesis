291, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The majority\", \"from\": 16183, \"to\": 16195}, {\"ngram\": \"gymnasts\", \"from\": 16199, \"to\": 16207}, {\"ngram\": \"one or two Olympics\", \"from\": 16219, \"to\": 16238}, {\"ngram\": \"some rare stars\", \"from\": 16245, \"to\": 16260}, {\"ngram\": \"Biles\", \"from\": 16266, \"to\": 16271}]}, {\"sentence\": \"The record for most total gymnastics medals is out of reach for Biles unless she defies time and comes back in 2028.\", \"from\": 16293, \"to\": 16409, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The record\", \"from\": 16293, \"to\": 16303}, {\"ngram\": \"most total gymnastics medals\", \"from\": 16308, \"to\": 16336}, {\"ngram\": \"reach\", \"from\": 16347, \"to\": 16352}, {\"ngram\": \"Biles\", \"from\": 16357, \"to\": 16362}, {\"ngram\": \"time\", \"from\": 16381, \"to\": 16385}]}, {\"sentence\": \"Former Soviet Union gymnast Larisa Latynina is second all time behind Phelps with 18 total medals, 9 of them gold, across three Olympics from 1956-64.\", \"from\": 16410, \"to\": 16560, \"entities\": [{\"begin\": 16410, \"end\": 16429, \"title\": \"http://dbpedia.org/resource/Soviet_Union\", \"score\": 0.9977458680664752, \"rank\": 0.002259224523674832, \"text\": \"Former Soviet Union\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Soviet_Union\", \"dbpedia\": \"http://dbpedia.org/resource/Soviet_Union\"}, {\"begin\": 16424, \"end\": 16429, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9849960255014945, \"rank\": 0.015107351951578793, \"text\": \"Union\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 16438, \"end\": 16453, \"title\": \"http://dbpedia.org/resource/Larisa_Latynina\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Larisa Latynina\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Larisa_Latynina\", \"dbpedia\": \"http://dbpedia.org/resource/Larisa_Latynina\"}, {\"begin\": 16480, \"end\": 16486, \"title\": \"http://dbpedia.org/resource/William_H._Phelps_Sr.\", \"score\": 0.7475209993991654, \"rank\": 0.3368684170305948, \"text\": \"Phelps\", \"types\": [\"Q901\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/William_H._Phelps_Sr.\", \"dbpedia\": \"http://dbpedia.org/resource/William_H._Phelps_Sr.\"}], \"noun_phrases\": [{\"ngram\": \"18 total medals\", \"from\": 16492, \"to\": 16507}, {\"ngram\": \"three Olympics\", \"from\": 16532, \"to\": 16546}]}, {\"sentence\": \"However, Biles could catch or pass some other American luminaries.\", \"from\": 16562, \"to\": 16628, \"entities\": [{\"begin\": 16608, \"end\": 16616, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.957584918702337, \"rank\": 0.03688834673468572, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"Biles\", \"from\": 16571, \"to\": 16576}]}, {\"sentence\": \"With two more gold medals she would tie track legend Allyson Felix with 7, and with four more she would tie swimming great Mark Spitz and track immortal Carl Lewis with 9.\", \"from\": 16629, \"to\": 16800, \"entities\": [{\"begin\": 16682, \"end\": 16695, \"title\": \"http://dbpedia.org/resource/Allyson_Felix\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Allyson Felix\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Allyson_Felix\", \"dbpedia\": \"http://dbpedia.org/resource/Allyson_Felix\"}, {\"begin\": 16752, \"end\": 16762, \"title\": \"http://dbpedia.org/resource/Mark_Spitz\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Mark Spitz\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Mark_Spitz\", \"dbpedia\"