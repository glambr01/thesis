"{\"uid\": \"tribune.com.pk-story-2484650-us-swimmer-ledecky-equals-medal-record-with-1500m-freestyle-gold-at-paris-olympics-2024\", \"noun_phrases\": [{\"sentence\": \"CY American swimmer sets an Olympic record time of 15:30.02 in the 1,500m freestyle, earning her 12th Olympic medal Katie Ledecky, widely regarded as the greatest female swimmer in history, claimed Olympic gold on Wednesday night in the 1,500-metre freestyle, a race she has dominated for over a decade.\", \"from\": 0, \"to\": 305, \"entities\": [{\"begin\": 4, \"end\": 12, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9998838807539914, \"rank\": 9.119196699027856e-05, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 118, \"end\": 131, \"title\": \"http://dbpedia.org/resource/Katie_Ledecky\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Katie Ledecky\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Katie_Ledecky\", \"dbpedia\": \"http://dbpedia.org/resource/Katie_Ledecky\"}], \"noun_phrases\": [{\"ngram\": \"an Olympic record time\", \"from\": 25, \"to\": 47}, {\"ngram\": \"the 1,500m freestyle\", \"from\": 63, \"to\": 83}, {\"ngram\": \"the greatest female swimmer\", \"from\": 150, \"to\": 177}, {\"ngram\": \"history\", \"from\": 181, \"to\": 188}, {\"ngram\": \"Olympic gold\", \"from\": 198, \"to\": 210}, {\"ngram\": \"Wednesday night\", \"from\": 214, \"to\": 229}, {\"ngram\": \"the 1,500-metre freestyle\", \"from\": 233, \"to\": 258}, {\"ngram\": \"over a decade\", \"from\": 289, \"to\": 302}]}, {\"sentence\": \"Ledecky took command early and never faced a challenge, finishing with an Olympic record time of 15:30.02.\", \"from\": 307, \"to\": 413, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Ledecky\", \"from\": 307, \"to\": 314}, {\"ngram\": \"command\", \"from\": 320, \"to\": 327}, {\"ngram\": \"a challenge\", \"from\": 350, \"to\": 361}, {\"ngram\": \"an Olympic record time\", \"from\": 378, \"to\": 400}]}, {\"sentence\": \"This marks her first gold medal of the Paris 2024 Games, adding to the bronze she secured on Saturday in the 400-meter freestyle.\", \"from\": 414, \"to\": 543, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her first gold medal\", \"from\": 425, \"to\": 445}, {\"ngram\": \"the Paris 2024 Games\", \"from\": 449, \"to\": 469}, {\"ngram\": \"the bronze\", \"from\": 481, \"to\": 491}, {\"ngram\": \"Saturday\", \"from\": 507, \"to\": 515}, {\"ngram\": \"the 400-meter freestyle\", \"from\": 519, \"to\": 542}]}, {\"sentence\": \"With this victory, Ledecky has now won 12 Olympic medals across four Games, tying the record for the most Olympic swimming medals won by a woman.\", \"from\": 545, \"to\": 690, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this victory\", \"from\": 550, \"to\": 562}, {\"ngram\": \"Ledecky\", \"from\": 564, \"to\": 571}, {\"ngram\": \"12 Olympic medals\", \"from\": 584, \"to\": 601}, {\"ngram\": \"four Games\", \"from\": 609, \"to\": 619}, {\"ngram\": \"the record\", \"from\": 627, \"to\": 637}, {\"ngram\": \"the most Olympic swimming medals\", \"from\": 642, \"to\": 674}, {\"ngram\": \"a woman\", \"from\": 682, \"to\": 689}]}, {\"sentence\": \"She shares this prestigious accolade with fellow Americans Jenny Thompson, Dara Torres, Natalie Coughlin, and Australian Emma McKeon, who is also competing in Paris.\", \"from\": 692, \"to\": 857, \"entities\": [{\"begin\": 751, \"end\": 765, \"title\": \"http://dbpedia.org/resource/Jenny_Thompson\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Jenny Thompson\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Jenny_Thompson\", \"dbpedia\": \"http://dbpedia.org/resource/Jenny_Thompson\"}, {\"begin\": 767, \"end\": 778, \"title\": \"http://dbpedia.org/resource/Dara_Torres\", \"score\": 1.0