, \"to\": 529, \"entities\": [{\"begin\": 371, \"end\": 383, \"title\": \"http://dbpedia.org/resource/Taylor_Fritz\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Taylor Fritz\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Taylor_Fritz\", \"dbpedia\": \"http://dbpedia.org/resource/Taylor_Fritz\"}, {\"begin\": 388, \"end\": 398, \"title\": \"http://dbpedia.org/resource/Tommy_Paul\", \"score\": 1.0, \"rank\": 3.8297620508041343e-23, \"text\": \"Tommy Paul\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Tommy_Paul\", \"dbpedia\": \"http://dbpedia.org/resource/Tommy_Paul\"}, {\"begin\": 404, \"end\": 410, \"title\": \"http://dbpedia.org/resource/Andy_Murray\", \"score\": 1.0, \"rank\": 5.875625727295227e-51, \"text\": \"Murray\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Andy_Murray\", \"dbpedia\": \"http://dbpedia.org/resource/Andy_Murray\"}, {\"begin\": 415, \"end\": 420, \"title\": \"http://dbpedia.org/resource/DaBaby\", \"score\": 0.9962764751012816, \"rank\": 0.003737441354857752, \"text\": \"Evans\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/DaBaby\", \"dbpedia\": \"http://dbpedia.org/resource/DaBaby\"}, {\"begin\": 439, \"end\": 446, \"title\": \"http://dbpedia.org/resource/British_Boxing_Board_of_Control\", \"score\": 0.9996660470955422, \"rank\": 0.00032846679965998447, \"text\": \"British\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/British_Boxing_Board_of_Control\", \"dbpedia\": \"http://dbpedia.org/resource/British_Boxing_Board_of_Control\"}, {\"begin\": 511, \"end\": 516, \"title\": \"http://dbpedia.org/resource/Japan_Davis_Cup_team\", \"score\": 0.9999999999818101, \"rank\": 1.4247457663441902e-11, \"text\": \"Japan\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Japan_Davis_Cup_team\", \"dbpedia\": \"http://dbpedia.org/resource/Japan_Davis_Cup_team\"}, {\"begin\": 521, \"end\": 528, \"title\": \"http://dbpedia.org/resource/Belgium_Billie_Jean_King_Cup_team\", \"score\": 0.7799626097273504, \"rank\": 0.2762317913757712, \"text\": \"Belgium\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Belgium_Billie_Jean_King_Cup_team\", \"dbpedia\": \"http://dbpedia.org/resource/Belgium_Billie_Jean_King_Cup_team\"}], \"noun_phrases\": []}, {\"sentence\": \"'I am proud of my career, my achievements and what I put into the sport,' Murray said after his last dance in the French capital.\", \"from\": 531, \"to\": 660, \"entities\": [{\"begin\": 605, \"end\": 611, \"title\": \"http://dbpedia.org/resource/Andy_Murray\", \"score\": 1.0, \"rank\": 5.875625727295227e-51, \"text\": \"Murray\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Andy_Murray\", \"dbpedia\": \"http://dbpedia.org/resource/Andy_Murray\"}, {\"begin\": 645, \"end\": 651, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.4854647398009583, \"rank\": 0.7788525436925454, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"my career\", \"from\": 546, \"to\": 555}, {\"ngram\": \"the sport\", \"from\": 593, \"to\": 602}, {\"ngram\": \"his last dance\", \"from\": 623, \"to\": 637}]}, {\"sentence\": \"'Obviously it was emotional because it's the last time I will play.\", \"from\": 661, \"to\": 728, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the last time\", \"from\": 702, \"to\": 715}]}, {\"sentence\": \"But I am genuinely happy now.\", \"from\": 729, \"to\": 758, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I am happy with how it finished.\", \"from\": 759, \"to\": 791, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I am glad I got to go out here at the Olympics and finish on my terms.'\", \"from\": 792, \"to\": 863, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the Olympics\", \"from\": 826, \"to\": 838}, {\"ngram\": \"my terms\", \"from\": 853, \"to\": 861}]}, {\"sentence\": \"Widely regarded as one of Great Britain's biggest sporting heroes, Murray hangs up his racket and has called time on his career with twoWimbledontitles, two Olympic gold medals, theUSOpen and the Davis Cup in his trophy cabinet.\", \"from\": 865, \"to\": 1093, \"entities\": [{\"begin\": 891, \"end\": 904, \"title\": \"http://dbpedia.org/resource/Great_Britain_Davis_Cup_team\", \"score\": 1.0, \"rank\": 6.892289561165865e-20, \"text\": \"Great Britain\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Great_Britain_Davis_Cup_team\", \"dbpedia\": \"http://dbpedia.org/resource/Great_Britain_Davis_Cup_team\"}, {\"begin\": 932, \"end\": 938, \"title\": \"http://dbpedia.org/resource/Andy_Murray\", \"score\": 1.0, \"rank\": 5.875625727295227e-51, \"text\": \"Murray\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Andy_Murray\", \"dbpedia\": \"http://dbpedia.org/resource/Andy_Murray\"}], \"noun_phrases\": [{\"ngram\": \"his racket\", \"from\": 948, \"to\": 958}, {\"ngram\": \"time\", \"from\": 974, \"to\": 978}, {\"ngram\": \"his career\", \"from\": 982, \"to\": 992}, {\"ngram\": \"twoWimbledontitles\", \"from\": 998, \"to\": 1016}, {\"ngram\": \"two Olympic gold medals\", \"from\": 1018, \"to\": 1041}, {\"ngram\": \"the Davis Cup\", \"from\": 1057, \"to\": 1070}, {\"ngram\": \"his trophy cabinet\", \"from\": 1074, \"to\": 1092}]}, {\"sentence\": \"The 37-year-oldended Britain's 77-year waitfor a Wimbledon men's singles champion in 2013, which sparked emotional scenes up and down the country.\", \"from\": 1095, \"to\": 1241, \"entities\": [{\"begin\": 1116, \"end\": 1123, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9992663410247556, \"rank\": 0.0007339618877097328, \"text\": \"Britain\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"a Wimbledon men's singles champion\", \"from\": 1142, \"to\": 1176}, {\"ngram\": \"emotional scenes\", \"from\": 1200, \"to\": 1216}, {\"ngram\": \"the country\", \"from\": 1229, \"to\": 1240}]}, {\"sentence\": \"He struggled badly with injuries in his twilight years but made a shock comeback with a metal hip and remarkably went on to land even more silverware.\", \"from\": 1243, \"to\": 1393, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"injuries\", \"from\": 1267, \"to\": 1275}, {\"ngram\": \"his twilight years\", \"from\": 1279, \"to\": 1297}, {\"ngram\": \"a shock comeback\", \"from\": 1307, \"to\": 1323}, {\"ngram\": \"a metal hip\", \"from\": 1329, \"to\": 1340}, {\"ngram\": \"even more silverware\", \"from\": 1372, \"to\": 1392}]}, {\"sentence\": \"Murray picked up a nasty back problem at Queen's Club in June, which required surgery and forced him out of one last appearance in the Wimbledon singles, althoughhe did get an emotional farewell playing doubleswith his brother Jamie.\", \"from\": 1395, \"to\": 1628, \"entities\": [{\"begin\": 1395, \"end\": 1401, \"title\": \"http://dbpedia.org/resource/Andy_Murray\", \"score\": 1.0, \"rank\": 5.875625727295227e-51, \"text\": \"Murray\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Andy_Murray\", \"dbpedia\": \"http://dbpedia.org/resource/Andy_Murray\"}], \"noun_phrases\": [{\"ngram\": \"a nasty back problem\", \"from\": 1412, \"to\": 1432}, {\"ngram\": \"Queen's Club\", \"from\": 1436, \"to\": 1448}, {\"ngram\": \"June\", \"from\": 1452, \"to\": 1456}, {\"ngram\": \"surgery\", \"from\": 1473, \"to\": 1480}, {\"ngram\": \"one last appearance\", \"from\": 1503, \"to\": 1522}, {\"ngram\": \"the Wimbledon singles\", \"from\": 1526, \"to\": 1547}, {\"ngram\": \"althoughhe\", \"from\": 1549, \"to\": 1559}, {\"ngram\": \"an emotional farewell\", \"from\": 1568, \"to\": 1589}, {\"ngram\": \"his brother\", \"from\": 1610, \"to\": 1621}, {\"ngram\": \"Jamie\", \"from\": 1622, \"to\": 1627}]}, {\"sentence\": \"He had been hoping to play Olympic singles but, again, could not get himself fit enough as he decided to solely focus on the doubles with fellow Brit Evans.\", \"from\": 1630, \"to\": 1786, \"entities\": [{\"begin\": 1780, \"end\": 1785, \"title\": \"http://dbpedia.org/resource/DaBaby\", \"score\": 0.9962764751012816, \"rank\": 0.003737441354857752, \"text\": \"Evans\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/DaBaby\", \"dbpedia\": \"http://dbpedia.org/resource/DaBaby\"}], \"noun_phrases\": [{\"ngram\": \"Olympic singles\", \"from\": 1657, \"to\": 1672}, {\"ngram\": \"the doubles\", \"from\": 1751, \"to\": 1762}]}, {\"sentence\": \"Murray registered a total of 46 career titles in singles, which puts him 15th overall in the Open Era.\", \"from\": 1788, \"to\": 1890, \"entities\": [{\"begin\": 1788, \"end\": 1794, \"title\": \"http://dbpedia.org/resource/Andy_Murray\", \"score\": 1.0, \"rank\": 5.875625727295227e-51, \"text\": \"Murray\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Andy_Murray\", \"dbpedia\": \"http://dbpedia.org/resource/Andy_Murray\"}], \"noun_phrases\": [{\"ngram\": \"a total\", \"from\": 1806, \"to\": 1813}, {\"ngram\": \"46 career titles\", \"from\": 1817, \"to\": 1833}, {\"ngram\": \"singles\", \"from\": 1837, \"to\": 1844}, {\"ngram\": \"the Open Era\", \"from\": 1877, \"to\": 1889}]}, {\"sentence\": \"He stands alone as the first tennis player - and only man in history - to win Olympic gold singles medals on two different surfaces.\", \"from\": 1891, \"to\": 2023, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the first tennis player\", \"from\": 1910, \"to\": 1933}, {\"ngram\": \"man\", \"from\": 1945, \"to\": 1948}, {\"ngram\": \"history\", \"from\": 1952, \"to\": 1959}, {\"ngram\": \"Olympic gold singles medals\", \"from\": 1969, \"to\": 1996}, {\"ngram\": \"two different surfaces\", \"from\": 2000, \"to\": 2022}]}, {\"sentence\": \"Heenjoyed 41 weeks as the world No.1, a sensational feat given the era of tennis he was playing in withNovak Djokovic, Rafael Nadal and Roger Federer.\", \"from\": 2025, \"to\": 2175, \"entities\": [{\"begin\": 2134, \"end\": 2142, \"title\": \"http://dbpedia.org/resource/Novak_Djokovic\", \"score\": 0.999999950986877, \"rank\": 4.9013346725412464e-08, \"text\": \"Djokovic\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Novak_Djokovic\", \"dbpedia\": \"http://dbpedia.org/resource/Novak_Djokovic\"}, {\"begin\": 2144, \"end\": 2156, \"title\": \"http://dbpedia.org/resource/Rafael_Nadal\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Rafael Nadal\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Rafael_Nadal\", \"dbpedia\": \"http://dbpedia.org/resource/Rafael_Nadal\"}, {\"begin\": 2161, \"end\": 2174, \"title\": \"http://dbpedia.org/resource/Roger_Federer\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Roger Federer\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Roger_Federer\", \"dbpedia\": \"http://dbpedia.org/resource/Roger_Federer\"}], \"noun_phrases\": [{\"ngram\": \"the world No.1\", \"from\": 2047, \"to\": 2061}, {\"ngram\": \"a sensational feat\", \"from\": 2063, \"to\": 2081}, {\"ngram\": \"the era\", \"from\": 2088, \"to\": 2095}, {\"ngram\": \"tennis\", \"from\": 2099, \"to\": 2105}]}, {\"sentence\": \"Murrayguided Britain to glory in the Davis Cuptoo, ending the country's 79-year wait to lift the trophy, with 2015 marking the team's first triumph since 1936.\", \"from\": 2177, \"to\": 2336, \"entities\": [{\"begin\": 2190, \"end\": 2197, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9992663410247556, \"rank\": 0.0007339618877097328, \"text\": \"Britain\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"glory\", \"from\": 2201, \"to\": 2206}, {\"ngram\": \"the Davis Cuptoo\", \"from\": 2210, \"to\": 2226}, {\"ngram\": \"the country's 79-year wait\", \"from\": 2235, \"to\": 2261}, {\"ngram\": \"the trophy\", \"from\": 2270, \"to\": 2280}, {\"ngram\": \"the team's first triumph\", \"from\": 2300, \"to\": 2324}]}, {\"sentence\": \"Murray, who also won Olympic silver alongside Laura Robson in mixed doubles and was a finalist at the other two Grand Slams he did not win - Roland-Garros and the Australian Open - has struggled with various injury problems since 2016and it looked like his career was overbefore he successfully returned with a metal hip.\", \"from\": 2338, \"to\": 2659, \"entities\": [{\"begin\": 2338, \"end\": 2344, \"title\": \"http://dbpedia.org/resource/Andy_Murray\", \"score\": 1.0, \"rank\": 5.875625727295227e-51, \"text\": \"Murray\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Andy_Murray\", \"dbpedia\": \"http://dbpedia.org/resource/Andy_Murray\"}, {\"begin\": 2384, \"end\": 2396, \"title\": \"http://dbpedia.org/resource/Laura_Robson\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Laura Robson\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Laura_Robson\", \"dbpedia\": \"http://dbpedia.org/resource/Laura_Robson\"}, {\"begin\": 2479, \"end\": 2492, \"title\": \"http://dbpedia.org/resource/French_Open\", \"score\": 0.9999999999986358, \"rank\": 1.488880785954864e-12, \"text\": \"Roland-Garros\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/French_Open\", \"dbpedia\": \"http://dbpedia.org/resource/French_Open\"}], \"noun_phrases\": [{\"ngram\": \"Olympic silver\", \"from\": 2359, \"to\": 2373}, {\"ngram\": \"mixed doubles\", \"from\": 2400, \"to\": 2413}, {\"ngram\": \"a finalist\", \"from\": 2422, \"to\": 2432}, {\"ngram\": \"the other two Grand Slams\", \"from\": 2436, \"to\": 2461}, {\"ngram\": \"the Australian Open\", \"from\": 2497, \"to\": 2516}, {\"ngram\": \"various injury problems\", \"from\": 2538, \"to\": 2561}, {\"ngram\": \"2016and\", \"from\": 2568, \"to\": 2575}, {\"ngram\": \"his career\", \"from\": 2591, \"to\": 2601}, {\"ngram\": \"a metal hip\", \"from\": 2647, \"to\": 2658}]}, {\"sentence\": \"After making a comeback, Murray worked his way back into the world top 50, won the European Open, reached three more ATP Tour finals, won the Queen's Club doubles title and lifted three trophies on the lower-level ATP Challenger Tour.\", \"from\": 2661, \"to\": 2895, \"entities\": [{\"begin\": 2686, \"end\": 2692, \"title\": \"http://dbpedia.org/resource/Andy_Murray\", \"score\": 1.0, \"rank\": 5.875625727295227e-51, \"text\": \"Murray\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Andy_Murray\", \"dbpedia\": \"http://dbpedia.org/resource/Andy_Murray\"}, {\"begin\": 2875, \"end\": 2894, \"title\": \"http://dbpedia.org/resource/ATP_Challenger_Tour\", \"score\": 1.0, \"rank\": 7.071102126359592e-32, \"text\": \"ATP Challenger Tour\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/ATP_Challenger_Tour\", \"dbpedia\": \"http://dbpedia.org/resource/ATP_Challenger_Tour\"}], \"noun_phrases\": [{\"ngram\": \"a comeback\", \"from\": 2674, \"to\": 2684}, {\"ngram\": \"his way\", \"from\": 2700, \"to\": 2707}, {\"ngram\": \"the world top\", \"from\": 2718, \"to\": 2731}, {\"ngram\": \"the European Open\", \"from\": 2740, \"to\": 2757}, {\"ngram\": \"three more ATP Tour