.org/resource/China_women's_national_football_team\"}, {\"begin\": 334, \"end\": 339, \"title\": \"http://dbpedia.org/resource/Macau\", \"score\": 0.9999953370545003, \"rank\": 4.637393961469223e-06, \"text\": \"Macao\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Macau\", \"dbpedia\": \"http://dbpedia.org/resource/Macau\"}], \"noun_phrases\": [{\"ngram\": \"Sports Scene Copied Athletes\", \"from\": 205, \"to\": 233}, {\"ngram\": \"a gala\", \"from\": 263, \"to\": 269}, {\"ngram\": \"Sunday night\", \"from\": 273, \"to\": 285}, {\"ngram\": \"their three-day visit\", \"from\": 293, \"to\": 314}]}, {\"sentence\": \"With the theme \\\"Our pride,\\\" the gala was made up of three parts: \\\"Surpass your dream,\\\" \\\"Break the limit\\\" and \\\"Build your future dream.\\\"\", \"from\": 372, \"to\": 507, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the theme\", \"from\": 377, \"to\": 386}, {\"ngram\": \"Our pride\", \"from\": 388, \"to\": 397}, {\"ngram\": \"the gala\", \"from\": 400, \"to\": 408}, {\"ngram\": \"three parts\", \"from\": 424, \"to\": 435}, {\"ngram\": \"your dream\", \"from\": 446, \"to\": 456}, {\"ngram\": \"the limit\", \"from\": 466, \"to\": 475}, {\"ngram\": \"your future dream\", \"from\": 488, \"to\": 505}]}, {\"sentence\": \"Olympians not only participated in performances on the stage, but also shared their experience and stories of making the country proud.\", \"from\": 508, \"to\": 643, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Olympians\", \"from\": 508, \"to\": 517}, {\"ngram\": \"performances\", \"from\": 543, \"to\": 555}, {\"ngram\": \"the stage\", \"from\": 559, \"to\": 568}, {\"ngram\": \"their experience\", \"from\": 586, \"to\": 602}, {\"ngram\": \"stories\", \"from\": 607, \"to\": 614}, {\"ngram\": \"the country\", \"from\": 625, \"to\": 636}]}, {\"sentence\": \"\\\"I wasn't fighting alone because our great country had my back,\\\" 2024 Paris Olympic Games gold medalist swimmer Pan Zhanle said.\", \"from\": 645, \"to\": 773, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"our great country\", \"from\": 678, \"to\": 695}, {\"ngram\": \"my back\", \"from\": 700, \"to\": 707}, {\"ngram\": \"\\\" 2024 Paris Olympic Games gold medalist swimmer Pan Zhanle\", \"from\": 708, \"to\": 767}]}, {\"sentence\": \"\\\"My gold medal is a gift to our country.\\\"\", \"from\": 774, \"to\": 815, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My gold medal\", \"from\": 775, \"to\": 788}, {\"ngram\": \"a gift\", \"from\": 792, \"to\": 798}, {\"ngram\": \"our country\", \"from\": 802, \"to\": 813}]}, {\"sentence\": \"\\\"We finished the final with a draw in regular time,\\\" said Chinese women's hockey player Li Hong.\", \"from\": 817, \"to\": 913, \"entities\": [{\"begin\": 875, \"end\": 882, \"title\": \"http://dbpedia.org/resource/Chinese_language\", \"score\": 0.8604915501958359, \"rank\": 0.15635974179100545, \"text\": \"Chinese\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Chinese_language\", \"dbpedia\": \"http://dbpedia.org/resource/Chinese_language\"}, {\"begin\": 905, \"end\": 912, \"title\": \"http://dbpedia.org/resource/Li_Hong\", \"score\": 1.0, \"rank\": 2.927688971121183e-16, \"text\": \"Li Hong\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Li_Hong\", \"dbpedia\": \"http://dbpedia.org/resource/Li_Hong\"}], \"noun_phrases\": [{\"ngram\": \"a draw\", \"from\": 845, \"to\": 851}, {\"ngram\": \"regular time\", \"from\": 855, \"to\": 867}]}, {\"sentence\": \"\\\"Though we lost in the penalty shootout, we received applause from the opponents' supporters when we traveled around the stadium wearing the Chinese national flags.\", \"from\": 914, \"to\": 1078, \"entities\": [{\"begin\": 1055, \"end\": 1077, \"title\": \"http://dbpedia.org/resource/Flag_of_China\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Chinese national flags\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Flag_of_China\", \"dbpedia\": \"http://dbpedia.org/resource/Flag_of_China\"}], \"noun_phrases\": [{\"ngram\": \"the penalty\", \"from\": 933, \"to\": 944}, {\"ngram\": \"applause\", \"from\": 967, \"to\": 975}, {\"ngram\": \"the opponents' supporters\", \"from\": 981, \"to\": 1006}, {\"ngram\": \"the stadium\", \"from\": 1031, \"to\": 1042}]}, {\"sentence\": \"That's when I realized that we had gained respect after displaying the spirit of Chinese athletes.\\\"\", \"from\": 1079, \"to\": 1178, \"entities\": [{\"begin\": 1160, \"end\": 1167, \"title\": \"http://dbpedia.org/resource/Chinese_language\", \"score\": 0.8604915501958359, \"rank\": 0.15635974179100545, \"text\": \"Chinese\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Chinese_language\", \"dbpedia\": \"http://dbpedia.org/resource/Chinese_language\"}], \"noun_phrases\": [{\"ngram\": \"respect\", \"from\": 1121, \"to\": 1128}, {\"ngram\": \"the spirit\", \"from\": 1146, \"to\": 1156}]}, {\"sentence\": \"\\\"I think the mixed doubles event requires good coordination and communication,\\\" champion paddler Sun Yingsha said.\", \"from\": 1180, \"to\": 1294, \"entities\": [{\"begin\": 1277, \"end\": 1288, \"title\": \"http://dbpedia.org/resource/Sun_Yingsha\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Sun Yingsha\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q13382519\"], \"wikid\": \"http://dbpedia.org/resource/Sun_Yingsha\", \"dbpedia\": \"http://dbpedia.org/resource/Sun_Yingsha\"}], \"noun_phrases\": [{\"ngram\": \"the mixed doubles event\", \"from\": 1189, \"to\": 1212}, {\"ngram\": \"good coordination\", \"from\": 1222, \"to\": 1239}, {\"ngram\": \"communication\", \"from\": 1244, \"to\": 1257}]}, {\"sentence\": \"\\\"We needed to adapt ourselves quickly to the changes in every game.\", \"from\": 1295, \"to\": 1362, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the changes\", \"from\": 1336, \"to\": 1347}, {\"ngram\": \"every game\", \"from\": 1351, \"to\": 1361}]}, {\"sentence\": \"I was happy that me and Wang Chuqin could win the event in Paris.\", \"from\": 1363, \"to\": 1428, \"entities\": [{\"begin\": 1387, \"end\": 1398, \"title\": \"http://dbpedia.org/resource/Wang_Chuqin\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Wang Chuqin\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q13382519\"], \"wikid\": \"http://dbpedia.org/resource/Wang_Chuqin\", \"dbpedia\": \"http://dbpedia.org/resource/Wang_Chuqin\"}, {\"begin\": 1422, \"end\": 1427, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999717431369, \"rank\": 2.8256826672490605e-08, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"the event\", \"from\": 1409, \"to\": 1418}]}, {\"sentence\": \"I want to thank you for your support.\\\"\", \"from\": 1429, \"to\": 1467, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"your support\", \"from\": 1453, \"to\": 1465}]}, {\"sentence\": \"\\\"Eating good food in Macao helped a lot to release my pressure,\\\" Chinese table tennis team captain Ma Long said.\", \"from\": 1469, \"to\": 1581, \"entities\": [{\"begin\": 1490, \"end\": 1495, \"title\": \"http://dbpedia.org/resource/Macau\", \"score\": 0.9999953370545003, \"rank\": 4.637393961469223e-06, \"text\": \"Macao\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Macau\", \"dbpedia\": \"http://dbpedia.org/resource/Macau\"}, {\"begin\": 1534, \"end\": 1541, \"title\": \"http://dbpedia.org/resource/Chinese_language\", \"score\": 0.8604915501958359, \"rank\": 0.15635974179100545, \"text\": \"Chinese\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Chinese_language\", \"dbpedia\": \"http://dbpedia.org/resource/Chinese_language\"}, {\"begin\": 1568, \"end\": 1575, \"title\": \"http://dbpedia.org/resource/Ma_Long\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Ma Long\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\