n_phrases\": [{\"ngram\": \"The parade\", \"from\": 801, \"to\": 811}, {\"ngram\": \"the arrival\", \"from\": 828, \"to\": 839}, {\"ngram\": \"the flame\", \"from\": 843, \"to\": 852}, {\"ngram\": \"riders\", \"from\": 866, \"to\": 872}, {\"ngram\": \"horseback\", \"from\": 876, \"to\": 885}, {\"ngram\": \"25 torchbearers\", \"from\": 887, \"to\": 902}, {\"ngram\": \"cadets\", \"from\": 908, \"to\": 914}, {\"ngram\": \"the shapes\", \"from\": 959, \"to\": 969}, {\"ngram\": \"the five interlocking Olympic rings\", \"from\": 973, \"to\": 1008}]}, {\"sentence\": \"The first torchbearer was Col. Thibault Vallette, equestrian gold medallist in the 2016 Rio Olympics, who passed it on to a group of young athletes as they passed it hand-to-hand in front of the presidential tribune.\", \"from\": 1011, \"to\": 1227, \"entities\": [{\"begin\": 1061, \"end\": 1071, \"title\": \"http://dbpedia.org/resource/Equestrianism\", \"score\": 0.8688797279460779, \"rank\": 0.14966364621411352, \"text\": \"equestrian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Equestrianism\", \"dbpedia\": \"http://dbpedia.org/resource/Equestrianism\"}], \"noun_phrases\": [{\"ngram\": \"The first torchbearer\", \"from\": 1011, \"to\": 1032}, {\"ngram\": \"Col. Thibault Vallette\", \"from\": 1037, \"to\": 1059}, {\"ngram\": \"the 2016 Rio Olympics\", \"from\": 1090, \"to\": 1111}, {\"ngram\": \"a group\", \"from\": 1133, \"to\": 1140}, {\"ngram\": \"young athletes\", \"from\": 1144, \"to\": 1158}, {\"ngram\": \"hand\", \"from\": 1185, \"to\": 1189}, {\"ngram\": \"front\", \"from\": 1193, \"to\": 1198}, {\"ngram\": \"the presidential tribune\", \"from\": 1202, \"to\": 1226}]}, {\"sentence\": \"Usually, the parade travels from the Napoleon-era Arc de Triomphe to the Concorde plaza, where France's last king and queen were beheaded.\", \"from\": 1229, \"to\": 1367, \"entities\": [{\"begin\": 1279, \"end\": 1294, \"title\": \"http://dbpedia.org/resource/Arc_de_Triomphe\", \"score\": 1.0, \"rank\": 1.531616147463843e-31, \"text\": \"Arc de Triomphe\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Arc_de_Triomphe\", \"dbpedia\": \"http://dbpedia.org/resource/Arc_de_Triomphe\"}, {\"begin\": 1324, \"end\": 1330, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9998655958008363, \"rank\": 0.00011514529706839755, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"the parade\", \"from\": 1238, \"to\": 1248}, {\"ngram\": \"the Concorde plaza\", \"from\": 1298, \"to\": 1316}, {\"ngram\": \"queen\", \"from\": 1347, \"to\": 1352}]}, {\"sentence\": \"This year, Concorde has been transformed into a huge Olympic venue for breakdancing, skateboarding and BMX.\", \"from\": 1369, \"to\": 1476, \"entities\": [{\"begin\": 1472, \"end\": 1475, \"title\": \"http://dbpedia.org/resource/BMX\", \"score\": 0.9987503699450819, \"rank\": 0.0012024464928911663, \"text\": \"BMX\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/BMX\", \"dbpedia\": \"http://dbpedia.org/resource/BMX\"}], \"noun_phrases\": [{\"ngram\": \"Concorde\", \"from\": 1380, \"to\": 1388}, {\"ngram\": \"a huge Olympic venue\", \"from\": 1415, \"to\": 1435}]}, {\"sentence\": \"So the parade route headed to the Bois de Boulogne park on the city's edge instead.\", \"from\": 1478, \"to\": 1561, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"So the parade route\", \"from\": 1478, \"to\": 1497}, {\"ngram\": \"the Bois de Boulogne park\", \"from\": 1508, \"to\": 1533}, {\"ngram\": \"the city's edge\", \"from\": 1537, \"to\": 1552}]}, {\"sentence\": \"Olympic venue construction around the Eiffel Tower means spectators can not gather beneath the monument to watch its annual fireworks show, either.\", \"from\": 1563, \"to\": 1710, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Olympic venue construction\", \"from\": 1563, \"to\": 1589}, {\"ngram\": \"the Eiffel Tower\", \"from\": 1597, \"to\": 1613}, {\"ngram\": \"spectators\", \"from\": 1620, \"to\": 1630}, {\"ngram\": \"the monument\", \"from\": 1654, \"to\": 1666}, {\"ngram\": \"its annual fireworks show\", \"from\": 1676, \"to\": 1701}]}, {\"sentence\": \"After its Bastille Day appearance, the torch relay will swing by Notre Dame Cathedral, the historic Sorbonne university and the Louvre Museum before heading to other Paris landmarks on Monday.\", \"from\": 1712, \"to\": 1904, \"entities\": [{\"begin\": 1812, \"end\": 1831, \"title\": \"http://dbpedia.org/resource/Sorbonne\", \"score\": 0.9978298834525925, \"rank\": 0.0018271519427476856, \"text\": \"Sorbonne university\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Sorbonne\", \"dbpedia\": \"http://dbpedia.org/resource/Sorbonne\"}, {\"begin\": 1840, \"end\": 1853, \"title\": \"http://dbpedia.org/resource/Louvre\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Louvre Museum\", \"types\": [\"Q41176\", \"Q33506\"], \"wikid\": \"http://dbpedia.org/resource/Louvre\", \"dbpedia\": \"http://dbpedia.org/resource/Louvre\"}, {\"begin\": 1878, \"end\": 1883, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.7974917592679916e-16, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"its Bastille Day appearance\", \"from\": 1718, \"to\": 1745}, {\"ngram\": \"the torch relay\", \"from\": 1747, \"to\": 1762}, {\"ngram\": \"Notre Dame Cathedral\", \"from\": 1777, \"to\": 1797}, {\"ngram\": \"Monday\", \"from\": 1897, \"to\": 1903}]}, {\"sentence\": \"This year's Bastille Day offered Macron a moment of distraction from the political turmoil he unleashed with snap elections that weakened his pro-business centrist party and his presidency.\", \"from\": 1906, \"to\": 2095, \"entities\": [{\"begin\": 1939, \"end\": 1945, \"title\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"score\": 1.0, \"rank\": 2.967799409113648e-20, \"text\": \"Macron\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"dbpedia\": \"http://dbpedia.org/resource/Emmanuel_Macron\"}], \"noun_phrases\": [{\"ngram\": \"This year's Bastille Day\", \"from\": 1906, \"to\": 1930}, {\"ngram\": \"a moment\", \"from\": 1946, \"to\": 1954}, {\"ngram\": \"distraction\", \"from\": 1958, \"to\": 1969}, {\"ngram\": \"the political turmoil\", \"from\": 1975, \"to\": 1996}, {\"ngram\": \"snap elections\", \"from\": 2015, \"to\": 2029}, {\"ngram\": \"his pro-business centrist party\", \"from\": 2044, \"to\": 2075}, {\"ngram\": \"his presidency\", \"from\": 2080, \"to\": 2094}]}, {\"sentence\": \"The result left a deadlocked parliament with no one clearly in charge.\", \"from\": 2097, \"to\": 2167, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The result\", \"from\": 2097, \"to\": 2107}, {\"ngram\": \"a deadlocked parliament\", \"from\": 2113, \"to\": 2136}, {\"ngram\": \"no one\", \"from\": 2142, \"to\": 2148}, {\"ngram\": \"charge\", \"from\": 2160, \"to\": 2166}]}, {\"sentence\": \"The prime minister could leave office within days, while the left-wing alliance that won the most seats is struggling to agree on a proposed replacement.\", \"from\": 2169, \"to\": 2322, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The prime minister\", \"from\": 2169, \"to\": 2187}, {\"ngram\": \"office\", \"from\": 2200, \"to\": 2206}, {\"ngram\": \"days\", \"from\": 2214, \"to\": 2218}, {\"ngram\": \"the left-wing alliance\", \"from\": 2226, \"to\": 2248}, {\"ngram\": \"the most seats\", \"from\": 2258, \"to\": 2272}, {\"ngram\": \"a proposed replacement\", \"from\": 2299, \"to\": 2321}]}, {\"sentence\": \"Additional sources\\u2022 AP\", \"from\": 2324, \"to\": 2346, \"entities\": [{\"begin\": 2344, \"end\": 2346, \"title\": \"http://dbpedia.org/resource/Associated_Press\", \"score\": 0.99999984319