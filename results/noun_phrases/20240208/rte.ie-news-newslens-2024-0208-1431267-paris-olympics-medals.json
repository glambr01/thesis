"{\"uid\": \"rte.ie-news-newslens-2024-0208-1431267-paris-olympics-medals\", \"noun_phrases\": [{\"sentence\": \"Medallists at the Paris Olympics will be rewarded with a piece of the Eiffel Tower, organisers have said, as they unveiled the hexagon-shaped medals forged out of scrap metal from the monument.\", \"from\": 0, \"to\": 193, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Medallists\", \"from\": 0, \"to\": 10}, {\"ngram\": \"the Paris Olympics\", \"from\": 14, \"to\": 32}, {\"ngram\": \"a piece\", \"from\": 55, \"to\": 62}, {\"ngram\": \"the Eiffel Tower\", \"from\": 66, \"to\": 82}, {\"ngram\": \"organisers\", \"from\": 84, \"to\": 94}, {\"ngram\": \"the hexagon-shaped medals\", \"from\": 123, \"to\": 148}, {\"ngram\": \"scrap metal\", \"from\": 163, \"to\": 174}, {\"ngram\": \"the monument\", \"from\": 180, \"to\": 192}]}, {\"sentence\": \"The idea was to link the games with symbols of France, said Thierry Reboul, creative director of Paris 2024.\", \"from\": 195, \"to\": 303, \"entities\": [{\"begin\": 242, \"end\": 248, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9990191270500441, \"rank\": 0.0009093612067164208, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 255, \"end\": 262, \"title\": \"http://dbpedia.org/resource/Augustin_Thierry\", \"score\": 1.0, \"rank\": 1.7629042340858768e-16, \"text\": \"Thierry\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Augustin_Thierry\", \"dbpedia\": \"http://dbpedia.org/resource/Augustin_Thierry\"}, {\"begin\": 292, \"end\": 302, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 0.9999999994106474, \"rank\": 5.894343689425365e-10, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"The idea\", \"from\": 195, \"to\": 203}, {\"ngram\": \"the games\", \"from\": 216, \"to\": 225}, {\"ngram\": \"symbols\", \"from\": 231, \"to\": 238}, {\"ngram\": \"creative director\", \"from\": 271, \"to\": 288}]}, {\"sentence\": \"\\\"The absolute symbol of Paris and France is the Eiffel Tower,\\\" said Mr Reboul.\", \"from\": 305, \"to\": 383, \"entities\": [{\"begin\": 329, \"end\": 334, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999977263, \"rank\": 2.342984194350423e-12, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 339, \"end\": 345, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9990191270500441, \"rank\": 0.0009093612067164208, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"The absolute symbol\", \"from\": 306, \"to\": 325}, {\"ngram\": \"the Eiffel Tower\", \"from\": 349, \"to\": 365}, {\"ngram\": \"Mr Reboul\", \"from\": 373, \"to\": 382}]}, {\"sentence\": \"\\\"It's the opportunity for the athletes to bring back a piece of Paris with them.\\\"\", \"from\": 385, \"to\": 466, \"entities\": [{\"begin\": 449, \"end\": 454, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999977263, \"rank\": 2.342984194350423e-12, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"the opportunity\", \"from\": 391, \"to\": 406}, {\"ngram\": \"the athletes\", \"from\": 411, \"to\": 423}, {\"ngram\": \"a piece\", \"from\": 438, \"to\": 445}]}, {\"sentence\": \"Designed by jeweller Chaumet, the 18-gram hexagon tokens, representing the shape of France, are made of iron from past refurbishment