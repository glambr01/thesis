\"}], \"noun_phrases\": [{\"ngram\": \"Johnson-Thompson\", \"from\": 2309, \"to\": 2325}, {\"ngram\": \"Thiam\", \"from\": 2330, \"to\": 2335}, {\"ngram\": \"head\", \"from\": 2350, \"to\": 2354}, {\"ngram\": \"this weekend's Europeans\", \"from\": 2366, \"to\": 2390}]}, {\"sentence\": \"Regarding those rivals, Laureus Academy member Ennis-Hill said: \\\"Anna's coming back from what looks like a pretty bad knee injury.\", \"from\": 2401, \"to\": 2531, \"entities\": [{\"begin\": 2425, \"end\": 2432, \"title\": \"http://dbpedia.org/resource/Laureus_World_Sports_Awards\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Laureus\", \"types\": [\"Q618779\"], \"wikid\": \"http://dbpedia.org/resource/Laureus_World_Sports_Awards\", \"dbpedia\": \"http://dbpedia.org/resource/Laureus_World_Sports_Awards\"}, {\"begin\": 2466, \"end\": 2470, \"title\": \"http://dbpedia.org/resource/Anna_Freud\", \"score\": 0.9987858998580121, \"rank\": 0.0006085595108209281, \"text\": \"Anna\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Anna_Freud\", \"dbpedia\": \"http://dbpedia.org/resource/Anna_Freud\"}], \"noun_phrases\": [{\"ngram\": \"those rivals\", \"from\": 2411, \"to\": 2423}, {\"ngram\": \"a pretty bad knee injury\", \"from\": 2506, \"to\": 2530}]}, {\"sentence\": \"She's building back.\", \"from\": 2532, \"to\": 2552, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"\\\"It's tough to come back into the heptathlon after that and she's a very explosive athlete.\", \"from\": 2554, \"to\": 2645, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the heptathlon\", \"from\": 2584, \"to\": 2598}, {\"ngram\": \"a very explosive athlete\", \"from\": 2620, \"to\": 2644}]}, {\"sentence\": \"And Nafi has had Achilles issues and is trying to win a third consecutive Olympics, which is a massive task.\", \"from\": 2646, \"to\": 2754, \"entities\": [{\"begin\": 2650, \"end\": 2654, \"title\": \"http://dbpedia.org/resource/Nafi_language\", \"s