"{\"uid\": \"jamaicaobserver.com-2024-02-29-paris-olympic-village-ready-time-confidence-grows\", \"noun_phrases\": [{\"sentence\": \"PARIS, France (AFP) - The organisers of the Paris Olympics took possession of the newly built athletes' village on Thursday on schedule, reinforcing growing confidence that they will be ready for the Games.\", \"from\": 0, \"to\": 206, \"entities\": [{\"begin\": 7, \"end\": 13, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9999844256798041, \"rank\": 1.5228181365836548e-05, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"PARIS\", \"from\": 0, \"to\": 5}, {\"ngram\": \"AFP\", \"from\": 15, \"to\": 18}, {\"ngram\": \"The organisers\", \"from\": 22, \"to\": 36}, {\"ngram\": \"the Paris Olympics\", \"from\": 40, \"to\": 58}, {\"ngram\": \"possession\", \"from\": 64, \"to\": 74}, {\"ngram\": \"the newly built athletes' village\", \"from\": 78, \"to\": 111}, {\"ngram\": \"Thursday\", \"from\": 115, \"to\": 123}, {\"ngram\": \"schedule\", \"from\": 127, \"to\": 135}, {\"ngram\": \"growing confidence\", \"from\": 149, \"to\": 167}, {\"ngram\": \"the Games\", \"from\": 196, \"to\": 205}]}, {\"sentence\": \"At an inauguration ceremony in northern Paris, chief organiser Tony Estanguet received a symbolic key for the complex in front of VIPs including President Emmanuel Macron.\", \"from\": 208, \"to\": 379, \"entities\": [{\"begin\": 248, \"end\": 253, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999997726, \"rank\": 3.0057217933871766e-13, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 271, \"end\": 285, \"title\": \"http://dbpedia.org/resource/Tony_Estanguet\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Tony Estanguet\", \"types\": [\"Q729\", \"Q5\", \"Q2