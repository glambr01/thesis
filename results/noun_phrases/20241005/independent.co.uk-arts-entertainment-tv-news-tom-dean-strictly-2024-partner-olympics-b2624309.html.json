.org/resource/Tom_Dean_(swimmer)\", \"score\": 0.9999936593363623, \"rank\": 0.0, \"text\": \"Tom Dean\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Tom_Dean_(swimmer)\", \"dbpedia\": \"http://dbpedia.org/resource/Tom_Dean_(swimmer)\"}], \"noun_phrases\": [{\"ngram\": \"ourPrivacy notice\", \"from\": 405, \"to\": 422}, {\"ngram\": \"the footsteps\", \"from\": 443, \"to\": 456}, {\"ngram\": \"many sportsmen\", \"from\": 460, \"to\": 474}, {\"ngram\": \"a contestant\", \"from\": 489, \"to\": 501}, {\"ngram\": \"this year'sStrictly Come Dancing\", \"from\": 505, \"to\": 537}]}, {\"sentence\": \"The professional swimmer, 24, was announced to participate on the 2024 run of the hit BBC dancing competition on Radio 1 in August, having accidentally confirmed rumours he would be a contestant after reaching the final of the men's 200m individual medley at the ParisOlympics.\", \"from\": 541, \"to\": 818, \"entities\": [{\"begin\": 627, \"end\": 630, \"title\": \"http://dbpedia.org/resource/BBC\", \"score\": 0.9995087267222753, \"rank\": 0.00033199541111708056, \"text\": \"BBC\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/BBC\", \"dbpedia\": \"http://dbpedia.org/resource/BBC\"}], \"noun_phrases\": [{\"ngram\": \"The professional swimmer\", \"from\": 541, \"to\": 565}, {\"ngram\": \"the 2024 run\", \"from\": 603, \"to\": 615}, {\"ngram\": \"Radio\", \"from\": 654, \"to\": 659}, {\"ngram\": \"August\", \"from\": 665, \"to\": 671}, {\"ngram\": \"rumours\", \"from\": 703, \"to\": 710}, {\"ngram\": \"a contestant\", \"from\": 723, \"to\": 735}, {\"ngram\": \"the men's 200m individual medley\", \"from\": 764, \"to\": 796}, {\"ngram\": \"the ParisOlympics\", \"from\": 800, \"to\": 817}]}, {\"sentence\": \"\\\"I am taking part inStrictly Come Dancing2024!\\\"\", \"from\": 820, \"to\": 867, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"part\", \"from\": 833, \"t