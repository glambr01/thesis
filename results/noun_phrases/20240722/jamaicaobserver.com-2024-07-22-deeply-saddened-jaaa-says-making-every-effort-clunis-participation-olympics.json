"{\"uid\": \"jamaicaobserver.com-2024-07-22-deeply-saddened-jaaa-says-making-every-effort-clunis-participation-olympics\", \"noun_phrases\": [{\"sentence\": \"The Jamaica Athletics Administrative Association (JAAA) says it's \\\"making every effort\\\" on behalf of national hammer thrower Nayoka Clunis to have world track and field authorities allow her to participate in the upcoming Paris Olympics.\", \"from\": 0, \"to\": 237, \"entities\": [{\"begin\": 4, \"end\": 48, \"title\": \"http://dbpedia.org/resource/Jamaica_Athletics_Administrative_Association\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Jamaica Athletics Administrative Association\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Jamaica_Athletics_Administrative_Association\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica_Athletics_Administrative_Association\"}, {\"begin\": 222, \"end\": 236, \"title\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Paris Olympics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/1924_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"JAAA\", \"from\": 50, \"to\": 54}, {\"ngram\": \"every effort\", \"from\": 74, \"to\": 86}, {\"ngram\": \"behalf\", \"from\": 91, \"to\": 97}, {\"ngram\": \"national hammer thrower Nayoka Clunis\", \"from\": 101, \"to\": 138}, {\"ngram\": \"world track and field authorities\", \"from\": 147, \"to\": 180}]}, {\"sentence\": \"It made the statement Monday after the Court of Arbitration for Sport's (CAS) Ad Hoc Division rejected Clunis' application to have the CAS hear her case against the JAAA after an administrative blunder by the local body left her name off the list of qualifiers for the Olympic Games.\", \"from\": 239, \"to\": 522, \"entities\": [{\"begin\": 312, \"end\": 315, \"title\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"score\": 1.0, \"rank\": 3.00249593