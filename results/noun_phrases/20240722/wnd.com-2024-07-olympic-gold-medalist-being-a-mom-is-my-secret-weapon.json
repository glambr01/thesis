, \"from\": 901, \"to\": 912}, {\"ngram\": \"those injuries\", \"from\": 943, \"to\": 957}, {\"ngram\": \"setbacks\", \"from\": 962, \"to\": 970}]}, {\"sentence\": \"She added that these setbacks help develop your character.\", \"from\": 1000, \"to\": 1058, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"these setbacks\", \"from\": 1015, \"to\": 1029}, {\"ngram\": \"your character\", \"from\": 1043, \"to\": 1057}]}, {\"sentence\": \"Motherhood helped her to succeed as well.\", \"from\": 1059, \"to\": 1100, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Motherhood\", \"from\": 1059, \"to\": 1069}]}, {\"sentence\": \"Get the hottest, most important news stories on the Internet - delivered FREE to your inbox as soon as they break!\", \"from\": 1102, \"to\": 1216, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the hottest, most important news stories\", \"from\": 1106, \"to\": 1146}, {\"ngram\": \"your inbox\", \"from\": 1183, \"to\": 1193}]}, {\"sentence\": \"Take just 30 seconds and sign up for WND's Email News Alerts!\", \"from\": 1217, \"to\": 1278, \"entities\": [{\"begin\": 1254, \"end\": 1257, \"title\": \"http://dbpedia.org/resource/WorldNetDaily\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"WND\", \"types\": [\"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/WorldNetDaily\", \"dbpedia\": \"http://dbpedia.org/resource/WorldNetDaily\"}], \"noun_phrases\": [{\"ngram\": \"just 30 seconds\", \"from\": 1222, \"to\": 1237}]}, {\"sentence\": \"\\\"[When] I was pregnant in the middle of my journey, I had a child prior to the London games, and I think that a lot of people felt sorry for me when I came back,\\\" she said.\", \"from\": 1280, \"to\": 1452, \"entities\": [{\"begin\": 1359, \"end\": 1365, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9999964648578684, \"rank\": 2.548099784019961e-06, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/r