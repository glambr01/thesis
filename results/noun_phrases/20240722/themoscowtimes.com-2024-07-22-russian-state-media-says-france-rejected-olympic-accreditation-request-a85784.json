"{\"uid\": \"themoscowtimes.com-2024-07-22-russian-state-media-says-france-rejected-olympic-accreditation-request-a85784\", \"noun_phrases\": [{\"sentence\": \"Russia's state news agency RIA NovostisaidMonday that French authorities rejected accreditation requests for its journalist to cover the 2024 Olympic Games in Paris, which are set to kick off later this week.\", \"from\": 0, \"to\": 208, \"entities\": [{\"begin\": 0, \"end\": 6, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999992060755599, \"rank\": 7.768722695738802e-07, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}, {\"begin\": 54, \"end\": 60, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.999428100948905, \"rank\": 0.00035161958251998457, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 159, \"end\": 164, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999764897896, \"rank\": 2.3510190702605314e-08, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"RIA NovostisaidMonday\", \"from\": 27, \"to\": 48}, {\"ngram\": \"accreditation requests\", \"from\": 82, \"to\": 104}, {\"ngram\": \"its journalist\", \"from\": 109, \"to\": 123}, {\"ngram\": \"the 2024 Olympic Games\", \"from\": 133, \"to\": 155}]}, {\"sentence\": \"Five RIA Novosti sports correspondents received identical letters on Sunday informing them that the event organizer, for reasons unknown, had not approved the requests they filed in February, the news agency said.\", \"from\": 210, \"to\": 423, \"entities\": [{\"begin\": 215, \"end\": 226, \"title\": \"http://dbpedia.org/resource/RIA_Novosti\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"RIA Novosti\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/RIA_Novosti\", \"dbpedia\": \"http://dbpedia.org/resource/RIA_Novosti\"}], \"noun_phrases\": [{\"ngram\": \"identical letters\", \"from\": 258, \"to\": 275}, {\"ngram\": \"Sunday\", \"from\": 279, \"to\": 285}, {\"ngram\": \"the event organizer\", \"from\": 306, \"to\": 325}, {\"ngram\": \"reasons\", \"from\": 331, \"to\": 338}, {\"ngram\": \"the requests\", \"from\": 365, \"to\": 377}, {\"ngram\": \"February\", \"from\": 392, \"to\": 400}, {\"ngram\": \"the news agency\", \"from\": 402, \"to\": 417}]}, {\"sentence\": \"France's acting Interior Minister Gerald DarmaninsaidSunday that 4,340 out of nearly 1 million accreditation requests were rejected on grounds including terrorism, disinformation and cyber threats.\", \"from\": 425, \"to\": 622, \"entities\": [{\"begin\": 425, \"end\": 431, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.8039272617790495, \"rank\": 0.24076512479944728, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 441, \"end\": 458, \"title\": \"http://dbpedia.org/resource/Interior_minister\", \"score\": 0.9998756049655599, \"rank\": 0.00012373540709339256, \"text\": \"Interior Minister\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Interior_minister\", \"dbpedia\": \"http://dbpedia.org/resource/Interior_minister\"}, {\"begin\": 459, \"end\": 465, \"title\": \"http://dbpedia.org/resource/Gerald_Ford\", \"score\": 0.9999994628484806, \"rank\": 2.6530791435412525e-07, \"text\": \"Gerald\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Gerald_Ford\", \"dbpedia\": \"http://dbpedia.org/resource/Gerald_Ford\"}], \"noun_phrases\": [{\"ngram\": \"nearly 1 million accreditation requests\", \"from\": 503, \"to\": 542}, {\"ngram\": \"grounds\", \"from\": 560, \"to\": 567}, {\"ngram\": \"terrorism\", \"from\": 578, \"to\": 587}, {\"ngram\": \"disinformation\", \"from\": 589, \"to\": 603}, {\"ngram\": \"cyber threats\", \"from\": 608, \"to\": 621}]}, {\"sentence\": \"Almost 100 of the rejected applications came from Russians, Belarusians and other nationals suspected of being state agents acting asjournalists, technical staff and physiotherapists, Darmanin told the weekly newspaper Le Journal du Dimanche.\", \"from\": 624, \"to\": 866, \"entities\": [{\"begin\": 684, \"end\": 695, \"title\": \"http://dbpedia.org/resource/Belarusians\", \"score\": 0.999999996528004, \"rank\": 3.472103974890988e-09, \"text\": \"Belarusians\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Belarusians\", \"dbpedia\": \"http://dbpedia.org/resource/Belarusians\"}], \"noun_phrases\": [{\"ngram\": \"the rejected applications\", \"from\": 638, \"to\": 663}, {\"ngram\": \"Russians\", \"from\": 674, \"to\": 682}, {\"ngram\": \"other nationals\", \"from\": 700, \"to\": 715}, {\"ngram\": \"state agents acting asjournalists\", \"from\": 735, \"to\": 768}, {\"ngram\": \"technical staff\", \"from\": 770, \"to\": 785}, {\"ngram\": \"physiotherapists\", \"from\": 790, \"to\": 806}, {\"ngram\": \"Darmanin\", \"from\": 808, \"to\": 816}, {\"ngram\": \"the weekly newspaper\", \"from\": 822, \"to\": 842}, {\"ngram\": \"Le Journal\", \"from\": 843, \"to\": 853}, {\"ngram\": \"du Dimanche\", \"from\": 854, \"to\": 865}]}, {\"sentence\": \"\\\"We refused a large number of 'journalists' who claimed to cover the Games.\", \"from\": 868, \"to\": 943, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a large number\", \"from\": 880, \"to\": 894}, {\"ngram\": \"'journalists\", \"from\": 898, \"to\": 910}, {\"ngram\": \"the Games\", \"from\": 933, \"to\": 942}]}, {\"sentence\": \"On the other hand, we have accepted Russians who work for the International Olympic Committee (IOC),\\\" he added.\", \"from\": 944, \"to\": 1055, \"entities\": [{\"begin\": 1006, \"end\": 1043, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee (IOC)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"the other hand\", \"from\": 947, \"to\": 961}, {\"ngram\": \"Russians\", \"from\": 980, \"to\": 988}]}, {\"sentence\": \"The minister clarified that the rejected applicants \\\"may not be there to carry out attacks,\\\" stressing that the Olympics are not under \\\"serious threat\\\" when they start on Friday.\", \"from\": 1057, \"to\": 1235, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The minister\", \"from\": 1057, \"to\": 1069}, {\"ngram\": \"the rejected applicants\", \"from\": 1085, \"to\": 1108}, {\"ngram\": \"attacks\", \"from\": 1140, \"to\": 1147}, {\"ngram\": \"the Olympics\", \"from\": 1165, \"to\": 1177}, {\"ngram\": \"\\\"serious threat\", \"from\": 1192, \"to\": 1207}, {\"ngram\": \"Friday\", \"from\": 1228, \"to\": 1234}]}, {\"sentence\": \"\\\"But in addition to intelligence and traditional espionage, there is the possibility of accessing entry points into computer networks to carry out a cyberattack,\\\" Darmanin said.\", \"from\": 1237, \"to\": 1414, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"addition\", \"from\": 1245, \"to\": 1253}, {\"ngram\": \"intelligence\", \"from\": 1257, \"to\": 1269}, {\"ngram\": \"traditional espionage\", \"from\": 1274, \"to\": 1295}, {\"ngram\": \"the possibility\", \"from\": 1306, \"to\": 1321}, {\"ngram\": \"entry points\", \"from\": 1335, \"to\": 1347}, {\"ngram\": \"computer networks\", \"from\": 1353, \"to\": 1370}, {\"ngram\": \"a cyberattack\", \"from\": 1384, \"to\": 1397}, {\"ngram\": \"Darmanin\", \"from\": 1400, \"to\": 1408}]}, {\"sentence\": \"Earlier in April, France 24 channel commentator Douglas Herbertsaidhis Russian wife and a Russian friend were rejected as volunteers for the 2024 Paris Olympics after failing background checks.\", \"from\": 1416, \"to\": 1609, \"entities\": [{\"begin\": 1506, \"end\": 1513, \"title\": \"http://dbpedia.org/resource/Russian_language\", \"score\": 0.573059748559337, \"rank\": 0.7445701476831923, \"text\": \"Russian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Russian_language\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_language\"}], \"noun_phrases\": [{\"ngram\": \"April\", \"from\": 1427, \"to\": 1432}, {\"ngram\": \"Douglas\", \"from\": 1464, \"to\": 1471}, {\"ngram\": \"volunteers\", \"from\": 1538, \"to\": 1548}, {\"ngram\": \"the 2024 Paris Olympics\", \"from\": 1553, \"to\": 1576}, {\"ngram\": \"background checks\", \"from\": 1591, \"to\": 1608}]}, {\"sentence\": \"A Message from The Moscow Times: Dear readers, We are facing unprecedented challenges.\", \"from\": 1611, \"to\": 1699, \"entities\": [{\"begin\": 1626, \"end\": 1642, \"title\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"The Moscow Times\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"dbpedia\": \"http://dbpedia.org/resource/The_Moscow_Times\"}], \"noun_phrases\": [{\"ngram\": \"Dear readers\", \"from\": 1644, \"to\": 1656}, {\"ngram\": \"unprecedented challenges\", \"from\": 1672, \"to\": 1696}]}, {\"sentence\": \"Russia's Prosecutor General's Office has designated The Moscow Times as an \\\"undesirable\\\" organization, criminalizing our work and putting our staff at risk of prosecution.\", \"from\": 1700, \"to\": 1871, \"entities\": [{\"begin\": 1700, \"end\": 1706, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999992060755599, \"rank\": 7.768722695738802e-07, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}, {\"begin\": 1709, \"end\": 1727, \"title\": \"http://dbpedia.org/resource/Prosecutor-General_of_Russia\", \"score\": 0.9999998607193089, \"rank\": 1.3928032466605467e-07, \"text\": \"Prosecutor General\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Prosecutor-General_of_Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Prosecutor-General_of_Russia\"}, {\"begin\": 1752, \"end\": 1768, \"title\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"The Moscow Times\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"dbpedia\": \"http://dbpedia.org/resource/The_Moscow_Times\"}], \"noun_phrases\": [{\"ngram\": \"an \\\"undesirable\\\" organization\", \"from\": 1772, \"to\": 1801}, {\"ngram\": \"our work\", \"from\": 1817, \"to\": 1825}, {\"ngram\": \"our staff\", \"from\": 1838, \"to\": 1847}, {\"ngram\": \"risk\", \"from\": 1851, \"to\": 1855}, {\"ngram\": \"prosecution\", \"from\": 1859, \"to\": 1870}]}, {\"sentence\": \"This follows our earlier unjust labeling as a \\\"foreign agent.\\\"\", \"from\": 1872, \"to\": 1934, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"our earlier unjust labeling\", \"from\": 1885, \"to\": 1912}, {\"ngram\": \"a \\\"foreign agent\", \"from\": 1916, \"to\": 1932}]}, {\"sentence\": \"These actions are direct attempts to silence independent journalism in Russia.\", \"from\": 1936, \"to\": 2014, \"entities\": [{\"begin\": 2007, \"end\": 2013, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999992060755599, \"rank\": 7.768722695738802e-07, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}], \"noun_phrases\": [{\"ngram\": \"These actions\", \"from\": 1936, \"to\": 1949}, {\"ngram\": \"direct attempts\", \"from\": 1954, \"to\": 1969}, {\"ngram\": \"independent journalism\", \"from\": 1981, \"to\": 2003}]}, {\"sentence\": \"The authorities claim our work \\\"discredits the decisions of the Russian leadership.\\\"\", \"from\": 2015, \"to\": 2099, \"entities\": [{\"begin\": 2079, \"end\": 2086, \"title\": \"http://dbpedia.org/resource/Russian_language\", \"score\": 0.573059748559337, \"rank\": 0.7445701476831923, \"text\": \"Russian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Russian_language\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_language\"}], \"noun_phrases\": [{\"ngram\": \"The authorities\", \"from\": 2015, \"to\": 2030}, {\"ngram\": \"our work\", \"from\": 2037, \"to\": 2045}, {\"ngram\": \"the decisions\", \"from\": 2058, \"to\": 2071}]}, {\"sentence\": \"We see things differently: we strive to provide accurate, unbiased reporting on Russia.\", \"from\": 2100, \"to\": 2187, \"entities\": [{\"begin\": 2180, \"end\": 2186, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999992060755599, \"rank\": 7.768722695738802e-07, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}], \"noun_phrases\": [{\"ngram\": \"things\", \"from\": 2107, \"to\": 2113}, {\"ngram\": \"accurate, unbiased reporting\", \"from\": 2148, \"to\": 2176}]}, {\"sentence\": \"We, the journalists of The Moscow Times, refuse to be silenced.\", \"from\": 2189, \"to\": 2252, \"entities\": [{\"begin\": 2212, \"end\": 2228, \"title\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"The Moscow Times\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"dbpedia\": \"http://dbpedia.org/resource/The_Moscow_Times\"}], \"noun_phrases\": [{\"ngram\": \"the journalists\", \"from\": 2193, \"to\": 2208}]}, {\"sentence\": \"But to continue our work,we need your help.\", \"from\": 2253, \"to\": 2296, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"our work\", \"from\": 2269, \"to\": 2277}, {\"ngram\": \"your help\", \"from\": 2286, \"to\": 2295}]}, {\"sentence\": \"Your support, no matter how small, makes a world of difference.\", \"from\": 2298, \"to\": 2361, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Your support\", \"from\": 2298, \"to\": 2310}, {\"ngram\": \"a world\", \"from\": 2339, \"to\": 2346}, {\"ngram\": \"difference\", \"from\": 2350, \"to\": 2360}]}, {\"sentence\": \"If you can, please support us monthly starting from just$2.It's quick to set up, and every contribution makes a significant impact.\", \"from\": 2362, \"to\": 2493, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"us\", \"from\": 2389, \"to\": 2391}, {\"ngram\": \"every contribution\", \"from\": 2447, \"to\": 2465}, {\"ngram\": \"a significant impact\", \"from\": 2472, \"to\": 2492}]}, {\"sentence\": \"By supporting The Moscow Times, you are defending open, independent journalism in the face of repression.\", \"from\": 2495, \"to\": 2600, \"entities\": [{\"begin\": 2509, \"end\": 2525, \"title\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"The Moscow Times\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"dbpedia\": \"http://dbpedia.org/resource/The_Moscow_Times\"}], \"noun_phrases\": [{\"ngram\": \"open, independent journalism\", \"from\": 2545, \"to\": 2573}, {\"ngram\": \"the face\", \"from\": 2577, \"to\": 2585}, {\"ngram\": \"repression\", \"from\": 2589, \"to\": 2599}]}, {\"sentence\": \"Thank you for standing with us.\", \"from\": 2601, \"to\": 2632, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"us\", \"from\": 2629, \"to\": 2631}]}]}"