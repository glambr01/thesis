}, {\"ngram\": \"high prices\", \"from\": 1370, \"to\": 1381}, {\"ngram\": \"Euro\", \"from\": 1400, \"to\": 1404}]}, {\"sentence\": \"Fans have complained at the 'incomprehensible' levels of security perimeters, with all areas within 100m of the Seine now completely off-limits, according to reports.\", \"from\": 1424, \"to\": 1590, \"entities\": [{\"begin\": 1536, \"end\": 1541, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999930525423545, \"rank\": 6.9475056124728735e-06, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"Fans\", \"from\": 1424, \"to\": 1428}, {\"ngram\": \"the 'incomprehensible' levels\", \"from\": 1448, \"to\": 1477}, {\"ngram\": \"security perimeters\", \"from\": 1481, \"to\": 1500}, {\"ngram\": \"all areas\", \"from\": 1507, \"to\": 1516}, {\"ngram\": \"100m\", \"from\": 1524, \"to\": 1528}, {\"ngram\": \"completely off-limits\", \"from\": 1546, \"to\": 1567}, {\"ngram\": \"reports\", \"from\": 1582, \"to\": 1589}]}, {\"sentence\": \"French police have deployed security cameras on a massive scale and an experimental AI-based video-surveillance system, which has caused controversy.\", \"from\": 1592, \"to\": 1741, \"entities\": [{\"begin\": 1592, \"end\": 1605, \"title\": \"http://dbpedia.org/resource/Law_enforcement_in_France\", \"score\": 1.0, \"rank\": 2.0178377988991293e-30, \"text\": \"French police\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Law_enforcement_in_France\", \"dbpedia\": \"http://dbpedia.org/resource/Law_enforcement_in_France\"}], \"noun_phrases\": [{\"ngram\": \"security cameras\", \"from\": 1620, \"to\": 1636}, {\"ngram\": \"a massive scale\", \"from\": 1640, \"to\": 1655}, {\"ngram\": \"an experimental AI-based video-surveillance system\", \"from\": 1660, \"to\": 1710}, {\"ngram\": \"controversy\", \"from\": 1729, \"to\": 1740}]}, {\"sentence\": \"Hi