 flight\", \"from\": 350, \"to\": 362}]}, {\"sentence\": \"TheOlympic footballand rugby sevens tournaments begin on Wednesday while the handball and archery starts on Thursday ahead of Friday's opening ceremony.\", \"from\": 382, \"to\": 534, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"TheOlympic footballand\", \"from\": 382, \"to\": 404}, {\"ngram\": \"Wednesday\", \"from\": 439, \"to\": 448}, {\"ngram\": \"the handball\", \"from\": 455, \"to\": 467}, {\"ngram\": \"archery\", \"from\": 472, \"to\": 479}, {\"ngram\": \"Thursday\", \"from\": 490, \"to\": 498}, {\"ngram\": \"Friday's opening ceremony\", \"from\": 508, \"to\": 533}]}, {\"sentence\": \"But why are there still over 500,000 unsold tickets for the Paris Games?\", \"from\": 536, \"to\": 608, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"still over 500,000 unsold tickets\", \"from\": 554, \"to\": 587}, {\"ngram\": \"the Paris Games\", \"from\": 592, \"to\": 607}]}, {\"sentence\": \"Read on to find out - and here's everything else to know about landing a last-minute deal\\u2026 Tony Estanguet, the head of the Paris 2024 organising committee, argues that a number of ticket packages have just come available with seating plans only recently finalised - explaining why ticket sales have been so low thus far.\", \"from\": 609, \"to\": 930, \"entities\": [{\"begin\": 701, \"end\": 715, \"title\": \"http://dbpedia.org/resource/Tony_Estanguet\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Tony Estanguet\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Tony_Estanguet\", \"dbpedia\": \"http://dbpedia.org/resource/Tony_Estanguet\"}, {\"begin\": 733, \"end\": 743, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.1435755591307998e-20, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}], 