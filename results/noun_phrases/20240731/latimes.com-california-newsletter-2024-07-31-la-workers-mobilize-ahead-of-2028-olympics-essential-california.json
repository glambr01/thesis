from\": 2402, \"to\": 2421}, {\"ngram\": \"the living wage\", \"from\": 2434, \"to\": 2449}, {\"ngram\": \"these workers\", \"from\": 2454, \"to\": 2467}, {\"ngram\": \"this city\", \"from\": 2502, \"to\": 2511}, {\"ngram\": \"this city\", \"from\": 2525, \"to\": 2534}]}, {\"sentence\": \"One of those workers is Jovan Houston, a passenger service agent at LAX.\", \"from\": 2548, \"to\": 2620, \"entities\": [{\"begin\": 2579, \"end\": 2586, \"title\": \"http://dbpedia.org/resource/Houston\", \"score\": 0.9999999999990905, \"rank\": 9.706422315777116e-13, \"text\": \"Houston\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Houston\", \"dbpedia\": \"http://dbpedia.org/resource/Houston\"}, {\"begin\": 2617, \"end\": 2620, \"title\": \"http://dbpedia.org/resource/Los_Angeles_International_Airport\", \"score\": 1.0, \"rank\": 8.070827463589143e-15, \"text\": \"LAX\", \"types\": [\"Q1248784\"], \"wikid\": \"http://dbpedia.org/resource/Los_Angeles_International_Airport\", \"dbpedia\": \"http://dbpedia.org/resource/Los_Angeles_International_Airport\"}], \"noun_phrases\": [{\"ngram\": \"those workers\", \"from\": 2555, \"to\": 2568}, {\"ngram\": \"a passenger service agent\", \"from\": 2587, \"to\": 2612}]}, {\"sentence\": \"She said her job is stressful and demanding - and she's making just $19.78 an hour.\", \"from\": 2621, \"to\": 2704, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her job\", \"from\": 2630, \"to\": 2637}]}, {\"sentence\": \"\\\"It's like a slap in the face to work so hard for so little pay,\\\" she told me.\", \"from\": 2706, \"to\": 2784, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a slap\", \"from\": 2717, \"to\": 2723}, {\"ngram\": \"the face\", \"from\": 2727, \"to\": 2735}, {\"ngram\": \"so little pay\", \"from\": 2756, \"to\": 2769}]}, {\"sentence\": \"Houston said better wages would allow her to stop living paycheck to paycheck and spend more time with her family.\", \"from\": 2786, \"to\": 2900, \"entitie