18, \"rank\": 1.2325553598594928e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"The Matildas' X account\", \"from\": 1146, \"to\": 1169}, {\"ngram\": \"a heartfelt message\", \"from\": 1177, \"to\": 1196}, {\"ngram\": \"its fans\", \"from\": 1202, \"to\": 1210}, {\"ngram\": \"messages\", \"from\": 1280, \"to\": 1288}, {\"ngram\": \"support\", \"from\": 1292, \"to\": 1299}]}, {\"sentence\": \"\\\"While this four-year journey has ended, another one is just around the corner.\", \"from\": 1302, \"to\": 1381, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this four-year journey\", \"from\": 1309, \"to\": 1331}, {\"ngram\": \"another one\", \"from\": 1343, \"to\": 1354}, {\"ngram\": \"the corner\", \"from\": 1370, \"to\": 1380}]}, {\"sentence\": \"We ask that you stay with us, the Matildas family, as our story continues to unfold,\\\" it wrote.\", \"from\": 1382, \"to\": 1477, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"us\", \"from\": 1408, \"to\": 1410}, {\"ngram\": \"our story\", \"from\": 1436, \"to\": 1445}]}, {\"sentence\": \"Devastated fans shared their heartbreak in response to the post with many saying how proud they were of the team.\", \"from\": 1479, \"to\": 1592, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Devastated fans\", \"from\": 1479, \"to\": 1494}, {\"ngram\": \"their heartbreak\", \"from\": 1502, \"to\": 1518}, {\"ngram\": \"response\", \"from\": 1522, \"to\": 1530}, {\"ngram\": \"the post\", \"from\": 1534, \"to\": 1542}, {\"ngram\": \"the team\", \"from\": 1583, \"to\": 1591}]}, {\"sentence\": \"Thank You, Australia \\u00f0\\u0178\\u00ab\\u00b6\\u00f0\\u0178'\\u0161\\u00f0\\u0178'\\u203aThank you for being with us and lifting us throughout every part of our journey over the past four years.\", \"from\": 1594, \"to\": 1732, \"entities\": [{\"begin\": 1605, \"end\": 1614, \"title\": \"http://d