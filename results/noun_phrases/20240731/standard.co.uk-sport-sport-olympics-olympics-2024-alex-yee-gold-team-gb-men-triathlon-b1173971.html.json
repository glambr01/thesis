dbpedia.org/resource/Paris\", \"score\": 0.9999999987837782, \"rank\": 1.2161203707187874e-09, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 387, \"end\": 392, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.6112613598513272, \"rank\": 0.6359558000509856, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"his run\", \"from\": 259, \"to\": 266}, {\"ngram\": \"perfection\", \"from\": 270, \"to\": 280}, {\"ngram\": \"gold\", \"from\": 288, \"to\": 292}, {\"ngram\": \"dramatic fashion\", \"from\": 332, \"to\": 348}, {\"ngram\": \"the silver\", \"from\": 361, \"to\": 371}]}, {\"sentence\": \"The Briton had looked certain to get silver again or even drop down to bronze at one point as New Zealand's Hayden Wilde pulled 15 seconds clear on the run.\", \"from\": 415, \"to\": 571, \"entities\": [{\"begin\": 415, \"end\": 425, \"title\": \"http://dbpedia.org/resource/The_Briton\", \"score\": 0.999999999990905, \"rank\": 0.0, \"text\": \"The Briton\", \"types\": [\"Q386724\", \"Q25379\", \"Q234460\"], \"wikid\": \"http://dbpedia.org/resource/The_Briton\", \"dbpedia\": \"http://dbpedia.org/resource/The_Briton\"}, {\"begin\": 509, \"end\": 520, \"title\": \"http://dbpedia.org/resource/New_Zealand_national_football_team\", \"score\": 0.6371695615605714, \"rank\": 0.23847029389274163, \"text\": \"New Zealand\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/New_Zealand_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/New_Zealand_national_football_team\"}, {\"begin\": 530, \"end\": 535, \"title\": \"http://dbpedia.org/resource/Oscar_Wilde\", \"score\": 0.9998615919560295, \"rank\": 0.00013633265905090992, \"text\": \"Wilde\", \"types\": [\"Q729\", \"Q5\", \"Q36180\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Oscar_Wilde\", \"dbpedia\": \"http://dbpedia.org/resource/Oscar_Wilde\"}], \"noun_phrases\": [{\"ngram\": \"silver\", \"from\": 452, \"to\": 458}, {\"ngram\": \"bronze\", \"from\": 486, \"to\": 492}, {\"ngram\": \"one point\", \"from\": 496, \"to\": 505}, {\"ngram\": \"the run\", \"from\": 563, \"to\": 570}]}, {\"sentence\": \"But Wilde, who had been well behind in the swim and had to work hard to get back to the leaders on the bike leg, was finally made to pay for that effort in the final metres as Yee surged past to take the gold and live up to his billing as pre-race favourite.\", \"from\": 573, \"to\": 831, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Wilde\", \"from\": 577, \"to\": 582}, {\"ngram\": \"the swim\", \"from\": 612, \"to\": 620}, {\"ngram\": \"the leaders\", \"from\": 657, \"to\": 668}, {\"ngram\": \"the bike leg\", \"from\": 672, \"to\": 684}, {\"ngram\": \"that effort\", \"from\": 714, \"to\": 725}, {\"ngram\": \"the final metres\", \"from\": 729, \"to\": 745}, {\"ngram\": \"Yee\", \"from\": 749, \"to\": 752}, {\"ngram\": \"the gold\", \"from\": 773, \"to\": 781}, {\"ngram\": \"his billing\", \"from\": 797, \"to\": 808}]}, {\"sentence\": \"In 30-degree heat, he sat leaning against the hoardings unable to move, exhausted by his efforts and seemingly dumbfounded by the result and the magnitude of his achievement.\", \"from\": 833, \"to\": 1007, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"30-degree heat\", \"from\": 836, \"to\": 850}, {\"ngram\": \"the hoardings\", \"from\": 875, \"to\": 888}, {\"ngram\": \"his efforts\", \"from\": 918, \"to\": 929}, {\"ngram\": \"the result\", \"from\": 959, \"to\": 969}, {\"ngram\": \"the magnitude\", \"from\": 974, \"to\": 987}, {\"ngram\": \"his achievement\", \"from\": 991, \"to\": 1006}]}, {\"sentence\": \"Hailing from the London borough of Lewisham, he had talked of how his rivals were \\\"natural born killers\\\" while he preferred to remain calm and be in \\\"a flow state\\\".\", \"from\": 1009, \"to\": 1173, \"entities\": [{\"begin\": 1026, \"end\": 1032, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9999997714340031, \"rank\": 2.268994370240271e-07, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}, {\"begin\": 1044, \"end\": 1052, \"title\": \"http://dbpedia.org/resource/Lewisham\", \"score\": 0.9153724047464316, \"rank\": 0.09231834172526258, \"text\": \"Lewisham\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Lewisham\", \"dbpedia\": \"http://dbpedia.org/resource/Lewisham\"}], \"noun_phrases\": [{\"ngram\": \"his rivals\", \"from\": 1075, \"to\": 1085}, {\"ngram\": \"\\\"natural born killers\", \"from\": 1091, \"to\": 1112}, {\"ngram\": \"a flow state\", \"from\": 1159, \"to\": 1171}]}, {\"sentence\": \"In the run, he gave little away either as Wilde pulled clear or as he reeled him in, and it was hard to say whether it was the New Zealander's capitulation or the perfect timing of Yee which accounted for the result - probably a bit of both.\", \"from\": 1175, \"to\": 1416, \"entities\": [{\"begin\": 1217, \"end\": 1222, \"title\": \"http://dbpedia.org/resource/Oscar_Wilde\", \"score\": 0.9998615919560295, \"rank\": 0.00013633265905090992, \"text\": \"Wilde\", \"types\": [\"Q729\", \"Q5\", \"Q36180\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Oscar_Wilde\", \"dbpedia\": \"http://dbpedia.org/resource/Oscar_Wilde\"}], \"noun_phrases\": [{\"ngram\": \"the run\", \"from\": 1178, \"to\": 1185}, {\"ngram\": \"the New Zealander's capitulation\", \"from\": 1298, \"to\": 1330}, {\"ngram\": \"the perfect timing\", \"from\": 1334, \"to\": 1352}, {\"ngram\": \"Yee\", \"from\": 1356, \"to\": 1359}, {\"ngram\": \"the result\", \"from\": 1380, \"to\": 1390}]}, {\"sentence\": \"It followed on from the mixed relay gold he won in Tokyo and ensured he was a double gold medallist at the Games like the athlete who inspired him to take up the sport, Alistair Brownlee.\", \"from\": 1418, \"to\": 1605, \"entities\": [{\"begin\": 1469, \"end\": 1474, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.6112613598513272, \"rank\": 0.6359558000509856, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"the mixed relay gold\", \"from\": 1438, \"to\": 1458}, {\"ngram\": \"a double gold medallist\", \"from\": 1494, \"to\": 1517}, {\"ngram\": \"the Games\", \"from\": 1521, \"to\": 1530}, {\"ngram\": \"the athlete\", \"from\": 1536, \"to\": 1547}, {\"ngram\": \"the sport\", \"from\": 1576, \"to\": 1585}]}, {\"sentence\": \"Aptly, Brownlee, who Yee had first watched as a youngster at London 2012, was among those in the stands here and predicted that his countryman would come away with gold.\", \"from\": 1607, \"to\": 1776, \"entities\": [{\"begin\": 1614, \"end\": 1622, \"title\": \"http://dbpedia.org/resource/Justin_Brownlee\", \"score\": 0.99846513254257, \"rank\": 0.0007940849137269288, \"text\": \"Brownlee\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Justin_Brownlee\", \"dbpedia\": \"http://dbpedia.org/resource/Justin_Brownlee\"}], \"noun_phrases\": [{\"ngram\": \"Yee\", \"from\": 1628, \"to\": 1631}, {\"ngram\": \"a youngster\", \"from\": 1653, \"to\": 1664}, {\"ngram\": \"London\", \"from\": 1668, \"to\": 1674}, {\"ngram\": \"the stands\", \"from\": 1700, \"to\": 1710}, {\"ngram\": \"his countryman\", \"from\": 1735, \"to\": 1749}, {\"ngram\": \"gold\", \"from\": 1771, \"to\": 1775}]}, {\"sentence\": \"But not 