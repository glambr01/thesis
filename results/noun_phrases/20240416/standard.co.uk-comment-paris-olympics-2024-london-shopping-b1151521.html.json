"{\"uid\": \"standard.co.uk-comment-paris-olympics-2024-london-shopping-b1151521.html\", \"noun_phrases\": [{\"sentence\": \"To use the search feature, we need your consent to load Google Custom Search, which may use cookies or similar technologies.\", \"from\": 0, \"to\": 124, \"entities\": [{\"begin\": 56, \"end\": 76, \"title\": \"http://dbpedia.org/resource/Google_Programmable_Search_Engine\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Google Custom Search\", \"types\": [\"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Google_Programmable_Search_Engine\", \"dbpedia\": \"http://dbpedia.org/resource/Google_Programmable_Search_Engine\"}], \"noun_phrases\": [{\"ngram\": \"the search feature\", \"from\": 7, \"to\": 25}, {\"ngram\": \"your consent\", \"from\": 35, \"to\": 47}, {\"ngram\": \"cookies\", \"from\": 92, \"to\": 99}, {\"ngram\": \"similar technologies\", \"from\": 103, \"to\": 123}]}, {\"sentence\": \"Please click 'Allow and Continue' below to enable search.\", \"from\": 125, \"to\": 182, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"search\", \"from\": 175, \"to\": 181}]}, {\"sentence\": \"See our privacy policy for more information.\", \"from\": 183, \"to\": 227, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"our privacy policy\", \"from\": 187, \"to\": 205}, {\"ngram\": \"more information\", \"from\": 210, \"to\": 226}]}, {\"sentence\": \"Comment Get our award-winning daily news email featuring exclusive stories, opinion and expert analysis I would like to be emailed about offers, event and updates from Evening Standard.\", \"from\": 229, \"to\": 418, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Comment\", \"from\": 229, \"to\": 236}, {\"ngram\": \"our award-winning daily news email\", \"from\": 241, \"to\": 275}, {\"ngram\": \"exclusive stories\", \"from\": 286, \"to\": 303}, {\"ngram\": \"opinion\", \"from\": 305, \"to\": 312}, {\"ngram\": \"expert analysis\", \"from\": 317, \"to\": 332}, {\"ngram\": \"offers\", \"from\": 366, \"to\": 372}, {\"ngram\": \"event\", \"from\": 374, \"to\": 379}, {\"ngram\": \"updates\", \"from\": 384, \"to\": 391}, {\"ngram\": \"Evening Standard\", \"from\": 397, \"to\": 413}]}, {\"sentence\": \"Read ourprivacy notice.\", \"from\": 419, \"to\": 442, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"ourprivacy notice\", \"from\": 424, \"to\": 441}]}, {\"sentence\": \"Barely a day goes by without someone prominent proclaiming that this summerLondonis going to be the overspill city of theOlympics.\", \"from\": 444, \"to\": 574, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Barely a day\", \"from\": 444, \"to\": 456}, {\"ngram\": \"someone prominent proclaiming\", \"from\": 473, \"to\": 502}, {\"ngram\": \"the overspill city\", \"from\": 540, \"to\": 558}, {\"ngram\": \"theOlympics\", \"from\": 562, \"to\": 573}]}, {\"sentence\": \"In fact, we havecarried many pieces about it ourselves.\", \"from\": 575, \"to\": 630, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"fact\", \"from\": 578, \"to\": 582}, {\"ngram\": \"many pieces\", \"from\": 599, \"to\": 610}]}, {\"sentence\": \"Come on in, we say, the water's lovely (considering the country's sewage problem, London's drinking water is certainly better than the water inParis), andwe do not have bed bugs!\", \"from\": 631, \"to\": 809, \"entities\": [{\"begin\": 713, \"end\": 719, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9999999999618012, \"rank\": 2.6261572659376696e-11, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}], \"noun_phrases\": [{\"ngram\": \"the country's sewage problem\", \"from\": 683, \"to\": 711}, {\"ngram\": \"the water inParis\", \"from\": 762, \"to\": 779}, {\"ngram\": \"andwe\", \"from\": 782, \"to\": 787}, {\"ngram\": \"bed bugs\", \"from\": 800, \"to\": 808}]}, {\"sentence\": \"Not French ones, anyway.\", \"from\": 810, \"to\": 834, \"entities\": [{\"begin\": 814, \"end\": 820, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9996389860562079, \"rank\": 0.0003296847333508669, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": []}, {\"sentence\": \"And now it's not just Londoners who are saying this, it's the French themselves.\", \"from\": 836, \"to\": 916, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"just Londoners\", \"from\": 853, \"to\": 867}]}, {\"sentence\": \"Last week, B\\u00e9n\\u00e9dicte Epinay, head of the luxury industry group Comite Colbert (which exists solely to promote French luxury brands), said that the Olympics would be a \\\"terrible period for business and culture.\", \"from\": 917, \"to\": 1126, \"entities\": [{\"begin\": 938, \"end\": 944, \"title\": \"http://dbpedia.org/resource/\\u00c9pinay-sur-Seine\", \"score\": 0.99118251903856, \"rank\": 0.0, \"text\": \"Epinay\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/\\u00c9pinay-sur-Seine\", \"dbpedia\": \"http://dbpedia.org/resource/\\u00c9pinay-sur-Seine\"}, {\"begin\": 987, \"end\": 994, \"title\": \"http://dbpedia.org/resource/Stephen_Colbert\", \"score\": 0.9999990362798695, \"rank\": 9.637211494500313e-07, \"text\": \"Colbert\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Stephen_Colbert\", \"dbpedia\": \"http://dbpedia.org/resource/Stephen_Colbert\"}, {\"begin\": 1027, \"end\": 1033, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9996389860562079, \"rank\": 0.0003296847333508669, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"head\", \"from\": 946, \"to\": 950}, {\"ngram\": \"the luxury industry group\", \"from\": 954, \"to\": 979}, {\"ngram\": \"the Olympics\", \"from\": 1060, \"to\": 1072}, {\"ngram\": \"a \\\"terrible period\", \"from\": 1082, \"to\": 1100}, {\"ngram\": \"business\", \"from\": 1105, \"to\": 1113}, {\"ngram\": \"culture\", \"from\": 1118, \"to\": 1125}]}, {\"sentence\": \"There is a big question mark around the event, but one that is tinged with concern.\\\"\", \"from\": 1127, \"to\": 1211, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a big question mark\", \"from\": 1136, \"to\": 1155}, {\"ngram\": \"the event\", \"from\": 1163, \"to\": 1172}, {\"ngram\": \"concern\", \"from\": 1202, \"to\": 1209}]}, {\"sentence\": \"This is a fear shared by many in the luxury sector, worried that a) potential customers are going to be too preoccupied with the event to actually go out and shop, and b) that the vast numbers of Olympic tourists will make the Parisianshoppingexperience even worse than it is already.\", \"from\": 1212, \"to\": 1496, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a fear\", \"from\": 1220, \"to\": 1226}, {\"ngram\": \"the luxury sector\", \"from\": 1245, \"to\": 1262}, {\"ngram\": \"potential customers\", \"from\": 1280, \"to\": 1299}, {\"ngram\": \"the event\", \"from\": 1337, \"to\": 1346}, {\"ngram\": \"the vast numbers\", \"from\": 1388, \"to\": 1404}, {\"ngram\": \"Olympic tourists\", \"from\": 1408, \"to\": 1424}, {\"ngram\": \"the Parisianshoppingexperience\", \"from\": 1435, \"to\": 1465}]}, {\"sentence\": \"One French industry expert told me last week: \\\"Shopping in Paris is going to be a nightmare.\", \"from\": 1497, \"to\": 1589, \"entities\": [{\"begin\": 1501, \"end\": 1507, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9996389860562079, \"rank\": 0.0003296847333508669, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 1556, \"end\": 1561, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.950517326622477e-22, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"a nightmare\", \"from\": 1577, \"to\": 1588}]}, {\"sentence\": \"No one is going to want to have a big cardboard shopping bag banging against their legs when the centre of the city is full of hordes of people in backpacks and shorts.\", \"from\": 1590, \"to\": 1758, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"No one\", \"from\": 1590, \"to\": 1596}, {\"ngram\": \"a big cardboard shopping bag\", \"from\": 1622, \"to\": 1650}, {\"ngram\": \"their legs\", \"from\": 1667, \"to\": 1677}, {\"ngram\": \"the centre\", \"from\": 1683, \"to\": 1693}, {\"ngram\": \"the city\", \"from\": 1697, \"to\": 1705}, {\"ngram\": \"hordes\", \"from\": 1717, \"to\": 1723}, {\"ngram\": \"people\", \"from\": 1727, \"to\": 1733}, {\"ngram\": \"backpacks\", \"from\": 1737, \"to\": 1746}, {\"ngram\": \"shorts\", \"from\": 1751, \"to\": 1757}]}, {\"sentence\": \"It's just not a very French experience.\\\"\", \"from\": 1759, \"to\": 1799, \"entities\": [{\"begin\": 1780, \"end\": 1786, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9996389860562079, \"rank\": 0.0003296847333508669, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": []}, {\"sentence\": \"No one I know is going to the Olympics, as they know it'll be a bunfight.\", \"from\": 1801, \"to\": 1874, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"No one\", \"from\": 1801, \"to\": 1807}, {\"ngram\": \"the Olympics\", \"from\": 1827, \"to\": 1839}, {\"ngram\": \"a bunfight\", \"from\": 1863, \"to\": 1873}]}, {\"sentence\": \"Much better to stay in London Indeed.\", \"from\": 1875, \"to\": 1915, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"London\", \"from\": 1898, \"to\": 1904}]}, {\"sentence\": \"When Parisians are worried about their inability to shop with purpose or style then you really know they are in trouble.\", \"from\": 1916, \"to\": 2036, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Parisians\", \"from\": 1921, \"to\": 1930}, {\"ngram\": \"their inability\", \"from\": 1949, \"to\": 1964}, {\"ngram\": \"purpose\", \"from\": 1978, \"to\": 1985}, {\"ngram\": \"style\", \"from\": 1989, \"to\": 1994}, {\"ngram\": \"trouble\", \"from\": 2028, \"to\": 2035}]}, {\"sentence\": \"Unsurprisingly, London retailers are rubbing their hands with barely disguised glee at the huge opportunities this throws up.\", \"from\": 2037, \"to\": 2162, \"entities\": [{\"begin\": 2053, \"end\": 2059, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9999999999618012, \"rank\": 2.6261572659376696e-11, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}], \"noun_phrases\": [{\"ngram\": \"their hands\", \"from\": 2082, \"to\": 2093}, {\"ngram\": \"barely disguised glee\", \"from\": 2099, \"to\": 2120}, {\"ngram\": \"the huge opportunities\", \"from\": 2124, \"to\": 2146}]}, {\"sentence\": \"Michael Ward, the sagacious managing director of Harrods, expects to have a bumper summer because of the consumer mayhem across the Channel.\", \"from\": 2163, \"to\": 2303, \"entities\": [{\"begin\": 2163, \"end\": 2175, \"title\": \"http://dbpedia.org/resource/School_of_Fish\", \"score\": 0.9999999999986358, \"rank\": 5.818063672774864e-13, \"text\": \"Michael Ward\", \"types\": [\"Q43229\", \"Q24229398\", \"Q215380\"], \"wikid\": \"http://dbpedia.org/resource/School_of_Fish\", \"dbpedia\": \"http://dbpedia.org/resource/School_of_Fish\"}, {\"begin\": 2212, \"end\": 2219, \"title\": \"http://dbpedia.org/resource/Harrods\", \"score\": 1.0, \"rank\": 2.0847764535370054e-29, \"text\": \"Harrods\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Harrods\", \"dbpedia\": \"http://dbpedia.org/resource/Harrods\"}], \"noun_phrases\": [{\"ngram\": \"the sagacious managing director\", \"from\": 2177, \"to\": 2208}, {\"ngram\": \"a bumper summer\", \"from\": 2237, \"to\": 2252}, {\"ngram\": \"the consumer mayhem\", \"from\": 2264, \"to\": 2283}, {\"ngram\": \"the Channel\", \"from\": 2291, \"to\": 2302}]}, {\"sentence\": \"\\\"You can not actually get down Avenue Montaigne for certain weeks of the Olympics,\\\" he said a few days ago, as he did heel kicks all the way down the Brompton Road, throwing his bowler hat in the air and spinning on a sixpence.\", \"from\": 2304, \"to\": 2531, \"entities\": [{\"begin\": 2335, \"end\": 2351, \"title\": \"http://dbpedia.org/resource/Avenue_Montaigne\", \"score\": 1.0, \"rank\": 1.1867825286020498e-42, \"text\": \"Avenue Montaigne\", \"types\": [\"Q34442\"], \"wikid\": \"http://dbpedia.org/resource/Avenue_Montaigne\", \"dbpedia\": \"http://dbpedia.org/resource/Avenue_Montaigne\"}], \"noun_phrases\": [{\"ngram\": \"certain weeks\", \"from\": 2356, \"to\": 2369}, {\"ngram\": \"the Olympics\", \"from\": 2373, \"to\": 2385}, {\"ngram\": \"kicks\", \"from\": 2427, \"to\": 2432}, {\"ngram\": \"the Brompton Road\", \"from\": 2450, \"to\": 2467}, {\"ngram\": \"his bowler hat\", \"from\": 2478, \"to\": 2492}, {\"ngram\": \"the air\", \"from\": 2496, \"to\": 2503}, {\"ngram\": \"a sixpence\", \"from\": 2520, \"to\": 2530}]}, {\"sentence\": \"Just last week, at the opening of theLondon Games Festivalat Coutts, several luxury PRs were talking up the shopping opportunities in London this summer.\", \"from\": 2533, \"to\": 2686, \"entities\": [{\"begin\": 2594, \"end\": 2600, \"title\": \"http://dbpedia.org/resource/Coutts\", \"score\": 1.0, \"rank\": 4.234963461832634e-14, \"text\": \"Coutts\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Coutts\", \"dbpedia\": \"http://dbpedia.org/resource/Coutts\"}, {\"begin\": 2667, \"end\": 2673, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9999999999618012, \"rank\": 2.6261572659376696e-11, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}], \"noun_phrases\": [{\"ngram\": \"the opening\", \"from\": 2552, \"to\": 2563}, {\"ngram\": \"several luxury PRs\", \"from\": 2602, \"to\": 2620}, {\"ngram\": \"the shopping opportunities\", \"from\": 2637, \"to\": 2663}]}, {\"sentence\": \"\\\"It's going to be properly Billy Bonkers,\\\" one said, with a massive Sloane Street smile.\", \"from\": 2687, \"to\": 2775, \"entities\": [{\"begin\": 2720, \"end\": 2727, \"title\": \"http://dbpedia.org/resource/Bonkers_(American_TV_series)\", \"score\": 0.9423231379014564, \"rank\": 0.03980808374527077, \"text\": \"Bonkers\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/Bonkers_(American_TV_series)\", \"dbpedia\": \"http://dbpedia.org/resource/Bonkers_(American_TV_series)\"}], \"noun_phrases\": [{\"ngram\": \"one\", \"from\": 2730, \"to\": 2733}, {\"ngram\": \"a massive Sloane Street smile\", \"from\": 2745, \"to\": 2774}]}, {\"sentence\": \"\\\"No one I know is going to Paris for the Olympics, as they know it'll be a bunfight.\", \"from\": 2776, \"to\": 2860, \"entities\": [{\"begin\": 2803, \"end\": 2808, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.950517326622477e-22, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"No one\", \"from\": 2777, \"to\": 2783}, {\"ngram\": \"the Olympics\", \"from\": 2813, \"to\": 2825}, {\"ngram\": \"a bunfight\", \"from\": 2849, \"to\": 2859}]}, {\"sentence\": \"Much better to stay in London and spend all their money here!\\\"\", \"from\": 2861, \"to\": 2923, \"entities\": [{\"begin\": 2884, \"end\": 2890, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9999999999618012, \"rank\": 2.6261572659376696e-11, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}], \"noun_phrases\": [{\"ngram\": \"all their money\", \"from\": 2901, \"to\": 2916}]}, {\"sentence\": \"They all have a point.\", \"from\": 2925, \"to\": 2947, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a point\", \"from\": 2939, \"to\": 2946}]}, {\"sentence\": \"Luxury shopping should be a luxury experience, which is why the golden age of luxury online retail appears to be fading into the past.\", \"from\": 2948, \"to\": 3082, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Luxury shopping\", \"from\": 2948, \"to\": 2963}, {\"ngram\": \"a luxury experience\", \"from\": 2974, \"to\": 2993}, {\"ngram\": \"the golden age\", \"from\": 3008, \"to\": 3022}, {\"ngram\": \"luxury online retail\", \"from\": 3026, \"to\": 3046}, {\"ngram\": \"the past\", \"from\": 3073, \"to\": 3081}]}, {\"sentence\": \"It's all very well being able to press a few buttons and have a dozen pairs of shoes arrive at your house before you have put your credit card away, but it does not beat the experience of wandering down Bond Street or popping intoSelfridgesand dropping a small fortune (that you probably can not afford) on something bold and glitzy and wonderfully expensive.\", \"from\": 3083, \"to\": 3442, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a few buttons\", \"from\": 3122, \"to\": 3135}, {\"ngram\": \"a dozen pairs\", \"from\": 3145, \"to\": 3158}, {\"ngram\": \"shoes\", \"from\": 3162, \"to\": 3167}, {\"ngram\": \"your house\", \"from\": 3178, \"to\": 3188}, {\"ngram\": \"your credit card\", \"from\": 3209, \"to\": 3225}, {\"ngram\": \"the experience\", \"from\": 3253, \"to\": 3267}, {\"ngram\": \"Bond Street\", \"from\": 3286, \"to\": 3297}, {\"ngram\": \"intoSelfridgesand\", \"from\": 3309, \"to\": 3326}, {\"ngram\": \"a small fortune\", \"from\": 3336, \"to\": 3351}, {\"ngram\": \"something\", \"from\": 3390, \"to\": 3399}]}, {\"sentence\": \"It's called spontaneity.\", \"from\": 3443, \"to\": 3467, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"spontaneity\", \"from\": 3455, \"to\": 3466}]}, {\"sentence\": \"Luxury shopping is not really a considered experience, which is why it's always more fun to go hunting on foot.\", \"from\": 3468, \"to\": 3579, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Luxury shopping\", \"from\": 3468, \"to\": 3483}, {\"ngram\": \"a considered experience\", \"from\": 3498, \"to\": 3521}, {\"ngram\": \"more fun\", \"from\": 3548, \"to\": 3556}, {\"ngram\": \"foot\", \"from\": 3574, \"to\": 3578}]}, {\"sentence\": \"Skateboarding world champion Sky Brown: 'I am going for gold at the Olympics' When are the Paris 2024 Olympics and how can I watch them in the UK?\", \"from\": 3581, \"to\": 3728, \"entities\": [{\"begin\": 3610, \"end\": 3619, \"title\": \"http://dbpedia.org/resource/Sky_Brown\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Sky Brown\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Sky_Brown\", \"dbpedia\": \"http://dbpedia.org/resource/Sky_Brown\"}, {\"begin\": 3725, \"end\": 3727, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9058744134115807, \"rank\": 0.10386858550050469, \"text\": \"UK\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"gold\", \"from\": 3637, \"to\": 3641}, {\"ngram\": \"the Olympics\", \"from\": 3645, \"to\": 3657}, {\"ngram\": \"the Paris\", \"from\": 3668, \"to\": 3677}, {\"ngram\": \"2024 Olympics\", \"from\": 3678, \"to\": 3691}]}, {\"sentence\": \"Paris better than London?\", \