"{\"uid\": \"cbc.ca-news-canada-windsor-documentary-detroit-olympic-games-1.7278678\", \"noun_phrases\": [{\"sentence\": \"A documentary on Detroit's bid to host the Summer Olympic Games in 1968 is being released to coincide with the 2024 games now underway in Paris.\", \"from\": 0, \"to\": 144, \"entities\": [{\"begin\": 17, \"end\": 24, \"title\": \"http://dbpedia.org/resource/Detroit\", \"score\": 1.0, \"rank\": 1.97559089005557e-18, \"text\": \"Detroit\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Detroit\", \"dbpedia\": \"http://dbpedia.org/resource/Detroit\"}, {\"begin\": 138, \"end\": 143, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999999897464482, \"rank\": 1.025357238680566e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"A documentary\", \"from\": 0, \"to\": 13}, {\"ngram\": \"the Summer Olympic Games\", \"from\": 39, \"to\": 63}, {\"ngram\": \"the 2024 games\", \"from\": 107, \"to\": 121}]}, {\"sentence\": \"Detroit's Olympic Uprisingchronicles the divided reaction to the city's Olympic quest.\", \"from\": 146, \"to\": 232, \"entities\": [{\"begin\": 146, \"end\": 153, \"title\": \"http://dbpedia.org/resource/Detroit\", \"score\": 1.0, \"rank\": 1.97559089005557e-18, \"text\": \"Detroit\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Detroit\", \"dbpedia\": \"http://dbpedia.org/resource/Detroit\"}], \"noun_phrases\": [{\"ngram\": \"the divided reaction\", \"from\": 183, \"to\": 203}, {\"ngram\": \"the city's Olympic quest\", \"from\": 207, \"to\": 231}]}, {\"sentence\": \"Writer and producer Silke Weineck said one point the documentary hopes to make is that 1963 - the year the bid for the 1968 Olympics was made - was a watershed moment that did not happen.\", \"from\": 234, \"to\": 421, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Writer\", \"from\": 234, \"to\": 240}, {\"ngram\": \"producer Silke Weineck\", \"from\": 245, \"to\": 267}, {\"ngram\": \"one point\", \"from\": 273, \"to\": 282}, {\"ngram\": \"the documentary\", \"from\": 283, \"to\": 298}, {\"ngram\": \"the year\", \"from\": 328, \"to\": 336}, {\"ngram\": \"the bid\", \"from\": 337, \"to\": 344}, {\"ngram\": \"the 1968 Olympics\", \"from\": 349, \"to\": 366}, {\"ngram\": \"a watershed moment\", \"from\": 382, \"to\": 400}]}, {\"sentence\": \"\\\"The bid for the Olympics was a chance to really rethink how the city worked and to finally make it more just,\\\" Weineck said onWindsor Morning.\", \"from\": 423, \"to\": 566, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The bid\", \"from\": 424, \"to\": 431}, {\"ngram\": \"the Olympics\", \"from\": 436, \"to\": 448}, {\"ngram\": \"a chance\", \"from\": 453, \"to\": 461}, {\"ngram\": \"the city\", \"from\": 484, \"to\": 492}, {\"ngram\": \"Weineck\", \"from\": 535, \"to\": 542}]}, {\"sentence\": \"\\\"One problem with the bid was that the Black community was not sufficiently involved and one young group of activists - and that's kind of the centre of our film - decides to mount a protest, saying Detroit is not worthy to host an event dedicated to universal brotherhood.\\\"\", \"from\": 568, \"to\": 842, \"entities\": [{\"begin\": 767, \"end\": 774, \"title\": \"http://dbpedia.org/resource/Detroit\", \"score\": 1.0, \"rank\": 1.97559089005557e-18, \"text\": \"Detroit\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Detroit\", \"dbpedia\": \"http://dbpedia.org/resource/Detroit\"}], \"noun_phrases\": [{\"ngram\": \"One problem\", \"from\": 569, \"to\": 580}, {\"ngram\": \"the bid\", \"from\": 586, \"to\": 593}, {\"ngram\": \"the Black community\", \"from\": 603, \"to\": 622}, {\"ngram\": \"one young group\", \"from\": 657, \"to\": 672}, {\"ngram\": \"activists\", \"from\": 676, \"to\": 685}, {\"ngram\": \"kind of the centre\", \"from\": 699, \"to\": 717}, {\"ngram\": \"our film\", \"from\": 721, \"to\": 729}, {\"ngram\": \"a protest\", \"from\": 749, \"to\": 758}, {\"ngram\": \"an event\", \"from\": 797, \"to\": 805}, {\"ngram\": \"universal brotherhood\", \"from\": 819, \"to\": 840}]}, {\"sentence\": \"Weineck said the film reveals the tensions between the people who were saying \\\"Detroit [is the] best city on earth, we must have the Olympics here,\\\" and those who were saying, \\\"wait a minute.\\\"\", \"from\": 844, \"to\": 1036, \"entities\": [{\"begin\": 923, \"end\": 930, \"title\": \"http://dbpedia.org/resource/Detroit\", \"score\": 1.0, \"rank\": 1.97559089005557e-18, \"text\": \"Detroit\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Detroit\", \"dbpedia\": \"http://dbpedia.org/resource/Detroit\"}], \"noun_phrases\": [{\"ngram\": \"the film\", \"from\": 857, \"to\": 865}, {\"ngram\": \"the tensions\", \"from\": 874, \"to\": 886}, {\"ngram\": \"the people\", \"from\": 895, \"to\": 905}, {\"ngram\": \"the] best city\", \"from\": 935, \"to\": 949}, {\"ngram\": \"earth\", \"from\": 953, \"to\": 958}, {\"ngram\": \"the Olympics\", \"from\": 973, \"to\": 985}]}, {\"sentence\": \"According to Weineck, the documentary includes \\\"some fabulous historic footage,\\\" including United States senator Mitt Romney's father, George Romney, who was the governor of Michigan, going all in on the bid.\", \"from\": 1038, \"to\": 1246, \"entities\": [{\"begin\": 1129, \"end\": 1150, \"title\": \"http://dbpedia.org/resource/United_States_Senate\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"United States senator\", \"types\": [\"Q43229\", \"Q24229398\", \"Q11204\"], \"wikid\": \"http://dbpedia.org/resource/United_States_Senate\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_Senate\"}, {\"begin\": 1151, \"end\": 1162, \"title\": \"http://dbpedia.org/resource/Mitt_Romney\", \"score\": 0.9999674583788696, \"rank\": 3.254096463290667e-05, \"text\": \"Mitt Romney\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Mitt_Romney\", \"dbpedia\": \"http://dbpedia.org/resource/Mitt_Romney\"}, {\"begin\": 1173, \"end\": 1186, \"title\": \"http://dbpedia.org/resource/George_W._Romney\", \"score\": 1.0, \"rank\": 1.8706826512241633e-39, \"text\": \"George Romney\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/George_W._Romney\", \"dbpedia\": \"http://dbpedia.org/resource/George_W._Romney\"}, {\"begin\": 1212, \"end\": 1220, \"title\": \"http://dbpedia.org/resource/Michigan\", \"score\": 0.9988345224354922, \"rank\": 0.0011668373256842719, \"text\": \"Michigan\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Michigan\", \"dbpedia\": \"http://dbpedia.org/resource/Michigan\"}], \"noun_phrases\": [{\"ngram\": \"Weineck\", \"from\": 1051, \"to\": 1058}, {\"ngram\": \"the documentary\", \"from\": 1060, \"to\": 1075}, {\"ngram\": \"some fabulous historic footage\", \"from\": 1086, \"to\": 1116}, {\"ngram\": \"the governor\", \"from\": 1196, \"to\": 1208}, {\"ngram\": \"the bid\", \"from\": 1238, \"to\": 1245}]}, {\"sentence\": \"There is also footage of Frederick Matthaei, an industrialist and the driving figure behind all of the bids starting in the late 30s, she said.\", \"from\": 1247, \"to\": 1390, \"entities\": [{\"begin\": 1272, \"end\": 1281, \"title\": \"http://dbpedia.org/resource/Frederick_the_Great\", \"score\": 1.0, \"rank\": 9.600634639259373e-22, \"text\": \"Frederick\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Frederick_the_Great\", \"dbpedia\": \"http://dbpedia.org/resource/Frederick_the_Great\"}, {\"begin\": 1282, \"end\": 1290, \"title\": \"http://dbpedia.org/resource/Christian_Frederick_Matthaei\", \"score\": 0.9992583856026849, \"rank\": 0.0007421647945113615, \"text\": \"Matthaei\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Christian_Frederick_Matthaei\", \"dbpedia\": \"http://dbpedia.org/resource/Christian_Frederick_Matthaei\"}], \"noun_phrases\": [{\"ngram\": \"footage\", \"from\": 1261, \"to\": 1268}, {\"ngram\": \"an industrialist\", \"from\": 1292, \"to\": 1308}, {\"ngram\": \"the driving figure\", \"from\": 1313, \"to\": 1331}, {\"ngram\": \"the bids\", \"from\": 1346, \"to\": 1354}, {\"ngram\": \"the late 30s\", \"from\": 1367, \"to\": 1379}]}, {\"sentence\": \"\\\"We show these guys hustling and boosting Detroit and being very, very happy about having now mounted the best bid in history, they are pretty sure they are going to get it this time,\\\" Weineck said.\", \"from\": 1392, \"to\": 1590, \"entities\": [{\"begin\": 1434, \"end\": 1441, \"title\": \"http://dbpedia.org/resource/Detroit\", \"score\": 1.0, \"rank\": 1.97559089005557e-18, \"text\": \"Detroit\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Detroit\", \"dbpedia\": \"http://dbpedia.org/resource/Detroit\"}], \"noun_phrases\": [{\"ngram\": \"these guys\", \"from\": 1401, \"to\": 1411}, {\"ngram\": \"the best bid\", \"from\": 1494, \"to\": 1506}, {\"ngram\": \"history\", \"from\": 1510, \"to\": 1517}, {\"ngram\": \"Weineck\", \"from\": 1577, \"to\": 1584}]}, {\"sentence\": \"\\\"We talk a little bit about what Detroit was like in the early 60s \\u2026 and we are trying to build that contrast between, on the one hand, an industrial city starting its decline, but still very wealthy, and the Black population, which suffers from housing discrimination, economic inequality [and] police brutality.\\\"\", \"from\": 1592, \"to\": 1906, \"entities\": [{\"begin\": 1625, \"end\": 1632, \"title\": \"http://dbpedia.org/resource/Detroit\", \"score\": 1.0, \"rank\": 1.97559089005557e-18, \"text\": \"Detroit\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Detroit\", \"dbpedia\": \"http://dbpedia.org/resource/Detroit\"}], \"noun_phrases\": [{\"ngram\": \"the early 60s\", \"from\": 1645, \"to\": 1658}, {\"ngram\": \"that contrast\", \"from\": 1688, \"to\": 1701}, {\"ngram\": \"the one hand\", \"from\": 1714, \"to\": 1726}, {\"ngram\": \"an industrial city\", \"from\": 1728, \"to\": 1746}, {\"ngram\": \"its decline\", \"from\": 1756, \"to\": 1767}, {\"ngram\": \"the Black population\", \"from\": 1797, \"to\": 1817}, {\"ngram\": \"housing discrimination\", \"from\": 1838, \"to\": 1860}, {\"ngram\": \"economic inequality [and] police brutality\", \"from\": 1862, \"to\": 1904}]}, {\"sentence\": \"Weineck said two events in the summer of 1963 negatively impacted Detroit's bid.\", \"from\": 1908, \"to\": 1988, \"entities\": [{\"begin\": 1974, \"end\": 1981, \"title\": \"http://dbpedia.org/resource/Detroit\", \"score\": 1.0, \"rank\": 1.97559089005557e-18, \"text\": \"Detroit\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Detroit\", \"dbpedia\": \"http://dbpedia.org/resource/Detroit\"}], \"noun_phrases\": [{\"ngram\": \"two events\", \"from\": 1921, \"to\": 1931}, {\"ngram\": \"the summer\", \"from\": 1935, \"to\": 1945}]}, {\"sentence\": \"First, Cynthia Scott - a 24-year-old African American woman - was shot on the streets by a policeman, Theodore Spicher.\", \"from\": 1989, \"to\": 2108, \"entities\": [{\"begin\": 2026, \"end\": 2042, \"title\": \"http://dbpedia.org/resource/African_Americans\", \"score\": 0.9999966300422269, \"rank\": 3.3699676769358676e-06, \"text\": \"African American\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/African_Americans\", \"dbpedia\": \"http://dbpedia.org/resource/African_Americans\"}], \"noun_phrases\": [{\"ngram\": \"Cynthia Scott\", \"from\": 1996, \"to\": 2009}, {\"ngram\": \"the streets\", \"from\": 2063, \"to\": 2074}, {\"ngram\": \"a policeman\", \"from\": 2078, \"to\": 2089}, {\"ngram\": \"Theodore Spicher\", \"from\": 2091, \"to\": 2107}]}, {\"sentence\": \"And while it wasn't the first police killing in Detroit, it \\\"really galvanized people because it was covered up within one day.\\\"\", \"from\": 2109, \"to\": 2237, \"entities\": [{\"begin\": 2157, \"end\": 2164, \"title\": \"http://dbpedia.org/resource/Detroit\", \"score\": 1.0, \"rank\": 1.97559089005557e-18, \"text\": \"Detroit\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Detroit\", \"dbpedia\": \"http://dbpedia.org/resource/Detroit\"}], \"noun_phrases\": [{\"ngram\": \"people\", \"from\": 2188, \"to\": 2194}, {\"ngram\": \"one day\", \"from\": 2228, \"to\": 2235}]}, {\"sentence\": \"Secondly, she said, just before the Detroit delegation leaves for Germany to present their bid to the International Olympic Committee, city council voted seven to two to maintain formal racial segregation in housing.\", \"from\": 2239, \"to\": 2455, \"entities\": [{\"begin\": 2275, \"end\": 2282, \"title\": \"http://dbpedia.org/resource/Detroit\", \"score\": 1.0, \"rank\": 1.97559089005557e-18, \"text\": \"Detroit\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Detroit\", \"dbpedia\": \"http://dbpedia.org/resource/Detroit\"}, {\"begin\": 2305, \"end\": 2312, \"title\": \"http://dbpedia.org/resource/Germany\", \"score\": 0.7191143269584002, \"rank\": 0.3899612734264525, \"text\": \"Germany\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Germany\", \"dbpedia\": \"http://dbpedia.org/resource/Germany\"}, {\"begin\": 2341, \"end\": 2372, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"their bid\", \"from\": 2324, \"to\": 2333}, {\"ngram\": \"city council\", \"from\": 2374, \"to\": 2386}, {\"ngram\": \"formal racial segregation\", \"from\": 2418, \"to\": 2443}, {\"ngram\": \"housing\", \"from\": 2447, \"to\": 2454}]}, {\"sentence\": \"\\\"It was shocking.\", \"from\": 2457, \"to\": 2474, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"And so people were really, really mad.\", \"from\": 2475, \"to\": 2513, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"people\", \"from\": 2482, \"to\": 2488}]}, {\"sentence\": \"So when they go to Baden-Baden, they thought they would go and triumph, but \\u2026 there were a lot of letters from Black Detroiters to the International Olympic Committee saying this city is not ready.\\\"\", \"from\": 2514, \"to\": 2712, \"entities\": [{\"begin\": 2533, \"end\": 2544, \"title\": \"http://dbpedia.org/resource/Baden-Baden\", \"score\": 0.9999999970277713, \"rank\": 2.9696622424424397e-09, \"text\": \"Baden-Baden\", \"types\": [\"Q486972\", \"Q3957\"], \"wikid\": \"http://dbpedia.org/resource/Baden-Baden\", \"dbpedia\": \"http://dbpedia.org/resource/Baden-Baden\"}, {\"begin\": 2625, \"end\": 2630, \"title\": \"http://dbpedia.org/resource/African_Americans\", \"score\": 0.9961932887016959, \"rank\": 0.003821217719933456, \"text\": \"Black\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/African_Americans\", \"dbpedia\": \"http://dbpedia.org/resource/African_Americans\"}, {\"begin\": 2631, \"end\": 2641, \"title\": \"http://dbpedia.org/resource/Detroiters_(TV_series)\", \"score\": 0.9588348365752419, \"rank\": 0.0, \"text\": \"Detroiters\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/Detroiters_(TV_series)\", \"dbpedia\": \"http://dbpedia.org/resource/Detroiters_(TV_series)\"}, {\"begin\": 2649, \"end\": 2680, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"a lot\", \"from\": 2603, \"to\": 2608}, {\"ngram\": \"letters\", \"from\": 2612, \"to\": 2619}, {\"ngram\": \"this city\", \"from\": 2688, \"to\": 2697}]}, {\"sentence\": \"Detroit has made a total of nine bids to host the Olympics: 1940, 1944, 1948, 1952, 1956, 1960, 1964, 1968, 1972.\", \"from\": 2714, \"to\": 2827, \"entities\": [{\"begin\": 2714, \"end\": 2721, \"title\": \"http://dbpedia.org/resource/Detroit\", \"score\": 1.0, \"rank\": 1.97559089005557e-18, \"text\": \"Detroit\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Detroit\", \"dbpedia\": \"http://dbpedia.org/resource/Detroit\"}], \"noun_phrases\": [{\"ngram\": \"a total\", \"from\": 2731, \"to\": 2738}, {\"ngram\": \"nine bids\", \"from\": 2742, \"to\": 2751}, {\"ngram\": \"the Olympics\", \"from\": 2760, \"to\": 2772}]}, {\"sentence\": \"Stefan Szymanski, the film's director, said Detroit was one of the most iconic cities on the planet in 1963, so it was not an oddity that people thought it was natural that this city might reasonably expect to host the Olympic Games.\", \"from\": 2829, \"to\": 3062, \"entities\": [{\"begin\": 2829, \"end\": 2835, \"title\": \"http://dbpedia.org/resource/Stefan_Salvatore\", \"score\": 0.9999999163651445, \"rank\": 8.363491951443351e-08, \"text\": \"Stefan\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Stefan_Salvatore\", \"dbpedia\": \"http://dbpedia.org/resource/Stefan_Salvatore\"}, {\"begin\": 2873, \"end\": 2880, \"title\": \"http://dbpedia.org/resource/Detroit\", \"score\": 1.0, \"rank\": 1.97559089005557e-18, \"text\": \"Detroit\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Detroit\", \"dbpedia\": \"http://dbpedia.org/resource/Detroit\"}], \"noun_phrases\": [{\"ngram\": \"the film's director\", \"from\": 2847, \"to\": 2866}, {\"ngram\": \"the most iconic cities\", \"from\": 2892, \"to\": 2914}, {\"ngram\"