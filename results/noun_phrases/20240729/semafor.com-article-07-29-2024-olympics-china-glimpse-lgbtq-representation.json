 512}]}, {\"sentence\": \"Afterward, the topics \\u00e2\\u0080\\u009cCCTV is silent\\u00e2\\u0080\\u009d and \\u00e2\\u0080\\u009cdrag queens\\u00e2\\u0080\\u009d trended on Chinese social media platform Weibo for a full day alongsidevideo clipsof the live broadcast from Paris.\", \"from\": 522, \"to\": 702, \"entities\": [{\"begin\": 598, \"end\": 605, \"title\": \"http://dbpedia.org/resource/Chinese_language\", \"score\": 0.9056731559251735, \"rank\": 0.09241827086490584, \"text\": \"Chinese\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Chinese_language\", \"dbpedia\": \"http://dbpedia.org/resource/Chinese_language\"}, {\"begin\": 696, \"end\": 701, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999994012227463, \"rank\": 5.987776979846194e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"the topics\", \"from\": 533, \"to\": 543}, {\"ngram\": \"\\u00e2\\u0080\\u009cCCTV\", \"from\": 544, \"to\": 551}, {\"ngram\": \"silent\\u00e2\\u0080\\u009d\", \"from\": 555, \"to\": 564}, {\"ngram\": \"\\u00e2\\u0080\\u009cdrag\", \"from\": 569, \"to\": 576}, {\"ngram\": \"queens\\u00e2\\u0080\\u009d\", \"from\": 577, \"to\": 586}, {\"ngram\": \"a full day\", \"from\": 638, \"to\": 648}, {\"ngram\": \"alongsidevideo\", \"from\": 649, \"to\": 663}, {\"ngram\": \"the live broadcast\", \"from\": 672, \"to\": 690}]}, {\"sentence\": \"Some users lamented missing the broadcast, which aired during the night in China, while others praised the Olympics for the display of diversity.\", \"from\": 704, \"to\": 849, \"entities\": [{\"begin\": 779, \"end\": 784, \"title\": \"http://dbpedia.org/resource/Mainland_China\", \"score\": 0.9863533965212785, \"rank\": 0.01285547715364084, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Mainland_China\", \"dbpedia\": \"http://dbpedia.org/re