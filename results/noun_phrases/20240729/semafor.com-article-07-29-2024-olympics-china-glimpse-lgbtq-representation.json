om\": 1253, \"to\": 1446, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The government\", \"from\": 1253, \"to\": 1267}, {\"ngram\": \"college-run LGBTQ clubs\", \"from\": 1279, \"to\": 1302}, {\"ngram\": \"social media accounts\", \"from\": 1314, \"to\": 1335}, {\"ngram\": \"an online war\", \"from\": 1347, \"to\": 1360}, {\"ngram\": \"\\u00e2\\u0080\\u009ceffeminate men\", \"from\": 1369, \"to\": 1386}, {\"ngram\": \"LGBTQ people\", \"from\": 1416, \"to\": 1428}, {\"ngram\": \"public life\", \"from\": 1434, \"to\": 1445}]}, {\"sentence\": \"\\u00e2\\u0080\\u009cDespite morerestrictions on LGBT+ advocacy in China, the community has shown resilience,\\u00e2\\u0080\\u009d Yuhsuan Chien, a China Dissent Monitor analyst, told Nikkei Aasia earlier this year, noting that government pressure has made online advocacy more common.\", \"from\": 1447, \"to\": 1696, \"entities\": [{\"begin\": 1478, \"end\": 1482, \"title\": \"http://dbpedia.org/resource/LGBT\", \"score\": 0.999919986237806, \"rank\": 7.627380163626352e-05, \"text\": \"LGBT\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/LGBT\", \"dbpedia\": \"http://dbpedia.org/resource/LGBT\"}, {\"begin\": 1496, \"end\": 1501, \"title\": \"http://dbpedia.org/resource/Mainland_China\", \"score\": 0.9863533965212785, \"rank\": 0.01285547715364084, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Mainland_China\", \"dbpedia\": \"http://dbpedia.org/resource/Mainland_China\"}, {\"begin\": 1559, \"end\": 1564, \"title\": \"http://dbpedia.org/resource/Mainland_China\", \"score\": 0.9863533965212785, \"rank\": 0.01285547715364084, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Mainland_China\", \"dbpedia\": \"http://dbpedia.org/resource/Mainland_China\"}, {\"begin\": 1595, \"end\": 1601, \"title\": \"http://dbpedia.org/resource/Japanese_diaspora\", \"score\": 0.9679049721380245, \"rank\": 0.019604636115519592, \"text\": \"Nikkei\", \"types\": 