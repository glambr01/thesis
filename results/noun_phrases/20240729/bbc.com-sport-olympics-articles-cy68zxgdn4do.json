Olympics\"}], \"noun_phrases\": [{\"ngram\": \"The controversial ruling\", \"from\": 2236, \"to\": 2260}, {\"ngram\": \"Canter\", \"from\": 2269, \"to\": 2275}, {\"ngram\": \"British equestrian\", \"from\": 2283, \"to\": 2301}, {\"ngram\": \"a review\", \"from\": 2355, \"to\": 2363}]}, {\"sentence\": \"Collett's individual Olympic record display contributed towards a team Olympic record in the dressage on the opening day of competition, but the cross-country result meant GB began the final eventing phase under pressure from the hosts.\", \"from\": 2438, \"to\": 2674, \"entities\": [{\"begin\": 2610, \"end\": 2612, \"title\": \"http://dbpedia.org/resource/Great_Britain\", \"score\": 0.9912217540250741, \"rank\": 0.008855983533939675, \"text\": \"GB\", \"types\": [\"Q23442\"], \"wikid\": \"http://dbpedia.org/resource/Great_Britain\", \"dbpedia\": \"http://dbpedia.org/resource/Great_Britain\"}], \"noun_phrases\": [{\"ngram\": \"Collett's individual Olympic record display\", \"from\": 2438, \"to\": 2481}, {\"ngram\": \"a team Olympic record\", \"from\": 2502, \"to\": 2523}, {\"ngram\": \"the dressage\", \"from\": 2527, \"to\": 2539}, {\"ngram\": \"the opening day\", \"from\": 2543, \"to\": 2558}, {\"ngram\": \"competition\", \"from\": 2562, \"to\": 2573}, {\"ngram\": \"the cross-country result\", \"from\": 2579, \"to\": 2603}, {\"ngram\": \"the final eventing phase\", \"from\": 2619, \"to\": 2643}, {\"ngram\": \"pressure\", \"from\": 2650, \"to\": 2658}, {\"ngram\": \"the hosts\", \"from\": 2664, \"to\": 2673}]}, {\"sentence\": \"However, in Monday's medal decider the British team produced a superb finish to celebrate another golden moment, and comfortably in the end.\", \"from\": 2676, \"to\": 2816, \"entities\": [{\"begin\": 2715, \"end\": 2722, \"title\": \"http://dbpedia.org/resource/British_Boxing_Board_of_Control\", \"score\": 0.9992469671481418, \"rank\": 0.0005665807390896253, \"text\": \"British\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/British