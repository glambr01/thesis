 2524, \"entities\": [{\"begin\": 2353, \"end\": 2359, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999995610845471, \"rank\": 4.2633124695738313e-07, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}, {\"begin\": 2362, \"end\": 2380, \"title\": \"http://dbpedia.org/resource/Prosecutor-General_of_Russia\", \"score\": 0.9999999999479314, \"rank\": 5.197108148981452e-11, \"text\": \"Prosecutor General\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Prosecutor-General_of_Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Prosecutor-General_of_Russia\"}, {\"begin\": 2405, \"end\": 2421, \"title\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"The Moscow Times\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"dbpedia\": \"http://dbpedia.org/resource/The_Moscow_Times\"}], \"noun_phrases\": [{\"ngram\": \"an \\\"undesirable\\\" organization\", \"from\": 2425, \"to\": 2454}, {\"ngram\": \"our work\", \"from\": 2470, \"to\": 2478}, {\"ngram\": \"our staff\", \"from\": 2491, \"to\": 2500}, {\"ngram\": \"risk\", \"from\": 2504, \"to\": 2508}, {\"ngram\": \"prosecution\", \"from\": 2512, \"to\": 2523}]}, {\"sentence\": \"This follows our earlier unjust labeling as a \\\"foreign agent.\\\"\", \"from\": 2525, \"to\": 2587, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"our earlier unjust labeling\", \"from\": 2538, \"to\": 2565}, {\"ngram\": \"a \\\"foreign agent\", \"from\": 2569, \"to\": 2585}]}, {\"sentence\": \"These actions are direct attempts to silence independent journalism in Russia.\", \"from\": 2589, \"to\": 2667, \"entities\": [{\"begin\": 2660, \"end\": 2666, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999995610845471, \"rank\": 4.2633124695738313e-07, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}], \"noun_phrases\": [{\"ngram\": \"These actions\", \"from\": 2589, \"to\": 2602}, {\"ngram\": \"direct attempts\", \"from\": 2607, \"to\": 2622}, {\"ngram\": \"independent journalism\", \"from\": 2634, \"to\": 2656}]}, {\"sentence\": \"The authorities claim our work \\\"discredits the decisions of the Russian leadership.\\\"\", \"from\": 2668, \"to\": 2752, \"entities\": [{\"begin\": 2732, \"end\": 2739, \"title\": \"http://dbpedia.org/resource/Russian_Armed_Forces\", \"score\": 0.7897390408658723, \"rank\": 0.2661737468049453, \"text\": \"Russian\", \"types\": [\"Q43229\", \"Q24229398\", \"Q176799\"], \"wikid\": \"http://dbpedia.org/resource/Russian_Armed_Forces\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_Armed_Forces\"}], \"noun_phrases\": [{\"ngram\": \"The authorities\", \"from\": 2668, \"to\": 2683}, {\"ngram\": \"our work\", \"from\": 2690, \"to\": 2698}, {\"ngram\": \"the decisions\", \"from\": 2711, \"to\": 2724}]}, {\"sentence\": \"We see things differently: we strive to provide accurate, unbiased reporting on Russia.\", \"from\": 2753, \"to\": 2840, \"entities\": [{\"begin\": 2833, \"end\": 2839, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999995610845471, \"rank\": 4.2633124695738313e-07, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}], \"noun_phrases\": [{\"ngram\": \"things\", \"from\": 2760, \"to\": 2766}, {\"ngram\": \"accurate, unbiased reporting\", \"from\": 2801, \"to\": 2829}]}, {\"sentence\": \"We, the journalists of The Moscow Times, refuse to be silenced.\", \"from\": 2842, \"to\": 2905, \"entities\": [{\"begin\": 2865, \"end\": 2881, \"title\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"The Moscow Times\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"dbpedia\": \"http://dbpedia.org/resource/The_Moscow_Times\"}], \"noun_phrases\": [{\"ngram\": \"the journalists\", \"from\": 2846, \"to\": 2861}]}, {\"sentence\": \"But to continue our work,we need your help.\", \"from\": 2906, \"to\": 2949, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"our work\", \"from\": 2922, \"to\": 2930}, {\"ngram\": \"your help\", \"from\": 2939, \"to\": 2948}]}, {\"sentence\": \"Your support, no matter how small, makes a world of difference.\", \"from\": 2951, \"to\": 3014, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Your support\", \"from\": 2951, \"to\": 2963}, {\"ngram\": \"a world\", \"from\": 2992, \"to\": 2999}, {\"ngram\": \"difference\", \"from\": 3003, \"to\": 3013}]}, {\"sentence\": \"If you can, please support us monthly starting from just$2.It's quick to set up, and every contribution makes a significant impact.\", \"from\": 3015, \"to\": 3146, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"us\", \"from\": 3042, \"to\": 3044}, {\"ngram\": \"every contribution\", \"from\": 3100, \"to\": 3118}, {\"ngram\": \"a significant impact\", \"from\": 3125, \"to\": 3145}]}, {\"sentence\": \"By supporting The Moscow Times, you are defending open, independent journalism in the face of repression.\", \"from\": 3148, \"to\": 3253, \"entities\": [{\"begin\": 3162, \"end\": 3178, \"title\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"The Moscow Times\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"dbpedia\": \"http://dbpedia.org/resource/The_Moscow_Times\"}], \"noun_phrases\": [{\"ngram\": \"open, independent journalism\", \"from\": 3198, \"to\": 3226}, {\"ngram\": \"the face\", \"from\": 3230, \"to\": 3238}, {\"ngram\": \"repression\", \"from\": 3242, \"to\": 3252}]}, {\"sentence\": \"Thank you for standing with us.