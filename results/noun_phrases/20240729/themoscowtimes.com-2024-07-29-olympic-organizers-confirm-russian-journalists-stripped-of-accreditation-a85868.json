"{\"uid\": \"themoscowtimes.com-2024-07-29-olympic-organizers-confirm-russian-journalists-stripped-of-accreditation-a85868\", \"noun_phrases\": [{\"sentence\": \"Olympic organizers on Monday confirmed that they canceled the accreditation of some reporters after Russia's state-run TASS news agency said several of its journalists could no longer cover the Paris Games.\", \"from\": 0, \"to\": 206, \"entities\": [{\"begin\": 100, \"end\": 106, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999995610845471, \"rank\": 4.2633124695738313e-07, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}, {\"begin\": 119, \"end\": 135, \"title\": \"http://dbpedia.org/resource/TASS\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"TASS news agency\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/TASS\", \"dbpedia\": \"http://dbpedia.org/resource/TASS\"}], \"noun_phrases\": [{\"ngram\": \"Olympic organizers\", \"from\": 0, \"to\": 18}, {\"ngram\": \"Monday\", \"from\": 22, \"to\": 28}, {\"ngram\": \"the accreditation\", \"from\": 58, \"to\": 75}, {\"ngram\": \"some reporters\", \"from\": 79, \"to\": 93}, {\"ngram\": \"its journalists\", \"from\": 152, \"to\": 167}, {\"ngram\": \"the Paris Games\", \"from\": 190, \"to\": 205}]}, {\"sentence\": \"TASS reported on Sunday that the removal of its journalists' accreditation, essential for covering sporting events, was \\\"completely unexpected\\\" and came after the journalists arrived in France, received passes and attended the opening and several events.\", \"from\": 208, \"to\": 462, \"entities\": [{\"begin\": 208, \"end\": 212, \"title\": \"http://dbpedia.org/resource/TASS\", \"score\": 1.0, \"rank\": 1.919735360082946e-34, \"text\": \"TASS\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/TASS\", \"dbpedia\": \"http://dbpedia.org/resource/TASS\"}, {\"begin\": 394, \"end\": 400, \"title\": \"http://dbpedia.org/resource/French_Third_Republic\", \"score\": 0.580298245747257, \"rank\": 0.6794193530205622, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/French_Third_Republic\", \"dbpedia\": \"http://dbpedia.org/resource/French_Third_Republic\"}], \"noun_phrases\": [{\"ngram\": \"Sunday\", \"from\": 225, \"to\": 231}, {\"ngram\": \"the removal\", \"from\": 237, \"to\": 248}, {\"ngram\": \"its journalists' accreditation\", \"from\": 252, \"to\": 282}, {\"ngram\": \"sporting events\", \"from\": 307, \"to\": 322}, {\"ngram\": \"the journalists\", \"from\": 367, \"to\": 382}, {\"ngram\": \"passes\", \"from\": 411, \"to\": 417}, {\"ngram\": \"the opening\", \"from\": 431, \"to\": 442}, {\"ngram\": \"several events\", \"from\": 447, \"to\": 461}]}, {\"sentence\": \"\\\"I can confirm that some accredited journalists have received an a posteriori decision from the competent authorities to withdraw their accreditation,\\\" Paris Olympics spokeswoman Anne Descamps told reporters.\", \"from\": 464, \"to\": 672, \"entities\": [{\"begin\": 648, \"end\": 656, \"title\": \"http://dbpedia.org/resource/Jean-Baptiste_Descamps\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Descamps\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Jean-Baptiste_Descamps\", \"dbpedia\": \"http://dbpedia.org/resource/Jean-Baptiste_Descamps\"}], \"noun_phrases\": [{\"ngram\": \"some accredited journalists\", \"from\": 484, \"to\": 511}, {\"ngram\": \"an a posteriori decision\", \"from\": 526, \"to\": 550}, {\"ngram\": \"the competent authorities\", \"from\": 556, \"to\": 581}, {\"ngram\": \"their accreditation\", \"from\": 594, \"to\": 613}, {\"ngram\": \"reporters\", \"from\": 662, \"to\": 671}]}, {\"sentence\": \"\\\"As the Paris 2024 Organising Committee, we are applying the decision without being involved in the rationale behind this information, which has not been communicated to us,\\