un_phrases\": []}, {\"sentence\": \"So why hold Olympic events on the Seine at all?\", \"from\": 2674, \"to\": 2721, \"entities\": [{\"begin\": 2708, \"end\": 2713, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 1.0, \"rank\": 7.568394541193505e-38, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"Olympic events\", \"from\": 2686, \"to\": 2700}]}, {\"sentence\": \"Maybe it\\u00e2\\u0080\\u0099s the history, the narrative arc, or for the plot.\", \"from\": 2723, \"to\": 2784, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Maybe it\\u00e2\\u0080\\u0099s\", \"from\": 2723, \"to\": 2735}, {\"ngram\": \"the history\", \"from\": 2736, \"to\": 2747}, {\"ngram\": \"the narrative arc\", \"from\": 2749, \"to\": 2766}, {\"ngram\": \"the plot\", \"from\": 2775, \"to\": 2783}]}, {\"sentence\": \"The first time Paris hosted an Olympics was 1900, the second iteration of the modern Games, and swimming events unspooled in an even more polluted Seine.\", \"from\": 2785, \"to\": 2938, \"entities\": [{\"begin\": 2800, \"end\": 2805, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.364130135866207e-33, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 2932, \"end\": 2937, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 1.0, \"rank\": 7.568394541193505e-38, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"The first time\", \"from\": 2785, \"to\": 2799}, {\"ngram\": \"an Olympics\", \"from\": 2813, \"to\": 2824}, {\"ngram\": \"the second iteration\", \"from\": 2835, \"to\": 2855}, {\"ngram\": \"the modern Games\", \"from\": 2859, \"to\": 2875}, {\"ngram\": \"swimming events\", \"from\": 2881, \"to\": 2896}]}, {\"sentence\": \"The second time the city hosted, in 1924, was one year after swimming was banned in the river, so events were held in the Piscine des Tourelles\\u00e2\\u0080\\u0094an actual pool.\", \"from\": 2939, \"to\": 3100, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The second time\", \"from\": 2939, \"to\": 2954}, {\"ngram\": \"the city\", \"from\": 2955, \"to\": 2963}, {\"ngram\": \"swimming\", \"from\": 3000, \"to\": 3008}, {\"ngram\": \"the river\", \"from\": 3023, \"to\": 3032}, {\"ngram\": \"events\", \"from\": 3037, \"to\": 3043}, {\"ngram\": \"the Piscine des Tourelles\\u00e2\\u0080\\u0094an actual pool\", \"from\": 3057, \"to\": 3099}]}, {\"sentence\": \"Olympic competitions now rest on E. coli measurements and uncontrollable acts of nature, like the rain that fell on Friday and Saturday.\", \"from\": 3102, \"to\": 3238, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Olympic competitions\", \"from\": 3102, \"to\": 3122}, {\"ngram\": \"E. coli measurements\", \"from\": 3135, \"to\": 3155}, {\"ngram\": \"uncontrollable acts\", \"from\": 3160, \"to\": 3179}, {\"ngram\": \"nature\", \"from\": 3183, \"to\": 3189}, {\"ngram\": \"the rain\", \"from\": 3196, \"to\": 3204}, {\"ngram\": \"Friday\", \"from\": 3218, \"to\": 3224}, {\"ngram\": \"Saturday\", \"from\": 3229, \"to\": 3237}]}, {\"sentence\": \"Rain overwhelms the treatment facilities, and allows more bacteria to frolic in the water.\", \"from\": 3239, \"to\": 3329, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Rain\", \"from\": 3239, \"to\": 3243}, {\"ngram\": \"the treatment facilities\", \"from\": 3255, \"to\": 3279}, {\"ngram\": \"more bacteria\", \"from\": 3292, \"to\": 3305}, {\"ngram\": \"the water\", \"from\": 3319, \"to\": 3328}]}, {\"sentence\": \"The mayor jumped in two weeks ago, but only after pushing the date back until levels were \\u00e2\\u0080\\u009cacceptable.\\u00e2\\u0080\\u009d A heavy rain later and she would not have dared dip a toe in.\", \"from\": 3330, \"to\": 3499, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The mayor\", \"from\": 3330, \"to\": 3339}, {\"ngram\": \"the date\", \"from\": 3388, \"to\": 3396}, {\"ngram\": \"levels\", \"from\": 3408, \"to\": 3414}, {\"ngram\": \"\\u00e2\\u0080\\u009cacceptable.\\u00e2\\u0080\\u009d A heavy rain\", \"from\": 3420, \"to\": 3450}, {\"ngram\": \"dip\", \"from\": 3486, \"to\": 3489}, {\"ngram\": \"a toe\", \"from\": 3490, \"to\": 3495}]}, {\"sentence\": \"British athletes have been vaccinated for typhoid and hepatitis A and will take antibiotics after competition.\", \"from\": 3500, \"to\": 3610, \"entities\": [{\"begin\": 3500, \"end\": 3507, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9999940706205308, \"rank\": 5.929375333668251e-06, \"text\": \"British\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"typhoid\", \"from\": 3542, \"to\": 3549}, {\"ngram\": \"hepatitis A\", \"from\": 3554, \"to\": 3565}, {\"ngram\": \"antibiotics\", \"from\": 3580, \"to\": 3591}, {\"ngram\": \"competition\", \"from\": 3598, \"to\": 3609}]}, {\"sentence\": \"This is assuming the water is declared \\u00e2\\u0080\\u009csafe enough\\u00e2\\u0080\\u009d for the two events in the Seine\\u00e2\\u0080\\u0094the triathlon and the 10km open-water swim.\", \"from\": 3611, \"to\": 3745, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the water\", \"from\": 3628, \"to\": 3637}, {\"ngram\": \"\\u00e2\\u0080\\u009csafe\", \"from\": 3650, \"to\": 3657}, {\"ngram\": \"the two events\", \"from\": 3672, \"to\": 3686}, {\"ngram\": \"the Seine\\u00e2\\u0080\\u0094the triathlon\", \"from\": 3690, \"to\": 3715}, {\"ngram\": \"the 10km open-water swim\", \"from\": 3720, \"to\": 3744}]}, {\"sentence\": \"If not, those races will be held in the Vaires-sur-Marne Nautical Stadium,