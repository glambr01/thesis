.\\\"\", \"from\": 576, \"to\": 723, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"X\", \"from\": 586, \"to\": 587}, {\"ngram\": \"the official Olympic Games\", \"from\": 589, \"to\": 615}, {\"ngram\": \"explainedthe scene\", \"from\": 624, \"to\": 642}, {\"ngram\": \"viewers\", \"from\": 657, \"to\": 664}, {\"ngram\": \"the absurdity\", \"from\": 675, \"to\": 688}, {\"ngram\": \"violence\", \"from\": 692, \"to\": 700}, {\"ngram\": \"human beings\", \"from\": 709, \"to\": 721}]}, {\"sentence\": \"Still, major figures such as House Speaker Mike Johnson, X owner Elon Musk and Kansas City Chiefs kicker Harrison Butker expressed outrage, describing the scene as a mockery of Christianity.\", \"from\": 724, \"to\": 914, \"entities\": [{\"begin\": 753, \"end\": 766, \"title\": \"http://dbpedia.org/resource/Speaker_of_the_United_States_House_of_Representatives\", \"score\": 0.9999984891280792, \"rank\": 1.3914086010201652e-06, \"text\": \"House Speaker\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Speaker_of_the_United_States_House_of_Representatives\", \"dbpedia\": \"http://dbpedia.org/resource/Speaker_of_the_United_States_House_of_Representatives\"}, {\"begin\": 789, \"end\": 798, \"title\": \"http://dbpedia.org/resource/Elon_Musk\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Elon Musk\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Elon_Musk\", \"dbpedia\": \"http://dbpedia.org/resource/Elon_Musk\"}, {\"begin\": 803, \"end\": 821, \"title\": \"http://dbpedia.org/resource/Kansas_City_Chiefs\", \"score\": 0.9997278082943283, \"rank\": 0.0002521779762325962, \"text\": \"Kansas City Chiefs\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/Kansas_City_Chiefs\", \"dbpedia\": \"http://dbpedia.org/resource/Kansas_City_Chiefs\"}, {\"begin\": 829, \"end\": 844, \"title\": \"http://dbpedia.org/resource/Harrison_Butker\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"H