"{\"uid\": \"rte.ie-lifestyle-food-2024-0802-1463148-can-a-chocolate-muffin-be-good-fuel-for-a-competing-olympian\", \"noun_phrases\": [{\"sentence\": \"You would not expect to hear chocolate muffins in the same sentence as the Paris 2024 Olympics, but Norwegian swimmer Henrik Christiansen has helped to change that narrative.\", \"from\": 0, \"to\": 174, \"entities\": [{\"begin\": 100, \"end\": 109, \"title\": \"http://dbpedia.org/resource/Norway\", \"score\": 0.9967948390862252, \"rank\": 0.003073165701653859, \"text\": \"Norwegian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Norway\", \"dbpedia\": \"http://dbpedia.org/resource/Norway\"}, {\"begin\": 118, \"end\": 137, \"title\": \"http://dbpedia.org/resource/Henrik_Christiansen_(swimmer)\", \"score\": 0.6621615443867334, \"rank\": 0.5102040816326032, \"text\": \"Henrik Christiansen\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Henrik_Christiansen_(swimmer)\", \"dbpedia\": \"http://dbpedia.org/resource/Henrik_Christiansen_(swimmer)\"}], \"noun_phrases\": [{\"ngram\": \"chocolate muffins\", \"from\": 29, \"to\": 46}, {\"ngram\": \"the same sentence\", \"from\": 50, \"to\": 67}, {\"ngram\": \"the Paris 2024 Olympics\", \"from\": 71, \"to\": 94}, {\"ngram\": \"that narrative\", \"from\": 159, \"to\": 173}]}, {\"sentence\": \"Since going viral on TikTok with a series of videos that feature him eating chocolate muffins at the Olympic village - namely the Maxi Muffin with Intense Chocolate from French catering company Coup de pates - we are all now craving the sweet treat too.\", \"from\": 176, \"to\": 429, \"entities\": [{\"begin\": 197, \"end\": 203, \"title\": \"http://dbpedia.org/resource/TikTok\", \"score\": 1.0, \"rank\": 2.794912702311064e-26, \"text\": \"TikTok\", \"types\": [\"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/TikTok\", \"dbpedia\": \"http://dbpedia.org/resource/TikTok\"}, {\"begin\": 346, \"end\": 352, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9944073694349826, \"rank\": 0.0055089803716371795, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"a series\", \"from\": 209, \"to\": 217}, {\"ngram\": \"videos\", \"from\": 221, \"to\": 227}, {\"ngram\": \"chocolate muffins\", \"from\": 252, \"to\": 269}, {\"ngram\": \"the Olympic village\", \"from\": 273, \"to\": 292}, {\"ngram\": \"namely the Maxi Muffin\", \"from\": 295, \"to\": 317}, {\"ngram\": \"Intense Chocolate\", \"from\": 323, \"to\": 340}, {\"ngram\": \"the sweet treat\", \"from\": 409, \"to\": 424}]}, {\"sentence\": \"The food supplier is surprised about the level of support they have received from new customers, and wrote in a caption on Instagram: \\\"We knew our Maxi Muffin with Intense Chocolate was something special\\u2026 but we did not expect it to spark such a chocolate storm!\", \"from\": 435, \"to\": 697, \"entities\": [{\"begin\": 558, \"end\": 567, \"title\": \"http://dbpedia.org/resource/Instagram\", \"score\": 1.0, \"rank\": 4.023766186649629e-21, \"text\": \"Instagram\", \"types\": [\"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Instagram\", \"dbpedia\": \"http://dbpedia.org/resource/Instagram\"}], \"noun_phrases\": [{\"ngram\": \"The food supplier\", \"from\": 435, \"to\": 452}, {\"ngram\": \"the level\", \"from\": 472, \"to\": 481}, {\"ngram\": \"support\", \"from\": 485, \"to\": 492}, {\"ngram\": \"new customers\", \"from\": 517, \"to\": 530}, {\"ngram\": \"a caption\", \"from\": 545, \"to\": 554}, {\"ngram\": \"our Maxi Muffin\", \"from\": 578, \"to\": 593}, {\"ngram\": \"Intense Chocolate\", \"from\": 599, \"to\": 616}, {\"ngram\": \"something\", \"from\": 621, \"to\": 630}, {\"ngram\": \"such a chocolate storm\", \"from\": 674, \"to\": 696}]}, {\"sentence\": \"Thank you all for the love!\\\"\", \"from\": 698, \"to\": 726, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the love\", \"from\": 716, \"to\": 724}]}, {\"sentence\": \"But how can chocolate muffins be good fuel for a competing Olympian?\", \"from\": 728, \"to\": 796, \"entities\": [{\"begin\": 787, \"end\": 795, \"title\": \"http://dbpedia.org/resource/Olympic_Games\", \"score\": 0.9999723956963592, \"rank\": 2.7604916196192012e-05, \"text\": \"Olympian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games\"}], \"noun_phrases\": [{\"ngram\": \"muffins\", \"from\": 750, \"to\": 757}, {\"ngram\": \"good fuel\", \"from\": 761, \"to\": 770}]}, {\"sentence\": \"Trained chef, nutrition coach and qualified fitness instructor, Lisa Marley said: \\\"A chocolate muffin may be considered good fuel for an Olympian due to its combination of carbohydrates, fats and sugars, which can provide a quick source of energy.\", \"from\": 798, \"to\": 1045, \"entities\": [{\"begin\": 862, \"end\": 866, \"title\": \"http://dbpedia.org/resource/Lisa_Simpson\", \"score\": 0.9999998411394826, \"rank\": 1.5880531144246827e-07, \"text\": \"Lisa\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Lisa_Simpson\", \"dbpedia\": \"http://dbpedia.org/resource/Lisa_Simpson\"}, {\"begin\": 935, \"end\": 943, \"title\": \"http://dbpedia.org/resource/Olympic_Games\", \"score\": 0.9999723956963592, \"rank\": 2.7604916196192012e-05, \"text\": \"Olympian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games\"}], \"noun_phrases\": [{\"ngram\": \"Trained chef\", \"from\": 798, \"to\": 810}, {\"ngram\": \"nutrition coach\", \"from\": 812, \"to\": 827}, {\"ngram\": \"qualified fitness instructor\", \"from\": 832, \"to\": 860}, {\"ngram\": \"A chocolate muffin\", \"from\": 881, \"to\": 899}, {\"ngram\": \"good fuel\", \"from\": 918, \"to\": 927}, {\"ngram\": \"its combination\", \"from\": 951, \"to\": 966}, {\"ngram\": \"carbohydrates\", \"from\": 970, \"to\": 983}, {\"ngram\": \"fats\", \"from\": 985, \"to\": 989}, {\"ngram\": \"sugars\", \"from\": 994, \"to\": 1000}, {\"ngram\": \"a quick source\", \"from\": 1020, \"to\": 1034}, {\"ngram\": \"energy\", \"from\": 1038, \"to\": 1044}]}, {\"sentence\": \"\\\"The carbohydrates in the muffin can provide immediate energy for physical activity, while the fats can provide sustained energy for longer endurance.\", \"from\": 1047, \"to\": 1197, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The carbohydrates\", \"from\": 1048, \"to\": 1065}, {\"ngram\": \"the muffin\", \"from\": 1069, \"to\": 1079}, {\"ngram\": \"immediate energy\", \"from\": 1092, \"to\": 1108}, {\"ngram\": \"physical activity\", \"from\": 1113, \"to\": 1130}, {\"ngram\": \"the fats\", \"from\": 1138, \"to\": 1146}, {\"ngram\": \"sustained energy\", \"from\": 1159, \"to\": 1175}, {\"ngram\": \"longer endurance\", \"from\": 1180, \"to\": 1196}]}, {\"sentence\": \"The sugar content can also provide a quick energy boost.\", \"from\": 1198, \"to\": 1254, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The sugar content\", \"from\": 1198, \"to\": 1215}, {\"ngram\": \"a quick energy boost\", \"from\": 1233, \"to\": 1253}]}, {\"sentence\": \"\\\"A chocolate muffin may be a convenient option for a quick energy boost, but it should be consumed in moderation as part of a well-rounded diet.\\\"\", \"from\": 1256, \"to\": 1401, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A chocolate muffin\", \"from\": 1257, \"to\": 1275}, {\"ngram\": \"a convenient option\", \"from\": 1283, \"to\": 1302}, {\"ngram\": \"a quick energy boost\", \"from\": 1307, \"to\": 1327}, {\"ngram\": \"moderation\", \"from\": 1358, \"to\": 1368}, {\"ngram\": \"part\", \"from\": 1372, \"to\": 1376}, {\"ngram\": \"a well-rounded diet\", \"from\": 1380, \"to\": 1399}]}, {\"sentence\": \"Corinna Chidley, a senior lecturer in health and performance nutrition at the University of Derby, added: \\\"It probably comes as no surprise that different athletes have different nutritional requirements; these differences will primarily be based on the type of event an athlete competes in and the demands of their training.\", \"from\": 1405, \"to\": 1730, \"entities\": [{\"begin\": 1405, \"end\": 1412, \"title\": \"http://dbpedia.org/resource/Corinna\", \"score\": 0.9999999999997726, \"rank\": 2.0037569139381014e-13, \"text\": \"Corinna\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Corinna\", \"dbpedia\": \"http://dbpedia.org/resource/Corinna\"}], \"noun_phrases\": [{\"ngram\": \"a senior lecturer\", \"from\": 1422, \"to\": 1439}, {\"ngram\": \"health and performance nutrition\", \"from\": 1443, \"to\": 1475}, {\"ngram\": \"the University\", \"from\": 1479, \"to\": 1493}, {\"ngram\": \"Derby\", \"from\": 1497, \"to\": 1502}, {\"ngram\": \"no surprise\", \"from\": 1533, \"to\": 1544}, {\"ngram\": \"different athletes\", \"from\": 1550, \"to\": 1568}, {\"ngram\": \"different nutritional requirements\", \"from\": 1574, \"to\": 1608}, {\"ngram\": \"these differences\", \"from\": 1610, \"to\": 1627}, {\"ngram\": \"the type\", \"from\": 1655, \"to\": 1663}, {\"ngram\": \"event\", \"from\": 1667, \"to\": 1672}, {\"ngram\": \"an athlete\", \"from\": 1673, \"to\": 1683}, {\"ngram\": \"the demands\", \"from\": 1700, \"to\": 1711}, {\"ngram\": \"their training\", \"from\": 1715, \"to\": 1729}]}, {\"sentence\": \"\\\"Endurance athletes, such as marathon runners or road and cross-country cyclists will require a sustained source of energy, predominately in the form of dietary carbohydrates, to fuel their competition and training.\", \"from\": 1734, \"to\": 1949, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Endurance athletes\", \"from\": 1735, \"to\": 1753}, {\"ngram\": \"marathon runners\", \"from\": 1763, \"to\": 1779}, {\"ngram\": \"road\", \"from\": 1783, \"to\": 1787}, {\"ngram\": \"cross-country cyclists\", \"from\": 1792, \"to\": 1814}, {\"ngram\": \"a sustained source\", \"from\": 1828, \"to\": 1846}, {\"ngram\": \"energy\", \"from\": 1850, \"to\": 1856}, {\"ngram\": \"the form\", \"from\": 1875, \"to\": 1883}, {\"ngram\": \"dietary carbohydrates\", \"from\": 1887, \"to\": 1908}, {\"ngram\": \"their competition\", \"from\": 1918, \"to\": 1935}, {\"ngram\": \"training\", \"from\": 1940, \"to\": 1948}]}, {\"sentence\": \"\\\"On the other hand, power-based athletes, such as sprinters, track cyclists, and shorter-distance swimmers will have a focus on power, which typically requires a greater amount of protein consumption compared to their endurance peers.\", \"from\": 1951, \"to\": 2185, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the other hand\", \"from\": 1955, \"to\": 1969}, {\"ngram\": \", power-based athletes\", \"from\": 1969, \"to\": 1991}, {\"ngram\": \"sprinters\", \"from\": 2001, \"to\": 2010}, {\"ngram\": \"track cyclists\", \"from\": 2012, \"to\": 2026}, {\"ngram\": \"shorter-distance swimmers\", \"from\": 2032, \"to\": 2057}, {\"ngram\": \"a focus\", \"from\": 2068, \"to\": 2075}, {\"ngram\": \"power\", \"from\": 2079, \"to\": 2084}, {\"ngram\": \"a greater amount\", \"from\": 2111, \"to\": 2127}, {\"ngram\": \"protein consumption\", \"from\": 2131, \"to\": 2150}, {\"ngram\": \"their endurance peers\", \"from\": 2163, \"to\": 2184}]}, {\"sentence\": \"\\\"The amount of energy consumed by elite athletes will typically be much greater than the general population in order to meet the demands of their training schedules with the nutritional intake being tailored to ensure adequate energy while maintaining optimal body composition.\\\"\", \"from\": 2187, \"to\": 2465, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The amount\", \"from\": 2188, \"to\": 2198}, {\"ngram\": \"energy\", \"from\": 2202, \"to\": 2208}, {\"ngram\": \"elite athletes\", \"from\": 2221, \"to\": 2235}, {\"ngram\": \"the general population\", \"from\": 2272, \"to\": 2294}, {\"ngram\": \"order\", \"from\": 2298, \"to\": 2303}, {\"ngram\": \"the demands\", \"from\": 2312, \"to\": 2323}, {\"ngram\": \"their training schedules\", \"from\": 2327, \"to\": 2351}, {\"ngram\": \"the nutritional intake\", \"from\": 2357, \"to\": 2379}, {\"ngram\": \"adequate energy\", \"from\": 2405, \"to\": 2420}, {\"ngram\": \"optimal body composition\", \"from\": 2439, \"to\": 2463}]}, {\"sentence\": \"If you now also fancy a chocolate muffin, Marley shares how you can make your own at home.\", \"from\": 2469, \"to\": 2559, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a chocolate muffin\", \"from\": 2491, \"to\": 2509}, {\"ngram\": \"home\", \"from\": 2554, \"to\": 2558}]}, {\"sentence\": \"Chocolate chip muffins Serves8-10, takes 20 minutes Search by ingredient, chef or programme \\u00a9 RT\\u00c9 2026.\", \"from\": 2561, \"to\": 2673, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Chocolate chip muffins\", \"from\": 2561, \"to\": 2583}, {\"ngram\": \"Serves8\", \"from\": 2584, \"to\": 2591}, {\"ngram\": \"20 minutes\", \"from\": 2602, \"to\": 2612}, {\"ngram\": \"Search\", \"from\": 2613, \"to\": 2619}, {\"ngram\": \"ingredient\", \"from\": 2623, \"to\": 2633}, {\"ngram\": \"chef\", \"from\": 2635, \"to\": 2639}, {\"ngram\": \"\\u00a9 RT\\u00c9\", \"from\": 2653, \"to\": 2658}]}, {\"sentence\": \"RT\\u00c9.ie is the website of Raidi\\u00f3 Teilif\\u00eds \\u00c9ireann, Ireland's National Public Service Media.\", \"from\": 2674, \"to\": 2764, \"entities\": [{\"begin\": 2699, \"end\": 2722, \"title\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\", \"score\": 0.9993664851268295, \"rank\": 0.0006339164685885233, \"text\": \"Raidi\\u00f3 Teilif\\u00eds \\u00c9ireann\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\", \"dbpedia\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\"}, {\"begin\": 27