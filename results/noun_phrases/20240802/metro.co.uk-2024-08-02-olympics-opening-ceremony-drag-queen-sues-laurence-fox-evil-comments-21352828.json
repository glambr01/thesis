}, {\"sentence\": \"'This is my kind of activism.\", \"from\": 2162, \"to\": 2191, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my kind\", \"from\": 2171, \"to\": 2178}, {\"ngram\": \"activism\", \"from\": 2182, \"to\": 2190}]}, {\"sentence\": \"I am going to make him pay for the things that everybody else is saying, because I want to show that it is time now to stop labeling queer people in an evil way,' This is not the first time Fox has faced legal action.\", \"from\": 2192, \"to\": 2410, \"entities\": [{\"begin\": 2383, \"end\": 2386, \"title\": \"http://dbpedia.org/resource/Fox_Broadcasting_Company\", \"score\": 0.9795658364124243, \"rank\": 0.020855809547142102, \"text\": \"Fox\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/Fox_Broadcasting_Company\", \"dbpedia\": \"http://dbpedia.org/resource/Fox_Broadcasting_Company\"}], \"noun_phrases\": [{\"ngram\": \"the things\", \"from\": 2223, \"to\": 2233}, {\"ngram\": \"everybody\", \"from\": 2239, \"to\": 2248}, {\"ngram\": \"time\", \"from\": 2299, \"to\": 2303}, {\"ngram\": \"queer people\", \"from\": 2325, \"to\": 2337}, {\"ngram\": \"an evil way\", \"from\": 2341, \"to\": 2352}, {\"ngram\": \"the first time\", \"from\": 2367, \"to\": 2381}, {\"ngram\": \"legal action\", \"from\": 2396, \"to\": 2408}]}, {\"sentence\": \"The public figure recently lost a High Court libel casefiled by Stonewall trustee Simon Blake and drag artist Crystal.\", \"from\": 2411, \"to\": 2529, \"entities\": [{\"begin\": 2475, \"end\": 2484, \"title\": \"http://dbpedia.org/resource/Stonewall_riots\", \"score\": 1.0, \"rank\": 2.860751268334314e-43, \"text\": \"Stonewall\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Stonewall_riots\", \"dbpedia\": \"http://dbpedia.org/resource/Stonewall_riots\"}, {\"begin\": 2499, \"end\": 2504, \"title\": \"http://dbpedia.org/resource/William_Blake\", \"score\": 0.9812136922209908, \"rank\": 0.01914599024453451, \"text\": \"Blake\", \"