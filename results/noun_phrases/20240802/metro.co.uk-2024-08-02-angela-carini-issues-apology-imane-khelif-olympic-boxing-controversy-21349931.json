m\": 2491, \"to\": 2509}]}, {\"sentence\": \"Whoever we put her with, it hurt her.\", \"from\": 2527, \"to\": 2564, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Whoever\", \"from\": 2527, \"to\": 2534}]}, {\"sentence\": \"We put her with Jose Quiles and they were equally matched.\", \"from\": 2565, \"to\": 2623, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Jose Quiles\", \"from\": 2581, \"to\": 2592}]}, {\"sentence\": \"From my point of view I do not see it as fair.'\", \"from\": 2624, \"to\": 2671, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my point\", \"from\": 2629, \"to\": 2637}, {\"ngram\": \"view\", \"from\": 2641, \"to\": 2645}]}, {\"sentence\": \"In the wake of the controversy in the aftermath of Khelif's win against Carini on Thursday,the International Olympic Committee (IOC) hit out at the treatment directed towards the Algerian and Taiwan's Lin Yu-ting, who also failed a gender eligibility test with the IBA.\", \"from\": 2673, \"to\": 2942, \"entities\": [{\"begin\": 2745, \"end\": 2751, \"title\": \"http://dbpedia.org/resource/Carini\", \"score\": 0.8986792650445573, \"rank\": 0.11274404439525075, \"text\": \"Carini\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Carini\", \"dbpedia\": \"http://dbpedia.org/resource/Carini\"}, {\"begin\": 2768, \"end\": 2805, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee (IOC)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 2852, \"end\": 2860, \"title\": \"http://dbpedia.org/resource/Algeria\", \"score\": 0.7382719013027692, \"rank\": 0.35276323380444385, \"text\": \"Algerian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Algeria\", \"dbpedia\": \"http://dbpedia.org/resource/Algeria\"}, {\"begin\"