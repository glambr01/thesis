 256}]}, {\"sentence\": \"AmazonCFOBrian Olsavskysays the volatile news cycle is partly to blame for itslower than expected sales forecastfor the quarter.\", \"from\": 259, \"to\": 387, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the volatile news cycle\", \"from\": 287, \"to\": 310}, {\"ngram\": \"expected sales\", \"from\": 348, \"to\": 362}, {\"ngram\": \"the quarter\", \"from\": 375, \"to\": 386}]}, {\"sentence\": \"On Thursday, the e-commerce giant said it was expecting $154 billion to $158.5 billion in revenue for the third quarter of this year, below the average analyst estimate of $158.24 billion.\", \"from\": 389, \"to\": 577, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Thursday\", \"from\": 392, \"to\": 400}, {\"ngram\": \"the e-commerce giant\", \"from\": 402, \"to\": 422}, {\"ngram\": \"revenue\", \"from\": 479, \"to\": 486}, {\"ngram\": \"the third quarter\", \"from\": 491, \"to\": 508}, {\"ngram\": \"this year\", \"from\": 512, \"to\": 521}, {\"ngram\": \"the average analyst estimate\", \"from\": 529, \"to\": 557}]}, {\"sentence\": \"Amazon stock prices fell by more than 7% in after-hours trading.\", \"from\": 578, \"to\": 642, \"entities\": [{\"begin\": 578, \"end\": 584, \"title\": \"http://dbpedia.org/resource/Amazon_Music\", \"score\": 0.5710447712894167, \"rank\": 0.5282484881844473, \"text\": \"Amazon\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Amazon_Music\", \"dbpedia\": \"http://dbpedia.org/resource/Amazon_Music\"}], \"noun_phrases\": [{\"ngram\": \"more than 7%\", \"from\": 606, \"to\": 618}, {\"ngram\": \"hours\", \"from\": 628, \"to\": 633}]}, {\"sentence\": \"\\\"On the revenue side, I'd just say it's going to be a tough quarter to forecast,\\\" Amazon CFO Brian Olsavsky toldThe Wall Street Journal's Sebastian Herreraduring a press briefing on Thursday.\", \"from\": 644, \"to\": 835, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the revenue side\", \"from\": 648, \"to\": 664}, {\"ngram\": \"a tough quarter\", \"from\": 696, \"to\": 711}, {\"ngram\": \"Amazon CFO Brian Olsavsky toldThe Wall Street Journal's Sebastian\", \"from\": 726, \"to\": 791}, {\"ngram\": \"a press briefing\", \"from\": 806, \"to\": 822}, {\"ngram\": \"Thursday\", \"from\": 826, \"to\": 834}]}, {\"sentence\": \"\\\"There is a lot of events that are occupying people's attention right now from political conventions to the election itself to the Olympics,\\\" he continued.\", \"from\": 837, \"to\": 992, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a lot\", \"from\": 847, \"to\": 852}, {\"ngram\": \"events\", \"from\": 856, \"to\": 862}, {\"ngram\": \"people's attention\", \"from\": 882, \"to\": 900}, {\"ngram\": \"political conventions\", \"from\": 916, \"to\": 937}, {\"ngram\": \"the election\", \"from\": 941, \"to\": 953}, {\"ngram\": \"the Olympics\", \"from\": 964, \"to\": 976}]}, {\"sentence\": \"Olsavsky later toldAxios' Hope Kingin the same briefing that the spate of newsmaking events in the recent and coming months meant that it would be much harder for Amazon to sell to customers.\", \"from\": 994, \"to\": 1185, \"entities\": [{\"begin\": 1157, \"end\": 1163, \"title\": \"http://dbpedia.org/resource/Amazon_Music\", \"score\": 0.5710447712894167, \"rank\": 0.5282484881844473, \"text\": \"Amazon\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Amazon_Music\", \"dbpedia\": \"http://dbpedia.org/resource/Amazon_Music\"}], \"noun_phrases\": [{\"ngram\": \"toldAxios' Hope Kingin\", \"from\": 1009, \"to\": 1031}, {\"ngram\": \"the spate\", \"from\": 1055, \"to\": 1064}, {\"ngram\": \"events\", \"from\": 1079, \"to\": 1085}, {\"ngram\": \"the recent and coming months\", \"from\": 1089, \"to\": 1117}, {\"ngram\": \"customers\", \"from\": 1175, \"to\": 1184}]}, {\"sentence\": \"\\\"No matter what you are selling or providing, customers only have so much attention,\\\" Olsavsky said.\", \"from\": 1187, \"to\": 1287, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"customers\", \"from\