ram\": \"incredible performances\", \"from\": 713, \"to\": 736}, {\"ngram\": \"the athletes\", \"from\": 740, \"to\": 752}, {\"ngram\": \"the awesome images\", \"from\": 757, \"to\": 775}, {\"ngram\": \"the world\", \"from\": 793, \"to\": 802}, {\"ngram\": \"billions\", \"from\": 806, \"to\": 814}, {\"ngram\": \"people\", \"from\": 818, \"to\": 824}]}, {\"sentence\": \"The hero picture of Brazilian star, Gabriel Medina, floating triumphantly in the air with his board also aloft is one of the most iconic images of these Games \\u00e2\\u0080\\u0093 and possibly any Games!\", \"from\": 826, \"to\": 1012, \"entities\": [{\"begin\": 862, \"end\": 876, \"title\": \"http://dbpedia.org/resource/Gabriel_Medina\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Gabriel Medina\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Gabriel_Medina\", \"dbpedia\": \"http://dbpedia.org/resource/Gabriel_Medina\"}], \"noun_phrases\": [{\"ngram\": \"The hero picture\", \"from\": 826, \"to\": 842}, {\"ngram\": \"Brazilian star\", \"from\": 846, \"to\": 860}, {\"ngram\": \"the air\", \"from\": 903, \"to\": 910}, {\"ngram\": \"his board\", \"from\": 916, \"to\": 925}, {\"ngram\": \"the most iconic images\", \"from\": 947, \"to\": 969}, {\"ngram\": \"these Games\", \"from\": 973, \"to\": 984}, {\"ngram\": \"\\u00e2\\u0080\\u0093\", \"from\": 985, \"to\": 988}, {\"ngram\": \"possibly any Games\", \"from\": 993, \"to\": 1011}]}, {\"sentence\": \"I dreamt of this moment, since the day the village of Teahupo'o on the mesmerizing island in French Polynesia was confirmed, to bring Olympic surfing to one of the sport's most majestic and spectacular locations.\", \"from\": 1014, \"to\": 1226, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this moment\", \"from\": 1026, \"to\": 1037}, {\"ngram\": \"the day\", \"from\": 1045, \"to\": 1052}, {\"ngram\": \"the village\", \"from\": 1053, \"to\": 1064}, {\"ngram\": \"Teahupo'o\", \"from\": 1068, \"to\": 1077}, {\"ngram\": \"the mesmerizing island\", \"from\": 1081, \"to\": 1103}, {\"ngram\": \"French Polynesia\", \"from\": 1107, \"to\": 1123}, {\"ngram\": \"Olympic\", \"from\": 1148, \"to\": 1155}, {\"ngram\": \"surfing\", \"from\": 1156, \"to\": 1163}, {\"ngram\": \"the sport's most majestic and spectacular locations\", \"from\": 1174, \"to\": 1225}]}, {\"sentence\": \"This is a dream come true, not only for me but all surfers.\", \"from\": 1227, \"to\": 1286, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a dream\", \"from\": 1235, \"to\": 1242}, {\"ngram\": \"all surfers\", \"from\": 1274, \"to\": 1285}]}, {\"sentence\": \"The incredible waves of Teahupo'o are one of the great wonders of the world.\", \"from\": 1287, \"to\": 1363, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The incredible waves\", \"from\": 1287, \"to\": 1307}, {\"ngram\": \"the great wonders\", \"from\": 1332, \"to\": 1349}, {\"ngram\": \"the world\", \"from\": 1353, \"to\": 1362}]}, {\"sentence\": \"The Tokyo Olympics in 2021 was staged in totally different circumstances as the world was reeling from the COVID-19 pandemic.\", \"from\": 1365, \"to\": 1490, \"entities\": [{\"begin\": 1369, \"end\": 1383, \"title\": \"http://dbpedia.org/resource/2020_Summer_Olympics\", \"score\": 1.0, \"rank\": 3.7368332502158844e-14, \"text\": \"Tokyo Olympics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2020_Summer_Olympics\"}, {\"begin\": 1472, \"end\": 1489, \"title\": \"http://dbpedia.org/resource/COVID-19_pandemic\", \"score\": 0.9999999999618012, \"rank\": 3.134826017103565e-11, \"text\": \"COVID-19 pandemic\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/COVID-19_pandemic\", \"dbpedia\": \"http://dbpedia.org/resource/COVID-19_pandemic\"}], \"noun_phrases\": [{\"ngram\": \"totally different circumstances\", \"from\": 1406, \"to\": 1437}, {\"ngram\": \"the world\", \"from\": 1441, \"to\": 1450}]}, {\"sentence\": \"Of course, surfing was thrilled to make its Olympic debut back then and we are grateful to the organizers for everything they did \\u00e2\\u0080\\u0093 but this time Tahiti is a totally different vibe.\", \"from\": 1491, \"to\": 1674, \"entities\": [{\"begin\": 1639, \"end\": 1645, \"title\": \"http://dbpedia.org/resource/Tahiti\", \"score\": 0.9999999423062053, \"rank\": 5.7693713370701704e-08, \"text\": \"Tahiti\", \"types\": [\"Q23442\"], \"wikid\": \"http://dbpedia.org/resource/Tahiti\", \"dbpedia\": \"http://dbpedia.org/resource/Tahiti\"}], \"noun_phrases\": [{\"ngram\": \"its Olympic debut\", \"from\": 1531, \"to\": 1548}, {\"ngram\": \"the organizers\", \"from\": 1582, \"to\": 1596}, {\"ngram\": \"everything\", \"from\": 1601, \"to\": 1611}, {\"ngram\": \"\\u00e2\\u0080\\u0093\", \"from\": 1621, \"to\": 1624}, {\"ngram\": \"a totally different vibe\", \"from\": 1649, \"to\": 1673}]}, {\"sentence\": \"We are thrilled to share this unique moment with the people of Tahiti.\", \"from\": 1675, \"to\": 1745, \"entities\": [{\"begin\": 1738, \"end\": 1744, \"title\": \"http://dbpedia.org/resource/Tahiti\", \"score\": 0.9999999423062053, \"rank\": 5.7693713370701704e-08, \"text\": \"Tahiti\", \"types\": [\"Q23442\"], \"wikid\": \"http://dbpedia.org/resource/Tahiti\", \"dbpedia\": \"http://dbpedia.org/resource/Tahiti\"}], \"noun_phrases\": [{\"ngram\": \"this unique moment\", \"from\": 1700, \"to\": 1718}, {\"ngram\": \"the people\", \"from\": 1724, \"to\": 1734}]}, {\"sentence\": \"We also have more surfing athletes in 2024, which is great news.\", \"from\": 1747, \"to\": 1811, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"more surfing athletes\", \"from\": 1760, \"to\": 1781}, {\"ngram\": \"great news\", \"from\": 1800, \"to\": 1810}]}, {\"sentence\": \"In Tokyo, we had 40 surfers from 18 nations and this has risen to 48 surfers \\u00e2\\u0080\\u0093 24 women and 24 men \\u00e2\\u0080\\u0093 representing 21 nations in Tahiti.\", \"from\": 1812, \"to\": 1951, \"entities\": [{\"begin\": 1815, \"end\": 1820, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.9999999999959073, \"rank\": 3.888974811393534e-12, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}, {\"begin\": 1944, \"end\": 1950, \"title\": \"http://dbpedia.org/resource/Tahiti\", \"score\": 0.9999999423062053, \"rank\": 5.7693713370701704e-08, \"text\": \"Tahiti\", \"types\": [\"Q23442\"], \"wikid\": \"http://dbpedia.org/resource/Tahiti\", \"dbpedia\": \"http://dbpedia.org/resource/Tahiti\"}], \"noun_phrases\": [{\"ngram\": \"40 surfers\", \"from\": 1829, \"to\": 1839}, {\"ngram\": \"18 nations\", \"from\": 1845, \"to\": 1855}, {\"ngram\": \"48 surfers\", \"from\": 1878, \"to\": 1888}, {\"ngram\": \"24 women\", \"from\": 1893, \"to\": 1901}, {\"ngram\": \"24 men\", \"from\": 1906, \"to\": 1912}, {\"ngram\": \"21 nations\", \"from\": 1930, \"to\": 1940}]}, {\"sentence\": \"It's amazing that surfing continues to develop around the world with a growing number of top-class athletes competing for Olympic medals.\", \"from\": 1952, \"to\": 2089, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"surfing\", \"from\": 1970, \"to\": 1977}, {\"ngram\": \"the world\", \"from\": 2006, \"to\": 2015}, {\"ngram\": \"a growing number\", \"from\": 2021, \"to\": 2037}, {\"ngram\": \"top-class athletes\", \"from\": 2041, \"to\": 2059}, {\"ngram\": \"Olympic medals\", \"from\": 2074, \"to\": 2088}]}, {\"sentence\": \"Olympic surfing is most importantly about the athletes \\u00e2\\u0080\\u0093 and nothing makes me prouder than seeing new surfers take to the Olympic stage.\", \"from\": 2091, \"to\": 2229, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Olympic surfing\", \"from\": 2091, \"to\": 2106}, {\"ngram\": \"the athletes\", \"from\": 2133, \"to\": 2145}, {\"ngram\": \"\\u00e2\\u0080\\u0093\", \"from\": 2146, \"to\": 2149}, {\"ngram\": \"nothing\", \"from\": 2154, \"to\": 2161}, {\"ngram\": \"new surfers\", \"from\": 2191, \"to\": 2202}, {\"ngram\": \"the Olympic stage\", \"from\": 2211, \"to\": 2228}]}, {\"sentence\": \"And one of the stories \\u00e2\\u0080\\u0093 and stars \\u00e2\\u0080\\u0093 of these Games is China's teenage surfing sensation, Yang Siqi, aged just 15.\", \"from\": 2230, \"to\": 2348, \"entities\": [{\"begin\": 2289, \"end\": 2294, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.999999965111329, \"rank\": 2.566555534347798e-08, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}], \"noun_phrases\": [{\"ngram\": \"the stories\", \"from\": 2241, \"to\": 2252}, {\"ngram\": \"\\u00e2\\u0080\\u0093\", \"from\": 2267, \"to\": 2270}, {\"ngram\": \"these Games\", \"from\": 2274, \"to\": 2285}, {\"ngram\": \"Yang Siqi\", \"from\": 2324, \"to\": 2333}]}, {\"sentence\": \"For such a young athlete, I am in awe of her talent and determination!\", \"from\": 2349, \"to\": 2419, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"such a young athlete\", \"from\": 2353, \"to\": 2373}, {\"ngram\": \"awe\", \"from\": 2383, \"to\": 2386}, {\"ngram\": \"her talent\", \"from\": 2390, \"to\": 2400}, {\"ngram\": \"determination\", \"from\": 2405, \"to\": 2418}]}, {\"sentence\": \"She promises to have a super career and I can not wait to see her continue her brilliant success.\", \"from\": 2420, \"to\": 2517, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a super career\", \"from\": 2441, \"to\": 2455}, {\"ngram\": \"her brilliant success\", \"from\": 2495, \"to\": 2516}]}, {\"sentence\": \"Yang Siqi of China competes during the women's round 1 heat of surfing of the Paris 2024 Olympic Games in Teahupo'o, Tahiti, French Polynesia, July 27, 2024.\", \"from\": 2519, \"to\": 2676, \"entities\": [{\"begin\": 2636, \"end\": 2642, \"title\": \"http://dbpedia.org/resource/Tahiti\", \"score\": 0.9999999423062053, \"rank\": 5.7693713370701704e-08, \"text\": \"Tahiti\", \"types\": [\"Q23442\"], \"wikid\": \"http://dbpedia.org/resource/Tahiti\", \"dbpedia\": \"http://dbpedia.org/resource/Tahiti\"}, {\"begin\": 2651, \"end\": 2660, \"title\": \"http://dbpedia.org/resource/Polynesia\", \"score\": 0.9999903296347031, \"rank\": 9.670458548006676e-06, \"text\": \"Polynesia\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Polynesia\", \"dbpedia\": \"http://dbpedia.org/resource/Polynesia\"}], \"noun_phrases\": [{\"ngram\": \"Yang Siqi\", \"from\": 2519, \"to\": 2528}, {\"ngram\": \"China\", \"from\": 2532, \"to\": 2537}, {\"ngram\": \"the women's round 1 heat\", \"from\": 2554, \"to\": 2578}, {\"ngram\": \"surfing\", \"from\": 2582, \"to\": 2589}, {\"ngram\": \"the Paris 2024 Olympic Games\", \"from\": 2593, \"to\": 2621}, {\"ngram\": \"Teahupo'o\", \"from\": 2625, \"to\": 2634}]}, {\"sentence\": \"/Xinhua The development of surfing to attract more young participants worldwide Surfing is perfect for the new era of the Games and selecting our sport for the Olympic program \\u00e2\\u0080\\u0093 with Tahiti as the venue \\u00e2\\u0080\\u0093 is testimony to the creative and inclusive spirit demonstrated by Paris 2024 and the International Olympic Committee (IOC).\", \"from\": 2677, \"to\": 3011, \"entities\": [{\"begin\": 2864, \"end\": 2870, \"title\": \"http://dbpedia.org/resource/Tahiti\", \"score\": 0.9999999423062053, \"rank\": 5.7693713370701704e-08, \"text\": \"Tahiti\", \"types\": [\"Q23442\"], \"wikid\": \"http://dbpedia.org/resource/Tahiti\", \"dbpedia\": \"http://dbpedia.org/resource/Tahiti\"}, {\"begin\": 2954, \"end\": 2964, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.1572255774549566e-33, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 2973, \"end\": 3004, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"The development\", \"from\": 2685, \"to\": 2700}, {\"ngram\": \"more young participants\", \"from\": 2723, \"to\": 2746}, {\"ngram\": \"Surfing\", \"from\": 2757, \"to\": 2764}, {\"ngram\": \"the new era\", \"from\": 2780, \"to\": 2791}, {\"ngram\": \"the Games\", \"from\": 2795, \"to\": 2804}, {\"ngram\": \"our sport\", \"from\": 2819, \"to\": 2828}, {\"ngram\": \"the Olympic program\", \"from\": 2833, \"to\": 2852}, {\"ngram\": \"the venue\", \"from\": 2872, \"to\": 2881}, {\"ngram\": \"\\u00e2\\u0080\\u0093\", \"from\": 2882, \"to\": 2885}, {\"ngram\": \"testimony\", \"from\": 2889, \"to\": 2898}, {\"ngram\": \"the creative and inclusive spirit\", \"from\": 2902, \"to\": 2935}, {\"ngram\": \"IOC\", \"from\": 3004, \"to\": 3007}]}, {\"sentence\": \"The International Surfing Association (ISA) was pleased to fully support this decision and our collective approach demonstrates clearly how the Olympic world is innovating to appeal to new audiences and generate excitement amongst young people.\", \"from\": 3012, \"to\": 3256, \"entities\": [{\"begin\": 3016, \"end\": 3049, \"title\": \"http://dbpedia.org/resource/International_Surfing_Association\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Surfing Association\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/International_Surfing_Association\", \"dbpedia\": \"http://dbpedia.org/resource/International_Surfing_Association\"}], \"noun_phrases\": [{\"ngram\": \"ISA\", \"from\": 3051, \"to\": 3054}, {\"ngram\": \"this decision\", \"from\": 3085, \"to\": 3098}, {\"ngram\": \"our collective approach\", \"from\": 3103, \"to\": 3126}, {\"ngram\": \"the Olympic world\", \"from\": 3152, \"to\": 3169}, {\"ngram\": \"new audiences\", \"from\": 3197, \"to\": 3210}, {\"ngram\": \"excitement\", \"from\": 3224, \"to\": 3234}, {\"ngram\": \"young people\", \"from\": 3243, \"to\": 3255}]}, {\"sentence\": \"The inclusion of surfing in the Olympic program in Tokyo 2020 was a landmark moment for the sport and for the Olympic Movement.\", \"from\": 3258, \"to\": 3385, \"entities\": [{\"begin\": 3309, \"end\": 3314, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.9999999999959073, \"rank\": 3.888974811393534e-12, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}, {\"begin\": 3368, \"end\": 3384, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 0.9999392465835796, \"rank\": 6.075710757331468e-05, \"text\": \"Olympic Movement\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"The inclusion\", \"from\": 3258, \"to\": 3271}, {\"ngram\": \"the Olympic program\", \"from\": 3286, \"to\": 3305}, {\"ngram\": \"a landmark moment\", \"from\": 3324, \"to\": 3341}, {\"ngram\": \"the sport\", \"from\": 3346, \"to\": 3355}]}, {\"sentence\": \"Now, with surfing enjoying a spectacular and enthralling second Games, the sport has already added great value and excitement with incredible action that is capturing the imaginations of a new generation.\", \"from\": 3386, \"to\": 3590, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a spectacular and enthralling second Games\", \"from\": 3413, \"to\": 3455}, {\"ngram\": \"the sport\", \"from\": 3457, \"to\": 3466}, {\"ngram\": \"great value\", \"from\": 3485, \"to\": 3496}, {\"ngram\": \"excitement\", \"from\": 3501, \"to\": 3511}, {\"ngram\": \"incredible action\", \"from\": 3517, \"to\": 3534}, {\"ngram\": \"the imaginations\", \"from\": 3553, \"to\": 3569}, {\"ngram\": \"a new generation\", \"from\": 3573, \"to\": 3589}]}, {\"sentence\": \"With its unique and modern blend of sport performance, lifestyle and culture, surfing is without doubt bringing new energy and relevance to the Olympic Games, much like snowboarding and other action sports had impacted the Olympic Winter Games years before.\", \"from\": 3592, \"to\": 3849, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"its unique and modern blend\", \"from\": 3597, \"to\": 3624}, {\"ngram\": \"sport performance\", \"from\": 3628, \"to\": 3645}, {\"ngram\": \"lifestyle\", \"from\": 3647, \"to\": 3656}, {\"ngram\": \"culture\", \"from\": 3661, \"to\": 3668}, {\"ngram\": \"surfing\", \"from\": 3670, \"to\": 3677}, {\"ngram\": \"doubt\", \"from\": 3689, \"to\": 3694}, {\"ngram\": \"new energy\", \"from\": 3704, \"to\": 3714}, {\"ngram\": \"relevance\", \"from\": 3719, \"to\": 3728}, {\"ngram\": \"the Olympic Games\", \"from\": 3732, \"to\": 3749}, {\"ngram\": \"snowboarding and other action sports\", \"from\": 3761, \"to\": 3797}, {\"ngram\": \"the Olympic Winter Games\", \"from\": 3811, \"to\": 3835}]}, {\"sentence\": \"With Los Angeles 2028 to follow and surfing's ambitions extending to Brisbane 2032 and beyond, the Olympic Movement has the opportunity to build on this momentum and to further enrich the Olympic experience long-term for a new, young demographic.\", \"from\": 3850, \"to\": 4096, \"entities\": [{\"begin\": 3855, \"end\": 3871, \"title\": \"http://dbpedia.org/resource/2028_Summer_Olympics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Los Angeles 2028\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2028_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2028_Summer_Olympics\"}, {\"begi