, \"to\": 176}]}, {\"sentence\": \"Carini took to Italian newspaper Gazzetta dello Sport to issue an apology to Khelif, who defeated her in a 46-second match on Thursday, inciting attacks on the boxer who once failed a now-discredited \\u00e2\\u0080\\u009cgender test\\u00e2\\u0080\\u009d conducted by the International Boxing Association.\", \"from\": 179, \"to\": 447, \"entities\": [{\"begin\": 179, \"end\": 185, \"title\": \"http://dbpedia.org/resource/Carini\", \"score\": 0.9999039352626006, \"rank\": 9.607396679751444e-05, \"text\": \"Carini\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Carini\", \"dbpedia\": \"http://dbpedia.org/resource/Carini\"}, {\"begin\": 194, \"end\": 201, \"title\": \"http://dbpedia.org/resource/Italian_language\", \"score\": 0.9998239839545388, \"rank\": 0.00011437424699443559, \"text\": \"Italian\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Italian_language\", \"dbpedia\": \"http://dbpedia.org/resource/Italian_language\"}, {\"begin\": 414, \"end\": 446, \"title\": \"http://dbpedia.org/resource/Women's_International_Boxing_Association\", \"score\": 1.0, \"rank\": 5.121073141669697e-16, \"text\": \"International Boxing Association\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Women's_International_Boxing_Association\", \"dbpedia\": \"http://dbpedia.org/resource/Women's_International_Boxing_Association\"}], \"noun_phrases\": [{\"ngram\": \"Gazzetta\", \"from\": 212, \"to\": 220}, {\"ngram\": \"Sport\", \"from\": 227, \"to\": 232}, {\"ngram\": \"an apology\", \"from\": 242, \"to\": 252}, {\"ngram\": \"Khelif\", \"from\": 256, \"to\": 262}, {\"ngram\": \"a 46-second match\", \"from\": 284, \"to\": 301}, {\"ngram\": \"Thursday\", \"from\": 305, \"to\": 313}, {\"ngram\": \"attacks\", \"from\": 324, \"to\": 331}, {\"ngram\": \"the boxer\", \"from\": 335, \"to\": 344}, {\"ngram\": \"a now-discredited \\u00e2\\u0080\\u009cgender test\\u00e2\\u0080\\u009d\", \"from