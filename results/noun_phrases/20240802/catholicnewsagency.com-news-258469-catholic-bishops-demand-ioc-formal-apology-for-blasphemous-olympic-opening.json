hrases\": [{\"ngram\": \"a first response\", \"from\": 2212, \"to\": 2228}, {\"ngram\": \"the scandal\", \"from\": 2232, \"to\": 2243}, {\"ngram\": \"the ceremony\", \"from\": 2258, \"to\": 2270}, {\"ngram\": \"the artistic director\", \"from\": 2272, \"to\": 2293}, {\"ngram\": \"the ceremony\", \"from\": 2310, \"to\": 2322}, {\"ngram\": \"local broadcaster BFMTV\", \"from\": 2343, \"to\": 2366}, {\"ngram\": \"the scene\", \"from\": 2367, \"to\": 2376}, {\"ngram\": \"the Last Supper\", \"from\": 2412, \"to\": 2427}]}, {\"sentence\": \"\\\"You will never find in my work a desire to denigrate anyone or anything,\\\" Jolly said, according to Reuters.\", \"from\": 2430, \"to\": 2538, \"entities\": [{\"begin\": 2530, \"end\": 2537, \"title\": \"http://dbpedia.org/resource/Reuters\", \"score\": 1.0, \"rank\": 1.7970082245103467e-17, \"text\": \"Reuters\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Reuters\", \"dbpedia\": \"http://dbpedia.org/resource/Reuters\"}], \"noun_phrases\": [{\"ngram\": \"my work\", \"from\": 2454, \"to\": 2461}, {\"ngram\": \"a desire\", \"from\": 2462, \"to\": 2470}, {\"ngram\": \"anyone\", \"from\": 2484, \"to\": 2490}, {\"ngram\": \"anything\", \"from\": 2494, \"to\": 2502}, {\"ngram\": \"Jolly\", \"from\": 2505, \"to\": 2510}]}, {\"sentence\": \"One day later, Olympics spokesperson Anne Descamps said, according toReuters: \\\"Clearly there was never an intention to show disrespect to any religious group.\", \"from\": 2540, \"to\": 2698, \"entities\": [{\"begin\": 2582, \"end\": 2590, \"title\": \"http://dbpedia.org/resource/Jean-Baptiste_Descamps\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Descamps\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Jean-Baptiste_Descamps\", \"dbpedia\": \"http://dbpedia.org/resource/Jean-Baptiste_Descamps\"}], \"noun_phrases\": [{\"ngram\": \"toReuters\", \"from\": 2607, \"to\": 2616}, {\"ngram\": \"an intention\", \"from\": 2643, \"to\": 2655}, {\"