 {\"sentence\": \"You could find \\\"Paris 2024\\\" branded on metal gating outside and giant Olympic rings beside the first tee, but otherwise this was just another pristine golf course.\", \"from\": 801, \"to\": 964, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Paris\", \"from\": 817, \"to\": 822}, {\"ngram\": \"metal\", \"from\": 840, \"to\": 845}, {\"ngram\": \"the first tee\", \"from\": 892, \"to\": 905}, {\"ngram\": \"just another pristine golf course\", \"from\": 930, \"to\": 963}]}, {\"sentence\": \"And then they came.\", \"from\": 966, \"to\": 985, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Spectators driven in by the busload, one after another after another, shuttled in from a nearby train station and deposited at the door.\", \"from\": 986, \"to\": 1122, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Spectators\", \"from\": 986, \"to\": 996}, {\"ngram\": \"the busload\", \"from\": 1010, \"to\": 1021}, {\"ngram\": \"another\", \"from\": 1033, \"to\": 1040}, {\"ngram\": \"another\", \"from\": 1047, \"to\": 1054}, {\"ngram\": \"a nearby train station\", \"from\": 1073, \"to\": 1095}, {\"ngram\": \"the door\", \"from\": 1113, \"to\": 1121}]}, {\"sentence\": \"They were not just golf fans, either: families with children wearing face paint and couples carrying flags; not just locals but Americans, Canadians, Koreans, Australians and Scandinavians here to watch.\", \"from\": 1123, \"to\": 1326, \"entities\": [{\"begin\": 1273, \"end\": 1280, \"title\": \"http://dbpedia.org/resource/Koreans\", \"score\": 0.9998833018420648, \"rank\": 9.309238625707645e-05, \"text\": \"Koreans\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Koreans\", \"dbpedia\": \"http://dbpedia.org/resource/Koreans\"}, {\"begin\": 1298, \"end\": 1311, \"title\": \"http://dbpedia.org/resource/Scandinavia\", \"score\": 0.9964908388125342, \"rank\": 0.0035205785121520065, \"text\": \"Scandinavians\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.