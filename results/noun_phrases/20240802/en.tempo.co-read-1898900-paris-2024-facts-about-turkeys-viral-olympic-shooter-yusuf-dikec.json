{\"ngram\": \"Netizens\", \"from\": 375, \"to\": 383}, {\"ngram\": \"an ordinary man\", \"from\": 395, \"to\": 410}, {\"ngram\": \"theOlympics\", \"from\": 448, \"to\": 459}, {\"ngram\": \"his style\", \"from\": 484, \"to\": 493}, {\"ngram\": \"a killer\", \"from\": 505, \"to\": 513}]}, {\"sentence\": \"Meanwhile, Indonesian netizens described him as a \\\"housing complex dad.\\\"\", \"from\": 515, \"to\": 587, \"entities\": [{\"begin\": 526, \"end\": 536, \"title\": \"http://dbpedia.org/resource/Indonesia\", \"score\": 0.9999999999990905, \"rank\": 1.1509406917308876e-12, \"text\": \"Indonesian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Indonesia\", \"dbpedia\": \"http://dbpedia.org/resource/Indonesia\"}], \"noun_phrases\": [{\"ngram\": \"a \\\"housing complex dad\", \"from\": 563, \"to\": 585}]}, {\"sentence\": \"Memes were quickly generated, some contrasting him with his Serbian opponent, Damir Mikec, who wore the official blinders over one eye, a lens over the other, and large ear protectors.\", \"from\": 589, \"to\": 773, \"entities\": [{\"begin\": 649, \"end\": 656, \"title\": \"http://dbpedia.org/resource/Serbia\", \"score\": 0.9998938586258942, \"rank\": 0.00010581949908336594, \"text\": \"Serbian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Serbia\", \"dbpedia\": \"http://dbpedia.org/resource/Serbia\"}, {\"begin\": 667, \"end\": 678, \"title\": \"http://dbpedia.org/resource/Damir_Mikec\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Damir Mikec\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Damir_Mikec\", \"dbpedia\": \"http://dbpedia.org/resource/Damir_Mikec\"}], \"noun_phrases\": [{\"ngram\": \"Memes\", \"from\": 589, \"to\": 594}, {\"ngram\": \"the official blinders\", \"from\": 689, \"to\": 710}, {\"ngram\": \"one eye\", \"from\": 716, \"to\": 723}, {\"ngram\": \"a lens\", \"from\": 725, \"to\": 731}, {\"ngram\": \"large ear protectors\", \"from\": 752, \"to\": 772}]}, {\"sentence\": \"Mikec and his partner Zorana Arunovi and Damir Mikec went on to win gold for the Serbian team.\", \"from\": 774, \"to\": 868, \"entities\": [{\"begin\": 815, \"end\": 826, \"title\": \"http://dbpedia.org/resource/Damir_Mikec\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Damir Mikec\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Damir_Mikec\", \"dbpedia\": \"http://dbpedia.org/resource/Damir_Mikec\"}, {\"begin\": 855, \"end\": 862, \"title\": \"http://dbpedia.org/resource/Serbia\", \"score\": 0.9998938586258942, \"rank\": 0.00010581949908336594, \"text\": \"Serbian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Serbia\", \"dbpedia\": \"http://dbpedia.org/resource/Serbia\"}], \"noun_phrases\": [{\"ngram\": \"Mikec\", \"from\": 774, \"to\": 779}, {\"ngram\": \"his partner\", \"from\": 784, \"to\": 795}, {\"ngram\": \"Zorana Arunovi\", \"from\": 796, \"to\": 810}, {\"ngram\": \"gold\", \"from\": 842, \"to\": 846}]}, {\"sentence\": \"Here are some known facts about Yusuf Dikec, the Turkish Olympian who is -- at the moment -- an Internet sensation.\", \"from\": 870, \"to\": 985, \"entities\": [{\"begin\": 902, \"end\": 907, \"title\": \"http://dbpedia.org/resource/Cat_Stevens\", \"score\": 0.9999999999008651, \"rank\": 5.810902238714658e-11, \"text\": \"Yusuf\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Cat_Stevens\", \"dbpedia\": \"http://dbpedia.org/resource/Cat_Stevens\"}, {\"begin\": 919, \"end\": 926, \"title\": \"http://dbpedia.org/resource/Turkey\", \"score\": 0.9610680697727413, \"rank\": 0.0403333689591827, \"text\": \"Turkish\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Turkey\", \"dbpedia\": \"http://dbpedia.org/resource/Turkey\"}, {\"begin\": 927, \"end\": 935, \"title\": \"http://dbpedia.org/resource/Olympic_Games\", \"score\": 0.9999999991123332, \"rank\": 8.8803086