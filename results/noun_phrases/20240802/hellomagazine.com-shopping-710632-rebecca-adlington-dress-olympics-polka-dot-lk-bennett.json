_phrases\": [{\"ngram\": \"The website's description\", \"from\": 896, \"to\": 921}, {\"ngram\": \"the look\", \"from\": 925, \"to\": 933}, {\"ngram\": \"a lightweight\", \"from\": 971, \"to\": 984}, {\"ngram\": \"floaty fabric\", \"from\": 989, \"to\": 1002}, {\"ngram\": \"a green and red spot print\", \"from\": 1006, \"to\": 1032}, {\"ngram\": \"a sleeveless, slightly-sheer style\", \"from\": 1039, \"to\": 1073}, {\"ngram\": \"a slip base\", \"from\": 1079, \"to\": 1090}, {\"ngram\": \"a round neck\", \"from\": 1100, \"to\": 1112}, {\"ngram\": \"pleat detail\", \"from\": 1118, \"to\": 1130}, {\"ngram\": \"a jaunty side tie\", \"from\": 1132, \"to\": 1149}, {\"ngram\": \"a midi skirt\", \"from\": 1155, \"to\": 1167}, {\"ngram\": \"an asymmetric tier\", \"from\": 1173, \"to\": 1191}]}, {\"sentence\": \"My suggestion would be to wear it with a pair of heels and for a summer wedding or a special birthday dinner.\", \"from\": 1195, \"to\": 1304, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My suggestion\", \"from\": 1195, \"to\": 1208}, {\"ngram\": \"a pair\", \"from\": 1234, \"to\": 1240}, {\"ngram\": \"heels\", \"from\": 1244, \"to\": 1249}, {\"ngram\": \"a summer wedding\", \"from\": 1258, \"to\": 1274}, {\"ngram\": \"a special birthday dinner\", \"from\": 1278, \"to\": 1303}]}, {\"sentence\": \"The mother-of-two added tan high heeled espadrilles (this summer shoe is adored by the Princess of Wales and the Duchess of Sussex FYI)and wore her famous blonde locks swept back.\", \"from\": 1306, \"to\": 1485, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"added tan\", \"from\": 1324, \"to\": 1333}, {\"ngram\": \"this summer shoe\", \"from\": 1359, \"to\": 1375}, {\"ngram\": \"the Princess\", \"from\": 1389, \"to\": 1401}, {\"ngram\": \"Wales\", \"from\": 1405, \"to\": 1410}, {\"ngram\": \"the Duchess\", \"from\": 1415, \"to\": 1426}, {\"ngram\": \"Sussex\", \"from\": 1430, \"to\": 1436}, {\"ngram\": \"her famous blonde locks\", \"from\": 1450, \"to\": 1473}]}, {\"sentence\": \"Becky's super chic look was put together bysublime stylistto the stars,Martine Alexander.The talented professional helpfully gave us the lowdown on how you can style polka-dots into your wardrobe.\", \"from\": 1487, \"to\": 1683, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Becky's super chic look\", \"from\": 1487, \"to\": 1510}, {\"ngram\": \"the stars\", \"from\": 1548, \"to\": 1557}, {\"ngram\": \"Martine Alexander\", \"from\": 1558, \"to\": 1575}, {\"ngram\": \"The talented professional\", \"from\": 1576, \"to\": 1601}, {\"ngram\": \"us\", \"from\": 1617, \"to\": 1619}, {\"ngram\": \"the lowdown\", \"from\": 1620, \"to\": 1631}, {\"ngram\": \"polka-dots\", \"from\": 1653, \"to\": 1663}, {\"ngram\": \"your wardrobe\", \"from\": 1669, \"to\": 1682}]}, {\"sentence\": \"\\\"As a rule, I always say make the bold print the main focus of your outfit.\", \"from\": 1685, \"to\": 1760, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a rule\", \"from\": 1689, \"to\": 1695}, {\"ngram\": \"the bold print\", \"from\": 1715, \"to\": 1729}, {\"ngram\": \"your outfit\", \"from\": 1748, \"to\": 1759}]}, {\"sentence\": \"With Becky's LK Bennett dress, we wanted to let the dress speak!\", \"from\": 1761, \"to\": 1825, \"entities\": [{\"begin\": 1774, \"end\": 1784, \"title\": \"http://dbpedia.org/resource/L.K.Bennett\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"LK Bennett\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/L.K.Bennett\", \"dbpedia\": \"http://dbpedia.org/resource/L.K.Bennett\"}], \"noun_phrases\": [{\"ngram\": \"the dress\", \"from\": 1809, \"to\": 1818}]}, {\"sentence\": \"We styled it with anude espadrille from Aspigaand Becky chose to have a simple hair style so her look wasn't too much.\", \"from\": 1826, \"to\": 1944, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"anude espadrille\", \"from\": 1844, \"to\": 1860}, {\"ngram\": \"Aspigaand Becky\", \"from\": 1866, \"to\": 1881}, {\"ngram\": \"a simple hair style\", \"from\": 1896, \"to\": 1915}, {\"ngram\": \"her look\", \"from\": 1919, \"to\": 1927}]}, {\"sentence\": \"\\\"However, if your style is more edgy and you want to make a bold statement, then clash your polka dots with a stripe!\", \"from\": 1946, \"to\": 2063, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"your style\", \"from\": 1959, \"to\": 1969}, {\"ngram\": \"a bold statement\", \"from\": 2004, \"to\": 2020}, {\"ngram\": \"your polka dots\", \"from\": 2033, \"to\": 2048}, {\"ngram\": \"a stripe\", \"from\": 2054, \"to\": 2062}]}, {\"sentence\": \"It's a simple but very effective way to stand out, for all the right reasons.\\\"\", \"from\": 2064, \"to\": 2142, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a simple but very effective way\", \"from\": 2069, \"to\": 2100}, {\"ngram\": \"all the right reasons\", \"from\": 2119, \"to\": 2140}]}, {\"sentence\": \"Martine added: \\\"Using polka dots as an accent in a block colour outfit is an easy way to create some interest without making it too garish, if that's not your personal style.\", \"from\": 2144, \"to\": 2318, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Martine\", \"from\": 2144, \"to\": 2151}, {\"ngram\": \"polka dots\", \"from\": 2166, \"to\": 2176}, {\"ngram\": \"an accent\", \"from\": 2180, \"to\": 2189}, {\"ngram\": \"a block colour outfit\", \"from\": 2193, \"to\": 2214}, {\"ngram\": \"an easy way\", \"from\": 2218, \"to\": 2229}, {\"ngram\": \"some interest\", \"from\": 2240, \"to\": 2253}, {\"ngram\": \"your personal style\", \"from\": 2298, \"to\": 2317}]}, {\"sentence\": \"For example, a polka dot neck scarf (can also be used as a twilly on your bag), headband, court shoe or pussy bow will just give a nod to the trend without being overkill.\", \"from\": 2319, \"to\": 2490, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"example\", \"from\": 2323, \"to\": 2330}, {\"ngram\": \"a polka dot neck scarf\", \"from\": 2332, \"to\": 2354}, {\"ngram\": \"a twilly\", \"from\": 2376, \"to\": 2384}, {\"ngram\": \"your bag\", \"from\": 2388, \"to\": 2396}, {\"ngram\": \"headband\", \"from\": 2399, \"to\": 2407}, {\"ngram\": \"court shoe\", \"from\": 2409, \"to\": 2419}, {\"ngram\": \"pussy bow\", \"from\": 2423, \"to\": 2432}, {\"ngram\": \"a nod\", \"from\": 2448, \"to\": 2453}, {\"ngram\": \"the trend\", \"from\": 2457, \"to\": 2466}]}, {\"sentence\": \"If you have found a dress or jumpsuit you love that's a very bold polka dot but it's too much for you, layer over with a blazer to tone down the overall look.\\\"\", \"from\": 2492, \"to\": 2651, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a dress\", \"from\": 2510, \"to\": 2517}, {\"ngram\": \"jumpsuit\", \"from\": 2521, \"to\": 2529}, {\"ngram\": \"a very bold polka dot\", \"from\": 2546, \"to\": 2567}, {\"ngram\": \"layer\", \"from\": 2595, \"to\": 2600}, {\"ngram\": \"a blazer\", \"from\": 2611, \"to\": 2619}, {\"ngram\": \"the overall look\", \"from\": 2633, \"to\": 2649}]}, {\"sentence\": \"Supported by Friends Like These\", \"from\": 2655, \"to\": 2686, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Friends\", \"from\": 2668, \"to\": 2675}]}]}"