es\": [{\"ngram\": \"my teammates\", \"from\": 7191, \"to\": 7203}, {\"ngram\": \"my sisters\", \"from\": 7219, \"to\": 7229}]}, {\"sentence\": \"We grew up together.\", \"from\": 7231, \"to\": 7251, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I spent more time with my teammates and athletes in Afghanistan than my family, playing on the national team together.\", \"from\": 7252, \"to\": 7370, \"entities\": [{\"begin\": 7304, \"end\": 7315, \"title\": \"http://dbpedia.org/resource/Afghanistan\", \"score\": 0.9361858381378713, \"rank\": 0.06816398973665337, \"text\": \"Afghanistan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Afghanistan\", \"dbpedia\": \"http://dbpedia.org/resource/Afghanistan\"}], \"noun_phrases\": [{\"ngram\": \"more time\", \"from\": 7260, \"to\": 7269}, {\"ngram\": \"my teammates\", \"from\": 7275, \"to\": 7287}, {\"ngram\": \"athletes\", \"from\": 7292, \"to\": 7300}, {\"ngram\": \"my family\", \"from\": 7321, \"to\": 7330}, {\"ngram\": \"the national team\", \"from\": 7343, \"to\": 7360}]}, {\"sentence\": \"So I put aside my research paper, and that year I did not celebrate my graduation; how I could celebrate my graduation when everything is banned for women in Afghanistan?\", \"from\": 7371, \"to\": 7541, \"entities\": [{\"begin\": 7529, \"end\": 7540, \"title\": \"http://dbpedia.org/resource/Afghanistan\", \"score\": 0.9361858381378713, \"rank\": 0.06816398973665337, \"text\": \"Afghanistan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Afghanistan\", \"dbpedia\": \"http://dbpedia.org/resource/Afghanistan\"}], \"noun_phrases\": [{\"ngram\": \"my research paper\", \"from\": 7386, \"to\": 7403}, {\"ngram\": \"my graduation\", \"from\": 7439, \"to\": 7452}, {\"ngram\": \"my graduation\", \"from\": 7476, \"to\": 7489}, {\"ngram\": \"everything\", \"from\": 7495, \"to\": 7505}, {\"ngram\": \"women\", \"from\": 7520, \"to\": 7525}]}, {\"sentence\": \"I started communicating with athletes; I 