": 398, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The move\", \"from\": 264, \"to\": 272}, {\"ngram\": \"Wednesday\", \"from\": 287, \"to\": 296}, {\"ngram\": \"a symbolic break\", \"from\": 301, \"to\": 317}, {\"ngram\": \"the amateur past\", \"from\": 323, \"to\": 339}, {\"ngram\": \"the Olympics\", \"from\": 343, \"to\": 355}, {\"ngram\": \"the games' most-watched events\", \"from\": 367, \"to\": 397}]}, {\"sentence\": \"The governing body of athletics said it is setting aside $2.4m to pay the gold medalists across the 48 men's, women's and mixed events on the track and field programme for this year's Paris Olympics.\", \"from\": 400, \"to\": 599, \"entities\": [{\"begin\": 584, \"end\": 598, \"title\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Paris Olympics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/1924_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"The governing body\", \"from\": 400, \"to\": 418}, {\"ngram\": \"athletics\", \"from\": 422, \"to\": 431}, {\"ngram\": \"the gold medalists\", \"from\": 470, \"to\": 488}, {\"ngram\": \"the 48 men's, women's and mixed events\", \"from\": 496, \"to\": 534}, {\"ngram\": \"the track and field programme\", \"from\": 538, \"to\": 567}]}, {\"sentence\": \"Relay teams will split the $50,000 among their members.\", \"from\": 600, \"to\": 655, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Relay teams\", \"from\": 600, \"to\": 611}, {\"ngram\": \"their members\", \"from\": 641, \"to\": 654}]}, {\"sentence\": \"Payments for silver and bronze medalists are planned to start from the 2028 Olympics in Los Angeles.\", \"from\": 656, \"to\": 756, \"entities\": [{\"begin\": 744, \"end\": 755, \"title\": \"http://dbpedia.org/resource/Los_Angeles\", \"score\": 0.9999877284358618, \"rank\": 1.0915100721960394e-05, \"text\": \"Los Angeles\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Los_Angeles\", \"dbpedia\": \"http://dbpedia.org/resource/Los_Angeles\"}], \"noun_phrases\": [{\"ngram\": \"Payments\", \"from\": 656, \"to\": 664}, {\"ngram\": \"silver and bronze medalists\", \"from\": 669, \"to\": 696}, {\"ngram\": \"the 2028 Olympics\", \"from\": 723, \"to\": 740}]}, {\"sentence\": \"World Athletics President Sebastian Coe told reporters that the move is meant \\\"to recognize that the revenue share that we receive is in large part because our athletes are the stars of the show\\\".\", \"from\": 758, \"to\": 954, \"entities\": [{\"begin\": 758, \"end\": 773, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 1.0, \"rank\": 1.8441799586129887e-14, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}, {\"begin\": 784, \"end\": 797, \"title\": \"http://dbpedia.org/resource/Sebastian_Coe\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Sebastian Coe\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Sebastian_Coe\", \"dbpedia\": \"http://dbpedia.org/resource/Sebastian_Coe\"}], \"noun_phrases\": [{\"ngram\": \"reporters\", \"from\": 803, \"to\": 812}, {\"ngram\": \"the move\", \"from\": 818, \"to\": 826}, {\"ngram\": \"the revenue share\", \"from\": 855, \"to\": 872}, {\"ngram\": \"large part\", \"from\": 895, \"to\": 905}, {\"ngram\": \"our athletes\", \"from\": 914, \"to\": 926}, {\"ngram\": \"the stars\", \"from\": 931, \"to\": 940}, {\"ngram\": \"the show\", \"from\": 944, \"to\": 952}]}, {\"sentence\": \"The prize money will come out of the share of Olympic revenue that the International Olympic Committee (IOC) distributes to World Athletics.\", \"from\": 956, \"to\": 1096, \"entities\": [{\"begin\": 1027, \"end\": 1064, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee (IOC)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 1080, \"end\": 1095, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 1.0, \"rank\": 1.8441799586129887e-14, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}], \"noun_phrases\": [{\"ngram\": \"The prize money\", \"from\": 956, \"to\": 971}, {\"ngram\": \"the share\", \"from\": 989, \"to\": 998}, {\"ngram\": \"Olympic revenue\", \"from\": 1002, \"to\": 1017}]}, {\"sentence\": \"However, the move could upset the balance of power in the Olympic movement ahead of the Paris Games.\", \"from\": 1098, \"to\": 1198, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the move\", \"from\": 1107, \"to\": 1115}, {\"ngram\": \"the balance\", \"from\": 1128, \"to\": 1139}, {\"ngram\": \"power\", \"from\": 1143, \"to\": 1148}, {\"ngram\": \"the Olympic movement\", \"from\": 1152, \"to\": 1172}, {\"ngram\": \"the Paris Games\", \"from\": 1182, \"to\": 1197}]}, {\"sentence\": \"Coe said World Athletics gave the IOC \\\"a heads-up\\\" of its intentions only on Wednesday morning, shortly before it published its announcement.\", \"from\": 1199, \"to\": 1340, \"entities\": [{\"begin\": 1208, \"end\": 1223, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 1.0, \"rank\": 1.8441799586129887e-14, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}, {\"begin\": 1233, \"end\": 1236, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.