"{\"uid\": \"newzimbabwe.com-paris-olympics-50000-for-a-gold-athletics-becomes-first-sport-to-offer-prize-money-to-olympians\", \"noun_phrases\": [{\"sentence\": \"Date: SkyNews Athletics will become the first sport to introduce prize money at the Olympics this summer.\", \"from\": 0, \"to\": 107, \"entities\": [{\"begin\": 7, \"end\": 14, \"title\": \"http://dbpedia.org/resource/Sky_News\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"SkyNews\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Sky_News\", \"dbpedia\": \"http://dbpedia.org/resource/Sky_News\"}], \"noun_phrases\": [{\"ngram\": \"the first sport\", \"from\": 36, \"to\": 51}, {\"ngram\": \"prize money\", \"from\": 65, \"to\": 76}, {\"ngram\": \"the Olympics\", \"from\": 80, \"to\": 92}]}, {\"sentence\": \"World Athletics, the international athletics federation, says it will pay Olympic gold medal winners $50,000 (around \\u00a339,400) at the Paris games.\", \"from\": 109, \"to\": 254, \"entities\": [{\"begin\": 109, \"end\": 124, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 0.9999999167332624, \"rank\": 8.326675894106134e-08, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}, {\"begin\": 242, \"end\": 247, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999990272954, \"rank\": 9.727076556505664e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"the international athletics federation\", \"from\": 126, \"to\": 164}, {\"ngram\": \"Olympic gold medal winners\", \"from\": 183, \"to\": 209}]}, {\"sentence\": \"The athletics governing body said it is setting aside $2.4m (\\u00a31.89m) to pay the gold medallists across 48 events at Paris' track and field programme.\", \"from\": 256, \"to\": 405, \"entities\": [{\"begin\": 372, \"end\": 377, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999990272954, \"rank\": 9.727076556505664e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"The athletics\", \"from\": 256, \"to\": 269}, {\"ngram\": \"body\", \"from\": 280, \"to\": 284}, {\"ngram\": \"$2.4m\", \"from\": 310, \"to\": 315}, {\"ngram\": \"the gold\", \"from\": 332, \"to\": 340}, {\"ngram\": \"medallists\", \"from\": 341, \"to\": 351}, {\"ngram\": \"48 events\", \"from\": 359, \"to\": 368}]}, {\"sentence\": \"Relay teams will split the $50,000 between their members.\", \"from\": 407, \"to\": 464, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Relay teams\", \"from\": 407, \"to\": 418}, {\"ngram\": \"their members\", \"from\": 450, \"to\": 463}]}, {\"sentence\": \"Payments for silver and bronze medallists are planned to begin at the 2028 Olympics in Los Angeles.\", \"from\": 466, \"to\": 565, \"entities\": [{\"begin\": 553, \"end\": 564, \"title\": \"http://dbpedia.org/resource/Los_Angeles\", \"score\": 0.9999999498252249, \"rank\": 3.038744396885522e-08, \"text\": \"Los Angeles\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Los_Angeles\", \"dbpedia\": \"http://dbpedia.org/resource/Los_Angeles\"}], \"noun_phrases\": [{\"ngram\": \"Payments\", \"from\": 466, \"to\": 474}, {\"ngram\": \"silver and bronze medallists\", \"from\": 479, \"to\": 507}, {\"ngram\": \"the 2028 Olympics\", \"from\": 532, \"to\": 549}]}, {\"sentence\": \"World Athletics President Sebastian Coe said: \\\"The introduction of prize money for Olympic gold medallists is a pivotal moment for World Athletics and the sport of athletics as a whole, underscoring our commitment to empowering the athletes and recognising the critical role they play in the success of any Olympic Games.\", \"from\": 567, \"to\": 888, \"entities\": [{\"begin\": 567, \"end\": 582, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 0.9999999167332624, \"rank\": 8.326675894106134e-08, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}, {\"begin\": 593, \"end\": 606, \"title\": \"http://dbpedia.org/resource/Sebastian_Coe\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Sebastian Coe\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Sebastian_Coe\", \"dbpedia\": \"http://dbpedia.org/resource/Sebastian_Coe\"}, {\"begin\": 698, \"end\": 713, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 0.9999999167332624, \"rank\": 8.326675894106134e-08, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}], \"noun_phrases\": [{\"ngram\": \"The introduction\", \"from\": 614, \"to\": 630}, {\"ngram\": \"prize money\", \"from\": 634, \"to\": 645}, {\"ngram\": \"Olympic gold medallists\", \"from\": 650, \"to\": 673}, {\"ngram\": \"a pivotal moment\", \"from\": 677, \"to\": 693}, {\"ngram\": \"the sport\", \"from\": 718, \"to\": 727}, {\"ngram\": \"athletics\", \"from\": 731, \"to\": 740}, {\"ngram\": \"a whole\", \"from\": 744, \"to\": 751}, {\"ngram\": \"our commitment\", \"from\": 766, \"to\": 780}, {\"ngram\": \"the athletes\", \"from\": 795, \"to\": 807}, {\"ngram\": \"the critical role\", \"from\": 824, \"to\": 841}, {\"ngram\": \"the success\", \"from\": 855, \"to\": 866}, {\"ngram\": \"any Olympic Games\", \"from\": 870, \"to\": 887}]}, {\"sentence\": \"\\\"This is the continuation of a journey we started back in 2015, which sees all the money World Athletics receives from the International Olympic Committee for the Olympic Games go directly back into our sport.\\\"\", \"from\": 890, \"to\": 1100, \"entities\": [{\"begin\": 979, \"end\": 994, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 0.9999999167332624, \"rank\": 8.326675894106134e-08, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}, {\"begin\": 1013, \"end\": 1044, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"the continuation\", \"from\": 899, \"to\": 915}, {\"ngram\": \"a journey\", \"from\": 919, \"to\": 928}, {\"ngram\": \"all the money\", \"from\": 965, \"to\": 978}, {\"ngram\": \"the Olympic Games\", \"from\": 1049, \"to\": 1066}, {\"ngram\": \"our sport\", \"from\": 1089, \"to\": 1098}]}, {\"sentence\": \"He added: \\\"While it is impossible to put a marketable value on winning an Olympic medal, or on the commitment and focus it takes to even represent your country at an Olympic Games, I think it is important we start somewhere and make sure some of the revenues generated by our athletes at the Olympic Games are directly returned to those who make the Games the global spectacle that it is.\\\"\", \"from\": 1102, \"to\": 1491, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a marketable value\", \"from\": 1143, \"to\": 1161}, {\"ngram\": \"an Olympic medal\", \"from\": 1173, \"to\": 1189}, {\"ngram\": \"the commitment\", \"from\": 1197, \"to\": 1211}, {\"ngram\": \"your country\", \"from\": 1249, \"to\": 1261}, {\"ngram\": \"an Olympic Games\", \"from\": 1265, \"to\": 1281}, {\"ngram\": \"the revenues\", \"from\": 1348, \"to\": 1360}, {\"ngram\": \"our athletes\", \"from\": 1374, \"to\": 1386}, {\"ngram\": \"the Olympic Games\", \"from\": 1390, \"to\": 1407}, {\"ngram\": \"the Games\", \"from\": 1448, \"to\": 1457}]}, {\"sentence\": \"The payment of prize money will depend upon the World Athletics ratification process, including athletes undergoing and clearing the usual anti-doping procedures.\", \"from\": 1493, \"to\": 1655, \"entities\": [{\"begin\": 1541, \"end\": 1556, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 0.9999999167332624, \"rank\": 8.326675894106134e-08, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}], \"noun_phrases\": [{\"ngram\": \"The payment\", \"from\": 1493, \"to\": 1504}, {\"ngram\": \"prize money\", \"from\": 1508, \"to\": 1519}, {\"ngram\": \"athletes\", \"from\": 1589, \"to\": 1597}, {\"ngram\": \"the usual anti-doping procedures\", \"from\": 1622, \"to\": 1654}]}, {\"sentence\": \"The modern Olympics originated as an amateur sports event and the International Olympic Committee does not award prize money, though many medallists receive payments from their countries' governments, national sports bodies or from sponsors.\", \"from\": 1657, \"to\": 1898, \"entities\": [{\"begin\": 1723, \"end\": 1754, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"The modern Olympics\", \"from\": 1657, \"to\": 1676}, {\"ngram\": \"an amateur sports event\", \"from\": 1691, \"to\": 1714}, {\"ngram\": \"prize money\", \"from\": 1770, \"to\": 1781}, {\"ngram\": \"many medallists\", \"from\": 1790, \"to\": 1805}, {\"ngram\": \"payments\", \"from\": 1814, \"to\": 1822}, {\"ngram\": \"their countries' governments\", \"from\": 1828, \"to\": 1856}, {\"ngram\": \"national sports bodies\", \"from\": 1858, \"to\": 1880}, {\"ngram\": \"sponsors\", \"from\": 1889, \"to\": 1897}]}, {\"sentence\": \"As well as the various men's and women's running races - both with and without hurdles - gold medallists in events including long jump, high jump, triple jump, hammer throw, javelin throw, discus throw, pole vault and shot put will receive the prize money.\", \"from\": 1900, \"to\": 2156, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"As well as the various men's and women's running races\", \"from\": 1900, \"to\": 1954}, {\"ngram\": \"hurdles - gold medallists\", \"from\": 1979, \"to\": 2004}, {\"ngram\": \"events\", \"from\": 2008, \"to\": 2014}, {\"ngram\": \"long jump\", \"from\": 2025, \"to\": 2034}, {\"ngram\": \"high jump\", \"from\": 2036, \"to\": 2045}, {\"ngram\": \"triple jump\", \"from\": 2047, \"to\": 2058}, {\"ngram\": \"hammer throw\", \"from\": 2060, \"to\": 2072}, {\"ngram\": \"javelin throw\", \"from\": 2074, \"to\": 2087}, {\"ngram\": \"discus throw\", \"from\": 2089, \"to\": 2101}, {\"ngram\": \"pole vault\", \"from\": 2103, \"to\": 2113}, {\"ngram\": \"shot put\", \"from\": 2118, \"to\": 2126}, {\"ngram\": \"the prize money\", \"from\": 2140, \"to\": 2155}]}, {\"sentence\": \"Race walking, the women's heptathlon and men's decathlon Olympic winners will also receive $50,000.\", \"from\": 2158, \"to\": 2257, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the women's heptathlon and men's decathlon Olympic winners\", \"from\": 2172, \"to\": 2230}]}, {\"sentence\": \"The International Olympic Committee did not immediately respond to Sky News' request for comment.\", \"from\": 2259, \"to\": 2356, \"entities\": [{\"begin\": 2263, \"end\": 2294, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 2326, \"end\": 2334, \"title\": \"http://dbpedia.org/resource/Sky_News\", \"score\": 0.9999999999067768, \"rank\": 9.320716254362655e-11, \"text\": \"Sky News\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Sky_News\", \"dbpedia\": \"http://dbpedia.org/resource/Sky_News\"}], \"noun_phrases\": [{\"ngram\": \"comment\", \"from\": 2348, \"to\": 2355}]}, {\"sentence\": \"NewZimbabwe.com - The Zimbabwe News You Trust is Zimbabwe's leading online newspaper and published by New Zimbabwe Media Ltd.\", \"from\": 2360, \"to\": 2485, \"entities\": [{\"begin\": 2409, \"end\": 2417, \"title\": \"http://dbpedia.org/resource/Zimbabwe\", \"score\": 0.9999999839219528, \"rank\": 1.1066124012977249e-08, \"text\": \"Zimbabwe\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Zimbabwe\", \"dbpedia\": \"http://dbpedia.org/resource/Zimbabwe\"}, {\"begin\": 2466, \"end\": 2474, \"title\": \"http://dbpedia.org/resource/Zimbabwe\", \"score\": 0.9999999839219528, \"rank\": 1.1066124012977249e-08, \"text\": \"Zimbabwe\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Zimbabwe\", \"dbpedia\": \"http://dbpedia.org/resource/Zimbabwe\"}], \"noun_phrases\": [{\"ngram\": \"The Zimbabwe News\", \"from\": 2378, \"to\": 2395}, {\"ngram\": \"You Trust\", \"from\": 2396, \"to\": 2405}]}, {\"sentence\": \"The platform brings you the latest breaking News, Business, Showbiz, Sports, Diaspora and gives you everything you have come to expect and love.\", \"from\": 2487, \"to\": 2631, \"entities\": [{\"begin\": 2564, \"end\": 2572, \"title\": \"http://dbpedia.org/resource/African_diaspora\", \"score\": 0.8999060724528299, \"rank\": 0.1107016179908148, \"text\": \"Diaspora\", \"types\": [\"Q41710\"]