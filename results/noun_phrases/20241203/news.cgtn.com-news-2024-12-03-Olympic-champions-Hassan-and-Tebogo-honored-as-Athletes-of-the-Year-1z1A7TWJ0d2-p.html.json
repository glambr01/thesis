sentence\": \"It's not only me.\", \"from\": 1172, \"to\": 1189, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"All the athletes have been amazing.\\\"\", \"from\": 1190, \"to\": 1226, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"All the athletes\", \"from\": 1190, \"to\": 1206}]}, {\"sentence\": \"Tebogo received his award after becoming the first African to be crowned Olympic champion in the 200m, crossing the line at the Stade de France in 19.46 seconds to edge out a pair of Americans, Kenny Bednarek and favorite Noah Lyles.\", \"from\": 1228, \"to\": 1461, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Tebogo\", \"from\": 1228, \"to\": 1234}, {\"ngram\": \"his award\", \"from\": 1244, \"to\": 1253}, {\"ngram\": \"the first African\", \"from\": 1269, \"to\": 1286}, {\"ngram\": \"Olympic champion\", \"from\": 1301, \"to\": 1317}, {\"ngram\": \"the 200m\", \"from\": 1321, \"to\": 1329}, {\"ngram\": \"the line\", \"from\": 1340, \"to\": 1348}, {\"ngram\": \"the Stade de France\", \"from\": 1352, \"to\": 1371}, {\"ngram\": \"19.46 seconds\", \"from\": 1375, \"to\": 1388}, {\"ngram\": \"a pair\", \"from\": 1401, \"to\": 1407}, {\"ngram\": \"Americans\", \"from\": 1411, \"to\": 1420}]}, {\"sentence\": \"\\\"This means a lot,\\\" said Tebogo, who doubled up with the men's track award.\", \"from\": 1463, \"to\": 1538, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a lot\", \"from\": 1475, \"to\": 1480}, {\"ngram\": \"Tebogo\", \"from\": 1488, \"to\": 1494}, {\"ngram\": \"the men's track award\", \"from\": 1516, \"to\": 1537}]}, {\"sentence\": \"\\\"It's not just about the team that is around you.\", \"from\": 1539, \"to\": 1588, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the team\", \"from\": 1560, \"to\": 1568}]}, {\"sentence\": \"There are a lot of fans out there that really want us to win something great for the continent.\", \"from\": 1589, \"to\": 1684, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a lot\", \"from\": 1599, \"to\": 1604}, {\"ngram\": \"fans\", \"from\": 1608, \"to\": 1612}, {\"ngram\": \"us\", \"from\": 1640, \"to\": 1642}, {\"ngram\": \"something\", \"from\": 1650, \"to\": 1659}, {\"ngram\": \"the continent\", \"from\": 1670, \"to\": 1683}]}, {\"sentence\": \"It was a real surprise to hear my name because I did not expect this.\\\"\", \"from\": 1685, \"to\": 1755, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a real surprise\", \"from\": 1692, \"to\": 1707}, {\"ngram\": \"my name\", \"from\": 1716, \"to\": 1723}]}, {\"sentence\": \"World Athletics, track and field's international governing federation, also honored several other athletes who stood out at the Olympics.\", \"from\": 1757, \"to\": 1894, \"entities\": [{\"begin\": 1757, \"end\": 1772, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 1.0, \"rank\": 4.488393079175843e-15, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}], \"noun_phrases\": [{\"ngram\": \"track\", \"from\": 1774, \"to\": 1779}, {\"ngram\": \"field's international governing federation\", \"from\": 1784, \"to\": 1826}, {\"ngram\": \"several other athletes\", \"from\": 1841, \"to\": 1863}, {\"ngram\": \"the Olympics\", \"from\": 1881, \"to\": 1893}]}, {\"sentence\": \"Swedish pole vaulter Armand Duplantis won the men's field award after an unbeaten 2024, winning Olympic gold and setting a new world record of 6.26 meters.\", \"from\": 1896, \"to\": 2051, \"entities\": [{\"begin\": 1896, \"end\": 1903, \"title\": \"http://dbpedia.org/resource/Sweden\", \"score\": 0.9996869019728548, \"rank\": 0.00016525400190753648, \"text\": \"Swedish\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Sweden\", \"dbpedia\": \"http://dbpedia.org/resource/Sweden\"}, {\"begin\": 1917, \"end\": 1933, \"title\": \"http://dbpedia.org/resource/Armand_Duplantis\", \"score\": 1.0, \"rank\": 0