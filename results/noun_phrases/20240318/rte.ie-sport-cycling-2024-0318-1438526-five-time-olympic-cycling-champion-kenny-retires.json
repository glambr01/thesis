"{\"uid\": \"rte.ie-sport-cycling-2024-0318-1438526-five-time-olympic-cycling-champion-kenny-retires\", \"noun_phrases\": [{\"sentence\": \"Laura Kenny, Britain's most successful female Olympic athlete, has announced her cycling retirement.\", \"from\": 0, \"to\": 100, \"entities\": [{\"begin\": 0, \"end\": 11, \"title\": \"http://dbpedia.org/resource/Laura_Kenny\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Laura Kenny\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Laura_Kenny\", \"dbpedia\": \"http://dbpedia.org/resource/Laura_Kenny\"}, {\"begin\": 13, \"end\": 20, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9955544337051375, \"rank\": 0.004445424934039186, \"text\": \"Britain\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"her cycling retirement\", \"from\": 77, \"to\": 99}]}, {\"sentence\": \"The 31-year-old has won five Olympic gold medals in her decorated career and had been expected to compete at the Paris Games this summer, but she told the BBC it was time to stop.\", \"from\": 102, \"to\": 281, \"entities\": [{\"begin\": 257, \"end\": 260, \"title\": \"http://dbpedia.org/resource/BBC\", \"score\": 0.7084997883802121, \"rank\": 0.41033817736766615, \"text\": \"BBC\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/BBC\", \"dbpedia\": \"http://dbpedia.org/resource/BBC\"}], \"noun_phrases\": [{\"ngram\": \"five Olympic gold medals\", \"from\": 126, \"to\": 150}, {\"ngram\": \"her decorated career\", \"from\": 154, \"to\": 174}, {\"ngram\": \"the Paris Games\", \"from\": 211, \"to\": 226}, {\"ngram\": \"time\", \"from\": 268, \"to\": 272}]}, {\"sentence\": \"Speaking to BBC Breakfast, Kenny said: \\\"I always knew deep down I would know when was the right time.\", \"from\": 283, \"to\": 384, \"entities\": [{\"begin\": 295, \"end\": 308, \"title\": \"http://dbpedia.org/resource/BBC_Breakfast\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"BBC Breakfast\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/BBC_Breakfast\", \"dbpedia\": \"http://dbpedia.org/resource/BBC_Breakfast\"}], \"noun_phrases\": [{\"ngram\": \"Kenny\", \"from\": 310, \"to\": 315}, {\"ngram\": \"the right time\", \"from\": 369, \"to\": 383}]}, {\"sentence\": \"I have had an absolute blast but now is the time for me to hang that bike up.\\\"\", \"from\": 385, \"to\": 463, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an absolute blast\", \"from\": 396, \"to\": 413}, {\"ngram\": \"the time\", \"from\": 425, \"to\": 433}, {\"ngram\": \"that bike\", \"from\": 449, \"to\": 458}]}, {\"sentence\": \"Kenny and her husband, Jason Kenny - Britain's most decorated Olympian - last year welcomed a second son to their family and she said spending time at home was proving more and more alluring to her.\", \"from\": 465, \"to\": 663, \"entities\": [{\"begin\": 488, \"end\": 499, \"title\": \"http://dbpedia.org/resource/Jason_Kenny\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Jason Kenny\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jason_Kenny\", \"dbpedia\": \"http://dbpedia.org/resource/Jason_Kenny\"}, {\"begin\": 502, \"end\": 509, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9955544337051375, \"rank\": 0.004445424934039186, \"text\": \"Britain\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}, {\"begin\": 527, \"end\": 535, \"title\": \"http://dbpedia.org/resource/Olympic_Games\", \"score\": 0.9995784655774462, \"rank\": 0.00042171042645173417, \"text\": \"Olympian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games\"}], 