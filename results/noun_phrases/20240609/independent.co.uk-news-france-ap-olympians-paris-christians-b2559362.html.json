: 1091, \"to\": 1096}, {\"ngram\": \"months\", \"from\": 1142, \"to\": 1148}, {\"ngram\": \"a shared hall\", \"from\": 1159, \"to\": 1172}, {\"ngram\": \"the Olympic village\", \"from\": 1176, \"to\": 1195}]}, {\"sentence\": \"There, they will provide some worship services, prayers and, above all, a non-judgmental listening ear to any athletes or staff in need, regardless of faith.\", \"from\": 1212, \"to\": 1369, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"some worship services\", \"from\": 1237, \"to\": 1258}, {\"ngram\": \"prayers\", \"from\": 1260, \"to\": 1267}, {\"ngram\": \"a non-judgmental listening ear\", \"from\": 1284, \"to\": 1314}, {\"ngram\": \"any athletes\", \"from\": 1318, \"to\": 1330}, {\"ngram\": \"staff\", \"from\": 1334, \"to\": 1339}, {\"ngram\": \"need\", \"from\": 1343, \"to\": 1347}, {\"ngram\": \"faith\", \"from\": 1363, \"to\": 1368}]}, {\"sentence\": \"\\\"We are not there to have them win,\\\" said Anne Schweitzer, who's coordinating about three dozen Protestant chaplains, the second-largest group.\", \"from\": 1371, \"to\": 1514, \"entities\": [{\"begin\": 1418, \"end\": 1428, \"title\": \"http://dbpedia.org/resource/Albert_Schweitzer\", \"score\": 1.0, \"rank\": 1.2999763786313665e-32, \"text\": \"Schweitzer\", \"types\": [\"Q901\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Albert_Schweitzer\", \"dbpedia\": \"http://dbpedia.org/resource/Albert_Schweitzer\"}], \"noun_phrases\": [{\"ngram\": \"about three dozen Protestant chaplains\", \"from\": 1449, \"to\": 1487}, {\"ngram\": \"the second-largest group\", \"from\": 1489, \"to\": 1513}]}, {\"sentence\": \"\\\"My goal is to have a Christian witness there, people who embody the love and care of Jesus, for the athletes who are under so much pressure.\\\"\", \"from\": 1515, \"to\": 1657, \"entities\": [{\"begin\": 1537, \"end\": 1546, \"title\": \"http://dbpedia.org/resource/Christianity\", \"score\": 0.9985935933631785, \"rank\": 0.00140838