, {\"ngram\": \"46 miles\", \"from\": 412, \"to\": 420}, {\"ngram\": \"hour - kitesurfing\", \"from\": 425, \"to\": 443}, {\"ngram\": \"new life\", \"from\": 462, \"to\": 470}, {\"ngram\": \"the Olympic regatta\", \"from\": 476, \"to\": 495}, {\"ngram\": \"its long-awaited Games\", \"from\": 509, \"to\": 531}, {\"ngram\": \"inMarseilleon\", \"from\": 538, \"to\": 551}]}, {\"sentence\": \"Executed at a pace that could leave even sprint cyclists standing, the sport's introduction has split traditionalists and those who believe it can follow the likes of breaking and skateboarding and inspire a new generation to get out on the water.\", \"from\": 562, \"to\": 809, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a pace\", \"from\": 574, \"to\": 580}, {\"ngram\": \"even sprint cyclists\", \"from\": 598, \"to\": 618}, {\"ngram\": \"the sport's introduction\", \"from\": 629, \"to\": 653}, {\"ngram\": \"traditionalists\", \"from\": 664, \"to\": 679}, {\"ngram\": \"the likes\", \"from\": 716, \"to\": 725}, {\"ngram\": \"a new generation\", \"from\": 768, \"to\": 784}, {\"ngram\": \"the water\", \"from\": 799, \"to\": 808}]}, {\"sentence\": \"Britishkitesurfing coach Stevie Morrison, a former Olympian and two-time world champion in Fireball and 49er categories, is firmly in the latter camp and believes its \\\"mind-blowing\\\" spectacle can take the Games - even almost 500 miles from itsParisepicentre - by storm.\", \"from\": 811, \"to\": 1080, \"entities\": [{\"begin\": 836, \"end\": 851, \"title\": \"http://dbpedia.org/resource/Stevie_Morrison\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Stevie Morrison\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Stevie_Morrison\", \"dbpedia\": \"http://dbpedia.org/resource/Stevie_Morrison\"}, {\"begin\": 862, \"end\": 870, \"title\": \"http://dbpedia.org/resource/Olympic_Games\", \"score\": 0.9999991815387769, \"rank\": 8.184590967227736e-07, \"text\": \"Olympian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games\"}, {\"begin\": 902, \"end\": 910, \"title\": \"http://dbpedia.org/resource/Buick_V8_engine\", \"score\": 0.9969741246047955, \"rank\": 0.0030350591060531976, \"text\": \"Fireball\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Buick_V8_engine\", \"dbpedia\": \"http://dbpedia.org/resource/Buick_V8_engine\"}], \"noun_phrases\": [{\"ngram\": \"49er categories\", \"from\": 915, \"to\": 930}, {\"ngram\": \"the latter camp\", \"from\": 945, \"to\": 960}, {\"ngram\": \"its \\\"mind-blowing\\\" spectacle\", \"from\": 974, \"to\": 1002}, {\"ngram\": \"the Games\", \"from\": 1012, \"to\": 1021}, {\"ngram\": \"itsParisepicentre\", \"from\": 1051, \"to\": 1068}, {\"ngram\": \"storm\", \"from\": 1074, \"to\": 1079}]}, {\"sentence\": \"\\\"They are achieving high speeds while they are essentially balanced on a tea tray, connected to a kite that is 15 metres up in the sky,\\\" Morrison told the PA news agency.\", \"from\": 1082, \"to\": 1252, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"high speeds\", \"from\": 1102, \"to\": 1113}, {\"ngram\": \"a tea tray\", \"from\": 1153, \"to\": 1163}, {\"ngram\": \"a kite\", \"from\": 1178, \"to\": 1184}, {\"ngram\": \"the sky\", \"from\": 1209, \"to\": 1216}, {\"ngram\": \"Morrison\", \"from\": 1219, \"to\": 1227}, {\"ngram\": \"the PA news agency\", \"from\": 1233, \"to\": 1251}]}, {\"sentence\": \"\\\"Visually it's stunning.\", \"from\": 1254, \"to\": 1278, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"The three-dimensional aspect is mind-blowing.\", \"from\": 1279, \"to\": 1324, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The three-dimensional aspect\", \"from\": 1279, \"to\": 1307}]}, {\"sentence\": \"I think people are going to be mesmerised a lot by the ballet-type skills the athletes show on the board.\\\"\", \"from\": 1325, \"to\": 1431, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"people\", \"from\": 1333, \"to\": 13