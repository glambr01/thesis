 \"from\": 448, \"to\": 476, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Ten seconds\", \"from\": 448, \"to\": 459}]}, {\"sentence\": \"Then, nearly 30.\", \"from\": 477, \"to\": 493, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"And then, the answer popped up.\", \"from\": 494, \"to\": 525, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the answer\", \"from\": 504, \"to\": 514}]}, {\"sentence\": \"Yes,Lylesis the 100-meter champion at the Paris Olympics.\", \"from\": 527, \"to\": 584, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Yes,Lylesis\", \"from\": 527, \"to\": 538}, {\"ngram\": \"the 100-meter champion\", \"from\": 539, \"to\": 561}, {\"ngram\": \"the Paris Olympics\", \"from\": 565, \"to\": 583}]}, {\"sentence\": \"The World's Fastest Man.\", \"from\": 585, \"to\": 609, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The World's Fastest Man\", \"from\": 585, \"to\": 608}]}, {\"sentence\": \"Just not by very much.\", \"from\": 611, \"to\": 633, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"The American showman edged out Jamaica's Kishane Thompson on Sunday by five-thousandths of a second - that's .005 of one tick of the clock - in a race for the ages.\", \"from\": 635, \"to\": 799, \"entities\": [{\"begin\": 639, \"end\": 647, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999173403520928, \"rank\": 7.833967048648077e-05, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 666, \"end\": 673, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.999999999998181, \"rank\": 2.03191055624782e-12, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}, {\"begin\": 684, \"end\": 692, \"title\": \"http://dbpedia.org/resource/Klay_Thompson\", \"score\": 0.999989592229