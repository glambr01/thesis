 \"wikid\": \"http://dbpedia.org/resource/New_Zealand_national_rugby_league_team\", \"dbpedia\": \"http://dbpedia.org/resource/New_Zealand_national_rugby_league_team\"}], \"noun_phrases\": [{\"ngram\": \"No medals\", \"from\": 2620, \"to\": 2629}, {\"ngram\": \"the athletics\", \"from\": 2649, \"to\": 2662}, {\"ngram\": \"swimming\", \"from\": 2666, \"to\": 2674}, {\"ngram\": \"the plenty\", \"from\": 2680, \"to\": 2690}, {\"ngram\": \"success\", \"from\": 2694, \"to\": 2701}, {\"ngram\": \"other countries\", \"from\": 2706, \"to\": 2721}]}, {\"sentence\": \"for ad-free news and current affairs Olympics 2024 RSS Follow RNZ News\", \"from\": 2724, \"to\": 2796, \"entities\": [{\"begin\": 2776, \"end\": 2779, \"title\": \"http://dbpedia.org/resource/RSS\", \"score\": 0.9930726773383738, \"rank\": 0.0069635526311505325, \"text\": \"RSS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/RSS\", \"dbpedia\": \"http://dbpedia.org/resource/RSS\"}, {\"begin\": 2788, \"end\": 2791, \"title\": \"http://dbpedia.org/resource/Radio_New_Zealand\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"RNZ\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Radio_New_Zealand\", \"dbpedia\": \"http://dbpedia.org/resource/Radio_New_Zealand\"}], \"noun_phrases\": []}]}"