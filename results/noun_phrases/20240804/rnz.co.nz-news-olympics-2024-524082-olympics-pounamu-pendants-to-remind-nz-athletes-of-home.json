"{\"uid\": \"rnz.co.nz-news-olympics-2024-524082-olympics-pounamu-pendants-to-remind-nz-athletes-of-home\", \"noun_phrases\": [{\"sentence\": \"Pouwhiringa for the New Zealand Olympic Committee, Oriini Kaipara at the official p\\u014dwhiri for the equestrian eventing.Photo:photosport No matter where they finish in their Olympic events, the entire New Zealand team will head away from Paris with something precious around their necks - pounamu pendants made by a M\\u0101ori tribe to remind them of home as they competed for medals.\", \"from\": 0, \"to\": 378, \"entities\": [{\"begin\": 20, \"end\": 49, \"title\": \"http://dbpedia.org/resource/New_Zealand_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"New Zealand Olympic Committee\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/New_Zealand_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/New_Zealand_Olympic_Committee\"}, {\"begin\": 51, \"end\": 65, \"title\": \"http://dbpedia.org/resource/Oriini_Kaipara\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Oriini Kaipara\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Oriini_Kaipara\", \"dbpedia\": \"http://dbpedia.org/resource/Oriini_Kaipara\"}, {\"begin\": 98, \"end\": 108, \"title\": \"http://dbpedia.org/resource/Equestrian_at_the_Summer_Olympics\", \"score\": 0.9988267333870349, \"rank\": 0.001156123285734255, \"text\": \"equestrian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Equestrian_at_the_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Equestrian_at_the_Summer_Olympics\"}, {\"begin\": 200, \"end\": 211, \"title\": \"http://dbpedia.org/resource/New_Zealand_national_rugby_league_team\", \"score\": 0.9728383734537482, \"rank\": 0.02425226788541476, \"text\": \"New Zealand\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/New_Zealand_national_rugby_league_team\", \"dbpedia\": \"http://dbpedia.org/resource/New_Zealand_national_rugby_league_team\"}, {\"begin\": 237, \"end\": 242, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999981612291, \"rank\": 1.8387543810555873e-09, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Pouwhiringa\", \"from\": 0, \"to\": 11}, {\"ngram\": \"the official p\\u014dwhiri\", \"from\": 69, \"to\": 89}, {\"ngram\": \"Photo\", \"from\": 118, \"to\": 123}, {\"ngram\": \"photosport\", \"from\": 124, \"to\": 134}, {\"ngram\": \"their Olympic events\", \"from\": 166, \"to\": 186}, {\"ngram\": \"something\", \"from\": 247, \"to\": 256}, {\"ngram\": \"their necks - pounamu pendants\", \"from\": 273, \"to\": 303}, {\"ngram\": \"a M\\u0101ori tribe\", \"from\": 312, \"to\": 325}, {\"ngram\": \"home\", \"from\": 344, \"to\": 348}, {\"ngram\": \"medals\", \"from\": 370, \"to\": 376}]}, {\"sentence\": \"The 550 pendants given to the athletes and their support teams were hand-crafted over the course of a year by the Te Runanga o Ngai Tahu M\\u0101ori tribe and are made from Tahutahi pounamu or snowflake jade, a rare green stone found in New Zealand.\", \"from\": 380, \"to\": 623, \"entities\": [{\"begin\": 497, \"end\": 504, \"title\": \"http://dbpedia.org/resource/Runanga,_New_Zealand\", \"score\": 0.9867389155217591, \"rank\": 0.0, \"text\": \"Runanga\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Runanga,_New_Zealand\", \"dbpedia\": \"http://dbpedia.org/resource/Runanga,_New_Zealand\"}, {\"begin\": 512, \"end\": 516, \"title\": \"http://dbpedia.org/resource/Bionicle\", \"score\": 0.9976014146673023, \"rank\": 0.002404352377100235, \"text\": \"Tahu\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Bionicle\", \"dbpedia\": \"http://dbpedia.org/resource/Bionicle\"}, {\"begin\": 517, \"end\": 522, \"title\": \"http://dbpedia.org/resource/New_Zealand_cuisine\", \"score\": 1.0, \"rank\": 3.1263437553050235e-29, \"text\": \"M\\u0101ori\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/New_Zealand_cuisine\", \"dbpedia\": \"http://dbpedia.org/resource/New_Zealand_cuisine\"}, {\"begin\": 611, \"end\": 622, \"title\": \"http://dbpedia.org/resource/New_Zealand_national_rugby_league_team\", \"score\": 0.9728383734537482, \"rank\": 0.02425226788541476, \"text\": \"New Zealand\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/New_Zealand_national_rugby_league_team\", \"dbpedia\": \"http://dbpedia.org/resource/New_Zealand_national_rugby_league_team\"}], \"noun_phrases\": [{\"ngram\": \"The 550 pendants\", \"from\": 380, \"to\": 396}, {\"ngram\": \"the athletes\", \"from\": 406, \"to\": 418}, {\"ngram\": \"their support teams\", \"from\": 423, \"to\": 442}, {\"ngram\": \"the course\", \"from\": 466, \"to\": 476}, {\"ngram\": \"a year\", \"from\": 480, \"to\": 486}, {\"ngram\": \"Tahutahi pounamu\", \"from\": 547, \"to\": 563}, {\"ngram\": \"snowflake jade\", \"from\": 567, \"to\": 581}, {\"ngram\": \"a rare green stone\", \"from\": 583, \"to\": 601}]}, {\"sentence\": \"\\\"It's a really real privilege to be gifted one, it's sort of a sign of respect, and everyone in the team received these when we arrived here in Paris,\\\" Kiwi rower Phillip Wilson told Reuters at the Vaires-sur-Marne Nautical Stadium.\", \"from\": 625, \"to\": 857, \"entities\": [{\"begin\": 769, \"end\": 774, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999981612291, \"rank\": 1.8387543810555873e-09, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 788, \"end\": 802, \"title\": \"http://dbpedia.org/resource/Phillip_Wilson\", \"score\": 0.9999999873602975, \"rank\": 1.2630645316418908e-08, \"text\": \"Phillip Wilson\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Phillip_Wilson\", \"dbpedia\": \"http://dbpedia.org/resource/Phillip_Wilson\"}, {\"begin\": 808, \"end\": 815, \"title\": \"http://dbpedia.org/resource/Reuters\", \"score\": 0.9999999695610318, \"rank\": 3.042253420936905e-08, \"text\": \"Reuters\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Reuters\", \"dbpedia\": \"http://dbpedia.org/resource/Reuters\"}, {\"begin\": 823, \"end\": 839, \"title\": \"http://dbpedia.org/resource/Vaires-sur-Marne\", \"score\": 0.9999999999868123, \"rank\": 1.3197022485961603e-11, \"text\": \"Vaires-sur-Marne\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Vaires-sur-Marne\", \"dbpedia\": \"http://dbpedia.org/resource/Vaires-sur-Marne\"}], \"noun_phrases\": [{\"ngram\": \"a really real privilege\", \"from\": 631, \"to\": 654}, {\"ngram\": \"one\", \"from\": 668, \"to\": 671}, {\"ngram\": \"sort of a sign\", \"from\": 678, \"to\": 692}, {\"ngram\": \"respect\", \"from\": 696, \"to\": 703}, {\"ngram\": \"everyone\", \"from\": 709, \"to\": 717}, {\"ngram\": \"the team\", \"from\": 721, \"to\": 729}]}, {\"sentence\": \"\\\"It's all part of the culture that the wider New Zealand Olympic team builds to make sure everyone feels special and feels part of what is an amazing team to be part of.\\\"\", \"from\": 859, \"to\": 1029, \"entities\": [{\"begin\": 904, \"end\": 928, \"title\": \"http://dbpedia.org/resource/New_Zealand_at_the_1976_Summer_Olympics\", \"score\": 0.9999405261645632, \"rank\": 5.9477372747952696e-05, \"text\": \"New Zealand Olympic team\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/New_Zealand_at_the_1976_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/New_Zealand_at_the_1976_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"part\", \"from\": 869, \"to\": 873}, {\"ngram\": \"the culture\", \"from\": 877, \"to\": 888}, {\"ngram\": \"everyone\", \"from\": 949, \"to\": 957}, {\"ngram\": \"part\", \"from\": 982, \"to\": 986}, {\"ngram\": \"an amazing team\", \"from\": 998, \"to\": 1013}, {\"ngram\": \"part\", \"from\": 1020, \"to\": 1024}]}, {\"sentence\": \"Tahutahi taonga gifted to New Zealands Olympic and Paralympic athletes.Photo:photosport Racing in the men's pairs in the rowing regatta, both he and his racing partner Dan Williamson wore their pendants around their necks, although Williamson said his was not the one he had been gifted in Paris.\", \"from\": 1031, \"to\": 1328, \"entities\": [{\"begin\": 1200, \"end\": 1214, \"title\": \"http://dbpedia.org/resource/Dan_Williamson\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Dan Williamson\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Dan_Williamson\", \"dbpedia\": \"http://dbpedia.org/resource/Dan_Williamson\"}, {\"begin\": 1264, \"end\": 1274, \"title\": \"http://dbpedia.org/resource/Zion_Williamson\", \"score\": 0.9999999999170086, \"rank\": 8.28981359397067e-11, \"text\": \"Williamson\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Zion_Williamson\", \"dbpedia\": \"http://dbpedia.org/resource/Zion_Williamson\"}, {\"begin\": 1322, \"end\": 1327, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999981612291, \"rank\": 1.8387543810555873e-09, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Tahutahi taonga\", \"from\": 1031, \"to\": 1046}, {\"ngram\": \"New Zealands Olympic and Paralympic athletes\", \"from\": 1057, \"to\": 1101}, {\"ngram\": \"the men's pairs\", \"from\": 1129, \"to\": 1144}, {\"ngram\": \"the rowing regatta\", \"from\": 1148, \"to\": 1166}, {\"ngram\": \"his racing partner\", \"from\": 1180, \"to\": 1198}, {\"ngram\": \"their pendants\", \"from\": 1219, \"to\": 1233}, {\"ngram\": \"their necks\", \"from\": 1241, \"to\": 1252}, {\"ngram\": \"the one\", \"from\": 1291, \"to\": 1298}]}, {\"sentence\": \"\\\"This one's actually a personal one gifted to me by family about six or seven years ago, I have not taken it off since.\", \"from\": 1330, \"to\": 1449, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"This one\", \"from\": 1331, \"to\": 1339}, {\"ngram\": \"a personal one\", \"from\": 1351, \"to\": 1365}, {\"ngram\": \"family\", \"from\": 1382, \"to\": 1388}]}, {\"sentence\": \"It's just a little reminder of home, your piece of home wherever wherever you go around the world,\\\" Williamson said.\", \"from\": 1450, \"to\": 1566, \"entities\": [{\"begin\": 1550, \"end\": 1560, \"title\": \"http://dbpedia.org/resource/Zion_Williamson\", \"score\": 0.9999999999170086, \"rank\": 8.28981359397067e-11, \"text\": \"Williamson\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Zion_Williamson\", \"dbpedia\": \"http://dbpedia.org/resource/Zion_Williamson\"}], \"noun_phrases\": [{\"ngram\": \"just a little reminder\", \"from\": 1455, \"to\": 1477}, {\"ngram\": \"home\", \"from\": 1481, \"to\": 1485}, {\"ngram\": \"home\", \"from\": 1501, \"to\": 1505}, {\"ngram\": \"the world\", \"from\": 1538, \"to\": 1547}]}, {\"sentence\": \"\\\"It's special to line up against the best athletes from all over the world, and to look down and know that you are from where we are from, from little New Zealand.\", \"from\": 1568, \"to\": 1731, \"entities\": [{\"begin\": 1719, \"end\": 1730, \"title\": \"http://dbpedia.org/resource/New_Zealand_national_rugby_league_team\", \"score\": 0.9728383734537482, \"rank\": 0.02425226788541476, \"text\": \"New Zealand\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/New_Zealand_national_rugby_league_team\", \"dbpedia\": \"http://dbpedia.org/resource/New_Zealand_national_rugby_league_team\"}], \"noun_phrases\": [{\"ngram\": \"the best athletes\", \"from\": 1601, \"to\": 1618}, {\"ngram\": \"the world\", \"from\": 1633, \"to\": 1642}]}, {\"sentence\": \"\\\"[There is] a lot of pride to wear the silver fern, to be able to wear pounamu around our neck and represent our country.\\\"\", \"from\": 1733, \"to\": 1855, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a lot\", \"from\": 1745, \"to\": 1750}, {\"ngram\": \"pride\", \"from\": 1754, \"to\": 1759}, {\"ngram\": \"the silver fern\", \"from\": 1768, \"to\": 1783}, {\"ngram\": \"pounamu\", \"from\": 1804, \"to\": 1811}, {\"ngram\": \"our neck\", \"from\": 1819, \"to\": 1827}, {\"ngram\": \"our country\", \"from\": 1842, \"to\": 1853}]}, {\"sentence\": \"One of the traditions associated with pounamu stones is that they should be gifted rather than bought.\", \"from\": 1857, \"to\": 1959, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the traditions\", \"from\": 1864, \"to\": 1878}, {\"ngram\": \"pounamu stones\", \"from\": 1895, \"to\": 1909}]}, {\"sentence\": \"In Paris, the pendants were laid out in groups during a ceremony for athletes to choose from, although the belief in New Zealand is that it is actually the stone that chooses the recipient, and not the other way round.\", \"from\": 1961, \"to\": 2179, \"entities\": [{\"begin\": 1964, \"end\": 1969, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999981612291, \"rank\": 1.8387543810555873e-09, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 2078, \"end\": 2089, \"title\": \"http://dbpedia.org/resource/New_Zealand_national_rugby_league_team\", \"score\": 0.9728383734537482, \"rank\": 0.02425226788541476, \"text\": \"New Zealand\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/New_Zealand_national_rugby_league_team\", \"dbpedia\": \"http://dbpedia.org/resource/New_Zealand_national_rugby_league_team\"}], \"noun_phrases\": [{\"ngram\": \"the pendants\", \"from\": 1971, \"to\": 1983}, {\"ngram\": \"groups\", \"from\": 2001, \"to\": 2007}, {\"ngram\": \"a ceremony\", \"from\": 2015, \"to\": 2025}, {\"ngram\": \"athletes\", \"from\": 2030, \"to\": 2038}, {\"ngram\": \"the belief\", \"from\": 2064, \"to\": 2074}, {\"ngram\": \"the stone\", \"from\": 2113, \"to\": 2122}, {\"ngram\": \"the recipient\", \"from\": 2136, \"to\": 2149}]}, {\"sentence\": \"\\\"Maori culture is something that the New Zealand team really embraces really well, we feel it makes you really feel part of who you are.\", \"from\": 2181, \"to\": 2317, \"entities\": [{\"begin\": 2218, \"end\": 2229, \"title\": \"http://dbpedia.org/resource/New_Zealand_national_rugby_league_team\", \"score\": 0.9728383734537482, \"rank\": 0.02425226788541476, \"text\": \"New Zealand\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/New_Zealand_national_rugby_league_team\", \"dbpedia\": \"http://dbpedia.org/resource/New_Zealand_national_rugby_league_team\"}], \"noun_phrases\": [{\"ngram\": \"Maori culture\", \"from\": 2182, \"to\": 2195}, {\"ngram\": \"something\", \"from\": 2199, \"to\": 2208}, {\"ngram\": \"part\", \"from\": 2297, \"to\": 2301}]}, {\"sentence\": \"And we do - away from home for two and a half months, it just brings you that little sense of home again,\\\" Wilson said.\", \"from\": 2318, \"to\": 2437, \"entities\": [{\"begin\": 2425, \"end\": 2431, \"title\": \"http://dbpedia.org/resource/Woodrow_Wilson\", \"score\": 0.6233635238669674, \"rank\": 0.6039701148465819, \"text\": \"Wilson\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Woodrow_Wilson\", \"dbpedia\": \"http://dbpedia.org/resource/Woodrow_Wilson\"}], \"noun_phrases\": [{\"ngram\": \"home\", \"from\": 2340, \"to\": 2344}, {\"ngram\": \"two and a half months\", \"from\": 2349, \"to\": 2370}, {\"ngram\": \"that little sense\", \"from\": 2391, \"to\": 2408}, {\"ngram\": \"home\", \"from\": 2412, \"to\": 2416}]}, {\"sentenc