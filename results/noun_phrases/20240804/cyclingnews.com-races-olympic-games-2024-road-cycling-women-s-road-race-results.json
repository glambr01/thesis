02}, {\"ngram\": \"the final outcome\", \"from\": 11012, \"to\": 11029}, {\"ngram\": \"almost the last possible moment\", \"from\": 11036, \"to\": 11067}]}, {\"sentence\": \"Results powered byFirstCycling Alasdair Fotheringham has been reporting on cycling since 1991.\", \"from\": 11070, \"to\": 11165, \"entities\": [{\"begin\": 11102, \"end\": 11123, \"title\": \"http://dbpedia.org/resource/Alasdair_Fotheringham\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Alasdair Fotheringham\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q1930187\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Alasdair_Fotheringham\", \"dbpedia\": \"http://dbpedia.org/resource/Alasdair_Fotheringham\"}], \"noun_phrases\": [{\"ngram\": \"Results\", \"from\": 11070, \"to\": 11077}, {\"ngram\": \"cycling\", \"from\": 11145, \"to\": 11152}]}, {\"sentence\": \"He has covered every Tour de France since 1992 bar one, as well as numerous other bike races of all shapes and sizes, ranging from the Olympic Games in 2008 to the now sadly defunct Subida a Urkiola hill climb in Spain.\", \"from\": 11166, \"to\": 11385, \"entities\": [{\"begin\": 11187, \"end\": 11201, \"title\": \"http://dbpedia.org/resource/Tour_de_France\", \"score\": 1.0, \"rank\": 1.5343736232898783e-19, \"text\": \"Tour de France\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tour_de_France\", \"dbpedia\": \"http://dbpedia.org/resource/Tour_de_France\"}, {\"begin\": 11379, \"end\": 11384, \"title\": \"http://dbpedia.org/resource/Spain_national_football_team\", \"score\": 0.9876232812877979, \"rank\": 0.012531688355086484, \"text\": \"Spain\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Spain_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Spain_national_football_team\"}], \"noun_phrases\": [{\"ngram\": \"numerous other bike races\", \"from\": 11233, \"to\": 11258}, {\"ngram\": \"all shapes\", \"from\": 11262, \"to\": 11272}, {\"ngram\": \"sizes\"