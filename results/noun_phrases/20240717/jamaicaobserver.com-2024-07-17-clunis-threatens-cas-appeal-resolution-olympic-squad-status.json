"{\"uid\": \"jamaicaobserver.com-2024-07-17-clunis-threatens-cas-appeal-resolution-olympic-squad-status\", \"noun_phrases\": [{\"sentence\": \"Nayoka Clunis' legal representatives have told the Jamaica Athletics Administrative Association (JAAA) that they intend to file an emergency appeal to the Court of Arbitration for Sport (CAS) on her behalf if an update to her Olympic status is not granted by 5 pm on Wednesday.\", \"from\": 0, \"to\": 277, \"entities\": [{\"begin\": 51, \"end\": 95, \"title\": \"http://dbpedia.org/resource/Jamaica_Athletics_Administrative_Association\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Jamaica Athletics Administrative Association\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Jamaica_Athletics_Administrative_Association\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica_Athletics_Administrative_Association\"}], \"noun_phrases\": [{\"ngram\": \"Nayoka Clunis' legal representatives\", \"from\": 0, \"to\": 36}, {\"ngram\": \"JAAA\", \"from\": 97, \"to\": 101}, {\"ngram\": \"an emergency appeal\", \"from\": 128, \"to\": 147}, {\"ngram\": \"the Court\", \"from\": 151, \"to\": 160}, {\"ngram\": \"Arbitration\", \"from\": 164, \"to\": 175}, {\"ngram\": \"Sport\", \"from\": 180, \"to\": 185}, {\"ngram\": \"CAS\", \"from\": 187, \"to\": 190}, {\"ngram\": \"her behalf\", \"from\": 195, \"to\": 205}, {\"ngram\": \"an update\", \"from\": 209, \"to\": 218}, {\"ngram\": \"her Olympic status\", \"from\": 222, \"to\": 240}, {\"ngram\": \"5 pm\", \"from\": 259, \"to\": 263}, {\"ngram\": \"Wednesday\", \"from\": 267, \"to\": 276}]}, {\"sentence\": \"Clunis was initially named to JAAA's athletics team for the Paris Olympics but then removed after it was found that due to an administrative error, which the JAAA admitted, her name was not submitted to World Athletics, the sport's governing body.\", \"from\": 279, \"to\": 526, \"entities\": [{\"begin\": 309, \"end\": 313, \"title\": \"http://dbpedia.org/resource/Jamaica_Athletics_Administrative_Association\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"JAAA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Jamaica_Athletics_Administrative_Association\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica_Athletics_Administrative_Association\"}, {\"begin\": 437, \"end\": 441, \"title\": \"http://dbpedia.org/resource/Jamaica_Athletics_Administrative_Association\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"JAAA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Jamaica_Athletics_Administrative_Association\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica_Athletics_Administrative_Association\"}, {\"begin\": 482, \"end\": 497, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 0.9999999999994316, \"rank\": 5.783106183665498e-13, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}], \"noun_phrases\": [{\"ngram\": \"Clunis\", \"from\": 279, \"to\": 285}, {\"ngram\": \"the Paris Olympics\", \"from\": 335, \"to\": 353}, {\"ngram\": \"an administrative error\", \"from\": 402, \"to\": 425}, {\"ngram\": \"her name\", \"from\": 452, \"to\": 460}, {\"ngram\": \"the sport's governing body\", \"from\": 499, \"to\": 525}]}, {\"sentence\": \"This was to be her Olympic debut.\", \"from\": 528, \"to\": 561, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her Olympic debut\", \"from\": 543, \"to\": 560}]}, {\"sentence\": \"Sayeed Bernard and Emir Crowne, who are acting in Clunis' interests, notified the JAAA and Jamaica Olympic Association (JOA) by email on Wednesday afternoon saying they have been instructed to file an emergency appeal to the CAS's ad hoc division if they do not receive an update on her situation by 5 pm on Wednesday.\", \"from\": 563, \"to\": 881, \"entities\": [{\"begin\": 582, \"end\": 586, \"title\": \"http://dbpedia.org/resource/Emir\", \"score\": 0.7569339036381777, \