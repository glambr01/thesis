"{\"uid\": \"aljazeera.com-sports-2024-7-17-paris-mayor-takes-pre-olympics-dip-to-prove-seine-clean-ahead-of-2024-games\", \"noun_phrases\": [{\"sentence\": \"Anne Hidalgo is the latest French politician to take the plunge and show River Seine is clean enough for Olympic events.\", \"from\": 0, \"to\": 120, \"entities\": [{\"begin\": 0, \"end\": 12, \"title\": \"http://dbpedia.org/resource/Anne_Hidalgo\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Anne Hidalgo\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Anne_Hidalgo\", \"dbpedia\": \"http://dbpedia.org/resource/Anne_Hidalgo\"}, {\"begin\": 27, \"end\": 33, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9848110623072004, \"rank\": 0.013286300178531036, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 73, \"end\": 84, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"River Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"the plunge\", \"from\": 53, \"to\": 63}, {\"ngram\": \"Olympic events\", \"from\": 105, \"to\": 119}]}, {\"sentence\": \"Save Share The mayor of Paris, Anne Hidalgo, has taken a long-awaited swim in the murky waters of the Seine amid joy and relief that the river is finally clean enough for outdoor Olympic swimming events later this month.\", \"from\": 122, \"to\": 344, \"entities\": [{\"begin\": 148, \"end\": 153, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999993179, \"rank\": 7.848686360298894e-13, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 155, \"end\": 167, \"title\": \"http://dbpedia.org/resource/Anne_Hidalgo\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Anne Hidalgo\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Anne_Hidalgo\", \"dbpedia\": \"http://dbpedia.org/resource/Anne_Hidalgo\"}, {\"begin\": 226, \"end\": 231, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999999629330893, \"rank\": 3.671261451305814e-08, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"Save Share\", \"from\": 122, \"to\": 132}, {\"ngram\": \"The mayor\", \"from\": 133, \"to\": 142}, {\"ngram\": \"a long-awaited swim\", \"from\": 177, \"to\": 196}, {\"ngram\": \"the murky waters\", \"from\": 200, \"to\": 216}, {\"ngram\": \"joy\", \"from\": 235, \"to\": 238}, {\"ngram\": \"relief\", \"from\": 243, \"to\": 249}, {\"ngram\": \"the river\", \"from\": 255, \"to\": 264}, {\"ngram\": \"outdoor Olympic swimming events\", \"from\": 293, \"to\": 324}]}, {\"sentence\": \"Wearing goggles and a wet suit, the 65-year-old city leader swam breaststroke under bright sunshine on Wednesday morning before immersing her face and beginning a front crawl, covering about 100 metres (about 110 yards) downstream.\", \"from\": 346, \"to\": 577, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"goggles\", \"from\": 354, \"to\": 361}, {\"ngram\": \"a wet suit\", \"from\": 366, \"to\": 376}, {\"ngram\": \"bright sunshine\", \"from\": 430, \"to\": 445}, {\"ngram\": \"Wednesday morning\", \"from\": 449, \"to\": 466}, {\"ngram\": \"her face\", \"from\": 484, \"to\": 492}, {\"ngram\": \"a front crawl\", \"from\": 507, \"to\": 520}, {\"ngram\": \"about 100 metres (about 110 yards) downstream\", \"from\": 531, \"to\": 576}]}, {\"sentence\": \"\\\"It's wonderful, very, very pleasant,\\\" Hidalgo told reporters of the greenish water.\", \"from\": 579, \"to\": 663, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Hidalgo\", \"from\": 618, \"to\": 625}, {\"ngram\": \"reporters\", \"from\": 631, \"to\": 640}, {\"ngram\": \"the greenish water\", \"from\": 644, \"to\": 662}]}, {\"sentence\": \"\\\"It's fresh but not cold.\\\"\", \"from\": 664, \"to\": 690, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"She was joined by senior local officials and chief organiser of the Paris Games, Tony Estanguet, a gold medal-winning canoeist who has been sweating on the state of the Seine before the opening of the games next week.\", \"from\": 692, \"to\": 909, \"entities\": [{\"begin\": 773, \"end\": 787, \"title\": \"http://dbpedia.org/resource/Tony_Estanguet\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Tony Estanguet\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Tony_Estanguet\", \"dbpedia\": \"http://dbpedia.org/resource/Tony_Estanguet\"}, {\"begin\": 861, \"end\": 866, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999999629330893, \"rank\": 3.671261451305814e-08, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"senior local officials\", \"from\": 710, \"to\": 732}, {\"ngram\": \"chief organiser\", \"from\": 737, \"to\": 752}, {\"ngram\": \"the Paris Games\", \"from\": 756, \"to\": 771}, {\"ngram\": \"a gold medal-winning canoeist\", \"from\": 789, \"to\": 818}, {\"ngram\": \"the state\", \"from\": 844, \"to\": 853}, {\"ngram\": \"the opening\", \"from\": 874, \"to\": 885}, {\"ngram\": \"the games\", \"from\": 889, \"to\": 898}]}, {\"sentence\": \"\\\"Today is a confirmation that we are exactly where we meant to be,\\\" Estanguet said.\", \"from\": 911, \"to\": 994, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Today\", \"from\": 912, \"to\": 917}, {\"ngram\": \"a confirmation\", \"from\": 921, \"to\": 935}, {\"ngram\": \"Estanguet\", \"from\": 979, \"to\": 988}]}, {\"sentence\": \"\\\"We are now ready to organise the games in the Seine.\\\"\", \"from\": 995, \"to\": 1049, \"entities\": [{\"begin\": 1042, \"end\": 1047, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999999629330893, \"rank\": 3.671261451305814e-08, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"the games\", \"from\": 1025, \"to\": 1034}]}, {\"sentence\": \"The swimming leg of the Olympics triathlon is set to take place in its waters on July 30-31 and August 5, followed by the open-water swimming on August 8-9.\", \"from\": 1051, \"to\": 1207, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The swimming leg\", \"from\": 1051, \"to\": 1067}, {\"ngram\": \"the Olympics triathlon\", \"from\": 1071, \"to\": 1093}, {\"ngram\": \"place\", \"from\": 1109, \"to\": 1114}, {\"ngram\": \"its waters\", \"from\": 1118, \"to\": 1128}, {\"ngram\": \"July\", \"from\": 1132, \"to\": 1136}, {\"ngram\": \"August\", \"from\": 1147, \"to\": 1153}, {\"ngram\": \"the open-water swimming\", \"from\": 1169, \"to\": 1192}, {\"ngram\": \"August\", \"from\": 1196, \"to\": 1202}]}, {\"sentence\": \"Despite an investment of 1.4 billion euros ($1.5bn) to prevent sewage leaks into the waterway, the river had been continually failing water quality tests until the start of this month.\", \"from\": 1209, \"to\": 1393, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an investment\", \"from\": 1217, \"to\": 1230}, {\"ngram\": \"1.4 billion euros\", \"from\": 1234, \"to\": 1251}, {\"ngram\": \"sewage leaks\", \"from\": 1272, \"to\": 1284}, {\"ngram\": \"the waterway\", \"from\": 1290, \"to\": 1302}, {\"ngram\": \"the river\", \"from\": 1304, \"to\": 1313}, {\"ngram\": \"water quality tests\", \"from\": 1343, \"to\": 1362}, {\"ngram\": \"the start\", \"from\": 1369, \"to\": 1378}, {\"ngram\": \"this month\", \"from\": 1382, \"to\": 1392}]}, {\"sentence\": \"Wednesday's dip in front of more than 150 journalists was intended to demonstrate that the river was ready, but also to underline what is meant to be one of the key legacy achievements of Paris 2024.\", \"from\": 1395, \"to\": 1594, \"entities\": [{\"begin\": 1583, \"end\": 1593, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 3.2552742405254985e-21, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"Wednesday's dip\", \"from\": 1395, \"to\": 1410}, {\"ngram\": \"front\", \"from\": 1414, \"to\": 1419}, {\"ngram\": \"more than 150 journalists\", \"from\": 1423, \"to\": 1448}, {\"ngram\": \"the river\", \"from\": 1482, \"to\": 1491}, {\"ngram\": \"the key legacy achievements\", \"from\": 1552, \"to\": 1579}]}, {\"sentence\": \"Hidalgo plans to create three public bathing areas in the Seine for the city's residents next year - a century after swimming was banned - while fish and other organisms are also returning to the waterway in greater numbers.\", \"from\": 1596, \"to\": 1820, \"entities\": [{\"begin\": 1654, \"end\": 1659, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999999629330893, \"rank\": 3.671261451305814e-08, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"Hidalgo\", \"from\": 1596, \"to\": 1603}, {\"ngram\": \"three public bathing areas\", \"from\": 1620, \"to\": 1646}, {\"ngram\": \"the city's residents\", \"from\": 1664, \"to\": 1684}, {\"ngram\": \"swimming\", \"from\": 1713, \"to\": 1721}, {\"ngram\": \"fish\", \"from\": 1741, \"to\": 1745}, {\"ngram\": \"other organisms\", \"from\": 1750, \"to\": 1765}, {\"ngram\": \"the waterway\", \"from\": 1788, \"to\": 1800}, {\"ngram\": \"greater numbers\", \"from\": 1804, \"to\": 1819}]}, {\"sentence\": \"The Seine's flow is currently about 400 cubic metres per second - many times above the usual level for this time of year of 100-150m3/s.\", \"from\": 1822, \"to\": 1958, \"entities\": [{\"begin\": 1826, \"end\": 1831, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999999629330893, \"rank\": 3.671261451305814e-08, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"about 400 cubic metres\", \"from\": 1852, \"to\": 1874}, {\"ngram\": \"second - many times\", \"from\": 1879, \"to\": 1898}, {\"ngram\": \"the usual level\", \"from\": 1905, \"to\": 1920}, {\"ngram\": \"this time\", \"from\": 1925, \"to\": 1934}, {\"ngram\": \"year\", \"from\": 1938, \"to\": 1942}, {\"ngram\": \"100-150m3/s.\", \"from\": 1946, \"to\": 1958}]}, {\"sentence\": \"Hidalgo's swim follows French Sports Minister Amelie Oudea Castera, who took the plunge and swam in the River Seine on July 13.\", \"from\": 1960, \"to\": 2087, \"entities\": [{\"begin\": 1960, \"end\": 1967, \"title\": \"http://dbpedia.org/resource/Miguel_Hidalgo_y_Costilla\", \"score\": 0.9739740466453293, \"rank\": 0.02672140335106014, \"text\": \"Hidalgo\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Miguel_Hidalgo_y_Costilla\", \"dbpedia\": \"http://dbpedia.org/resource/Miguel_Hidalgo_y_Costilla\"}, {\"begin\": 1983, \"end\": 1989, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9848110623072004, \"rank\": 0.013286300178531036, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 2064, \"end\": 2075, \"title\": \"http://