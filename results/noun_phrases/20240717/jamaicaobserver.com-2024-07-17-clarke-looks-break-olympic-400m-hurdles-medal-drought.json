vent.\", \"from\": 3260, \"to\": 3415, \"entities\": [{\"begin\": 3387, \"end\": 3393, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9998213043727121, \"rank\": 0.00017832900847210623, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}, {\"begin\": 3394, \"end\": 3408, \"title\": \"http://dbpedia.org/resource/Diamond_League\", \"score\": 0.9999962473429986, \"rank\": 1.8374352377255155e-06, \"text\": \"Diamond League\", \"types\": [\"Q623109\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Diamond_League\", \"dbpedia\": \"http://dbpedia.org/resource/Diamond_League\"}], \"noun_phrases\": [{\"ngram\": \"Clarke\", \"from\": 3260, \"to\": 3266}, {\"ngram\": \"his seasonal debut\", \"from\": 3288, \"to\": 3306}, {\"ngram\": \"Europe\", \"from\": 3310, \"to\": 3316}, {\"ngram\": \"Saturday\", \"from\": 3320, \"to\": 3328}, {\"ngram\": \"the men's 400m hurdles\", \"from\": 3357, \"to\": 3379}]}, {\"sentence\": \"The men's 400m hurdles competition at the Paris Olympic Games begins on Monday, August 5 at 3:05 am.\", \"from\": 3417, \"to\": 3517, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The men's 400m hurdles competition\", \"from\": 3417, \"to\": 3451}, {\"ngram\": \"the Paris Olympic Games\", \"from\": 3455, \"to\": 3478}, {\"ngram\": \"Monday\", \"from\": 3489, \"to\": 3495}, {\"ngram\": \"August\", \"from\": 3497, \"to\": 3503}, {\"ngram\": \"3:05 am\", \"from\": 3509, \"to\": 3516}]}, {\"sentence\": \"HOUSE RULES\", \"from\": 3523, \"to\": 3534, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"HOUSE RULES\", \"from\": 3523, \"to\": 3534}]}]}"