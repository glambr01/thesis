"{\"uid\": \"rte.ie-news-ireland-2024-0811-1464469-ireland-olympics-senator\", \"noun_phrases\": [{\"sentence\": \"Ireland should start developing a bid to host the 2072 Summer Olympics, according to Fianna F\\u00e1il Senator Malcolm Byrne.\", \"from\": 0, \"to\": 119, \"entities\": [{\"begin\": 0, \"end\": 7, \"title\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"score\": 0.9999876262393617, \"rank\": 1.2316967925228402e-05, \"text\": \"Ireland\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"dbpedia\": \"http://dbpedia.org/resource/Republic_of_Ireland\"}, {\"begin\": 85, \"end\": 96, \"title\": \"http://dbpedia.org/resource/Fianna_F\\u00e1il\", \"score\": 0.9999999994314521, \"rank\": 0.0, \"text\": \"Fianna F\\u00e1il\", \"types\": [\"Q7278\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Fianna_F\\u00e1il\", \"dbpedia\": \"http://dbpedia.org/resource/Fianna_F\\u00e1il\"}, {\"begin\": 105, \"end\": 118, \"title\": \"http://dbpedia.org/resource/Malcolm_Byrne\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Malcolm Byrne\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Malcolm_Byrne\", \"dbpedia\": \"http://dbpedia.org/resource/Malcolm_Byrne\"}], \"noun_phrases\": [{\"ngram\": \"a bid\", \"from\": 32, \"to\": 37}, {\"ngram\": \"the 2072 Summer Olympics\", \"from\": 46, \"to\": 70}]}, {\"sentence\": \"His suggestion comes as Team Ireland broke its medal record in Paris, bringing back seven in total.\", \"from\": 121, \"to\": 220, \"entities\": [{\"begin\": 145, \"end\": 157, \"title\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\", \"score\": 0.9999999979685299, \"rank\": 1.6498416946095457e-09, \"text\": \"Team Ireland\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\"}, {\"begin\": 184, \"end\": 189, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999999500594765, \"rank\": 4.994023265834867e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"His suggestion\", \"from\": 121, \"to\": 135}, {\"ngram\": \"its medal record\", \"from\": 164, \"to\": 180}, {\"ngram\": \"total\", \"from\": 214, \"to\": 219}]}, {\"sentence\": \"Mr Byrne said that such a bid would \\\"almost mark the sesquicentenary of when Ireland began competing in the Olympics as an independent State\\\".\", \"from\": 222, \"to\": 364, \"entities\": [{\"begin\": 225, \"end\": 230, \"title\": \"http://dbpedia.org/resource/David_Byrne\", \"score\": 0.9897996198501275, \"rank\": 0.01030237158354429, \"text\": \"Byrne\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/David_Byrne\", \"dbpedia\": \"http://dbpedia.org/resource/David_Byrne\"}, {\"begin\": 299, \"end\": 306, \"title\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"score\": 0.9999876262393617, \"rank\": 1.2316967925228402e-05, \"text\": \"Ireland\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"dbpedia\": \"http://dbpedia.org/resource/Republic_of_Ireland\"}], \"noun_phrases\": [{\"ngram\": \"such a bid\", \"from\": 241, \"to\": 251}, {\"ngram\": \"the sesquicentenary\", \"from\": 271, \"to\": 290}, {\"ngram\": \"the Olympics\", \"from\": 326, \"to\": 338}, {\"ngram\": \"an independent State\", \"from\": 342, \"to\": 362}]}, {\"sentence\": \"\\\"There will probably be a few eye rolls at this suggestion, but I think we could start to develop a plan so that we have the world class infrastructure to host major international events and there is none bigger than the Olympics,\\\" he said.\", \"from\": 366, \"to\": 606, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a few eye rolls\", \"from\": 390, \"to\": 405},