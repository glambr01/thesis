 1390}]}, {\"sentence\": \"\\\"Me and my dad worked out that by Paris, that's when I'd be old enough to compete.\", \"from\": 1392, \"to\": 1474, \"entities\": [{\"begin\": 1426, \"end\": 1431, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 2.660609773520357e-17, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"my dad\", \"from\": 1400, \"to\": 1406}]}, {\"sentence\": \"That's when I decided.\", \"from\": 1475, \"to\": 1497, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I trained every single second I could.\\\"\", \"from\": 1498, \"to\": 1537, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"every single second\", \"from\": 1508, \"to\": 1527}]}, {\"sentence\": \"He dedicated himself to the sport, and the hard work paid off here on a tense run to the final that displayed his speed and skill in a blur of fast fists and spinning kicks.\", \"from\": 1539, \"to\": 1712, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the sport\", \"from\": 1563, \"to\": 1572}, {\"ngram\": \"the hard work\", \"from\": 1578, \"to\": 1591}, {\"ngram\": \"a tense run\", \"from\": 1609, \"to\": 1620}, {\"ngram\": \"his speed\", \"from\": 1649, \"to\": 1658}, {\"ngram\": \"skill\", \"from\": 1663, \"to\": 1668}, {\"ngram\": \"a blur\", \"from\": 1672, \"to\": 1678}, {\"ngram\": \"fast fists\", \"from\": 1682, \"to\": 1692}, {\"ngram\": \"spinning kicks\", \"from\": 1697, \"to\": 1711}]}, {\"sentence\": \"Cunningham first beat Niger's Abdoul Issoufou in two straight rounds, and then saw off Cuba's Rafael Alba in the deciding round of their quarter-final.\", \"from\": 1714, \"to\": 1865, \"entities\": [{\"begin\": 1714, \"end\": 1724, \"title\": \"http://dbpedia.org/resource/Briggs_Cunningham\", \"score\": 0.9999987852418701, \"rank\": 1.2147590061664464e-06, \"text\": \"Cunningham\", \"types\": [\"Q729\", \"Q5\", \