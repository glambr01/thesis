}, {\"ngram\": \"regulations\", \"from\": 131, \"to\": 142}, {\"ngram\": \"female athletes\", \"from\": 153, \"to\": 168}, {\"ngram\": \"high testosterone\", \"from\": 174, \"to\": 191}, {\"ngram\": \"medication\", \"from\": 200, \"to\": 210}, {\"ngram\": \"a May hearing\", \"from\": 231, \"to\": 244}, {\"ngram\": \"the European Court\", \"from\": 248, \"to\": 266}, {\"ngram\": \"Human Rights\", \"from\": 270, \"to\": 282}, {\"ngram\": \"ECHR\", \"from\": 284, \"to\": 288}]}, {\"sentence\": \"The 33-year-old South African athlete won a long legal battle last July against Switzerland at the ECHR, which ruled she was the victim of discrimination from the Lausanne-based Court of Arbitration for Sport.\", \"from\": 292, \"to\": 501, \"entities\": [{\"begin\": 372, \"end\": 383, \"title\": \"http://dbpedia.org/resource/Switzerland\", \"score\": 0.9988702806937237, \"rank\": 0.0009662885477189271, \"text\": \"Switzerland\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Switzerland\", \"dbpedia\": \"http://dbpedia.org/resource/Switzerland\"}, {\"begin\": 391, \"end\": 395, \"title\": \"http://dbpedia.org/resource/European_Court_of_Human_Rights\", \"score\": 0.9999740069997108, \"rank\": 2.5993675856917086e-05, \"text\": \"ECHR\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/European_Court_of_Human_Rights\", \"dbpedia\": \"http://dbpedia.org/resource/European_Court_of_Human_Rights\"}], \"noun_phrases\": [{\"ngram\": \"The 33-year-old South African athlete\", \"from\": 292, \"to\": 329}, {\"ngram\": \"a long legal battle\", \"from\": 334, \"to\": 353}, {\"ngram\": \"the victim\", \"from\": 417, \"to\": 427}, {\"ngram\": \"discrimination\", \"from\": 431, \"to\": 445}, {\"ngram\": \"the Lausanne-based Court\", \"from\": 451, \"to\": 475}, {\"ngram\": \"Arbitration\", \"from\": 479, \"to\": 490}, {\"ngram\": \"Sport\", \"from\": 495, \"to\": 500}]}, {\"sentence\": \"But Swiss authorities, supported by World Athletics, have taken the matter to the ECHR's Grand Chamber, whose rulings are binding, with hearings slated to start on May 15.\", \"from\": 503, \"to\": 674, \"entities\": [{\"begin\": 507, \"end\": 512, \"title\": \"http://dbpedia.org/resource/Switzerland\", \"score\": 0.931834972574354, \"rank\": 0.0730652973284594, \"text\": \"Swiss\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Switzerland\", \"dbpedia\": \"http://dbpedia.org/resource/Switzerland\"}, {\"begin\": 539, \"end\": 554, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 1.0, \"rank\": 4.6229764975904926e-14, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}, {\"begin\": 585, \"end\": 589, \"title\": \"http://dbpedia.org/resource/European_Court_of_Human_Rights\", \"score\": 0.9999740069997108, \"rank\": 2.5993675856917086e-05, \"text\": \"ECHR\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/European_Court_of_Human_Rights\", \"dbpedia\": \"http://dbpedia.org/resource/European_Court_of_Human_Rights\"}], \"noun_phrases\": [{\"ngram\": \"the matter\", \"from\": 567, \"to\": 577}, {\"ngram\": \"whose rulings\", \"from\": 607, \"to\": 620}, {\"ngram\": \"hearings\", \"from\": 639, \"to\": 647}, {\"ngram\": \"May\", \"from\": 667, \"to\": 670}]}, {\"sentence\": \"\\\"We lack funds.\", \"from\": 676, \"to\": 691, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"funds\", \"from\": 685, \"to\": 690}]}, {\"sentence\": \"We have a lot of experts that come in that we need to pay,\\\" Caster told a press conference in Johannesburg.\", \"from\": 692, \"to\": 799, \"entities\": [{\"begin\": 786, \"end\": 798, \"title\": \"http://dbpedia.org/resource/Johannesburg\", \"score\": 0.9999559999160852, \"rank\": 4.318181881429762e-05, \"text\": \"Johannesburg\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Johannesburg\", \"dbpedia\": \"http://dbpedia.org/resource/Johannesburg\"}], \"noun_phrases\": [{\"ngram\": \"a lot\", \"from\": 700, \"to\": 705}, {\"ngram\": \"experts\", \"from\": 709, \"to\": 716}, {\"ngram\": \"Caster\", \"from\": 752, \"to\": 758}, {\"ngram\": \"a press conference\", \"from\": 764, \"to\": 782}]}, {\"sentence\": \"\\\"Anything that you may contribute, it makes a huge difference.\\\"\", \"from\": 801, \"to\": 864, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a huge difference\", \"from\": 845, \"to\": 862}]}, {\"sentence\": \"Semenya, who is classed as having \\\"differences in sexual development (DSD)\\\" but has always been legally identified as female, has refused to take drugs to reduce her testosterone levels since track and field's governing body World Athletics introduced the original rules in 2018.\", \"from\": 866, \"to\": 1145, \"entities\": [{\"begin\": 936, \"end\": 939, \"title\": \"http://dbpedia.org/resource/Direct_Stream_Digital\", \"score\": 0.9543496806662434, \"rank\": 0.047833954637897996, \"text\": \"DSD\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Direct_Stream_Digital\", \"dbpedia\": \"http://dbpedia.org/resource/Direct_Stream_Digital\"}, {\"begin\": 1091, \"end\": 1106, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 1.0, \"rank\": 4.6229764975904926e-14, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}], \"noun_phrases\": [{\"ngram\": \"Semenya\", \"from\": 866, \"to\": 873}, {\"ngram\": \"differences\", \"from\": 901, \"to\": 912}, {\"ngram\": \"sexual development\", \"from\": 916, \"to\": 934}, {\"ngram\": \"female\", \"from\": 984, \"to\": 990}, {\"ngram\": \"drugs\", \"from\": 1012, \"to\": 1017}, {\"ngram\": \"her testosterone levels\", \"from\": 1028, \"to\": 1051}, {\"ngram\": \"the original rules\", \"from\": 1118, \"to\": 1136}]}, {\"sentence\": \"As a result, the Olympic 800m champion in 2012 and 2016 and world gold medallist in 2009, 2011 and 2017, has been barred from competing at her favoured two-lap distance and was forced to make an unsuccessful move up to 5,000m.\", \"from\": 1147, \"to\": 1373, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a result\", \"from\": 1150, \"to\": 1158}, {\"ngram\": \"world gold medallist\", \"from\": 1207, \"to\": 1227}, {\"ngram\": \"her favoured two-lap distance\", \"from\": 1286, \"to\": 1315}, {\"ngram\": \"an unsuccessful move\", \"from\": 1339, \"to\": 1359}]}, {\"sentence\": \"The ruling by the ECHR last July was largely symbolic as it does not call into question the World Athletics ruling and does not pave the way for Semenya to return to competition without taking the medication.\", \"from\": 1375, \"to\": 1583, \"entities\": [{\"begin\": 1393, \"end\": 1397, \"title\": \"http://dbpedia.org/resource/European_Court_of_Human_Rights\", \"score\": 0.9999740069997108, \"rank\": 2.5993675856917086e-05, \"text\": \"ECHR\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/European_Court_of_Human_Rights\", \"dbpedia\": \"http://dbpedia.org/resource/European_Court_of_Human_Rights\"}, {\"begin\": 1467, \"end\": 1482, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 1.0, \"rank\": 4.6229764975904926e-14, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}], \"noun_phrases\": [{\"ngram\": \"The ruling\", \"from\": 1375, \"to\": 1385}, {\"ngram\": \"question\", \"from\": 1454, \"to\": 1462}, {\"ngram\": \"the way\", \"from\": 1508, \"to\": 1515}, {\"ngram\": \"Semenya\", \"from\": 1520, \"to\": 1527}, {\"ngram\": \"competition\", \"from\": 1541, \"to\": 1552}, {\"ngram\": \"the medication\", \"from\": 1568, \"to\": 1582}]}, {\"sentence\": \"In her book, \\\"The Race To Be Myself\\\", Semenya confesses her career at the top is over.\", \"from\": 1585, \"to\": 1671, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her book\", \"from\": 1588, \"to\": 1596}, {\"ngram\": \"The Race\", \"from\": 1599, \"to\": 1607}, {\"ngram\": \"Semenya\", \"from\": 1623, \"to\": 1630}, {\"ngram\": \"her career\", \"from\": 1641, \"to\": 1651}, {\"ngram\": \"the top\", \"from\": 1655, \"to\": 1662}]}, {\"sentence\": \"\\\"I do not want to talk more about sports as I have accomplished everything I have ever wanted,\\\" Semenya said on Friday.\", \"from\": 1673, \"to\": 1792, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"sports\", \"from\": 1707, \"to\": 1713}, {\"ngram\": \"everything\", \"from\": 1737, \"to\": 1747}, {\"ngram\": \"Semenya\", \"from\": 1769, \"to\": 1776}, {\"ngram\": \"Friday\", \"from\": 1785, \"to\": 1791}]}, {\"sentence\": \"She said she was now focused on being an advocate for young athletes facing similar challenges.\", \"from\": 1794, \"to\": 1889, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an advocate\", \"from\": 1832, \"to\": 1843}, {\"ngram\": \"young athletes\", \"from\": 1848, \"to\": 1862}, {\"ngram\": \"similar challenges\", \"from\": 1870, \"to\": 1888}]}, {\"sentence\": \"\\\"We all know what this case is all about, it is about the differences in women's body.\", \"from\": 1891, \"to\": 1977, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this case\", \"from\": 1909, \"to\": 1918}, {\"ngram\": \"the differences\", \"from\": 1945, \"to\": 1960}, {\"ngram\": \"women's body\", \"from\": 1964, \"to\": 1976}]}, {\"sentence\": \"And the main goal is to make sure that we protect\\u2026 these young kids so they can be able to compete.\\\"\", \"from\": 1978, \"to\": 2078, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the main goal\", \"from\": 1982, \"to\": 1995}]}, {\"sentence\": \"Semenya's lawyers, who work pro-bono, said that for the upcoming ECHR's Grand Chamber part of their client's decade-long legal battle, costs are expected to reach about $180,000.\", \"from\": 2080, \"to\": 2258, \"entities\": [{\"begin\": 2145, \"end\": 2149, \"title\": \"http://dbpedia.org/resource/European_Court_of_Human_Rights\", \"score\": 0.9999740069997108, \"rank\": 2.5993675856917086e-05, \"text\": \"ECHR\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/European_Court_of_Human_Rights\", \"dbpedia\": \"http://dbpedia.org/resource/European_Court_of_Human_Rights\"}], \"noun_phrases\": [{\"ngram\": \"Semenya's lawyers\", \"from\": 2080, \"to\": 2097}, {\"ngram\": \"their client's decade-long legal battle\", \"from\": 2174, \"to\": 2213}, {\"ngram\": \"costs\", \"from\": 2215, \"to\": 2220}]}, {\"sentence\": \"World Athletics introduced the DSD regulations to create a level playing field in women's events.\", \"from\": 2260, \"to\": 2357, \"entities\": [{\"begin\": 2260, \"end\": 2275, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 1.0, \"rank\": 4.6229764975904926e-14, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}, {\"begin\": 2291, \"end\": 2294, \"title\": \"http://dbpedia.org/resource/Direct_Stream_Digital\", \"score\": 0.9543496806662434, \"rank\": 0.047833954637897996, \"text\": \"DSD\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Direct_Stream_Digital\", \"dbpedia\": \"http://dbpedia.org/resource/Direct_Stream_Digital\"}], \"noun_phrases\": [{\"ngram\": \"a level playing field\", \"from\": 2317, \"to\": 2338}, {\"ngram\": \"women's events\", \"from\": 2342, \"to\": 2356}]}, {\"sentence\": \"Semenya failed to reach the 5,000m final at the 2022 world championships in Eugene.\", \"from\": 2359, \"to\": 2442, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Semenya\", \"from\": 2359, \"to\": 2366}, {\"ngram\": \"the 5,000m\", \"from\": 2383, \"to\": 2393}, {\"ngram\": \"the 2022 world championships\", \"from\": 2403, \"to\": 2431}, {\"