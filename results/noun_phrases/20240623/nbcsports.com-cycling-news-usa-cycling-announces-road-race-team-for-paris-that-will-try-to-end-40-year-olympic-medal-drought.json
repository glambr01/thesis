 1150}, {\"ngram\": \"all the people\", \"from\": 1171, \"to\": 1185}, {\"ngram\": \"the way\", \"from\": 1212, \"to\": 1219}]}, {\"sentence\": \"I do not think it will fully sink in until I am there.\\\"\", \"from\": 1221, \"to\": 1276, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Chloe Dygert and Taylor Knibb already had secured the two women's spots on the team.\", \"from\": 1278, \"to\": 1362, \"entities\": [{\"begin\": 1278, \"end\": 1290, \"title\": \"http://dbpedia.org/resource/Chlo\\u00e9_Dygert\", \"score\": 0.9999999166202577, \"rank\": 0.0, \"text\": \"Chloe Dygert\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Chlo\\u00e9_Dygert\", \"dbpedia\": \"http://dbpedia.org/resource/Chlo\\u00e9_Dygert\"}, {\"begin\": 1295, \"end\": 1307, \"title\": \"http://dbpedia.org/resource/Taylor_Knibb\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Taylor Knibb\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Taylor_Knibb\", \"dbpedia\": \"http://dbpedia.org/resource/Taylor_Knibb\"}], \"noun_phrases\": [{\"ngram\": \"the two women's spots\", \"from\": 1328, \"to\": 1349}, {\"ngram\": \"the team\", \"from\": 1353, \"to\": 1361}]}, {\"sentence\": \"Dygert won the time trial world title to earn an automatic nomination, while Knibb was a surprising winner of the U.S. time trial championship to earn her spot.\", \"from\": 1363, \"to\": 1523, \"entities\": [{\"begin\": 1440, \"end\": 1445, \"title\": \"http://dbpedia.org/resource/Taylor_Knibb\", \"score\": 0.999999999906322, \"rank\": 9.345170290149899e-11, \"text\": \"Knibb\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Taylor_Knibb\", \"dbpedia\": \"http://dbpedia.org/resource/Taylor_Knibb\"}], \"noun_phrases\": [{\"ngram\": \"Dygert\", \"from\": 1363, \"to\": 1369}, {\"ngram\": \"the time\", \"from\": 1374, \"to\": 1382}, {\"ngram\": \"trial world title\", \"fro