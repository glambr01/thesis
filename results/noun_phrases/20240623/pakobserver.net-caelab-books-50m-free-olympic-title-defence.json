"{\"uid\": \"pakobserver.net-caelab-books-50m-free-olympic-title-defence\", \"noun_phrases\": [{\"sentence\": \"Caeleb Dressel shook off his doubts and booked a chance to defend his 50m freestyle Olympic title in Paris with a victory on Friday at the US Olympic swimming trials.\", \"from\": 0, \"to\": 168, \"entities\": [{\"begin\": 2, \"end\": 16, \"title\": \"http://dbpedia.org/resource/Caeleb_Dressel\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Caeleb Dressel\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Caeleb_Dressel\", \"dbpedia\": \"http://dbpedia.org/resource/Caeleb_Dressel\"}, {\"begin\": 103, \"end\": 108, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999952601684, \"rank\": 4.739927654827072e-09, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 141, \"end\": 167, \"title\": \"http://dbpedia.org/resource/2020_United_States_Olympic_trials_(swimming)\", \"score\": 0.5975359342915416, \"rank\": 0.6735395189003551, \"text\": \"US Olympic swimming trials\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/2020_United_States_Olympic_trials_(swimming)\", \"dbpedia\": \"http://dbpedia.org/resource/2020_United_States_Olympic_trials_(swimming)\"}], \"noun_phrases\": [{\"ngram\": \"his doubts\", \"from\": 25, \"to\": 35}, {\"ngram\": \"a chance\", \"from\": 47, \"to\": 55}, {\"ngram\": \"his 50m freestyle Olympic title\", \"from\": 66, \"to\": 97}, {\"ngram\": \"a victory\", \"from\": 112, \"to\": 121}, {\"ngram\": \"Friday\", \"from\": 125, \"to\": 131}]}, {\"sentence\": \"Dressel, whose five gold medals at the Tokyo Olympics in 2021 included the 50m and 100m free and 100m fly, booked his first individual swim in Paris after missing out with a third-place finish in the 100m free.\", \"from\": 170, \"to\": 380, \"entities\": [{\"begin\": 313, \"end\": 318, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999952601684, \"rank\": 4.739927654827072e-09, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Dressel\", \"from\": 170, \"to\": 177}, {\"ngram\": \"whose five gold medals\", \"from\": 179, \"to\": 201}, {\"ngram\": \"the Tokyo Olympics\", \"from\": 205, \"to\": 223}, {\"ngram\": \"his first individual swim\", \"from\": 284, \"to\": 309}, {\"ngram\": \"a third-place finish\", \"from\": 342, \"to\": 362}, {\"ngram\": \"the 100m\", \"from\": 366, \"to\": 374}]}, {\"sentence\": \"The victory capped a long, often rocky road back to the top for the seven-time Olympic gold medallist, who stepped away from the sport abruptly in 2022.\", \"from\": 382, \"to\": 534, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The victory\", \"from\": 382, \"to\": 393}, {\"ngram\": \"a long, often rocky road\", \"from\": 401, \"to\": 425}, {\"ngram\": \"the top\", \"from\": 434, \"to\": 441}, {\"ngram\": \"the seven-time Olympic gold medallist\", \"from\": 446, \"to\": 483}, {\"ngram\": \"the sport\", \"from\": 507, \"to\": 516}]}, {\"sentence\": \"Dressel looked in vintage form at Lucas Oil Stadium, home of the NFL's Indianapolis Colts, exploding off the blocks to win the 50 free in 21.41sec.\", \"from\": 535, \"to\": 682, \"entities\": [{\"begin\": 600, \"end\": 603, \"title\": \"http://dbpedia.org/resource/National_Football_League\", \"score\": 0.8828655484396805, \"rank\": 0.13105976474899378, \"text\": \"NFL\", \"types\": [\"Q623109\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/National_Football_League\", \"dbpedia\": \"http://dbpedia.org/resource/National_Football_League\"}, {\"begin\": 606, \"end\": 624, \"title\": \"http://dbpedia.org/resource/Indianapolis_Colts\", \"score\": 0.9996003376005942, \"rank\": 0.0002924605928066586, \"text\": \"Indianapolis Colts\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/Indianapolis_Colts\", \"dbpedia\": \"http://dbpedia.org/resource/Indianapolis_Colts\"}], \"noun_phrases\": [{\"ngram\": \"Dressel\", \"from\": 535, \"to\": 542}, {\"ngram\": \"vintage form\", \"from\": 553, \"to\": 565}, {\"ngram\": \"Lucas Oil Stadium\", \"from\": 569, \"to\": 586}, {\"ngram\": \"home\", \"from\": 588, \"to\": 592}, {\"ngram\": \"the blocks\", \"from\": 640, \"to\": 650}, {\"ngram\": \"21.41sec\", \"from\": 673, \"to\": 681}]}, {\"sentence\": \"The time makes him the fourth-fastest in the world this year, a list led by Australian Cameron McEvoy.\", \"from\": 684, \"to\": 786, \"entities\": [{\"begin\": 760, \"end\": 770, \"title\": \"http://dbpedia.org/resource/Australians\", \"score\": 0.5987998097740536, \"rank\": 0.6674318208343982, \"text\": \"Australian\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Australians\", \"dbpedia\": \"http://dbpedia.org/resource/Australians\"}, {\"begin\": 771, \"end\": 785, \"title\": \"http://dbpedia.org/resource/Cameron_McEvoy\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Cameron McEvoy\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Cameron_McEvoy\", \"dbpedia\": \"http://dbpedia.org/resource/Cameron_McEvoy\"}], \"noun_phrases\": [{\"ngram\": \"The time\", \"from\": 684, \"to\": 692}, {\"ngram\": \"the world\", \"from\": 725, \"to\": 734}, {\"ngram\": \"a list\", \"from\": 746, \"to\": 752}]}, {\"sentence\": \"\\\"I knew it was one of my toughest nights,\\\" said Dressel, who would return to top the times in the 100m butterfly semi-finals in 50.79sec.\", \"from\": 788, \"to\": 925, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my toughest nights\", \"from\": 810, \"to\": 828}, {\"ngram\": \"Dressel\", \"from\": 836, \"to\": 843}, {\"ngram\": \"top\", \"from\": 865, \"to\": 868}, {\"ngram\": \"the 100m\", \"from\": 882, 