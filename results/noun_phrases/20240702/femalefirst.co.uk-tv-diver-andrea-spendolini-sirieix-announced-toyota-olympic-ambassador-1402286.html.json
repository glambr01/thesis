"{\"uid\": \"femalefirst.co.uk-tv-diver-andrea-spendolini-sirieix-announced-toyota-olympic-ambassador-1402286.html\", \"noun_phrases\": [{\"sentence\": \"2 July 2024 Toyotaannounces top British diver Andrea Spendolini-Sirieix as an Olympic ambassador.\", \"from\": 0, \"to\": 100, \"entities\": [{\"begin\": 35, \"end\": 42, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9636437443429576, \"rank\": 0.03596211839183914, \"text\": \"British\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}, {\"begin\": 49, \"end\": 74, \"title\": \"http://dbpedia.org/resource/Andrea_Spendolini-Sirieix\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Andrea Spendolini-Sirieix\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Andrea_Spendolini-Sirieix\", \"dbpedia\": \"http://dbpedia.org/resource/Andrea_Spendolini-Sirieix\"}], \"noun_phrases\": [{\"ngram\": \"an Olympic ambassador\", \"from\": 75, \"to\": 96}]}, {\"sentence\": \"She joins a number of athletes partnering with the company in the run up to the Paris 2024 Olympic and Paralympic Games, who embody Toyota's 'Start Your Impossible' message - that you can overcome challenges and achieve your goals.\", \"from\": 102, \"to\": 333, \"entities\": [{\"begin\": 182, \"end\": 192, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 4.3016219845415514e-15, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"a number\", \"from\": 112, \"to\": 120}, {\"ngram\": \"athletes\", \"from\": 124, \"to\": 132}, {\"ngram\": \"the company\", \"from\": 149, \"to\": 160}, {\"ngram\": \"the run\", \"from\": 164, \"to\": 171}, {\"ngram\": \"Your Impossible' message\", \"from\": 250, \"to\": 274}, {\"ngram\": \"challenges\", \"from\": 299, \"to\": 309}, {\"ngram\": \"your goals\", \"from\": 322, \"to\": 332}]}, {\"sentence\": \"Diver Andrea Spendolini-Sirieix The announcement coincides with the release of the third episode ofThe Journeydocuseries, produced with Team GB, which features Spendolini-Sirieix talking about the mental challenges she has overcome to reach top level competition, and her dreams of achieving Olympic success.\", \"from\": 335, \"to\": 646, \"entities\": [{\"begin\": 341, \"end\": 366, \"title\": \"http://dbpedia.org/resource/Andrea_Spendolini-Sirieix\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Andrea Spendolini-Sirieix\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Andrea_Spendolini-Sirieix\", \"dbpedia\": \"http://dbpedia.org/resource/Andrea_Spendolini-Sirieix\"}, {\"begin\": 474, \"end\": 481, \"title\": \"http://dbpedia.org/resource/Team_GB\", \"score\": 0.9999997271202491, \"rank\": 2.468954695001301e-07, \"text\": \"Team GB\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Team_GB\", \"dbpedia\": \"http://dbpedia.org/resource/Team_GB\"}], \"noun_phrases\": [{\"ngram\": \"The announcement\", \"from\": 367, \"to\": 383}, {\"ngram\": \"the release\", \"from\": 399, \"to\": 410}, {\"ngram\": \"the third episode ofThe Journeydocuseries\", \"from\": 414, \"to\": 455}, {\"ngram\": \"Spendolini-Sirieix\", \"from\": 495, \"to\": 513}, {\"ngram\": \"the mental challenges\", \"from\": 528, \"to\": 549}, {\"ngram\": \"top level competition\", \"from\": 576, \"to\": 597}, {\"ngram\": \"her dreams\", \"from\": 603, \"to\": 613}, {\"ngram\": \"Olympic success\", \"from\": 627, \"to\": 642}]}, {\"sentence\": \"Aged 19, Spendolini-Sirieix has been diving for 11 years and is already a world-class competitor.\", \"from\": 650, \"to\": 747, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Spendolini-Sirieix\", \"from\": 659, \"to\": 677}, {\"ngram\": \"11 years\", \"from\": 698, \"to\": 706}, {\"ngram\": \"a world-class competitor\", \"from\": 722, \"to\": 746}]}, {\"sentence\": \"She burst onto the scene as a 13-year-old, making her international debut, and just two years later won her first solo gold at the 2020 FINA Diving Grand Prix.\", \"from\": 748, \"to\": 907, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the scene\", \"from\": 763, \"to\": 772}, {\"ngram\": \"her international debut\", \"from\": 798, \"to\": 821}, {\"ngram\": \"her first solo gold\", \"from\": 852, \"to\": 871}, {\"ngram\": \"the 2020 FINA Diving Grand Prix\", \"from\": 875, \"to\": 906}]}, {\"sentence\": \"She has amassed over 20 senior national and international medals, including two golds at the most recent Commonwealth Games in Birmingham and two golds at the European Games in Rome.\", \"from\": 908, \"to\": 1090, \"entities\": [{\"begin\": 1013, \"end\": 1031, \"title\": \"http://dbpedia.org/resource/Commonwealth_Games\", \"score\": 0.9979895836965409, \"rank\": 0.0013992982463664956, \"text\": \"Commonwealth Games\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Commonwealth_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Commonwealth_Games\"}, {\"begin\": 1035, \"end\": 1045, \"title\": \"http://dbpedia.org/resource/Birmingham\", \"score\": 0.9850601661319074, \"rank\": 0.015166138302589654, \"text\": \"Birmingham\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Birmingham\", \"dbpedia\": \"http://dbpedia.org/resource/Birmingham\"}, {\"begin\": 1085, \"end\": 1089, \"title\": \"http://dbpedia.org/resource/Rome\", \"score\": 0.9962868155132945, \"rank\": 0.0035045382639010197, \"text\": \"Rome\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Rome\", \"dbpedia\": \"http://dbpedia.org/resource/Rome\"}], \"noun_phrases\": [{\"ngram\": \"over 20 senior national and international medals\", \"from\": 924, \"to\": 972}, {\"ngram\": \"two golds\", \"from\": 984, \"to\": 993}, {\"ngram\": \"two golds\", \"from\": 1050, \"to\": 1059}, {\"ngram\": \"the European Games\", \"from\": 1063, \"to\": 1081}]}, {\"sentence\": \"This tally has helped her become Britain's most successful female diver of all time.\", \"from\": 1091, \"to\": 1175, \"entities\": [{\"begin\": 1124, \"end\": 1131, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.99540278874105, \"rank\": 0.004616732063403861, \"text\": \"Britain\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"This tally\", \"from\": 1091, \"to\": 1101}, {\"ngram\": \"all time\", \"from\": 1166, \"to\": 1174}]}, {\"sentence\": \"InThe Journey, Spendolini-Sirieix reveals how diving has moulded her personal development: \\\"I have gone through a lot with my diving and it's shaped who I am, not just as a diver, but as an athlete.\", \"from\": 1179, \"to\": 1377, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"InThe Journey\", \"from\": 1179, \"to\": 1192}, {\"ngram\": \"Spendolini-Sirieix\", \"from\": 1194, \"to\": 1212}, {\"ngram\": \"diving\", \"from\": 1225, \"to\": 1231}, {\"ngram\": \"her personal development\", \"from\": 1244, \"to\": 1268}, {\"ngram\": \"a lot\", \"from\": 1291, \"to\": 1296}, {\"ngram\": \"my diving\", \"from\": 1302, \"to\": 1311}, {\"ngram\": \"a diver\", \"from\": 1350, \"to\": 1357}, {\"ngram\": \"an athlete\", \"from\": 1366, \"to\": 1376}]}, {\"sentence\": \"And the drive, focus and determination that I have in training, I brought into school.\\\"\", \"from\": 1378, \"to\": 1465, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the drive\", \"from\": 1382, \"to\": 1391}, {\"ngram\": \"focus\", \"from\": 1393, \"to\": 1398}, {\"ngram\": \"determination\", \"from\": 1403, \"to\": 1416}, {\"ngram\": \"training\", \"from\": 1432, \"to\": 1440}, {\"ngram\": \"school\", \"from\": 1457, \"to\": 1463}]}, {\"sentence\": \"Spendolini-Sirieix describes how it felt when she started on the senior dive circuit at just 13 years old: \\\"I was a little scrawny kid, no meat on me, and I was throwing myself off 10 metres like the adults.\", \"from\": 1469, \"to\": 1676, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Spendolini-Sirieix\", \"from\": 1469, \"to\": 1487}, {\"ngram\": \"the senior dive circuit\", \"from\": 1530, \"to\": 1553}, {\"ngram\": \"a little scrawny kid\", \"from\": 1583, \"to\": 1603}, {\"ngram\": \"no meat\", \"from\": 1605, \"to\": 1612}, {\"ngram\": \"the adults\", \"from\": 1665, \"to\": 1675}]}, {\"sentence\": \"Nothing is expected of you when you are the underdog, it was like a superpower.\\\"\", \"from\": 1678, \"to\": 1758, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Nothing\", \"from\": 1678, \"to\": 1685}, {\"ngram\": \"the underdog\", \"from\": 1718, \"to\": 1730}, {\"ngram\": \"a superpower\", \"from\": 1744, \"to\": 1756}]}, {\"sentence\": \"Later in the film she talks about the stress she experienced after a disappointing result from a competition in Budapest when she was 13 and going through adolescence, which made her question whether she wanted to continue diving: \\\"I was having panic attacks at school and at training.\", \"from\": 1760, \"to\": 2045, \"entities\": [{\"begin\": 1872, \"end\": 1880, \"title\": \"http://dbpedia.org/resource/Budapest\", \"score\": 0.9999998251780806, \"rank\": 1.7482150317695376e-07, \"text\": \"Budapest\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Budapest\", \"dbpedia\": \"http://dbpedia.org/resource/Budapest\"}], \"noun_phrases\": [{\"ngram\": \"the film\", \"from\": 1769, \"to\": 1777}, {\"ngram\": \"the stress\", \"from\": 1794, \"to\": 1804}, {\"ngram\": \"a disappointing result\", \"from\": 1827, \"to\": 1849}, {\"ngram\": \"a competition\", \"from\": 1855, \"to\": 1868}, {\"ngram\": \"adolescence\", \"from\": 1915, \"to\": 1926}, {\"ngram\": \"her question\", \"from\": 1939, \"to\": 1951}, {\"ngram\": \"diving\", \"from\": 1983, \"to\": 1989}, {\"ngram\": \"panic attacks\", \"from\": 2005, \"to\": 2018}, {\"ngram\": \"school\", \"from\": 2022, \"to\": 2028}, {\"ngram\": \"training\", \"from\": 2036, \"to\": 2044}]}, {\"sentence\": \"That period was incredibly difficult - I just did not perform.\", \"from\": 2047, \"to\": 2109, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"That period\", \"from\": 2047, \"to\": 2058}]}, {\"sentence\": \"As much as it was painful, it was also the best kick in the butt I could have asked for.\", \"from\": 2110, \"to\": 2198, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the best kick\", \"from\": 2149, \"to\": 2162}, {\"ngram\": \"the butt\", \"from\": 2166, \"to\": 2174}]}, {\"sentence\": \"Sometimes you learn the most when you are at rock bottom.\\\"\", \"from\": 2200, \"to\": 2258, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"rock bottom\", \"from\": 2245, \"to\": 2256}]}, {\"sentence\": \"Spendolini-Sirieix's mother Alex also features in the film.\", \"from\": 2260, \"to\": 2319, \"entities\": [{\"begin\": 2288, \"end\": 2292, \"title\": \"http://dbpedia.org/resource/Alex_Rousseau\", \"score\": 0.9999863625846447, \"rank\": 6.858305225133834e-06, \"text\": \"Alex\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Alex_Rousseau\", \"dbpedia\": \"http://dbpedia.org/resource/Alex_Rousseau\"}], \"noun_phrases\": [{\"ngram\": \"Spendolini-Sirieix's mother\", \"from\": 2260, \"to\": 2287}, {\"ngram\": \"the film\", \"from\": 2310, \"to\": 2318}]}, {\"sentence\": \"The strength and importance of her support are clear when Andrea speaks with emotion about her mum being her superhero: \\\"Having that strong person behind you who will not let you give up, as much at the time that I really did not like it, it's something that I value so much.\", \"from\": 2320, \"to\": 2595, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The strength\", \"from\": 2320, \"to\": 2332}, {\"ngram\": \"importance\", \"from\": 2337, \"to\": 2347}, {\"ngram\": \"her support\", \"from\": 2351, \"to\": 2362}, {\"ngram\": \"Andrea\", \"from\": 2378, \"to\": 2384}, {\"ngram\": \"emotion\", \"from\": 2397, \"to\": 2404}, {\"ngram\": \"her mum\", \"from\": 2411, \"to\": 2418}, {\"ngram\": \"her superhero\", \"from\": 2425, \"to\": 2438}, {\"ngram\": \"that strong person\", \"from\": 2448, \"to\": 2466}, {\"ngram\": \"the time\", \"from\": 2519, \"to\": 2527}, {\"ngram\": \"something\", \"from\": 2564, \"to\": 2573}]}, {\"sentence\": \"My mum means everything to me; it's that kind of relationship that I will never take for granted - she's taught me how to be a strong woman.\", \"from\": 2596, \"to\": 2736, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My mum\", \"from\": 2596, \"to\": 2602}, {\"ngram\": \"everything\", \"from\": 2609, \"to\": 2619}, {\"ngram\": \"that kind\", \"from\": 2632, \"to\": 2641}, {\"ngram\": \"relationship\", \"from\": 2645, \"to\": 2657}, {\"ngram\": \"a strong woman\", \"from\": 2721, \"to\": 2735}]}, {\"sentence\": \"Episode three ofThe Journeyis live on Team GB's YouTube channel and can be viewed here: The four-part docuseriesThe Journey,createdbyTeam GB and Toyota, brings fans inside the lives of four athletes as they prepare for the Paris 2024 Olympic Games.\", \"from\": 2740, \"to\": 2989, \"entities\": [{\"begin\": 2778, \"end\": 2785, \"title\": \"http://dbpedia.org/resource/Team_GB\", \"score\": 0.9999997271202491, \"rank\": 2.468954695001301e-07, \"text\": \"Team GB\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Team_GB\", \"dbpedia\": \"http://dbpedia.org/resource/Team_GB\"}, {\"begin\": 2857, \"end\": 2864, \"title\": \"http://dbpedia.org/resource/Dodge_Journey\", \"score\": 0.9999999999995453, \"rank\": 3.742722203546558e-13, \"text\": \"Journey\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Dodge_Journey\", \"dbpedia\": \"http://dbpedia.org/resource/Dodge_Journey\"}, {\"begin\": 2879, \"end\": 2881, \"title\": \"h