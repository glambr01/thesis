"{\"uid\": \"devdiscourse.com-article-science-environment-2848573-olympics-french-foie-gras-back-on-menus-after-bird-flu-spares-ducks\", \"noun_phrases\": [{\"sentence\": \"A jump in foie gras output this winter as France was virtually spared from bird flu that had ravaged flocks in previous years will allow chefs to have enough of the delicacy when visitors rush to Paris for the Olympics, producers said on Monday.\", \"from\": 0, \"to\": 245, \"entities\": [{\"begin\": 42, \"end\": 48, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9995791538427937, \"rank\": 0.0003726119010529496, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 196, \"end\": 201, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999733715871, \"rank\": 2.662845696222095e-08, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"A jump\", \"from\": 0, \"to\": 6}, {\"ngram\": \"bird flu\", \"from\": 75, \"to\": 83}, {\"ngram\": \"flocks\", \"from\": 101, \"to\": 107}, {\"ngram\": \"previous years\", \"from\": 111, \"to\": 125}, {\"ngram\": \"chefs\", \"from\": 137, \"to\": 142}, {\"ngram\": \"the delicacy\", \"from\": 161, \"to\": 173}, {\"ngram\": \"visitors\", \"from\": 179, \"to\": 187}, {\"ngram\": \"the Olympics\", \"from\": 206, \"to\": 218}, {\"ngram\": \"producers\", \"from\": 220, \"to\": 229}, {\"ngram\": \"Monday\", \"from\": 238, \"to\": 244}]}, {\"sentence\": \"France has been among the countries worst affected by an unprecedented global spread of highly pathogenic avian influenza, commonly called bird flu, that has disrupted supply of poultry meat and eggs and sent prices rocketing in many parts of the globe in the past years.\", \"from\": 246, \"to\": 517, \"entities\": [{\"begin\": 246, \"end\": 252, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9995791538427937, \"rank\": 0.0003726119010529496, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"the countries\", \"from\": 268, \"to\": 281}, {\"ngram\": \"an unprecedented global spread\", \"from\": 300, \"to\": 330}, {\"ngram\": \"highly pathogenic avian influenza\", \"from\": 334, \"to\": 367}, {\"ngram\": \"bird flu\", \"from\": 385, \"to\": 393}, {\"ngram\": \"supply\", \"from\": 414, \"to\": 420}, {\"ngram\": \"poultry meat\", \"from\": 424, \"to\": 436}, {\"ngram\": \"eggs\", \"from\": 441, \"to\": 445}, {\"ngram\": \"prices\", \"from\": 455, \"to\": 461}, {\"ngram\": \"many parts\", \"from\": 475, \"to\": 485}, {\"ngram\": \"the globe\", \"from\": 489, \"to\": 498}, {\"ngram\": \"the past years\", \"from\": 502, \"to\": 516}]}, {\"sentence\": \"This prompted the government to launch a campaign in October to vaccinate all ducks against bird flu.\", \"from\": 519, \"to\": 620, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the government\", \"from\": 533, \"to\": 547}, {\"ngram\": \"a campaign\", \"from\": 558, \"to\": 568}, {\"ngram\": \"October\", \"from\": 572, \"to\": 579}, {\"ngram\": \"all ducks\", \"from\": 593, \"to\": 602}, {\"ngram\": \"bird flu\", \"from\": 611, \"to\": 619}]}, {\"sentence\": \"Ducks are among the most sensitive species to the virus and the most likely to carry it without being noticed, causing higher dissemination risks.\", \"from\": 621, \"to\": 767, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Ducks\", \"from\": 621, \"to\": 626}, {\"ngram\": \"the most sensitive species\", \"from\": 637, \"to\": 663}, {\"ngram\": \"the virus\", \"from\": 667, \"to\": 676}, {\"ngram\": \"higher dissemination risks\", \"from\": 740, \"to\": 766}]}, {\"sentence\": \"France, by far the world's largest producer of foie gras, only experienced 10 outbreaks of bird flu since it started vaccination, against 304 outbreaks by the same time last year, official data showed.\", \"from\": 768, \"to\": 969, \"entities\": [{\"begin\": 768, \"end\": 774, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9995791538427937, \"rank\": 0.0003726119010529496, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 815, \"end\": 824, \"title\": \"http://dbpedia.org/resource/Foie_gras\", \"score\": 1.0, \"rank\": 7.684803023126376e-28, \"text\": \"foie gras\", \"types\": [\"Q2095\"], \"wikid\": \"http://dbpedia.org/resource/Foie_gras\", \"dbpedia\": \"http://dbpedia.org/resource/Foie_gras\"}], \"noun_phrases\": [{\"ngram\": \"the world's largest producer\", \"from\": 783, \"to\": 811}, {\"ngram\": \"10 outbreaks\", \"from\": 843, \"to\": 855}, {\"ngram\": \"bird flu\", \"from\": 859, \"to\": 867}, {\"ngram\": \"vaccination\", \"from\": 885, \"to\": 896}, {\"ngram\": \"304 outbreaks\", \"from\": 906, \"to\": 919}, {\"ngram\": \"the same time\", \"from\": 923, \"to\": 936}, {\"ngram\": \"official data\", \"from\": 948, \"to\": 961}]}, {\"sentence\": \"Fewer outbreaks allowed producers to raise foie gras output for the first time this decade in 2023, with industry group Cifog estimating the gain at 20% to 10,000 tonnes.\", \"from\": 971, \"to\": 1141, \"entities\": [{\"begin\": 1014, \"end\": 1023, \"title\": \"http://dbpedia.org/resource/Foie_gras\", \"score\": 1.0, \"rank\": 7.684803023126376e-28, \"text\": \"foie gras\", \"types\": [\"Q2095\"], \"wikid\": \"http://dbpedia.org/resource/Foie_gras\", \"dbpedia\": \"http://dbpedia.org/resource/Foie_gras\"}], \"noun_phrases\": [{\"ngram\": \"Fewer outbreaks\", \"from\": 971, \"to\": 986}, {\"ngram\": \"producers\", \"from\": 995, \"to\": 1004}, {\"ngram\": \"the first time\", \"from\": 1035, \"to\": 1049}, {\"ngram\": \"industry group Cifog\", \"from\": 1076, \"to\": 1096}, {\"ngram\": \"the gain\", \"from\": 1108, \"to\": 1116}, {\"ngram\": \"20%\", \"from\": 1120, \"to\": 1123}, {\"ngram\": \"10,000 tonnes\", \"from\": 1127, \"to\": 1140}]}, {\"sentence\": \"\\\"We are once again becoming a reliable producer in terms of supply and quality,\\\" Cifog Director Marie-Pierre Pe told Reuters.\", \"from\": 1142, \"to\": 1267, \"entities\": [{\"begin\": 1259, \"end\": 1266, \"title\": \"http://dbpedia.org/resource/Reuters\", \"score\": 0.9999997607306172, \"rank\": 2.392693036375806e-07, \"text\": \"Reuters\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Reuters\", \"dbpedia\": \"http://dbpedia.org/resource/Reuters\"}], \"noun_phrases\": [{\"ngram\": \"a reliable producer\", \"from\": 1170, \"to\": 1189}, {\"ngram\": \"terms\", \"from\": 1193, \"to\": 1198}, {\"ngram\": \"supply\", \"from\": 1202, \"to\": 1208}, {\"ngram\": \"quality\", \"from\": 1213, \"to\": 1220}, {\"ngram\": \"Cifog Director Marie-Pierre Pe\", \"from\": 1223, \"to\": 1253}]}, {\"sentence\": \"\\\"The challenge is to put duck breast and French foie gras back on restaurant menus, particularly in the run-up to the big event that is the Olympic Games where the whole world will come to France.\", \"from\": 1269, \"to\": 1465, \"entities\": [{\"begin\": 1310, \"end\": 1316, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9993022772162701, \"rank\": 0.00035682538663171087, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 1317, \"end\": 1326, \"title\": \"http://dbpedia.org/resource/Foie_gras\", \"score\": 1.0, \"rank\": 7.684803023126376e-28, \"text\": \"foie gras\", \"types\": [\"Q2095\"], \"wikid\": \"http://dbpedia.org/resource/Foie_gras\", \"dbpedia\": \"http://dbpedia.org/resource/Foie_gras\"}, {\"begin\": 1458, \"end\": 1464, \"title\": \"http://dbpedia.org/res