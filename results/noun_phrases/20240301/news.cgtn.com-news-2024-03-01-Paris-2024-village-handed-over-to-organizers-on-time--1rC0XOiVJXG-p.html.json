\": 751}, {\"ngram\": \"their staff\", \"from\": 756, \"to\": 767}, {\"ngram\": \"the Olympics\", \"from\": 775, \"to\": 787}, {\"ngram\": \"9,000 athletes\", \"from\": 805, \"to\": 819}, {\"ngram\": \"their staff\", \"from\": 824, \"to\": 835}, {\"ngram\": \"the Paralympics\", \"from\": 840, \"to\": 855}]}, {\"sentence\": \"\\\"It's a demonstration that we have honored our commitments,\\\" Macron told reporters after meeting workers, who he said should be \\\"proud\\\" of taking part in what he called \\\"the adventure of a century.\\\"\", \"from\": 858, \"to\": 1056, \"entities\": [{\"begin\": 919, \"end\": 925, \"title\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"score\": 1.0, \"rank\": 1.2291121460342531e-17, \"text\": \"Macron\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"dbpedia\": \"http://dbpedia.org/resource/Emmanuel_Macron\"}], \"noun_phrases\": [{\"ngram\": \"a demonstration\", \"from\": 864, \"to\": 879}, {\"ngram\": \"our commitments\", \"from\": 901, \"to\": 916}, {\"ngram\": \"reporters\", \"from\": 931, \"to\": 940}, {\"ngram\": \"workers\", \"from\": 955, \"to\": 962}, {\"ngram\": \"part\", \"from\": 1004, \"to\": 1008}, {\"ngram\": \"\\\"the adventure\", \"from\": 1027, \"to\": 1041}, {\"ngram\": \"a century\", \"from\": 1045, \"to\": 1054}]}, {\"sentence\": \"A view of buildings at the Paris 2024 Olympic village on its inauguration day in Saint-Denis, northern Paris, France, February 29, 2024.\", \"from\": 1058, \"to\": 1194, \"entities\": [{\"begin\": 1085, \"end\": 1095, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 2.613918060238781e-19, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 1139, \"end\": 1150, \"title\": \"http://dbpedia.org/resource/Basilica_of_S