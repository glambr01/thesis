"{\"uid\": \"cnbc.com-2024-08-14-frances-political-tensions-return-to-the-fore-as-olympics-end.html\", \"noun_phrases\": [{\"sentence\": \"Time is running out on the so-called \\\"Olympic political truce\\\" declared by French President Emmanuel Macron in late July, pushing the country's rocky political landscape back into focus.\", \"from\": 0, \"to\": 188, \"entities\": [{\"begin\": 77, \"end\": 93, \"title\": \"http://dbpedia.org/resource/President_of_France\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"French President\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/President_of_France\", \"dbpedia\": \"http://dbpedia.org/resource/President_of_France\"}, {\"begin\": 94, \"end\": 109, \"title\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Emmanuel Macron\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"dbpedia\": \"http://dbpedia.org/resource/Emmanuel_Macron\"}], \"noun_phrases\": [{\"ngram\": \"Time\", \"from\": 0, \"to\": 4}, {\"ngram\": \"the so-called \\\"Olympic political truce\", \"from\": 23, \"to\": 61}, {\"ngram\": \"late July\", \"from\": 111, \"to\": 120}, {\"ngram\": \"the country's rocky political landscape\", \"from\": 130, \"to\": 169}, {\"ngram\": \"focus\", \"from\": 180, \"to\": 185}]}, {\"sentence\": \"The snap legislative election called by Macron for early July - just before Paris hosted the world's biggest sporting event -resulted in a hung parliament, with no party or alliance securing a majority.\", \"from\": 190, \"to\": 392, \"entities\": [{\"begin\": 230, \"end\": 236, \"title\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"score\": 1.0, \"rank\": 1.338591693658649e-40, \"text\": \"Macron\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"dbpedia\": \"http://dbpedia.org/resource/Emmanuel_Macron\"}, {\"begin\": 266, \"end\": 271, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.5091519977664e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"The snap legislative election\", \"from\": 190, \"to\": 219}, {\"ngram\": \"early July\", \"from\": 241, \"to\": 251}, {\"ngram\": \"the world's biggest sporting event\", \"from\": 279, \"to\": 313}, {\"ngram\": \"a hung parliament\", \"from\": 327, \"to\": 344}, {\"ngram\": \"no party\", \"from\": 351, \"to\": 359}, {\"ngram\": \"alliance\", \"from\": 363, \"to\": 371}, {\"ngram\": \"a majority\", \"from\": 381, \"to\": 391}]}, {\"sentence\": \"The left-wing New Popular Front alliance won the highest number of seats and prevented a much-discussed victory for the far-right National Rally.\", \"from\": 393, \"to\": 538, \"entities\": [{\"begin\": 411, \"end\": 424, \"title\": \"http://dbpedia.org/resource/Popular_front\", \"score\": 1.0, \"rank\": 1.9689613963422207e-14, \"text\": \"Popular Front\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Popular_front\", \"dbpedia\": \"http://dbpedia.org/resource/Popular_front\"}, {\"begin\": 523, \"end\": 537, \"title\": \"http://dbpedia.org/resource/National_Rally\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"National Rally\", \"types\": [\"Q7278\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/National_Rally\", \"dbpedia\": \"http://dbpedia.org/resource/National_Rally\"}], \"noun_phrases\": [{\"ngram\": \"the highest number\", \"from\": 438, \"to\": 456}, {\"ngram\": \"seats\", \"from\": 460, \"to\": 465}, {\"ngram\": \"a much-discussed victory\", \"from\": 480, \"to\": 504}]}, {\"sentence\": \"For the past few weeks, however, the nation has been largely united by sporting spirit.\", \"from\": 540, \"to\": 627, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the past few weeks\", \"from\": 544, \"to\": 562}, {\"ngram\": \"the nation\", \"from\": 573, \"to\": 583}, {\"ngram\": \"sporting spirit\", \"from\": 611, \"to\": 626}]}, {\"sentence\": \"The usual stream of squabbling from politicians across the spectrum has dried up, and a\\\"caretaker\\\" governmenthas remained nominally in place.\", \"from\": 629, \"to\": 770, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The usual stream\", \"from\": 629, \"to\": 645}, {\"ngram\": \"politicians\", \"from\": 665, \"to\": 676}, {\"ngram\": \"the spectrum\", \"from\": 684, \"to\": 696}, {\"ngram\": \"a\\\"caretaker\", \"from\": 715, \"to\": 726}, {\"ngram\": \"place\", \"from\": 764, \"to\": 769}]}, {\"sentence\": \"The National Assembly's next nine-month session is not due to begin until Oct. 1.\", \"from\": 771, \"to\": 852, \"entities\": [{\"begin\": 775, \"end\": 792, \"title\": \"http://dbpedia.org/resource/National_Assembly\", \"score\": 0.9999967806235853, \"rank\": 2.531980286389796e-06, \"text\": \"National Assembly\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/National_Assembly\", \"dbpedia\": \"http://dbpedia.org/resource/National_Assembly\"}], \"noun_phrases\": [{\"ngram\": \"Oct.\", \"from\": 845, \"to\": 849}]}, {\"sentence\": \"Macron is set to remain president until his term runs out in 2027, although much of his domestic political capital has been expended after his Renaissance party's electoral battering.\", \"from\": 854, \"to\": 1037, \"entities\": [{\"begin\": 854, \"end\": 860, \"title\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"score\": 1.0, \"rank\": 1.338591693658649e-40, \"text\": \"Macron\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"dbpedia\": \"http://dbpedia.org/resource/Emmanuel_Macron\"}, {\"begin\": 997, \"end\": 1008, \"title\": \"http://dbpedia.org/resource/Renaissance\", \"score\": 0.9996026481413727, \"rank\": 0.00037652176452429505, \"text\": \"Renaissance\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Renaissance\", \"dbpedia\": \"http://dbpedia.org/resource/Renaissance\"}], \"noun_phrases\": [{\"ngram\": \"president\", \"from\": 878, \"to\": 887}, {\"ngram\": \"his term\", \"from\": 894, \"to\": 902}, {\"ngram\": \"his domestic political capital\", \"from\": 938, \"to\": 968}]}, {\"sentence\": \"One of the key questions back on the agenda now is who Macron will appoint as the new prime minister - who leads the French government, nominates ministers and instigates legislation - after the resignation of his ally Gabriel Attal.\", \"from\": 1039, \"to\": 1272, \"entities\": [{\"begin\": 1094, \"end\": 1100, \"title\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"score\": 1.0, \"rank\": 1.338591693658649e-40, \"text\": \"Macron\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"dbpedia\": \"http://dbpedia.org/resource/Emmanuel_Macron\"}, {\"begin\": 1156, \"end\": 1162, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.5735532878796636, \"rank\": 0.5535610422472148, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 1258, \"end\": 1271, \"title\": \"http://dbpedia.org/resource/Gabriel_Attal\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Gabriel Attal\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Gabriel_Attal\", \"dbpedia\": \"http://dbpedia.org/resource/Gabriel_Attal\"}], \"noun_phrases\": [{\"ngram\": \"the key questions\", \"from\": 1046, \"to\": 1063}, {\"ngram\": \"the agenda\", \"from\": 1072, \"to\": 1082}, {\"ngram\": \"the new prime minister\", \"from\": 1117, \"to\": 1139}, {\"ngram\": \"ministers\", \"from\": 1185, \"to\": 1194}, {\"ngram\": \"legislation\", \"from\": 1210, \"to\": 1221}, {\"ngram\": \"the resignation\", \"from\": 1230, \"to\": 1245}, {\"ngram\": \"his ally\", \"from\": 1249, \"to\": 1257}]}, {\"sentence\": \"Macron is keeping his cards close to his chest, and has not commented on Lucie Castets, the little-known candidate nominated for the role by New Popular Front after much debate.\", \"from\": 1274, \"to\": 1451, \"entities\": [{\"begin\": 1274, \"end\": 1280, \"title\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"score\": 1.0, \"rank\": 1.338591693658649e-40, \"text\": \"Macron\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"dbpedia\": \"http://dbpedia.org/resource/Emmanuel_Macron\"}, {\"begin\": 1353, \"end\": 1360, \"title\": \"http://dbpedia.org/resource/Castets_(grape)\", \"score\": 0.5009607382045541, \"rank\": 0.6944444444443503, \"text\": \"Castets\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Castets_(grape)\", \"dbpedia\": \"http://dbpedia.org/resource/Castets_(grape)\"}, {\"begin\": 1419, \"end\": 1432, \"title\": \"http://dbpedia.org/resource/Popular_front\", \"score\": 1.0, \"rank\": 1.9689613963422207e-14, \"text\": \"Popular Front\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Popular_front\", \"dbpedia\": \"http://dbpedia.org/resource/Popular_front\"}], \"noun_phrases\": [{\"ngram\": \"his cards\", \"from\": 1292, \"to\": 1301}, {\"ngram\": \"his chest\", \"from\": 1311, \"to\": 1320}, {\"ngram\": \"the little-known candidate\", \"from\": 1362, \"to\": 1388}, {\"ngram\": \"the role\", \"from\": 1403, \"to\": 1411}, {\"ngram\": \"much debate\", \"from\": 1439, \"to\": 1450}]}, {\"sentence\": \"While theoretically free to appoint anyone to the role, and with no obligation to choose a candidate from the party with the most seats, an unpopular choice could be ousted by a vote of no confidence in parliament.\", \"from\": 1453, \"to\": 1667, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"anyone\", \"from\": 1489, \"to\": 1495}, {\"ngram\": \"the role\", \"from\": 1499, \"to\": 1507}, {\"ngram\": \"no obligation\", \"from\": 1518, \"to\": 1531}, {\"ngram\": \"a candidate\", \"from\": 1542, \"to\": 1553}, {\"ngram\": \"the party\", \"from\": 1559, \"to\": 1568}, {\"ngram\": \"the most seats\", \"from\": 1574, \"to\": 1588}, {\"ngram\": \"an unpopular choice\", \"from\": 1590, \"to\": 1609}, {\"ngram\": \"a vote\", \"from\": 1629, \"to\": 1635}, {\"ngram\": \"no confidence\", \"from\": 1639, \"to\": 1652}, {\"ngram\": \"parliament\", \"from\": 1656, \"to\": 1666}]}, {\"sentence\": \"Macron cannot dissolve the National Assembly and call another election for another year.\", \"from\": 1668, \"to\": 1756, \"entities\": [{\"begin\": 1668, \"end\": 1674, \"title\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"score\": 1.0, \"rank\": 1.338591693658649e-40, \"text\": \"Macron\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"dbpedia\": \"http://dbpedia.org/resource/Emmanuel_Macron\"}, {\"begin\": 1695, \"end\": 1712, \"title\": \"http://dbpedia.org/resource/National_Assembly\", \"score\": 0.9999967806235853, \"rank\": 2.531980286389796e-06, \"text\": \"National Assembly\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/National_Assembly\", \"dbpedia\": \"http://dbpedia.org/resource/National_Assembly\"}], \"noun_phrases\": [{\"ngram\": \"another election\", \"from\": 1722, \"to\": 1738}, {\"ngram\": \"another year\", \"from\": 1743, \"to\": 1755}]}, {\"sentence\": \"Elsa Clara Massoc, assistant professor of International Political Economy at the University of St. Gallen, said the situation was \\\"unprecedented\\\" and looked to be a potential \\\"dead-end\\\" because of the extent of division in the new parliament.\", \"from\": 1758, \"to\": 2000, \"entities\": [{\"begin\": 1758, \"end\": 1762, \"title\": \"http://dbpedia.org/resource/Elsa_von_Brabant\", \"score\": 0.9998412217001831, \"rank\