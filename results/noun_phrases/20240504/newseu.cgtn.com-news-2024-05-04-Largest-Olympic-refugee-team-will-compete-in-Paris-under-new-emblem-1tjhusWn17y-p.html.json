9}]}, {\"sentence\": \"From 74 athletes, 36 were chosen to compete in this year's games which kick off in the French capital on July 26th.\", \"from\": 583, \"to\": 698, \"entities\": [{\"begin\": 670, \"end\": 676, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9999678917390862, \"rank\": 1.8548873031363168e-05, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"74 athletes\", \"from\": 588, \"to\": 599}, {\"ngram\": \"this year's games\", \"from\": 630, \"to\": 647}, {\"ngram\": \"July 26th\", \"from\": 688, \"to\": 697}]}, {\"sentence\": \"They come from 11 countries, are currently being hosted by 15 National Olympic Committees and are representing 12 sports.\", \"from\": 699, \"to\": 820, \"entities\": [{\"begin\": 761, \"end\": 788, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 0.9999969207694563, \"rank\": 3.079240172247933e-06, \"text\": \"National Olympic Committees\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"11 countries\", \"from\": 714, \"to\": 726}, {\"ngram\": \"12 sports\", \"from\": 810, \"to\": 819}]}, {\"sentence\": \"Among them was Cindy Ngamba, the first athlete from the refugee team to be selected for boxing.\", \"from\": 822, \"to\": 917, \"entities\": [{\"begin\": 837, \"end\": 842, \"title\": \"http://dbpedia.org/resource/Cindy_McCain\", \"score\": 0.9979348250407112, \"rank\": 0.0020512036897294833, \"text\": \"Cindy\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Cindy_McCain\", \"dbpedia\": \"http://dbpedia.org/resource/Cindy_McCain\"}, {\"begin\": 843, \"end\": 849, \"title\": \