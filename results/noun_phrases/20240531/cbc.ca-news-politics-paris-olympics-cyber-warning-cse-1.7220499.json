"{\"uid\": \"cbc.ca-news-politics-paris-olympics-cyber-warning-cse-1.7220499\", \"noun_phrases\": [{\"sentence\": \"As athletes and officials prepare for this summer's Paris Olympics, Canada's electronic intelligence agency is warning them to also get ready for likely cyberattacks.\", \"from\": 0, \"to\": 166, \"entities\": [{\"begin\": 52, \"end\": 66, \"title\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Paris Olympics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/1924_Summer_Olympics\"}, {\"begin\": 68, \"end\": 74, \"title\": \"http://dbpedia.org/resource/Canada\", \"score\": 0.9999999999995453, \"rank\": 3.158060689662271e-13, \"text\": \"Canada\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Canada\", \"dbpedia\": \"http://dbpedia.org/resource/Canada\"}], \"noun_phrases\": [{\"ngram\": \"athletes\", \"from\": 3, \"to\": 11}, {\"ngram\": \"officials\", \"from\": 16, \"to\": 25}, {\"ngram\": \"likely cyberattacks\", \"from\": 146, \"to\": 165}]}, {\"sentence\": \"The Communications Security Establishment (CSE) - in charge of gathering signals intelligence and protecting the federal government's cyber networks - issued a threat bulletin Friday morning aimed at tourists, government officials and athletes attending the events, as well as Canadian organizations involved in organizing, managing, sponsoring and broadcasting major sporting events.\", \"from\": 168, \"to\": 552, \"entities\": [{\"begin\": 172, \"end\": 209, \"title\": \"http://dbpedia.org/resource/Communications_Security_Establishment\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Communications Security Establishment\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Communications_Security_Establishment\", \"dbpedia\": \"http://dbpedia.org/resource/Communications_Security_Establishment\"}, {\"begin\": 211, \"end\": 214, \"title\": \"http://dbpedia.org/resource/Communications_Security_Establishment\", \"score\": 1.0, \"rank\": 1.3114297183834375e-34, \"text\": \"CSE\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Communications_Security_Establishment\", \"dbpedia\": \"http://dbpedia.org/resource/Communications_Security_Establishment\"}, {\"begin\": 445, \"end\": 453, \"title\": \"http://dbpedia.org/resource/Canada\", \"score\": 0.9988732099508913, \"rank\": 0.0009156678561942789, \"text\": \"Canadian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Canada\", \"dbpedia\": \"http://dbpedia.org/resource/Canada\"}], \"noun_phrases\": [{\"ngram\": \"charge\", \"from\": 221, \"to\": 227}, {\"ngram\": \"gathering\", \"from\": 231, \"to\": 240}, {\"ngram\": \"signals intelligence\", \"from\": 241, \"to\": 261}, {\"ngram\": \"the federal government's cyber networks\", \"from\": 277, \"to\": 316}, {\"ngram\": \"a threat bulletin\", \"from\": 326, \"to\": 343}, {\"ngram\": \"tourists\", \"from\": 368, \"to\": 376}, {\"ngram\": \"government officials\", \"from\": 378, \"to\": 398}, {\"ngram\": \"athletes\", \"from\": 403, \"to\": 411}, {\"ngram\": \"the events\", \"from\": 422, \"to\": 432}, {\"ngram\": \"organizing\", \"from\": 480, \"to\": 490}, {\"ngram\": \"major sporting events\", \"from\": 530, \"to\": 551}]}, {\"sentence\": \"\\\"The high profile and costly nature of major international sporting events make them a prime target for cybercriminals looking to exploit targets of opportunity for profit.\", \"from\": 554, \"to\": 726, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The high profile\", \"from\": 555, \"to\": 571}, {\"ngram\": \"costly nature\", \"from\": 576, \"to\": 589}, {\"ngram\": \"major international sporting events\", \"from\": 593, \"to\": 628}, {\"ngram\": \"cybercriminals\", \"from\": 658, \"to\": 672}, {\"ngram\": \"targets\", \"from\": 692, \"to\": 699}, {\"ngram\": \"opportunity\", \"from\": 703, \"to\": 714}, {\"ngram\": \"profit\", \"from\": 719, \"to\": 725}]}, {\"sentence\": \"They also provide a global stage for hacktivists and state-sponsored actors to gather information and publicly embarrass a target,\\\" thereport says.\", \"from\": 727, \"to\": 874, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a global stage\", \"from\": 745, \"to\": 759}, {\"ngram\": \"hacktivists\", \"from\": 764, \"to\": 775}, {\"ngram\": \"state-sponsored actors\", \"from\": 780, \"to\": 802}, {\"ngram\": \"information\", \"from\": 813, \"to\": 824}, {\"ngram\": \"a target\", \"from\": 848, \"to\": 856}, {\"ngram\": \"thereport\", \"from\": 859, \"to\": 868}]}, {\"sentence\": \"Sami Khoury, head of CSE's Canadian Centre for Cyber Security, said the Olympics, this summer's Formula 1 Canadian Grand Prix in Montreal and the World Junior Championships in Ottawa this winter are all ripe for \\\"cyber malfeasance.\\\"\", \"from\": 876, \"to\": 1108, \"entities\": [{\"begin\": 876, \"end\": 880, \"title\": \"http://dbpedia.org/resource/Sami_Brady\", \"score\": 1.0, \"rank\": 1.9160104329960944e-18, \"text\": \"Sami\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Sami_Brady\", \"dbpedia\": \"http://dbpedia.org/resource/Sami_Brady\"}, {\"begin\": 881, \"end\": 887, \"title\": \"http://dbpedia.org/resource/Elias_Khoury\", \"score\": 0.9030624868344221, \"rank\": 0.10734308486799747, \"text\": \"Khoury\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Elias_Khoury\", \"dbpedia\": \"http://dbpedia.org/resource/Elias_Khoury\"}, {\"begin\": 897, \"end\": 900, \"title\": \"http://dbpedia.org/resource/Communications_Security_Establishment\", \"score\": 1.0, \"rank\": 1.3114297183834375e-34, \"text\": \"CSE\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Communications_Security_Establishment\", \"dbpedia\": \"http://dbpedia.org/resource/Communications_Security_Establishment\"}, {\"begin\": 903, \"end\": 911, \"title\": \"http://dbpedia.org/resource/Canada\", \"score\": 0.9988732099508913, \"rank\": 0.0009156678561942789, \"text\": \"Canadian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Canada\", \"dbpedia\": \"http://dbpedia.org/resource/Canada\"}, {\"begin\": 1005, \"end\": 1013, \"title\": \"http://dbpedia.org/resource/Montreal\", \"score\": 0.9999999921701601, \"rank\": 7.812439872850872e-09, \"text\": \"Montreal\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Montreal\", \"dbpedia\": \"http://dbpedia.org/resource/Montreal\"}, {\"begin\": 1022, \"end\": 1048, \"title\": \"http://dbpedia.org/resource/IIHF_World_Junior_Championship\", \"score\": 0.8965234812641834, \"rank\": 0.1152635042551826, \"text\": \"World Junior Championships\", \"types\": [\"Q623109\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/IIHF_World_Junior_Championship\", \"dbpedia\": \"http://dbpedia.org/resource/IIHF_World_Junior_Championship\"}, {\"begin\": 1052, \"end\": 1058, \"title\": \"http://dbpedia.org/resource/Ottawa\", \"score\": 1.0, \"rank\": 4.32731553352939e-16, \"text\": \"Ottawa\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Ottawa\", \"dbpedia\": \"http://dbpedia.org/resource/Ottawa\"}], \"noun_phrases\": [{\"ngram\": \"head\", \"from\": 889, \"to\": 893}, {\"ngram\": \"Cyber Security\", \"from\": 923, \"to\": 937}, {\"ngram\": \"the Olympics\", \"from\": 944, \"to\": 956}, {\"ngram\": \"this summer's Formula 1 Canadian Grand Prix\", \"from\": 958, \"to\": 1001}, {\"ngram\": \"this winter\", \"from\": 1059, \"to\": 1070}, {\"ngram\": \"cyber malfeasance\", \"from\": 1089, \"to\": 1106}]}, {\"sentence\": \"The CSE bulletin said cybercriminals \\\"will very likely target\\\" for extortion large organizations - such as government organizations and corporations involved in sponsoring the events - and local businesses, especially those in the travel and hospitality sectors.\", \"from\": 1110, \"to\": 1372, \"entities\": [{\"begin\": 1114, \"end\": 1117, \"title\": \"http://dbpedia.org/resource/Communications_Security_Establishment\", \"score\": 1.0, \"rank\": 1.3114297183834375e-34, \"text\": \"CSE\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Communications_Security_Establishment\", \"dbpedia\": \"http://dbpedia.org/resource/Communications_Security_Establishment\"}], \"noun_phrases\": [{\"ngram\": \"cybercriminals\", \"from\": 1132, \"to\": 1146}, {\"ngram\": \"extortion\", \"from\": 1177, \"to\": 1186}, {\"ngram\": \"large organizations\", \"from\": 1187, \"to\": 1206}, {\"ngram\": \"government organizations\", \"from\": 1217, \"to\": 1241}, {\"ngram\": \"corporations\", \"from\": 1246, \"to\": 1258}, {\"ngram\": \"the events - and local businesses\", \"from\": 1282, \"to\": 1315}, {\"ngram\": \"especially those\", \"from\": 1317, \"to\": 1333}, {\"ngram\": \"the travel and hospitality sectors\", \"from\": 1337, \"to\": 1371}]}, {\"sentence\": \"Attendees and spectators should also be aware they could be targeted through phishing emails and malicious websites, the agency said.\", \"from\": 1374, \"to\": 1507, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Attendees\", \"from\": 1374, \"to\": 1383}, {\"ngram\": \"spectators\", \"from\": 1388, \"to\": 1398}, {\"ngram\": \"phishing emails\", \"from\": 1451, \"to\": 1466}, {\"ngram\": \"malicious websites\", \"from\": 1471, \"to\": 1489}, {\"ngram\": \"the agency\", \"from\": 1491, \"to\": 1501}]}, {\"sentence\": \"\\\"Topical event-related lures may include promises of discounted merchandise, free event tickets or access to a livestream of the events,\\\" the report says.\", \"from\": 1509, \"to\": 1663, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Topical event-related lures\", \"from\": 1510, \"to\": 1537}, {\"ngram\": \"promises\", \"from\": 1550, \"to\": 1558}, {\"ngram\": \"discounted merchandise\", \"from\": 1562, \"to\": 1584}, {\"ngram\": \"free event tickets\", \"from\": 1586, \"to\": 1604}, {\"ngram\": \"access\", \"from\": 1608, \"to\": 1614}, {\"ngram\": \"a livestream\", \"from\": 1618, \"to\": 1630}, {\"ngram\": \"the events\", \"from\": 1634, \"to\": 1644}, {\"ngram\": \"the report\", \"from\": 1647, \"to\": 1657}]}, {\"sentence\": \"CSE said state-sponsored cyber threat actors likely will try to spy on prominent and high-profile individuals, including representatives of government and anti-doping organziations.\", \"from\": 1665, \"to\": 1846, \"entities\": [{\"begin\": 1665, \"end\": 1668, \"title\": \"http://dbpedia.org/resource/Communications_Security_Establishment\", \"score\": 1.0, \"rank\": 1.3114297183834375e-34, \"text\": \"CSE\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Communications_Security_Establishment\", \"dbpedia\": \"http://dbpedia.org/resource/Communications_Security_Establishment\"}], \"noun_phrases\": [{\"ngram\": \"state-sponsored cyber threat actors\", \"from\": 1674, \"to\": 1709}, {\"ngram\": \"prominent and high-profile individuals\", \"from\": 1736, \"to\": 1774}, {\"ngram\": \"representatives\", \"from\": 1786, \"to\": 1801}, {\"ngram\": \"government\", \"from\": 1805, \"to\": 1815}, {\"ngram\": \"anti-doping organziations\", \"from\": 1820, \"to\": 1845}]}, {\"sentence\": \"\\\"We know that these events, especially [the] opening ceremony, closing ceremony, tend to draw a lot of very important people to those events, heads of states, you know, senior government officials.\", \"from\": 1848, \"to\": 2045, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"these events\", \"from\": 1862, \"to\": 1874}, {\"ngram\": \"especially [the] opening ceremony\", \"from\": 1876, \"to\": 1909}, {\"ngram\": \"closing ceremony\", \"from\": 1911, \"to\": 1927}, {\"ngram\": \"a lot\", \"from\": 1942, \"to\": 1947}, {\"ngram\": \"very important people\", \"from\": 1951, \"to\": 1972}, {\"ngram\": \"those events\", \"from\": 1976, \"to\": 1988}, {\"ngram\": \"heads\", \"from\": 1990, \"to\": 1995}, {\"ngram\": \"states\", \"from\": 1999, \"to\": 2005}]}, {\"sentence\": \"And that's a very rich target for a nation state,\\\" said Khoury.\", \"from\": 2046, \"to\": 2109, \"entities\": [{\"begin\": 2102, \"end\": 2108, \"title\": \"http://dbpedia.org/resource/Elias_Khoury\", \"score\": 0.9030624868344221, \"rank\": 0.10734308486799747, \"text\": \"Khoury\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Elias_Khoury\", \"dbpedia\": \"http://dbpedia.org/resource/Elias_Khoury\"}], \"noun_phrases\": [{\"ngram\": \"a very rich target\", \"from\": 2057, \"to\": 2075}, {\"ngram\": \"a nation state\", \"from\": 2080, \"to\": 2094}]}, {\"sentence\": \"He said state actors will be looking to collect foreign intelligence or personal information on dignitaries and create a backdoor on their phones to obtain access to their office systems.\", \"from\": 2111, \"to\": 2298, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"state actors\", \"from\": 2119, \"to\": 2131}, {\"ngram\": \"foreign intelligence\", \"from\": 2159, \"to\": 2179}, {\"ngram\": \"personal information\", \"from\": 2183, \"to\": 2203}, {\"ngram\": \"dignitaries\", \"from\": 2207, \"to\": 2218}, {\"ngram\": \"a backdoor\", \"from\": 2230, \"to\": 2240}, {\"ngram\": \"their phones\", \"from\": 2244, \"to\": 2256}, {\"ngram\": \"access\", \"from\": 2267, \"to\": 2273}, {\"ngram\": \"their office systems\", \"from\": 2277, \"to\": 2297}]}, {\"sentence\": \"\\\"If I go to Paris, a state sponsored [actor] then exploits my phone.\", \"from\": 2300, \"to\": 2368, \"entities\": [{\"begin\": 2312, \"end\": 2317, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999999999622105, \"rank\": 3.781050958098674e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"a state\", \"from\": 2319, \"to\": 2326}, {\"ngram\": \"actor\", \"from\": 2338, \"to\": 2343}, {\"ngram\": \"my phone\", \"from\": 2359, \"to\": 2367}]}, {\"sentence\": \"I come back to work, I am now connected to my IT infrastructure at work and and this is an easy way for a state sponsor to get into our IT without having to maybe exploit the it from the outside,\\\" he said.\", \"from\": 2369, \"to\": 2574, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"work\", \"from\": 2384, \"to\": 2388}, {\"ngram\": \"my IT infrastructure\", \"from\": 2412, \"to\": 2432}, {\"ngram\": \"work\", \"from\": 2436, \"to\": 2440}, {\"ngram\": \"an easy way\", \"from\": 2457, \"to\": 2468}, {\"ngram\": \"a state sponsor\", \"from\": 2473, \"to\": 2488}, {\"ngram\": \"the outside\", \"from\": 2552, \"to\": 2563}]}, {\"sentence\": \"The CSE report points to the 2016 Olympics in Rio, where Russia-backed threat actors targeted hotel chain wi-fi networks and routers used by Olympics officials for reconnaissance.\", \"from\": 2576, \"to\": 2755, \"entities\": [{\"begin\": 2580, \"end\": 2583, \"title\": \"http://dbpedia.org/resource/Communications_Security_Establishment\", \"score\": 1.0, \"rank\": 1.3114297183834375e-34, \"text\": \"CSE\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Communications_Security_Establishment\", \"dbpedia\": \"http://dbpedia.org/resource/Communications_Security_Establishment\"}, {\"begin\": 2605, \"end\": 2618, \"title\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"score\": 1.0, \"rank\": 5.861981409021185e-19, \"text\": \"2016 Olympics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2016_Summer_Olympics\"}, {\"begin\": 2622, \"end\": 2625, \"title\": \"http://dbpedia.org/resource/Earth_Summit\", \"score\": 0.8234957048649733, \"rank\": 0.1455881841077775, \"text\": \"Rio\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Earth_Summit\", \"dbpedia\": \"http://dbpedia.org/resource/Earth_Summit\"}], \"noun_phrases\": [{\"ngram\": \"Russia-backed threat actors\", \"from\": 2633, \"to\": 2660}, {\"ngram\": \"hotel chain wi-fi networks\", \"from\": 2670, \"to\": 2696}, {\"ngram\": \"routers\", \"from\": 2701, \"to\": 2708}, {\"ngram\": \"Olympics officials\", \"from\": 2717, \"to\": 2735}, {\"ngram\": \"reconnaissance\", \"from\": 2740, \"to\": 2754}]}, {\"sentence\": \"They were ultimately able to compromise the World Anti-Doping Agency (WADA) databaseand leaked the personal information of 127 athletes, including their test reports, therapeutic use exemptions and past infractions.\", \"from\": 2757, \"to\": 2972, \"entities\": [{\"begin\": 2801, \"end\": 2832, \"title\": \"http://dbpedia.org/resource/World_Anti-Doping_Agency\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"World Anti-Doping Agency (WADA)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Anti-Doping_Agency\", \"dbpedia\": \"http://dbpedia.org/resource/World_Anti-Doping_Agency\"}], \"noun_phrases\": [{\"ngram\": \"the personal information\", \"from\": 2852, \"to\": 2876}, {\"ngram\": \"127 athletes\", \"from\": 2880, \"to\": 2892}, {\"ngram\": \"their test reports\", \"from\": 2904, \"to\": 2922}, {\"ngram\": \"therapeutic use exemptions\", \"from\": 2924, \"to\": 2950}, {\"ngram\": \"past infractions\", \"from\": 2955, \"to\": 2971}]}, {\"sentence\": \"Hacktvists likely will also see this summer's Olympics as an opportunity to get their messages out through website defacements, distributed denial-of-service (DDoS) attacks and hack-and-leak operations, said CSE.\", \"from\": 2974, \"to\": 3186, \"entities\": [{\"begin\": 3182, \"end\": 3185, \"title\": \"http://dbpedia.org/resource/Communications_Security_Establishment\", \"score\": 1.0, \"rank\": 1.3114297183834375e-34, \"text\": \"CSE\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Communications_Security_Establishment\", \"dbpedia\": \"http://dbpedia.org/resource/Communications_Security_Establishment\"}], \"noun_phrases\": [{\"ngram\": \"Hacktvists\", \"from\": 2974, \"to\": 2984}, {\"ngram\": \"this summer's Olympics\", \"from\": 3006, \"to\": 3028}, {\"ngram\": \"an opportunity\", \"from\": 3032, \"to\": 3046}, {\"ngram\": \"their messages\", \"from\": 3054, \"to\": 3068}, {\"ngram\": \"website defacements\", \"from\": 3081, \"to\": 3100}, {\"ngram\": \"service\", \"from\": 3124, \"to\": 3131}, {\"ngram\": \"(DDoS\", \"from\": 3132, \"to\": 3137}, {\"ngram\": \"hack-and-leak operations\", \"from\": 3151, \"to\": 3175}]}, {\"sentence\": \"\\\"Major international sporting events provide an opportunity for hacktivists to widely promote their messaging on domestic issues, environmental causes or international conflict situations,\\\" it said.\", \"from\": 3188, \"to\": 3386, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Major international sporting events\", \"from\": 3189, \"to\": 3224}, {\"ngram\": \"an opportunity\", \"from\": 3233, \"to\": 3247}, {\"ngram\": \"hacktivists\", \"from\": 3252, \"to\": 3263}, {\"ngram\": \"their messaging\", \"from\": 3282, \"to\": 3297}, {\"ngram\": \"domestic issues\", \"from\": 3301, \"to\": 3316}]}, {\"sentence\": \"The threat report said the anti-government protests in France regarding changes to the minimum pension age are \\\"likely a motivation for domestic hacktivism against the 2024 Paris Olympics.\\\"\", \"from\": 3388, \"to\": 3577, \"entities\": [{\"begin\": 3443, \"end\": 3449, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9978150009081147, \"rank\": 0.001864232734888434, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"The