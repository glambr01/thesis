"}], \"noun_phrases\": [{\"ngram\": \"The women\\u00e2\\u0080\\u0099s 400mH race\", \"from\": 1220, \"to\": 1244}, {\"ngram\": \"fun\", \"from\": 1253, \"to\": 1256}, {\"ngram\": \"\\u00e2\\u0080\\u0094\", \"from\": 1274, \"to\": 1277}]}, {\"sentence\": \"Her result was predictable which is why superfans had been begging her to try the flat 400 or even the 200m, an event in which she had a promising early season result.\", \"from\": 1311, \"to\": 1478, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Her result\", \"from\": 1311, \"to\": 1321}, {\"ngram\": \"superfans\", \"from\": 1351, \"to\": 1360}, {\"ngram\": \"even the 200m\", \"from\": 1405, \"to\": 1418}, {\"ngram\": \"an event\", \"from\": 1420, \"to\": 1428}, {\"ngram\": \"a promising early season result\", \"from\": 1446, \"to\": 1477}]}, {\"sentence\": \"Regardless of what could have been, Sydney performed at her absolute best with another world record in the 400mH and a masterful 400m leg in the 4x4.\", \"from\": 1480, \"to\": 1629, \"entities\": [{\"begin\": 1516, \"end\": 1522, \"title\": \"http://dbpedia.org/resource/Sydney\", \"score\": 0.9987934512211736, \"rank\": 0.0008241834695506164, \"text\": \"Sydney\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Sydney\", \"dbpedia\": \"http://dbpedia.org/resource/Sydney\"}], \"noun_phrases\": [{\"ngram\": \"another world record\", \"from\": 1559, \"to\": 1579}, {\"ngram\": \"the 400mH\", \"from\": 1583, \"to\": 1592}, {\"ngram\": \"a masterful 400m leg\", \"from\": 1597, \"to\": 1617}, {\"ngram\": \"the 4x4\", \"from\": 1621, \"to\": 1628}]}, {\"sentence\": \"Both races were a pleasure to watch.\", \"from\": 1630, \"to\": 1666, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Both races\", \"from\": 1630, \"to\": 1640}, {\"ngram\": \"a pleasure\", \"from\": 1646, \"to\": 1656}]}, {\"sentence\": \"Sydney met expectations.\", \"from\": 1668, \"to\": 1692, \"entities\": [{\"begin\": 1668, \"end\": 1674, \"title\": \"http://d