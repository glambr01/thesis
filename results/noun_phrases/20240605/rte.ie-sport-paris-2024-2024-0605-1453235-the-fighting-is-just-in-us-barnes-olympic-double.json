], \"noun_phrases\": [{\"ngram\": \"3:1 more punches\", \"from\": 4597, \"to\": 4613}, {\"ngram\": \"a countback\", \"from\": 4657, \"to\": 4668}]}, {\"sentence\": \"\\\"I felt myself in the fight that I did not win because it was very close.\", \"from\": 4671, \"to\": 4744, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the fight\", \"from\": 4689, \"to\": 4698}]}, {\"sentence\": \"But it is what it is, I lost to the best, I gave it all and I could not have given anymore.\\\"\", \"from\": 4745, \"to\": 4837, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Barnes' dreams of Olympic gold were ended on 8 August 2016 with a split decision defeat to Spain's Samuel Carmona in Rio.\", \"from\": 4839, \"to\": 4960, \"entities\": [{\"begin\": 4930, \"end\": 4935, \"title\": \"http://dbpedia.org/resource/Spain_national_football_team\", \"score\": 0.9999999999986358, \"rank\": 7.402963647133687e-13, \"text\": \"Spain\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Spain_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Spain_national_football_team\"}, {\"begin\": 4938, \"end\": 4952, \"title\": \"http://dbpedia.org/resource/Samuel_Carmona\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Samuel Carmona\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Samuel_Carmona\", \"dbpedia\": \"http://dbpedia.org/resource/Samuel_Carmona\"}, {\"begin\": 4956, \"end\": 4959, \"title\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"score\": 0.999999999614829, \"rank\": 3.8499885308158973e-10, \"text\": \"Rio\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2016_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"Barnes' dreams\", \"from\": 4839, \"to\": 4853}, {\"ngram\": \"Olympic gold\", \"from\": 4857, \"to\": 4869}, {\"ngram\": \"8 August\", \"from\": 4884, \"t