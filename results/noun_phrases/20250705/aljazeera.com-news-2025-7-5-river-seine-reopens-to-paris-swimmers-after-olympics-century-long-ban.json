81, \"to\": 3728}, {\"ngram\": \"bacterial levels\", \"from\": 3769, \"to\": 3785}, {\"ngram\": \"several years\", \"from\": 3803, \"to\": 3816}]}, {\"sentence\": \"Despite being in line with current regulations, the official water-testing methodology has limitations and undercounts the bacteria, he said.\", \"from\": 3818, \"to\": 3959, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"line\", \"from\": 3835, \"to\": 3839}, {\"ngram\": \"current regulations\", \"from\": 3845, \"to\": 3864}, {\"ngram\": \"the official water-testing methodology\", \"from\": 3866, \"to\": 3904}, {\"ngram\": \"limitations\", \"from\": 3909, \"to\": 3920}, {\"ngram\": \"the bacteria\", \"from\": 3937, \"to\": 3949}]}, {\"sentence\": \"\\\"What we see is that the water quality in the Seine is highly variable,\\\" Angelescu said.\", \"from\": 3961, \"to\": 4049, \"entities\": [{\"begin\": 4007, \"end\": 4012, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 1.0, \"rank\": 2.824284662638903e-15, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"the water quality\", \"from\": 3982, \"to\": 3999}, {\"ngram\": \"Angelescu\", \"from\": 4034, \"to\": 4043}]}, {\"sentence\": \"\\\"There are only a few days in a swimming season where I would say water quality is acceptable for swimming.\\\"\", \"from\": 4050, \"to\": 4158, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"only a few days\", \"from\": 4061, \"to\": 4076}, {\"ngram\": \"a swimming season\", \"from\": 4080, \"to\": 4097}, {\"ngram\": \"water quality\", \"from\": 4116, \"to\": 4129}, {\"ngram\": \"swimming\", \"from\": 4148, \"to\": 4156}]}, {\"sentence\": \"Some Parisians are also hesitant about the idea of swimming in the Seine.\", \"from\": 4160, \"to\": 4233, \"entities\": [{\"begin\": 4227, \"end\": 4232, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 1.0, \"r