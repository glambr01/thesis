ies\": [], \"noun_phrases\": []}, {\"sentence\": \"Sex is much more complicated.\\\"\", \"from\": 4531, \"to\": 4561, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Sex\", \"from\": 4531, \"to\": 4534}]}, {\"sentence\": \"People generally find out they have a difference in sex development around when they are born or once they become a teenager.\", \"from\": 4563, \"to\": 4688, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"People\", \"from\": 4563, \"to\": 4569}, {\"ngram\": \"a difference\", \"from\": 4599, \"to\": 4611}, {\"ngram\": \"sex development\", \"from\": 4615, \"to\": 4630}, {\"ngram\": \"a teenager\", \"from\": 4677, \"to\": 4687}]}, {\"sentence\": \"But Professor H\\u00f8jbjerg Gravholt explained the last patient he had diagnosed was a woman in her early thirties who had sought help as she could not get pregnant.\", \"from\": 4690, \"to\": 4850, \"entities\": [{\"begin\": 4704, \"end\": 4712, \"title\": \"http://dbpedia.org/resource/H\\u00f8jbjerg\", \"score\": 0.9764823238924786, \"rank\": 0.0, \"text\": \"H\\u00f8jbjerg\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/H\\u00f8jbjerg\", \"dbpedia\": \"http://dbpedia.org/resource/H\\u00f8jbjerg\"}], \"noun_phrases\": [{\"ngram\": \"the last patient\", \"from\": 4732, \"to\": 4748}, {\"ngram\": \"a woman\", \"from\": 4770, \"to\": 4777}, {\"ngram\": \"her early thirties\", \"from\": 4781, \"to\": 4799}, {\"ngram\": \"help\", \"from\": 4815, \"to\": 4819}]}, {\"sentence\": \"\\\"She had a normal vagina, a normal external female appearance, but did not have a uterus, and she also produced a lot of testosterone from her two testes, which were placed at the same place as the ovaries,\\\" he added.\", \"from\": 4852, \"to\": 5069, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a normal vagina\", \"from\": 4861, \"to\": 4876}, {\"ngram\": \"a normal external female appearance\", \"from\": 4878, \"to\": 4913}, {\"ngram\": \"a uterus\", \"from\": 4932, \"to\": 4940}, {\"ngram\": \"a lot\", \"from\": 4964, \"to\": 4969}, {\"ngram\": \"testosterone\", \"from\": 4973, \"to\": 4985}, {\"ngram\": \"her two testes\", \"from\": 4991, \"to\": 5005}, {\"ngram\": \"the same place\", \"from\": 5028, \"to\": 5042}, {\"ngram\": \"the ovaries\", \"from\": 5046, \"to\": 5057}]}, {\"sentence\": \"Her experience demonstrates how complicated differences in sex development are, he said, explaining the patient was \\\"devastated\\\" when he told her that she could not get pregnant due to not having a uterus.\", \"from\": 5071, \"to\": 5276, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Her experience\", \"from\": 5071, \"to\": 5085}, {\"ngram\": \"how complicated differences\", \"from\": 5099, \"to\": 5126}, {\"ngram\": \"sex development\", \"from\": 5130, \"to\": 5145}, {\"ngram\": \"the patient\", \"from\": 5171, \"to\": 5182}, {\"ngram\": \"a uterus\", \"from\": 5267, \"to\": 5275}]}, {\"sentence\": \"Professor H\\u00f8jbjerg Gravholt explains around half of the patients he sees do not have a uterus so they can not carry a child through a pregnancy - while the other half have a uterus, but do not produce eggs.\", \"from\": 5278, \"to\": 5484, \"entities\": [{\"begin\": 5288, \"end\": 5296, \"title\": \"http://dbpedia.org/resource/H\\u00f8jbjerg\", \"score\": 0.9764823238924786, \"rank\": 0.0, \"text\": \"H\\u00f8jbjerg\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/H\\u00f8jbjerg\", \"dbpedia\": \"http://dbpedia.org/resource/H\\u00f8jbjerg\"}], \"noun_phrases\": [{\"ngram\": \"half\", \"from\": 5322, \"to\": 5326}, {\"ngram\": \"the patients\", \"from\": 5330, \"to\": 5342}, {\"ngram\": \"a uterus\", \"from\": 5363, \"to\": 5371}, {\"ngram\": \"a child\", \"from\": 5394, \"to\": 5401}, {\"ngram\": \"a pregnancy\", \"from\": 5410, \"to\": 5421}, {\"ngram\": \"the other half\", \"from\": 5430, \"to\": 5444}, {\"ngram\": \"a uterus\", \"from\": 5450, \"to\": 5458}, {\"ngram\": \"eggs\", \"from\": 5479, \"to\": 5483}]}, {\"sentenc