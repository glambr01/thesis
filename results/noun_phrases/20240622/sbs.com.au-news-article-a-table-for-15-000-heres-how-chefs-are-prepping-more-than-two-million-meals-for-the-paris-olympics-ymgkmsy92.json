, \"from\": 800, \"to\": 851}, {\"ngram\": \"every way\", \"from\": 862, \"to\": 871}]}, {\"sentence\": \"Chef Charles Guilloy, who is leading the Sodexo Live!\", \"from\": 931, \"to\": 984, \"entities\": [{\"begin\": 936, \"end\": 943, \"title\": \"http://dbpedia.org/resource/Charles_I_of_England\", \"score\": 0.5834769149023782, \"rank\": 0.7119650990811607, \"text\": \"Charles\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Charles_I_of_England\", \"dbpedia\": \"http://dbpedia.org/resource/Charles_I_of_England\"}], \"noun_phrases\": [{\"ngram\": \"the Sodexo Live\", \"from\": 968, \"to\": 983}]}, {\"sentence\": \"catering team, will prep and cook for not only the athletes but also their team officials.\", \"from\": 985, \"to\": 1075, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"catering team\", \"from\": 985, \"to\": 998}, {\"ngram\": \"not only the athletes\", \"from\": 1023, \"to\": 1044}, {\"ngram\": \"their team officials\", \"from\": 1054, \"to\": 1074}]}, {\"sentence\": \"Estelle Lamotte, a nutrition and logistics expert who is part of Guilloy's team, said: \\\"The Olympic Games was a no-brainer.\\\"\", \"from\": 1077, \"to\": 1201, \"entities\": [{\"begin\": 1077, \"end\": 1084, \"title\": \"http://dbpedia.org/resource/Estelle_Getty\", \"score\": 0.9998416299380766, \"rank\": 0.000158393894173498, \"text\": \"Estelle\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Estelle_Getty\", \"dbpedia\": \"http://dbpedia.org/resource/Estelle_Getty\"}], \"noun_phrases\": [{\"ngram\": \"a nutrition and logistics expert\", \"from\": 1094, \"to\": 1126}, {\"ngram\": \"part\", \"from\": 1134, \"to\": 1138}, {\"ngram\": \"Guilloy's team\", \"from\": 1142, \"to\": 1156}, {\"ngram\": \"The Olympic Games\", \"from\": 1165, \"to\": 1182}, {\"ngram\": \"a no-brainer\", \"from\": 1187, \"to\": 1199}]}, {\"sentence\": \"\\\"I am extremely excited.\", \"from\": 1203, \"to\