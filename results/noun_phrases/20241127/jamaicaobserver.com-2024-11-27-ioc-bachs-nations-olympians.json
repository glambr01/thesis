"{\"uid\": \"jamaicaobserver.com-2024-11-27-ioc-bachs-nations-olympians\", \"noun_phrases\": [{\"sentence\": \"DESPITE many believing the country underperformed at the Paris Olympics last summer, International Olympic Committee (IOC) President Thomas Bach says Jamaica played a crucial role in the success of the Games.\", \"from\": 0, \"to\": 208, \"entities\": [{\"begin\": 150, \"end\": 157, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.9999999985357135, \"rank\": 1.3095649381397188e-09, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}], \"noun_phrases\": [{\"ngram\": \"the country\", \"from\": 23, \"to\": 34}, {\"ngram\": \"the Paris Olympics\", \"from\": 53, \"to\": 71}, {\"ngram\": \"IOC\", \"from\": 118, \"to\": 121}, {\"ngram\": \"a crucial role\", \"from\": 165, \"to\": 179}, {\"ngram\": \"the success\", \"from\": 183, \"to\": 194}, {\"ngram\": \"the Games\", \"from\": 198, \"to\": 207}]}, {\"sentence\": \"Fifty-eight Jamaicans competed in four sporting disciplines.\", \"from\": 210, \"to\": 270, \"entities\": [{\"begin\": 222, \"end\": 231, \"title\": \"http://dbpedia.org/resource/Jamaicans\", \"score\": 0.9999999999818101, \"rank\": 1.7767932418793417e-11, \"text\": \"Jamaicans\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Jamaicans\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaicans\"}], \"noun_phrases\": [{\"ngram\": \"four sporting disciplines\", \"from\": 244, \"to\": 269}]}, {\"sentence\": \"Jamaica ended with six medals, all from track and field, consisting of one gold, three silver and two bronze.\", \"from\": 271, \"to\": 380, \"entities\": [{\"begin\": 271, \"end\": 278, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.9999999985357135, \"rank\": 1.3095649381397188e-09, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}], \"noun_phrases\": [{\"ngram\": \"six medals\", \"from\": 290, \"to\": 300}, {\"ngram\": \"track\", \"from\": 311, \"to\": 316}, {\"ngram\": \"field\", \"from\": 321, \"to\": 326}, {\"ngram\": \"one gold\", \"from\": 342, \"to\": 350}, {\"ngram\": \"three silver\", \"from\": 352, \"to\": 364}, {\"ngram\": \"two bronze\", \"from\": 369, \"to\": 379}]}, {\"sentence\": \"There was a belief that Jamaica should have had a bigger medal haul due its prowess in athletics but Bach, who has served as president of the IOC since 2013, says he was impressed with Jamaica's performances.\", \"from\": 382, \"to\": 590, \"entities\": [{\"begin\": 406, \"end\": 413, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.9999999985357135, \"rank\": 1.3095649381397188e-09, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}, {\"begin\": 483, \"end\": 487, \"title\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"score\": 0.9999999948709046, \"rank\": 5.129114801549775e-09, \"text\": \"Bach\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"dbpedia\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\"}, {\"begin\": 524, \"end\": 527, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 9.721593554772191e-27, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 567, \"end\": 574, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.9999999985357135, \"rank\": 1.3095649381397188e-09, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}], \"noun_phrases\": [{\"ngram\": \"a belief\", \"from\": 392, \"to\": 400}, {\"ngram\": \"a bigger medal haul\", \"from\": 430, \"to\": 449}, {\"ngram\": \"its prowess\", \"from\": 454, \"to\": 465}, {\"ngram\": \"athletics\", \"from\": 469, \"to\": 478}, {\"ngram\": \"president\", \"from\": 507, \"to\": 516}]}, {\"sentence\": \"\\\"I want to express my heartfelt congratulations to all the Jamaican athletes who took part in the sensational Olympic Games, Paris 2024,\\\" he said.\", \"from\": 592, \"to\": 738, \"entities\": [{\"begin\": 651, \"end\": 659, \"title\": \"http://dbpedia.org/resource/Jamaicans\", \"score\": 0.9616892770155253, \"rank\": 0.03983690324909938, \"text\": \"Jamaican\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Jamaicans\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaicans\"}, {\"begin\": 717, \"end\": 727, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 0.9999999999940883, \"rank\": 5.9409605573887065e-12, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"my heartfelt congratulations\", \"from\": 611, \"to\": 639}, {\"ngram\": \"part\", \"from\": 678, \"to\": 682}, {\"ngram\": \"the sensational Olympic Games\", \"from\": 686, \"to\": 715}]}, {\"sentence\": \"\\\"Your amazing performances and your sporting success, especially the medallists, brought so much pride and joy to all the people of 'Jamrock'.\", \"from\": 740, \"to\": 882, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Your amazing performances\", \"from\": 741, \"to\": 766}, {\"ngram\": \"your sporting success\", \"from\": 771, \"to\": 792}, {\"ngram\": \"especially the medallists\", \"from\": 794, \"to\": 819}, {\"ngram\": \"so much pride\", \"from\": 829, \"to\": 842}, {\"ngram\": \"joy\", \"from\": 847, \"to\": 850}, {\"ngram\": \"all the people\", \"from\": 854, \"to\": 868}, {\"ngram\": \"Jamrock\", \"from\": 873, \"to\": 880}]}, {\"sentence\": \"Jamaica and your athletes contributed to the great success of the Olympic Games, Paris 2024.\\\"\", \"from\": 883, \"to\": 976, \"entities\": [{\"begin\": 883, \"end\": 890, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.9999999985357135, \"rank\": 1.3095649381397188e-09, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}], \"noun_phrases\": [{\"ngram\": \"your athletes\", \"from\": 895, \"to\": 908}, {\"ngram\": \"the great success\", \"from\": 924, \"to\": 941}, {\"ngram\": \"the Olympic Games\", \"from\": 945, \"to\": 962}]}, {\"sentence\": \"Bach was addressing stakeholders at the Jamaica Olympic Association's (JOA) celebration event for Jamaica's medallists recently.\", \"from\": 978, \"to\": 1106, \"entities\": [{\"begin\": 978, \"end\": 982, \"title\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"score\": 0.9999999948709046, \"rank\": 5.129114801549775e-09, \"text\": \"Bach\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"dbpedia\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\"}, {\"begin\": 1018, \"end\": 1045, \"title\": \"http://dbpedia.org/resource/Jamaica_Olympic_Association\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Jamaica Olympic Association\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Jamaica_Olympic_Association\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica_Olympic_Association\"}, {\"begin\": 1049, \"end\": 1052, \"title\": \"http://dbpedia.org/resource/Newspaper_Preservation_Act_of_1970\", \"score\": 0.9999999999993179, \"rank\": 0.0, \"text\": \"JOA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Newspaper_Preservation_Act_of_1970\", \"dbpedia\": \"http://dbpedia.org/resource/Newspaper_Preservation_Act_of_1970\"}, {\"begin\": 1076, \"end\": 1083, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.9999999985357135, \"rank\": 1.3095649381397188e-09, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}], \"noun_phrases\": [{\"ngram\": \"stakeholders\", \"from\": 998, \"to\": 1010}]}, {\"sentence\": \"He says the athletes' attitude throughout the Olympics was admirable and that it sent a powerful message worldwide.\", \"from\": 1108, \"to\": 1223, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the athletes' attitude\", \"from\": 1116, \"to\": 1138}, {\"ngram\": \"the Olympics\", \"from\": 1150, \"to\": 1162}, {\"ngram\": \"a powerful message\", \"from\": 1194, \"to\": 1212}]}, {\"sentence\": \"\\\"The Olympic Games are, first and foremost, about sport but you showed us that they are also about much more than sport,\\\" Bach said.\", \"from\": 1225, \"to\": 1357, \"entities\": [{\"begin\": 1347, \"end\": 1351, \"title\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"score\": 0.9999999948709046, \"rank\": 5.129114801549775e-09, \"text\": \"Bach\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"dbpedia\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\"}], \"noun_phrases\": [{\"ngram\": \"The Olympic Games\", \"from\": 1226, \"to\": 1243}, {\"ngram\": \"sport\", \"from\": 1275, \"to\": 1280}, {\"ngram\": \"us\", \"from\": 1296, \"to\": 1298}, {\"ngram\": \"sport\", \"from\": 1339, \"to\": 1344}]}, {\"sentence\": \"\\\"The Olympic Games are about togetherness, hope, solidarity, peace.\", \"from\": 1358, \"to\": 1425, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The Olympic Games\", \"from\": 1359, \"to\": 1376}, {\"ngram\": \"togetherness, hope, solidarity, peace\", \"from\": 1387, \"to\": 1424}]}, {\"sentence\": \"You, the Jamaican athletes, played an essential part in creating this culture of peace.\", \"from\": 1426, \"to\": 1513, \"entities\": [{\"begin\": 1435, \"end\": 1443, \"title\": \"http://dbpedia.org/resource/Jamaicans\", \"score\": 0.9616892770155253, \"rank\": 0.03983690324909938, \"text\": \"Jamaican\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Jamaicans\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaicans\"}], \"noun_phrases\": [{\"ngram\": \"an essential part\", \"from\": 1461, \"to\": 1478}, {\"ngram\": \"this culture\", \"from\": 1491, \"to\": 1503}, {\"ngram\": \"peace\", \"from\": 1507, \"to\": 1512}]}, {\"sentence\": \"\\\"This is why, as you celebrate your success in Paris, I would like to thank all Jamaican Olympians for showing us how our world would be if we all were to live in the same Olympic spirit of peaceful coexistence.\", \"from\": 1515, \"to\": 1726, \"entities\": [{\"begin\": 1562, \"end\": 1567, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999927442786, \"rank\": 7.255791470864619e-09, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 1595, \"end\": 1603, \"title\": \"http://dbpedia.org/resource/Jamaicans\", \"score\": 0.9616892770155253, \"rank\": 0.03983690324909938, \"text\": \"Jamaican\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Jamaicans\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaicans\"}], \"noun_phrases\": [{\"ngram\": \"your success\", \"from\": 1546, \"to\": 1558}, {\"ngram\": \"us\", \"from\": 1626, \"to\": 1628}, {\"ngram\": \"our world\", \"from\": 1633, \"to\": 1642}, {\"ngram\": \"the same Olympic spirit\", \"from\": 1678, \"to\": 1701}, {\"ngram\": \"peaceful coexistence\", \"from\": 1705, \"to\": 1725}]}, {\"sentence\": \"I call on you to please share this culture of peace with your communities, family, and friends.\", \"from\": 1727, \"to\": 1822, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this culture\", \"from\": 1757, \"to\": 1769}, {\"ngram\": \"peace\", \"from\": 1773, \"to\": 1778}, {\"ngram\": \"your communities\", \"from\": 1784, \"to\": 1800}, {\"ngram\": \"family\", \"from\": 1802, \"to\": 1808}, {\"ngram\": \"friends\", \"from\": 1814, \"to\": 1821}]}, {\"sentence\": \"This way, even if the Olympic Games come to an end we can continue to live this culture of peace every single day.\\\"\", \"from\": 1823, \"to\": 1938, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the Olympic Games\", \"from\": 1841, \"to\": 1858}, {\"ngram\": \"an end\", \"from\": 1867, \"to\": 1873}, {\"ngram\": \"this culture\", \"from\": 1898, \"to\": 1910}, {\"ngram\": \"peace\", \"from\": 1914, \"to\": 1919}]}, {\"sentence\": \"JOA President Christopher Samuda praised Bach's tenure as IOC president, as he is set to demit office next year.\", \"from\": 1940, \"to\": 2052, \"entities\": [{\"begin\": 1940, \"end\": 1943, \"title\": \"http://dbpedia.org/resource/Newspaper_Preservation_Act_of_1970\", \"score\": 0.9999999999993179, \"rank\": 0.0, \"text\": \"JOA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Newspaper_Preservation_Act_of_1970\", \"dbpedia\": \"http://dbpedia.org/resource/Newspaper_Preservation_Act_of_1970\"}, {\"begin\": 1981, \"end\": 1985, \"title\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"score\": 0.9999999948709046, \"rank\": 5.129114801549775e-09, \"text\": \"Bach\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"dbpedia\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\"}, {\"begin\": 1998, \"end\": 2001, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 9.721593554772191e-27, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/Internationa