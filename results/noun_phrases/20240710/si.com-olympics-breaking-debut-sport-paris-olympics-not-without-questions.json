"ngram\": \"an outlet\", \"from\": 5141, \"to\": 5150}, {\"ngram\": \"his ample energy\", \"from\": 5155, \"to\": 5171}, {\"ngram\": \"anime\", \"from\": 5194, \"to\": 5199}, {\"ngram\": \"a lot\", \"from\": 5212, \"to\": 5217}, {\"ngram\": \"my friends\", \"from\": 5221, \"to\": 5231}]}, {\"sentence\": \"\\u00e2\\u0080\\u009cSo we would make up characters and play at recess.\", \"from\": 5246, \"to\": 5299, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"characters\", \"from\": 5269, \"to\": 5279}, {\"ngram\": \"recess\", \"from\": 5292, \"to\": 5298}]}, {\"sentence\": \"And I did the same at home.\", \"from\": 5300, \"to\": 5327, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"home\", \"from\": 5322, \"to\": 5326}]}, {\"sentence\": \"My parents remember me running around in my underwear at home, pretending to be Goku or Spider-Man.\\u00e2\\u0080\\u009d By the time he was in ninth grade, his classmates had dubbed him B-Boy Kimchi.\", \"from\": 5328, \"to\": 5510, \"entities\": [{\"begin\": 5408, \"end\": 5412, \"title\": \"http://dbpedia.org/resource/Goku\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Goku\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Goku\", \"dbpedia\": \"http://dbpedia.org/resource/Goku\"}], \"noun_phrases\": [{\"ngram\": \"My parents\", \"from\": 5328, \"to\": 5338}, {\"ngram\": \"my underwear\", \"from\": 5369, \"to\": 5381}, {\"ngram\": \"home\", \"from\": 5385, \"to\": 5389}, {\"ngram\": \"Spider-Man.\\u00e2\\u0080\\u009d\", \"from\": 5416, \"to\": 5430}, {\"ngram\": \"the time\", \"from\": 5434, \"to\": 5442}, {\"ngram\": \"ninth grade\", \"from\": 5453, \"to\": 5464}, {\"ngram\": \"his classmates\", \"from\": 5466, \"to\": 5480}, {\"ngram\": \"B-Boy Kimchi\", \"from\": 5496, \"to\": 5508}]}, {\"sentence\": \"(He\\u00e2\\u0080\\u0099s since adopted a new moniker: Phil Wizard, the surname coming from a crew he used to be a part of.)\", \"from\": 5511, \"to\": 5617, \"entities\": [], \"noun_phrases\"