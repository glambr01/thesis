act\", \"from\": 2180, \"to\": 2188}, {\"ngram\": \"hundreds of millions\", \"from\": 2194, \"to\": 2214}, {\"ngram\": \"viewers\", \"from\": 2218, \"to\": 2225}, {\"ngram\": \"the world\", \"from\": 2240, \"to\": 2249}, {\"ngram\": \"this terrible scene\", \"from\": 2300, \"to\": 2319}, {\"ngram\": \"something\", \"from\": 2328, \"to\": 2337}]}, {\"sentence\": \"\\\"I do not want to argue with anyone today, but I only choose to protest through my gesture against a blatant injustice.\\\"\", \"from\": 2359, \"to\": 2479, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"anyone\", \"from\": 2388, \"to\": 2394}, {\"ngram\": \"my gesture\", \"from\": 2439, \"to\": 2449}, {\"ngram\": \"a blatant injustice\", \"from\": 2458, \"to\": 2477}]}, {\"sentence\": \"The Prime Minister announced he would grant Barbosu the Romanian bronze medal prize bonus of \\u20ac21,000 (AU$35,000) even though she officially came fourth.\", \"from\": 2481, \"to\": 2633, \"entities\": [{\"begin\": 2537, \"end\": 2545, \"title\": \"http://dbpedia.org/resource/Romanian_language\", \"score\": 0.9984295876360267, \"rank\": 0.0015517829172125566, \"text\": \"Romanian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Romanian_language\", \"dbpedia\": \"http://dbpedia.org/resource/Romanian_language\"}], \"noun_phrases\": [{\"ngram\": \"The Prime Minister\", \"from\": 2481, \"to\": 2499}, {\"ngram\": \"Barbosu\", \"from\": 2525, \"to\": 2532}, {\"ngram\": \"(AU$35,000\", \"from\": 2582, \"to\": 2592}]}, {\"sentence\": \"Barbosu has since posted on Instagram that her Olympic experience had been \\\"a dream come true\\\".\", \"from\": 2635, \"to\": 2730, \"entities\": [{\"begin\": 2663, \"end\": 2672, \"title\": \"http://dbpedia.org/resource/Instagram\", \"score\": 1.0, \"rank\": 1.1689688704796883e-19, \"text\": \"Instagram\", \"types\": [\"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Instagram\", \"dbpedia\": \"http://dbpedia.org/resource/Instagram\"}], \"noun_phrases\": [{\"