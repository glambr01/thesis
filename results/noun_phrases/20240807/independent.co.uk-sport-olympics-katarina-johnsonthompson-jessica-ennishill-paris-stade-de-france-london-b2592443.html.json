ities\": [], \"noun_phrases\": [{\"ngram\": \"the TV cameras\", \"from\": 2676, \"to\": 2690}, {\"ngram\": \"everyone\", \"from\": 2695, \"to\": 2703}, {\"ngram\": \"home\", \"from\": 2716, \"to\": 2720}]}, {\"sentence\": \"If I'd thought about that my head would have completely gone.\", \"from\": 2722, \"to\": 2783, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my head\", \"from\": 2748, \"to\": 2755}]}, {\"sentence\": \"\\\"It was just about keeping my mind focused on the things I could control.\\\"\", \"from\": 2785, \"to\": 2859, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my mind\", \"from\": 2812, \"to\": 2819}, {\"ngram\": \"the things\", \"from\": 2831, \"to\": 2841}]}, {\"sentence\": \"Ennis-Hill believes the proximity of Paris to the UK could work in Johnson-Thompson's favour to winning that elusive Olympic gold.\", \"from\": 2861, \"to\": 2991, \"entities\": [{\"begin\": 2898, \"end\": 2903, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999642288919, \"rank\": 3.5771086717768166e-08, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 2911, \"end\": 2913, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9898661769151662, \"rank\": 0.009879800441989915, \"text\": \"UK\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"Ennis-Hill\", \"from\": 2861, \"to\": 2871}, {\"ngram\": \"the proximity\", \"from\": 2881, \"to\": 2894}, {\"ngram\": \"Johnson-Thompson's favour\", \"from\": 2928, \"to\": 2953}, {\"ngram\": \"that elusive Olympic gold\", \"from\": 2965, \"to\": 2990}]}, {\"sentence\": \"She said: \\\"I think it helps, not having the need to adapt to different time zones and travelling so much.\", \"from\": 2993, \"to\": 3098, \"entities\": [], \"noun_phrases\": [{\