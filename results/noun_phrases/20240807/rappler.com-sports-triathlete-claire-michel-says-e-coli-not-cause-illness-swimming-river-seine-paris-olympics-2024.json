om\": 1284, \"to\": 1312}]}, {\"sentence\": \"\\\"After the daily situation meeting this morning between Ville de Paris, Paris 2024 and World Aquatics, it has been decided that the familiarization session to take place today, 6 August 2024, is cancelled,\\\" World Aquatics said in a statement.\", \"from\": 1320, \"to\": 1562, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Ville de Paris\", \"from\": 1376, \"to\": 1390}, {\"ngram\": \"the familiarization session\", \"from\": 1448, \"to\": 1475}, {\"ngram\": \"place\", \"from\": 1484, \"to\": 1489}, {\"ngram\": \"World Aquatics\", \"from\": 1527, \"to\": 1541}, {\"ngram\": \"a statement\", \"from\": 1550, \"to\": 1561}]}, {\"sentence\": \"While the E. Coli bacteria levels were within the acceptable threshold, the levels of another bacteria, Enterococci, were not.\", \"from\": 1564, \"to\": 1690, \"entities\": [{\"begin\": 1668, \"end\": 1679, \"title\": \"http://dbpedia.org/resource/Enterococcus\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Enterococci\", \"types\": [\"Q12136\"], \"wikid\": \"http://dbpedia.org/resource/Enterococcus\", \"dbpedia\": \"http://dbpedia.org/resource/Enterococcus\"}], \"noun_phrases\": [{\"ngram\": \"the E. Coli bacteria levels\", \"from\": 1570, \"to\": 1597}, {\"ngram\": \"the acceptable threshold\", \"from\": 1610, \"to\": 1634}, {\"ngram\": \"the levels\", \"from\": 1636, \"to\": 1646}, {\"ngram\": \"another bacteria\", \"from\": 1650, \"to\": 1666}]}, {\"sentence\": \"\\\"The water quality review showed E. coli levels ranged from 326 to 517 (considered \\\"very good\\\" to \\\"good\\\") at the four collection points taken on 5 August between 5:00 and 6:00 a.m.,\\\" World Aquatics added.\", \"from\": 1692, \"to\": 1896, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The water quality review\", \"from\": 1693, \"to\": 1717}, {\"ngram\": \"E. coli levels\", \"from\": 1725, \"to\": 1739}, {\"ngram\": \"the four collection points\", \"from\": 1801, \"to\": 1827}, {\"ngram\": \"5 Aug