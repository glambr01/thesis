 \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The plea\", \"from\": 217, \"to\": 225}, {\"ngram\": \"top\", \"from\": 235, \"to\": 238}, {\"ngram\": \"criticism\", \"from\": 242, \"to\": 251}, {\"ngram\": \"the amount\", \"from\": 257, \"to\": 267}, {\"ngram\": \"plastic bottles\", \"from\": 271, \"to\": 286}, {\"ngram\": \"fans\", \"from\": 301, \"to\": 305}, {\"ngram\": \"the Paris Games\", \"from\": 309, \"to\": 324}]}, {\"sentence\": \"Events in the French capital have been lined with advertising for the ubiquitous fizzy drinks of Coca-Cola, which has been sponsoring the Olympics since 1928.\", \"from\": 327, \"to\": 485, \"entities\": [{\"begin\": 341, \"end\": 347, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.5647411205489578, \"rank\": 0.767038573896441, \"text\": \"French\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 424, \"end\": 433, \"title\": \"http://dbpedia.org/resource/Coca-Cola\", \"score\": 0.999996060992571, \"rank\": 3.939022948203295e-06, \"text\": \"Coca-Cola\", \"types\": [\"Q2095\"], \"wikid\": \"http://dbpedia.org/resource/Coca-Cola\", \"dbpedia\": \"http://dbpedia.org/resource/Coca-Cola\"}], \"noun_phrases\": [{\"ngram\": \"Events\", \"from\": 327, \"to\": 333}, {\"ngram\": \"advertising\", \"from\": 377, \"to\": 388}, {\"ngram\": \"the ubiquitous fizzy drinks\", \"from\": 393, \"to\": 420}, {\"ngram\": \"the Olympics\", \"from\": 461, \"to\": 473}]}, {\"sentence\": \"But these sugary drinks \\\"offer little or no nutritional value\\\" and promoting such unhealthy products has no place in sport, according to Trish Cotter and Sandra Mullin of global health group Vital Strategies.\", \"from\": 487, \"to\": 695, \"entities\": [{\"begin\": 624, \"end\": 629, \"title\": \"http://dbpedia.org/resource/Trish_Stratus\", \"score\": 0.9999518635026037, \"rank\": 3.651884839687914e-05, \"text\": \"Trish\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q13474373\"], \"wikid\": \"http://dbpedia.org/resource/Trish_Stratus\", \"dbpedia\": \"http://dbpedia.org/resource/Trish_Stratus\"}, {\"begin\": 641, \"end\": 647, \"title\": \"http://dbpedia.org/resource/Sandra_Reemer\", \"score\": 0.9998462458290756, \"rank\": 0.00013257284052450296, \"text\": \"Sandra\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Sandra_Reemer\", \"dbpedia\": \"http://dbpedia.org/resource/Sandra_Reemer\"}], \"noun_phrases\": [{\"ngram\": \"these sugary drinks\", \"from\": 491, \"to\": 510}, {\"ngram\": \"little or no nutritional value\", \"from\": 518, \"to\": 548}, {\"ngram\": \"such unhealthy products\", \"from\": 564, \"to\": 587}, {\"ngram\": \"no place\", \"from\": 592, \"to\": 600}, {\"ngram\": \"sport\", \"from\": 604, \"to\": 609}, {\"ngram\": \"global health group Vital Strategies\", \"from\": 658, \"to\": 694}]}, {\"sentence\": \"Sugary drinks are a \\\"key driver\\\" of a range of serious health problems affecting people across the world, including obesity, diabetes, high blood pressure and heart disease, the pair wrote in a commentary in the journal BMJ Global Health.\", \"from\": 697, \"to\": 935, \"entities\": [{\"begin\": 917, \"end\": 920, \"title\": \"http://dbpedia.org/resource/The_BMJ\", \"score\": 1.0, \"rank\": 4.885782884587844e-44, \"text\": \"BMJ\", \"types\": [\"Q737498\", \"Q386724\", \"Q234460\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_BMJ\", \"dbpedia\": \"http://dbpedia.org/resource/The_BMJ\"}], \"noun_phrases\": [{\"ngram\": \"Sugary drinks\", \"from\": 697, \"to\": 710}, {\"ngram\": \"a \\\"key driver\", \"from\": 715, \"to\": 728}, {\"ngram\": \"a range\", \"from\": 733, \"to\": 740}, {\"ngram\": \"serious health problems\", \"from\": 744, \"to\": 767}, {\"ngram\": \"people\", \"from\": 778, \"to\": 784}, {\"ngram\": \"the world\", \"from\": 792, \"to\": 801}, {\"ngram\": \"obesity\", \"from\": 813, \"to\": 820}, {\"ngram\": \"diabetes\", \"from\": 822, \"to\": 830}, {\"ngram\": \"high blood pressure\", \"from\": 832, \"to\": 851}, {\"ngram\": \"heart disease\", \"from\": 856, \"to\": 869}, {\"ngram\": \"the pair\", \"from\": 871, \"to\": 879}, {\"ngram\": \"a commentary\", \"from\": 889, \"to\": 901}, {\"ngram\": \"the journal\", \"from\": 905, \"to\": 916}]}, {\"sentence\": \"Coca-Cola's products also contribute to global plastic pollution, greenhouse gas emissions and use up a huge amount of water, they added.\", \"from\": 937, \"to\": 1074, \"entities\": [{\"begin\": 937, \"end\": 946, \"title\": \"http://dbpedia.org/resource/Coca-Cola\", \"score\": 0.999996060992571, \"rank\": 3.939022948203295e-06, \"text\": \"Coca-Cola\", \"types\": [\"Q2095\"], \"wikid\": \"http://dbpedia.org/resource/Coca-Cola\", \"dbpedia\": \"http://dbpedia.org/resource/Coca-Cola\"}], \"noun_phrases\": [{\"ngram\": \"global plastic pollution\", \"from\": 977, \"to\": 1001}, {\"ngram\": \"greenhouse gas emissions\", \"from\": 1003, \"to\": 1027}, {\"ngram\": \"a huge amount\", \"from\": 1039, \"to\": 1052}, {\"ngram\": \"water\", \"from\": 1056, \"to\": 1061}]}, {\"sentence\": \"\\\"By continuing its association with Coca-Cola, the Olympic movement risks being complicit in intensifying a global epidemic of poor nutrition, environmental degradation and climate change,\\\" the authors wrote.\", \"from\": 1076, \"to\": 1284, \"entities\": [{\"begin\": 1112, \"end\": 1121, \"title\": \"http://dbpedia.org/resource/Coca-Cola\", \"score\": 0.999996060992571, \"rank\": 3.939022948203295e-06, \"text\": \"Coca-Cola\", \"types\": [\"Q2095\"], \"wikid\": \"http://dbpedia.org/resource/Coca-Cola\", \"dbpedia\": \"http://dbpedia.org/resource/Coca-Cola\"}], \"noun_phrases\": [{\"ngram\": \"its association\", \"from\": 1091, \"to\": 1106}, {\"ngram\": \"the Olympic movement risks\", \"from\": 1123, \"to\": 1149}, {\"ngram\": \"a global epidemic\", \"from\": 1182, \"to\": 1199}, {\"ngram\": \"poor nutrition\", \"from\": 1203, \"to\": 1217}, {\"ngram\": \"environmental degradation\", \"from\": 1219, \"to\": 1244}, {\"ngram\": \"climate change\", \"from\": 1249, \"to\": 1263}, {\"ngram\": \"the authors\", \"from\": 1266, \"to\": 1277}]}, {\"sentence\": \"\\\"It's time for the International Olympic Committee (IOC) to cut ties with Coca-Cola in the interest of athletes, spectators and the planet.\\\"\", \"from\": 1286, \"to\": 1426, \"entities\": [{\"begin\": 1305, \"end\": 1342, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee (IOC)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 1360, \"end\": 1369, \"title\": \"http://dbpedia.org/resource/Coca-Cola\", \"score\": 0.999996060992571, \"rank\": 3.939022948203295e-06, \"text\": \"Coca-Cola\", \"types\": [\"Q2095\"], \"wikid\": \"http://dbpedia.org/resource/Coca-Cola\", \"dbpedia\": \"http://dbpedia.org/resource/Coca-Cola\"}], \"noun_phrases\": [{\"ngram\": \"time\", \"from\": 1292, \"to\": 1296}, {\"ngram\": \"ties\", \"from\": 1350, \"to\": 1354}, {\"ngram\": \"the interest\", \"from\": 1373, \"to\": 1385}, {\"ngram\": \"athletes\", \"from\": 1389, \"to\": 1397}, {\"ngram\": \"spectators\", \"from\": 1399, \"to\": 1409}, {\"ngram\": \"the planet\", \"from\": 1414, \"to\": 1424}]}, {\"sentence\": \"Coca-Cola did not respond to a request for comment.\", \"from\": 1428, \"to\": 1479, \"entities\": [{\"begin\": 1428, \"end\": 1437, \"title\": \"http://dbpedia.org/resource/Coca-Cola\", \"score\": 0.999996060992571, \"rank\": 3.939022948203295e-06, \"text\": \"Coca-Cola\", \"types\": [\"Q2095\"], \"wikid\": \"http://dbpedia.org/resource/Coca-Cola\", \"dbpedia\": \"http://dbpedia.org/resource/Coca-Cola\"}], \"noun_phrases\": [{\"ngram\": \"a request\", \"from\": 1457, \"to\": 1466}, {\"ngram\": \"comment\", \"from\": 1471, \"to\": 1478}]}, {\"sentence\": \"The IOC defended its partnership with the soft drink company, noting that it also offers sugar-free options, including water, tea and coffee.\", \"from\": 1481, \"to\": 1622, \"entities\": [{\"begin\": 1485, \"end\": 1488, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 0.999999999998181, \"rank\": 1.8866004205512893e-12, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"its partnership\", \"from\": 1498, \"to\": 1513}, {\"ngram\": \"the soft drink company\", \"from\": 1519, \"to\": 1541}, {\"ngram\": \"sugar-free options\", \"from\": 1570, \"to\": 1588}, {\"ngram\": \"water\", \"from\": 1600, \"to\": 1605}, {\"ngram\": \"tea\", \"from\": 1607, \"to\": 1610}, {\"ngram\": \"coffee\", \"from\": 1615, \"to\": 1621}]}, {\"sentence\": \"\\\"We are incredibly proud of almost 100 years of partnership with the Coca-Cola company,\\\" Anne-Sophie Voumard, the IOC's television and marketing services managing director, said at a daily press conference.\", \"from\": 1624, \"to\": 1830, \"entities\": [{\"begin\": 1693, \"end\": 1702, \"title\": \"http://dbpedia.org/resource/Coca-Cola\", \"score\": 0.999996060992571, \"rank\": 3.939022948203295e-06, \"text\": \"Coca-Cola\", \"types\": [\"Q2095\"], \"wikid\": \"http://dbpedia.org/resource/Coca-Cola\", \"dbpedia\": \"http://dbpedia.org/resource/Coca-Cola\"}, {\"begin\": 1738, \"end\": 1741, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 0.999999999998181, \"rank\": 1.8866004205512893e-12, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/Inter