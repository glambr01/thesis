"{\"uid\": \"metro.co.uk-2024-08-07-a-motorbike-track-cycling-olympics-21378299\", \"noun_phrases\": [{\"sentence\": \"The track cycling is taking centre stage at theParis2024Olympicsat the Saint-Quentin-en-Yvelines velodrome.\", \"from\": 0, \"to\": 107, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The track cycling\", \"from\": 0, \"to\": 17}, {\"ngram\": \"centre stage\", \"from\": 28, \"to\": 40}, {\"ngram\": \"-Yvelines\", \"from\": 87, \"to\": 96}]}, {\"sentence\": \"And fans tuning into the action at home will have noticed a motorbike, called the derny, lapping around the track in the keirin,one of the blue ribband eventsin the Olympic cycling schedule.\", \"from\": 109, \"to\": 299, \"entities\": [{\"begin\": 230, \"end\": 236, \"title\": \"http://dbpedia.org/resource/Keirin\", \"score\": 1.0, \"rank\": 4.605985552425301e-49, \"text\": \"keirin\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Keirin\", \"dbpedia\": \"http://dbpedia.org/resource/Keirin\"}], \"noun_phrases\": [{\"ngram\": \"fans\", \"from\": 113, \"to\": 117}, {\"ngram\": \"the action\", \"from\": 130, \"to\": 140}, {\"ngram\": \"home\", \"from\": 144, \"to\": 148}, {\"ngram\": \"a motorbike\", \"from\": 167, \"to\": 178}, {\"ngram\": \"the derny\", \"from\": 187, \"to\": 196}, {\"ngram\": \"the track\", \"from\": 213, \"to\": 222}, {\"ngram\": \"the blue ribband\", \"from\": 244, \"to\": 260}, {\"ngram\": \"the Olympic cycling schedule\", \"from\": 270, \"to\": 298}]}, {\"sentence\": \"But what exactly is the derny and what role does it play at the start of races?\", \"from\": 301, \"to\": 380, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the derny\", \"from\": 321, \"to\": 330}, {\"ngram\": \"what role\", \"from\": 335, \"to\": 344}, {\"ngram\": \"the start\", \"from\": 361, \"to\": 370}, {\"ngram\": \"races\", \"from\": 374, \"to\": 379}]}, {\"sentence\": \"Follow Metro.co.uk's live blog for updates from the Paris 2024 games Here is everything you need to know.\", \"from\": 382, \"to\": 488, \"entities\": [{\"begin\": 434, \"end\": 444, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 2.5080955839776866e-15, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"Follow Metro.co.uk's live blog\", \"from\": 382, \"to\": 412}, {\"ngram\": \"updates\", \"from\": 417, \"to\": 424}, {\"ngram\": \"everything\", \"from\": 459, \"to\": 469}]}, {\"sentence\": \"The derny, which is electric, is used as a pacer.\", \"from\": 490, \"to\": 539, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The derny\", \"from\": 490, \"to\": 499}, {\"ngram\": \"a pacer\", \"from\": 531, \"to\": 538}]}, {\"sentence\": \"The derny is used to bring riders up to a speed of 50 km per hour before the official start of the keirin race.\", \"from\": 541, \"to\": 652, \"entities\": [{\"begin\": 640, \"end\": 646, \"title\": \"http://dbpedia.org/resource/Keirin\", \"score\": 1.0, \"rank\": 4.605985552425301e-49, \"text\": \"keirin\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Keirin\", \"dbpedia\": \"http://dbpedia.org/resource/Keirin\"}], \"noun_phrases\": [{\"ngram\": \"The derny\", \"from\": 541, \"to\": 550}, {\"ngram\": \"riders\", \"from\": 568, \"to\": 574}, {\"ngram\": \"a speed\", \"from\": 581, \"to\": 588}, {\"ngram\": \"50 km\", \"from\": 592, \"to\": 597}, {\"ngram\": \"hour\", \"from\": 602, \"to\": 606}, {\"ngram\": \"the official start\", \"from\": 614, \"to\": 632}]}, {\"sentence\": \"The derny bike completes three laps of the velodrome before leaving the track, at which point the race gets officially underway, with a three lap shootout to determine the winner of the race.\", \"from\": 654, \"to\": 845, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The derny bike\", \"from\": 654, \"to\": 668}, {\"ngram\": \"three laps\", \"fro