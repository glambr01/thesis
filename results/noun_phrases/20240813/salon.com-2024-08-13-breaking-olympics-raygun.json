"{\"uid\": \"salon.com-2024-08-13-breaking-olympics-raygun\", \"noun_phrases\": [{\"sentence\": \"Eddie the Eagle.\", \"from\": 0, \"to\": 16, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Eddie\", \"from\": 0, \"to\": 5}, {\"ngram\": \"the Eagle\", \"from\": 6, \"to\": 15}]}, {\"sentence\": \"The Jamaican bobsledding team.\", \"from\": 17, \"to\": 47, \"entities\": [{\"begin\": 21, \"end\": 29, \"title\": \"http://dbpedia.org/resource/Jamaicans\", \"score\": 0.9999768507355951, \"rank\": 2.3149777979607966e-05, \"text\": \"Jamaican\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Jamaicans\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaicans\"}], \"noun_phrases\": []}, {\"sentence\": \"Great underdog stories are part of the Olympics\\u00e2\\u0080\\u0099 fabric, giving TV audiences supplemental heroes to cheer on.\", \"from\": 48, \"to\": 159, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Great underdog stories\", \"from\": 48, \"to\": 70}, {\"ngram\": \"part\", \"from\": 75, \"to\": 79}, {\"ngram\": \"the Olympics\\u00e2\\u0080\\u0099 fabric\", \"from\": 83, \"to\": 105}, {\"ngram\": \"TV audiences\", \"from\": 114, \"to\": 126}, {\"ngram\": \"supplemental heroes\", \"from\": 127, \"to\": 146}]}, {\"sentence\": \"The most famous of these contenders have the hearts of champions if not the skills \\u00e2\\u0080\\u0094 although some, like the 1980 U.S. men\\u00e2\\u0080\\u0099s ice hockey team, which was mainly comprised of amateurs,make history by pulling off miracles.\", \"from\": 160, \"to\": 382, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"these contenders\", \"from\": 179, \"to\": 195}, {\"ngram\": \"the hearts\", \"from\": 201, \"to\": 211}, {\"ngram\": \"champions\", \"from\": 215, \"to\": 224}, {\"ngram\": \"the 1980 U.S. men\\u00e2\\u0080\\u0099s ice hockey team\", \"from\": 267, \"to\": 304}, {\"ngram\": \"amateurs\", \"from\": 336, \"to\": 344}, {\"ngram\": \"history\", \"from\": 350, \"to\": 357}, {\"ngram\": \"miracles\", \"from\": 373, \"to\": 381}]}, {\"sentence\": \"Rachael Gunn\\u00c2 was never going to do that.\", \"from\": 384, \"to\": 425, \"entities\": [{\"begin\": 384, \"end\": 391, \"title\": \"http://dbpedia.org/resource/Rachael_Ray\", \"score\": 1.0, \"rank\": 1.954685108182224e-18, \"text\": \"Rachael\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Rachael_Ray\", \"dbpedia\": \"http://dbpedia.org/resource/Rachael_Ray\"}], \"noun_phrases\": []}, {\"sentence\": \"The 36-year-old college professor said as much after she was eliminated from the Paris Games\\u00e2\\u0080\\u0099 breaking competition that left viewers alternately befuddled, delighted and enraged due to its confident awkwardness.\", \"from\": 426, \"to\": 639, \"entities\": [{\"begin\": 507, \"end\": 512, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.2126414565155273e-19, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"The 36-year-old college professor\", \"from\": 426, \"to\": 459}, {\"ngram\": \"viewers\", \"from\": 553, \"to\": 560}, {\"ngram\": \"its confident awkwardness\", \"from\": 613, \"to\": 638}]}, {\"sentence\": \"Gunn, who represented Australia in the b-girls competition under the moniker Raygun, was knocked out in the round-robin competition without scoring a single point.Worse, she was totally fine with that.\", \"from\": 641, \"to\": 842, \"entities\": [{\"begin\": 641, \"end\": 645, \"title\": \"http://dbpedia.org/resource/Clan_Gunn\", \"score\": 0.9450606859663546, \"rank\": 0.04667837041860824, \"text\": \"Gunn\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Clan_Gunn\", \"dbpedia\": \"http://dbpedia.org/resource/Clan_Gunn\"}, {\"begin\": 663, \"end\": 672, \"title\": \"http://dbpedia.org/resource/Australia\", \"score\": 0.9999999932824721, \"rank\": 6.711898052801648e-09, \"text\": \"Australia\", \"