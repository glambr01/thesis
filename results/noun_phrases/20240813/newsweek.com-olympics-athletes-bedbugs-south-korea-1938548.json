"{\"uid\": \"newsweek.com-olympics-athletes-bedbugs-south-korea-1938548\", \"noun_phrases\": [{\"sentence\": \"Published Aug 13, 2024 at 10:01 AM EDT updated Aug 13, 2024 at 11:32 AM EDT News Reporter South Korea has placed a bedbug sniffer dog at its main international airport to try to prevent the insects entering the country from the ParisOlympics.\", \"from\": 0, \"to\": 247, \"entities\": [{\"begin\": 95, \"end\": 106, \"title\": \"http://dbpedia.org/resource/South_Korea\", \"score\": 0.9998201954111354, \"rank\": 0.00017983692198507295, \"text\": \"South Korea\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/South_Korea\", \"dbpedia\": \"http://dbpedia.org/resource/South_Korea\"}], \"noun_phrases\": [{\"ngram\": \"Aug\", \"from\": 10, \"to\": 13}, {\"ngram\": \"10:01 AM\", \"from\": 26, \"to\": 34}, {\"ngram\": \"EDT\", \"from\": 35, \"to\": 38}, {\"ngram\": \"a bedbug sniffer dog\", \"from\": 113, \"to\": 133}, {\"ngram\": \"its main international airport\", \"from\": 137, \"to\": 167}, {\"ngram\": \"the insects\", \"from\": 186, \"to\": 197}, {\"ngram\": \"the country\", \"from\": 207, \"to\": 218}, {\"ngram\": \"the ParisOlympics\", \"from\": 224, \"to\": 241}]}, {\"sentence\": \"Ceco, a two-year-old beagle, is leading the bedbug detection efforts at the Incheon International Airport in Seoul.\", \"from\": 249, \"to\": 364, \"entities\": [{\"begin\": 325, \"end\": 354, \"title\": \"http://dbpedia.org/resource/Incheon_International_Airport\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Incheon International Airport\", \"types\": [\"Q1248784\"], \"wikid\": \"http://dbpedia.org/resource/Incheon_International_Airport\", \"dbpedia\": \"http://dbpedia.org/resource/Incheon_International_Airport\"}, {\"begin\": 358, \"end\": 363, \"title\": \"http://dbpedia.org/resource/Incheon_International_Airport\", \"score\": 0.792887666812136, \"rank\": 0.2578122593351744, \"text\": \"Seoul\", \"types\": [\"Q1248784\"], \"wikid\": \"http://dbpedia.org/resource/Incheon_International_Airport\", \"dbpedia\": \"http://dbpedia.org/resource/Incheon_International_Airport\"}], \"noun_phrases\": [{\"ngram\": \"Ceco\", \"from\": 249, \"to\": 253}, {\"ngram\": \"a two-year-old beagle\", \"from\": 255, \"to\": 276}, {\"ngram\": \"the bedbug detection efforts\", \"from\": 289, \"to\": 317}]}, {\"sentence\": \"Pest control company Cesco trained the dog to sniff out pheromones, the chemicals released by bedbugs, according to the Korea Post.\", \"from\": 366, \"to\": 497, \"entities\": [{\"begin\": 486, \"end\": 496, \"title\": \"http://dbpedia.org/resource/Korea_Post\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Korea Post\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Korea_Post\", \"dbpedia\": \"http://dbpedia.org/resource/Korea_Post\"}], \"noun_phrases\": [{\"ngram\": \"Pest control company Cesco\", \"from\": 366, \"to\": 392}, {\"ngram\": \"the dog\", \"from\": 401, \"to\": 408}, {\"ngram\": \"pheromones\", \"from\": 422, \"to\": 432}, {\"ngram\": \"the chemicals\", \"from\": 434, \"to\": 447}, {\"ngram\": \"bedbugs\", \"from\": 460, \"to\": 467}]}, {\"sentence\": \"The company said that Ceco has an accuracy of at least 95 percent in detecting bedbugs.\", \"from\": 499, \"to\": 586, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The company\", \"from\": 499, \"to\": 510}, {\"ngram\": \"Ceco\", \"from\": 521, \"to\": 525}, {\"ngram\": \"an accuracy\", \"from\": 530, \"to\": 541}, {\"ngram\": \"at least 95 percent\", \"from\": 545, \"to\": 564}, {\"ngram\": \"bedbugs\", \"from\": 578, \"to\": 585}]}, {\"sentence\": \"\\\"Ceco can detect bedbugs far more faster than the human eye, identifying every stage of bedbug life, from eggs to adults, within just 1 to 2 minutes per room-a significant advantage for the hospitality industry,\\\" the company said, per the Korea Post.\", \"from\": 588, \"to\": 838, \"entities\": [{\"begin\": 827, \"end\": 837, \"title\": \"http://dbpedia.org/resource/Korea_Post\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Korea Post\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Korea_Post\", \"dbpedia\": \"http://dbpedia.org/resource/Korea_Post\"}], \"noun_phrases\": [{\"ngram\": \"Ceco\", \"from\": 589, \"to\": 593}, {\"ngram\": \"bedbugs\", \"from\": 605, \"to\": 612}, {\"ngram\": \"the human eye\", \"from\": 634, \"to\": 647}, {\"ngram\": \"every stage\", \"from\": 661, \"to\": 672}, {\"ngram\": \"bedbug life\", \"from\": 676, \"to\": 687}, {\"ngram\": \"eggs\", \"from\": 694, \"to\": 698}, {\"ngram\": \"adults\", \"from\": 702, \"to\": 708}, {\"ngram\": \"just 1 to 2 minutes\", \"from\": 717, \"to\": 736}, {\"ngram\": \"room\", \"from\": 741, \"to\": 745}, {\"ngram\": \"a significant advantage\", \"from\": 746, \"to\": 769}, {\"ngram\": \"the hospitality industry\", \"from\": 774, \"to\": 798}, {\"ngram\": \"the company\", \"from\": 801, \"to\": 812}]}, {\"sentence\": \"The Korea Disease Control and Prevention Agency said the dog had been deployed at an airport booth, along with a human bedbug control expert, which will remain active until September 8.\", \"from\": 840, \"to\": 1025, \"entities\": [{\"begin\": 844, \"end\": 849, \"title\": \"http://dbpedia.org/resource/South_Korea\", \"score\": 0.9999158869125011, \"rank\": 7.219429352952193e-05, \"text\": \"Korea\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/South_Korea\", \"dbpedia\": \"http://dbpedia.org/resource/South_Korea\"}], \"noun_phrases\": [{\"ngram\": \"the dog\", \"from\": 893, \"to\": 900}, {\"ngram\": \"an airport booth\", \"from\": 922, \"to\": 938}, {\"ngram\": \"a human bedbug control expert\", \"from\": 951, \"to\": 980}, {\"ngram\": \"September\", \"from\": 1013, \"to\": 1022}]}, {\"sentence\": \"Passengers coming from areas at risk of bedbug infestations can be checked at the booth and receive extermination services if needed.\", \"from\": 1027, \"to\": 1160, \"entities\": 