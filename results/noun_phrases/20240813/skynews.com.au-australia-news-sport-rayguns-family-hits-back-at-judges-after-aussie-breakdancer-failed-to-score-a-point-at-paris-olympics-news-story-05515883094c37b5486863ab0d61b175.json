436}, {\"ngram\": \"the taxpayer\", \"from\": 2451, \"to\": 2463}, {\"ngram\": \"a university and Olympic level\", \"from\": 2472, \"to\": 2502}, {\"ngram\": \"a go\", \"from\": 2535, \"to\": 2539}]}, {\"sentence\": \"How the Olympian managed to even qualify for the Games has been called into question by many Australians, who pondered if she was the best the country could offer to compete in the sport.\", \"from\": 2662, \"to\": 2849, \"entities\": [{\"begin\": 2670, \"end\": 2678, \"title\": \"http://dbpedia.org/resource/Olympic_Games\", \"score\": 0.9999999084082034, \"rank\": 7.638638078210214e-08, \"text\": \"Olympian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games\"}], \"noun_phrases\": [{\"ngram\": \"the Games\", \"from\": 2707, \"to\": 2716}, {\"ngram\": \"question\", \"from\": 2738, \"to\": 2746}, {\"ngram\": \"many Australians\", \"from\": 2750, \"to\": 2766}, {\"ngram\": \"the country\", \"from\": 2801, \"to\": 2812}, {\"ngram\": \"the sport\", \"from\": 2839, \"to\": 2848}]}, {\"sentence\": \"\\\"She has made the competion a laughing stock.\", \"from\": 2851, \"to\": 2896, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the competion\", \"from\": 2865, \"to\": 2878}]}, {\"sentence\": \"It's not the comedy festival.\", \"from\": 2897, \"to\": 2926, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the comedy festival\", \"from\": 2906, \"to\": 2925}]}, {\"sentence\": \"How could the Oceania judges get it so wrong using the criteria of assessment used at the Olympics,\\\" one disgruntled Aussie said on a Facebook post.\", \"from\": 2927, \"to\": 3075, \"entities\": [{\"begin\": 2941, \"end\": 2948, \"title\": \"http://dbpedia.org/resource/Oceania\", \"score\": 0.9997904101121593, \"rank\": 0.00017789186575227698, \"text\": \"Oceania\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Oceania\", \"dbpedia\": \"http://dbpedia.org/resource/Oceania\"}], \"noun_phrase