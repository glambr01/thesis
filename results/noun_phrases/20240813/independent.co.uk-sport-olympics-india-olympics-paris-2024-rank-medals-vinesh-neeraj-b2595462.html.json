78}, {\"ngram\": \"children\", \"from\": 10099, \"to\": 10107}, {\"ngram\": \"the age\", \"from\": 10113, \"to\": 10120}, {\"ngram\": \"four and five years\", \"from\": 10124, \"to\": 10143}, {\"ngram\": \"public hostels\", \"from\": 10163, \"to\": 10177}, {\"ngram\": \"training\", \"from\": 10185, \"to\": 10193}]}, {\"sentence\": \"\\\"So it is kind of strange, they have ignored some sports that are popular while focusing on those that they have better chances winning, even if those sports have no fans.\\\"\", \"from\": 10206, \"to\": 10378, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"some sports\", \"from\": 10251, \"to\": 10262}, {\"ngram\": \"better chances\", \"from\": 10319, \"to\": 10333}, {\"ngram\": \"those sports\", \"from\": 10351, \"to\": 10363}, {\"ngram\": \"no fans\", \"from\": 10369, \"to\": 10376}]}, {\"sentence\": \"Gymnastics, he points out, is one sport that receives high investment.\", \"from\": 10380, \"to\": 10450, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Gymnastics\", \"from\": 10380, \"to\": 10390}, {\"ngram\": \"one sport\", \"from\": 10410, \"to\": 10419}, {\"ngram\": \"high investment\", \"from\": 10434, \"to\": 10449}]}, {\"sentence\": \"China has more than 2,183 state schools that train children as young as five to groom them for the Olympics, Reuters reported in 2016.\", \"from\": 10452, \"to\": 10586, \"entities\": [{\"begin\": 10452, \"end\": 10457, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9999806869591866, \"rank\": 1.9186662545148582e-05, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}, {\"begin\": 10561, \"end\": 10568, \"title\": \"http://dbpedia.org/resource/Reuters\", \"score\": 0.9999999998672138, \"rank\": 1.3322048032365646e-10, \"text\": \"Reuters\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Reuters\", \"dbpedia\": \"http://dbpedia.org/