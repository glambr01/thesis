 {\"ngram\": \"sustained investment\", \"from\": 5306, \"to\": 5326}, {\"ngram\": \"some sports\", \"from\": 5353, \"to\": 5364}, {\"ngram\": \"more attention\", \"from\": 5384, \"to\": 5398}, {\"ngram\": \"field hockey\", \"from\": 5408, \"to\": 5420}, {\"ngram\": \"a sport\", \"from\": 5422, \"to\": 5429}, {\"ngram\": \"whichIndia\", \"from\": 5433, \"to\": 5443}, {\"ngram\": \"a second straight bronze\", \"from\": 5448, \"to\": 5472}, {\"ngram\": \"Parisafter\", \"from\": 5476, \"to\": 5486}, {\"ngram\": \"a41-year medal drought\", \"from\": 5494, \"to\": 5516}]}, {\"sentence\": \"India once dominated hockey, winning a record 11 Olympic medals, including eight gold, in the sport until 1980.\", \"from\": 5528, \"to\": 5639, \"entities\": [{\"begin\": 5528, \"end\": 5533, \"title\": \"http://dbpedia.org/resource/India\", \"score\": 1.0, \"rank\": 1.602295784083816e-15, \"text\": \"India\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/India\", \"dbpedia\": \"http://dbpedia.org/resource/India\"}], \"noun_phrases\": [{\"ngram\": \"hockey\", \"from\": 5549, \"to\": 5555}, {\"ngram\": \"a record 11 Olympic medals\", \"from\": 5565, \"to\": 5591}, {\"ngram\": \"eight gold\", \"from\": 5603, \"to\": 5613}, {\"ngram\": \"the sport\", \"from\": 5618, \"to\": 5627}]}, {\"sentence\": \"A steady decline over the following quarter century reached a nadir in 2008 when it did not even qualify for the Beijing Games.\", \"from\": 5640, \"to\": 5767, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A steady decline\", \"from\": 5640, \"to\": 5656}, {\"ngram\": \"the following quarter century\", \"from\": 5662, \"to\": 5691}, {\"ngram\": \"a nadir\", \"from\": 5700, \"to\": 5707}, {\"ngram\": \"the Beijing Games\", \"from\": 5749, \"to\": 5766}]}, {\"sentence\": \"The embarrassment sparked a process of rebuilding that culminated in a bronze medal at Tokyo, says former hockey goalkeeper and coach AB Subbaiah.\", \"from\": 5769, \"to\": 5915, \"entities\": [{\"beg