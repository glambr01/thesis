.org/resource/Paris\", \"score\": 0.9999999996055067, \"rank\": 3.945394137440342e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"A peak audience\", \"from\": 172, \"to\": 187}, {\"ngram\": \"gold\", \"from\": 226, \"to\": 230}, {\"ngram\": \"the Women's 60kg Boxing\", \"from\": 234, \"to\": 257}]}, {\"sentence\": \"The Dublin boxer's winning performance was the most-watched event of RT\\u00c9's Olympic coverage, which spanned 17 days and over 250 hours of live action.\", \"from\": 285, \"to\": 434, \"entities\": [{\"begin\": 289, \"end\": 295, \"title\": \"http://dbpedia.org/resource/Dublin\", \"score\": 0.994963501332162, \"rank\": 0.0049812060078621495, \"text\": \"Dublin\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Dublin\", \"dbpedia\": \"http://dbpedia.org/resource/Dublin\"}, {\"begin\": 354, \"end\": 357, \"title\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\", \"score\": 0.9835396432123026, \"rank\": 0.013767790549921992, \"text\": \"RT\\u00c9\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\", \"dbpedia\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\"}], \"noun_phrases\": [{\"ngram\": \"the most-watched event\", \"from\": 328, \"to\": 350}, {\"ngram\": \"live action\", \"from\": 422, \"to\": 433}]}, {\"sentence\": \"Rhasidat Adeleke's 4th place finish in the Women's 400m final was the second most-watched event, garnering a peak audience of 926,000 viewers, followed by the Women's 4x400m Relay final which peaked at 910,000.\", \"from\": 436, \"to\": 646, \"entities\": [{\"begin\": 436, \"end\": 452, \"title\": \"http://dbpedia.org/resource/Rhasidat_Adeleke\", \"score\": 0.9999999999349711, \"rank\": 0.0, \"text\": \"Rhasidat Adeleke\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Rhasidat_Adeleke\", \"dbpedia\": \"http://dbpedia.org/resource/Rhasidat_Adeleke\"}], \"noun_phrases\": [{\"ngram\": \"the Women's 400m\", \"from\": 475, \"to\": 491}, {\"ngram\": \"the second most-watched event\", \"from\": 502, \"to\": 531}, {\"ngram\": \"a peak audience\", \"from\": 543, \"to\": 558}, {\"ngram\": \"926,000 viewers\", \"from\": 562, \"to\": 577}, {\"ngram\": \"the Women's 4x400m Relay\", \"from\": 591, \"to\": 615}]}, {\"sentence\": \"The RT\\u00c9 Player clocked a total of 7.2 million streams of the Olympic Games, with Harrington's gold medal win once again coming in as the most-watched event.\", \"from\": 648, \"to\": 804, \"entities\": [{\"begin\": 652, \"end\": 655, \"title\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\", \"score\": 0.9835396432123026, \"rank\": 0.013767790549921992, \"text\": \"RT\\u00c9\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\", \"dbpedia\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\"}, {\"begin\": 729, \"end\": 739, \"title\": \"http://dbpedia.org/resource/Roger_F._Harrington\", \"score\": 0.99998521388506, \"rank\": 7.759578468613423e-06, \"text\": \"Harrington\", \"types\": [\"Q901\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Roger_F._Harrington\", \"dbpedia\": \"http://dbpedia.org/resource/Roger_F._Harrington\"}], \"noun_phrases\": [{\"ngram\": \"a total\", \"from\": 671, \"to\": 678}, {\"ngram\": \"7.2 million streams\", \"from\": 682, \"to\": 701}, {\"ngram\": \"the Olympic Games\", \"from\": 705, \"to\": 722}, {\"ngram\": \"the most-watched event\", \"from\": 781, \"to\": 803}]}, {\"sentence\": \"Olympics content on RT\\u00c9's social channels amassed 90 million views with over 9.5 million engagements on TikTok, Instagram, Facebook and X. RT\\u00c9 Group Head of Sport Declan McBennett said the level of engagement from the Irish public was \\\"unprecedented for the world's greatest sporting event and RT\\u00c9 was privileged to play a part in that across all platforms\\\".\", \"from\": 806, \"to\": 1165, \"entities\": [{\"begin\": 826, \"end\": 829, \"title\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\", \"score\": 0.9835396432123026, \"rank\": 0.013767790549921992, \"text\": \"RT\\u00c9\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\", \"dbpedia\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\"}, {\"begin\": 1025, \"end\": 1030, \"title\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"score\": 0.9989242399872977, \"rank\": 0.0010710266296297527, \"text\": \"Irish\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"dbpedia\": \"http://dbpedia.org/resource/Republic_of_Ireland\"}, {\"begin\": 1101, \"end\": 1104, \"title\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\", \"score\": 0.9835396432123026, \"rank\": 0.013767790549921992, \"text\": \"RT\\u00c9\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\", \"dbpedia\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\"}], \"noun_phrases\": [{\"ngram\": \"Olympics content\", \"from\": 806, \"to\": 822}, {\"ngram\": \"90 million views\", \"from\": 856, \"to\": 872}, {\"ngram\": \"over 9.5 million engagements\", \"from\": 878, \"to\": 906}, {\"ngram\": \"Sport\", \"from\": 963, \"to\": 968}, {\"ngram\": \"the level\", \"from\": 991, \"to\": 1000}, {\"ngram\": \"engagement\", \"from\": 1004, \"to\": 1014}, {\"ngram\": \"the world's greatest sporting event\", \"from\": 1060, \"to\": 1095}, {\"ngram\": \"a part\", \"from\": 1127, \"to\": 1133}, {\"ngram\": \"all platforms\", \"from\": 1149, \"to\": 1162}]}, {\"sentence\": \"Team Ireland's medal winning performances featured high in the list of most-watched events.\", \"from\": 1167, \"to\": 1258, \"entities\": [{\"begin\": 1167, \"end\": 1179, \"title\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\", \"score\": 1.0, \"rank\": 3.1652373549782853e-24, \"text\": \"Team Ireland\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"the list\", \"from\": 1226, \"to\": 1234}, {\"ngram\": \"most-watched events\", \"from\": 1238, \"to\": 1257}]}, {\"sentence\": \"Mona McSharry's bronze medal swim on 29 July peaked at 621,000 viewers, while Fintan McCarthy and Paul O'Donovan's back-to-back gold medal win in the lightweight rowing double sculls was seen by a peak audience of 429,000.\", \"from\": 1260, \"to\": 1482, \"entities\": [{\"begin\": 1260, \"end\": 1273, \"title\": \"http://dbpedia.org/resource/Mona_McSharry\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Mona McSharry\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Mona_McSharry\", \"dbpedia\": \"http://dbpedia.org/resource/Mona_McSharry\"}, {\"begin\": 1338, \"end\": 1353, \"title\": \"http://dbpedia.org/resource/Fintan_McCarthy\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Fintan McCarthy\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Fintan_McCarthy\", \"dbpedia\": \"http://dbpedia.org/resource/Fintan_McCarthy\"}, {\"begin\": 1358, \"end\": 1372, \"title\": \"http://dbpedia.org/resource/Paul_O'Donovan\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Paul O'Donovan\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Paul_O'Donovan\", \"dbpedia\": \"http://dbpedia.org/resource/Paul_O'Donovan\"}], \"noun_phrases\": [{\"ngram\": \"29 July\", \"from\": 1297, \"to\": 1304}, {\"ngram\": \"621,000 viewers\", \"from\": 1315, \"to\": 1330}, {\"ngram\": \"the lightweight rowing double sculls\", \"from\": 1406, \"to\": 1442}, {\"ngram\": \"a peak audience\", \"from\": 1455, \"to\": 1470}]}, {\"sentence\": \"Armagh swimmer Daniel Wiffen's bronze medal swim in the 1,500m Freestyle was watched by a peak of 790,000 viewers, as he added to the gold medal he won in the 800m Freestyle.\", \"from\": 1484, \"to\": 1658, \"entities\": [{\"begin\": 1484, \"end\": 1490, \"title\": \"http://dbpedia.org/resource/Armagh_GAA\", \"score\": 0.9999992624953384, \"rank\": 7.37435916250358e-07, \"text\": \"Armagh\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Armagh_GAA\", \"dbpedia\": \"http://dbpedia.org/resource/Armagh_GAA\"}], \"noun_phrases\": [{\"ngram\": \"Daniel Wiffen's bronze medal swim\", \"from\": 1499, \"to\": 1532}, {\"ngram\": \"the 1,500m Freestyle\", \"from\": 1536, \"to\": 1556}, {\"ngram\": \"a peak\", \"from\": 1572, \"to\": 1578}, {\"ngram\": \"790,000 viewers\", \"from\": 1582, \"to\": 1597}, {\"ngram\": \"the gold medal\", \"from\": 1614, \"to\": 1628}, {\"ngram\": \"the 800m Freestyle\", \"from\": 1639, \"to\": 1657}]}, {\"sentence\": \"A peak audience of 629,000 tuned in as gymnast Rhys McClenaghan secured gold on the pommel horse.\", \"from\": 1660, \"to\": 1757, \"entities\": [{\"begin\": 1707, \"end\": 1723, \"title\": \"http://dbpedia.org/resource/Rhys_McClenaghan\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Rhys McClenaghan\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Rhys_McClenaghan\", \"dbpedia\": \"http://dbpedia.org/resource/Rhys_McClenaghan\"}], \"noun_phrases\": [{\"ngram\": \"A peak audience\", \"from\": 1660, \"to\": 1675}, {\"ngram\": \"gold\", \"from\": 1732, \"to\": 1736}, {\"ngram\": \"the pommel horse\", \"from\": 1740, \"to\": 1756}]}, {\"sentence\": \"Yesterday's homecoming event, broadcast live on RT\\u00c9 One from O'Connell Street in Dublin, had an average audience of over 200,000 with 43,000 streams to date on RT\\u00c9 Player.\", \"from\": 1759, \"to\": 1930, \"entities\": [{\"begin\": 1820, \"end\": 1836, \"title\": \"http://dbpedia.org/resource/O'Connell_Street\", \"score\": 1.0, \"rank\": 2.9204395952747295e-30, \"text\": \"O'Connell Street\", \"types\": [\"Q34442\"], \"wikid\": \"http://dbpedia.org/resource/O'Connell_Street\", \"dbpedia\": \"http://dbpedia.org/resource/O'Connell_Street\"}, {\"begin\": 1840, \"end\": 1846, \"title\": \"http://dbpedia.org/resource/Dublin\", \"score\": 0.994963501332162, \"rank\": 0.0049812060078621495, \"text\": \"Dublin\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Dublin\", \"dbpedia\": \"http://dbpedia.org/resource/Dublin\"}, {\"begin\": 1919, \"end\": 1922, \"title\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\", \"score\": 0.9835396432123026, \"rank\": 0.013767790549921992, \"text\": \"RT\\u00c9\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\", \"dbpedia\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\"}], \"noun_phrases\": [{\"ngram\": \"Yesterday's homecoming event\", \"from\": 1759, \"to\": 1787}, {\"ngram\": \"RT\\u00c9\", \"from\": 1807, \"to\": 1810}, {\"ngram\": \"an average audience\", \"from\": 1852, \"to\": 1871}, {\"ngram\": \"43,000 streams\", \"from\": 1893, \"to\": 1907}, {\"ngram\": \"date\", \"from\": 1911, \"to\": 1915}]}, {\"sentence\": \"RT\\u00c9 Director General Kevin Bakhurst said that the scale, quality and dynamism of the coverage is \\\"testament to the dedication of teams across RT\\u00c9, and to the unique mission of public service media in guaranteeing free-to-air access for national sporting occasions such as this\\\".\", \"from\": 1932, \"to\": 2210, \"entiti