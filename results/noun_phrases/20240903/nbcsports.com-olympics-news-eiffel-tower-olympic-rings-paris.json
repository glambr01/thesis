"{\"uid\": \"nbcsports.com-olympics-news-eiffel-tower-olympic-rings-paris\", \"noun_phrases\": [{\"sentence\": \"A set of Olympic rings could adorn the Eiffel Tower long after the Paris Games.\", \"from\": 0, \"to\": 79, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A set\", \"from\": 0, \"to\": 5}, {\"ngram\": \"Olympic rings\", \"from\": 9, \"to\": 22}, {\"ngram\": \"the Eiffel Tower\", \"from\": 35, \"to\": 51}, {\"ngram\": \"the Paris Games\", \"from\": 63, \"to\": 78}]}, {\"sentence\": \"Paris Mayor Anne Hidalgo said she wants a set of rings to return to the tower and has the support of IOC President Thomas Bach.\", \"from\": 81, \"to\": 208, \"entities\": [{\"begin\": 81, \"end\": 92, \"title\": \"http://dbpedia.org/resource/List_of_mayors_of_Paris\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Paris Mayor\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/List_of_mayors_of_Paris\", \"dbpedia\": \"http://dbpedia.org/resource/List_of_mayors_of_Paris\"}, {\"begin\": 93, \"end\": 105, \"title\": \"http://dbpedia.org/resource/Anne_Hidalgo\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Anne Hidalgo\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Anne_Hidalgo\", \"dbpedia\": \"http://dbpedia.org/resource/Anne_Hidalgo\"}, {\"begin\": 182, \"end\": 195, \"title\": \"http://dbpedia.org/resource/President_of_the_International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"IOC President\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/President_of_the_International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/President_of_the_International_Olympic_Committee\"}, {\"begin\": 196, \"end\": 207, \"title\": \"http://dbpedia.org/resource/Thomas_Bach\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Thomas Bach\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Thomas_Bach\", \"dbpedia\": \"http://dbpedia.org/resource/Thomas_Bach\"}], \"noun_phrases\": [{\"ngram\": \"a set\", \"from\": 121, \"to\": 126}, {\"ngram\": \"rings\", \"from\": 130, \"to\": 135}, {\"ngram\": \"the tower\", \"from\": 149, \"to\": 158}, {\"ngram\": \"the support\", \"from\": 167, \"to\": 178}]}, {\"sentence\": \"\\\"This decision brings together two ephemeral objects - the most famous monument in Paris, initially intended as temporary when it was built in 1889, and the symbol of Olympism, originally installed only for the duration of the Games - to create new images of Paris that promote a world of dialogue for peace and fraternity, celebrating effort, unity, and intelligence,\\\" the City of Paris media office said Tuesday.\", \"from\": 210, \"to\": 624, \"entities\": [{\"begin\": 293, \"end\": 298, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999690772, \"rank\": 3.0866904572413225e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 469, \"end\": 474, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999690772, \"rank\": 3.0866904572413225e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 592, \"end\": 597, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999690772, \"rank\": 3.0866904572413225e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"This decision\", \"from\": 211, \"to\": 224}, {\"ngram\": \"two ephemeral objects\", \"from\": 241, \"to\": 262}, {\"ngram\": \"the most famous monument\", \"from\": 265, \"to\": 289}, {\"ngram\": \"the symbol\", \"from\": 363, \"to\": 373}, {\"ngram\": \"Olympism\", \"from\": 377, \"to\": 385}, {\"ngram\": \"the duration\", \"from\": 417, \"to\": 429}, {\"ngram\": \"the Games\", \"from\": 433, \"to\": 442}, {\"ngram\": \"new images\", \"from\": 455, \"to\": 465}, {\"ngram\": \"a world\", \"from\": 488, \"to\": 495}, {\"ngram\": \"dialogue\", \"from\": 499, \"to\": 507}, {\"ngram\": \"peace\", \"from\": 512, \"to\": 517}, {\"ngram\": \"fraternity\", \"from\": 522, \"to\": 532}, {\"ngram\": \"effort\", \"from\": 546, \"to\": 552}, {\"ngram\": \"unity\", \"from\": 554, \"to\": 559}, {\"ngram\": \"intelligence\", \"from\": 565, \"to\": 577}]}, {\"sentence\": \"The current set of rings on the tower, which have been in place since June 7, \\\"were designed for temporary use and cannot remain as they are,\\\" according to the City of Paris.\", \"from\": 626, \"to\": 800, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The current set\", \"from\": 626, \"to\": 641}, {\"ngram\": \"rings\", \"from\": 645, \"to\": 650}, {\"ngram\": \"the tower\", \"from\": 654, \"to\": 663}, {\"ngram\": \"place\", \"from\": 684, \"to\": 689}, {\"ngram\": \"June\", \"from\": 696, \"to\": 700}, {\"ngram\": \"temporary use\", \"from\": 723, \"to\": 736}, {\"ngram\": \"the City\", \"from\": 782, \"to\": 790}, {\"ngram\": \"Paris\", \"from\": 794, \"to\": 799}]}, {\"sentence\": \"Those rings are scheduled to be removed in mid-September.\", \"from\": 801, \"to\": 858, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Those rings\", \"from\": 801, \"to\": 812}, {\"ngram\": \"mid\", \"from\": 844, \"to\": 847}, {\"ngram\": \"September\", \"from\": 848, \"to\": 857}]}, {\"sentence\": \"The IOC said Tuesday that it is conducting a feasibility study into having Olympic rings on the tower in the future with conclusions expected \\\"in the next months.\\\"\", \"from\": 860, \"to\": 1023, \"entities\": [{\"begin\": 864, \"end\": 867, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 0.9999999999959073, \"rank\": 3.876649046927144e-12, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q2