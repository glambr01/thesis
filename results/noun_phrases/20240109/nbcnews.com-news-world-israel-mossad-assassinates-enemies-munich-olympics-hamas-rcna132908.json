", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Leon Panetta\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Leon_Panetta\", \"dbpedia\": \"http://dbpedia.org/resource/Leon_Panetta\"}, {\"begin\": 7134, \"end\": 7137, \"title\": \"http://dbpedia.org/resource/Central_Intelligence_Agency\", \"score\": 1.0, \"rank\": 1.6594616488902836e-30, \"text\": \"CIA\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Central_Intelligence_Agency\", \"dbpedia\": \"http://dbpedia.org/resource/Central_Intelligence_Agency\"}, {\"begin\": 7163, \"end\": 7175, \"title\": \"http://dbpedia.org/resource/Presidency_of_Barack_Obama\", \"score\": 1.0, \"rank\": 2.4541263817473346e-15, \"text\": \"Barack Obama\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Presidency_of_Barack_Obama\", \"dbpedia\": \"http://dbpedia.org/resource/Presidency_of_Barack_Obama\"}, {\"begin\": 7216, \"end\": 7224, \"title\": \"http://dbpedia.org/resource/Al-Qaeda\", \"score\": 1.0, \"rank\": 4.3975557456610807e-39, \"text\": \"Al Qaeda\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Al-Qaeda\", \"dbpedia\": \"http://dbpedia.org/resource/Al-Qaeda\"}, {\"begin\": 7239, \"end\": 7247, \"title\": \"http://dbpedia.org/resource/Pakistan\", \"score\": 0.9999999995980033, \"rank\": 4.0076278646911864e-10, \"text\": \"Pakistan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Pakistan\", \"dbpedia\": \"http://dbpedia.org/resource/Pakistan\"}, {\"begin\": 7306, \"end\": 7321, \"title\": \"http://dbpedia.org/resource/Osama_bin_Laden\", \"score\": 1.0, \"rank\": 2.956997567617068e-129, \"text\": \"Osama bin Laden\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Osama_bin_Laden\", \"dbpedia\": \"http://dbpedia.org/resource/Osama_bin_Laden\"}, {\"begin\": 7328, \"end\": 7334, \"title\": \"http://dbpedia.org/resource/Israel