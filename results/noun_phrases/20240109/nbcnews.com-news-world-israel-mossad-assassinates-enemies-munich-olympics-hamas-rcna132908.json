2.181361733312565e-06, \"text\": \"Israeli\", \"types\": [\"Q43229\", \"Q24229398\", \"Q176799\"], \"wikid\": \"http://dbpedia.org/resource/Israel_Defense_Forces\", \"dbpedia\": \"http://dbpedia.org/resource/Israel_Defense_Forces\"}, {\"begin\": 8588, \"end\": 8595, \"title\": \"http://dbpedia.org/resource/Diplomatic_mission\", \"score\": 1.0, \"rank\": 3.403583444371253e-88, \"text\": \"Embassy\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Diplomatic_mission\", \"dbpedia\": \"http://dbpedia.org/resource/Diplomatic_mission\"}], \"noun_phrases\": [{\"ngram\": \"others\", \"from\": 8547, \"to\": 8553}, {\"ngram\": \"refuge\", \"from\": 8566, \"to\": 8572}]}, {\"sentence\": \"To resolve the crisis, Israel agreed to administer an antidote to Mashal and to release several Hamas militants imprisoned in Israel, including the group's founder, Sheikh Ahmed Yassin.\", \"from\": 8597, \"to\": 8782, \"entities\": [{\"begin\": 8620, \"end\": 8626, \"title\": \"http://dbpedia.org/resource/Israel\", \"score\": 1.0, \"rank\": 3.636532831398473e-55, \"text\": \"Israel\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Israel\", \"dbpedia\": \"http://dbpedia.org/resource/Israel\"}, {\"begin\": 8663, \"end\": 8669, \"title\": \"http://dbpedia.org/resource/FK_Mash'al_Mubarek\", \"score\": 0.9999985338037567, \"rank\": 7.377293145391655e-07, \"text\": \"Mashal\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/FK_Mash'al_Mubarek\", \"dbpedia\": \"http://dbpedia.org/resource/FK_Mash'al_Mubarek\"}, {\"begin\": 8693, \"end\": 8698, \"title\": \"http://dbpedia.org/resource/Hamas\", \"score\": 1.0, \"rank\": 2.971771652560964e-77, \"text\": \"Hamas\", \"types\": [\"Q7278\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Hamas\", \"dbpedia\": \"http://dbpedia.org/resource/Hamas\"}, {\"begin\": 8723, \"end\": 8729, \"title\": \"http://dbpedia.org/resource/Israel\", \"score\": 1.0, \"rank\": 3.6365