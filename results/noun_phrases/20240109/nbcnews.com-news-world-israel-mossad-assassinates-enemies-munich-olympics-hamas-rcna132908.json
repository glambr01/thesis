804, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"whatever target\", \"from\": 7728, \"to\": 7743}, {\"ngram\": \"fact\", \"from\": 7771, \"to\": 7775}]}, {\"sentence\": \"Although Israel has earned a reputation for ruthless efficiency and stealth in taking out its enemies, its spies also have made devastating mistakes over the years and suffered embarrassing failures.\", \"from\": 7806, \"to\": 8005, \"entities\": [{\"begin\": 7815, \"end\": 7821, \"title\": \"http://dbpedia.org/resource/Israel\", \"score\": 1.0, \"rank\": 3.636532831398473e-55, \"text\": \"Israel\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Israel\", \"dbpedia\": \"http://dbpedia.org/resource/Israel\"}], \"noun_phrases\": [{\"ngram\": \"a reputation\", \"from\": 7833, \"to\": 7845}, {\"ngram\": \"ruthless efficiency\", \"from\": 7850, \"to\": 7869}, {\"ngram\": \"stealth\", \"from\": 7874, \"to\": 7881}, {\"ngram\": \"its enemies\", \"from\": 7896, \"to\": 7907}, {\"ngram\": \"its spies\", \"from\": 7909, \"to\": 7918}, {\"ngram\": \"devastating mistakes\", \"from\": 7934, \"to\": 7954}, {\"ngram\": \"the years\", \"from\": 7960, \"to\": 7969}, {\"ngram\": \"embarrassing failures\", \"from\": 7983, \"to\": 8004}]}, {\"sentence\": \"In the post-Munich operation, in 1973, Israeli assassins mistook a Moroccan waiter, Ahmed Bouchikhi, for Ali Hassan Salameh, a security aide to PLO leader Yasser Arafat.\", \"from\": 8007, \"to\": 8176, \"entities\": [{\"begin\": 8046, \"end\": 8053, \"title\": \"http://dbpedia.org/resource/Israel_Defense_Forces\", \"score\": 0.9999976485396835, \"rank\": 2.181361733312565e-06, \"text\": \"Israeli\", \"types\": [\"Q43229\", \"Q24229398\", \"Q176799\"], \"wikid\": \"http://dbpedia.org/resource/Israel_Defense_Forces\", \"dbpedia\": \"http://dbpedia.org/resource/Israel_Defense_Forces\"}, {\"begin\": 8074, \"end\": 8082, \"title\": \"http://dbpedia.org/resource/Morocco\", \"score\": 0.9999998588309709, \"rank\": 1.4116875694898988e-07, \"text\":