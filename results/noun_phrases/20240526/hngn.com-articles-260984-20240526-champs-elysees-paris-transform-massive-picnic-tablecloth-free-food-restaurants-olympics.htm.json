"{\"uid\": \"hngn.com-articles-260984-20240526-champs-elysees-paris-transform-massive-picnic-tablecloth-free-food-restaurants-olympics.htm\", \"noun_phrases\": [{\"sentence\": \"One of the world's most famous boulevards was the scene of a massive picnic Sunday as more than 4,000 people sat down on a 700-foot-long, red-and-white checkered \\\"tablecloth\\\" to feast on free food.\", \"from\": 0, \"to\": 197, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the world's most famous boulevards\", \"from\": 7, \"to\": 41}, {\"ngram\": \"the scene\", \"from\": 46, \"to\": 55}, {\"ngram\": \"a massive picnic\", \"from\": 59, \"to\": 75}, {\"ngram\": \"more than 4,000 people\", \"from\": 86, \"to\": 108}, {\"ngram\": \"a 700-foot-long, red-and-white checkered \\\"tablecloth\", \"from\": 121, \"to\": 173}, {\"ngram\": \"free food\", \"from\": 187, \"to\": 196}]}, {\"sentence\": \"The event on the Champs-Elys\\u00e9es in Paris, dubbed \\\"Le Grand Pique-Nique des Champs,\\\" drew applications from more than 270,000 people who hoped to take part, the French newspaperLe Mondereported.\", \"from\": 199, \"to\": 392, \"entities\": [{\"begin\": 216, \"end\": 230, \"title\": \"http://dbpedia.org/resource/Champs-\\u00c9lys\\u00e9es\", \"score\": 0.9992163039514818, \"rank\": 0.0, \"text\": \"Champs-Elys\\u00e9es\", \"types\": [\"Q34442\"], \"wikid\": \"http://dbpedia.org/resource/Champs-\\u00c9lys\\u00e9es\", \"dbpedia\": \"http://dbpedia.org/resource/Champs-\\u00c9lys\\u00e9es\"}, {\"begin\": 234, \"end\": 239, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 8.494495141759346e-18, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 359, \"end\": 365, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9622827280804442, \"rank\": 0.037656442073743086, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"The event\", \"from\": 199, \"to\": 208}, {\"ngram\": \"\\\"Le Grand Pique-Nique des Champs\", \"from\": 248, \"to\": 280}, {\"ngram\": \"applications\", \"from\": 288, \"to\": 300}, {\"ngram\": \"more than 270,000 people\", \"from\": 306, \"to\": 330}, {\"ngram\": \"part\", \"from\": 349, \"to\": 353}]}, {\"sentence\": \"One of the lucky winners, Yasmina Train of Paris, told theAssociated Pressthat picnicking on the City of Lights' iconic street between the Arc de Triomphe and Avenue Georges V was \\\"a dream coming true.\\\"\", \"from\": 394, \"to\": 596, \"entities\": [{\"begin\": 437, \"end\": 442, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 8.494495141759346e-18, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 533, \"end\": 548, \"title\": \"http://dbpedia.org/resource/Arc_de_Triomphe\", \"score\": 0.9999999999995453, \"rank\": 5.464563265389959e-13, \"text\": \"Arc de Triomphe\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Arc_de_Triomphe\", \"dbpedia\": \"http://dbpedia.org/resource/Arc_de_Triomphe\"}], \"noun_phrases\": [{\"ngram\": \"the lucky winners\", \"from\": 401, \"to\": 418}, {\"ngram\": \"Yasmina Train\", \"from\": 420, \"to\": 433}, {\"ngram\": \"theAssociated Pressthat\", \"from\": 449, \"to\": 472}, {\"ngram\": \"the City\", \"from\": 487, \"to\": 495}, {\"ngram\": \"Lights' iconic street\", \"from\": 499, \"to\": 520}, {\"ngram\": \"Avenue Georges V\", \"from\": 553, \"to\": 569}, {\"ngram\": \"a dream\", \"from\": 575, \"to\": 582}]}, {\"sentence\": \"\\\"I took some pictures and I sent that to friends, you know, all over the world,\\\" Train said.\", \"from\": 598, \"to\": 690, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"some pictures\", \"from\": 606, \"to\": 619}, {\"ngram\": \"friends\", \"from\": 639, \"to\": 646}, {\"ngram\": \"the world\", \"from\": 667, \"to\": 676}, {\"ngram\": \"Train\", \"from\": 679, \"to\": 684}]}, {\"sentence\": \"The meals, served in wicker picnic baskets, were prepared in eight \\\"temporary kitchens\\\" that were \\\"organized and managed by the grand chefs\\\" of eateries along the avenue, Marc-Antoine Jamet, chairperson of the Champs-Elys\\u00e9es Committee, told AP.\", \"from\": 692, \"to\": 936, \"entities\": [{\"begin\": 902, \"end\": 916, \"title\": \"http://dbpedia.org/resource/Champs-\\u00c9lys\\u00e9es\", \"score\": 0.999999999943384, \"rank\": 0.0, \"text\": \"Champs-Elys\\u00e9es\", \"types\": [\"Q34442\"], \"wikid\": \"http://dbpedia.org/resource/Champs-\\u00c9lys\\u00e9es\", \"dbpedia\": \"http://dbpedia.org/resource/Champs-\\u00c9lys\\u00e9es\"}, {\"begin\": 933, \"end\": 935, \"title\": \"http://dbpedia.org/resource/Andhra_Pradesh\", \"score\": 0.9414117750304887, \"rank\": 0.06198098246202887, \"text\": \"AP\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Andhra_Pradesh\", \"dbpedia\": \"http://dbpedia.org/resource/Andhra_Pradesh\"}], \"noun_phrases\": [{\"ngram\": \"The meals\", \"from\": 692, \"to\": 701}, {\"ngram\": \"wicker picnic baskets\", \"from\": 713, \"to\": 734}, {\"ngram\": \"eight \\\"temporary kitchens\", \"from\": 753, \"to\": 778}, {\"ngram\": \"the grand chefs\", \"from\": 816, \"to\": 831}, {\"ngram\": \"eateries\", \"from\": 836, \"to\": 844}, {\"ngram\": \"the avenue\", \"from\": 851, \"to\": 861}, {\"ngram\": \"Marc-Antoine Jamet\", \"from\": 863, \"to\": 881}, {\"ngram\": \"chairperson\", \"from\": 883, \"to\": 894}]}, {\"sentence\": \"The offerings included creative sandwiches and puff pastries from restaurants that ranged from the famed Brasserie Foquet's to McDonald's,APsaid.\", \"from\": 938, \"to\": 1083, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The offerings\", \"from\": 938, \"to\": 951}, {\"ngram\": \"creative sandwiches\", \"from\": 961, \"to\": 980}, {\"ngram\": \"pastries\", \"from\": 990, \"to\": 998}, {\"ngram\": \"restaurants\", \"from\": 1004, \"to\": 1015}, {\"ngram\": \"the famed Brasserie Foquet\", \"from\": 1033, \"to\": 1059}, {\"ngram\": \"McDonald's\", \"from\": 1065, \"to\": 1075}, {\"ngram\": \"APsaid\", \"from\": 1076, \"to\": 1082}]}, {\"sentence\": \"Two sittings were scheduled at noon and 2 p.m. and the tablecloth was assembled on-site by 150 people from 25 pieces of recycled material, according to Le Monde.\", \"from\": 1085, \"to\": 1246, \"entities\": [{\"begin\": 1237, \"end\": 1245, \"title\": \"http://dbpedia.org/resource/Le_Monde\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Le Monde\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/Le_Monde\", \"dbpedia\": \"http://dbpedia.org/resource/Le_Monde\"}], \"noun_phrases\": [{\"ngram\": \"Two sittings\", \"from\": 1085, \"to\": 1097}, {\"ngram\": \"noon\", \"from\": 1116, \"to\": 1120}, {\"ngram\": \"2 p.m.\", \"from\": 1125, \"to\": 1131}, {\"ngram\": \"the tablecloth\", \"from\": 1136, \"to\": 1150}, {\"ngram\": \"site\", \"from\": 1168, \"to\": 1172}, {\"ngram\": \"150 people\", \"from\": 1176, \"to\": 1186}, {\"ngram\": \"25 pieces\", \"from\": 1192, \"to\": 1201}, {\"ngram\": \"recycled material\", \"from\": 1205, \"to\": 1222}]}, {\"sentence\": \"The event, held exactly two months before Paris will host the opening ceremony of the Summer Olympcis, was aimed at boosting local interest in the Champs-Elys\\u00e9es, a popular tourist destination due to its designer boutiques and gourmet restaurants.\", \"from\": 1248, \"to\": 1495, \"entities\": [{\"begin\": 1290, \"end\": 1295, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 8.494495141759346e-18, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 13