"{\"uid\": \"jdsupra.com-legalnews-paris-olympic-games-2024-reminder-of-6747830\", \"noun_phrases\": [{\"sentence\": \"France will host the Olympic Games from 26 July to 11 August 2024, and the Paralympic Games from 29 August to 8 September 2024.\", \"from\": 0, \"to\": 129, \"entities\": [{\"begin\": 2, \"end\": 8, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9714392081891466, \"rank\": 0.0256772378001994, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"the Olympic Games\", \"from\": 17, \"to\": 34}, {\"ngram\": \"26 July\", \"from\": 40, \"to\": 47}, {\"ngram\": \"11 August\", \"from\": 51, \"to\": 60}, {\"ngram\": \"the Paralympic Games\", \"from\": 71, \"to\": 91}, {\"ngram\": \"29 August\", \"from\": 97, \"to\": 106}, {\"ngram\": \"8 September\", \"from\": 110, \"to\": 121}]}, {\"sentence\": \"A number of foreign workers are expected to come to work in France during this period, and non-French employers may wonder whether they need to comply with specific rules.\", \"from\": 131, \"to\": 302, \"entities\": [{\"begin\": 191, \"end\": 197, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9714392081891466, \"rank\": 0.0256772378001994, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"A number\", \"from\": 131, \"to\": 139}, {\"ngram\": \"foreign workers\", \"from\": 143, \"to\": 158}, {\"ngram\": \"this period\", \"from\": 205, \"to\": 216}, {\"ngram\": \"non-French employers\", \"from\": 222, \"to\": 242}, {\"ngram\": \"specific rules\", \"from\": 287, \"to\": 301}]}, {\"sentence\": \"Employers should obtain advice on the legal requirements that may apply to their specific situation.\", \"from\": 304, \"to\": 404, \"entities\": [], \"noun_phrases\": [{\"ngram\":