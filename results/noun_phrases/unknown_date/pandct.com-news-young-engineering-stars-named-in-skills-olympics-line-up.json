7}, {\"ngram\": \"vital insights\", \"from\": 2292, \"to\": 2306}, {\"ngram\": \"our apprenticeship and training programmes\", \"from\": 2332, \"to\": 2374}]}, {\"sentence\": \"\\\"I could not be prouder of the exceptional young people in Team UK; they are fantastic role models.\", \"from\": 2410, \"to\": 2509, \"entities\": [{\"begin\": 2474, \"end\": 2476, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9999999666538321, \"rank\": 3.334481163106301e-08, \"text\": \"UK\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"prouder\", \"from\": 2426, \"to\": 2433}, {\"ngram\": \"the exceptional young people\", \"from\": 2437, \"to\": 2465}, {\"ngram\": \"fantastic role models\", \"from\": 2487, \"to\": 2508}]}, {\"sentence\": \"Together with Pearson, we will use their participation at WorldSkills to boost the prestige of technical and vocational education, inspiring many more young people to take up technical and vocational training across the UK to help drive investment, jobs and economic growth.\\\"\", \"from\": 2511, \"to\": 2786, \"entities\": [{\"begin\": 2569, \"end\": 2580, \"title\": \"http://dbpedia.org/resource/WorldSkills\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"WorldSkills\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/WorldSkills\", \"dbpedia\": \"http://dbpedia.org/resource/WorldSkills\"}, {\"begin\": 2731, \"end\": 2733, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9999999666538321, \"rank\": 3.334481163106301e-08, \"text\": \"UK\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"Pearson\", \"from\": 2525, \"to\": 2532}, {\"ngram\": \"their participation\", \"from\": 2546, \"to\": 2565}, {\"ngram\": \"the prestige\", \"from\": 2590