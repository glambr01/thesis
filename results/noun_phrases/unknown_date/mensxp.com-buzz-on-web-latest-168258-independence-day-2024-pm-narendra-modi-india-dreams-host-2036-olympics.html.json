gram\": \"the Olympics\", \"from\": 1998, \"to\": 2010}, {\"ngram\": \"a historic moment\", \"from\": 2019, \"to\": 2036}, {\"ngram\": \"not everyone\", \"from\": 2048, \"to\": 2060}, {\"ngram\": \"the right decision\", \"from\": 2090, \"to\": 2108}]}, {\"sentence\": \"That would be historic-imagine the host country not winning any gold medals!\", \"from\": 2111, \"to\": 2187, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the host country\", \"from\": 2142, \"to\": 2158}, {\"ngram\": \"any gold medals\", \"from\": 2171, \"to\": 2186}]}, {\"sentence\": \"Just kidding \\ud83d\\ude0c This is a good thing for us, but every country ends up in loss after hosting the Olympics, so no one is interested in hosting the Olympics anymore.\", \"from\": 2188, \"to\": 2351, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a good thing\", \"from\": 2211, \"to\": 2223}, {\"ngram\": \"us\", \"from\": 2228, \"to\": 2230}, {\"ngram\": \"every country\", \"from\": 2236, \"to\": 2249}, {\"ngram\": \"loss\", \"from\": 2261, \"to\": 2265}, {\"ngram\": \"the Olympics\", \"from\": 2280, \"to\": 2292}, {\"ngram\": \"no one\", \"from\": 2297, \"to\": 2303}, {\"ngram\": \"the Olympics\", \"from\": 2329, \"to\": 2341}]}, {\"sentence\": \"Hosting is nice , but should definitely provide more facilities and focus to improve our athletes .\", \"from\": 2353, \"to\": 2452, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"more facilities\", \"from\": 2401, \"to\": 2416}, {\"ngram\": \"our athletes\", \"from\": 2438, \"to\": 2450}]}, {\"sentence\": \"We need to show improvements in 2028 Always talking about economy losses.Everyone knows Olympics host nation country always suffers a lot in terms of finance and infrastructure.Absolute wastage Do not waste our tax money, build good infrastructure first, bridges & Roads are falling every other day.\", \"from\": 2453, \"to\": 2754, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"improvements\", \"from\": 2469, \"to\": 2481}, {\"ngram\": \"economy