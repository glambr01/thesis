, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Fabrice Riceputi\", \"from\": 2603, \"to\": 2619}, {\"ngram\": \"historian\", \"from\": 2621, \"to\": 2630}, {\"ngram\": \"author\", \"from\": 2635, \"to\": 2641}, {\"ngram\": \"\\\"Ici\", \"from\": 2645, \"to\": 2649}, {\"ngram\": \"noya les Alg\\u00e9riens\", \"from\": 2653, \"to\": 2671}, {\"ngram\": \"the Algerians\", \"from\": 2690, \"to\": 2703}, {\"ngram\": \"a very broad estimate\", \"from\": 2748, \"to\": 2769}, {\"ngram\": \"the actual number\", \"from\": 2774, \"to\": 2791}, {\"ngram\": \"victims\", \"from\": 2795, \"to\": 2802}, {\"ngram\": \"the night\", \"from\": 2806, \"to\": 2815}, {\"ngram\": \"17 October\", \"from\": 2819, \"to\": 2829}, {\"ngram\": \"150 deaths\", \"from\": 2857, \"to\": 2867}]}, {\"sentence\": \"In March, the National Assembly, parliament's lower house, voted 67-11 in favour of a non-binding resolution condemning \\\"the police brutality\\\" that occurred on 17 October 1961.\", \"from\": 2886, \"to\": 3062, \"entities\": [{\"begin\": 2900, \"end\": 2917, \"title\": \"http://dbpedia.org/resource/National_Assembly\", \"score\": 0.9915901379167819, \"rank\": 0.008172564687662332, \"text\": \"National Assembly\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/National_Assembly\", \"dbpedia\": \"http://dbpedia.org/resource/National_Assembly\"}], \"noun_phrases\": [{\"ngram\": \"March\", \"from\": 2889, \"to\": 2894}, {\"ngram\": \"parliament's lower house\", \"from\": 2919, \"to\": 2943}, {\"ngram\": \"favour\", \"from\": 2960, \"to\": 2966}, {\"ngram\": \"a non-binding resolution\", \"from\": 2970, \"to\": 2994}, {\"ngram\": \"the police brutality\", \"from\": 3007, \"to\": 3027}, {\"ngram\": \"17 October\", \"from\": 3046, \"to\": 3056}]}, {\"sentence\": \"The resolution also asked that France establish a national day of remembrance.\", \"from\": 3063, \"to\": 3141, \"entities\": [{\"begin\": 3094, \"end\": 3100, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.7882027045681219, \"rank\": 0.2687068392401943, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"The resolution\", \"from\": 3063, \"to\": 3077}, {\"ngram\": \"a national day\", \"from\": 3111, \"to\": 3125}, {\"ngram\": \"remembrance\", \"from\": 3129, \"to\": 3140}]}, {\"sentence\": \"\\\"Our wounds have not healed yet [...] and they are already organising the Olympics in the cemetery of our brothers,\\\" Moha, a French-Algerian young man who grew up hearing the story of his grandfather's protest on the massacre day, remarked toTNA.\", \"from\": 3143, \"to\": 3389, \"entities\": [{\"begin\": 3260, \"end\": 3264, \"title\": \"http://dbpedia.org/resource/Moh\", \"score\": 0.9999999965343704, \"rank\": 3.4655555744125243e-09, \"text\": \"Moha\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Moh\", \"dbpedia\": \"http://dbpedia.org/resource/Moh\"}], \"noun_phrases\": [{\"ngram\": \"Our wounds\", \"from\": 3144, \"to\": 3154}, {\"ngram\": \"the Olympics\", \"from\": 3213, \"to\": 3225}, {\"ngram\": \"the cemetery\", \"from\": 3229, \"to\": 3241}, {\"ngram\": \"our brothers\", \"from\": 3245, \"to\": 3257}, {\"ngram\": \"a French-Algerian young man\", \"from\": 3266, \"to\": 3293}, {\"ngram\": \"the story\", \"from\": 3314, \"to\": 3323}, {\"ngram\": \"his grandfather's protest\", \"from\": 3327, \"to\": 3352}, {\"ngram\": \"the massacre day\", \"from\": 3356, \"to\": 3372}, {\"ngram\": \"toTNA\", \"from\": 3383, \"to\": 3388}]}, {\"sentence\": \"Similarly, many other Algerians and North Africanstookto social media to voice their frustration.\", \"from\": 3391, \"to\": 3488, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Similarly, many other Algerians\", \"from\": 3391, \"to\": 3422}, {\"ngram\": \"North Africanstookto social media\", \"from\": 3427, \"to\": 3460}, {\"ngram\": \"their frustration\", \"from\": 3470, \"to\": 3487}]}, {\"sentence\": \"During more than 132 years of colonisation, France killed between 400,000 and 1.5 million Algerians, in one of its bloodiest colonial conquests in Africa's history.\", \"from\": 3490, \"to\": 3654, \"entities\": [{\"begin\": 3534, \"end\": 3540, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.7882027045681219, \"rank\": 0.2687068392401943, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"more than 132 years\", \"from\": 3497, \"to\": 3516}, {\"ngram\": \"colonisation\", \"from\": 3520, \"to\": 3532}, {\"ngram\": \"between 400,000 and 1.5 million Algerians\", \"from\": 3548, \"to\": 3589}, {\"ngram\": \"its bloodiest colonial conquests\", \"from\": 3601, \"to\": 3633}, {\"ngram\": \"Africa's history\", \"from\": 3637, \"to\": 3653}]}, {\"sentence\": \"Sixty-two years since the liberation of Algeria, France has not owned up to the crimes its army and police committed during the war.\", \"from\": 3656, \"to\": 3788, \"entities\": [{\"begin\": 3696, \"end\": 3703, \"title\": \"http://dbpedia.org/resource/Algerian_War\", \"score\": 0.9999880262087755, \"rank\": 1.1973927466366647e-05, \"text\": \"Algeria\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/Algerian_War\", \"dbpedia\": \"http://dbpedia.org/resource/Algerian_War\"}, {\"begin\": 3705, \"end\": 3711, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.7882027045681219, \"rank\": 0.2687068392401943, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"the liberation\", \"from\": 3678, \"to\": 3692}, {\"ngram\": \"the crimes\", \"from\": 3732, \"to\": 3742}, {\"ngram\": \"its army\", \"from\": 3743, \"to\": 3751}, {\"ngram\": \"police\", \"from\": 3756, \"to\": 3762}, {\"ngram\": \"the war\", \"from\": 3780, \"to\": 3787}]}, {\"sentence\": \"Are abused migrant workers the dirty secret of Paris Olympics?\", \"from\": 3790, \"to\": 3852, \"entities\": [{\"begin\": 3837, \"end\": 3851, \"title\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Paris Olympics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/1924_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"migrant workers\", \"from\": 3801, \"to\": 3816}, {\"ngram\": \"the dirty secret\", \"from\": 3817, \"to\": 3833}]}, {\"sentence\": \"As a candidate for the presidency, Macron was one of the few Parisian politicians to break the silence on France's \\\"crimes against humanity\\\" in Algeria.\", \"from\": 3854, \"to\": 4006, \"entities\": [{\"begin\": 3889, \"end\": 3895, \"title\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"score\": 1.0, \"rank\": 1.9075152500400446e-43, \"text\": \"Macron\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"dbpedia\": \"http://dbpedia.org/resource/Emmanuel_Macron\"}, {\"begin\": 3960, \"end\": 3966, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.7882027045681219, \"rank\": 0.2687068392401943, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 3998, \"end\": 4005, \"title\": \"http://dbpedia.org/resource/Algerian_War\", \"score\": 0.9999880262087755, \"rank\": 1.1973927466366647e-05, \"text\": \"Algeria\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/Algerian_War\", \"dbpedia\": \"http://dbpedia.org/resource/Algerian_War\"}], \"noun_phrases\": [{\"ngram\": \"a candidate\", \"from\": 3857, \"to\": 3868}, {\"ngram\": \"the presidency\", \"from\": 3873, \"to\": 3887}, {\"n