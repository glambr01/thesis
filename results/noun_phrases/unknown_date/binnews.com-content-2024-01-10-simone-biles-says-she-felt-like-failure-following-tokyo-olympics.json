ce\": \"However, Biles said she did not like how the public put her on a \\\"pedestal as a mental-health advocate.\\\"\", \"from\": 951, \"to\": 1055, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Biles\", \"from\": 960, \"to\": 965}, {\"ngram\": \"the public\", \"from\": 992, \"to\": 1002}, {\"ngram\": \"a \\\"pedestal\", \"from\": 1014, \"to\": 1025}, {\"ngram\": \"a mental-health advocate\", \"from\": 1029, \"to\": 1053}]}, {\"sentence\": \"\\\"I was not okay with that,\\\" she said.\", \"from\": 1057, \"to\": 1094, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"\\\"If I can be a lending hand and help people, then I will be open, honest, and vulnerable, but you cannot stick me in front of a crowd and say, 'Do everything she's doing.'\", \"from\": 1095, \"to\": 1266, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a lending hand\", \"from\": 1108, \"to\": 1122}, {\"ngram\": \"people\", \"from\": 1132, \"to\": 1138}, {\"ngram\": \"front\", \"from\": 1212, \"to\": 1217}, {\"ngram\": \"a crowd\", \"from\": 1221, \"to\": 1228}, {\"ngram\": \"everything\", \"from\": 1242, \"to\": 1252}]}, {\"sentence\": \"\\\" Since pulling out of the Tokyo Olympics, Biles said she has overcome her fear and is ready for the 2024 Summer Olympics if she's called on.\", \"from\": 1267, \"to\": 1409, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the Tokyo Olympics\", \"from\": 1290, \"to\": 1308}, {\"ngram\": \"Biles\", \"from\": 1310, \"to\": 1315}, {\"ngram\": \"her fear\", \"from\": 1338, \"to\": 1346}, {\"ngram\": \"the 2024 Summer Olympics\", \"from\": 1364, \"to\": 1388}]}, {\"sentence\": \"\\\"If I do not make it to Paris, it will not absolutely crush me,\\\" Biles told Vanity Fair.\", \"from\": 1411, \"to\": 1499, \"entities\": [{\"begin\": 1435, \"end\": 1440, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999997087875696, \"rank\": 2.912125612157675e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resourc