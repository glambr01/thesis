23, \"to\": 4426}, {\"ngram\": \"sexual orientation\", \"from\": 4438, \"to\": 4456}, {\"ngram\": \"gender identity\", \"from\": 4458, \"to\": 4473}, {\"ngram\": \"pregnancy\", \"from\": 4478, \"to\": 4487}]}, {\"sentence\": \"It also protects against unequal treatment based on reproductive healthcare and autonomy.\\\"\", \"from\": 4489, \"to\": 4579, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"unequal treatment\", \"from\": 4514, \"to\": 4531}, {\"ngram\": \"reproductive healthcare\", \"from\": 4541, \"to\": 4564}, {\"ngram\": \"autonomy\", \"from\": 4569, \"to\": 4577}]}, {\"sentence\": \"A\\\"yes\\\"vote puts these protections in the New York state constitution.\", \"from\": 4581, \"to\": 4650, \"entities\": [{\"begin\": 4622, \"end\": 4630, \"title\": \"http://dbpedia.org/resource/New_York_City\", \"score\": 0.9997289311649469, \"rank\": 0.00018183002109136695, \"text\": \"New York\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/New_York_City\", \"dbpedia\": \"http://dbpedia.org/resource/New_York_City\"}], \"noun_phrases\": [{\"ngram\": \"these protections\", \"from\": 4597, \"to\": 4614}]}, {\"sentence\": \"A\\\"no\\\"vote leaves these protections out of the state constitution.\", \"from\": 4651, \"to\": 4716, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A\\\"no\\\"vote\", \"from\": 4651, \"to\": 4660}, {\"ngram\": \"these protections\", \"from\": 4668, \"to\": 4685}, {\"ngram\": \"the state constitution\", \"from\": 4693, \"to\": 4715}]}, {\"sentence\": \"On the county level, there is only one contested race for Essex County Judge between Lake Placid attorney Bryan Liam Kennelly on the Democrat and Working Families party lines and Essex County District Attorney Kristy Sprague on the Republican and Conservative lines.\", \"from\": 4718, \"to\": 4984, \"entities\": [{\"begin\": 4776, \"end\": 4788, \"title\": \"http://dbpedia.org/resource/Essex\", \"score\": 0.9986205078963407, \"rank\": 0.0013813977307621233, \"text\