, {\"begin\": 195, \"end\": 200, \"title\": \"http://dbpedia.org/resource/Gallo_Record_Company\", \"score\": 0.9999999003102907, \"rank\": 9.949739954542454e-08, \"text\": \"Gallo\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\", \"Q18127\"], \"wikid\": \"http://dbpedia.org/resource/Gallo_Record_Company\", \"dbpedia\": \"http://dbpedia.org/resource/Gallo_Record_Company\"}, {\"begin\": 266, \"end\": 278, \"title\": \"http://dbpedia.org/resource/South_Africa\", \"score\": 1.0, \"rank\": 5.50874947774816e-31, \"text\": \"South Africa\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/South_Africa\", \"dbpedia\": \"http://dbpedia.org/resource/South_Africa\"}, {\"begin\": 311, \"end\": 316, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.1404448179296765e-15, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Picture\", \"from\": 171, \"to\": 178}, {\"ngram\": \"A total\", \"from\": 208, \"to\": 215}, {\"ngram\": \"75 athletes\", \"from\": 219, \"to\": 230}, {\"ngram\": \"nine sports\", \"from\": 234, \"to\": 245}, {\"ngram\": \"the Olympic Games\", \"from\": 289, \"to\": 306}]}, {\"sentence\": \"After unveiling aninitial group of 39 athleteslast month, the latest additions announced by the SA Sports Confederation and Olympic Committee (Sascoc) on Wednesday night have increased the size of the provisional national team to 114 athletes in 15 codes, with one more squad announcement still to be made.\", \"from\": 330, \"to\": 636, \"entities\": [{\"begin\": 426, \"end\": 428, \"title\": \"http://dbpedia.org/resource/South_Africa\", \"score\": 1.0, \"rank\": 4.681878973453476e-70, \"text\": \"SA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/South_Africa\", \"dbpedia\": \"http://dbpedia.org/resource/South_Africa\"}], \"noun_phrases\": [{\"ngram\": \"aninitial group\", \"from\": 346, \"to\": 361}, {\"ngram\": \"39 athleteslast month\", \"from\": 365, \"to\": 386}, {\"ngram\": \"the latest additions\", \"from\": 388, \"to\": 408}, {\"ngram\": \"Olympic Committee\", \"from\": 454, \"to\": 471}, {\"ngram\": \"Sascoc\", \"from\": 473, \"to\": 479}, {\"ngram\": \"Wednesday night\", \"from\": 484, \"to\": 499}, {\"ngram\": \"the size\", \"from\": 515, \"to\": 523}, {\"ngram\": \"the provisional national team\", \"from\": 527, \"to\": 556}, {\"ngram\": \"114 athletes\", \"from\": 560, \"to\": 572}, {\"ngram\": \"15 codes\", \"from\": 576, \"to\": 584}, {\"ngram\": \"one more squad announcement\", \"from\": 591, \"to\": 618}]}, {\"sentence\": \"ALSO READ:Team SA kit unveiled for Paris Olympics Seven athletes have been added to the athletics squad, which now consists of 24 individuals.\", \"from\": 638, \"to\": 781, \"entities\": [{\"begin\": 653, \"end\": 655, \"title\": \"http://dbpedia.org/resource/South_Africa\", \"score\": 1.0, \"rank\": 4.681878973453476e-70, \"text\": \"SA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/South_Africa\", \"dbpedia\": \"http://dbpedia.org/resource/South_Africa\"}, {\"begin\": 673, \"end\": 687, \"title\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Paris Olympics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/1924_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"the athletics squad\", \"from\": 722, \"to\": 741}, {\"ngram\": \"24 individuals\", \"from\": 765, \"to\": 779}]}, {\"sentence\": \"Along with five sprinters who have boosted the men's 4x100m and 4x400m relay teams, the squad's new additions also includemarathon runner Elroy Gelantand discus thrower Francois Prinsloo.\", \"from\": 782, \"to\": 969, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"five sprinters\", \"from\": 793, \"to\": 807}, {\"ngram\": \"the men's 4x100m\", \"from\": 825, \"to\": 841}, {\"ngram\": \"m relay teams\", \"from\": 851, \"to\": 864}, {\"ngram\": \"the squad's new additions\", \"from\": 866, \"to\": 891}]}, {\"sentence\": \"The three-member triathlon team includes former Olympic bronze medallist Henri Schoeman, while the seven-strong cycling team features experienced road specialist Ashleigh Moolman Pasio and cross country riders Alan Hatherley and Candice Lill.\", \"from\": 971, \"to\": 1213, \"entities\": [{\"begin\": 1044, \"end\": 1058, \"title\": \"http://dbpedia.org/resource/Henri_Schoeman\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Henri Schoeman\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Henri_Schoeman\", \"dbpedia\": \"http://dbpedia.org/resource/Henri_Schoeman\"}, {\"begin\": 1133, \"end\": 1149, \"title\": \"http://dbpedia.org/resource/Ashleigh_Moolman\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Ashleigh Moolman\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Ashleigh_Moolman\", \"dbpedia\": \"http://dbpedia.org/resource/Ashleigh_Moolman\"}], \"noun_phrases\": [{\"ngram\": \"The three-member triathlon team\", \"from\": 971, \"to\": 1002}, {\"ngram\": \"the seven-strong cycling team\", \"from\": 1066, \"to\": 1095}, {\"ngram\": \"Candice Lill\", \"from\": 1200, \"to\": 1212}]}, {\"sentence\": \"The men's pair of John Smith (a former gold medallist in the men's four) and Christopher Baxter will represent the country in rowing.\", \"from\": 1215, \"to\": 1348, \"entities\": [{\"begin\": 1233, \"end\": 1243, \"title\": \"http://dbpedia.org/resource/John_Smith_(explorer)\", \"score\": 0.7271469534497925, \"rank\": 0.2756449933546725, \"text\": \"John Smith\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/John_Smith_(explorer)\", \"dbpedia\": \"http://dbpedia.org/resource/John_Smith_(explorer)\"}, {\"begin\": 1304, \"end\": 1310, \"title\": \"http://dbpedia.org/resource/Baxter_International\", \"score\": 0.9970625056526002, \"rank\": 0.002946133688169343, \"text\": \"Baxter\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Baxter_International\", \"dbpedia\": \"http://dbpedia.org/resource/Baxter_International\"}], \"noun_phrases\": [{\"ngram\": \"The men's pair\", \"from\": 1215, \"to\": 1229}, {\"ngram\": \"a former gold medallist\", \"from\": 1245, \"to\": 1268}, {\"ngram\": \"the country\", \"from\": 1326, \"to\": 1337}]}, {\"sentence\": \"In team sports, the provisional SA women's rugby sevens squad features 16 athletes (a final team will be announced before the end of June), while 32 players have been confirmed in the men's and women's hockey sides.\", \"from\": 1350, \"to\": 1565, \"entities\": [{\"begin\": 1382, \"end\": 1384, \"title\": \"http://dbpedia.org/resource/South_Africa\", \"score\": 1.0, \"rank\": 4.681878973453476e-70, \"text\": \"SA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/South_Africa\", \"dbpedia\": \"http://dbpedia.org/resource/South_Africa\"}], \"noun_phrases\": [{\"ngram\": \"team sports\", \"from\": 1353, \"to\": 1364}, {\"ngram\": \"16 athletes\", \"from\": 1421, \"to\": 1432}, {\"ngram\": \"a final team\", \"from\": 1434, \"to\": 1446}, {\"ngram\": \"the end\", \"from\": 1472, \"to\": 1479}, {\"ngram\": \"June\", \"from\": 1483, \"to\": 1487}, {\"ngram\": \"32 players\", \"from\": 1496, \"to\": 1506}, {\"ngram\": \"the men's and women's hockey sides\", \"from\": 1530, \"to\": 1564}]}, {\"sentence\": \"Other athletes were also added to the national team for theParis Gamesin archery, badminton and fencing, and a total of six reserves were included in athletics and hockey.\", \"from\": 1567, \"to\": 1738, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Other athletes\", \"from\": 1567, \"to\": 1581}, {\"ngram\": \"the national team\", \"from\": 1601, \"to\": 1618}, {\"ngram\": \"theParis Gamesin archery\",