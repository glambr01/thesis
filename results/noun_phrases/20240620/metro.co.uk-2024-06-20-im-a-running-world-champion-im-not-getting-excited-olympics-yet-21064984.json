"{\"uid\": \"metro.co.uk-2024-06-20-im-a-running-world-champion-im-not-getting-excited-olympics-yet-21064984\", \"noun_phrases\": [{\"sentence\": \"Parkrun is great.\", \"from\": 0, \"to\": 17, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Parkrun\", \"from\": 0, \"to\": 7}]}, {\"sentence\": \"There is probably one within 10 miles of wherever you live in this country.\", \"from\": 18, \"to\": 93, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"10 miles\", \"from\": 47, \"to\": 55}, {\"ngram\": \"this country\", \"from\": 80, \"to\": 92}]}, {\"sentence\": \"And I love that an Olympian can stand on the same startline as someone pushing a buggy.\", \"from\": 94, \"to\": 181, \"entities\": [{\"begin\": 113, \"end\": 121, \"title\": \"http://dbpedia.org/resource/Olympic_Games\", \"score\": 0.9999997920454223, \"rank\": 2.0793265972711102e-07, \"text\": \"Olympian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games\"}], \"noun_phrases\": [{\"ngram\": \"the same startline\", \"from\": 135, \"to\": 153}, {\"ngram\": \"someone\", \"from\": 157, \"to\": 164}, {\"ngram\": \"a buggy\", \"from\": 173, \"to\": 180}]}, {\"sentence\": \"You would not getLionel Messiturning up at Goals in Bexleyheath to have a kickabout, would you?\", \"from\": 183, \"to\": 278, \"entities\": [{\"begin\": 235, \"end\": 246, \"title\": \"http://dbpedia.org/resource/Bexleyheath\", \"score\": 0.9999999999577085, \"rank\": 2.6038528395262864e-11, \"text\": \"Bexleyheath\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Bexleyheath\", \"dbpedia\": \"http://dbpedia.org/resource/Bexleyheath\"}], \"noun_phrases\": [{\"ngram\": \"Messiturning\", \"from\": 207, \"to\": 219}, {\"ngram\": \"Goals\", \"from\": 226, \"to\": 231}, {\"ngram\": \"a kickabout\", \"from\": 255, \"to\": 266}]}, {\"sentence\": \"But it's cool when people see you in the same race as them.\", \"from\": 279, \"to\": 338, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"people\", \"from\": 298, \"to\": 304}, {\"ngram\": \"the same race\", \"from\": 316, \"to\": 329}]}, {\"sentence\": \"I am proud to say I have done one a year since I was 16.\", \"from\": 340, \"to\": 396, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"It's class.\", \"from\": 397, \"to\": 408, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"class\", \"from\": 402, \"to\": 407}]}, {\"sentence\": \"I have helped out at Bushy Park as well as done the race itself.\", \"from\": 409, \"to\": 473, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Bushy Park\", \"from\": 430, \"to\": 440}, {\"ngram\": \"the race\", \"from\": 457, \"to\": 465}]}, {\"sentence\": \"They are pretty supportive there as they see me as 'one of their own'.\", \"from\": 474, \"to\": 544, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"At the same time, people do not bother me too much and just let me get on with running.\", \"from\": 546, \"to\": 633, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the same time\", \"from\": 549, \"to\": 562}, {\"ngram\": \"people\", \"from\": 564, \"to\": 570}]}, {\"sentence\": \"I still want a hard race after all.\", \"from\": 634, \"to\": 669, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a hard race\", \"from\": 647, \"to\": 658}]}, {\"sentence\": \"The thing with parkrun is it's not a massive demand on your weekend.\", \"from\": 671, \"to\": 739, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The thing\", \"from\": 671, \"to\": 680}, {\"ngram\": \"parkrun\", \"from\": 686, \"to\": 693}, {\"ngram\": \"a massive demand\", \"from\": 706, \"to\": 722}, {\"ngram\": \"your weekend\", \"from\": 726, \"to\": 738}]}, {\"sentence\": \"It starts at 9am and you still have everything else waiting for you after you cross the finish line.\", \"from\": 740, \"to\": 840, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"everything\", \"from\": 776, \"to\": 786}, {\"ngram\": \"the finish line\", \"from\": 824, \"to\": 839}]}, {\"sentence\": \"There is also such a great sense of community.\", \"from\": 842, \"to\": 888, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"such a great sense\", \"from\": 856, \"to\": 874}, {\"ngram\": \"community\", \"from\": 878, \"to\": 887}]}, {\"sentence\": \"Everybody is on their own journey, nobody's judging anyone, and of coursedon't forget the social element to it.\", \"from\": 889, \"to\": 1000, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Everybody\", \"from\": 889, \"to\": 898}, {\"ngram\": \"their own journey\", \"from\": 905, \"to\": 922}, {\"ngram\": \"nobody\", \"from\": 924, \"to\": 930}, {\"ngram\": \"anyone\", \"from\": 941, \"to\": 947}, {\"ngram\": \"coursedon't\", \"from\": 956, \"to\": 967}, {\"ngram\": \"the social element\", \"from\": 975, \"to\": 993}]}, {\"sentence\": \"Joining parkrun is free - it does not matter if you are a keen runner, a jogger, a walker, a social stroller or are keen to volunteer and cheer from the sidelines.\", \"from\": 1002, \"to\": 1165, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Joining parkrun\", \"from\": 1002, \"to\": 1017}, {\"ngram\": \"a keen runner\", \"from\": 1058, \"to\": 1071}, {\"ngram\": \"a jogger\", \"from\": 1073, \"to\": 1081}, {\"ngram\": \"a walker\", \"from\": 1083, \"to\": 1091}, {\"ngram\": \"a social stroller\", \"from\": 1093, \"to\": 1110}, {\"ngram\": \"the sidelines\", \"from\": 1151, \"to\": 1164}]}, {\"sentence\": \"Register for parkrun here.\", \"from\": 1167, \"to\": 1193, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"parkrun\", \"from\": 1180, \"to\": 1187}]}, {\"sentence\": \"Did we mention it's free (tick) and you only need to do it once (tick tick).\", \"from\": 1195, \"to\": 1271, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"free (tick\", \"from\": 1215, \"to\": 1225}]}, {\"sentence\": \"You also do not have to just do your local parkrun.\", \"from\": 1273, \"to\": 1324, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"your local parkrun\", \"from\": 1305, \"to\": 1323}]}, {\"sentence\": \"There are so many great places you can see by doing different ones around the country.\", \"from\": 1325, \"to\": 1411, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"so many great places\", \"from\": 1335, \"to\": 1355}, {\"ngram\": \"different ones\", \"from\": 1377, \"to\": 1391}, {\"ngram\": \"the country\", \"from\": 1399, \"to\": 1410}]}, {\"sentence\": \"My advice to anyone, whether you are going along for the first time or have done parkrun before, would be not to just get out of the car and run.\", \"from\": 1413, \"to\": 1558, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My advice\", \"from\": 1413, \"to\": 1422}, {\"ngram\": \"anyone\", \"from\": 1426, \"to\": 1432}, {\"ngram\": \"the first time\", \"from\": 1466, \"to\": 1480}, {\"ngram\": \"parkrun\", \"from\": 1494, \"to\": 1501}, {\"ngram\": \"the car\", \"from\": 1542, \"to\": 1549}]}, {\"sentence\": \"You need to do a warm-up, do some stretches and move around, jogging a little bit before you start.\", \"from\": 1560, \"to\": 1659, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a warm-up\", \"from\": 1575, \"to\": 1584}, {\"ngram\": \"some stretches\", \"from\": 1589, \"to\": 1603}]}, {\"sentence\": \"It is so, so important.\", \"from\": 1660, \"to\": 1683, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"The British Olympic trials take place next weekend and it is safe to say it is going to be as competitive - or almost as competitive - in Manchester as it will be in Paris for the Games themselves.\", \"from\": 1685, \"to\": 1882, \"entities\": [{\"begin\": 1689, \"end\": 1696, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9998146902956022, \"rank\": 0.00014072112304908962, \"text\": \"British\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}, {\"begin\": 1823, \"end\": 1833, \"title\": \"http://dbpedia.org/resource/Manchester\", \"score\": 0.9999999838719306, \"rank\": 1.2829808544008028e-08, \"text\": \"Manchester\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Manchester\", \"dbpedia\": \"http://dbpedia.org/resource/Manchester\"}, {\"begin\": 1851, \"end\": 1856, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999613701228, \"rank\": 3.862984579295617e-08, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"place\", \"from\": 1717, \"to\": 1722}, {\"ngram\": \"the Games\", \"from\": 1861, \"to\": 1870}]}, {\"sentence\": \"The 1500metres field will be so strong as we race for the three places on offer, the likes of my fellow Scots, current world champion Josh Kerr and Neil Gourley, lining up alongside me, all of us with gold-medal ambitions this summer.\", \"from\": 1884, \"to\": 2118, \"entities\": [{\"begin\": 2018, \"end\": 2022, \"title\": \"http://dbpedia.org/resource/Josh_Lyman\", \"score\": 0.9941618318754829, \"rank\": 0.005822337391265364, \"text\": \"Josh\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Josh_Lyman\", \"dbpedia\": \"http://dbpedia.org/resource/Josh_Lyman\"}], \"noun_phrases\": [{\"ngram\": \"The 1500metres field\", \"from\": 1884, \"to\": 1904}, {\"ngram\": \"the three places\", \"from\": 1938, \"to\": 1954}, {\"ngram\": \"offer\", \"from\": 1958, \"to\": 1963}, {\"ngram\": \"the likes\", \"from\": 1965, \"to\": 1974}, {\"ngram\": \"my fellow Scots\", \"from\": 1978, \"to\": 1993}, {\"ngram\": \"Neil Gourley\", \"from\": 2032, \"to\": 2044}, {\"ngram\": \"us\", \"from\": 2077, \"to\": 2079}, {\"ngram\": \"gold-medal ambitions\", \"from\": 2085, \"to\": 2105}]}, {\"sentence\": \"There is a lot of uncertainty for everybody.\", \"from\": 2120, \"to\": 2164, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a lot\", \"from\": 2129, \"to\": 2134}, {\"ngram\": \"uncertainty\", \"from\": 2138, \"to\": 2149}, {\"ngram\": \"everybody\", \"from\": 2154, \"to\": 2163}]}, {\"sentence\": \"You can not make plans to go to the Olympics until you are picked.\", \"from\": 2165, \"to\": 2231, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"plans\", \"from\": 2182, \"to\": 2187}, {\"ngram\": \"the Olympics\", \"from\": 2197, \"to\": 2209}]}, {\"sentence\": \"The first three go, it's as simple as that.\", \"from\": 2232, \"to\": 2275, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"You have to bring yourself up to the standard of the race.\", \"from\": 2277, \"to\": 2335, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the standard\", \"from\": 2310, \"to\": 2322}, {\"ngram\": \"the race\", \"from\": 2326, \"to\": 2334}]}, {\"sentence\": \"A lot of people have shown the potential to run fast but all I can do is race.\", \"from\": 2336, \"to\": 2414, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A lot\", \"from\": 2336, \"to\": 2341}, {\"ngram\": \"people\", \"from\": 2345, \"to\": 2351}, {\"ngram\": \"the potential\", \"from\": 2363, \"to\": 2376}, {\"ngram\": \"race\", \"from\": 2409, \"to\": 2413}]}, {\"sentence\": \"Josh and the European champion Jakob Ingebrigtsen have been known to share some trash talk but that's not for me.\", \"from\": 2416, \"to\": 2529, \"entities\": [{\"begin\": 2416, \"end\": 2420, \"title\": \"http://dbpedia.org/resource/Josh_Lyman\", \"score\": 0.9941618318754829, \"rank\": 0.005822337391265364, \"text\": \"Josh\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Josh_Lyman\", \"dbpedia\": \"http://dbpedia.org/resource/Josh_Lyman\"}, {\"begin\": 2429, \"end\": 2446, \"title\": \"http://dbpedia.org/resource/European_Athletics_Championships\", \"score\": 0.9999997978602755, \"rank\": 2.0190777177034084e-07, \"text\": \"European champion\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/European_Athletics_Championships\", \"dbpedia\": \"http://dbpedia.org/resource/European_Athletics_Championships\"}, {\"begin\": 2447, \"end\": 2465, \"title\": \"http://dbpedia.org/resource/Jakob_Ingebrigtsen\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Jakob Ingebrigtsen\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jakob_Ingebrigtsen\", \"dbpedia\": \"http://dbpedia.org/resource/Jakob_Ingebrigtsen\"}], \"noun_phrases\": [{\"ngram\": \"some trash talk\", \"from\": 2491, \"to\": 2506}]}, {\"sentence\": \"I believe the Olympic title will not be fought out just between them when it comes down to it.\", \"from\": 2530, \"to\": 2624, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the Olympic title\", \"from\": 2540, \"to\": 2557}]}, {\"sentence\": \"However, the main thing for me is to focus on qualifying next weekend.\", \"from\": 2625, \"to\": 2695, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the main thing\", \"from\": 2634, \"to\": 2648}]}, {\"sentence\": \"I can not look beyond that.\", \"from\": 2696, \"to\": 2723, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"The 1500m has a lot of attention on it right now and rightly so.\", \"from\": 2725, \"to\": 2789, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The 1500m\", \"from\": 2725, \"to\": 2734}, {\"ngram\": \"a lot\", \"from\": 2739, \"to\": 2744}, {\"ngram\": \"attention\", \"from\": 2748, \"to\": 2757}]}, {\"sentence\": \"It is a spotlight we are enjoying.\", \"from\": 2790, \"to\": 2824, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a spotlight\", \"from\": 2796, \"to\": 2807}]}, {\"sentence\": \"My belief is there are eight athletes who are in the mix for Olympic medals.\", \"from\": 2825, \"to\": 2901, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My belief\", \"from\": 2825, \"to\": 2834}, {\"ngram\": \"eight athletes\", \"from\": 2848, \"to\": 2862}, {\"ngram\": \"the mix\", \"from\": 2874, \"to\": 2881}, {\"ngram\": \"Olympic medals\", \"from\": 2886, \"to\": 2900}]}, {\"sentence\": \"Fitness-wise, I am as good as I would have hoped to be at this point.\", \"from\": 2903, \"to\": 2972, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this point\", \"from\": 2961, \"to\": 2971}]}, {\"sentence\": \"Like Josh, I chose not to compete at the European Championships earlier this month.\", \"from\": 2973, \"to\": 3056, \"entities\": [{\"begin\": 2978, \"end\": 2982, \"title\": \"http://dbpedia.org/resource/Josh_Lyman\", \"score\": 0.9941618318754829, \"rank\": 0.005822337391265364, \"text\": \"Josh\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Josh_Lyman\", \"dbpedia\": \"http://dbpedia.org/resource/Josh_Lyman\"}], \"noun_phrases\": [{\"ngram\": \"the European Championships\", \"from\": 3010, \"to\": 3036}]}, {\"sentence\": \"But I have probably not given the best account of myself yet so I am looking forward to the trials.\", \"from\": 3057, \"to\": 3156, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the best account\", \"from\": 3087, \"to\": 3103}, {\"ngram\": \"the trials\", \"from\": 3145, \"to\": 3155}]}, {\"sentence\": \"I can not get complacent and miss out on an Olympic Games but I feel I am on the right track.\", \"from\": 3158, \"to\": 3251, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an Olympic Games\", \"from\": 3199, \"to\": 3215}, {\"ngram\": \"the right track\", \"from\": 3235, \"to\": 3250}]}, {\"sentence\": \"It is about being as adaptable as possible and keeping an open mind on multiple scenarios in Manchester.\", \"from\": 3252, \"to\": 3356, \"entities\": [{\"begin\": 3345, \"end\": 3355, \"title\": \"http://dbpedia.org/resource/Manchester\", \"score\": 0.9999999838719306, \"rank\": 1.2829808544008028e-08, \"text\": \"Manchester\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Manchester\", \"dbpedia\": \"http://dbpedia.org/resource/Manchester\"}], \"noun_phrases\": [{\"ngram\": \"an open mind\", \"from\": 3307, \"to\": 3319}, {\"ngram\": \"multiple scenarios\", \"from\": 3323, \"to\": 3341}]}, {\"sentence\": \"It's often pretty rainy there and windy too, so you do not want to be the one who comes and takes the race out fast.\", \"from\": 3357, \"to\": 3473, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the race\", \"from\": 3455, \"to\": 3463}]}, {\"sentence\": \"Trials is stressful.\", \"from\": 3475, \"to\": 3495, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Trials\", \"from\": 3475, \"to\": 3481}]}, {\"sentence\": \"It's not an enjoyable weekend because of what is at stake and there will a sense of relief for sure when it's done and hopefully you have made it through.\", \"from\": 3496, \"to\": 3650, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an enjoyable weekend\", \"from\": 3505, \"to\": 3525}, {\"ngram\": \"stake\", \"from\": 3548, \"to\": 3553}, {\"ngram\": \"a sense\", \"from\": 3569, \"to\": 3576}, {\"ngram\": \"relief\", \"from\": 3580, \"to\": 3586}]}, {\"sentence\": \"Then, and only then, can you allow yourself to focus on the main one in Paris.\", \"from\": 3652, \"to\": 3730, \"entities\": [{\"begin\": 3724, \"end\": 3729, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999613701228, \"rank\": 3.862984579295617e-08, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": []}, {\"sentence\": \"I see trials as more of an obstacle than somewhere to peak for.\", \"from\": 3731, \"to\": 3794, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"trials\", \"from\": 3737, \"to\": 3743}, {\"ngram\": \"an obstacle\", \"from\": 3755, \"to\": 3766}]}, {\"sentence\": \"There is no doubt Manchester will be racing in its purest form and I hope to come through to the other side.\", \"from\": 3795, \"to\": 3903, \"entities\": [{\"begin\": 3813, \"end\": 3823, \"title\": \"http://dbpedia.org/resource/Manchester\", \"score\": 0.9999999838719306, \"rank\": 1.2829808544008028e-08, \"text\": \"Manchester\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Manchester\", \"dbpedia\": \"http://dbpedia.org/resource/Manchester\"}], \"noun_phrases\": [{\"ngram\": \"its purest form\", \"from\": 3842, \"to\": 3857}, {\"ngram\": \"the other side\", \"from\": 3888, \"to\": 3902}]}, {\"sentence\": \"Britain's former 1500m world champion writes for Metro ahead of the Olympic Games.\", \"from\": 3905, \"to\": 3987, \"entities\": [{\"begin\": 3905, \"end\": 3912, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9999370616163161, \"rank\": 6.187606956215568e-05, \"text\": \"Britain\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"Metro\", \"from\": 3954, \"to\": 3959}, {\"ngram\": \"the Olympic Games\", \"from\": 3969, \"to\": 3986}]}, {\"sentence\": \"Jake receives funding from The National Lottery, which raises more than \\u00a330m a week for good causes including vital funding into sport, from grassroots to elite level.\", \"from\": 3988, \"to\": 4155, \"entities\": [{\"begin\": 3988, \"end\": 3992, \"title\": \"http://dbpedia.org/resource/Animorphs\", \"score\": 0.9999234980201791, \"rank\": 6.496061401050627e-05, \"text\": \"Jake\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Animorphs\", \"dbpedia\": \"http://dbpedia.org/resource/Animorphs\"}, {\"begin\": 4015, \"end\": 4035, \"title\": \"http://dbpedia.org/resource/National_Lottery_(United_Kingdom)\", \"score\": 0.9999999999290594, \"rank\": 0.0, \"text\": \"The National Lottery\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/National_Lottery_(United_Kingdom)\", \"dbpedia\": \"http://dbpedia.org/resource/National_Lottery_(United_Kingdom)\"}], \"noun_phrases\": [{\"ngram\": \"funding\", \"from\": 4002, \"to\": 4009