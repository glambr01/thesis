gram\": \"his Saint-Denis office\", \"from\": 3982, \"to\": 4004}]}, {\"sentence\": \"\\\"The power of the Games is to make sure that there is a good place for (track and field), for swimming, for gymnastics, for basketball, for volleyball, for handball, for judo, for 54 sports.\\\"\", \"from\": 4006, \"to\": 4197, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The power\", \"from\": 4007, \"to\": 4016}, {\"ngram\": \"the Games\", \"from\": 4020, \"to\": 4029}, {\"ngram\": \"a good place\", \"from\": 4060, \"to\": 4072}, {\"ngram\": \"track\", \"from\": 4078, \"to\": 4083}, {\"ngram\": \"field\", \"from\": 4088, \"to\": 4093}, {\"ngram\": \"swimming\", \"from\": 4100, \"to\": 4108}, {\"ngram\": \"gymnastics\", \"from\": 4114, \"to\": 4124}, {\"ngram\": \"basketball\", \"from\": 4130, \"to\": 4140}, {\"ngram\": \"volleyball\", \"from\": 4146, \"to\": 4156}, {\"ngram\": \"handball\", \"from\": 4162, \"to\": 4170}, {\"ngram\": \"judo\", \"from\": 4176, \"to\": 4180}, {\"ngram\": \"54 sports\", \"from\": 4186, \"to\": 4195}]}, {\"sentence\": \"The International Olympic Committee groups sports by popularity, and the most important get the most money and preference, according to the Association of Summer Olympic International Federations.\", \"from\": 4199, \"to\": 4395, \"entities\": [{\"begin\": 4203, \"end\": 4234, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"popularity\", \"from\": 4252, \"to\": 4262}, {\"ngram\": \"the most money\", \"from\": 4291, \"to\": 4305}, {\"ngram\": \"preference\", \"from\": 4310, \"to\": 4320}, {\"ngram\": \"the Association\", \"from\": 4335, \"to\": 4350}, {\"ngram\": \"Summer Olympic International Federations\", \"from\": 4354, \"to\": 4394}]}, {\"sentence\": \"Gymnastics is one of three sports in the top group, with swimming and track and field, while basketball is in the second grouping.\", \"from\": 4396, \"to\": 4526, \"entities\": [{\"begin\": 4396, \"end\": 4406, \"title\": \"http://dbpedia.org/resource/Gymnastics\", \"score\": 0.999999995705366, \"rank\": 4.2949770006457475e-09, \"text\": \"Gymnastics\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Gymnastics\", \"dbpedia\": \"http://dbpedia.org/resource/Gymnastics\"}], \"noun_phrases\": [{\"ngram\": \"three sports\", \"from\": 4417, \"to\": 4429}, {\"ngram\": \"the top group\", \"from\": 4433, \"to\": 4446}, {\"ngram\": \"swimming\", \"from\": 4453, \"to\": 4461}, {\"ngram\": \"track\", \"from\": 4466, \"to\": 4471}, {\"ngram\": \"field\", \"from\": 4476, \"to\": 4481}, {\"ngram\": \"basketball\", \"from\": 4489, \"to\": 4499}, {\"ngram\": \"the second grouping\", \"from\": 4506, \"to\": 4525}]}, {\"sentence\": \"Multiple presidents of basketball federations around the world say the IOC's tiered system is why gymnastics has often been staged in arenas that are normally used for hoops outside the Olympics.\", \"from\": 4527, \"to\": 4722, \"entities\": [{\"begin\": 4598, \"end\": 4601, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.730459367470642e-49, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"Multiple presidents\", \"from\": 4527, \"to\": 4546}, {\"ngram\": \"basketball federations\", \"from\": 4550, \"to\": 4572}, {\"ngram\": \"the world\", \"from\": 4580, \"to\": 4589}, {\"ngram\": \"gymnastics\", \"from\": 4625, \"to\": 4635}, {\"ngram\": \"arenas\", \"from\": 4661, \"to\": 4667}, {\"ngram\": \"hoops\", \"from\": 4695, \"to\": 4700}, 