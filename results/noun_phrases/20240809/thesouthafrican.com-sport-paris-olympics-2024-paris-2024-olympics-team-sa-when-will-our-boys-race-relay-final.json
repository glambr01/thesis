79}, {\"ngram\": \"the man\", \"from\": 883, \"to\": 890}, {\"ngram\": \"the moment\", \"from\": 894, \"to\": 904}, {\"ngram\": \"a surprise late inclusion\", \"from\": 913, \"to\": 938}, {\"ngram\": \"their 4x400m relay team\", \"from\": 942, \"to\": 965}]}, {\"sentence\": \"Immediately they become strong contenders.\", \"from\": 967, \"to\": 1009, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"strong contenders\", \"from\": 991, \"to\": 1008}]}, {\"sentence\": \"21-year-old Letsile Tebogo produced the run of his life to claim gold in a much-anticipated 200m event.\", \"from\": 1011, \"to\": 1114, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"21-year-old Letsile Tebogo\", \"from\": 1011, \"to\": 1037}, {\"ngram\": \"the run\", \"from\": 1047, \"to\": 1054}, {\"ngram\": \"his life\", \"from\": 1058, \"to\": 1066}, {\"ngram\": \"gold\", \"from\": 1076, \"to\": 1080}, {\"ngram\": \"a much-anticipated 200m event\", \"from\": 1084, \"to\": 1113}]}, {\"sentence\": \"He was the fastest qualifier and the only man to go under 20 seconds in the semi-finals, so he was certainly expected to medal.\", \"from\": 1115, \"to\": 1242, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the only man\", \"from\": 1148, \"to\": 1160}, {\"ngram\": \"20 seconds\", \"from\": 1173, \"to\": 1183}, {\"ngram\": \"the semi\", \"from\": 1187, \"to\": 1195}, {\"ngram\": \"finals\", \"from\": 1196, \"to\": 1202}]}, {\"sentence\": \"However, 100m champion andAmerican superstar Noah Lyleswas the overwhelming favourite to claim gold alongside his compatriot Kenny Bednarek.\", \"from\": 1243, \"to\": 1383, \"entities\": [{\"begin\": 1368, \"end\": 1382, \"title\": \"http://dbpedia.org/resource/Kenny_Bednarek\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Kenny Bednarek\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kenny_Bednarek\", \"dbpedia\": \"http://dbpedia.org/resource/Kenny_Bednarek\"}], \"noun_phrases\": [{\"ngram\": \"100m champion