s\": [{\"ngram\": \"part\", \"from\": 735, \"to\": 739}, {\"ngram\": \"this competition\", \"from\": 743, \"to\": 759}, {\"ngram\": \"a woman\", \"from\": 767, \"to\": 774}, {\"ngram\": \"Khelif\", \"from\": 782, \"to\": 788}, {\"ngram\": \"a post-fight press conference\", \"from\": 792, \"to\": 821}]}, {\"sentence\": \"\\\"I was born a woman, I have lived as a woman and I have competed as a woman.\", \"from\": 824, \"to\": 900, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a woman\", \"from\": 836, \"to\": 843}, {\"ngram\": \"a woman\", \"from\": 861, \"to\": 868}, {\"ngram\": \"a woman\", \"from\": 892, \"to\": 899}]}, {\"sentence\": \"There is no doubt that there are enemies of success, and that gives my success a special taste because of these attacks.\\\"\", \"from\": 901, \"to\": 1022, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"no doubt\", \"from\": 910, \"to\": 918}, {\"ngram\": \"enemies\", \"from\": 934, \"to\": 941}, {\"ngram\": \"success\", \"from\": 945, \"to\": 952}, {\"ngram\": \"my success\", \"from\": 969, \"to\": 979}, {\"ngram\": \"a special taste\", \"from\": 980, \"to\": 995}, {\"ngram\": \"these attacks\", \"from\": 1007, \"to\": 1020}]}, {\"sentence\": \"The IBA had failed to provide any concrete evidence of the testing process or results at a chaotic press conference staged by the discredited governing body in Paris last week.\", \"from\": 1024, \"to\": 1200, \"entities\": [{\"begin\": 1028, \"end\": 1031, \"title\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\", \"score\": 0.9969103888267965, \"rank\": 0.0030962142877949046, \"text\": \"IBA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\", \"dbpedia\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\"}, {\"begin\": 1184, \"end\": 1189, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999890861, \"rank\": 1.0990162736571748e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"any concrete evidence\", \"from\": 1054, \"to\": 1075}, {\"ngram\": \"the testing process\", \"from\": 1079, \"to\": 1098}, {\"ngram\": \"results\", \"from\": 1102, \"to\": 1109}, {\"ngram\": \"a chaotic press conference\", \"from\": 1113, \"to\": 1139}, {\"ngram\": \"the discredited governing body\", \"from\": 1150, \"to\": 1180}]}, {\"sentence\": \"The IBA has been barred from involvement in each of the last two Olympic boxing tournaments by the IOC over financial and corruption concerns and its president Umar Kremlev has repeatedly railed against the governance of IOC president Thomas Bach.\", \"from\": 1202, \"to\": 1449, \"entities\": [{\"begin\": 1206, \"end\": 1209, \"title\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\", \"score\": 0.9969103888267965, \"rank\": 0.0030962142877949046, \"text\": \"IBA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\", \"dbpedia\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\"}, {\"begin\": 1301, \"end\": 1304, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 8.201249604539926e-29, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 1362, \"end\": 1366, \"title\": \"http://dbpedia.org/resource/Umar\", \"score\": 0.999997636564395, \"rank\": 2.3608304926800366e-06, \"text\": \"Umar\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Umar\", \"dbpedia\": \"http://dbpedia.org/resource/Umar\"}, {\"begin\": 1423, \"end\": 1426, \"title\": \"http://dbpedia.org/resource/International_Olympic_Com