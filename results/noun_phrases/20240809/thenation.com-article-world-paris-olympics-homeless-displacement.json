\"}, {\"begin\": 8442, \"end\": 8459, \"title\": \"http://dbpedia.org/resource/Seine-Saint-Denis\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Seine-Saint-Denis\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Seine-Saint-Denis\", \"dbpedia\": \"http://dbpedia.org/resource/Seine-Saint-Denis\"}, {\"begin\": 8614, \"end\": 8624, \"title\": \"http://dbpedia.org/resource/Parliament_of_Singapore\", \"score\": 0.9983439789085458, \"rank\": 0.0016483034801953267, \"text\": \"Parliament\", \"types\": [\"Q43229\", \"Q24229398\", \"Q11204\"], \"wikid\": \"http://dbpedia.org/resource/Parliament_of_Singapore\", \"dbpedia\": \"http://dbpedia.org/resource/Parliament_of_Singapore\"}], \"noun_phrases\": [{\"ngram\": \"memberAur\\u00e9lie Trouv\\u00e9\", \"from\": 8391, \"to\": 8411}, {\"ngram\": \"a district\", \"from\": 8428, \"to\": 8438}, {\"ngram\": \"an area\", \"from\": 8461, \"to\": 8468}, {\"ngram\": \"the city\", \"from\": 8472, \"to\": 8480}, {\"ngram\": \"the Games\", \"from\": 8500, \"to\": 8509}, {\"ngram\": \"us\", \"from\": 8516, \"to\": 8518}, {\"ngram\": \"The whole Olympic system\", \"from\": 8521, \"to\": 8545}, {\"ngram\": \"members\", \"from\": 8603, \"to\": 8610}, {\"ngram\": \"very few levers\", \"from\": 8634, \"to\": 8649}, {\"ngram\": \"resources\", \"from\": 8653, \"to\": 8662}, {\"ngram\": \"the impacts\", \"from\": 8672, \"to\": 8683}, {\"ngram\": \"the Olympics\", \"from\": 8687, \"to\": 8699}, {\"ngram\": \"the people\", \"from\": 8703, \"to\": 8713}, {\"ngram\": \"our cities\", \"from\": 8718, \"to\": 8728}, {\"ngram\": \"our ecosystems\", \"from\": 8733, \"to\": 8747}]}, {\"sentence\": \"This lack of accountability was very much on the mind of M\\u00e9decins du Monde outreach worker Brunnhilde Chellian.\", \"from\": 8751, \"to\": 8862, \"entities\": [{\"begin\": 8842, \"end\": 8852, \"title\": \"http://dbpedia.org/resource/Brunhild\", \"score\": 1.0, \"rank\": 1.1688351794489898e-57, \"text\": \"Brunnhilde\", \"types\": [], \"wi