edia.org/resource/Hilton_Worldwide\"}], \"noun_phrases\": [{\"ngram\": \"some people\", \"from\": 3421, \"to\": 3432}, {\"ngram\": \"XY chromosomes\", \"from\": 3443, \"to\": 3457}, {\"ngram\": \"the \\\"make-male\\\" gene\", \"from\": 3493, \"to\": 3513}]}, {\"sentence\": \"\\\"These people do not make testosterone.\", \"from\": 3516, \"to\": 3555, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"These people\", \"from\": 3517, \"to\": 3529}, {\"ngram\": \"testosterone\", \"from\": 3542, \"to\": 3554}]}, {\"sentence\": \"They develop a very typical female anatomy,\\\" Dr Hilton says.\", \"from\": 3556, \"to\": 3616, \"entities\": [{\"begin\": 3604, \"end\": 3610, \"title\": \"http://dbpedia.org/resource/Hilton_Worldwide\", \"score\": 1.0, \"rank\": 1.8878718190396046e-15, \"text\": \"Hilton\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Hilton_Worldwide\", \"dbpedia\": \"http://dbpedia.org/resource/Hilton_Worldwide\"}], \"noun_phrases\": [{\"ngram\": \"a very typical female anatomy\", \"from\": 3569, \"to\": 3598}]}, {\"sentence\": \"So a test that identifies XY chromosomes does not offer a complete picture.\", \"from\": 3618, \"to\": 3693, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a test\", \"from\": 3621, \"to\": 3627}, {\"ngram\": \"XY chromosomes\", \"from\": 3644, \"to\": 3658}, {\"ngram\": \"a complete picture\", \"from\": 3674, \"to\": 3692}]}, {\"sentence\": \"And in the case of Imane Khelif and Lin Yu-ting, the IBA has not disclosed details of the way they were tested.\", \"from\": 3694, \"to\": 3805, \"entities\": [{\"begin\": 3730, \"end\": 3741, \"title\": \"http://dbpedia.org/resource/Lin_Yu-ting\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Lin Yu-ting\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Lin_Yu-ting\", \"dbpedia\": \"http://dbpedia.org/resource/Lin_Yu-ting\"}, {\"begin\": 3747, \"end\": 3750, \"title\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\", \"score\": 0.9999999999954525, \"rank\": 4.341473310611913e-12, \"text\": \"IBA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\", \"dbpedia\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\"}], \"noun_phrases\": [{\"ngram\": \"the case\", \"from\": 3701, \"to\": 3709}, {\"ngram\": \"Imane Khelif\", \"from\": 3713, \"to\": 3725}, {\"ngram\": \"details\", \"from\": 3769, \"to\": 3776}, {\"ngram\": \"the way\", \"from\": 3780, \"to\": 3787}]}, {\"sentence\": \"However, Dr Hilton also says that in most people with DSD who have XY chromosomes, the SRY \\\"make-male\\\" gene is present.\", \"from\": 3807, \"to\": 3926, \"entities\": [{\"begin\": 3819, \"end\": 3825, \"title\": \"http://dbpedia.org/resource/Hilton_Worldwide\", \"score\": 1.0, \"rank\": 1.8878718190396046e-15, \"text\": \"Hilton\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Hilton_Worldwide\", \"dbpedia\": \"http://dbpedia.org/resource/Hilton_Worldwide\"}, {\"begin\": 3861, \"end\": 3864, \"title\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"score\": 0.8135295012280547, \"rank\": 0.22921172310346108, \"text\": \"DSD\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\"}], \"noun_phrases\": [{\"ngram\": \"most people\", \"from\": 3844, \"to\": 3855}, {\"ngram\": \"XY chromosomes\", \"from\": 3874, \"to\": 3888}, {\"ngram\": \"the SRY \\\"make-male\\\" gene\", \"from\": 3890, \"to\": 3914}]}, {\"sentence\": \"These people usually have testicles which are often inside the body.\", \"from\": 3928, \"to\": 3996, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"These people\", \"from\": 3928, \"to\": 3940}, {\"ngram\": \"testicles\", \"from\": 3954, \"to\": 3963}, {\"ngram\": \"the body\", \"from\": 3987, \"to\": 3995}]}, {\"sentence\": \"\\\"When they hit puberty they start producing testosterone - which is what underpins male advantage in sports,\\\" says Dr Hilton.\", \"from\": 3998, \"to\": 4123, \"entities\": [{\"begin\": 4116, \"end\": 4122, \"title\": \"http://dbpedia.org/resource/Hilton_Worldwide\", \"score\": 1.0, \"rank\": 1.8878718190396046e-15, \"text\": \"Hilton\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Hilton_Worldwide\", \"dbpedia\": \"http://dbpedia.org/resource/Hilton_Worldwide\"}], \"noun_phrases\": [{\"ngram\": \"puberty\", \"from\": 4013, \"to\": 4020}, {\"ngram\": \"testosterone\", \"from\": 4042, \"to\": 4054}, {\"ngram\": \"male advantage\", \"from\": 4081, \"to\": 4095}, {\"ngram\": \"sports\", \"from\": 4099, \"to\": 4105}]}, {\"sentence\": \"The most famous example is Caster Semenya - a double Olympic gold medallist and three-time world champion over 800m, though Prof Alun Williams says there is not direct evidence that DSD athletes have the same advantage as typical males.\", \"from\": 4125, \"to\": 4361, \"entities\": [{\"begin\": 4254, \"end\": 4267, \"title\": \"http://dbpedia.org/resource/Alun_Williams\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Alun Williams\", \"types\": [\"Q729\", \"Q5\", \"Q36180\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Alun_Williams\", \"dbpedia\": \"http://dbpedia.org/resource/Alun_Williams\"}, {\"begin\": 4307, \"end\": 4310, \"title\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"score\": 0.8135295012280547, \"rank\": 0.22921172310346108, \"text\": \"DSD\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\"}], \"noun_phrases\": [{\"ngram\": \"The most famous example\", \"from\": 4125, \"to\": 4148}, {\"ngram\": \"a double Olympic gold medallist\", \"from\": 4169, \"to\": 4200}, {\"ngram\": \"800m\", \"from\": 4236, \"to\": 4240}, {\"ngram\": \"direct evidence\", \"from\": 4286, \"to\": 4301}, {\"ngram\": \"the same advantage\", \"from\": 4325, \"to\": 4343}, {\"ngram\": \"typical males\", \"from\": 4347, \"to\": 4360}]}, {\"sentence\": \"The roadblock is in a gene required to generate external genitalia - which boys need in order to grow a penis.\", \"from\": 4363, \"to\": 4473, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The roadblock\", \"from\": 4363, \"to\": 4376}, {\"ngram\": \"a gene\", \"from\": 4383, \"to\": 4389}, {\"ngram\": \"external genitalia\", \"from\": 4411, \"to\": 4429}, {\"ngram\": \"boys\", \"from\": 4438, \"to\": 4442}, {\"ngram\": \"order\", \"from\": 4451, \"to\": 4456}, {\"ngram\": \"a penis\", \"from\": 4465, \"to\": 4472}]}, {\"sentence\": \"Anyone with the same condition as Caster Semenya has a mutation within that gene that stops it functioning normally.\", \"from\": 4474, \"to\": 4590, \"entities\": [{\"begin\": 4508, \"end\": 4522, \"title\": \"http://dbpedia.org/resource/Caster_Semenya\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Caster Semenya\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Caster_Semenya\", \"dbpedia\": \"http://dbpedia.org/resource/Caster_Semenya\"}], \"noun_phrases\": [{\"ngram\": \"Anyone\", \"from\": 4474, \"to\": 4480}, {\"ngram\": \"the same condition\", \"from\": 4486, \"to\": 4504}, {\"ngram\": \"a mutation\", \"from\": 4527, \"to\": 4537}, {\"ngram\": \"that gene\", \"from\": 4545, \"to\": 4554}]}, {\"sentence\": \"In the womb, they will develop a male anatomy until the final stage of growing a penis - and when they are not able to, then they will start developing a vulva and a clitoris.\", \"from\": 4592, \"to\": 4767, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the womb\", \"from\": 4595, \"to\": 4603}, {\"ngram\": \"a male anatomy\", \"from\": 4623, \"to\": 4637}, {\"ngram\": \"the final stage\", \"from\": 4644, \"to\": 4659}, {\"ngram\": \"a penis\", \"from\": 4671, \"to\": 4678}, {\"ngram\": \"a vulva\", \"from\": 4744, \"to\": 4751}, {\"ngram\": \"a clitoris\", \"from\": 4756, \"to\": 4766}]}, {\"sentence\": \"But they do not develop female reproductive organs: they do not have a cervix or a uterus.\", \"from\": 4769, \"to\": 4859, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"female reproductive organs\", \"from\": 4793, \"to\": 4819}, {\"ngram\": \"a cervix\", \"from\": 4838, \"to\": 4846}, {\"ngram\": \"a uterus\", \"from\": 4850, \"to\": 4858}]}, {\"sentence\": \"These people do not have periods and they can not get pregnant.\", \"from\": 4861, \"to\": 4924, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"These people\", \"from\": 4861, \"to\": 4873}, {\"ngram\": \"periods\", \"from\": 4886, \"to\": 4893}]}, {\"sentence\": \"Having sex with males can be difficult.\", \"from\": 4925, \"to\": 4964, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"sex\", \"from\": 4932, \"to\": 4935}, {\"ngram\": \"males\", \"from\": 4941, \"to\": 4946}]}, {\"sentence\": \"Discovering you have this kind of genetic mutation can be a shock.\", \"from\": 4966, \"to\": 5032, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this kind\", \"from\": 4987, \"to\": 4996}, {\"ngram\": \"genetic mutation\", \"from\": 5000, \"to\": 5016}, {\"ngram\": \"a shock\", \"from\": 5024, \"to\": 5031}]}, {\"sentence\": \"\\\"The most recent woman we diagnosed with having XY chromosomes was 33,\\\" says Claus H\\u00f8jbjerg Gravholt - an endocrinology professor at Aarhus University who spent the past 30 years dealing with DSD.\", \"from\": 5034, \"to\": 5231, \"entities\": [{\"begin\": 5082, \"end\": 5096, \"title\": \"http://dbpedia.org/resource/XY_sex-determination_system\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"XY chromosomes\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/XY_sex-determination_system\", \"dbpedia\": \"http://dbpedia.org/resource/XY_sex-determination_system\"}, {\"begin\": 5118, \"end\": 5126, \"title\": \"http://dbpedia.org/resource/H\\u00f8jbjerg\", \"score\": 0.9764823238924786, \"rank\": 0.0, \"text\": \"H\\u00f8jbjerg\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/H\\u00f8jbjerg\", \"dbpedia\": \"http://dbpedia.org/resource/H\\u00f8jbjerg\"}, {\"begin\": 5168, \"end\": 5185, \"title\": \"http://dbpedia.org/resource/Aarhus_University\", \"score\": 1.0, \"rank\": 4.5344983253880646e-45, \"text\": \"Aarhus University\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/Aarhus_University\", \"dbpedia\": \"http://dbpedia.org/resource/Aarhus_University\"}, {\"begin\": 5227, \"end\": 5230, \"title\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"score\": 0.8135295012280547, \"rank\": 0.22921172310346108, \"text\": \"DSD\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\"}], \"noun_phrases\": [{\"ngram\": \"The most recent woman\", \"from\": 5035, \"to\": 5056}, {\"ngram\": \"an endocrinology professor\", \"from\": 5137, \"to\": 5163}, {\"ngram\": \"the past 30 years\", \"from\": 5195, \"to\": 5212}]}, {\"sentence\": \"His patient came to see him because she had no idea why she could not get pregnant.\", \"from\": 5233, \"to\": 5316, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"His patient\", \"from\": 5233, \"to\": 5244}, {\"ngram\": \"no idea\", \"from\": 5277, \"to\": 5284}]}, {\"sentence\": \"\\\"We discovered she did not have a uterus, so she would never be able to have a baby.\", \"from\": 5318, \"to\": 5402, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a uterus\", \"from\": 5350, \"to\": 5358}, {\"ngram\": \"a baby\", \"from\": 5395, \"to\": 5401}]}, {\"sentence\": \"She was absolutely devastated.\\\"\", \"from\": 5403, \"to\": 5434, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Prof Gravholt says the implications that come with questioning one's gender identity can be destabilising - and he often refers his patients to a psychologist.\", \"from\": 5436, \"to\": 5595, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Prof Gravholt\", \"from\": 5436, \"to\": 5449}, {\"ngram\": \"the implications\", \"from\": 5455, \"to\": 5471}, {\"ngram\": \"one's gender identity\", \"from\": 5499, \"to\": 5520}, {\"ngram\": \"his patients\", \"from\": 5564, \"to\": 5576}, {\"ngram\": \"a psychologist\", \"from\": 5580, \"to\": 5594}]}, {\"sentence\": \"\\\"If I showed you her photo, you would say: that's a woman.\", \"from\": 5597, \"to\": 5655, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her photo\", \"from\": 5614, \"to\": 5623}, {\"ngram\": \"a woman\", \"from\": 5647, \"to\": 5654}]}, {\"sentence\": \"She has a female body, she is married to a man.\", \"from\": 5656, \"to\": 5703, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a female body\", \"from\": 5664, \"to\": 5677}, {\"ngram\": \"a man\", \"from\": 5697, \"to\": 5702}]}, {\"sentence\": \"She feels like a female.\", \"from\": 5704, \"to\": 5728, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a female\", \"from\": 5719, \"to\": 5727}]}, {\"sentence\": \"And that is the case for most of my patients.\\\"\", \"from\": 5729, \"to\": 5775, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the case\", \"from\": 5741, \"to\": 5749}, {\"ngram\": \"my patients\", \"from\": 5762, \"to\": 5773}]}, {\"sentence\": \"When Prof Gravholt asked her why she did not consult a doctor about not getting periods, she said there was another older woman in her family who never menstruated - so she thought it wasn't abnormal.\", \"from\": 5777, \"to\": 5977, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Prof Gravholt\", \"from\": 5782, \"to\": 5795}, {\"ngram\": \"a doctor\", \"from\": 5830, \"to\": 5838}, {\"ngram\": \"periods\", \"from\": 5857, \"to\": 5864}, {\"ngram\": \"another older woman\", \"from\": 5885, \"to\": 5904}, {\"ngram\": \"her family\", \"from\": 5908, \"to\": 5918}]}, {\"sentence\": \"There is another genetic mutation Prof Gravholt has come across.\", \"from\": 5979, \"to\": 6043, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"another genetic mutation\", \"from\": 5988, \"to\": 6012}, {\"ngram\": \"Prof Gravholt\", \"from\": 6013, \"to\": 6026}]}, {\"sentence\": \"He has diagnosed males who have XX chromosomes - which are normally found in females.\", \"from\": 6045, \"to\": 6130, \"entities\": [{\"begin\": 6077, \"end\": 6079, \"title\": \"http://dbpedia.org/resource/XY_sex-determination_system\", \"score\": 1.0, \"rank\": 4.6395136353696135e-73, \"text\": \"XX\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/XY_sex-determination_system\", \"dbpedia\": \"http://dbpedia.org/resource/XY_sex-determination_system\"}], \"noun_phrases\": [{\"ngram\": \"males\", \"from\": 6062, \"to\": 6067}, {\"ngram\": \"females\", \"from\": 6122, \"to\": 6129}]}, {\"sentence\": \"\\\"These men are infertile.\", \"from\": 6131, \"to\": 6156, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"These men\", \"from\": 6132, \"to\": 6141}]}, {\"sentence\": \"They look like normal males, but their testes are smaller than average and do not produce sperm.\", \"from\": 6157, \"to\": 6253, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"normal males\", \"from\": 6172, \"to\": 6184}, {\"ngram\": \"their testes\", \"from\": 6190, \"to\": 6202}, {\"ngram\": \"sperm\", \"from\": 6247, \"to\": 6252}]}, {\"sentence\": \"It's always devastating when they find out.\", \"from\": 6254, \"to\": 6297, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"As they grow older, they stop producing testosterone in the way most men do.\\\"\", \"from\": 6298, \"to\": 6375, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"testosterone\", \"from\": 6338, \"to\": 6350}, {\"ngram\": \"the way\", \"from\": 6354, \"to\": 6361}, {\"ngram\": \"most men\", \"from\": 6362, \"to\": 6370}]}, {\"sentence\": \"In some cultures, talking openly about periods and female anatomy is not culturally acceptable.\", \"from\": 6377, \"to\": 6472, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"some cultures\", \"from\": 6380, \"to\": 6393}, {\"ngram\": \"periods\", \"from\": 6416, \"to\": 6423}, {\"ngram\": \"female anatomy\", \"from\": 6428, \"to\": 6442}]}, {\"sentence\": \"In some parts of the world, women may lack the education to understand that there is something atypical going on in their bodies.\", \"from\": 6473, \"to\": 6602, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"some parts\", \"from\": 6476, \"to\": 6486}, {\"ngram\": \"the world\", \"from\": 6490, \"to\": 6499}, {\"ngram\": \"women\", \"from\": 6501, \"to\": 6506}, {\"ngram\": \"the education\", \"from\": 6516, \"to\": 6529}, {\"ngram\": \"something\", \"from\": 6558, \"to\": 6567}, {\"ngram\": \"their bodies\", \"from\": 6589, \"to\": 6601}]}, {\"sentence\": \"And that's why experts believe that many DSDs are never diagnosed - which means that comprehensive data is scarce.\", \"from\": 6604, \"to\": 6718, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"experts\", \"from\": 6619, \"to\": 6626}, {\"ngram\": \"many DSDs\", \"from\": 6640, \"to\": 6649}, {\"ngram\": \"comprehensive data\", \"from\": 6689, \"to\": 6707}]}, {\"sentence\": \"But Prof Gravholt points to figures from Denmark as a good indicator.\", \"from\": 6720, \"to\": 6789, \"entities\": [{\"begin\": 6761, \"end\": 6768, \"title\": \"http://dbpedia.org/resource/Denmark\", \"score\": 1.0, \"rank\": 4.1309201538018176e-13, \"text\": \"Denmark\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Denmark\", \"dbpedia\": \"http://dbpedia.org/resource/Denmark\"}], \"noun_phrases\": [{\"ngram\": \"figures\", \"from\": 6748, \"to\": 6755}, {\"ngram\": \"a good indicator\", \"from\": 6772, \"to\": 6788}]}, {\"sentence\": \"\\\"Denmark is probably the best country in the world at collecting this data - we have a national registry with everyone who has ever had a chromosome examination.\\\"\", \"from\": 6791, \"to\": 6953, \"entities\": [{\"begin\": 6792, \"end\": 6799, \"title\": \"http://dbpedia.org/resource/Denmark\", \"score\": 1.0, \"rank\": 4.1309201538018176e-13, \"text\": \"Denmark\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Denmark\", \"dbpedia\": \"http://dbpedia.org/resource/Denmark\"}], \"noun_phrases\": [{\"ngram\": \"the best country\", \"from\": 6812, \"to\": 6828}, {\"ngram\": \"the world\", \"from\": 6832, \"to\": 6841}, {\"ngram\": \"this data\", \"from\": 6856, \"to\": 6865}, {\"ngram\": \"a national registry\", \"from\": 6876, \"to\": 6895}, {\"ngram\": \"everyone\", \"from\": 6901, \"to\": 6909}, {\"ngram\": \"a chromosome examination\", \"from\": 6927, \"to\": 6951}]}, {\"sentence\": \"He says that XY chromosomes in females are very rare - in Denmark it's about one in 15,000.\", \"from\": 6955, \"to\": 7046, \"entities\": [{\"begin\": 6968, \"end\": 6982, \"title\": \"http://dbpedia.org/resource/XY_sex-determination_system\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"XY chromosomes\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/XY_sex-determination_system\", \"dbpedia\": \"http://dbpedia.org/resource/XY_sex-determination_system\"}, {\"begin\": 7013, \"end\": 7020, \"title\": \"http://dbpedia.org/resource/Denmark\", \"score\": 1.0, \"rank\": 4.1309201538018176e-13, \"text\": \"Denmark\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Denmark\", \"dbpedia\": \"http://dbpedia.org/resource/Denmark\"}], \"noun_phrases\": [{\"ngram\": \"females\", \"from\": 6986, \"to\": 6993}]}, {\"sentence\": \"But he believes that when adding these many genetic conditions together, about one in 300 people are affected.\", \"from\": 7048, \"to\": 7158, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"these many genetic conditions\", \"from\": 7081, \"to\": 7110}, {\"ngram\": \"about one in 300 people\", \"from\": 7121, \"to\": 7144}]}, {\"sentence\": \"\\\"We are learning that these variations are more common than we thought,\\\" Prof Gravholt says.\", \"from\": 7160, \"to\": 7252, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"these variations\", \"from\": 7182, \"to\": 7198}, {\"ngram\": \"Prof Gravholt\", \"from\": 7233, \"to\": 7246}]}, {\"sentence\": \"\\\"A lot of patients are being diagnosed later in life.\", \"from\": 7253, \"to\": 7306, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A lot\", \"from\": 7254, \"to\": 7259}, {\"ngram\": \"patients\", \"from\": 7263, \"to\": 7271}, {\"ngram\": \"life\", \"from\": 7301, \"to\": 7305}]}, {\"sentence\": \"The oldest person I diagnosed was a male in his 60s.\\\"\", \"from\": 7307, \"to\": 7360, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The oldest person\", \"from\": 7307, \"to\": 7324}, {\"ngram\": \"a male\", \"from\": 7341, \"to\": 7347}, {\"ngram\": \"his 60s\", \"from\": 7351, \"to\": 7358}]}, {\"sentence\": \"Do people with differences of sex development have an unfair advantage in sport?\", \"from\": 7362, \"to\": 7442, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"people\", \"from\": 7365, \"to\": 7371}, {\"ngram\": \"differences\", \"from\": 7377, \"to\": 7388}, {\"ngram\": \"sex development\", \"from\": 7392, \"to\": 7407}, {\"ngram\": \"an unfair advantage\", \"from\": 7413, \"to\": 7432}, {\"ngram\": \"sport\", \"from\": 7436, \"to\": 7441}]}, {\"sentence\": \"The short answer is that there is not enough data to reach a definitive conclusion.\", \"from\": 7443, \"to\": 7526, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The short answer\", \"from\": 7443, \"to\": 7459}, {\"ngram\": \"enough data\", \"from\": 7481, \"to\": 7492}, {\"ngram\": \"a definitive conclusion\", \"from\": 7502, \"to\": 7525}]}, {\"sentence\": \"\\\"It would not surprise me if some people with a type of DSD had some physical advantage over women,\\\" says Prof Alun Williams.\", \"from\": 7528, \"to\": 7653, \"entities\": [{\"begin\": 7584, \"end\": 7587, \"title\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"score\": 0.8135295012280547, \"rank\": 0.22921172310346108, \"text\": \"DSD\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\"}, {\"begin\": 7639, \"end\": 7652, \"title\": \"http://dbpedia.org/resource/Alun_Williams\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Alun Williams\", \"types\": [\"Q729\", \"Q5\", \"Q36180\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Alun_Williams\", \"dbpedia\": \"http://dbpedia.org/resource/Alun_Williams\"}], \"noun_phrases\": [{\"ngram\": \"some people\", \"from\": 7557, \"to\": 7568}, {\"ngram\": \"a type\", \"from\": 7574, \"to\": 7580}, {\"ngram\": \"some physical advantage\", \"from\": 7592, \"to\": 7615}, {\"ngram\": \"women\", \"from\": 7621, \"to\": 7626}]}, {\"sentence\": \"Those advantages could include larger muscle mass, as well as bigger and longer bones and larger organs such as lungs and heart.\", \"from\": 7654, \"to\": 7782, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Those advantages\", \"from\": 7654, \"to\": 7670}, {\"ngram\": \"larger muscle mass\", \"from\": 7685, \"to\": 7703}, {\"ngram\": \"bigger and longer bones\", \"from\": 7716, \"to\": 7739}, {\"ngram\": \"larger organs\", \"from\": 7744, \"to\": 7757}, {\"ngram\": \"lungs\", \"from\": 7766, \"to\": 7771}, {\"ngram\": \"heart\", \"from\": 7776, \"to\": 7781}]}, {\"sentence\": \"He says they may also have higher levels of blood haemoglobin that lead to improved oxygen delivery to where it's needed in working muscles.\", \"from\": 7784, \"to\": 7924, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"higher levels\", \"from\": 7811, \"to\": 7824}, {\"ngram\": \"blood haemoglobin\", \"from\": 7828, \"to\": 7845}, {\"ngram\": \"improved oxygen delivery\", \"from\": 7859, \"to\": 7883}, {\"ngram\": \"working muscles\", \"from\": 7908, \"to\": 7923}]}, {\"sentence\": \"\\\"Some people with some types of DSDs might have advantages in some or all of those elements, ranging from 0-100%, depending on the type of DSD and its precise genetic cause.\\\"\", \"from\": 7926, \"to\": 8100, \"entities\": [{\"begin\": 8065, \"end\": 8068, \"title\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"score\": 0.8135295012280547, \"rank\": 0.22921172310346108, \"text\": \"DSD\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\"}], \"noun_phrases\": [{\"ngram\": \"Some people\", \"from\": 7927, \"to\": 7938}, {\"ngram\": \"some types\", \"from\": 7944, \"to\": 7954}, {\"ngram\": \"DSDs\", \"from\": 7958, \"to\": 7962}, {\"ngram\": \"advantages\", \"from\": 7974, \"to\": 7984}, {\"ngram\": \"those elements\", \"from\": 8003, \"to\": 8017}, {\"ngram\": \"0-100%\", \"from\": 8032, \"to\": 8038}, {\"ngram\": \"the type\", \"from\": 8053, \"to\": 8061}, {\"ngram\": \"its precise genetic cause\", \"from\": 8073, \"to\": 8098}]}, {\"sentence\": \"He believes his opinion is representative of the experts in his field, but that more evidence is needed.\", \"from\": 8102, \"to\": 8206, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"his opinion\", \"from\": 8114, \"to\": 8125}, {\"ngram\": \"the experts\", \"from\": 8147, \"to\": 8158}, {\"ngram\": \"his field\", \"from\": 8162, \"to\": 8171}, {\"ngram\": \"more evidence\", \"from\": 8182, \"to\": 8195}]}, {\"sentence\": \"When it comes to Imane Khelif and Lin Yu-ting, we do not have enough information to know if they have a DSD that would need to be regulated.\", \"from\": 8208, \"to\": 8348, \"entities\": [{\"begin\": 8225, \"end\": 8237, \"title\": \"http://dbpedia.org/resource/Imane_Khelif\", \"score\": 0.9999996421621021, \"rank\": 0.0, \"text\": \"Imane Khelif\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Imane_Khelif\", \"dbpedia\": \"http://dbpedia.org/resource/Imane_Khelif\"}, {\"begin\": 8242, \"end\": 8253, \"title\": \"http://dbpedia.org/resource/Lin_Yu-ting\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Lin Yu-ting\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Lin_Yu-ting\", \"dbpedia\": \"http://dbpedia.org/resource/Lin_Yu-ting\"}, {\"begin\": 8312, \"end\": 8315, \"title\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"score\": 0.8135295012280547, \"rank\": 0.22921172310346108, \"text\": \"DSD\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\"}], \"noun_phrases\": [{\"ngram\": \"enough information\", \"from\": 8270, \"to\": 8288}]}, {\"sentence\": \"Regulating elite sports, which typically rely on male-female binary categories in competition, is complicated because the biology of sex itself is complex.\", \"from\": 8350, \"to\": 8505, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"elite sports\", \"from\": 8361, \"to\": 8373}, {\"ngram\": \"male-female binary categories\", \"from\": 8399, \"to\": 8428}, {\"ngram\": \"competition\", \"from\": 8432, \"to\": 8443}, {\"ngram\": \"the biology\", \"from\": 8468, \"to\": 8479}, {\"ngram\": \"sex\", \"from\": 8483, \"to\": 8486}]}, {\"sentence\": \"Dr Shane Heffernan has a PhD in molecular genetics in elite sports and is currently working on a paper on what athletes think about competitors with a DSD.\", \"from\": 8507, \"to\": 8662, \"entities\": [{\"begin\": 8510, \"end\": 8515, \"title\": \"http://dbpedia.org/resource/Shane_McMahon\", \"score\": 0.7858443651276559, \"rank\": 0.14497863551809176, \"text\": \"Shane\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Shane_McMahon\", \"dbpedia\": \"http://dbpedia.org/resource/Shane_McMahon\"}, {\"begin\": 8658, \"end\": 8661, \"title\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"score\": 0.8135295012280547, \"rank\": 0.22921172310346108, \"text\": \"DSD\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\"}], \"noun_phrases\": [{\"ngram\": \"a PhD\", \"from\": 8530, \"to\": 8535}, {\"ngram\": \"molecular genetics\", \"from\": 8539, \"to\": 8557}, {\"ngram\": \"elite sports\", \"from\": 8561, \"to\": 8573}, {\"ngram\": \"a paper\", \"from\": 8602, \"to\": 8609}, {\"ngram\": \"athletes\", \"from\": 8618, \"to\": 8626}, {\"ngram\": \"competitors\", \"from\": 8639, \"to\": 8650}]}, {\"sentence\": \"He says it's all about the nuance of the individual's genetic condition.\", \"from\": 8664, \"to\": 8736, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the nuance\", \"from\": 8687, \"to\": 8697}, {\"ngram\": \"the individual's genetic condition\", \"from\": 8701, \"to\": 8735}]}, {\"sentence\": \"For example, females with a DSD known as androgen insensitivity syndrome have XY chromosomes; they produce testosterone; but their bodies are not equipped to process it.\", \"from\": 8738, \"to\": 8907, \"entities\": [{\"begin\": 8766, \"end\": 8769, \"title\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"score\": 0.8135295012280547, \"rank\": 0.22921172310346108, \"text\": \"DSD\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\"}, {\"begin\": 8816, \"end\": 8830, \"title\": \"http://dbpedia.org/resource/XY_sex-determination_system\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"XY chromosomes\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/XY_sex-determination_system\", \"dbpedia\": \"http://dbpedia.org/resource/XY_sex-determination_system\"}], \"noun_phrases\": [{\"ngram\": \"example\", \"from\": 8742, \"to\": 8749}, {\"ngram\": \"females\", \"from\": 8751, \"to\": 8758}, {\"ngram\": \"androgen insensitivity syndrome\", \"from\": 8779, \"to\": 8810}, {\"ngram\": \"testosterone\", \"from\": 8845, \"to\": 8857}, {\"ngram\": \"their bodies\", \"from\": 8863, \"to\": 8875}]}, {\"sentence\": \"So they do not get any of the benefits from that testosterone, like males do.\", \"from\": 8908, \"to\": 8985, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the benefits\", \"from\": 8934, \"to\": 8946}, {\"ngram\": \"that testosterone\", \"from\": 8952, \"to\": 8969}, {\"ngram\": \"males\", \"from\": 8976, \"to\": 8981}]}, {\"sentence\": \"Dr Heffernan says that there are not enough known and studied athletes with a DSD to make a valid scientific conclusion as to whether they definitely have an advantage, and as to whether they should be eligible or ineligible to compete in the female category.\", \"from\": 8987, \"to\": 9246, \"entities\": [{\"begin\": 9065, \"end\": 9068, \"title\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"score\": 0.8135295012280547, \"rank\": 0.22921172310346108, \"text\": \"DSD\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\"}], \"noun_phrases\": [{\"ngram\": \"Dr Heffernan\", \"from\": 8987, \"to\": 8999}, {\"ngram\": \"athletes\", \"from\": 9049, \"to\": 9057}, {\"ngram\": \"a valid scientific conclusion\", \"from\": 9077, \"to\": 9106}, {\"ngram\": \"an advantage\", \"from\": 9142, \"to\": 9154}, {\"ngram\": \"the female category\", \"from\": 9226, \"to\": 9245}]}, {\"sentence\": \"He believes that the International Olympic Committee is not basing its eligibility criteria on the best available science.\", \"from\": 9248, \"to\": 9370, \"entities\": [{\"begin\": 9269, \"end\": 9300, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"its eligibility criteria\", \"from\": 9315, \"to\": 9339}, {\"ngram\": \"the best available science\", \"from\": 9343, \"to\": 9369}]}, {\"sentence\": \"\\\"This is worrying.\", \"from\": 9372, \"to\": 9390, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"The IOC makes an 'assumption of no advantage' - but there is no direct evidence for this, nor that there is a performance advantage with DSD athletes solely because of their genetic variations.\", \"from\": 9391, \"to\": 9584, \"entities\": [{\"begin\": 9395, \"end\": 9398, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 2.3619516232971095e-33, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 9528, \"end\": 9531, \"title\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"score\": 0.8135295012280547, \"rank\": 0.22921172310346108, \"text\": \"DSD\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\"}], \"noun_phrases\": [{\"ngram\": \"an 'assumption\", \"from\": 9405, \"to\": 9419}, {\"ngram\": \"no advantage\", \"from\": 9423, \"to\": 9435}, {\"ngram\": \"no direct evidence\", \"from\": 9452, \"to\": 9470}, {\"ngram\": \"a performance advantage\", \"from\": 9499, \"to\": 9522}, {\"ngram\": \"their genetic variations\", \"from\": 9559, \"to\": 9583}]}, {\"sentence\": \"\\\"We simply do not have enough data.\", \"from\": 9586, \"to\": 9621, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"enough data\", \"from\": 9609, \"to\": 9620}]}, {\"sentence\": \"Many people hold an emotional position when it comes to inclusion in the female category, but how can the IOC justify this position - without the data to support it?\\\"\", \"from\": 9622, \"to\": 9788, \"entities\": [{\"begin\": 9728, \"end\": 9731, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 2.3619516232971095e-33, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"Many people\", \"from\": 9622, \"to\": 9633}, {\"ngram\": \"an emotional position\", \"from\": 9639, \"to\": 9660}, {\"ngram\": \"inclusion\", \"from\": 9678, \"to\": 9687}, {\"ngram\": \"the female category\", \"from\": 9691, \"to\": 9710}, {\"ngram\": \"this position\", \"from\": 9740, \"to\": 9753}, {\"ngram\": \"the data\", \"from\": 9764, \"to\": 9772}]}, {\"sentence\": \"He is one of many people who are urging the Olympics committee, international federations and funding councils to invest in research on athletes with a DSD - but he appreciates it's difficult, because there can be a lot of stigma towards the individual athletes when it comes to these conditions.\", \"from\": 9790, \"to\": 10086, \"entities\": [{\"begin\": 9942, \"end\": 9945, \"title\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"score\": 0.8135295012280547, \"rank\": 0.22921172310346108, \"text\": \"DSD\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_Signals_Directorate\"}], \"noun_phrases\": [{\"ngram\": \"many people\", \"from\": 9803, \"to\": 9814}, {\"ngram\": \"the Olympics committee\", \"from\": 9830, \"to\": 9852}, {\"ngram\": \"international federations\", \"from\": 9854, \"to\": 9879}, {\"ngram\": \"funding councils\", \"from\": 9884, \"to\": 9900}, {\"ngram\": \"research\", \"from\": 9914, \"to\": 9922}, {\"ngram\": \"athletes\", \"from\": 9926, \"to\": 9934}, {\"ngram\": \"a lot\", \"from\": 10004, \"to\": 10009}, {\"ngram\": \"stigma\", \"from\": 10013, \"to\": 10019}, {\"ngram\": \"the individual athletes\", \"from\": 10028, \"to\": 10051}, {\"ngram\": \"these conditions\", \"from\": 10069, \"to\": 10085}]}, {\"sentence\": \"Some are calling for mandatory sex testing at the next Olympics - including Reem Alsalem, the UN's special rapporteur on violence against women and girls.\", \"from\": 10088, \"to\": 10242, \"entities\": [{\"begin\": 10182, \"end\": 10184, \"title\": \"http://dbpedia.org/resource/United_Nations\", \"score\": 0.9999936519790515, \"rank\": 6.320764332667733e-06, \"text\": \"UN\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Nations\", \"dbpedia\": \"http://dbpedia.org/resource/United_Nations\"}], \"noun_phrases\": [{\"ngram\": \"mandatory sex testing\", \"from\": 10109, \"to\": 10130}, {\"ngram\": \"the next Olympics\", \"from\": 10134, \"to\": 10151}, {\"ngram\": \"Reem Alsalem\", \"from\": 10164, \"to\": 10176}, {\"ngram\": \"violence\", \"from\": 10209, \"to\": 10217}, {\"ngram\": \"women\", \"from\": 10226, \"to\": 10231}, {\"ngram\": \"girls\", \"from\": 10236, \"to\": 10241}]}, {\"sentence\": \"\\\"Screening DNA is now a piece of cake,\\\" Dr Emma Hilton says.\", \"from\": 10244, \"to\": 10304, \"entities\": [{\"begin\": 10287, \"end\": 10291, \"title\": \"http://dbpedia.org/resource/Emma_Swan\", \"score\": 0.9982065348714207, \"rank\": 0.0017966841649124507, \"text\": \"Emma\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Emma_Swan\", \"dbpedia\": \"http://dbpedia.org/resource/Emma_Swan\"}, {\"begin\": 10292, \"end\": 10298, \"title\": \"http://dbpedia.org/resource/Hilton_Worldwide\", \"score\": 1.0, \"rank\": 1.8878718190396046e-15, \"text\": \"Hilton\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Hilton_Worldwide\", \"dbpedia\": \"http://dbpedia.org/resource/Hilton_Worldwide\"}], \"noun_phrases\": [{\"ngram\": \"Screening DNA\", \"from\": 10245, \"to\": 10258}, {\"ngram\": \"a piece\", \"from\": 10266, \"to\": 10273}, {\"ngram\": \"cake\", \"from\": 10277, \"to\": 10281}]}, {\"sentence\": \"\\\"A simple cheek swab would be sufficient, and it's minimally invasive.\\\"\", \"from\": 10305, \"to\": 10376, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A simple cheek swab\", \"from\": 10306, \"to\": 10325}]}, {\"sentence\": \"She says swabs should happen when athletes first register for their first affiliated competition - before they start winning medals and the spotlight hits them, so as to avoid what happened with Imane Khelif.\", \"from\": 10378, \"to\": 10586, \"entities\": [{\"begin\": 10573, \"end\": 10585, \"title\": \"http://dbpedia.org/resource/Imane_Khelif\", \"score\": 0.9999996421621021, \"rank\": 0.0, \"text\": \"Imane Khelif\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Imane_Khelif\", \"dbpedia\": \"http://dbpedia.org/resource/Imane_Khelif\"}], \"noun_phrases\": [{\"ngram\": \"swabs\", \"from\": 10387, \"to\": 10392}, {\"ngram\": \"athletes\", \"from\": 10412, \"to\": 10420}, {\"ngram\": \"their first affiliated competition\", \"from\": 10440, \"to\": 10474}, {\"ngram\": \"medals\", \"from\": 10503, \"to\": 10509}, {\"ngram\": \"the spotlight\", \"from\": 10514, \"to\": 10527}]}, {\"sentence\": \"But there is disagreement on that among scientists.\", \"from\": 10588, \"to\": 10639, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"disagreement\", \"from\": 10601, \"to\": 10613}, {\"ngram\": \"scientists\", \"from\": 10628, \"to\": 10638}]}, {\"sentence\": \"\\\"A cheek swab would not allow you to reach a robust conclusion on someone's sex and potential advantage in sport,\\\" says Prof Williams.\", \"from\": 10641, \"to\": 10775, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A cheek swab\", \"from\": 10642, \"to\": 10654}, {\"ngram\": \"a robust conclusion\", \"from\": 10684, \"to\": 10703}, {\"ngram\": \"someone's sex\", \"from\": 10707, \"to\": 10720}, {\"ngram\": \"potential advantage\", \"from\": 10725, \"to\": 10744}, {\"ngram\": \"sport\", \"from\": 10748, \"to\": 10753}, {\"ngram\": \"Prof Williams\", \"from\": 10761, \"to\": 10774}]}, {\"sentence\": \"He argues a comprehensive sex test would have to include these three categories: 1.\", \"from\": 10777, \"to\": 10861, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a comprehensive sex test\", \"from\": 10787, \"to\": 10811}, {\"ngram\": \"these three categories\", \"from\": 10834, \"to\": 10856}]}, {\"sentence\": \"Genetics (including looking for a Y chromosome and the SRY \\\"make-male\\\" gene).\", \"from\": 10862, \"to\": 10939, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Genetics\", \"from\": 10862, \"to\": 10870}, {\"ngram\": \"a Y chromosome\", \"from\": 10894, \"to\": 10908}, {\"ngram\": \"the SRY \\\"make-male\\\" gene\", \"from\": 10913, \"to\": 10937}]}, {\"sentence\": \"2.\", \"from\": 10941, \"to\": 10943, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Hormones (including, but not limited to, testosterone).\", \"from\": 10944, \"to\": 10999, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Hormones\", \"from\": 10944, \"to\": 10952}, {\"ngram\": \"testosterone\", \"from\": 10985, \"to\": 10997}]}, {\"sentence\": \"3.\", \"from\": 11001, \"to\": 11003, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"The body's responsiveness to hormones like testosterone.\", \"from\": 11004, \"to\": 11060, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The body's responsiveness\", \"from\": 11004, \"to\": 11029}, {\"ngram\": \"hormones\", \"from\": 11033, \"to\": 11041}, {\"ngram\": \"testosterone\", \"from\": 11047, \"to\": 11059}]}, {\"sentence\": \"Some people might have a Y chromosome, but be completely insensitive to testosterone.\", \"from\": 11061, \"to\": 11146, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Some people\", \"from\": 11061, \"to\": 11072}, {\"ngram\": \"a Y chromosome\", \"from\": 11084, \"to\": 11098}, {\"ngram\": \"testosterone\", \"from\": 11133, \"to\": 11145}]}, {\"sentence\": \"He believes this is currently not being done because it's expensive, it requires people with very specific expertise - and there are ethical concerns about the testing procedure.\", \"from\": 11148, \"to\": 11326, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"people\", \"from\": 11229, \"to\": 11235}, {\"ngram\": \"very specific expertise\", \"from\": 11241, \"to\": 11264}, {\"ngram\": \"ethical concerns\", \"from\": 11281, \"to\": 11297}, {\"ngram\": \"the testing procedure\", \"from\": 11304, \"to\": 11325}]}, {\"sentence\": \"\\\"This assessment can be humiliating.\", \"from\": 11328, \"to\": 11364, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"This assessment\", \"from\": 11329, \"to\": 11344}]}, {\"sentence\": \"It includes measurements of the most intimate parts of anatomy, like the size of your breast and your clitoris, the depth of your voice, the extent of your body hair.\\\"\", \"from\": 11365, \"to\": 11532, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"measurements\", \"from\": 11377, \"to\": 11389}, {\"ngram\": \"the most intimate parts\", \"from\": 11393, \"to\": 11416}, {\"ngram\": \"anatomy\", \"from\": 11420, \"to\": 11427}, {\"ngram\": \"th