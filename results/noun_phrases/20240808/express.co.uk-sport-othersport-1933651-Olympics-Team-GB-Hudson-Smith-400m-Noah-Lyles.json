]}, {\"sentence\": \"\\\"I could bait him out so much with that.\", \"from\": 1370, \"to\": 1410, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"But he's a global superstar now guys, so I have got to leave some mystery out there.\\\"\", \"from\": 1411, \"to\": 1496, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a global superstar\", \"from\": 1420, \"to\": 1438}, {\"ngram\": \"now guys\", \"from\": 1439, \"to\": 1447}, {\"ngram\": \"some mystery\", \"from\": 1472, \"to\": 1484}]}, {\"sentence\": \"He also vowed to go and visit the 27-year-old once he left theBBCstudio.\", \"from\": 1497, \"to\": 1569, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"theBBCstudio\", \"from\": 1556, \"to\": 1568}]}, {\"sentence\": \"Hudson-Smith did cut a far more jovial figure than the one of the previous evening, having fallen short of becoming Team GB's first maleOlympic400m champion since Eric Liddell 100 years ago.\", \"from\": 1571, \"to\": 1761, \"entities\": [{\"begin\": 1687, \"end\": 1694, \"title\": \"http://dbpedia.org/resource/Team_GB\", \"score\": 0.9999999962105903, \"rank\": 3.708461224955394e-09, \"text\": \"Team GB\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Team_GB\", \"dbpedia\": \"http://dbpedia.org/resource/Team_GB\"}, {\"begin\": 1734, \"end\": 1746, \"title\": \"http://dbpedia.org/resource/Eric_Liddell\", \"score\": 1.0, \"rank\": 1.212869590674479e-38, \"text\": \"Eric Liddell\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Eric_Liddell\", \"dbpedia\": \"http://dbpedia.org/resource/Eric_Liddell\"}], \"noun_phrases\": [{\"ngram\": \"Hudson-Smith\", \"from\": 1571, \"to\": 1583}, {\"ngram\": \"a far more jovial figure\", \"from\": 1592, \"to\": 1616}, {\"ngram\": \"the previous evening\", \"from\": 1633, \"to\": 1653}]}, {\"sentence\": \"But immediately after his race, he vowed to go for gold again in Los Angeles in four years' time.\", \"from\": 1762, \"to\": 1859, \"entities\"