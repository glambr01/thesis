egin\": 1253, \"end\": 1257, \"title\": \"http://dbpedia.org/resource/Palestinians\", \"score\": 0.9999636374849821, \"rank\": 2.994336431873035e-05, \"text\": \"Arab\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Palestinians\", \"dbpedia\": \"http://dbpedia.org/resource/Palestinians\"}, {\"begin\": 1278, \"end\": 1285, \"title\": \"http://dbpedia.org/resource/Reuters\", \"score\": 1.0, \"rank\": 5.627282206577677e-20, \"text\": \"Reuters\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Reuters\", \"dbpedia\": \"http://dbpedia.org/resource/Reuters\"}], \"noun_phrases\": [{\"ngram\": \"El Khalfaoui\", \"from\": 1135, \"to\": 1147}, {\"ngram\": \"more than 20 people\", \"from\": 1158, \"to\": 1177}]}, {\"sentence\": \"It was thefatal shooting by police of Nahel Merzouk- a 17-year-old of North African heritage - in similar circumstances in a Paris suburb in 2023 thatsparked nationwide unrest and stirred deep-seated grievancesover neglect and discrimination among communities of immigrant descent.\", \"from\": 1294, \"to\": 1575, \"entities\": [{\"begin\": 1364, \"end\": 1377, \"title\": \"http://dbpedia.org/resource/North_Africa\", \"score\": 0.9999985302740129, \"rank\": 1.2241220051603446e-06, \"text\": \"North African\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/North_Africa\", \"dbpedia\": \"http://dbpedia.org/resource/North_Africa\"}, {\"begin\": 1419, \"end\": 1424, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.6842176798102979e-15, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"thefatal shooting\", \"from\": 1301, \"to\": 1318}, {\"ngram\": \"police\", \"from\": 1322, \"to\": 1328}, {\"ngram\": \"Nahel Merzouk-\", \"from\": 1332, \"to\": 1346}, {\"ngram\": \"similar circumstances\", \"from\": 1392, \"to\": 1413},