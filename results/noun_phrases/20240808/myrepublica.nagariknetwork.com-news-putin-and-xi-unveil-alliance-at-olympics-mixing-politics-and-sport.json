 \"from\": 2042, \"to\": 2055}, {\"ngram\": \"the women's tennis tour\", \"from\": 2062, \"to\": 2085}, {\"ngram\": \"events\", \"from\": 2097, \"to\": 2103}, {\"ngram\": \"the case\", \"from\": 2115, \"to\": 2123}, {\"ngram\": \"a tennis player\", \"from\": 2139, \"to\": 2154}, {\"ngram\": \"a senior official\", \"from\": 2193, \"to\": 2210}, {\"ngram\": \"sexual assault\", \"from\": 2214, \"to\": 2228}]}, {\"sentence\": \"Chinese media have shown Peng making public appearances, including a video phone call last year with Olympics boss Bach.\", \"from\": 2230, \"to\": 2350, \"entities\": [{\"begin\": 2230, \"end\": 2237, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9999999981328074, \"rank\": 1.8669057186088787e-09, \"text\": \"Chinese\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}, {\"begin\": 2345, \"end\": 2349, \"title\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"score\": 1.0, \"rank\": 1.2054157240422688e-14, \"text\": \"Bach\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"dbpedia\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\"}], \"noun_phrases\": [{\"ngram\": \"Peng\", \"from\": 2255, \"to\": 2259}, {\"ngram\": \"public appearances\", \"from\": 2267, \"to\": 2285}, {\"ngram\": \"a video phone call\", \"from\": 2297, \"to\": 2315}]}, {\"sentence\": \"\\\"I would like to thank you for the invitation to the opening of the Olympic Games,\\\" Putin told Xi.\", \"from\": 2352, \"to\": 2450, \"entities\": [{\"begin\": 2436, \"end\": 2441, \"title\": \"http://dbpedia.org/resource/Vladimir_Putin\", \"score\": 1.0, \"rank\": 1.4861746419066837e-46, \"text\": \"Putin\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Vladimir_Putin\", \"dbpedia\": \"http://dbpedia.org/resource/Vladimir_Putin\"}], \"noun_phrase