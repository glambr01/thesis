, {\"ngram\": \"this test\", \"from\": 49477, \"to\": 49486}]}, {\"sentence\": \"They knew that he was running sick today.\", \"from\": 49488, \"to\": 49529, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"They say that was his choice.\", \"from\": 49530, \"to\": 49559, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"his choice\", \"from\": 49548, \"to\": 49558}]}, {\"sentence\": \"U.S. Track and Field says they did follow all the necessary safety and health protocols.\", \"from\": 49560, \"to\": 49648, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"U.S. Track\", \"from\": 49560, \"to\": 49570}, {\"ngram\": \"Field\", \"from\": 49575, \"to\": 49580}, {\"ngram\": \"all the necessary safety and health protocols\", \"from\": 49602, \"to\": 49647}]}, {\"sentence\": \"But Noah Lyles was around a lot of these other athletes, so there are going to be some big questions asked about this decision to have him included in this race.\", \"from\": 49649, \"to\": 49810, \"entities\": [{\"begin\": 49653, \"end\": 49663, \"title\": \"http://dbpedia.org/resource/Noah_Lyles\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Noah Lyles\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Noah_Lyles\", \"dbpedia\": \"http://dbpedia.org/resource/Noah_Lyles\"}], \"noun_phrases\": [{\"ngram\": \"around a lot\", \"from\": 49668, \"to\": 49680}, {\"ngram\": \"these other athletes\", \"from\": 49684, \"to\": 49704}, {\"ngram\": \"some big questions\", \"from\": 49731, \"to\": 49749}, {\"ngram\": \"this decision\", \"from\": 49762, \"to\": 49775}, {\"ngram\": \"this race\", \"from\": 49800, \"to\": 49809}]}, {\"sentence\": \"Remember, Juana, Noah Lyles has suffered from asthma and allergies in the past.\", \"from\": 49811, \"to\": 49890, \"entities\": [{\"begin\": 49828, \"end\": 49838, \"title\": \"http://dbpedia.org/resource/Noah_Lyles\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Noah Lyles\", \"types\": [\"Q729\", \"Q5\", \"Q21562