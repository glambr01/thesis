ities\": [{\"begin\": 2440, \"end\": 2453, \"title\": \"http://dbpedia.org/resource/Derrick_White_(basketball)\", \"score\": 0.9925925345590776, \"rank\": 0.006633499170812927, \"text\": \"Derrick White\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Derrick_White_(basketball)\", \"dbpedia\": \"http://dbpedia.org/resource/Derrick_White_(basketball)\"}, {\"begin\": 2499, \"end\": 2505, \"title\": \"http://dbpedia.org/resource/Serbia_national_football_team\", \"score\": 0.9816187680344238, \"rank\": 0.01870117097886594, \"text\": \"Serbia\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Serbia_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Serbia_national_football_team\"}], \"noun_phrases\": [{\"ngram\": \"Marko Guduric\", \"from\": 2376, \"to\": 2389}, {\"ngram\": \"a four-point play\", \"from\": 2400, \"to\": 2417}, {\"ngram\": \"a bomb\", \"from\": 2457, \"to\": 2463}, {\"ngram\": \"the arc\", \"from\": 2481, \"to\": 2488}, {\"ngram\": \"the fourth quarter\", \"from\": 2511, \"to\": 2529}, {\"ngram\": \"the ascent\", \"from\": 2533, \"to\": 2543}]}, {\"sentence\": \"But the US team, reckoned to be the most talented since Michael Jordan led the 1992 Dream Team, found a way.\", \"from\": 2546, \"to\": 2654, \"entities\": [{\"begin\": 2554, \"end\": 2556, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 1.0, \"rank\": 3.608968997647895e-18, \"text\": \"US\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\"}, {\"begin\": 2602, \"end\": 2616, \"title\": \"http://dbpedia.org/resource/Michael_Jordan\", \"score\": 1.0, \"rank\": 7.10687774444244e-43, \"text\": \"Michael Jordan\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"]