Young_(basketball)\"}], \"noun_phrases\": [{\"ngram\": \"Young\", \"from\": 1435, \"to\": 1440}, {\"ngram\": \"her first attempt\", \"from\": 1448, \"to\": 1465}, {\"ngram\": \"the game\", \"from\": 1469, \"to\": 1477}, {\"ngram\": \"a big offensive rebound\", \"from\": 1502, \"to\": 1525}, {\"ngram\": \"\\u00c2\", \"from\": 1550, \"to\": 1551}]}, {\"sentence\": \"After an uncharacteristic turnover, she got the ball back for Team USA and scored on two straight possessions: one on a step-through in the paint, the other a mid-range pullup.\", \"from\": 1595, \"to\": 1771, \"entities\": [{\"begin\": 1657, \"end\": 1665, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 0.9999999834321899, \"rank\": 1.5534818616007885e-08, \"text\": \"Team USA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\"}], \"noun_phrases\": [{\"ngram\": \"an uncharacteristic turnover\", \"from\": 1601, \"to\": 1629}, {\"ngram\": \"the ball\", \"from\": 1639, \"to\": 1647}, {\"ngram\": \"two straight possessions\", \"from\": 1680, \"to\": 1704}, {\"ngram\": \"a step-through\", \"from\": 1713, \"to\": 1727}, {\"ngram\": \"the paint\", \"from\": 1731, \"to\": 1740}, {\"ngram\": \"the other a mid-range pullup\", \"from\": 1742, \"to\": 1770}]}, {\"sentence\": \"She did her thing on the defensive end too, causing three turnovers for Nigeria.\", \"from\": 1772, \"to\": 1852, \"entities\": [{\"begin\": 1844, \"end\": 1851, \"title\": \"http://dbpedia.org/resource/Nigeria_national_football_team\", \"score\": 0.9624438927997488, \"rank\": 0.03804389228087575, \"text\": \"Nigeria\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Nigeria_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Nigeria_national_football_team\"}], \"noun_phrases\": [{\"ngram\