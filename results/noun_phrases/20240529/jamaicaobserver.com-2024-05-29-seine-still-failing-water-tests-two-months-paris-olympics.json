"{\"uid\": \"jamaicaobserver.com-2024-05-29-seine-still-failing-water-tests-two-months-paris-olympics\", \"noun_phrases\": [{\"sentence\": \"PARIS, France (AFP)- Water tests in the Seine in Paris show the river is still too dirty to swim in, two months before the start of the Paris Olympics when it is set be used by athletes, data from a charity showed Wednesday.\", \"from\": 0, \"to\": 224, \"entities\": [{\"begin\": 7, \"end\": 13, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9998201778044381, \"rank\": 0.00010487454987661973, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 40, \"end\": 45, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999999999986358, \"rank\": 1.1238930327443188e-12, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}, {\"begin\": 49, \"end\": 54, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999979536, \"rank\": 2.0714865602290796e-12, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"PARIS\", \"from\": 0, \"to\": 5}, {\"ngram\": \"the river\", \"from\": 60, \"to\": 69}, {\"ngram\": \"the start\", \"from\": 119, \"to\": 128}, {\"ngram\": \"the Paris Olympics\", \"from\": 132, \"to\": 150}, {\"ngram\": \"athletes\", \"from\": 177, \"to\": 185}, {\"ngram\": \"data\", \"from\": 187, \"to\": 191}, {\"ngram\": \"a charity\", \"from\": 197, \"to\": 206}]}, {\"sentence\": \"French authorities have been in a race against time to clean up the Seine, which is set to host the swimming leg of the triathlon at the end of July as well as the open-water swimming in August.\", \"from\": 226, \"to\": 420, \"entities\": [{\"begin\": 226, \"end\": 232, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.7182212736137727, \"rank\": 0.3753156926390309, \"text\": \"French\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 294, \"end\": 299, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999999999986358, \"rank\": 1.1238930327443188e-12, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"a race\", \"from\": 258, \"to\": 264}, {\"ngram\": \"time\", \"from\": 273, \"to\": 277}, {\"ngram\": \"the swimming leg\", \"from\": 322, \"to\": 338}, {\"ngram\": \"the triathlon\", \"from\": 342, \"to\": 355}, {\"ngram\": \"the end\", \"from\": 359, \"to\": 366}, {\"ngram\": \"July\", \"from\": 370, \"to\": 374}, {\"ngram\": \"August\", \"from\": 413, \"to\": 419}]}, {\"sentence\": \"Water charity Surfrider has been conducting regular tests to measure levels of two crucial bacteria which indicate the presence of faecal matter.\", \"from\": 422, \"to\": 567, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Water charity Surfrider\", \"from\": 422, \"to\": 445}, {\"ngram\": \"regular tests\", \"from\": 466, \"to\": 479}, {\"ngram\": \"levels\", \"from\": 491, \"to\": 497}, {\"ngram\": \"two crucial bacteria\", \"from\": 501, \"to\": 521}, {\"ngram\": \"the presence\", \"from\": 537, \"to\": 549}, {\"ngram\": \"faecal matter\", \"from\": 553, \"to\": 566}]}, {\"sentence\": \"Its latest results showed levels of E. Coli and enterococci higher than authorised levels set by sports federations and European bathing standards.\", \"from\": 569, \"to\": 716, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Its latest results\", \"from\": 569, \"to\": 587}, {\"ngram\": \"levels\", \"from\": 595, \"to\": 601}, {\"ngram\": \"E. Coli\", \"from\": 605, \"to\": 612}, {\"ngram\": \"enterococci\", \"from\": 617, \"to\": 628}, {\"ngram\": \"authorised levels\", \"from\": 641, \"to\": 658}, {\"ngram\": \"sports federations\", \"from\": 666, \"to\": 684}, {\"ngram\": \"European bathing standards\", \"from\": 689, \"to\": 715}]}, {\"sentence\": \"One reading for E.Coli at the Alexandre III bridge was more than three times higher than the maximum level authorised by the triathlon and open-water swimming federations.\", \"from\": 718, \"to\": 889, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"One reading\", \"from\": 718, \"to\": 729}, {\"ngram\": \"E.Coli\", \"from\": 734, \"to\": 740}, {\"ngram\": \"the Alexandre III bridge\", \"from\": 744, \"to\": 768}, {\"ngram\": \"the maximum level\", \"from\": 807, \"to\": 824}, {\"ngram\": \"the triathlon\", \"from\": 839, \"to\": 852}, {\"ngram\": \"open-water swimming federations\", \"from\": 857, \"to\": 888}]}, {\"sentence\": \"Heavy rainfall in May is likely to have contributed to what Surfrider called the \\\"poor\\\" water quality.\", \"from\": 891, \"to\": 993, \"entities\": [{\"begin\": 951, \"end\": 960, \"title\": \"http://dbpedia.org/resource/Surfrider\", \"score\": 0.8020135056823948, \"rank\": 0.0, \"text\": \"Surfrider\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Surfrider\", \"dbpedia\": \"http://dbpedia.org/resource/Surfrider\"}], \"noun_phrases\": [{\"ngram\": \"Heavy rainfall\", \"from\": 891, \"to\": 905}, {\"ngram\": \"May\", \"from\": 909, \"to\": 912}, {\"ngram\": \"the \\\"poor\\\" water quality\", \"from\": 968, \"to\": 992}]}, {\"sentence\": \"It noted that there had been heavy rain 36 hours before the tests, but only light rain in the 12 hours previous.\", \"from\": 995, \"to\": 1107, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"heavy rain\", \"from\": 1024, \"to\": 1034}, {\"ngram\": \"the tests\", \"from\": 1051, \"to\": 1060}, {\"ngram\": \"the 12 hours\", \"from\": 1085, \"to\": 1097}]}, {\"sentence\": \"Heavy rainfall is known to overwhelm Paris' more than century-old sewage system, leading to direct discharges into the river of untreated effluent.\", \"from\": 1109, \"to\": 1256, \"entities\": [{\"begin\": 1146, \"end\": 1151, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999979536, \"rank\": 2.0714865602290796e-12, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Heavy rainfall\", \"from\": 1109, \"to\": 1123}, {\"ngram\": \"century-old sewage system\", \"from\": 1163, \"to\": 1188}, {\"ngram\": \"direct discharges\", \"from\": 1201, \"to\": 1218}, {\"ngram\": \"the river\", \"from\": 1224, \"to\": 1233}, {\"ngram\": \"untreated effluent\", \"from\": 1237, \"to\": 1255}]}, {\"sentence\": \"Organisers are praying for fine weather during the July 26-August 11 Olympics and have been open about the possibility of needing to delay or even cancel the Seine swimming in the event of storms.\", \"from\": 1258, \"to\": 1454, \"entities\": [{\"begin\": 1416, \"end\": 1421, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999999999986358, \"rank\": 1.1238930327443188e-12, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"Organisers\", \"from\": 1258, \"to\": 1268}, {\"ngram\": \"fine weather\", \"from\": 1285, \"to\": 1297}, {\"ngram\": \"the July 26-August 11 Olympics\", \"from\": 1305, \"to\": 1335}, {\"ngram\": \"the possibility\", \"from\": 1361, \"to\": 1376}, {\"ngram\": \"the event\", \"from\": 1434, \"to\": 1443}, {\"ngram\": \"storms\", \"from\": 1447, \"to\": 1453}]}, {\"sentence\": \"Although a new water treatment plant was inaugurated upstream of Paris at the end of April in Champigny-sur-Marne, another major Olympics-related water infrastructure project has yet to enter service.\", \"from\": 1456, \"to\": 1656, \"entities\": [{\"begin\": 1521, \"end\": 1526, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999979536, \"rank\": 2.0714865602290796e-12, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 1550, \"end\": 1569, \"title\": \"http://dbpedia.org/resource/Champigny-sur-Marne\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Champigny-sur-Marne\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Champigny-sur-Marne\", \"dbpedia\": \"http://dbpedia.org/resource/Champigny-sur-Marne\"}], \"noun_phrases\": [{\"ngram\": \"a new water treatment plant\", \"from\": 1465, \"to\": 1492}, {\"ngram\": \"the end\", \"from\": 1530, \"to\": 1537}, {\"ngram\": \"April\", \"from\": 1541, \"to\": 1546}, {\"ngram\": \"another major Olympics-related water infrastructure project\", \"from\": 1571, \"to\": 1630}, {\"ngram\": \"service\", \"from\": 1648, \"to\": 1655}]}, {\"sentence\": \"A giant new underground storm water facility close to the Austerlitz train station in eastern Paris - which will stock water to prevent discharges into the river - is scheduled to come on stream in early June.\", \"from\": 1658, \"to\": 1867, \"entities\": [{\"begin\": 1716, \"end\": 1726, \"title\": \"http://dbpedia.org/resource/Gare_d'Austerlitz\", \"score\": 0.9992967232026942, \"rank\": 0.0007037717436720232, \"text\": \"Austerlitz\", \"types\": [\"Q719456\"], \"wikid\": \"http://dbpedia.org/resource/Gare_d'Austerlitz\", \"dbpedia\": \"http://dbpedia.org/resource/Gare_d'Austerlitz\"}, {\"begin\": 1752, \"end\": 1757, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999979536, \"rank\": 2.0714865602290796e-12, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"A giant new underground storm water faci