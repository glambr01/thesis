"{\"uid\": \"nbcsports.com-olympics-news-lilly-king-swimming-paris-olympics\", \"noun_phrases\": [{\"sentence\": \"Lilly King, a five-time Olympic medalist and 11-time world champion breaststroker, plans to make the Paris Games her final Olympics, should she make the team at June's trials, though it will not be the last overall competition of her career.\", \"from\": 0, \"to\": 241, \"entities\": [{\"begin\": 0, \"end\": 5, \"title\": \"http://dbpedia.org/resource/Eli_Lilly_and_Company\", \"score\": 0.999999816104963, \"rank\": 1.8207438414054893e-07, \"text\": \"Lilly\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Eli_Lilly_and_Company\", \"dbpedia\": \"http://dbpedia.org/resource/Eli_Lilly_and_Company\"}], \"noun_phrases\": [{\"ngram\": \"a five-time Olympic medalist\", \"from\": 12, \"to\": 40}, {\"ngram\": \"11-time world champion breaststroker\", \"from\": 45, \"to\": 81}, {\"ngram\": \"her final Olympics\", \"from\": 113, \"to\": 131}, {\"ngram\": \"the team\", \"from\": 149, \"to\": 157}, {\"ngram\": \"June's trials\", \"from\": 161, \"to\": 174}, {\"ngram\": \"the last overall competition\", \"from\": 198, \"to\": 226}, {\"ngram\": \"her career\", \"from\": 230, \"to\": 240}]}, {\"sentence\": \"\\\"I do not want to go to 2028,\\\" she said Friday of the next Games in Los Angeles.\", \"from\": 243, \"to\": 323, \"entities\": [{\"begin\": 311, \"end\": 322, \"title\": \"http://dbpedia.org/resource/Los_Angeles\", \"score\": 0.9999950891538066, \"rank\": 4.514272195797758e-06, \"text\": \"Los Angeles\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Los_Angeles\", \"dbpedia\": \"http://dbpedia.org/resource/Los_Angeles\"}], \"noun_phrases\": [{\"ngram\": \"the next Games\", \"from\": 293, \"to\": 307}]}, {\"sentence\": \"\\\"I am not going to be done after this Olympics, but I will be watching 2028 definitely.\\\"\", \"from\": 324, \"to\": 412, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this Olympics\", \"from\": 357, \"to\": 370}]}, {\"sentence\": \"King, 27, said she has a competitive endpoint in mind, which she will publicly share later.\", \"from\": 414, \"to\": 505, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"King\", \"from\": 414, \"to\": 418}, {\"ngram\": \"a competitive endpoint\", \"from\": 437, \"to\": 459}, {\"ngram\": \"mind\", \"from\": 463, \"to\": 467}]}, {\"sentence\": \"\\\"(After competing) I am going to relax and learn how to be a normal human and do (swim) clinics for a while.\", \"from\": 507, \"to\": 615, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a normal human\", \"from\": 566, \"to\": 580}, {\"ngram\": \"(swim) clinics\", \"from\": 588, \"to\": 602}]}, {\"sentence\": \"That's my plan,\\\" she said.\", \"from\": 616, \"to\": 642, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my plan\", \"from\": 623, \"to\": 630}]}, {\"sentence\": \"\\\"I am going to be Lilly King as long as they allow me to be Lilly King and hopefully get to spread some of my knowledge and what the sport has given me back to the swimming community.\\\"\", \"from\": 643, \"to\": 827, \"entities\": [{\"begin\": 661, \"end\": 666, \"title\": \"http://dbpedia.org/resource/Eli_Lilly_and_Company\", \"score\": 0.999999816104963, \"rank\": 1.8207438414054893e-07, \"text\": \"Lilly\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Eli_Lilly_and_Company\", \"dbpedia\": \"http://dbpedia.org/resource/Eli_Lilly_and_Company\"}, {\"begin\": 703, \"end\": 708, \"title\": \"http://dbpedia.org/resource/Eli_Lilly_and_Company\", \"score\": 0.999999816104963, \"rank\": 1.8207438414054893e-07, \"text\": \"Lilly\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Eli_Lilly_and_Company\", \"dbpedia\": \"http://dbpedia.org/resource/Eli_Lilly_and_Company\"}], \"noun_phrases\": [{\"ngram\": \"my knowledge\", \"from\": 750, \"to\": 762}, {\"ngram\": \"the sport\", \"from\": 772, \"to\": 781}, {\"ngram\": \"the swimming community\", \"from\": 803, \"to\": 825}]}, {\"sentence\": \"King, an Indiana native, will be one of the home favorites at the Olympic Trials at the Indianapolis Colts' Lucas Oil Stadium, where the top two in her events - the 100m and 200m breaststrokes - make the team for the Paris Games.\", \"from\": 829, \"to\": 1058, \"entities\": [{\"begin\": 838, \"end\": 845, \"title\": \"http://dbpedia.org/resource/Indiana\", \"score\": 0.9046037533196847, \"rank\": 0.10433986488139395, \"text\": \"Indiana\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Indiana\", \"dbpedia\": \"http://dbpedia.org/resource/Indiana\"}], \"noun_phrases\": [{\"ngram\": \"King\", \"from\": 829, \"to\": 833}, {\"ngram\": \"the home favorites\", \"from\": 869, \"to\": 887}, {\"ngram\": \"the Olympic Trials\", \"from\": 891, \"to\": 909}, {\"ngram\": \"the Indianapolis Colts' Lucas Oil Stadium\", \"from\": 913, \"to\": 954}, {\"ngram\": \"her events\", \"from\": 977, \"to\": 987}, {\"ngram\": \"the 100m\", \"from\": 990, \"to\": 998}, {\"ngram\": \"the team\", \"from\": 1029, \"to\": 1037}, {\"ngram\": \"the Paris Games\", \"from\": 1042, \"to\": 1057}]}, {\"sentence\": \"Growing up in Evansville, she drove past the stadium en route to swim meets one mile northwest at the Indiana University Natatorium.\", \"from\": 1060, \"to\": 1192, \"entities\": [{\"begin\": 1074, \"end\": 1084, \"title\": \"http://dbpedia.org/resource/University_of_Evansville\", \"score\": 0.9940870754434487, \"rank\": 0.005947879552964499, \"text\": \"Evansville\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/University_of_Evansville\", \"dbpedia\": \"http://dbpedia.org/resource/University_of_Evansville\"}, {\"begin\": 1162, \"end\": 1191, \"title\": \"http://dbpedia.org/resource/Indiana_University_Natatorium\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Indiana University Natatorium\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Indiana_University_Natatorium\", \"dbpedia\": \"http://dbpedia.org/resource/Indiana_University_Natatorium\"}], \"noun_phrases\": [{\"ngram\": \"the stadium\", \"from\": 1101, \"to\": 1112}, {\"ngram\": \"route\", \"from\": 1116, \"to\": 1121}]}, {\"sentence\": \"\\\"It was like, oh, I see Lucas Oil, it's time to swim fast,\\\" said King, who won eight NCAA breaststroke titles in her four years at Indiana, where she still trains.\", \"from\": 1194, \"to\": 1357, \"entities\": [{\"begin\": 1218, \"end\": 1223, \"title\": \"http://dbpedia.org/resource/George_Lucas\", \"score\": 0.9999315743810804, \"rank\": 6.791844786623696e-05, \"text\": \"Lucas\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/George_Lucas\", \"dbpedia\": \"http://dbpedia.org/resource/George_Lucas\"}, {\"begin\": 1279, \"end\": 1283, \"title\": \"http://dbpedia.org/resource/National_Collegiate_Athletic_Association\", \"score\": 0.9994472404239766, \"rank\": 0.00041154972008126435, \"text\": \"NCAA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/National_Collegiate_Athletic_Association\", \"dbpedia\": \"http://dbpedia.org/resource/National_Collegiate_Athletic_Association\"}, {\"begin\": 1325, \"end\": 1332, \"title\": \"http://dbpedia.org/resource/Indiana\", \"score\": 0.9046037533196847, \"rank\": 0.10433986488139395, \"text\": \"Indiana\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Indiana\", \"dbpedia\": \"http://dbpedia.org/resource/Indiana\"}], \"noun_phrases\": [{\"ngram\": \"time\", \"from\": 1234, \"to\": 1238}, {\"ngram\": \"King\", \"from\": 1259, \"to\": 1263}, {\"ngram\": \"her four years\", \"from\": 1307, \"to\": 1321}]}, {\"sentence\": \"She made every U.S. team since sweeping the 100m and 200m breaststrokes at the 2016 Olympic Trials following her freshman year in Bloomington, then winning 100m breast gold at the Rio Games over Russian rival Yuliya Yefimova.\", \"from\": 1359, \"to\": 1584, \"entities\": [{\"begin\": 1489, \"end\": 1500, \"title\": \"http://dbpedia.org/resource/Indiana_University_Bloomington\", \"score\": 1.0, \"rank\": 4.798499381546921e-25, \"text\": \"Bloomington\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/Indiana_University_Bloomington\", \"dbpedia\": \"http://dbpedia.org/resource/Indiana_University_Bloomington\"}, {\"begin\": 1554, \"end\": 1561, \"title\": \"http://dbpedia.org/resource/Russian_language\", \"score\": 0.9792715728890894, \"rank\": 0.020652678460615824, \"text\": \"Russian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Russian_language\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_language\"}, {\"begin\": 1568, \"end\": 1583, \"title\": \"http://dbpedia.org/resource/Yuliya_Yefimova\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Yuliya Yefimova\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Yuliya_Yefimova\", \"dbpedia\": \"http://dbpedia.org/resource/Yuliya_Yefimova\"}], \"noun_phrases\": [{\"ngram\": \"every U.S. team\", \"from\": 1368, \"to\": 1383}, {\"ngram\": \"the 100m and 200m breaststrokes\", \"from\": 1399, \"to\": 1430}, {\"ngram\": \"the 2016 Olympic Trials\", \"from\": 1434, \"to\": 1457}, {\"ngram\": \"her freshman year\", \"from\": 1468, \"to\": 1485}, {\"ngram\": \"100m breast gold\", \"from\": 1515, \"to\": 1531}, {\"ngram\": \"the Rio Games\", \"from\": 1535, \"to\": 1548}]}, {\"sentence\": \"King captured a world title in all three breaststrokes - 50m, 100m and 200m - and has owned the 100m breast world record since 2017.\", \"from\": 1586, \"to\": 1718, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"King\", \"from\": 1586, \"to\": 1590}, {\"ngram\": \"a world title\", \"from\": 1600, \"to\": 1613}, {\"ngram\": \"all three breaststrokes\", \"from\": 1617, \"to\": 1640}, {\"ngram\": \"50m\", \"from\": 1643, \"to\": 1646}, {\"ngram\": \"100m\", \"from\": 1648, \"to\": 1652}, {\"ngram\": \"200m\", \"from\": 1657, \"to\": 1661}, {\"ngram\": \"the 100m breast world record\", \"from\": 1678, \"to\": 1706}]}, {\"sentence\": \"At the Tokyo Olympics, she took 100m breast bronze (behind breakout Alaskan winner Lydia Jacoby) and 200m breast silver, sharing the podium with close friend Annie Lazor, the bronze medalist.\", \"from\": 1720, \"to\": 1911, \"entities\": [{\"begin\": 1803, \"end\": 1815, \"title\": \"http://dbpedia.org/resource/Lydia_Jacoby\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Lydia Jacoby\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Lydia_Jacoby\", \"dbpedia\": \"http://dbpedia.org/resource/Lydia_Jacoby\"}, {\"begin\": 1878, \"end\": 1889, \"title\": \"http://dbpedia.org/resource/Annie_Lazor\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Annie Lazor\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Annie_Lazor\", \"dbpedia\": \"http://dbpedia.org/resource/Annie_Lazor\"}], \"noun_phrases\": [{\"ngram\": \"the Tokyo Olympics\", \"from\": 1723, \"to\": 1741}, {\"ngram\": \"100m breast bronze\", \"from\": 1752, \"to\": 1770}, {\"ngram\": \"breakout Alaskan winner\", \"from\": 1779, \"to\": 1802}, {\"ngram\": \"200m breast silver\", \"from\": 1821, \"to\": 1839}, {\"ngram\": \"the podium\", \"from\": 1849, \"to\": 1859}, {\"ngram\": \"the bronze medalist\", \"from\": 1891, \"to\": 1910}]}, {\"sentence\": \"King placed fourth in the 100m and 200m breaststrokes at last July's world championships.\", \"from\": 1913, \"to\": 2002, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"King\", \"from\": 1913, \"to\": 1917}, {\"ngram\": \"the 100m\", \"from\": 1935, \"to\": 1943}, {\"ngram\": \"200m breaststrokes\", \"from\": 1948, \"to\": 1966}, {\"ngram\": \"last July's world championships\", \"from\": 1970, \"to\": 2001}]}, {\"se