"{\"uid\": \"thenews.com.pk-latest-1216145-google-pulls-olympics-ai-ad-after-backlash\", \"noun_phrases\": [{\"sentence\": \"SAN FRANCISCO: Google confirmed Friday that it had pulled an ad for its Gemini artificial intelligence after it landed flat with some Olympics viewers.\", \"from\": 0, \"to\": 151, \"entities\": [{\"begin\": 15, \"end\": 21, \"title\": \"http://dbpedia.org/resource/Google\", \"score\": 0.958710009832526, \"rank\": 0.04306758235351471, \"text\": \"Google\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Google\", \"dbpedia\": \"http://dbpedia.org/resource/Google\"}, {\"begin\": 72, \"end\": 78, \"title\": \"http://dbpedia.org/resource/Project_Gemini\", \"score\": 0.8436676973956941, \"rank\": 0.18530080381783426, \"text\": \"Gemini\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Project_Gemini\", \"dbpedia\": \"http://dbpedia.org/resource/Project_Gemini\"}], \"noun_phrases\": [{\"ngram\": \"an ad\", \"from\": 58, \"to\": 63}, {\"ngram\": \"some Olympics viewers\", \"from\": 129, \"to\": 150}]}, {\"sentence\": \"The \\\"Dear Sydney\\\" ad, intended to tout capabilities of Gemini AI, featured a dad warmly describing how the tool wrote his daughter a fan letter from her to US hurdler Sydney McLaughlin-Levrone.\", \"from\": 153, \"to\": 346, \"entities\": [{\"begin\": 208, \"end\": 214, \"title\": \"http://dbpedia.org/resource/Project_Gemini\", \"score\": 0.8436676973956941, \"rank\": 0.18530080381783426, \"text\": \"Gemini\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Project_Gemini\", \"dbpedia\": \"http://dbpedia.org/resource/Project_Gemini\"}, {\"begin\": 215, \"end\": 217, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 0.9999725839524907, \"rank\": 2.7415127615964438e-05, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}, 