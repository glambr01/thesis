"{\"uid\": \"thenorthernecho.co.uk-news-24491780.first-man-darlington-area-ever-win-olympic-gold\", \"noun_phrases\": [{\"sentence\": \"Echo MemoriesHeritageHistoryNostalgiaPeopleSportDarlingtonNorth Yorkshire BLAIR ONSLOW COCHRANE is probably the first person with strong County Durham and North Yorkshire links to win an Olympic Gold.\", \"from\": 0, \"to\": 201, \"entities\": [{\"begin\": 64, \"end\": 73, \"title\": \"http://dbpedia.org/resource/Yorkshire\", \"score\": 0.9999999989836397, \"rank\": 1.016480571026981e-09, \"text\": \"Yorkshire\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Yorkshire\", \"dbpedia\": \"http://dbpedia.org/resource/Yorkshire\"}, {\"begin\": 81, \"end\": 87, \"title\": \"http://dbpedia.org/resource/HMAS_Onslow\", \"score\": 0.9999999999918145, \"rank\": 6.070970983835465e-12, \"text\": \"ONSLOW\", \"types\": [\"Q11446\"], \"wikid\": \"http://dbpedia.org/resource/HMAS_Onslow\", \"dbpedia\": \"http://dbpedia.org/resource/HMAS_Onslow\"}, {\"begin\": 88, \"end\": 96, \"title\": \"http://dbpedia.org/resource/Cochrane_Library\", \"score\": 0.999969965700004, \"rank\": 1.7176900699598597e-05, \"text\": \"COCHRANE\", \"types\": [\"Q737498\", \"Q386724\", \"Q234460\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/Cochrane_Library\", \"dbpedia\": \"http://dbpedia.org/resource/Cochrane_Library\"}, {\"begin\": 138, \"end\": 151, \"title\": \"http://dbpedia.org/resource/County_Durham\", \"score\": 1.0, \"rank\": 1.020624558237462e-23, \"text\": \"County Durham\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/County_Durham\", \"dbpedia\": \"http://dbpedia.org/resource/County_Durham\"}, {\"begin\": 156, \"end\": 171, \"title\": \"http://dbpedia.org/resource/North_Yorkshire\", \"score\": 0.9999993562966918, \"rank\": 6.435758432408837e-07, \"text\": \"North Yorkshire\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/North_Yorkshire\", \"dbpedia\": \"http://dbpedia.org/resource/North_Yorkshire\"}], \"noun_phrases\": [{\"ngram\": \"the first person\", \"from\": 108, \"to\": 124}, {\"ngram\": \"an Olympic Gold\", \"from\": 184, \"to\": 199}]}, {\"sentence\": \"The official Olympic books say that he was born in 1853 in Darlington, but that is only where his birth was registered.\", \"from\": 203, \"to\": 322, \"entities\": [{\"begin\": 262, \"end\": 272, \"title\": \"http://dbpedia.org/resource/Darlington\", \"score\": 1.0, \"rank\": 5.657644691741755e-22, \"text\": \"Darlington\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Darlington\", \"dbpedia\": \"http://dbpedia.org/resource/Darlington\"}], \"noun_phrases\": [{\"ngram\": \"The official Olympic books\", \"from\": 203, \"to\": 229}, {\"ngram\": \"his birth\", \"from\": 297, \"to\": 306}]}, {\"sentence\": \"He was actually born in Monkend at Croft-on-Tees, and so in North Yorkshire, into a family of sailors.\", \"from\": 324, \"to\": 426, \"entities\": [{\"begin\": 359, \"end\": 372, \"title\": \"http://dbpedia.org/resource/Croft-on-Tees\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Croft-on-Tees\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Croft-on-Tees\", \"dbpedia\": \"http://dbpedia.org/resource/Croft-on-Tees\"}, {\"begin\": 384, \"end\": 399, \"title\": \"http://dbpedia.org/resource/North_Yorkshire\", \"score\": 0.9999993562966918, \"rank\": 6.435758432408837e-07, \"text\": \"North Yorkshire\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/North_Yorkshire\", \"dbpedia\": \"http://dbpedia.org/resource/North_Yorkshire\"}], \"noun_phrases\": [{\"ngram\": \"Monkend\", \"from\": 348, \"to\": 355}, {\"ngram\": \"a family\", \"from\": 406, \"to\": 414}, {\"ngram\": \"sailors\", \"from\": 418, \"to\": 425}]}, {\"sentence\": \"His great-grandfather, the 9th Earl of Dundonald, a Scottish aristocrat, lost nearly all the family fortune by ploughing it into his invention of coal tar which, he said, would waterproof ships to prevent rotting timbers.\", \"from\": 427, \"to\": 648, \"entities\": [{\"begin\": 479, \"end\": 487, \"title\": \"http://dbpedia.org/resource/Scottish_people\", \"score\": 0.8770538995622618, \"rank\": 0.14018074231166203, \"text\": \"Scottish\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Scottish_people\", \"dbpedia\": \"http://dbpedia.org/resource/Scottish_people\"}], \"noun_phrases\": [{\"ngram\": \"His great-grandfather\", \"from\": 427, \"to\": 448}, {\"ngram\": \"the 9th Earl\", \"from\": 450, \"to\": 462}, {\"ngram\": \"Dundonald\", \"from\": 466, \"to\": 475}, {\"ngram\": \"nearly all the family fortune\", \"from\": 505, \"to\": 534}, {\"ngram\": \"his invention\", \"from\": 556, \"to\": 569}, {\"ngram\": \"coal tar\", \"from\": 573, \"to\": 581}, {\"ngram\": \"ships\", \"from\": 615, \"to\": 620}, {\"ngram\": \"timbers\", \"from\": 640, \"to\": 647}]}, {\"sentence\": \"The 9th Earl's two sons, Thomas and Archibald, fought so heroically in the Mediterranean during the Napoleonic Wars that Napoleon nicknamed the oldest \\\"Le Loup des Mers\\\" - the Sea Wolf.\", \"from\": 650, \"to\": 835, \"entities\": [{\"begin\": 675, \"end\": 681, \"title\": \"http://dbpedia.org/resource/Thomas_the_Tank_Engine\", \"score\": 0.9961044194315426, \"rank\": 0.0037896534422560946, \"text\": \"Thomas\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Thomas_the_Tank_Engine\", \"dbpedia\": \"http://dbpedia.org/resource/Thomas_the_Tank_Engine\"}, {\"begin\": 686, \"end\": 695, \"title\": \"http://dbpedia.org/resource/Archibald_Prize\", \"score\": 0.9886072415804054, \"rank\": 0.011524049124069222, \"text\": \"Archibald\", \"types\": [\"Q618779\"], \"wikid\": \"http://dbpedia.org/resource/Archibald_Prize\", \"dbpedia\": \"http://dbpedia.org/resource/Archibald_Prize\"}, {\"begin\": 771, \"end\": 779, \"title\": \"http://dbpedia.org/resource/Napoleon\", \"score\": 1.0, \"rank\": 2.1114554840312e-29, \"text\": \"Napoleon\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Napoleon\", \"dbpedia\": \"http://dbpedia.org/resource/Napoleon\"}], \"noun_phrases\": [{\"ngram\": \"The 9th Earl's two sons\", \"from\": 650, \"to\": 673}, {\"ngram\": \"the Mediterranean\", \"from\": 721, \"to\": 738}, {\"ngram\": \"the Napoleonic Wars\", \"from\": 746, \"to\": 765}, {\"ngram\": \"the oldest \\\"Le Loup des Mers\", \"from\": 790, \"to\": 818}, {\"ngram\": \"the Sea Wolf\", \"from\": 822, \"to\": 834}]}, {\"sentence\": \"The younger brother, Archibald, married Jane Mowbray of Sunderland, and they took up residence at Hetton Hall, at Hetton-le-Hole.\", \"from\": 836, \"to\": 965, \"entities\": [{\"begin\": 857, \"end\": 866, \"title\": \"http://dbpedia.org/resource/Archibald_Prize\", \"score\": 0.9886072415804054, \"rank\": 0.011524049124069222, \"text\": \"Archibald\", \"types\": [\"Q618779\"], \"wikid\": \"http://dbpedia.org/resource/Archibald_Prize\", \"dbpedia\": \"http://dbpedia.org/resource/Archibald_Prize\"}, {\"begin\": 876, \"end\": 880, \"title\": \"http://dbpedia.org/resource/Jane_Seymour\", \"score\": 0.9999997122231848, \"rank\": 2.8748363945516686e-07, \"text\": \"Jane\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jane_Seymour\", \"dbpedia\": \"http://dbpedia.org/resource/Jane_Seymour\"}, {\"begin\": 881, \"end\": 888, \"title\": \"http://dbpedia.org/resource/House_of_Mowbray\", \"score\": 0.999999999530246, \"rank\": 4.698169599981744e-10, \"text\": \"Mowbray\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/House_of_Mowbray\", \"dbpedia\": \"http://dbpedia.org/resource/House_of_Mowbray\"}, {\"begin\": 892, \"end\": 902, \"title\": \"http://dbpedia.org/resource/Sunderland\", \"score\": 0.9999992854111777, \"rank\": 7.145894385105591e-07, \"text\": \"Sunderland\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Sunderland\", \"dbpedia\": \"h