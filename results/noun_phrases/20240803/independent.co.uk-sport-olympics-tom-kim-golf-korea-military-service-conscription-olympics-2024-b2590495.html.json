core\": 0.9627323638600225, \"rank\": 0.03864681543727106, \"text\": \"Korean\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Korean_language\", \"dbpedia\": \"http://dbpedia.org/resource/Korean_language\"}], \"noun_phrases\": [{\"ngram\": \"A rule\", \"from\": 1223, \"to\": 1229}, {\"ngram\": \"the 1970s\", \"from\": 1244, \"to\": 1253}, {\"ngram\": \"the Olympic Games\", \"from\": 1287, \"to\": 1304}, {\"ngram\": \"medals\", \"from\": 1318, \"to\": 1324}, {\"ngram\": \"the promise\", \"from\": 1330, \"to\": 1341}, {\"ngram\": \"exemption\", \"from\": 1345, \"to\": 1354}]}, {\"sentence\": \"That rule has evolved to include gold at the Asian Games, which the South Korean football team memorably won in 2022 to ensure their greatest player, Tottenham's Son Heung-min, avoided military service and continued his career in the Premier League.\", \"from\": 1356, \"to\": 1605, \"entities\": [{\"begin\": 1424, \"end\": 1450, \"title\": \"http://dbpedia.org/resource/Football_in_South_Korea\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"South Korean football team\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Football_in_South_Korea\", \"dbpedia\": \"http://dbpedia.org/resource/Football_in_South_Korea\"}, {\"begin\": 1506, \"end\": 1515, \"title\": \"http://dbpedia.org/resource/Tottenham_Hotspur_F.C.\", \"score\": 0.9819490669487635, \"rank\": 0.01838015182328236, \"text\": \"Tottenham\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Tottenham_Hotspur_F.C.\", \"dbpedia\": \"http://dbpedia.org/resource/Tottenham_Hotspur_F.C.\"}, {\"begin\": 1590, \"end\": 1604, \"title\": \"http://dbpedia.org/resource/Premier_League\", \"score\": 0.9999999999990905, \"rank\": 5.422467454839246e-13, \"text\": \"Premier League\", \"types\": [\"Q623109\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Premier_League\", \"dbpedia\": \"http://dbpedia.org/resource/Premier_League\"}], \"noun_phrases\": 