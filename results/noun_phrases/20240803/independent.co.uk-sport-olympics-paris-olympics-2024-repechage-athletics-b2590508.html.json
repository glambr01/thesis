"{\"uid\": \"independent.co.uk-sport-olympics-paris-olympics-2024-repechage-athletics-b2590508.html\", \"noun_phrases\": [{\"sentence\": \"Notifications can be managed in browser preferences.\", \"from\": 0, \"to\": 52, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Notifications\", \"from\": 0, \"to\": 13}, {\"ngram\": \"browser preferences\", \"from\": 32, \"to\": 51}]}, {\"sentence\": \"Please refresh the page or navigate to another page on the site to be automatically logged inPlease refresh your browser to be logged in Swipe for next article Athletics events at the Paris Games will see a change Removed from bookmarks I would like to be emailed about offers, events and updates from The Independent.\", \"from\": 54, \"to\": 376, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the page\", \"from\": 69, \"to\": 77}, {\"ngram\": \"another page\", \"from\": 93, \"to\": 105}, {\"ngram\": \"the site\", \"from\": 109, \"to\": 117}, {\"ngram\": \"inPlease\", \"from\": 145, \"to\": 153}, {\"ngram\": \"your browser\", \"from\": 162, \"to\": 174}, {\"ngram\": \"Swipe\", \"from\": 191, \"to\": 196}, {\"ngram\": \"next article Athletics events\", \"from\": 201, \"to\": 230}, {\"ngram\": \"the Paris Games\", \"from\": 234, \"to\": 249}, {\"ngram\": \"a change\", \"from\": 259, \"to\": 267}, {\"ngram\": \"bookmarks\", \"from\": 281, \"to\": 290}, {\"ngram\": \"offers\", \"from\": 324, \"to\": 330}, {\"ngram\": \"events\", \"from\": 332, \"to\": 338}, {\"ngram\": \"updates\", \"from\": 343, \"to\": 350}, {\"ngram\": \"The Independent\", \"from\": 356, \"to\": 371}]}, {\"sentence\": \"Read ourPrivacy notice TheParis 2024Olympic Games will have a repechage round for all individual track events from 200m to 1500m.\", \"from\": 377, \"to\": 507, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"ourPrivacy notice\", \"from\": 382, \"to\": 399}, {\"ngram\": \"TheParis 2024Olympic Games\", \"from\": 400, \"to\": 426}, {\"ngram\": \"a repechage round\", \"from\": 437, \"to\": 454}, {\"ngram\": \"all individual track events\", \"from\": 459, \"to\": 486}, {\"ngram\": \"1500m.\", \"from\": 500, \"to\": 506}]}, {\"sentence\": \"The decision is a change from the standard competition format, and will include hurdles events.\", \"from\": 509, \"to\": 604, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The decision\", \"from\": 509, \"to\": 521}, {\"ngram\": \"a change\", \"from\": 525, \"to\": 533}, {\"ngram\": \"the standard competition format\", \"from\": 539, \"to\": 570}, {\"ngram\": \"hurdles events\", \"from\": 589, \"to\": 603}]}, {\"sentence\": \"\\\"The repechage rounds will give more exposure to our sport during the peak Olympic period and will be carefully scheduled to ensure that every event on our Olympic programme retains its share of the spotlight\\\", saidWorld AthleticsPresidentSebastian Coewhen the new rounds were announced in July 2022.\", \"from\": 606, \"to\": 906, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The repechage rounds\", \"from\": 607, \"to\": 627}, {\"ngram\": \"more exposure\", \"from\": 638, \"to\": 651}, {\"ngram\": \"our sport\", \"from\": 655, \"to\": 664}, {\"ngram\": \"the peak Olympic period\", \"from\": 672, \"to\": 695}, {\"ngram\": \"every event\", \"from\": 743, \"to\": 754}, {\"ngram\": \"our Olympic programme\", \"from\": 758, \"to\": 779}, {\"ngram\": \"its share\", \"from\": 788, \"to\": 797}, {\"ngram\": \"the spotlight\", \"from\": 801, \"to\": 814}, {\"ngram\": \"saidWorld AthleticsPresidentSebastian Coewhen\", \"from\": 817, \"to\": 862}, {\"ngram\": \"the new rounds\", \"from\": 863, \"to\": 877}, {\"ngram\": \"July\", \"from\": 896, \"to\": 900}]}, {\"sentence\": \"What is a repechage?\", \"from\": 908, \"to\": 928, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a repechage\", \"from\": 916, \"to\": 927}]}, {\"sentence\": \"A repechage is a term from rowing and wrestling that allows athletes who have been knocked out in the early rounds have a second chance at qualifying for matches later on.\", \"from\": 930, \"to\": 1101, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A repechage\", \"from\": 930, \"to\": 941}, {\"ngram\": \"a term\", \"from\": 945, \"to\": 951}, {\"ngram\": \"athletes\", \"from\": 990, \"to\": 998}, {\"ngram\": \"the early rounds\", \"from\": 1028, \"to\": 1044}, {\"ngram\": \"a second chance\", \"from\": 1050, \"to\": 1065}, {\"ngram\": \"matches\", \"from\": 1084, \"to\": 1091}]}, {\"sentence\": \"How will it work?\", \"from\": 1103, \"to\": 1120, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"In every first round heat, a certain number of athletes will secure their progress by finishing in the automatic qualifying positions, but for those who do not finish, there will be a second chance to reach the semi-finals with a repechage heats.\", \"from\": 1122, \"to\": 1368, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"every first round heat\", \"from\": 1125, \"to\": 1147}, {\"ngram\": \"a certain number\", \"from\": 1149, \"to\": 1165}, {\"ngram\": \"athletes\", \"from\": 1169, \"to\": 1177}, {\"ngram\": \"their progress\", \"from\": 1190, \"to\": 1204}, {\"ngram\": \"the automatic qualifying positions\", \"from\": 1221, \"to\": 1255}, {\"ngram\": \"a second chance\", \"from\": 1304, \"to\": 1319}, {\"ngram\": \"the semi\", \"from\": 1329, \"to\": 1337}, {\"ngram\": \"finals\", \"from\": 1338, \"to\": 1344}, {\"ngram\": \"a repechage heats\", \"from\": 1350, \"to\": 1367}]}, {\"sentence\": \"This new system will replace the former when athletes would go through with the fastest times.\", \"from\": 1370, \"to\": 1464, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"This new system\", \"from\": 1370, \"to\": 1385}, {\"ngram\": \"athletes\", \"from\": 1415, \"to\": 1423}, {\"ngram\": \"the fastest times\", \"from\": 1446, \"to\": 1463}]}, {\"sentence\": \"What does it mean?\", \"from\": 1466, \"to\": 1484, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Ultimately, it means that each of the included events will have four rounds, a first round, a repechage round, semi-finals and the final, whereas previously they had contained three.\", \"from\": 1486, \"to\": 1668, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the included events\", \"from\": 1520, \"to\": 1539}, {\"ngram\": \"four rounds\", \"from\": 1550, \"to\": 1561}, {\"ngram\": \"a first round\", \"from\": 1563, \"to\": 1576}, {\"ngram\": \"a repechage round\", \"from\": 1578, \"to\": 1595}, {\"ngram\": \"semi\", \"from\": 1597, \"to\": 1601}, {\"ngram\": \"finals\", \"from\": 1602, \"to\": 1608}]}, {\"sentence\": \"Every athlete will therefore run in at least two races at the Olympic Games.\", \"from\": 1670, \"to\": 1746, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Every athlete\", \"from\": 1670, \"to\": 1683}, {\"ngram\": \"at least two races\", \"from\": 1706, \"to\": 1724}, {\"ngram\": \"the Olympic Games\", \"from\": 1728, \"to\": 1745}]}, {\"sentence\": \"What about the other races?\", \"from\": 1748, \"to\": 1775, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the other races\", \"from\": 1759, \"to\": 1774}]}, {\"sentence\": \"There will be no repechage for the 100m, which has prelimary heats already before the first one.\", \"from\": 1777, \"to\": 1873, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"no repechage\", \"from\": 1791, \"to\": 1803}, {\"ngram\": \"the 100m\", \"from\": 1808, \"to\": 1816}, {\"ngram\": \"prelimary heats\", \"from\": 1828, \"to\": 1843}]}, {\"sentence\": \"There will also be no repechage for events from 3000m and increasing in distance because of the already limited time for recovery between the events.\", \"from\": 1875, \"to\": 2024, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"no repechage\", \"from\": 1894, \"to\": 1906}, {\"ngram\": \"events\", \"from\": 1911, \"to\": 1917}, {\"ngram\": \"3000m\", \"from\": 1923, \"to\": 1928}, {\"ngram\": \"distance\", \"from\": 1947, \"to\": 1955}, {\"ngram\": \"the already limited time\", \"from\": 1967, \"to\": 1991}, {\"ngram\": \"recovery\", \"from\": 1996, \"to\": 2004}, {\"ngram\": \"the events\", \"from\": 2013, \"to\": 2023}]}, {\"sentence\": \"Athletics at Paris 2024, repechage schedule: Join thought-provoking conversations, follow other Independent readers and see their replies Please refresh the page or navigate to another page on the site to be automatically logged inPlease refresh your browser to be logged in\", \"from\": 2026, \"to\": 2302, \"entities\": [{\"begin\": 2123, \"end\": 2134, \"title\": \"http://dbpedia.org/resource/The_Independent\", \"score\": 0.9998021831391841, \"rank\": 0.000142275838543299, \"text\": \"Independent\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Independent\", \"dbpedia\": \"http://dbpedia.org/resource/The_Independent\"}], \"noun_phrases\": [{\"ngram\": \"Athletics\", \"from\": 2026, \"to\": 2035}, {\"ngram\": \"Paris\", \"from\": 2039, \"to\": 2044}, {\"ngram\": \"repechage schedule\", \"from\": 2051, \"to\": 2069}, {\"ngram\": \"Join thought-provoking conversations\", \"from\": 2071, \"to\": 2107}, {\"ngram\": \"their replies\", \"from\": 2150, \"to\": 2163}, {\"ngram\": \"the page\", \"from\": 2179, \"to\": 2187}, {\"ngram\": \"another page\", \"from\": 2203, \"to\": 2215}, {\"ngram\": \"the site\", \"from\": 2219, \"to\": 2227}, {\"ngram\": \"inPlease\", \"from\": 2255, \"to\": 2263}, {\"ngram\": \"your browser\", \"from\": 2272, \"to\": 2284}]}]}"