 {\"ngram\": \"the Olympic Games\", \"from\": 859, \"to\": 876}, {\"ngram\": \"the mockery\", \"from\": 888, \"to\": 899}, {\"ngram\": \"the mystery\", \"from\": 903, \"to\": 914}, {\"ngram\": \"the mysteries\", \"from\": 918, \"to\": 931}, {\"ngram\": \"billions\", \"from\": 971, \"to\": 979}, {\"ngram\": \"people\", \"from\": 983, \"to\": 989}, {\"ngram\": \"the world\", \"from\": 997, \"to\": 1006}]}, {\"sentence\": \"Freedom, diversity, and creativity are not compatible with insulting the beliefs of others, nor with mocking them, in ways that have nothing to do with human equality.\\\"\", \"from\": 1008, \"to\": 1176, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Freedom\", \"from\": 1008, \"to\": 1015}, {\"ngram\": \"diversity\", \"from\": 1017, \"to\": 1026}, {\"ngram\": \"creativity\", \"from\": 1032, \"to\": 1042}, {\"ngram\": \"the beliefs\", \"from\": 1077, \"to\": 1088}, {\"ngram\": \"others\", \"from\": 1092, \"to\": 1098}, {\"ngram\": \"ways\", \"from\": 1126, \"to\": 1130}, {\"ngram\": \"nothing\", \"from\": 1141, \"to\": 1148}, {\"ngram\": \"human equality\", \"from\": 1160, \"to\": 1174}]}, {\"sentence\": \"The French bishopswrote: \\\"We thank the members of other religious denominations who expressed their solidarity with us.\", \"from\": 1178, \"to\": 1297, \"entities\": [{\"begin\": 1182, \"end\": 1188, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9992680560872184, \"rank\": 0.0007239504562171434, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"the members\", \"from\": 1213, \"to\": 1224}, {\"ngram\": \"other religious denominations\", \"from\": 1228, \"to\": 1257}, {\"ngram\": \"their solidarity\", \"from\": 1272, \"to\": 1288}, {\"ngram\": \"us\", \"from\": 1294, \"to\": 1296}]}, {\"sentence\": \"This morning, we are thinking of all Christians on every continent who have been hurt by the outrageousness and provocation of certain scenes.\", \"from\": 1298, \"to\": 1440, \"entities\": [{\"begin\": 1335, \"end\": 1345, \"title\": \"http://dbpedia.org/resource/Christianity\", \"score\": 0.9690029567821201, \"rank\": 0.02921264509633959, \"text\": \"Christians\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Christianity\", \"dbpedia\": \"http://dbpedia.org/resource/Christianity\"}], \"noun_phrases\": [{\"ngram\": \"every continent\", \"from\": 1349, \"to\": 1364}, {\"ngram\": \"the outrageousness\", \"from\": 1387, \"to\": 1405}, {\"ngram\": \"provocation\", \"from\": 1410, \"to\": 1421}, {\"ngram\": \"certain scenes\", \"from\": 1425, \"to\": 1439}]}, {\"sentence\": \"We want them to understand that the Olympic celebration goes far beyond the ideological biases of a few artists.\\\"\", \"from\": 1441, \"to\": 1554, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the Olympic celebration\", \"from\": 1473, \"to\": 1496}, {\"ngram\": \"the ideological biases\", \"from\": 1513, \"to\": 1535}, {\"ngram\": \"a few artists\", \"from\": 1539, \"to\": 1552}]}, {\"sentence\": \"At least one company,CSpire, has canceled its advertising for the Olympics, not that the athletes are to blame.\", \"from\": 1556, \"to\": 1667, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"At least one company\", \"from\": 1556, \"to\": 1576}, {\"ngram\": \"CSpire\", \"from\": 1577, \"to\": 1583}, {\"ngram\": \"its advertising\", \"from\": 1598, \"to\": 1613}, {\"ngram\": \"the Olympics\", \"from\": 1618, \"to\": 1630}, {\"ngram\": \"the athletes\", \"from\": 1641, \"to\": 1653}]}, {\"sentence\": \"To be fair to NBC and other officials, it was claimed that much of the performance was kept secret to surprise the audience.\", \"from\": 1668, \"to\": 1792, \"entities\": [{\"begin\": 1682, \"end\": 1685, \"title\": \"http://dbpedia.org/resource/NBC\", \"score\": 0.9999999999936335, \"rank\": 5.357793988503086e-12, \"text\": \"NBC\", \"types\": [