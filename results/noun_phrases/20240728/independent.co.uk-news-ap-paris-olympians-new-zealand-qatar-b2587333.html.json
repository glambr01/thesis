[{\"ngram\": \"the city\", \"from\": 423, \"to\": 431}, {\"ngram\": \"the capital\", \"from\": 450, \"to\": 461}, {\"ngram\": \"fashion\", \"from\": 465, \"to\": 472}, {\"ngram\": \"the word \\\"fashion\", \"from\": 474, \"to\": 491}, {\"ngram\": \"any other Games\", \"from\": 546, \"to\": 561}]}, {\"sentence\": \"And so it made sense to Angela Ruggiero, a four-time U.S. Olympic medalist in ice hockey, that if she was going to launch a celebration of gender parity in these Games, it should be with a fashion show.\", \"from\": 564, \"to\": 766, \"entities\": [{\"begin\": 588, \"end\": 603, \"title\": \"http://dbpedia.org/resource/Angela_Ruggiero\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Angela Ruggiero\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q11774891\"], \"wikid\": \"http://dbpedia.org/resource/Angela_Ruggiero\", \"dbpedia\": \"http://dbpedia.org/resource/Angela_Ruggiero\"}], \"noun_phrases\": [{\"ngram\": \"sense\", \"from\": 579, \"to\": 584}, {\"ngram\": \"a four-time U.S. Olympic medalist\", \"from\": 605, \"to\": 638}, {\"ngram\": \"ice hockey\", \"from\": 642, \"to\": 652}, {\"ngram\": \"a celebration\", \"from\": 686, \"to\": 699}, {\"ngram\": \"gender parity\", \"from\": 703, \"to\": 716}, {\"ngram\": \"these Games\", \"from\": 720, \"to\": 731}, {\"ngram\": \"a fashion show\", \"from\": 751, \"to\": 765}]}, {\"sentence\": \"And that's how some 20 or so former or currentOlympianswound up sashaying down a makeshift runway on Sunday at a Paris restaurant, to whoops and high-fives from a supportive audience.\", \"from\": 767, \"to\": 950, \"entities\": [{\"begin\": 880, \"end\": 885, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 8.242099739612728e-15, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"a makeshift runway\", \"from\": 846, \"to\": 864}, {\"ngram\": \"Sunday\", \"from\": 868, \"to\": 874}, {\"ngram\": \"whoops\", \"from\": 901, \"to\": 907}, {\"ngram\": \"high-fives\", \"from\": 912, \"to\": 922}, {\"ngram\": \"a supportive audience\", \"from\": 928, \"to\": 949}]}, {\"sentence\": \"For years, says Ruggiero, who runs a market research firm focused on the intersection of sport and innovation, she's been following \\\"this trend of sport and fashion colliding.\\\"\", \"from\": 952, \"to\": 1128, \"entities\": [{\"begin\": 968, \"end\": 976, \"title\": \"http://dbpedia.org/resource/Ostinato\", \"score\": 0.9999999999990905, \"rank\": 7.222924736625815e-13, \"text\": \"Ruggiero\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ostinato\", \"dbpedia\": \"http://dbpedia.org/resource/Ostinato\"}], \"noun_phrases\": [{\"ngram\": \"years\", \"from\": 956, \"to\": 961}, {\"ngram\": \"a market research firm\", \"from\": 987, \"to\": 1009}, {\"ngram\": \"the intersection\", \"from\": 1021, \"to\": 1037}, {\"ngram\": \"sport\", \"from\": 1041, \"to\": 1046}, {\"ngram\": \"innovation\", \"from\": 1051, \"to\": 1061}, {\"ngram\": \"this trend\", \"from\": 1085, \"to\": 1095}, {\"ngram\": \"sport and fashion colliding\", \"from\": 1099, \"to\": 1126}]}, {\"sentence\": \"\\\"And the Olympics are in Paris.\", \"from\": 1130, \"to\": 1161, \"entities\": [{\"begin\": 1155, \"end\": 1160, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 8.242099739612728e-15, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"the Olympics\", \"from\": 1135, \"to\": 1147}]}, {\"sentence\": \"I mean, what a perfect venue to celebrate a monumental achievement of gender parity on the field while nodding to opportunities off the field, including elevating these women's voices through style,\\\" she told The Associated Press.\", \"from\": 1162, \"to\": 1392, \"entities\": [{\"begin\": 1375, \"end\": 1391, \"title\": \"http://dbpedia.org/resource/Associated_Press\", \"score\": 0.9999999681504056, \"rank\": 3.1849667454937055e-08, \"text\": \"Associated Press\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Associated_Press\", \"dbpedia\": \"http://dbpedia.org/resource/Associated_Press\"}], \"noun_phrases\": [{\"ngram\": \"a monumental achievement\", \"from\": 1204, \"to\": 1228}, {\"ngram\": \"gender parity\", \"from\": 1232, \"to\": 1245}, {\"ngram\": \"the field\", \"from\": 1249, \"to\": 1258}, {\"ngram\": \"opportunities\", \"from\": 1276, \"to\": 1289}, {\"ngram\": \"the field\", \"from\": 1294, \"to\": 1303}, {\"ngram\": \"these women's voices\", \"from\": 1325, \"to\": 1345}, {\"ngram\": \"style\", \"from\": 1354, \"to\": 1359}]}, {\"sentence\": \"This year, the International Olympic Committee set a goal of a 50-50 split between male and female athletes.\", \"from\": 1394, \"to\": 1502, \"entities\": [{\"begin\": 1409, \"end\": 1440, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"a goal\", \"from\": 1445, \"to\": 1451}, {\"ngram\": \"a 50-50 split\", \"from\": 1455, \"to\": 1468}, {\"ngram\": \"male and female athletes\", \"from\": 1477, \"to\": 1501}]}, {\"sentence\": \"For the first time, women have an equal share with men of an entry quota that's 10,500 athletes across 329 events.\", \"from\": 1503, \"to\": 1617, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the first time\", \"from\": 1507, \"to\": 1521}, {\"ngram\": \"women\", \"from\": 1523, \"to\": 1528}, {\"ngram\": \"an equal share\", \"from\": 1534, \"to\": 1548}, {\"ngram\": \"men\", \"from\": 1554, \"to\": 1557}, {\"ngram\": \"an entry quota\", \"from\": 1561, \"to\": 1575}, {\"ngram\": \"10,500 athletes\", \"from\": 1583, \"to\": 1598}, {\"ngram\": \"329 events\", \"from\": 1606, \"to\": 1616}]}, {\"sentence\": \"The actual gender split will not be known until the end of the Games, given unknowns in team selections, rules in different countries, and other areas.\", \"from\": 1619, \"to\": 1770, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The actual gender split\", \"from\": 1619, \"to\": 1642}, {\"ngram\": \"the end\", \"from\": 1667, \"to\": 1674}, {\"ngram\": \"the Games\", \"from\": 1678, \"to\": 1687}, {\"ngram\": \"unknowns\", \"from\": 1695, \"to\": 1703}, {\"ngram\": \"team selections\", \"from\": 1707, \"to\": 1722}, {\"ngram\": \"rules\", \"from\": 1724, \"to\": 1729}, {\"ngram\": \"different countries\", \"from\": 1733, \"to\": 1752}, {\"ngram\": \"other areas\", \"from\": 1758, \"to\": 1769}]}, {\"sentence\": \"It's possible the numbers will fall just short of parity.\", \"from\": 1771, \"to\": 1828, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the numbers\", \"from\": 1785, \"to\": 1796}, {\"ngram\": \"parity\", \"from\": 1821, \"to\": 1827}]}, {\"sentence\": \"But regardless of where specific numbers fall, the female athletes who joined Ruggiero on the runway - many from the United States, but also from Australia,New Zealand, Liberia,Qatarand elsewhere - were eager to celebrate the moment.\", \"from\": 1829, \"to\": 2062, \"entities\": [{\"begin\": 1907, \"end\": 1915, \"title\": \"http://dbpedia.org/resource/Ostinato\", \"score\": 0.9999999999990905, \"rank\": 7.222924736625815e-13, \"text\": \"Ruggiero\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ostinato\", \"dbpedia\": \"http://dbpedia.org/resource/Ostinato\"}, {\"begin\": 1946, \"end\": 1959, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9871487871587159, \"rank\": 0.012202870386331846, \"text\": \"United States\", \"types\": [\"Q6256\"], \"wikid\": \"ht