ence\": \"We are lucky in France to live in a free country.\\\"\", \"from\": 2082, \"to\": 2132, \"entities\": [{\"begin\": 2098, \"end\": 2104, \"title\": \"http://dbpedia.org/resource/Kingdom_of_France\", \"score\": 0.6792551567236563, \"rank\": 0.4626601157559581, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Kingdom_of_France\", \"dbpedia\": \"http://dbpedia.org/resource/Kingdom_of_France\"}], \"noun_phrases\": [{\"ngram\": \"a free country\", \"from\": 2116, \"to\": 2130}]}, {\"sentence\": \"Pleaselet us knowif you are having issues with commenting.\", \"from\": 2134, \"to\": 2192, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"us\", \"from\": 2144, \"to\": 2146}, {\"ngram\": \"issues\", \"from\": 2169, \"to\": 2175}]}, {\"sentence\": \"Copyright \\u00a9 2025 Breitbart\", \"from\": 2202, \"to\": 2228, \"entities\": [{\"begin\": 2219, \"end\": 2228, \"title\": \"http://dbpedia.org/resource/Breitbart_News\", \"score\": 0.9999999687722725, \"rank\": 3.12276848477733e-08, \"text\": \"Breitbart\", \"types\": [\"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Breitbart_News\", \"dbpedia\": \"http://dbpedia.org/resource/Breitbart_News\"}], \"noun_phrases\": [{\"ngram\": \"Copyright \\u00a9\", \"from\": 2202, \"to\": 2213}]}]}"