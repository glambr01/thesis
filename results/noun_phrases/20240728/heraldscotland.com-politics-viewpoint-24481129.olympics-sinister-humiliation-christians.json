oun_phrases\": [{\"ngram\": \"the opening sequences\", \"from\": 1179, \"to\": 1200}, {\"ngram\": \"Friday's night opening ceremony\", \"from\": 1204, \"to\": 1235}, {\"ngram\": \"the Paris Olympics\", \"from\": 1240, \"to\": 1258}, {\"ngram\": \"very influential people\", \"from\": 1281, \"to\": 1304}, {\"ngram\": \"a central theme\", \"from\": 1383, \"to\": 1398}]}, {\"sentence\": \"Yet, I refrained from making any trite, smartass comments about it on social media lest I become guilty of seeing demons where none exist.\", \"from\": 1400, \"to\": 1538, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"any trite\", \"from\": 1429, \"to\": 1438}, {\"ngram\": \"social media\", \"from\": 1470, \"to\": 1482}, {\"ngram\": \"demons\", \"from\": 1514, \"to\": 1520}, {\"ngram\": \"none\", \"from\": 1527, \"to\": 1531}]}, {\"sentence\": \"Having watched it again the following morning, I began to sympathise with those who had expressed anger at the grotesque rendering of Leonardo da Vinci's painting of The Last Supper.\", \"from\": 1540, \"to\": 1722, \"entities\": [{\"begin\": 1674, \"end\": 1691, \"title\": \"http://dbpedia.org/resource/Leonardo_da_Vinci\", \"score\": 1.0, \"rank\": 2.095865985259681e-35, \"text\": \"Leonardo da Vinci\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Leonardo_da_Vinci\", \"dbpedia\": \"http://dbpedia.org/resource/Leonardo_da_Vinci\"}], \"noun_phrases\": [{\"ngram\": \"anger\", \"from\": 1638, \"to\": 1643}, {\"ngram\": \"the grotesque rendering\", \"from\": 1647, \"to\": 1670}, {\"ngram\": \"The Last Supper\", \"from\": 1706, \"to\": 1721}]}, {\"sentence\": \"The great Italian renaissance artist had made his painting as a work of reverence for one of the holiest and most sacred events in the Christian narrative.\", \"from\": 1723, \"to\": 1878, \"entities\": [{\"begin\": 1733, \"end\": 1752, \"title\": \"http://dbpedia.org/resource/Italian_Renaissance\", \"score\": 1.0, \"rank\": 4.7567445044153776e-15, \"text\": \"Italian renaiss