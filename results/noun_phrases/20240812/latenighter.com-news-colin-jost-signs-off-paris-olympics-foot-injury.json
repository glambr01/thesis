egin\": 1065, \"end\": 1069, \"title\": \"http://dbpedia.org/resource/David_Jost\", \"score\": 0.9999995682379472, \"rank\": 3.697017293257709e-07, \"text\": \"Jost\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/David_Jost\", \"dbpedia\": \"http://dbpedia.org/resource/David_Jost\"}, {\"begin\": 1176, \"end\": 1182, \"title\": \"http://dbpedia.org/resource/Tahiti\", \"score\": 0.9999999999799911, \"rank\": 1.9821927598312403e-11, \"text\": \"Tahiti\", \"types\": [\"Q23442\"], \"wikid\": \"http://dbpedia.org/resource/Tahiti\", \"dbpedia\": \"http://dbpedia.org/resource/Tahiti\"}], \"noun_phrases\": [{\"ngram\": \"an ingenious way\", \"from\": 1083, \"to\": 1099}, {\"ngram\": \"all the exciting surfing action\", \"from\": 1123, \"to\": 1154}, {\"ngram\": \"the first place\", \"from\": 1200, \"to\": 1215}]}, {\"sentence\": \"\\\"I swam to a nearby yacht, and convinced them to let me use their VPN in exchange for, ironically, feet pics.\", \"from\": 1218, \"to\": 1327, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a nearby yacht\", \"from\": 1229, \"to\": 1243}, {\"ngram\": \"their VPN\", \"from\": 1278, \"to\": 1287}, {\"ngram\": \"exchange\", \"from\": 1291, \"to\": 1299}, {\"ngram\": \"pics\", \"from\": 1322, \"to\": 1326}]}, {\"sentence\": \"That way I was able to log into Peacock from international waters,\\\" Jost explained.\", \"from\": 1328, \"to\": 1411, \"entities\": [{\"begin\": 1360, \"end\": 1367, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.9999999440624394, \"rank\": 5.506843451417256e-08, \"text\": \"Peacock\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Peafowl\", \"dbpedia\": \"http://dbpedia.org/resource/Peafowl\"}, {\"begin\": 1396, \"end\": 1400, \"title\": \"http://dbpedia.org/resource/David_Jost\", \"score\": 0.9999995682379472, \"rank\": 3.697017293257709e-07, \"text\": \"Jost\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"]