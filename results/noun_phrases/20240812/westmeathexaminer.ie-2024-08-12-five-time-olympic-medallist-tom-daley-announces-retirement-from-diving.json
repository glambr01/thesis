8}, {\"ngram\": \"time\", \"from\": 189, \"to\": 193}, {\"ngram\": \"his career\", \"from\": 197, \"to\": 207}, {\"ngram\": \"an interview\", \"from\": 215, \"to\": 227}]}, {\"sentence\": \"Daley, who added a fifth Olympic medal to his collection with silver in the 10m synchro event in Paris, said: \\\"It feels very, very surreal.\", \"from\": 249, \"to\": 388, \"entities\": [{\"begin\": 346, \"end\": 351, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999996857264289, \"rank\": 3.142735583267251e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Daley\", \"from\": 249, \"to\": 254}, {\"ngram\": \"a fifth Olympic medal\", \"from\": 266, \"to\": 287}, {\"ngram\": \"his collection\", \"from\": 291, \"to\": 305}, {\"ngram\": \"silver\", \"from\": 311, \"to\": 317}, {\"ngram\": \"the 10m synchro event\", \"from\": 321, \"to\": 342}]}, {\"sentence\": \"\\\"I felt so incredibly nervous going into this, knowing it was my last Olympics.\", \"from\": 390, \"to\": 469, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my last Olympics\", \"from\": 452, \"to\": 468}]}, {\"sentence\": \"\\\"There was a lot of pressure and expectations.\", \"from\": 471, \"to\": 517, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a lot\", \"from\": 482, \"to\": 487}, {\"ngram\": \"pressure\", \"from\": 491, \"to\": 499}, {\"ngram\": \"expectations\", \"from\": 504, \"to\": 516}]}, {\"sentence\": \"I was eager for it to be done.\", \"from\": 518, \"to\": 548, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"\\\"But when I walked out, and saw my husband (Lance) and kids (Robbie and Phoenix) and my friends and family in the audience, I was like, you know what?\", \"from\": 550, \"to\": 700, \"entities\": [{\"begin\": 611, \"end\": 617, \"title\": \"http://dbpedia.org/resource/Clan_Donnachaidh\", \"score\": 0.9713014819097575, \"rank\": 0.021553828795404087, \"text\": \"Robbie\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Clan_Donnachaidh\", \"dbpedia\": \"http://dbpedia.org/resource/Clan_Donnachaidh\"}, {\"begin\": 622, \"end\": 629, \"title\": \"http://dbpedia.org/resource/Phoenix_Raceway\", \"score\": 0.8299142631978581, \"rank\": 0.20128892522760708, \"text\": \"Phoenix\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Phoenix_Raceway\", \"dbpedia\": \"http://dbpedia.org/resource/Phoenix_Raceway\"}], \"noun_phrases\": [{\"ngram\": \"my husband\", \"from\": 582, \"to\": 592}, {\"ngram\": \"Lance\", \"from\": 594, \"to\": 599}, {\"ngram\": \"kids\", \"from\": 605, \"to\": 609}, {\"ngram\": \"my friends\", \"from\": 635, \"to\": 645}, {\"ngram\": \"family\", \"from\": 650, \"to\": 656}, {\"ngram\": \"the audience\", \"from\": 660, \"to\": 672}]}, {\"sentence\": \"This is exactly why I did this.\", \"from\": 701, \"to\": 732, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"\\\"It was emotional at the end, up there on the platform, knowing it was going to be my last competitive dive.\", \"from\": 734, \"to\": 842, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the end\", \"from\": 755, \"to\": 762}, {\"ngram\": \"the platform\", \"from\": 776, \"to\": 788}, {\"ngram\": \"my last competitive dive\", \"from\": 817, \"to\": 841}]}, {\"sentence\": \"\\\"But I have to make the decision at some point, and it feels like the right time.\", \"from\": 844, \"to\": 925, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the decision\", \"from\": 864, \"to\": 876}, {\"ngram\": \"some point\", \"from\": 880, \"to\": 890}, {\"ngram\": \"the right time\", \"from\": 910, \"to\": 924}]}, {\"sentence\": \"It's the right time to call it a day.\\\"\", \"from\": 926, \"to\": 964, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the right time\", \"from\": 931, \"to\": 945}]}, {\"sentence\": \"Daley competed at five Games, making his bow at Beijing 2008 and winning gold and bronz