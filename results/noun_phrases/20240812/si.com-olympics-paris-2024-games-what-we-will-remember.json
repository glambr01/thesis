\", \"from\": 6600, \"to\": 6621}]}, {\"sentence\": \"We will remember Richardson\\u00e2\\u0080\\u0099s moment any time someone searches for the right image to convey that it\\u00e2\\u0080\\u0099s time to get serious.\", \"from\": 6623, \"to\": 6750, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Richardson\\u00e2\\u0080\\u0099s\", \"from\": 6640, \"to\": 6654}, {\"ngram\": \"someone\", \"from\": 6671, \"to\": 6678}, {\"ngram\": \"the right image\", \"from\": 6692, \"to\": 6707}, {\"ngram\": \"that it\\u00e2\\u0080\\u0099s time\", \"from\": 6718, \"to\": 6734}]}, {\"sentence\": \"Again, no offense toSydney McLaughlin-Levrone,Gabby Thomas,Quincy Hall, Cole Hocker,Rai Benjamin, Grant Holloway,Julian Alfred, Femke Bol and all the other runners who supplied moments of brilliance.\", \"from\": 6752, \"to\": 6951, \"entities\": [{\"begin\": 6798, \"end\": 6810, \"title\": \"http://dbpedia.org/resource/Gabrielle_Thomas\", \"score\": 1.0, \"rank\": 1.8977005221952625e-17, \"text\": \"Gabby Thomas\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Gabrielle_Thomas\", \"dbpedia\": \"http://dbpedia.org/resource/Gabrielle_Thomas\"}, {\"begin\": 6811, \"end\": 6817, \"title\": \"http://dbpedia.org/resource/Quincy_Center_station\", \"score\": 1.0, \"rank\": 4.374287721233278e-19, \"text\": \"Quincy\", \"types\": [\"Q719456\"], \"wikid\": \"http://dbpedia.org/resource/Quincy_Center_station\", \"dbpedia\": \"http://dbpedia.org/resource/Quincy_Center_station\"}, {\"begin\": 6824, \"end\": 6835, \"title\": \"http://dbpedia.org/resource/Cole_Hocker\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Cole Hocker\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Cole_Hocker\", \"dbpedia\": \"http://dbpedia.org/resource/Cole_Hocker\"}, {\"begin\": 6836, \"end\": 6848, \"title\": \"http://dbpedia.org/resource/Rai_Benjamin\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Rai Benjamin\", \"types\":