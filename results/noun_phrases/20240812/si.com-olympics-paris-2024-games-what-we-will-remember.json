ities\": [], \"noun_phrases\": [{\"ngram\": \"an Olympic sport\", \"from\": 9214, \"to\": 9230}]}, {\"sentence\": \"But for two fascinating days in Paris, it was.\", \"from\": 9232, \"to\": 9278, \"entities\": [{\"begin\": 9264, \"end\": 9269, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.7950847303899912e-31, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"two fascinating days\", \"from\": 9240, \"to\": 9260}]}, {\"sentence\": \"And we\\u00e2\\u0080\\u0099ll remember Snoop Dogg blessing the proceedings,Raygun, Phil Wizard, the other B-Girls and B-Boys, the set design and everything that came along with it.\", \"from\": 9279, \"to\": 9441, \"entities\": [{\"begin\": 9300, \"end\": 9310, \"title\": \"http://dbpedia.org/resource/Snoop_Dogg\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Snoop Dogg\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Snoop_Dogg\", \"dbpedia\": \"http://dbpedia.org/resource/Snoop_Dogg\"}, {\"begin\": 9336, \"end\": 9342, \"title\": \"http://dbpedia.org/resource/Raygun\", \"score\": 1.0, \"rank\": 2.848780314823817e-59, \"text\": \"Raygun\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Raygun\", \"dbpedia\": \"http://dbpedia.org/resource/Raygun\"}], \"noun_phrases\": [{\"ngram\": \"we\\u00e2\\u0080\\u0099ll\", \"from\": 9283, \"to\": 9290}, {\"ngram\": \"the proceedings\", \"from\": 9320, \"to\": 9335}, {\"ngram\": \"Phil Wizard\", \"from\": 9344, \"to\": 9355}, {\"ngram\": \"the other B-Girls\", \"from\": 9357, \"to\": 9374}, {\"ngram\": \"B-Boys\", \"from\": 9379, \"to\": 9385}, {\"ngram\": \"the set design\", \"from\": 9387, \"to\": 9401}, {\"ngram\": \"everything\", \"from\": 9406, \"to\": 9416}]}, {\"sentence\": \"I wrotea longer columnearlier this week aboutGold Zone, NBC\\u00e2\\u0080\\u0099sNFL RedZone\\u00e2\\u0080\\u0093style whip-around show that took viewers around Paris for 10 hours every day.\", \"from\": 9443, \"to\": 9597, \"entities\": [{\"begin\": 9568, \"end\": 9573, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.7950847303899912e-31, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Zone\", \"from\": 9493, \"to\": 9497}, {\"ngram\": \"NBC\\u00e2\\u0080\\u0099sNFL RedZone\\u00e2\\u0080\\u0093style whip-around show\", \"from\": 9499, \"to\": 9542}, {\"ngram\": \"viewers\", \"from\": 9553, \"to\": 9560}, {\"ngram\": \"10 hours\", \"from\": 9578, \"to\": 9586}]}, {\"sentence\": \"I won\\u00e2\\u0080\\u0099t repeat myself too much here, except to say that the show matched my sensibilities exactly, with its blend of major sports, high-interest moments and check-ins with niche events.Gold Zoneis not actually new, but for a variety of reasons this was the Olympics in which NBC perfected it.\", \"from\": 9598, \"to\": 9892, \"entities\": [{\"begin\": 9875, \"end\": 9878, \"title\": \"http://dbpedia.org/resource/NBC\", \"score\": 0.9857948451934083, \"rank\": 0.014409848941647242, \"text\": \"NBC\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/NBC\", \"dbpedia\": \"http://dbpedia.org/resource/NBC\"}], \"noun_phrases\": [{\"ngram\": \"the show\", \"from\": 9656, \"to\": 9664}, {\"ngram\": \"my sensibilities\", \"from\": 9673, \"to\": 9689}, {\"ngram\": \"its blend\", \"from\": 9704, \"to\": 9713}, {\"ngram\": \"major sports\", \"from\": 9717, \"to\": 9729}, {\"ngram\": \"high-interest moments\", \"from\": 9731, \"to\": 9752}, {\"ngram\": \"check-ins\", \"from\": 9757, \"to\": 9766}, {\"ngram\": \"niche events\", \"from\": 9772, \"to\": 9784}, {\"ngram\": \"Gold Zoneis\", \"from\": 9785, \"to\": 9796}, {\"ngram\": \"a variety\", \"from\": 9823, \"to\": 9832},