"{\"uid\": \"thenews.com.pk-print-1218969-canada-s-b-boy-phil-wizard-wins-first-olympic-breaking-gold\", \"noun_phrases\": [{\"sentence\": \"PARIS: Canada\\u00b4s B-Boy Phil Wizard won the inaugural Olympic men\\u00b4s breaking gold in Paris on Saturday, and said he hoped it \\\"opens doors to people\\\" involved in the high-energy dance sport.\", \"from\": 0, \"to\": 187, \"entities\": [{\"begin\": 83, \"end\": 88, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999413376, \"rank\": 5.857369834970401e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"PARIS\", \"from\": 0, \"to\": 5}, {\"ngram\": \"Canada\\u00b4s B-Boy Phil Wizard\", \"from\": 7, \"to\": 33}, {\"ngram\": \"the inaugural Olympic men\\u00b4s breaking gold\", \"from\": 38, \"to\": 79}, {\"ngram\": \"Saturday\", \"from\": 92, \"to\": 100}, {\"ngram\": \"doors\", \"from\": 130, \"to\": 135}, {\"ngram\": \"people\", \"from\": 139, \"to\": 145}, {\"ngram\": \"the high-energy dance sport\", \"from\": 159, \"to\": 186}]}, {\"sentence\": \"Phil Wizard, whose real name is Philip Kim, beat France\\u00b4s B-Boy Dany Dann in the final amid the opulent grandeur of the Place de la Concorde, with B-Boy Victor of the US taking bronze.\", \"from\": 189, \"to\": 373, \"entities\": [{\"begin\": 221, \"end\": 231, \"title\": \"http://dbpedia.org/resource/Philip_Kim\", \"score\": 0.9999999991202912, \"rank\": 0.0, \"text\": \"Philip Kim\", \"types\": [\"Q901\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Philip_Kim\", \"dbpedia\": \"http://dbpedia.org/resource/Philip_Kim\"}, {\"begin\": 309, \"end\": 329, \"title\": \"http://dbpedia.org/resource/Place_de_la_Concorde\", \"score\": 0.9999999550350377, \"rank\": 4.496491214688404e-08, \"text\": \"Place de la Concorde\", \"types\": [\"Q34442\"], \"wikid\": \"http://dbpedia.org/resource/Place_de_la_Concorde\", \"dbpedia\": \"http://dbpedia.org/resource/Place_de_la_Concorde\"}, {\"begin\": 336, \"end\": 341, \"title\": \"http://dbpedia.org/resource/Breakdancing\", \"score\": 1.0, \"rank\": 2.4252544406629943e-36, \"text\": \"B-Boy\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Breakdancing\", \"dbpedia\": \"http://dbpedia.org/resource/Breakdancing\"}, {\"begin\": 342, \"end\": 348, \"title\": \"http://dbpedia.org/resource/RCA_Records\", \"score\": 0.9997587318972343, \"rank\": 0.00023637129891402356, \"text\": \"Victor\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\", \"Q18127\"], \"wikid\": \"http://dbpedia.org/resource/RCA_Records\", \"dbpedia\": \"http://dbpedia.org/resource/RCA_Records\"}, {\"begin\": 356, \"end\": 358, \"title\": \"http://dbpedia.org/resource/Billboard_Hot_100\", \"score\": 0.9452885292320061, \"rank\": 0.04260829457212623, \"text\": \"US\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Billboard_Hot_100\", \"dbpedia\": \"http://dbpedia.org/resource/Billboard_Hot_100\"}], \"noun_phrases\": [{\"ngram\": \"Phil Wizard\", \"from\": 189, \"to\": 200}, {\"ngram\": \"whose real name\", \"from\": 202, \"to\": 217}, {\"ngram\": \"France\\u00b4s B-Boy Dany Dann\", \"from\": 238, \"to\": 262}, {\"ngram\": \"the opulent grandeur\", \"from\": 281, \"to\": 301}, {\"ngram\": \"bronze\", \"from\": 366, \"to\": 372}]}, {\"sentence\": \"Breaking, better known as breakdancing, is making its first and possibly last appearance at the Olympics, having been left off the programme for Los Angeles 2028.\", \"from\": 375, \"to\": 537, \"entities\": [{\"begin\": 520, \"end\": 536, \"title\": \"http://dbpedia.org/resource/2028_Summer_Olympics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Los Angeles 2028\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2028_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2028_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"Breaking\", \"from\": 375, \"to\": 383}, {\"ngram\": \"possibly last appearance\", \"from\": 439, \"to\": 463}, {\"ngram\": \"the Olympics\", \"from\": 467, \"to\": 479}, {\"ngram\": \"the programme\", \"from\": 502, \"to\": 515}]}, {\"sentence\": \"Phil Wizard said breaking was \\\"an underappreciated sport\\\" and hoped its Olympic debut would change people\\u00b4s minds.\", \"from\": 539, \"to\": 653, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Phil Wizard\", \"from\": 539, \"to\": 550}, {\"ngram\": \"breaking\", \"from\": 556, \"to\": 564}, {\"ngram\": \"an underappreciated sport\", \"from\": 570, \"to\": 595}, {\"ngram\": \"its Olympic debut\", \"from\": 607, \"to\": 624}, {\"ngram\": \"people\\u00b4s minds\", \"from\": 638, \"to\": 652}]}, {\"sentence\": \"\\\"I hope that today was a perfect example of showing the world how incredible breaking is -- that was truly my only goal here,\\\" said the 27-year-old, a former world champion.\", \"from\": 655, \"to\": 828, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"today\", \"from\": 668, \"to\": 673}, {\"ngram\": \"a perfect example\", \"from\": 678, \"to\": 695}, {\"ngram\": \"the world\", \"from\": 707, \"to\": 716}, {\"ngram\": \"how incredible breaking\", \"from\": 717, \"to\": 740}, {\"ngram\": \"my only goal\", \"from\": 762, \"to\": 774}, {\"ngram\": \"a former world champion\", \"from\": 804, \"to\": 827}]}, {\"sentence\": \"\\\"I\\u00b4m so grateful and so happy to come out with the win, but more than anything I just wanted to show the world what breaking is.\\\"\", \"from\": 830, \"to\": 959, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the win\", \"from\": 877, \"to\": 884}, {\"ngram\": \"anything\", \"from\": 900, \"to\": 908}, {\"ngram\": \"the world\", \"from\": 931, \"to\": 940}, {\"ngram\": \"what breaking\", \"from\": 941, \"to\": 954}]}, {\"sentence\": \"The competition saw 16 dancers, known as B-Boys, going head-to-head in a series of battles, starting with a pool stage before moving to a knock-out round.\", \"from\": 961, \"to\": 1115, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The competition\", \"from\": 961, \"to\": 976}, {\"ngram\": \"16 dancers\", \"from\": 981, \"to\": 991}, {\"ngram\": \"B-Boys\", \"from\": 1002, \"to\": 1008}, {\"ngram\": \"head\", \"from\": 1024, \"to\": 1028}, {\"ngram\": \"a series\", \"from\": 1032, \"to\": 1040}, {\"ngram\": \"battles\", \"from\": 1044, \"to\": 1051}, {\"ngram\": \"a pool stage\", \"from\": 1067, \"to\": 1079}, {\"ngram\": \"a knock-out round\", \"from\": 1097, \"to\": 1114}]}, {\"sentence\": \"Phil Wizard had the crowd against him in the final against local hero Dany Dann, a 36-year-old with blue hair whose real name is Danis Civil.\", \"from\": 1117, \"to\": 1258, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Phil Wizard\", \"from\": 1117, \"to\": 1128}, {\"ngram\": \"the crowd\", \"from\": 1133, \"to\": 1142}, {\"ngram\": \"local hero Dany Dann\", \"from\": 1176, \"to\": 1196}, {\"ngram\": \"blue hair\", \"from\": 1217, \"to\": 1226}, {\"ngram\": \"whose real name\", \"from\": 1227, \"to\": 1242}, {\"ngram\": \"Danis Civil\", \"from\": 1246, \"to\": 1257}]}, {\"sentence\": \"But the Canadian soon had them eating out of his hand thanks to his incredible routine, for which the judges awarded him a 3-0 victory.\", \"from\": 1259, \"to\": 1394, \"entities\": [{\"begin\": 1267, \"end\": 1275, \"title\": \"http://dbpedia.org/resource/Canadians\", \"score\": 0.9215388791829883, \"rank\": 0.046083683276507734, \"text\": \"Canadian\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Canadians\", \"dbpedia\": \"http://dbpedia.org/resource/Canadians\"}], \"noun_phrases\": [{\"ngram\": \"his hand\", \"from\": 1304, \"to\": 1312}, {\"ngram\": \"his incredible routine\", \"from\": 1323, \"to\": 1345}, {\"ngram\": \"the judges\", \"from\": 1357, \"to\": 1367}, {\"ngram\": \"a 3-0 victory\", \"from\": 1380, \"to\": 1393}]}, {\"sentence\": \"\\\"I was stressed out of my mind,\\\" said Phil Wizard.\", \"from\": 1396, \"to\": 1446, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my mind\", \"from\": 1419, \"to\": 1426}, {\"ngram\": \"Phil Wizard\", \"from\": 1434, \"to\": 1445}]}, {\"sentence\": \"\\\"It\\u00b4s been a whirlwind of emotion.\", \"from\": 1448, \"to\": 1482, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"It\\u00b4s\", \"from\": 1449, \"to\": 1453}, {\"ngram\": \"a whirlwind\", \"from\": 1459, \"to\": 1470}, {\"ngram\": \"emotion\", \"from\": 1474, \"to\": 1481}]}, {\"sentence\": \"I cried my eyes out because I was so scared to do this.\", \"from\": 1483, \"to\": 1538, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my eyes\", \"from\": 1491, \"to\": 1498}]}, {\"sentence\": \"\\\"There\\u00b4s been a lot of pressure, a lot of expectations -- I\\u00b4m glad I was able to deliver.\\\"\", \"from\": 1540, \"to\": 1630, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"There\\u00b4s\", \"from\": 1541, \"to\": 1548}, {\"ngram\": \"a lot\", \"from\": 1554, \"to\": 1559}, {\"ngram\": \"pressure\", \"from\": 1563, \"to\": 1571}, {\"ngram\": \"expectations\", \"from\": 1582, \"to\": 1594}]}, {\"sentence\": \"Danny Dann, a former European champion, said he felt like he had \\\"represented breaking\\\" to the world.\", \"from\": 1632, \"to\": 1733, \"entities\": [{\"begin\": 1653, \"end\": 1670, \"title\": \"http://dbpedia.org/resource/European_Figure_Skating_Championships\", \"score\": 0.9984076745910907, \"rank\": 0.0007787051941659369, \"text\": \"European champion\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/European_Figure_Skating_Championships\", \"dbpedia\": \"http://dbpedia.org/resource/European_Figure_Skating_Championships\"}], \"noun_phrases\": [{\"ngram\": \"Danny Dann\", \"from\": 1632, \"to\": 1642}, {\"ngram\": \"breaking\", \"from\": 1710, \"to\": 1718}, {\"ngram\": \"the world\", \"from\": 1723, \"to\": 1732}]}, {\"sentence\": \"\\\"I\\u00b4m delighted, I really didn\\u00b4t think I would win this medal,\\\" he said, revealing that he dyed his hair blue because it was his \\\"lucky colour\\\".\", \"from\": 1735, \"to\": 1878, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"I\\u00b4m\", \"from\": 1736, \"to\": 1739}, {\"ngram\": \"this medal\", \"from\": 1785, \"to\": 1795}, {\"ngram\": \"his hair\", \"from\": 1830, \"to\": 1838}, {\"ngram\": \"his \\\"lucky colour\", \"from\": 1859, \"to\": 1876}]}, {\"sentence\": \"\\\"I just went there to see how things would go and I\\u00b4m going home with a silver medal.\\\"\", \"from\": 1879, \"to\": 1965, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"things\", \"from\": 1909, \"to\": 1915}, {\"ngram\": \"a silver medal\", \"from\": 1949, \"to\": 1963}]}, {\"sentence\": \"Despite the spectacular moves on show, Phil Wizard said the panel of judges were looking for \\\"something new every round\\\".\", \"from\": 1967, \"to\": 2088, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the spectacular moves\", \"from\": 1975, \"to\": 1996}, {\"ngram\": \"show\", \"from\": 2000, \"to\": 2004}, {\"ngram\": \"Phil Wizard\", \"from\": 2006, \"to\": 2017}, {\"ngram\": \"the panel\", \"from\": 2023, \"to\": 2032}, {\"ngram\": \"judges\", \"from\": 2036, \"to\": 2042}, {\"ngram\": \"something\", \"from\": 2061, \"to\": 2070}, {\"ngram\": \"every round\", \"from\": 2075, \"to\": 2086}]}, {\"sentence\": \"\\\"You may well think it\\u00b4s the most explosive, crazy dynamic movements that score the most points,\\\" he said.\", \"from\": 2090, \"to\": 2196, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the most explosive, crazy dynamic movements\", \"from\": 2115, \"to\": 2158}, {\"ngram\": \"the most points\", \"from\": 2170, \"to\": 2185}]}, {\"sentence\": \"\\\"But in breaking there\\u00b4s a lot of different categories and the most important thing is originality and diversity of movement.\\\"\", \"from\": 2197, \"to\": 2323, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"there\\u00b4s\", \"from\": 2214, \"to\": 2221}, {\"ngram\": \"different categories\", \"from\": 2231, \"to\": 2251}, {\"ngram\": \"the most important thing\", \"from\": 2256, \"to\": 2280}, {\"ngram\": \"originality\", \"from\": 2284, \"to\": 2295}, {\"ngram\": \"diversity\", \"from\": 2300, \"to\": 2309}, {\"ngram\": \"movement\", \"from\": 2313, \"to\": 2321}]}, {\"sentence\": \"The B-Boys perform on a circular stage, accompanied by DJs pumping out hip-hop classics and MCs hyping up the crowd.\", \"from\": 2325, \"to\": 2441, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The B-Boys\", \"from\": 2325, \"to\": 2335}, {\"ngram\": \"a circular stage\", \"from\": 2347, \"to\": 2363}, {\"ngram\": \"DJs\", \"from\": 2380, \"to\": 2383}, {\"ngram\": \"hip-hop classics\", \"from\": 2396, \"to\": 2412}, {\"ngram\": \"MCs\", \"from\": 2417, \"to\": 2420}, {\"ngram\": \"the crowd\", \"from\": 2431, \"to\": 2440}]}, {\"sentence\": \"Breaking originated in the block parties held in the Bronx in New York in the 1970s.\", \"from\": 2443, \"to\": 2527, \"entities\": [{\"begin\": 2496, \"end\": 2501, \"title\": \"http://dbpedia.org/resource/The_Bronx\", \"score\": 0.9999999938368092, \"rank\": 6.163211623318487e-09, \"text\": \"Bronx\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/The_Bronx\", \"dbpedia\": \"http://dbpedia.org/resource/The_Bronx\"}, {\"begin\": 2505, \"end\": 2513, \"title\": \"http://dbpedia.org/resource/New_York_City\", \"score\": 0.9999998943928914, \"rank\": 1.0489474933284812e-07, \"text\": \"New York\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/New_York_City\", \"dbpedia\": \"http://dbpedia.org/resource/New_York_City\"}], \"noun_phrases\": [{\"ngram\": \"Breaking\", \"from\": 2443, \"to\": 2451}, {\"ngram\": \"the block parties\", \"from\": 2466, \"to\": 2483}, {\"ngram\": \"the 1970s\", \"from\": 2517, \"to\": 2526}]}, {\"sentence\": \"B-Boy Victor, also known as Victor Montalvo, said the competition represented \\\"the true essence of hip hop and breaking culture\\\".\", \"from\": 2529, \"to\": 2658, \"entities\": [{\"begin\": 2529, \"end\": 2534, \"title\": \"http://dbpedia.org/resource/Breakdancing\", \"score\": 1.0, \"rank\": 2.4252544406629943e-36, \"text\": \"B-Boy\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Breakdancing\", \"dbpedia\": \"http://dbpedia.org/resource/Breakdancing\"}, {\"begin\": 2535, \"end\": 2541, \"title\": \"http://dbpedia.org/resource/RCA_Records\", \"score\": 0.9997587318972343, \"rank\": 0.00023637129891402356, \"text\": \"Victor\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\", \"Q18127\"], \"wikid\": \"http://dbpedia.org/resource/RCA_Records\", \"dbpedia\": \"http://dbpedia.org/resource/RCA_Records\"}, {\"begin\": 2557, \"end\": 2563, \"title\": \"http://dbpedia.org/resource/RCA_Records\", \"score\": 0.9997587318972343, \"rank\": 0.00023637129891402356, \"text\": \"Victor\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\", \"Q18127\"], \"wikid\": \"http://dbpedia.org/resource/RCA_Records\", \"dbpedia\": \"http://dbpedia.org/resource/RCA_Records\"}, {\"begin\": 2564, \"end\": 2572, \"title\": \"http://dbpedia.org/resource/Montalvo_Beach\", \"score\": 0.9894755037246608, \"rank\": 0.0064197935718665715, \"text\": \"Montalvo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Montalvo_Beach\", \"dbpedia\": \"http://dbpedia.org/resource/Montalvo_Beach\"}], \"noun_phrases\": [{\"ngram\": \"the competition\", \"from\": 2579, \"to\": 2594}, {\"ngram\": \"\\\"the true essence\", \"from\": 2607, \"to\": 2624}, {\"ngram\": \"hip hop\", \"from\": 2628, \"to\": 2635}, {\"ngram\": \"breaking culture\", \"from\": 2640, \"to\": 2656}]}, {\"sentence\": \"\\\"We just want to make sure that we show everyone that it\\u00b4s a dance, first of all,\\\" said Victor, who beat Japan\\u00b4s Shigekix for the bronze medal.\", \"from\": 2659, \"to\": 2802, \"entities\": [{\"begin\": 2747, \"end\": 2753, \"title\": \"http://dbpedia.org/resource/RCA_Records\", \"score\": 0.99975