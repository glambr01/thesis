53}, {\"ngram\": \"Tom Daleyhas\", \"from\": 654, \"to\": 666}, {\"ngram\": \"his retirement fromdivingafter\", \"from\": 677, \"to\": 707}, {\"ngram\": \"his fifth Olympic medal\", \"from\": 716, \"to\": 739}]}, {\"sentence\": \"Daleysecured synchronised 10m platfom silveralongside Noah Williams to complete a full set of medals at theOlympics, winning gold in the event with Matty Lee in Tokyo to go with three bronzes.\", \"from\": 756, \"to\": 948, \"entities\": [{\"begin\": 810, \"end\": 823, \"title\": \"http://dbpedia.org/resource/Noah_Williams_(diver)\", \"score\": 0.999998273608197, \"rank\": 0.0, \"text\": \"Noah Williams\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Noah_Williams_(diver)\", \"dbpedia\": \"http://dbpedia.org/resource/Noah_Williams_(diver)\"}, {\"begin\": 904, \"end\": 913, \"title\": \"http://dbpedia.org/resource/Matty_Lee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Matty Lee\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Matty_Lee\", \"dbpedia\": \"http://dbpedia.org/resource/Matty_Lee\"}, {\"begin\": 917, \"end\": 922, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.9967987128169249, \"rank\": 0.0032114430739976804, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}], \"noun_phrases\": [{\"ngram\": \"a full set\", \"from\": 836, \"to\": 846}, {\"ngram\": \"medals\", \"from\": 850, \"to\": 856}, {\"ngram\": \"theOlympics\", \"from\": 860, \"to\": 871}, {\"ngram\": \"gold\", \"from\": 881, \"to\": 885}, {\"ngram\": \"the event\", \"from\": 889, \"to\": 898}, {\"ngram\": \"three bronzes\", \"from\": 934, \"to\": 947}]}, {\"sentence\": \"The 30-year-old was one ofTeam GB's opening ceremony flagbearers and concludes a competitive career that has included five Olympic appearances and two individual world titles.\", \"from\": 950, \"to\": 1125, \"entities\": [{\"begin\": 981, \"end\": 983, \"title\": \"http://dbpedia.org/resource/Gigabyte\", \"score\": 0.4409318331118572, \"rank\": 0.6531336825019018, \"text\": \"GB\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Gigabyte\", \"dbpedia\": \"http://dbpedia.org/resource/Gigabyte\"}], \"noun_phrases\": [{\"ngram\": \"a competitive career\", \"from\": 1029, \"to\": 1049}, {\"ngram\": \"five Olympic appearances\", \"from\": 1068, \"to\": 1092}, {\"ngram\": \"two individual world titles\", \"from\": 1097, \"to\": 1124}]}, {\"sentence\": \"The diver had indicated during the Games that he mightremain in the sport to compete in Los Angeles, the city he now calls home, in 2028.\", \"from\": 1127, \"to\": 1264, \"entities\": [{\"begin\": 1215, \"end\": 1226, \"title\": \"http://dbpedia.org/resource/Los_Angeles\", \"score\": 0.9999999957944965, \"rank\": 4.18988076832855e-09, \"text\": \"Los Angeles\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Los_Angeles\", \"dbpedia\": \"http://dbpedia.org/resource/Los_Angeles\"}], \"noun_phrases\": [{\"ngram\": \"The diver\", \"from\": 1127, \"to\": 1136}, {\"ngram\": \"the Games\", \"from\": 1158, \"to\": 1167}, {\"ngram\": \"the sport\", \"from\": 1191, \"to\": 1200}]}, {\"sentence\": \"But Daley - whoreversed his first retirementto feature in Paris - has said that it is the \\\"right time to call it a day\\\".\", \"from\": 1266, \"to\": 1386, \"entities\": [{\"begin\": 1324, \"end\": 1329, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999973242666, \"rank\": 2.67573257846476e-09, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"his first retirementto feature\", \"from\": 1290, \"to\": 1320}, {\"ngram\": \"the \\\"right time\", \"from\": 1352, \"to\": 1367}]}, {\"sentence\": \"\\\"It was emotional at the end, up there on the platform, knowing it was going to be my last competitive dive,\\\" Daleytold Vogue, confirming the news.\", \"from\": 1388, \"to\": 1535, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the end\", \"from\": 1409, \"to\": 1416}, {\"ngram\": \"the platform\", \"from\": 1430, \"to\": 1442}, {\"ngram\": \"my last competitive dive\", \"from\": 1471, \"to\": 1495}, {\"ngram\": \"the news\", \"from\": 1526, \"to\": 1534}]}, {\"sentence\": \"\\\"But I have to make the decision at some point, and it feels like the right time.\", \"from\": 1536, \"to\": 1617, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the decision\", \"from\": 1556, \"to\": 1568}, {\"ngram\": \"some point\", \"from\": 1572, \"to\": 1582}, {\"ngram\": \"the right time\", \"from\": 1602, \"to\": 1616}]}, {\"sentence\": \"It's the right time to call it a day.\", \"from\": 1618, \"to\": 1655, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the right time\", \"from\": 1623, \"to\": 1637}]}, {\"sentence\": \"\\\"It feels very, very surreal.\", \"from\": 1657, \"to\": 1686, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I felt so incredibly nervous going into this, knowing it was my last Olympics.\", \"from\": 1687, \"to\": 1765, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my last Olympics\", \"from\": 1748, \"to\": 1764}]}, {\"sentence\": \"There was a lot of pressure and expectation.\", \"from\": 1766, \"to\": 1810, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a lot\", \"from\": 1776, \"to\": 1781}, {\"ngram\": \"pressure\", \"from\": 1785, \"to\": 1793}, {\"ngram\": \"expectation\", \"from\": 1798, \"to\": 1809}]}, {\"sentence\": \"I was eager for it to be done\\u2026 but when I walked out, and saw my husband [Dustin Lance Black] and kidsand my friends and family in the audience, I was like, you know what?\", \"from\": 1811, \"to\": 1982, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my husband\", \"from\": 1873, \"to\": 1883}, {\"ngram\": \"my friends\", \"from\": 1917, \"to\": 1927}, {\"ngram\": \"family\", \"from\": 1932, \"to\": 1938}, {\"ngram\": \"the audience\", \"from\": 1942, \"to\": 1954}]}, {\"sentence\": \"This is exactly why I did this.\", \"from\": 1983, \"to\": 2014, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I am here, and no matter what happens in the competition itself, I am going to be happy.\\\"\", \"from\": 2015, \"to\": 2104, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the competition\", \"from\": 2056, \"to\": 2071}]}, {\"sentence\": \"Daley made his Olympic debut as the youngest member of Team GB's squad at the 2008 Olympics, finishing seventh in the 10m platform competition.\", \"from\": 2106, \"to\": 2249, \"entities\": [{\"begin\": 2161, \"end\": 2168, \"title\": \"http://dbpedia.org/resource/Team_GB\", \"score\": 0.9999999999731699, \"rank\": 2.670276172653211e-11, \"text\": \"Team GB\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Team_GB\", \"dbpedia\": \"http://dbpedia.org/resource/Team_GB\"}], \"noun_phrases\": [{\"ngram\": \"Daley\", \"from\": 2106, \"to\": 2111}, {\"ngram\": \"his Olympic debut\", \"from\": 2117, \"to\": 2134}, {\"ngram\": \"the youngest member\", \"from\": 2138, \"to\": 2157}, {\"ngram\": \"the 2008 Olympics\", \"from\": 2180, \"to\": 2197}, {\"ngram\": \"the 10m platform competition\", \"from\": 2220, \"to\": 2248}]}, {\"sentence\": \"Having secured a first world title in Rome in 2009, Daley added individual Olympic bronze at London 2012 before winning the first of three synchronised medals in Rio de Janeiro.\", \"from\": 2251, \"to\": 2428, \"entities\": [{\"begin\": 2289, \"end\": 2293, \"title\": \"http://dbpedia.org/resource/Rome\", \"score\": 0.9891155994532662, \"rank\": 0.010833799160244961, \"text\": \"Rome\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Rome\", \"dbpedia\": \"http://dbpedia.org/resource/Rome\"}, {\"begin\": 2344, \"end\": 2355, \"title\": \"http://dbpedia.org/resource/2012_Summer_Olympics\", \"score\": 0.9999999999313332, \"rank\": 6.876634258265439e-11, \"text\": \"London 2012\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2012_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2012_Summer_Olympics\"}, {\"begin\": 2413, \"end\": 2427, \"title\": \"http://dbpedia.org/resource/Rio_de_Janeiro\", \"score\": 1.0, \"rank\": 5.62408081314835e-16, \"text\": \"Rio de Janeiro\", \"types\": [\"Q486972\", \"Q3957\"], \"wikid\": \"http://dbpedia.org/resource/Rio_de_Janeiro\", \"dbpedia\": \"http://dbpedia.org/resource/Rio_de_Janeiro\"}], \"noun_phrases\": [{\"ngram\": \"a first world title\", \"from\": 2266, \"to\": 2285}, {\"ngram\": \"Daley\", \"from\": 2303, \"to\": 2308}, {\"ngram\": \"individual Olympic bronze\", \"from\": 2315, \"to\": 2340}, {\"ngram\": \"three synchronised medals\", \"from\": 2384, \"to\": 2409}]}, {\"sentence\": \"Born in Plymouth, he is the only three-time winner of the BBC Young Sports Personality of the Year award and was made an OBE in the 2022 New Year Honours.\", \"from\": 2430, \"to\": 2584, \"entities\": [{\"begin\": 2438, \"end\": 2446, \"title\": \"http://dbpedia.org/resource/Plymouth\", \"score\": 0.9999999583913004, \"rank\": 3.9916032303123156e-08, \"text\": \"Plymouth\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Plymouth\", \"dbpedia\": \"http://dbpedia.org/resource/Plymouth\"}, {\"begin\": 2551, \"end\": 2554, \"title\": \"http://dbpedia.org/resource/Order_of_the_British_Empire\", \"score\": 0.9999999976128038, \"rank\": 2.3871634444629565e-09, \"text\": \"OBE\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Order_of_the_British_Empire\", \"dbpedia\": \"http://dbpedia.org/resource/Order_of_the_British_Empire\"}], \"noun_phrases\": [{\"ngram\": \"the only three-time winner\", \"from\": 2454, \"to\": 2480}, {\"ngram\": \"the BBC Young Sports Personality\", \"from\": 2484, \"to\": 2516}, {\"ngram\": \"the Year award\", \"from\": 2520, \"to\": 2534}, {\"ngram\": \"the 2022 New Year Honours\", \"from\": 2558, \"to\": 2583}]}, {\"sentence\": \"Having come out of retirement to allow his children to see him dive at the Olympics, Daley wasvoted one of Team GB's flag bearers alongside Helen Gloverfor the opening ceremony along the River Seine.\", \"from\": 2586, \"to\": 2785, \"entities\": [{\"begin\": 2693, \"end\": 2700, \"title\": \"http://dbpedia.org/resource/Team_GB\", \"score\": 0.9999999999731699, \"rank\": 2.670276172653211e-11, \"text\": \"Team GB\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Team_GB\", \"dbpedia\": \"http://dbpedia.org/resource/Team_GB\"}, {\"begin\": 2773, \"end\": 2784, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"River Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"retirement\", \"from\": 2605, \"to\": 2615}, {\"ngram\": \"his children\", \"from\": 2625, \"to\": 2637}, {\"ngram\": \"the Olympics\", \"from\": 2657, \"to\": 2669}, {\"ngram\": \"Daley\", \"from\": 2671, \"to\": 2676}, {\"ngram\": \"Helen Gloverfor\", \"from\": 2726, \"to\": 2741}, {\"ngram\": \"the opening ceremony\", \"from\": 2742, \"to\": 2762}]}, {\"sentence\": \"He and Williams combined to secure silver behind Chinese pair Yang Hao and Lian Junjie in a brilliant Games for Great Britain's divers thatsaw them win a medal in every synchronised event.\", \"from\": 2787, \"to\": 2975, \"entities\": [{\"begin\": 2836, \"end\": 2843, \"title\": \"http://dbpedia.org/resource/Chinese_language\", \"score\": 0.949289324102268, \"rank\": 0.03577497419475333, \"text\": \"Chinese\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Chinese_language\", \"dbpedia\": \"http://dbpedia.org/resource/Chinese_language\"}, {\"begin\": 2849, \"end\": 2857, \"title\": \"http://dbpedia.org/resource/Yang_Hao_(Sui_dynasty)\", \"score\": 0.5916864370255184, \"rank\": 0.40495867768596194, \"text\": \"Yang Hao\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Yang_Hao_(Sui_dynasty)\", \"dbpedia\": \"http://dbpedia.org/resource/Yang_Hao_(Sui_dynasty)\"}, {\"begin\": 2862, \"end\": 2873, \"title\": \"http://dbpedia.org/resource/Lian_Junjie\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Lian Junjie\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Lian_Junjie\", \"dbpedia\": \"http://dbpedia.org/resource/Lian_Junjie\"}, {\"begin\": 2899, \"end\": 2912, \"title\": \"http://dbpedia.org/resource/Great_Britain_women's_national_field_hockey_team\", \"score\": 0.807529524446299, \"rank\": 0.2383448152384971, \"text\": \"Great Britain\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Great_Britain_women's_national_field_hockey_team\", \"dbpedia\": \"http://dbpedia.org/resource/Great_Britain_women's_national_field_hockey_team\"}], \"noun_phrases\": [{\"ngram\": \"Williams\", \"from\": 2794, \"to\": 2802}, {\"ngram\": \"silver\", \"from\": 2822, \"to\": 2828}, {\"ngram\": \"a brilliant Games\", \"from\": 2877, \"to\": 2894}, {\"ngram\": \"a medal\", \"from\": 2939, \"to\": 2946}, {\"ngram\": \"every synchronised event\", \"from\": 2950, \"to\": 2974}]}, {\"sentence\": \"\\\"To currently be Britain's most decorated diver\\u2026 I feel so incredibly proud,\\\" Daley added.\", \"from\": 2977, \"to\": 3067, \"entities\": [{\"begin\": 2994, \"end\": 3001, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9111409414457592, \"rank\": 0.09752456286568481, \"text\": \"Britain\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"Daley\", \"from\": 3055, \"to\": 3060}]}, {\"sentence\": \"\\\"When I look back, I am really, genuinely satisfied with what I have done.\\\"\", \"from\": 3068, \"to\": 3143, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Of his immediate plans, Daleyadded to the BBC: \\\"I want to be with my family.\", \"from\": 3145, \"to\": 3221, \"entities\": [{\"begin\": 3187, \"end\": 3190, \"title\": \"http://dbpedia.org/resource/BBC\", \"score\": 0.9927676791503189, \"rank\": 0.007022251058897304, \"text\": \"BBC\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/BBC\", \"dbpedia\": \"http://dbpedia.org/resource/BBC\"}], \"noun_phrases\": [{\"ngram\": \"his immediate plans\", \"from\": 3148, \"to\": 3167}, {\"ngram\": \"my family\", \"from\": 3211, \"to\": 3220}]}, {\"sentence\": \"I am really excited to be able to spend some time with them and just be able to feel a bit normal for a couple of days.\", \"from\": 3222, \"to\": 3341, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"some time\", \"from\": 3262, \"to\": 3271}, {\"ngram\": \"a couple\", \"from\": 3324, \"to\": 3332}, {\"ngram\": \"days\", \"from\": 3336, \"to\": 3340}]}, {\"sentence\": \"\\\"It's always hard when you say goodbye to your sport.\", \"from\": 3343, \"to\": 3396, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"goodbye\", \"from\": 3374, \"to\": 3381}, {\"ngram\": \"your sport\", \"from\": 3385, \"to\": 3395}]}, {\"sentence\": \"Lots of things to process, but I think it's the right time.\", \"from\": 3397, \"to\": 3456, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Lots\", \"from\": 3397, \"to\": 3401}, {\"ngram\": \"things\", \"from\": 3405, \"to\": 3411}, {\"ngram\": \"the right time\", \"from\": 3441, \"to\": 3455}]}, {\"sentence\": \"This year felt like such a bonus and I got to compete in front of my family, my kids.\", \"from\": 3457, \"to\": 3542, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"such a bonus\", \"from\": 3477, \"to\": 3489}, {\"ngram\": \"front\", \"from\": 3514, \"to\": 3519}, {\"ngram\": \"my family\", \"from\": 3523, \"to\": 3532}]}, {\"sentence\": \"I got to be flag bearer.\", \"from\": 3543, \"to\": 3567, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"flag bearer\", \"from\": 3555, \"to\": 3566}]}, {\"sentence\": \"So yeah, bucket list ticked off on every occasion.\\\"\", \"from\": 3568, \"to\": 3619, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"bucket list\", \"from\": 3577, \"to\": 3588}, {\"ngram\": \"every occasion\", \"from\": 3603, \"to\": 3617}]}, {\"sentence\": \"Join thought-provoking conversations, follow other Independent readers and see their replies Please refresh the page or navigate to another page on the site to be automatically logged inPlease refresh your browser to be logged in\", \"from\": 3621, \"to\": 3851, \"entities\": [{\"begin\": 3672, \"end\": 3683, \"title\": \"http://dbpedia.org/resource/The_Independent\", \"score\": 1.0, \"rank\": 4.004821222346373e-16, \"text\": \"Independent\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Independent\", \"dbpedia\": \"http://dbpedia.org/resource/The_Independent\"}], \"noun_phrases\": [{\"ngram\": \"thought-provoking conversations\", \"from\": 3626, \"to\": 3657}, {\"ngram\": \"their replies\", \"from\": 3700, \"to\": 3713}, {\"ngram\": \"the page\", \"from\": 3729, \"to\": 3737}, {\"ngram\": \"another page\", \"from\": 3753, \"to\": 3765}, {\"ngram\": \"the site\", \"from\": 3769, \"to\": 3777}, {\"ngram\": \"inPlease\", \"from\": 3805, \"to\": 3813}, {\"ngram\": \"your browser\", \"from\": 3822, \"to\": 3834}]}]}"