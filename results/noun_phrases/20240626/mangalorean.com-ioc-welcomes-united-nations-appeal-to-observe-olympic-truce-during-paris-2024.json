 \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 182, \"end\": 213, \"title\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"score\": 0.9999517260527481, \"rank\": 4.794151561634909e-05, \"text\": \"United Nations General Assembly\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"dbpedia\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\"}, {\"begin\": 253, \"end\": 269, \"title\": \"http://dbpedia.org/resource/Member_states_of_the_United_Nations\", \"score\": 0.9999687314848583, \"rank\": 3.126949293141775e-05, \"text\": \"UN Member States\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Member_states_of_the_United_Nations\", \"dbpedia\": \"http://dbpedia.org/resource/Member_states_of_the_United_Nations\"}], \"noun_phrases\": [{\"ngram\": \"Olympic Truce\", \"from\": 47, \"to\": 60}, {\"ngram\": \"just one month\", \"from\": 93, \"to\": 107}, {\"ngram\": \"the start\", \"from\": 118, \"to\": 127}, {\"ngram\": \"the Olympic Games\", \"from\": 131, \"to\": 148}, {\"ngram\": \"the chief\", \"from\": 164, \"to\": 173}, {\"ngram\": \"Tuesday\", \"from\": 216, \"to\": 223}, {\"ngram\": \"a solemn appeal\", \"from\": 229, \"to\": 244}, {\"ngram\": \"the observance\", \"from\": 273, \"to\": 287}, {\"ngram\": \"the Olympic Truce\", \"from\": 291, \"to\": 308}]}, {\"sentence\": \"The President of the United Nations General Assembly (UNGA), Dennis Francis, on Tuesday called on all warring parties around the world to agree to \\\"true mutual ceasefires\\\" for the duration of the Truce.\", \"from\": 311, \"to\": 513, \"entities\": [{\"begin\": 332, \"end\": 363, \"title\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"score\": 0.9999517260527481, \"rank\": 4.794151561634909e-05, \"text\": \"United Nations General Assembly\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"dbpedia\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\"}, {\"begin\": 365, \"end\": 369, \"title\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"UNGA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"dbpedia\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\"}, {\"begin\": 372, \"end\": 386, \"title\": \"http://dbpedia.org/resource/Dennis_Francis\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Dennis Francis\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Dennis_Francis\", \"dbpedia\": \"http://dbpedia.org/resource/Dennis_Francis\"}], \"noun_phrases\": [{\"ngram\": \"The President\", \"from\": 311, \"to\": 324}, {\"ngram\": \"Tuesday\", \"from\": 391, \"to\": 398}, {\"ngram\": \"all warring parties\", \"from\": 409, \"to\": 428}, {\"ngram\": \"the world\", \"from\": 436, \"to\": 445}, {\"ngram\": \"\\\"true mutual ceasefires\", \"from\": 458, \"to\": 481}, {\"ngram\": \"the duration\", \"from\": 487, \"to\": 499}, {\"ngram\": \"the Truce\", \"from\": 503, \"to\": 512}]}, {\"sentence\": \"The resolution for the observance of the Olympic Truce for the Olympic and Paralympic Games Paris 2024 was formally adopted by the UN in November last year, calling for the Olympic Truce to be respected from seven days before the start of the Olympic Games until seven days after the Paralympic Games.\", \"from\": 515, \"to\": 816, \"entities\": [{\"begin\": 646, \"end\": 648, \"title\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"score\": 0.9370170675816948, \"rank\": 0.06721629197241535, \"text\": \"UN\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"dbpedia\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\"}, {\"begin\": 688, \"end\": 701, \"title\": \"http://dbpedia.org/resource/Olympic_Truce\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Olympic Truce\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Truce\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Truce\"}], \"noun_phrases\": [{\"ngram\": \"The resolution\", \"from\": 515, \"to\": 529}, {\"ngram\": \"the observance\", \"from\": 534, \"to\": 548}, {\"ngram\": \"the Olympic Truce\", \"from\": 552, \"to\": 569}, {\"ngram\": \"the Olympic and Paralympic Games Paris\", \"from\": 574, \"to\": 612}, {\"ngram\": \"November\", \"from\": 652, \"to\": 660}, {\"ngram\": \"seven days\", \"from\": 723, \"to\": 733}, {\"ngram\": \"the start\", \"from\": 741, \"to\": 750}, {\"ngram\": \"the Olympic Games\", \"from\": 754, \"to\": 771}, {\"ngram\": \"seven days\", \"from\": 778, \"to\": 788}, {\"ngram\": \"the Paralympic Games\", \"from\": 795, \"to\": 815}]}, {\"sentence\": \"\\\"I solemnly appeal to all Member States to demonstrate their commitment to the Olympic Truce for the 2024 Paris Olympic and Paralympic Games and to undertake concrete actions at the local, national, regional and world levels to promote and strengthen a culture of peace and harmony based on the spirit of the Truce,\\\" said UNGA President Francis.\", \"from\": 818, \"to\": 1163, \"entities\": [{\"begin\": 1140, \"end\": 1144, \"title\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"UNGA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"dbpedia\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\"}, {\"begin\": 1155, \"end\": 1162, \"title\": \"http://dbpedia.org/resource/Pope_Francis\", \"score\": 0.9999056887444773, \"rank\": 9.414001346848355e-05, \"text\": \"Francis\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19546\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Pope_Francis\", \"dbpedia\": \"http://dbpedia.org/resource/Pope_Francis\"}], \"noun_phrases\": [{\"ngram\": \"all Member States\", \"from\": 840, \"to\": 857}, {\"ngram\": \"their commitment\", \"from\": 873, \"to\": 889}, {\"ngram\": \"the Olympic Truce\", \"from\": 893, \"to\": 910}, {\"ngram\": \"the 2024 Paris Olympic and Paralympic Games\", \"from\": 915, \"to\": 958}, {\"ngram\": \"concrete actions\", \"from\": 976, \"to\": 992}, {\"ngram\": \"the local, national, regional and world levels\", \"from\": 996, \"to\": 1042}, {\"ngram\": \"a culture\", \"from\": 1069, \"to\": 1078}, {\"ngram\": \"peace\", \"from\": 1082, \"to\": 1087}, {\"ngram\": \"harmony\", \"from\": 1092, \"to\": 1099}, {\"ngram\": \"the spirit\", \"from\": 1109, \"to\": 1119}, {\"ngram\": \"the Truce\", \"from\": 1123, \"to\": 1132}]}, {\"sentence\": \"\\\"I also call upon all warring parties of current armed conflicts around the world to boldly agree to true mutual ceasefires for the duration of the Olympic Truce, thus providing an opportunity to settle disputes peacefully.\\\"\", \"from\": 1165, \"to\": 1389, \"entities\": [{\"begin\": 1313, \"end\": 1326, \"title\": \"http://dbpedia.org/resource/Olympic_Truce\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Olympic Truce\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Truce\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Truce\"}], \"noun_phrases\": [{\"ngram\": \"all warring parties\", \"from\": 1183, \"to\": 1202}, {\"ngram\": \"current armed conflicts\", \"from\": 1206, \"to\": 1229}, {\"ngram\": \"the world\", \"from\": 1237, \"to\": 1246}, {\"ngram\": \"true mutual ceasefires\", \"from\": 1266, \"to\": 1288}, {\"ngram\": \"the duration\", \"from\": 1293, \"to\": 1305}, {\"ngram\": \"an opportunity\", \"from\": 1343, \"to\": 1357}, {\"ngram\": \"disputes\", \"from\": 1368, \"to\": 1376}]}, {\"sentence\": \"The Paris Olympic Games will be held in the French capital from July 26 to August 11, 2024.\", \"from\": 1391, \"to\": 1482, \"entities\": [{\"begin\": 1435, \"end\": 1441, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.7600277193004258, \"rank\": 0.2316206164458123, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"The Paris Olympic Games\", \"from\": 1391, \"to\": 1414}, {\"ngram\": \"July\", \"from\": 1455, \"to\": 1459}, {\"ngram\": \"August\", \"from\": 1466, \"to\": 1472}]}, {\"sentence\": \"Francis also noted that Paris 2024 would be \\\"breaking new ground in gender equality and inclusivity\\\" by allocating the same number of quota places to male and female athletes and emphasised that the participation of the Refugee Olympic Team would be \\\"a powerful symbol of inclusion and our shared humanity\\\".\", \"from\": 1484, \"to\": 1791, \"entities\": [{\"begin\": 1484, \"end\": 1491, \"title\": \"http://dbpedia.org/resource/Pope_Francis\", \"score\": 0.9999056887444773, \"rank\": 9.414001346848355e-05, \"text\": \"Francis\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19546\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Pope_Francis\", \"dbpedia\": \"http://dbpedia.org/resource/Pope_Francis\"}, {\"begin\": 1508, \"end\": 1518, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 6.644589505112482e-14, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 1704, \"end\": 1724, \"title\": \"http://dbpedia.org/resource/IOC_Refugee_Olympic_Team_at_the_2020_Summer_Olympics\", \"score\": 0.9988374256678073, \"rank\": 0.0011638341541377998, \"text\": \"Refugee Olympic Team\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/IOC_Refugee_Olympic_Team_at_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/IOC_Refugee_Olympic_Team_at_the_2020_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"new ground\", \"from\": 1538, \"to\": 1548}, {\"ngram\": \"gender equality\", \"from\": 1552, \"to\": 1567}, {\"ngram\": \"inclusivity\", \"from\": 1572, \"to\": 1583}, {\"ngram\": \"the same number\", \"from\": 1599, \"to\": 1614}, {\"ngram\": \"quota places\", \"from\": 1618, \"to\": 1630}, {\"ngram\": \"male and female athletes\", \"from\": 1634, \"to\": 1658}, {\"ngram\": \"the participation\", \"from\": 1679, \"to\": 1696}, {\"ngram\": \"a powerful symbol\", \"from\": 1735, \"to\": 1752}, {\"ngram\": \"inclusion\", \"from\": 1756, \"to\": 1765}, {\"ngram\": \"our shared humanity\", \"from\": 1770, \"to\": 1789}]}, {\"sentence\": \"International Olympic Committee (IOC) President Thomas Bach welcomed the UN's appeal while emphasising the enduring significance of the Olympic Truce.\", \"from\": 1793, \"to\": 1943, \"entities\": [{\"begin\": 1793, \"end\": 1830, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee (IOC)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 1841, \"end\": 1852, \"title\": \"http://dbpedia.org/resource/Thomas_Bach\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Thomas Bach\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Thomas_Bach\", \"dbpedia\": \"http://dbpedia.org/resource/Thomas_Bach\"}, {\"begin\": 1866, \"end\": 1868, \"title\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"score\": 0.9370170675816948, \"rank\": 0.06721629197241535, \"text\": \"UN\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"dbpedia\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\"}], \"noun_phrases\": [{\"ngram\": \"the enduring significance\", \"from\": 1896, \"to\": 1921}, {\"ngram\": \"the Olympic Truce\", \"from\": 1925, \"to\": 1942}]}, {\"sentence\": \"\\\"The Olympic Truce represents the very essence of what the Olympic Games stand for - peace, unity and the hope of building a better world.\", \"from\": 1945, \"to\": 2083, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The Olympic Truce\", \"from\": 1946, \"to\": 1963}, {\"ngram\": \"the very essence\", \"from\": 1975, \"to\": 1991}, {\"ngram\": \"the Olympic Games\", \"from\": 2000, \"to\": 2017}, {\"ngram\": \"peace\", \"from\": 2030, \"to\": 2035}, {\"ngram\": \"unity\", \"from\": 2037, \"to\": 2042}, {\"ngram\": \"the hope\", \"from\": 2047, \"to\": 2055}, {\"ngram\": \"a better world\", \"from\": 2068, \"to\": 2082}]}, {\"sentence\": \"In these difficult times, when we are all facing so much confrontation, division and polarisation, the Olympic Truce is more relevant than ever.\", \"from\": 2084, \"to\": 2228, \"entities\": [{\"begin\": 2187, \"end\": 2200, \"title\": \"http://dbpedia.org/resource/Olympic_Truce\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Olympic Truce\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Truce\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Truce\"}], \"noun_phrases\": [{\"ngram\": \"these difficult times\", \"from\": 2087, \"to\": 2108}, {\"ngram\": \"so much confrontation\", \"from\": 2133, \"to\": 2154}, {\"ngram\": \"division\", \"from\": 2156, \"to\": 2164}, {\"ngram\": \"polarisation\", \"from\": 2169, \"to\": 2181}]}, {\"sentence\": \"And, as an event that unites the world in peaceful competition, the Olympic Games Paris 2024 will be a powerful reminder that we can all come together peacefully, even in times of wars and crises,\\\" he said.\", \"from\": 2229, \"to\": 2435, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an event\", \"from\": 2237, \"to\": 2245}, {\"ngram\": \"the world\", \"from\": 2258, \"to\": 2267}, {\"ngram\": \"peaceful competition\", \"from\": 2271, \"to\": 2291}, {\"ngram\": \"the Olympic Games Paris\", \"from\": 2293, \"to\": 2316}, {\"ngram\": \"a powerful reminder\", \"from\": 2330, \"to\": 2349}, {\"ngram\": \"times\", \"from\": 2400, \"to\": 2405}, {\"ngram\": \"wars\", \"from\": 2409, \"to\": 2413}, {\"ngram\": \"crises\", \"from\": 2418, \"to\": 2424}]}, {\"sentence\": \"The IOC has suspended the membership of Russia and Belarus for the war in Ukraine and sportspersons from these two countries will be participating in Paris Olympics as neutral athletes.\", \"from\": 2437, \"to\": 2622, \"entities\": [{\"begin\": 2441, \"end\": 2444, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.3690774546462037e-17, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 2477, \"end\": 2483, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999627256678072, \"rank\": 3.440557573173518e-05, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}, {\"begin\": 2488, \"end\": 2495, \"title\": \"http://dbpedia.org/resource/Belarus\", \"score\": 0.9979142609386378, \"rank\": 0.002089901559089094, \"text\": \"Belarus\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Belarus\", \"dbpedia\": \"http://dbpedia.org/resource/Belarus\"}, {\"begin\": 2511, \"end\": 2518, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 0.9972776991709043, \"rank\": 0.0027086116402528985, \"text\": \"Ukraine\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpe