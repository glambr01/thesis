ots,\\\" says Kapono.\", \"from\": 6438, \"to\": 6510, \"entities\": [{\"begin\": 6449, \"end\": 6458, \"title\": \"http://dbpedia.org/resource/Polynesia\", \"score\": 1.0, \"rank\": 3.6496984050798375e-16, \"text\": \"Polynesia\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Polynesia\", \"dbpedia\": \"http://dbpedia.org/resource/Polynesia\"}, {\"begin\": 6503, \"end\": 6509, \"title\": \"http://dbpedia.org/resource/Keola_Beamer\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Kapono\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Keola_Beamer\", \"dbpedia\": \"http://dbpedia.org/resource/Keola_Beamer\"}], \"noun_phrases\": [{\"ngram\": \"us\", \"from\": 6443, \"to\": 6445}, {\"ngram\": \"our roots\", \"from\": 6486, \"to\": 6495}]}, {\"sentence\": \"\\\"This is now the war we fight.\", \"from\": 6511, \"to\": 6541, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the war\", \"from\": 6524, \"to\": 6531}]}, {\"sentence\": \"We fight for our environment.\\\"\", \"from\": 6542, \"to\": 6572, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"our environment\", \"from\": 6555, \"to\": 6570}]}, {\"sentence\": \"(Reporting by Lincoln Feast in Tahiti; Editing by Michael Perry)\", \"from\": 6574, \"to\": 6638, \"entities\": [{\"begin\": 6588, \"end\": 6595, \"title\": \"http://dbpedia.org/resource/Abraham_Lincoln\", \"score\": 0.9999998065518599, \"rank\": 1.9344830952537767e-07, \"text\": \"Lincoln\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Abraham_Lincoln\", \"dbpedia\": \"http://dbpedia.org/resource/Abraham_Lincoln\"}, {\"begin\": 6605, \"end\": 6611, \"title\": \"http://dbpedia.org/resource/Tahiti\", \"score\": 0.9999999969791133, \"rank\": 3.0207707151943693e-09, \"text\": \"Tahiti\", \"types\": [\"Q23442\"], \"wikid\": \"http://dbpedia.org/resource/Tahiti\", \"dbpedia\": \"http://dbpedia.org/resource/Tahiti\"}, {\"begin\": 6624, \"end\": 6637, \"title\": \"http://dbpedia.org/re