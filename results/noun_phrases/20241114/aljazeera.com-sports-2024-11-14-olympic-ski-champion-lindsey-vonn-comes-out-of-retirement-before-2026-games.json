ne_skiing\"}], \"noun_phrases\": [{\"ngram\": \"Her 82 World Cup race victories\", \"from\": 824, \"to\": 855}, {\"ngram\": \"the record\", \"from\": 865, \"to\": 875}, {\"ngram\": \"a woman\", \"from\": 880, \"to\": 887}, {\"ngram\": \"that total\", \"from\": 894, \"to\": 904}, {\"ngram\": \"January\", \"from\": 921, \"to\": 928}, {\"ngram\": \"up to 97 wins\", \"from\": 995, \"to\": 1008}, {\"ngram\": \"the history\", \"from\": 1045, \"to\": 1056}, {\"ngram\": \"the sport\", \"from\": 1060, \"to\": 1069}]}, {\"sentence\": \"Before eclipsing Vonn's total, Shiffrin said: \\\"I do not know if I could fill Lindsey's shoes, the way that she has worn them.\\\"\", \"from\": 1072, \"to\": 1198, \"entities\": [{\"begin\": 1103, \"end\": 1111, \"title\": \"http://dbpedia.org/resource/Richard_Shiffrin\", \"score\": 0.9999999913652573, \"rank\": 0.0, \"text\": \"Shiffrin\", \"types\": [\"Q901\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Richard_Shiffrin\", \"dbpedia\": \"http://dbpedia.org/resource/Richard_Shiffrin\"}, {\"begin\": 1149, \"end\": 1156, \"title\": \"http://dbpedia.org/resource/Parts_of_Lindsey\", \"score\": 0.5909093367937478, \"rank\": 0.6435204619808089, \"text\": \"Lindsey\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Parts_of_Lindsey\", \"dbpedia\": \"http://dbpedia.org/resource/Parts_of_Lindsey\"}], \"noun_phrases\": [{\"ngram\": \"Vonn's total\", \"from\": 1089, \"to\": 1101}]}, {\"sentence\": \"Vonn's last competition was in February 2019 after she dealt with a long series of injuries throughout her career.\", \"from\": 1200, \"to\": 1314, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Vonn's last competition\", \"from\": 1200, \"to\": 1223}, {\"ngram\": \"February\", \"from\": 1231, \"to\": 1239}, {\"ngram\": \"a long series\", \"from\": 1266, \"to\": 1279}, {\"ngram\": \"injuries\", \"from\": 1283, \"to\": 1291}, {\"ngram\": \"her career\", \"from\": 1303, \"to\": 1313}]}, {\"sente