"{\"uid\": \"duluthnewstribune.com-lifestyle-dave-hoops-column-judging-olympics-of-beer-no-easy-feat\", \"noun_phrases\": [{\"sentence\": \"Sponsored By ADVERTISEMENT ADVERTISEMENT ADVERTISEMENT Greetings, my friends.\", \"from\": 0, \"to\": 81, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"ADVERTISEMENT\", \"from\": 13, \"to\": 26}, {\"ngram\": \"Greetings\", \"from\": 55, \"to\": 64}, {\"ngram\": \"my friends\", \"from\": 66, \"to\": 76}]}, {\"sentence\": \"Today, I am writing about the most major beer competition for beer - not necessarily award-winning beer, but the process and the significance of producing an award-winning beer.\", \"from\": 82, \"to\": 259, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the most major beer competition\", \"from\": 108, \"to\": 139}, {\"ngram\": \"beer\", \"from\": 144, \"to\": 148}, {\"ngram\": \"not necessarily award-winning beer\", \"from\": 151, \"to\": 185}, {\"ngram\": \"the process\", \"from\": 191, \"to\": 202}, {\"ngram\": \"the significance\", \"from\": 207, \"to\": 223}, {\"ngram\": \"an award-winning beer\", \"from\": 237, \"to\": 258}]}, {\"sentence\": \"This is a fun topic, and I love the idea of trying to explain it.\", \"from\": 260, \"to\": 325, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a fun topic\", \"from\": 268, \"to\": 279}, {\"ngram\": \"the idea\", \"from\": 292, \"to\": 300}]}, {\"sentence\": \"ADVERTISEMENT I write this after returning from judging the World Beer Cup in Las Vegas.\", \"from\": 329, \"to\": 418, \"entities\": [{\"begin\": 408, \"end\": 417, \"title\": \"http://dbpedia.org/resource/Las_Vegas_Strip\", \"score\": 0.7201485018536423, \"rank\": 0.3885901998782442, \"text\": \"Las Vegas\", \"types\": [\"Q34442\"], \"wikid\": \"http://dbpedia.org/resource/Las_Vegas_Strip\", \"dbpedia\": \"http://dbpedia.org/resource/Las_Vegas_Strip\"}], \"noun_phrases\": [{\"ngram\": \"the World Beer Cup\", \"from\": 385, \"to\": 403}]}, {\"sentence\": \"This yearly event takes place just before the Craft Brewers Conference, the yearly conference and trade show for the brewing industry.\", \"from\": 419, \"to\": 553, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"This yearly event\", \"from\": 419, \"to\": 436}, {\"ngram\": \"place\", \"from\": 443, \"to\": 448}, {\"ngram\": \"the Craft Brewers Conference\", \"from\": 461, \"to\": 489}, {\"ngram\": \"the yearly conference and trade show\", \"from\": 491, \"to\": 527}, {\"ngram\": \"the brewing industry\", \"from\": 532, \"to\": 552}]}, {\"sentence\": \"It is often called \\\"the Olympics of Beer\\\" and began in 1996.\", \"from\": 554, \"to\": 614, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"\\\"the Olympics\", \"from\": 573, \"to\": 586}, {\"ngram\": \"Beer\", \"from\": 590, \"to\": 594}]}, {\"sentence\": \"Each year, these two events take place in a different city.\", \"from\": 615, \"to\": 674, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"these two events\", \"from\": 626, \"to\": 642}, {\"ngram\": \"place\", \"from\": 648, \"to\": 653}, {\"ngram\": \"a different city\", \"from\": 657, \"to\": 673}]}, {\"sentence\": \"Last year was Nashville; it was in Las Vegas for the first time.\", \"from\": 675, \"to\": 739, \"entities\": [{\"begin\": 689, \"end\": 698, \"title\": \"http://dbpedia.org/resource/Nashville_Predators\", \"score\": 0.9903687489622235, \"rank\": 0.009722260103641661, \"text\": \"Nashville\", \"types\": [\"Q4498974\", \"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/Nashville_Predators\", \"dbpedia\": \"http://dbpedia.org/resource/Nashville_Predators\"}, {\"begin\": 710, \"end\": 719, \"title\": \"http://dbpedia.org/resource/Las_Vegas_Strip\", \"score\": 0.7201485018536423, \"rank\": 0.3885901998782442, \"text\": \"Las Vegas\", \"types\": [\"Q34442\"], \"wikid\": \"http://dbpedia.org/resource/Las_Vegas_Strip\", \"dbpedia\": \"http://dbpedia.org/resource/Las_Vegas_Strip\"}], \"noun_phrases\": [{\"ngram\": \"the first time\", \"from\": 724, \"to\": 738}]}, {\"sentence\": \"This competition is one of the largest in the world and is unique in that the beers are also from all over the world.\", \"from\": 743, \"to\": 860, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"This competition\", \"from\": 743, \"to\": 759}, {\"ngram\": \"the world\", \"from\": 785, \"to\": 794}, {\"ngram\": \"the beers\", \"from\": 817, \"to\": 826}, {\"ngram\": \"the world\", \"from\": 850, \"to\": 859}]}, {\"sentence\": \"The numbers are impressive: 290 judges from 37 countries spent seven days judging 9,300 beers over 110 categories.\", \"from\": 861, \"to\": 975, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The numbers\", \"from\": 861, \"to\": 872}, {\"ngram\": \"290 judges\", \"from\": 889, \"to\": 899}, {\"ngram\": \"37 countries\", \"from\": 905, \"to\": 917}, {\"ngram\": \"seven days\", \"from\": 924, \"to\": 934}, {\"ngram\": \"9,300 beers\", \"from\": 943, \"to\": 954}, {\"ngram\": \"110 categories\", \"from\": 960, \"to\": 974}]}, {\"sentence\": \"That's over 60,000 bottles and cans opened and served by over 300 hardworking volunteers.\", \"from\": 976, \"to\": 1065, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"over 60,000 bottles\", \"from\": 983, \"to\": 1002}, {\"ngram\": \"cans\", \"from\": 1007, \"to\": 1011}, {\"ngram\": \"over 300 hardworking volunteers\", \"from\": 1033, \"to\": 1064}]}, {\"sentence\": \"I was impressed this year with the high quality of most beers I tried.\", \"from\": 1069, \"to\": 1139, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the high quality\", \"from\": 1100, \"to\": 1116}, {\"ngram\": \"most beers\", \"from\": 1120, \"to\": 1130}]}, {\"sentence\": \"The judges are very committed and serious about their jobs.\", \"from\": 1140, \"to\": 1199, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The judges\", \"from\": 1140, \"to\": 1150}, {\"ngram\": \"their jobs\", \"from\": 1188, \"to\": 1198}]}, {\"sentence\": \"We taste all day, get there early, and keep focus.\", \"from\": 1200, \"to\": 1250, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"focus\", \"from\": 1244, \"to\": 1249}]}, {\"sentence\": \"Becoming a judge is a rigorous path that requires many steps and expertise.\", \"from\": 1252, \"to\": 1327, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a judge\", \"from\": 1261, \"to\": 1268}, {\"ngram\": \"a rigorous path\", \"from\": 1272, \"to\": 1287}, {\"ngram\": \"many steps\", \"from\": 1302, \"to\": 1312}, {\"ngram\": \"expertise\", \"from\": 1317, \"to\": 1326}]}, {\"sentence\": \"I was told the waiting list is currently three years long and many of the folks I worked with this year had 10-25 years under their belts, so new blood gets added slowly as the competition grows.\", \"from\": 1328, \"to\": 1523, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the waiting list\", \"from\": 1339, \"to\": 1355}, {\"ngram\": \"the folks\", \"from\": 1398, \"to\": 1407}, {\"ngram\": \"this year\", \"from\": 1422, \"to\": 1431}, {\"ngram\": \"10-25 years\", \"from\": 1436, \"to\": 1447}, {\"ngram\": \"their belts\", \"from\": 1454, \"to\": 1465}, {\"ngram\": \"new blood\", \"from\": 1470, \"to\": 1479}, {\"ngram\": \"the competition\", \"from\": 1501, \"to\": 1516}]}, {\"sentence\": \"ADVERTISEMENT I am going to explain how we go about judging these beers.\", \"from\": 1527, \"to\": 1600, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"these beers\", \"from\": 1587, \"to\": 1598}]}, {\"sentence\": \"What's the process?\", \"from\": 1601, \"to\": 1620, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the process\", \"from\": 1608, \"to\": 1619}]}, {\"sentence\": \"To enter a medal-worthy beer, the brewer puts huge energy into the recipe and the process and thoughtfully considers the category.\", \"from\": 1621, \"to\": 1751, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a medal-worthy beer\", \"from\": 1630, \"to\": 1649}, {\"ngram\": \"the brewer\", \"from\": 1651, \"to\": 1661}, {\"ngram\": \"huge energy\", \"from\": 1667, \"to\": 1678}, {\"ngram\": \"the recipe\", \"from\": 1684, \"to\": 1694}, {\"ngram\": \"the process\", \"from\": 1699, \"to\": 1710}, {\"ngram\": \"the category\", \"from\": 1738, \"to\": 1750}]}, {\"sentence\": \"Also, the safe transport of the beer to the judging venue is critical.\", \"from\": 1752, \"to\": 1822, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the safe transport\", \"from\": 1758, \"to\": 1776}, {\"ngram\": \"the beer\", \"from\": 1780, \"to\": 1788}, {\"ngram\": \"the judging venue\", \"from\": 1792, \"to\": 1809}]}, {\"sentence\": \"The actual judging is blind.\", \"from\": 1824, \"to\": 1852, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The actual judging\", \"from\": 1824, \"to\": 1842}]}, {\"sentence\": \"We do not know who made the sample we are evaluating.\", \"from\": 1853, \"to\": 1906, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the sample\", \"from\": 1877, \"to\": 1887}]}, {\"sentence\": \"We are given a category to judge, for example, American Pale Ale.\", \"from\": 1907, \"to\": 1972, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a category\", \"from\": 1920, \"to\": 1930}, {\"ngram\": \"example\", \"from\": 1945, \"to\": 1952}]}, {\"sentence\": \"Usually, six judges at a table will judge by rounds.\", \"from\": 1973, \"to\": 2025, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"six judges\", \"from\": 1982, \"to\": 1992}, {\"ngram\": \"a table\", \"from\": 1996, \"to\": 2003}, {\"ngram\": \"rounds\", \"from\": 2018, \"to\": 2024}]}, {\"sentence\": \"The first round will typically have 12 beers and we judges pick the three best beers to advance to the next round.\", \"from\": 2029, \"to\": 2143, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The first round\", \"from\": 2029, \"to\": 2044}, {\"ngram\": \"12 beers\", \"from\": 2065, \"to\": 2073}, {\"ngram\": \"the three best beers\", \"from\": 2093, \"to\": 2113}, {\"ngram\": \"the next round\", \"from\": 2128, \"to\": 2142}]}, {\"sentence\": \"We do this by evaluating the beer on several attributes: appearance, aroma, flavor and taste, mouthfeel, technical achievement, true to style, and overall impression.\", \"from\": 2144, \"to\": 2310, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the beer\", \"from\": 2169, \"to\": 2177}, {\"ngram\": \"several attributes\", \"from\": 2181, \"to\": 2199}, {\"ngram\": \"style\", \"from\": 2280, \"to\": 2285}]}, {\"sentence\": \"We note comments for the brewer to receive after the competition.\", \"from\": 2311, \"to\": 2376, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"comments\", \"from\": 2319, \"to\": 2327}, {\"ngram\": \"the brewer\", \"from\": 2332, \"to\": 2342}, {\"ngram\": \"the competition\", \"from\": 2360, \"to\": 2375}]}, {\"sentence\": \"When a beer advances to Round 2, the process repeats.\", \"from\": 2380, \"to\": 2433, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a beer\", \"from\": 2385, \"to\": 2391}, {\"ngram\": \"Round\", \"from\": 2404, \"to\": 2409}, {\"ngram\": \"the process\", \"from\": 2413, \"to\": 2424}]}, {\"sentence\": \"To win a medal, three to five rounds must usually be \\\"won\\\" to advance.\", \"from\": 2434, \"to\": 2504, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a medal\", \"from\": 2441, \"to\": 2448}, {\"ngram\": \"three to five rounds\", \"from\": 2450, \"to\": 2470}]}, {\"sentence\": \"ADVERTISEMENT At the end, medals are awarded based on these criteria: I am in a unique situation because I am a national-level judge and participate in the process of awarding medals, but I have also been submitting beers in competitions for many years.\", \"from\": 2508, \"to\": 2763, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the end\", \"from\": 2525, \"to\": 2532}, {\"ngram\": \"medals\", \"from\": 2534, \"to\": 2540}, {\"ngram\": \"these criteria\", \"from\": 2562, \"to\": 2576}, {\"ngram\": \"a unique situation\", \"from\": 2586, \"to\": 2604}, {\"ngram\": \"a national-level judge\", \"from\": 2618, \"to\": 2640}, {\"ngram\": \"the process\", \"from\": 2660, \"to\": 2671}, {\"ngram\": \"awarding medals\", \"from\": 2675, \"to\": 2690}, {\"ngram\": \"beers\", \"from\": 2724, \"to\": 2729}, {\"ngram\": \"competitions\", \"from\": 2733, \"to\": 2745}, {\"ngram\": \"many years\", \"from\": 2750, \"to\": 2760}]}, {\"sentence\": \"Of course, I am not allowed to judge any categories in which I have entered a beer.\", \"from\": 2764, \"to\": 2847, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"any categories\", \"from\": 2801, \"to\": 2815}, {\"ngram\": \"a beer\", \"from\": 2840, \"to\": 2846}]}, {\"sentence\": \"But, again, it's a unique perspective of being invested in both sides of the process.\", \"from\": 2848, \"to\": 2933, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a unique perspective\", \"from\": 2865, \"to\": 2885}, {\"ngram\": \"both sides\", \"from\": 2907, \"to\": 2917}, {\"ngram\": \"the process\", \"from\": 2921, \"to\": 2932}]}, {\"sentence\": \"This adds to a great perspective in the discussion.\", \"from\": 2934, \"to\": 2985, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a great perspective\", \"from\": 2947, \"to\": 2966}, {\"ngram\": \"the discussion\", \"from\": 2970, \"to\": 2984}]}, {\"sentence\": \"But what does it all mean?\", \"from\": 2989, \"to\": 3015, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"A lot.\", \"from\": 3016, \"to\": 3022, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A lot\", \"from\": 3016, \"to\": 3021}]}, {\"sentence\": \"It means winning breweries can advertise their success verified by experts to the public.\", \"from\": 3023, \"to\": 3112, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"breweries\", \"from\": 3040, \"to\": 3049}, {\"ngram\": \"their success\", \"from\": 3064, \"to\": 3077}, {\"ngram\": \"experts\", \"from\": 3090, \"to\": 3097}, {\"ngram\": \"the public\", \"from\": 3101, \"to\": 3111}]}, {\"sentence\": \"It means that their beer stands out in excellence.\", \"from\": 3113, \"to\": 3163, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"their beer\", \"from\": 3127, \"to\": 3137}, {\"ngram\": \"excellence\", \"from\": 3152, \"to\": 3162}]}, {\"sentence\": \"It means that breweries are willing to submit beer with subjective judging in a hugely competitive environment where many great beers are passed up.\", \"from\": 3164, \"to\": 3312, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"breweries\", \"from\": 3178, \"to\": 3187}, {\"ngram\": \"beer\", \"from\": 3210, \"to\": 3214}, {\"ngram\": \"subjective judging\", \"from\": 3220, \"to\": 3238}, {\"ngram\": \"a hugely competitive environment\", \"from\": 3242, \"to\": 3274}, {\"ngram\": \"many great beers\", \"from\": 3281, \"to\": 3297}]}, {\"sentence\": \"Are the competitions fair?\", \"from\": 3316, \"to\": 3342, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the competitions\", \"from\": 3320, \"to\": 3336}]}, {\"sentence\": \"Before I started as an official judge, I often felt no, they were not (if I did not win).\", \"from\": 3343, \"to\": 3432, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an official judge\", \"from\": 3363, \"to\": 3380}]}, {\"sentence\": \"Now, I feel strongly that they are very fair and are being judged by many of the very best beer evaluators on the planet.\", \"from\": 3433, \"to\": 3554, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the very best beer evaluators\", \"from\": 3510, \"to\": 3539}, {\"ngram\": \"the planet\", \"from\": 3543, \"to\": 3553}]}, {\"sentence\": \"I am not trying to say only seek out medal-winning beer.\", \"from\": 3556, \"to\": 3612, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"medal-winning beer\", \"from\": 3593, \"to\": 3611}]}, {\"sentence\": \"No way.\", \"from\": 3613, \"to\": 3620, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"No way\", \"from\": 3613, \"to\": 3619}]}, {\"sentence\": \"Always enjoy the beers you love.\", \"from\": 3621, \"to\": 3653, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the beers\", \"from\": 3634, \"to\": 3643}]}, {\"sentence\": \"But breweries that do have distinctive awards in their quiver are surely worth a try.\", \"from\": 3654, \"to\": 3739, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"breweries\", \"from\": 3658, \"to\": 3667}, {\"ngram\": \"distinctive awards\", \"from\": 3681, \"to\": 3699}, {\"ngram\": \"their quiver\", \"from\": 3703, \"to\": 3715}]}, {\"sentence\": \"ADVERTISEMENT Hopefully, I have helped those of you interested in the \\\"how\\\" of beer competitions and given you some ideas to seek out.\", \"from\": 3741, \"to\": 3878, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"beer competitions\", \"from\": 3820, \"to\": 3837}, {\"ngram\": \"some ideas\", \"from\": 3852, \"to\": 3862}]}, {\"sentence\": \"The results of the 2024 World Beer Cup are atworldbeercup.org.\", \"from\": 3879, \"to\": 3941, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The results\", \"from\": 3879, \"to\": 3890}, {\"ngram\": \"the 2024 World Beer Cup\", \"from\": 3894, \"to\": 3917}]}, {\"sentence\": \"Thanks for reading and please email me with questions or comments.\", \"from\": 3945, \"to\": 4011, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Thanks\", \"from\": 3945, \"to\": 3951}, {\"ngram\": \"reading\", \"from\": 3956, \"to\": 3963}, {\"ngram\": \"questions\", \"from\": 3989, \"to\": 3998}, {\"ngram\": \"comments\", \"from\": 4002, \"to\": 4010}]}, {\"sentence\": \"Dave Hoops, who lives and works in Duluth, is a veteran brewer and beer judge.\", \"from\": 4013, \"to\": 4091, \"entities\": [{\"begin\": 4048, \"end\": 4054, \"title\": \"http://dbpedia.org/resource/University_of_Minnesota_Duluth\", \"score\": 0.9941787619287776, \"rank\": 0.005854980522508149, \"text\": \"Duluth\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/University_of_Minnesota_Duluth\", \"dbpedia\": \"http://dbpedia.org/resource/University_of_Minnesota_Duluth\"}], \"noun_phrases\": [{\"ngram\": \"Dave Hoops\", \"from\": 4013, \"to\": 4023}, {\"ngram\": \"a veteran brewer\", \"from\": 4059, \"to\": 4075}, {\"ngram\": \"beer judge\", \"from\": 4080, \"to\": 4090}]}, {\"sentence\": \"Have a beer-related question for Dave?\", \"from\": 4092, \"to\": 4130, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a beer-related question\", \"from\": 4097, \"to\": 4120}, {\"ngram\": \"Dave\", \"from\": 4125, \"to\": 4129}]}, {\"sentence\": \"Email him atdave@hoopsbrewing.comor the News Tribune atlifestyle@duluthnews.com.\", \"from\": 4131, \"to\": 4211, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the News Tribune atlifestyle@duluthnews.com\", \"from\": 4167, \"to\": 4210}]}, {\"sentence\": \"ADVERTISEMENT ADVERTISEMENT\", \"from\": 4215, \"to\": 4243, \"entities\": [], \"noun_phrases\": []}]}"