"{\"uid\": \"theproducenews.com-headlines-wakefern-shoprite-sponsor-special-olympics-new-jersey-summer-games\", \"noun_phrases\": [{\"sentence\": \"Nearly 500 ShopRite and Wakefern Food Corp. team members and their families volunteered at the 2024 Special Olympics New Jersey Summer Games at The College of New Jersey.\", \"from\": 0, \"to\": 172, \"entities\": [{\"begin\": 26, \"end\": 34, \"title\": \"http://dbpedia.org/resource/Wakefern_Food_Corporation\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Wakefern\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Wakefern_Food_Corporation\", \"dbpedia\": \"http://dbpedia.org/resource/Wakefern_Food_Corporation\"}], \"noun_phrases\": [{\"ngram\": \"their families\", \"from\": 61, \"to\": 75}, {\"ngram\": \"the 2024 Special Olympics New Jersey Summer Games\", \"from\": 91, \"to\": 140}, {\"ngram\": \"The College\", \"from\": 144, \"to\": 155}, {\"ngram\": \"New Jersey\", \"from\": 159, \"to\": 169}]}, {\"sentence\": \"ShopRite and Wakefern have been sponsors of Special Olympics New Jersey for more than 30 years, providing meals, activities and volunteer contributions each year.\", \"from\": 173, \"to\": 335, \"entities\": [{\"begin\": 217, \"end\": 233, \"title\": \"http://dbpedia.org/resource/Special_Olympics\", \"score\": 0.9999999999997726, \"rank\": 2.289121125198889e-13, \"text\": \"Special Olympics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Special_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Special_Olympics\"}, {\"begin\": 234, \"end\": 244, \"title\": \"http://dbpedia.org/resource/New_Jersey\", \"score\": 0.9999999974666025, \"rank\": 2.076229553541793e-09, \"text\": \"New Jersey\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/New_Jersey\", \"dbpedia\": \"http://dbpedia.org/resource/New_Jersey\"}], \"noun_phrases\": [{\"ngram\": \"ShopRite\", \"from\": 173, \"to\": 181}, {\"ngram\": \"Wakefern\",