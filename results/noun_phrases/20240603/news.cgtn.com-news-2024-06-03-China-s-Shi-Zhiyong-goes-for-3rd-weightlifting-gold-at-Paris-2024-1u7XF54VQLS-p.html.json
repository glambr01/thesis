"}, {\"begin\": 1460, \"end\": 1465, \"title\": \"http://dbpedia.org/resource/Japan_women's_national_football_team\", \"score\": 0.4306613554864145, \"rank\": 0.7359363986004899, \"text\": \"Japan\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Japan_women's_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Japan_women's_national_football_team\"}], \"noun_phrases\": [{\"ngram\": \"Shi Zhiyong\", \"from\": 1297, \"to\": 1308}, {\"ngram\": \"the gold medal\", \"from\": 1343, \"to\": 1357}, {\"ngram\": \"men\", \"from\": 1361, \"to\": 1364}, {\"ngram\": \"73-kilogram event\", \"from\": 1381, \"to\": 1398}, {\"ngram\": \"the Tokyo Olympics\", \"from\": 1402, \"to\": 1420}]}, {\"sentence\": \"/CFP \\\"I thought the World Cup would be my last international tournament,\\\" Shi told China Media Group (CMG).\", \"from\": 1482, \"to\": 1590, \"entities\": [{\"begin\": 1566, \"end\": 1583, \"title\": \"http://dbpedia.org/resource/China_Media_Group\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"China Media Group\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/China_Media_Group\", \"dbpedia\": \"http://dbpedia.org/resource/China_Media_Group\"}, {\"begin\": 1585, \"end\": 1588, \"title\": \"http://dbpedia.org/resource/Yo_Gotti\", \"score\": 0.8159161327713268, \"rank\": 0.225616127637743, \"text\": \"CMG\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Yo_Gotti\", \"dbpedia\": \"http://dbpedia.org/resource/Yo_Gotti\"}], \"noun_phrases\": [{\"ngram\": \"/CFP\", \"from\": 1482, \"to\": 1486}, {\"ngram\": \"the World Cup\", \"from\": 1498, \"to\": 1511}, {\"ngram\": \"my last international tournament\", \"from\": 1521, \"to\": 1553}, {\"ngram\": \"Shi\", \"from\": 1556, \"to\": 1559}]}, {\"sentence\": \"\\\"I knew I would be facing strong opponents and I did not train well enough.\", \"from\": 1591, \"to\": 1666, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"strong opponents\", \"from\": 1617, \"to\": 1633}]}, {\"sentence\": \"I wanted to give my best efforts to wrap up my international career.\", \"from\": 1667, \"to\": 1735, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my best efforts\", \"from\": 1684, \"to\": 1699}, {\"ngram\": \"my international career\", \"from\": 1711, \"to\": 1734}]}, {\"sentence\": \"\\\"Shi failed to lift 360 kilograms at the World Cup, but after watching others compete, he felt that he wasn't too far behind and could continue to do it.\", \"from\": 1735, \"to\": 1888, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Shi\", \"from\": 1736, \"to\": 1739}, {\"ngram\": \"360 kilograms\", \"from\": 1755, \"to\": 1768}, {\"ngram\": \"the World Cup\", \"from\": 1772, \"to\": 1785}, {\"ngram\": \"others\", \"from\": 1806, \"to\": 1812}]}, {\"sentence\": \"A few days later, he managed to lift 230 kilograms in deadlift in practice.\", \"from\": 1889, \"to\": 1964, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"230 kilograms\", \"from\": 1926, \"to\": 1939}, {\"ngram\": \"deadlift\", \"from\": 1943, \"to\": 1951}, {\"ngram\": \"practice\", \"from\": 1955, \"to\": 1963}]}, {\"sentence\": \"That gave him confidence to challenge himself again in Paris.He recalled how frustrated he was previously when he could not finish regular training on daily basis.\", \"from\": 1965, \"to\": 2128, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"confidence\", \"from\": 1979, \"to\": 1989}, {\"ngram\": \"Paris\", \"from\": 2020, \"to\": 2025}, {\"ngram\": \"regular training\", \"from\": 2096, \"to\": 2112}, {\"ngram\": \"daily basis\", \"from\": 2116, \"to\": 2127}]}, {\"sentence\": \"However, as he has grown healthier in recent months, he has picked up more and more practice every day which gave him true happiness.\", \"from\": 2129, \"to\": 2262, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"recent months\", \"from\": 2167, \"to\": 2180}, {\"ngram\": \"more and more practice\", \"from\": 2199, \"to\": 2221}, {\"ngram\": \"true happiness\", \"from\": 2247, \"to\": 2261}]}, {\"sentence\": \"\\\"I am so happy that I can maintain systematic training every day now,\\\" Shi said.\", \"from\": 2262, \"to\": 2342, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"systematic training\", \"from\": 2297, \"to\": 2316}, {\"ngram\": \"Shi\", \"from\": 2333, \"to\": 2336}]}, {\"sentence\": \"\\\"I may not lift too much sometimes, but I can do it on daily basis.\", \"from\": 2343, \"to\": 2410, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"daily basis\", \"from\": 2398, \"to\": 2409}]}, {\"sentence\": \"I make a little progress every day and then I grow better in the end.\", \"from\": 2411, \"to\": 2480, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a little progress\", \"from\": 2418, \"to\": 2435}, {\"ngram\": \"the end\", \"from\": 2472, \"to\": 2479}]}, {\"sentence\": \"But first, I must keep systematic training sessions.\\\"\", \"from\": 2481, \"to\": 2534, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"systematic training sessions\", \"from\": 2504, \"to\": 2532}]}, {\"sentence\": \"SITEMAP EXPLORE MORE DOWNLOAD OUR APP Copyright \\u00c2\\u00a9 2024 CGTN.\\u00e4\\u00ba\\u00acICP\\u00e5\\u00a4\\u008720000184\\u00e5\\u008f\\u00b7 Disinformation report hotline: 010-85061466 SITEMAP EXPLORE MORE DOWNLOAD OUR APP Copyright \\u00c2\\u00a9 2024 CGTN.\\u00e4\\u00ba\\u00acICP\\u00e5\\u00a4\\u008720000184\\u00e5\\u008f\\u00b7 Disinformation report hotline: 010-85061466\", \"from\": 2536, \"to\": 2796, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"SITEMAP\", \"from\": 2536, \"to\": 2543}, {\"ngram\": \"MORE DOWNLOAD\", \"from\": 2552, \"to\": 2565}, {\"ngram\": \"Copyright \\u00c2\\u00a9 2024 CGTN.\\u00e4\\u00ba\\u00acICP\\u00e5\\u00a4\\u008720000184\\u00e5\\u008f\", \"from\": 2574, \"to\": 2616}, {\"ngram\": \"Disinformation report hotline\", \"from\": 2618, \"to\": 2647}, {\"ngram\": \"010-85061466 