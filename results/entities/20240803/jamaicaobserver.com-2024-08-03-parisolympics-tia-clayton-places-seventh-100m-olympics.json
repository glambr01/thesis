ds.\", \"from\": 615, \"to\": 748, \"entities\": [{\"begin\": 713, \"end\": 722, \"title\": \"http://dbpedia.org/resource/Thomas_Jefferson\", \"score\": 0.999862957211582, \"rank\": 0.00013706157051515116, \"text\": \"Jefferson\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Thomas_Jefferson\", \"dbpedia\": \"http://dbpedia.org/resource/Thomas_Jefferson\"}]}, {\"sentence\": \"-Paul A Reid  Tags:  HOUSE RULES\", \"from\": 750, \"to\": 782, \"entities\": []}]}"