, \"entities\": []}, {\"sentence\": \"\\\"We did everything to get back in the game, but we were not able to.\\\"\", \"from\": 1485, \"to\": 1554, \"entities\": []}, {\"sentence\": \"Guard Jamal Murray of the Denver Nuggets said Canada missed some key shots that could have helped them remain in the game.\", \"from\": 1556, \"to\": 1678, \"entities\": [{\"begin\": 1562, \"end\": 1574, \"title\": \"http://dbpedia.org/resource/Jamal_Murray\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Jamal Murray\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jamal_Murray\", \"dbpedia\": \"http://dbpedia.org/resource/Jamal_Murray\"}, {\"begin\": 1582, \"end\": 1596, \"title\": \"http://dbpedia.org/resource/Denver_Nuggets\", \"score\": 1.0, \"rank\": 2.242806255567971e-35, \"text\": \"Denver Nuggets\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/Denver_Nuggets\", \"dbpedia\": \"http://dbpedia.org/resource/Denver_Nuggets\"}, {\"begin\": 1602, \"end\": 1608, \"title\": \"http://dbpedia.org/resource/Canada_men's_national_ice_hockey_team\", \"score\": 0.9078339606609305, \"rank\": 0.07732314736585544, \"text\": \"Canada\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Canada_men's_national_ice_hockey_team\", \"dbpedia\": \"http://dbpedia.org/resource/Canada_men's_national_ice_hockey_team\"}]}, {\"sentence\": \"\\\"We were able to make it within, I think a five-point game a few times.\", \"from\": 1680, \"to\": 1751, \"entities\": []}, {\"sentence\": \"It never really got over that hump,\\\" Murray said.\", \"from\": 1752, \"to\": 1801, \"entities\": [{\"begin\": 1789, \"end\": 1795, \"title\": \"http://dbpedia.org/resource/Andy_Murray\", \"score\": 0.9968324611102186, \"rank\": 0.0030135167869083756, \"text\": \"Murray\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Andy_Murray\", \"dbpedia\": \"h