, \"from\": 6901, \"to\": 6964, \"entities\": []}, {\"sentence\": \"Looked like they were replaying the chariot race from Ben Hur.\", \"from\": 6966, \"to\": 7028, \"entities\": [{\"begin\": 7020, \"end\": 7027, \"title\": \"http://dbpedia.org/resource/Judah_Ben-Hur\", \"score\": 0.9999842287982053, \"rank\": 1.577145032184488e-05, \"text\": \"Ben Hur\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Judah_Ben-Hur\", \"dbpedia\": \"http://dbpedia.org/resource/Judah_Ben-Hur\"}]}, {\"sentence\": \"Only thing missing was the spiked shoes.\", \"from\": 7029, \"to\": 7069, \"entities\": []}, {\"sentence\": \"The person asking for a re-run of a 5000m is rather optimistic.\", \"from\": 7071, \"to\": 7134, \"entities\": []}, {\"sentence\": \"Looked like they were replaying the chariot race from Ben Hur.\", \"from\": 7136, \"to\": 7198, \"entities\": [{\"begin\": 7190, \"end\": 7197, \"title\": \"http://dbpedia.org/resource/Judah_Ben-Hur\", \"score\": 0.9999842287982053, \"rank\": 1.577145032184488e-05, \"text\": \"Ben Hur\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Judah_Ben-Hur\", \"dbpedia\": \"http://dbpedia.org/resource/Judah_Ben-Hur\"}]}, {\"sentence\": \"Only thing missing was the spiked shoes.\", \"from\": 7199, \"to\": 7239, \"entities\": []}]}"