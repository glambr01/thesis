tities\": [{\"begin\": 2251, \"end\": 2268, \"title\": \"http://dbpedia.org/resource/UAE_Team_Emirates\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"UAE Team Emirates\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/UAE_Team_Emirates\", \"dbpedia\": \"http://dbpedia.org/resource/UAE_Team_Emirates\"}]}, {\"sentence\": \"He has become one of the biggest stars of its supporting cast around two-time Tour de France winner Tadej Poga\\u010dar of Slovenia.\", \"from\": 2278, \"to\": 2404, \"entities\": [{\"begin\": 2356, \"end\": 2370, \"title\": \"http://dbpedia.org/resource/Tour_de_France\", \"score\": 0.6786135289931379, \"rank\": 0.4735927848115331, \"text\": \"Tour de France\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tour_de_France\", \"dbpedia\": \"http://dbpedia.org/resource/Tour_de_France\"}]}, {\"sentence\": \"In his Olympic debut in Tokyo, McNulty was the top American man in the road race (sixth) and time trial (24th).\", \"from\": 2406, \"to\": 2517, \"entities\": [{\"begin\": 2430, \"end\": 2435, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.9781138644550901, \"rank\": 0.022324462963333392, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}, {\"begin\": 2437, \"end\": 2444, \"title\": \"http://dbpedia.org/resource/Jimmy_McNulty\", \"score\": 0.9999999991373443, \"rank\": 8.626470839703671e-10, \"text\": \"McNulty\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Jimmy_McNulty\", \"dbpedia\": \"http://dbpedia.org/resource/Jimmy_McNulty\"}, {\"begin\": 2457, \"end\": 2465, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.6997566430952208, \"rank\": 0.42877439488173985, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}]}, {\"sentence\": \"Last year, McNulty won a mountain stage of the Giro, his lone Grand Tour start in 2023.\", \"from\": 2519, \"to\": 2606, \"entities\": [{\"begin\": 2530, \"end\": 2537, \"title\": \"http://dbpedia.org/resource/Jimmy_McNulty\", \"score\": 0.9999999991373443, \"rank\": 8.626470839703671e-10, \"text\": \"McNulty\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Jimmy_McNulty\", \"dbpedia\": \"http://dbpedia.org/resource/Jimmy_McNulty\"}]}, {\"sentence\": \"Expect Vingegaard and Poga\\u010dar, who did not race Paris-Roubaix, to lead their teams in the Grand Tour season, which begins with the Giro starting May 4.\", \"from\": 2608, \"to\": 2759, \"entities\": [{\"begin\": 2630, \"end\": 2637, \"title\": \"http://dbpedia.org/resource/Tadej_Poga\\u010dar\", \"score\": 0.9956688528441069, \"rank\": 0.0, \"text\": \"Poga\\u010dar\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Tadej_Poga\\u010dar\", \"dbpedia\": \"http://dbpedia.org/resource/Tadej_Poga\\u010dar\"}, {\"begin\": 2656, \"end\": 2669, \"title\": \"http://dbpedia.org/resource/Paris\\u2013Roubaix\", \"score\": 0.9816675037644488, \"rank\": 0.004431782209560121, \"text\": \"Paris-Roubaix\", \"types\": [\"Q1656682\", \"Q15091377\"], \"wikid\": \"http://dbpedia.org/resource/Paris\\u2013Roubaix\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\\u2013Roubaix\"}]}, {\"sentence\": \"Poga\\u010dar is expected to race the Giro.\", \"from\": 2760, \"to\": 2797, \"entities\": [{\"begin\": 2760, \"end\": 2767, \"title\": \"http://dbpedia.org/resource/Tadej_Poga\\u010dar\", \"score\": 0.9956688528441069, \"rank\": 0.0, \"text\": \"Poga\\u010dar\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Tadej_Poga\\u010dar\", \"dbpedia\": \"http://dbpedia.org/resource/Tadej_Poga\\u010dar\"}]}, {\"sentence\": \"Poga\\u010dar and Vingegaard are both expected for the Tour 