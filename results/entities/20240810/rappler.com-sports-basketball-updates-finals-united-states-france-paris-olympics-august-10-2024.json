a.org/resource/Stephen_Curry\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Steph Curry\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Stephen_Curry\", \"dbpedia\": \"http://dbpedia.org/resource/Stephen_Curry\"}]}, {\"sentence\": \"Kevin Durant and Devin Booker fired 15 points each as LeBron James posted a double-double of 14 points and 10 assists in a rematch of their Tokyo Games finale three years ago.\", \"from\": 407, \"to\": 582, \"entities\": [{\"begin\": 413, \"end\": 419, \"title\": \"http://dbpedia.org/resource/Kevin_Durant\", \"score\": 1.0, \"rank\": 6.469168160720176e-23, \"text\": \"Durant\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kevin_Durant\", \"dbpedia\": \"http://dbpedia.org/resource/Kevin_Durant\"}, {\"begin\": 424, \"end\": 436, \"title\": \"http://dbpedia.org/resource/Devin_Booker\", \"score\": 1.0, \"rank\": 1.4602795201753524e-32, \"text\": \"Devin Booker\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Devin_Booker\", \"dbpedia\": \"http://dbpedia.org/resource/Devin_Booker\"}, {\"begin\": 461, \"end\": 473, \"title\": \"http://dbpedia.org/resource/LeBron_James\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"LeBron James\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/LeBron_James\", \"dbpedia\": \"http://dbpedia.org/resource/LeBron_James\"}]}, {\"sentence\": \"The French again settled for silver, this time with Victor Wembanyama, the reigning NBA Rookie of the Year, leading the way with 26 points.\", \"from\": 584, \"to\": 723, \"entities\": [{\"begin\": 588, \"end\": 594, \"title\": \"http://dbpedia.org/resource/French_people\", \"score\": 0.4327036748189879, \"rank\": 0.6884056538731066, \"text\": \"French\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/French_people\", \"dbpedia\": \"http://dbpedia.org/resource/French_people\"}, {\"begin\": 636, \"end\": 653, \"title\": \"http://dbpedia.org/resource/Victor_Wembanyama\", \"score\": 0.9999841253320871, \"rank\": 0.0, \"text\": \"Victor Wembanyama\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Victor_Wembanyama\", \"dbpedia\": \"http://dbpedia.org/resource/Victor_Wembanyama\"}, {\"begin\": 668, \"end\": 671, \"title\": \"http://dbpedia.org/resource/National_Basketball_Association\", \"score\": 1.0, \"rank\": 1.8362776504829032e-19, \"text\": \"NBA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/National_Basketball_Association\", \"dbpedia\": \"http://dbpedia.org/resource/National_Basketball_Association\"}]}, {\"sentence\": \"And then there were two.\", \"from\": 725, \"to\": 749, \"entities\": []}, {\"sentence\": \"After surviving their respective semifinal foes by the slimmest of margins, Team USA and host country France duke it out for the 2024 Paris Olympics men's basketball title on Saturday, August 10 (Sunday, August 11, Manila time).\", \"from\": 751, \"to\": 979, \"entities\": [{\"begin\": 827, \"end\": 835, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 1.0, \"rank\": 7.500105852226197e-16, \"text\": \"Team USA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\"}, {\"begin\": 853, \"end\": 859, \"title\": \"http://dbpedia.org/resource/France_national_football_team\", \"score\": 0.6716353085274364, \"rank\": 0.48685275579510745, \"text\": \"France\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/France_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/France_national_football_team\"}, {\"begin\": 966, \"end\": 972, \"title\": \"http://dbpedia.org/resource/Manila\", \"score\": 0.9998578434990825, \"rank\": 0.00014213024168521969, \"text\": \"Manila\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Manila\", \"dbpedia\": \"http://dbpedia.org/resource/Manila\"}]}, {\"sentence\": \"This highly anticipated gold-medal showdown between USA and France is a rematch of their Tokyo Games finale three years ago, where the Americans edged the French,87-82, for their fourth consecutive crown.\", \"from\": 981, \"to\": 1185, \"entities\": [{\"begin\": 1033, \"end\": 1036, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_soccer_team\", \"score\": 0.9988109184507193, \"rank\": 0.0007838043620992228, \"text\": \"USA\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_soccer_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_soccer_team\"}, {\"begin\": 1041, \"end\": 1047, \"title\": \"http://dbpedia.org/resource/France_national_football_team\", \"score\": 0.6716353085274364, \"rank\": 0.48685275579510745, \"text\": \"France\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/France_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/France_national_football_team\"}]}, {\"sentence\": \"In arguably one of the best basketball games in Olympic history, the mighty Americans prevailed over Serbia in their semifinal duel last Friday, August 9, with a thrilling95-91come-from-behind escape.\", \"from\": 1187, \"to\": 1387, \"entities\": [{\"begin\": 1288, \"end\": 1294, \"title\": \"http://dbpedia.org/resource/Serbia_national_football_team\", \"score\": 0.9978623876894178, \"rank\": 0.002085569444862486, \"text\": \"Serbia\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Serbia_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Serbia_national_football_team\"}]}, {\"sentence\": \"Thanks to an all-time performance fromSteph Curry- who went off for 36 points built on nine triples - USA managed to overcome a 17-point deficit in the first half and a 13-point disadvantage at the start of the fourth quarter to move within a win of its fifth straight gold and its 17th overall.\", \"from\": 1389, \"to\": 1684, \"entities\": []}, {\"sentence\": \"After finally breaking out of his slump, look for Curry to put on a shooting clinic anew as he looks to capture his first-ever Olympic gold with the star-studded USA cast.\", \"from\": 1686, \"to\": 1857, \"entities\": [{\"begin\": 1848, \"end\": 1851, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_soccer_team\", \"score\": 0.9988109184507193, \"rank\": 0.0007838043620992228, \"text\": \"USA\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_soccer_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_soccer_team\"}]}, {\"sentence\": \"Meanwhile, count on LeBron James - who delivered a triple-double of 16 points, 12 rebounds, and 10 assists against Serbia - and Kevin Durant to save the best for last and continue to show the way for USA in what could be their final appearances in the Olympic stage.\", \"from\": 1859, \"to\": 2125, \"entities\": [{\"begin\": 1879, \"end\": 1891, \"title\": \"http://dbpedia.org/resource/LeBron_James\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"LeBron James\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/LeBron_James\", \"dbpedia\": \"http://dbpedia.org/resource/LeBron_James\"}, {\"begin\": 1974, \"end\": 1980, \"title\": \"http://dbpedia.org/resource/Serbia_national_football_team\", \"score\": 0.9978623876894178, \"rank\": 0.002085569444862486, \"text\": \"Serbia\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Serbia_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Serbia_national_football_team\"}, {\"begin\": 1993, \"end\": 1999, \"title\": \"http://dbpedia.org/resource/Kevin_Durant\", \"score\": 1.0, \"rank\": 6.469168160720176e-23, \"text\": \"Durant\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kevin_Durant\", \"dbpedia\": \"http://dbpedia.org/resource/Kevin_Durant\"}, {\"begin\": 2059, \"end\": 2062, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_soccer_team\", \"score\": 0.9988109184507193, \"rank\": 0.0007838043620992228, \"text\": \"USA\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_soccer_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_soccer_team\"}]}, {\"sentence\": \"Joel Embiid - who stepped up huge with 19 points against Serbia - is also expected to deliver once more for the Americans and shake off the boos from the hostile French crowd.\", \"from\": 2127, \"to\": 2302, \"entities\": [{\"begin\": 2184, \"end\": 2190, \"title\": \"http://dbpedia.org/resource/Serbia_national_football_team\", \"score\": 0.9978623876894178, \"rank\": 0.002085569444862486, \"text\": \"Serbia\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Serbia_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Serbia_national_football_team\"}, {\"begin\": 2289, \"end\": 2295, \"title\": \"http://dbpedia.org/resource/French_people\", \"score\": 0.4327036748189879, \"rank\": 0.6884056538731066, \"text\": \"French\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/French_people\", \"dbpedia\": \"http://dbpedia.org/resource/French_people\"}]}, {\"sentence\": \"Embiid has been heavily booed by the home fans since the start of the Paris Games as he decided to play for the powerhouse USA despite having dual citizenship in France.\", \"from\": 2304, \"to\": 2473, \"entities\": [{\"begin\": 2427, \"end\": 2430, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_soccer_team\", \"score\": 0.9988109184507193, \"rank\": 0.0007838043620992228, \"text\": \"USA\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_soccer_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_soccer_team\"}, {\"begin\": 2466, \"end\": 2472, \"title\": \"http://dbpedia.org/resource/France_national_football_team\", \"score\": 0.6716353085274364, \"rank\": 0.48685275579510745, \"text\": \"France\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/France_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/France_national_football_team\"}]}, {\"sentence\": \"For the French, who are also coming off a similar 4-point comeback win over Germany in the semifinals,73-69, expect towering 7-foot-4 sensationVictor Wembanyamato give it all on the court and hold his own against USA's frontline of Embiid and Anthony Davis.\", \"from\": 2475, \"to\": 2732, \"entities\": [{\"begin\": 2483, \"end\": 2489, \"title\": \"http://dbpedia.org/resource/French_people\", \"score\": 0.4327036748189879, \"rank\": 0.6884056538731066, \"text\": \"French\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/French_people\", \"dbpedia\": \"http://dbpedia.org/resource/French_people\"}, {\"begin\": 2551, \"end\": 2558, \"title\": \"http://dbpedia.org/resource/Germany_national_football_team\", \"score\": 0.9991099826021735, \"rank\": 0.0008906803296001924, \"text\": \"Germany\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Germany_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Germany_national_football_team\"}, {\"begin\": 2688, \"end\": 2691, \"title\": \"http://d