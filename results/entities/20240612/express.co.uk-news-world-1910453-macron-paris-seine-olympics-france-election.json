9740059610041658, \"rank\": 0.0, \"text\": \"Ciotti\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/\\u00c9ric_Ciotti\", \"dbpedia\": \"http://dbpedia.org/resource/\\u00c9ric_Ciotti\"}, {\"begin\": 2695, \"end\": 2710, \"title\": \"http://dbpedia.org/resource/The_Republicans_(France)\", \"score\": 0.9858665854984828, \"rank\": 0.014053243980715642, \"text\": \"The Republicans\", \"types\": [\"Q7278\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/The_Republicans_(France)\", \"dbpedia\": \"http://dbpedia.org/resource/The_Republicans_(France)\"}, {\"begin\": 2896, \"end\": 2910, \"title\": \"http://dbpedia.org/resource/National_Rally\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"National Rally\", \"types\": [\"Q7278\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/National_Rally\", \"dbpedia\": \"http://dbpedia.org/resource/National_Rally\"}]}, {\"sentence\": \"\\\"We must, first and foremost, continue relentlessly to act for greater security and (state) firmness, and implement the laws that have been passed, like our European texts, to reduce illegal immigration.\\\"\", \"from\": 3010, \"to\": 3214, \"entities\": []}, {\"sentence\": \"SEARCH  CONNECT WITH US  TODAY'S PAPER  See today's front and back pages, download the newspaper, order back issues and use the historic Daily Express newspaper archive.\", \"from\": 3216, \"to\": 3385, \"entities\": [{\"begin\": 3353, \"end\": 3366, \"title\": \"http://dbpedia.org/resource/Daily_Express\", \"score\": 1.0, \"rank\": 3.1726676421394613e-16, \"text\": \"Daily Express\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/Daily_Express\", \"dbpedia\": \"http://dbpedia.org/resource/Daily_Express\"}]}, {\"sentence\": \"EXPRESS.CO.UK  Daily Express uses notifications to keep you updated\", \"from\": 3387, \"to\": 3454, \"entities\": [{\"begin\": 3402, \"end\": 3415