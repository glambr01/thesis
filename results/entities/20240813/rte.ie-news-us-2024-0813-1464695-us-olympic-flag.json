"{\"uid\": \"rte.ie-news-us-2024-0813-1464695-us-olympic-flag\", \"entities\": [{\"sentence\": \"The Olympic flag arrived in Los Angeles, where it will be flown in 2028 when the city hosts the next Summer Games.\", \"from\": 0, \"to\": 114, \"entities\": [{\"begin\": 28, \"end\": 39, \"title\": \"http://dbpedia.org/resource/Los_Angeles\", \"score\": 0.9999923287738075, \"rank\": 7.671263935981916e-06, \"text\": \"Los Angeles\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Los_Angeles\", \"dbpedia\": \"http://dbpedia.org/resource/Los_Angeles\"}]}, {\"sentence\": \"The flag arrived on board a Delta Airlines jet carrying American athletes and officials, and was painted with \\\"LA28\\\" and palm trees on its side.\", \"from\": 116, \"to\": 260, \"entities\": [{\"begin\": 172, \"end\": 180, \"title\": \"http://dbpedia.org/resource/American_Airlines\", \"score\": 0.7181919884288577, \"rank\": 0.3923851075661257, \"text\": \"American\", \"types\": [\"Q4830453\", \"Q46970\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/American_Airlines\", \"dbpedia\": \"http://dbpedia.org/resource/American_Airlines\"}]}, {\"sentence\": \"Los Angeles Mayor Karen Bass stepped off the plane dressed in a red Team USA tracksuit, smiled broadly and waved the Olympic flag before descending airstairs to be greeted by California Governor Gavin Newsom.\", \"from\": 262, \"to\": 470, \"entities\": [{\"begin\": 262, \"end\": 273, \"title\": \"http://dbpedia.org/resource/Los_Angeles\", \"score\": 0.9999923287738075, \"rank\": 7.671263935981916e-06, \"text\": \"Los Angeles\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Los_Angeles\", \"dbpedia\": \"http://dbpedia.org/resource/Los_Angeles\"}, {\"begin\": 280, \"end\": 290, \"title\": \"http://dbpedia.org/resource/Karen_Bass\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Karen Bass\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"htt