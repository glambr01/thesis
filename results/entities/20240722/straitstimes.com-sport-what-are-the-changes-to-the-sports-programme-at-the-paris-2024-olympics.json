dia.org/resource/Paris\", \"score\": 1.0, \"rank\": 3.7927017962776926e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 362, \"end\": 368, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.864812046833288, \"rank\": 0.1172922913882636, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}]}, {\"sentence\": \"REUTERS/Fabrizio Bensch/File Photo    Published\\u00c2Jul 22, 2024, 06:44 PM  Updated\\u00c2Jul 22, 2024, 06:44 PM  PARIS - The Paris Olympics, which open on Friday, will feature a new sport in breaking, plus three young sports returning from the Tokyo Games -- climbing, skateboarding and surfing.\", \"from\": 387, \"to\": 673, \"entities\": [{\"begin\": 387, \"end\": 394, \"title\": \"http://dbpedia.org/resource/Reuters\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"REUTERS\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Reuters\", \"dbpedia\": \"http://dbpedia.org/resource/Reuters\"}, {\"begin\": 395, \"end\": 403, \"title\": \"http://dbpedia.org/resource/Fabrizio_Faniello\", \"score\": 0.9997315638128274, \"rank\": 0.0002685082642571692, \"text\": \"Fabrizio\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Fabrizio_Faniello\", \"dbpedia\": \"http://dbpedia.org/resource/Fabrizio_Faniello\"}]}, {\"sentence\": \"These are the changes to the sports programme:  BREAKING TO MAKE OLYMPIC DEBUT  A competitive form of breakdancing that blends artistry and dance with acrobatic moves, breaking will debut at the Paris Olympics.\", \"from\": 674, \"to\": 884, \"entities\": []}, {\"sentence\": \"The urban dance style, which originated in the Bronx borough of New York in the 1970s, was announced as part of the Paris 2024 programme in late 2020.\", \"from\": 885, \"to\": 1035, \"entities\": [{\"begin\": 932, \"end\": 937, \"title\": \"http://dbpedia.org/resource/The_Bronx\", \"score\": 0.9999781440957226, \"rank\": 2.1849661395788195e-05, \"text\": \"Bronx\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/The_Bronx\", \"dbpedia\": \"http://dbpedia.org/resource/The_Bronx\"}, {\"begin\": 949, \"end\": 957, \"title\": \"http://dbpedia.org/resource/New_York_City\", \"score\": 0.999999986293915, \"rank\": 1.3075306988942024e-08, \"text\": \"New York\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/New_York_City\", \"dbpedia\": \"http://dbpedia.org/resource/New_York_City\"}, {\"begin\": 1001, \"end\": 1011, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 7.577673642199388e-31, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}]}, {\"sentence\": \"Twice World DanceSport Federation (WDSF) championship winner Victor Montalvo and Canadian Phil Wizard (Philip Kim) will be the favourites in the B-Boy category.\", \"from\": 1037, \"to\": 1197, \"entities\": [{\"begin\": 1037, \"end\": 1042, \"title\": \"http://dbpedia.org/resource/Twice\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Twice\", \"types\": [\"Q43229\", \"Q24229398\", \"Q215380\"], \"wikid\": \"http://dbpedia.org/resource/Twice\", \"dbpedia\": \"http://dbpedia.org/resource/Twice\"}, {\"begin\": 1043, \"end\": 1070, \"title\": \"http://dbpedia.org/resource/World_DanceSport_Federation\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"World DanceSport Federation\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_DanceSport_Federation\", \"dbpedia\": \"http://dbpedia.org/resource/World_DanceSport_Federation\"}, {\"begin\": 1072, \"end\": 1076, \"title\": \"http://dbpedia.org/resource/World_DanceSport_Federation\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"WDSF\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_DanceSport_Federation\", \"dbpedia\": \"http://dbpedia.org/resource/World_DanceSport_Federation\"}, {\"begin\": 1098, \"end\": 1104, \"title\": \"http://dbpedia.org/resource/JVCKenwood_Victor_Entertainment\", \"score\": 0.6782250071704339, \"rank\": 0.4642587428473728, \"text\": \"Victor\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/JVCKenwood_Victor_Entertainment\", \"dbpedia\": \"http://dbpedia.org/resource/JVCKenwood_Victor_Entertainment\"}, {\"begin\": 1105, \"end\": 1113, \"title\": \"http://dbpedia.org/resource/Montalvo_Beach\", \"score\": 0.5507311254812526, \"rank\": 0.8074555646510927, \"text\": \"Montalvo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Montalvo_Beach\", \"dbpedia\": \"http://dbpedia.org/resource/Montalvo_Beach\"}, {\"begin\": 1118, \"end\": 1126, \"title\": \"http://dbpedia.org/resource/Canada\", \"score\": 0.7454080804852026, \"rank\": 0.3415344549340246, \"text\": \"Canadian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Canada\", \"dbpedia\": \"http://dbpedia.org/resource/Canada\"}, {\"begin\": 1140, \"end\": 1150, \"title\": \"http://dbpedia.org/resource/Philip_Kim\", \"score\": 0.9999999999986358, \"rank\": 0.0, \"text\": \"Philip Kim\", \"types\": [\"Q901\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Philip_Kim\", \"dbpedia\": \"http://dbpedia.org/resource/Philip_Kim\"}]}, {\"sentence\": \"Montalvo, 30, held off Wizard in the final to take the WDSF World Breaking Championship title last year and became the first American to qualify for breaking at the Olympics.\", \"from\": 1199, \"to\": 1373, \"entities\": [{\"begin\": 1254, \"end\": 1258, \"title\": \"http://dbpedia.org/resource/World_DanceSport_Federation\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"WDSF\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_DanceSport_Federation\", \"dbpedia\": \"http://dbpedia.org/resource/World_DanceSport_Federation\"}, {\"begin\": 1324, \"end\": 1332, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999976784883646, \"rank\": 2.2627230253633843e-06, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}]}, {\"sentence\": \"Wizard, 27, won the WDSF championship in 2022.\", \"from\": 1375, \"to\": 1421, \"entities\": [{\"begin\": 1395, \"end\": 1399, \"title\": \"http://dbpedia.org/resource/World_DanceSport_Federation\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"WDSF\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_DanceSport_Federation\", \"dbpedia\": \"http://dbpedia.org/resource/World_DanceSport_Federation\"}]}, {\"sentence\": \"In the B-Girl category, the 2023 world champion, 17-year-old Nicka (Dominika Banevic) of Lithuania, and Japanese Ami (Ami Yuasa) will be the ones to watch out for.\", \"from\": 1423, \"to\": 1586, \"entities\": [{\"begin\": 1512, \"end\": 1521, \"title\": \"http://dbpedia.org/resource/Lithuania_men's_national_basketball_team\", \"score\": 0.9999993845101092, \"rank\": 6.154880315146826e-07, \"text\": \"Lithuania\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Lithuania_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/Lithuania_men's_national_basketball_team\"}, {\"begin\": 1527, \"end\": 1535, \"title\": \"http://dbpedia.org/resource/Japanese_language\", \"score\": 0.925979374479553, \"rank\": 0.07932572820721624, \"text\": \"Japanese\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Japanese_language\", \"dbpedia\": \"http://dbpedia.org/resource/Japanese_language\"}]}, {\"sentence\": \"NEW CANOE SLALOM EVENT KAYAK CROSS  Having made its Olympic debut at Munich 1972, canoe slalom will see a new event added to its roster with kayak cross making its debut at Paris 2024.\", \"from\": 1588, \"to\": 1772, \"entities\": [{\"begin\": 1657, \"end\": 1668, \"title\": \"http://dbpedia.org/resource/1972_Summer_Olympics\", \"score\": 1.0, \"rank\": 4.3331598897429116e-19, \"text\": \"Munich 1972\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/1972_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/1972_Summer_Olympics\"}, {\"begin\": 1676, \"end\": 1682, \"title\": \"http://dbpedia.org/resource/Slalom_skiing\", \"score\": 0.9975719911988181, \"rank\": 0.0024339183762134044, \"text\": \"slalom\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Slalom_skiing\", \"dbpedia\": \"http://dbpedia.org/resource/Slalom_skiing\"}, {\"begin\": 1729, \"end\": 1734, \"title\": \"http://dbpedia.org/resource/Kayak\", \"score\": 0.9997396949149565, \"rank\": 0.0002603728612450093, \"text\": \"kayak\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Kayak\", \"dbpedia\": \"http://dbpedia.org/resource/Kayak\"}, {\"begin\": 1761, \"end\": 1771, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 7.577673642199388e-31, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}]}, {\"sentence\": \"Kayak cross is an extreme canoe slalom, which sees competitors in kayaks race on white water, jostling each other with their paddles for pole position.\", \"from\": 1774, \"to\": 1925, \"entities\": [{\"begin\": 1774, \"end\": 1779, \"title\": \"http://dbpedia.org/resource/Kayak\", \"score\": 0.9946471631148672, \"rank\": 0.005381643947402234, \"text\": \"Kayak\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Kayak\", \"dbpedia\": \"http://dbpedia.org/resource/Kayak\"}]}, {\"sentence\": \"The Olympic event will begin with timed solo runs before introducing a frenetic element of head-to-head competition as four racers face off against each other, vying for position on the course with placings changing rapidly and contact almost inevitable.\", \"from\": 1927, \"to\": 2181, \"entities\": []}, {\"sentence\": \"Britain's world champion Joe Clarke and Australia's Jessica Fox are among the favourites to win inaugural gold medals in the event, but the chaotic nature of the four-person races makes them almost impossible to predict.\", \"from\": 2183, \"to\": 2403, \"entities\": [{\"begin\": 2183, \"end\": 2190, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9739360457103582, \"rank\": 0.026761365806436534, \"text\": \"Britain\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}, {\"begin\": 2208, \"end\": 2211, \"title\": \"http://dbpedia.org/resource/Joe_Jonas\", \"score\": 0.7249027750288392, \"rank\": 0.37754178015805073, \"text\": \"Joe\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Joe_Jonas\", \"dbpedia\": \"http://dbpedia.org/resource/Joe_Jonas\"}, {\"begin\": 2223, \"end\": 2232, \"title\": \"http://dbpedia.org/resource/Australia\", \"score\": 0.9954110237575978, \"rank\": 0.004602442083448757, \"text\": \"Australia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Australia\", \"dbpedia\": \"http://dbpedia.org/resource/Australia\"}, {\"begin\": 2235, \"end\": 2246, \"title\": \"http://dbpedia.org/resource/Jessica_Fox_(actress)\", \"score\": 0.548202986974713, \"rank\": 0.8241415192508661, \"text\": \"Jessica Fox\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jessica_Fox_(actress)\", \"dbpedia\": \"http://dbpedia.org/resource/Jessica_Fox_(actress)\"}]}, {\"sentence\": \"There will be six medals up for grabs, and an equal number of men and women competing.\", \"from\": 2405, \"to\": 2491, \"entities\": []}, {\"sentence\": \"WHICH NEW SPORTS ARE RETURNING FROM TOKYO?\", \"from\": 2493, \"to\": 2535, \"entities\": []}, {\"sentence\": \"The Paris organisers have included sport climbing, skateboarding and surfing \\u00e2\\u0080\\u0094 all of which also featured as additional events at Tokyo 2020.\", \"from\": 2537, \"to\": 2680, \"entities\": [{\"begin\": 2541, \"end\": 2546, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 3.7927017962776926e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 2669, \"end\": 2674, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.9935929139914746, \"rank\": 0.006448358572849138, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}]}, {\"sentence\": \"Climbing: There will be two events for male and female competitors in Paris -- speed climbing and a combined bouldering and lead competition.\", \"from\": 2682, \"to\": 2823, \"entities\": [{\"begin\": 2752, \"end\": 2757, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 3.7927017962776926e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"Skateboarding: Skateboarding will have two disciplines, street and park.\", \"from\": 2825, \"to\": 2897, \"entities\": []}, {\"sentence\": \"Surfing: Almost 16,000 km from the main Games venues, 48 surfers will compete in the shortboard events in Teahupo'o in Tahiti.\", \"from\": 2899, \"to\": 3025, \"entities\": [{\"begin\": 3018, \"end\": 3024, \"title\": \"http://dbpedia.org/resource/Tahiti\", \"score\": 0.9999998697358108, \"rank\": 1.2975996287379378e-07, \"text\": \"Tahiti\", \"types\": [\"Q23442\"], \"wikid\": \"http://dbpedia.org/resource/Tahiti\", \"dbpedia\": \"http://dbpedia.org/resource/Tahiti\"}]}, {\"sentence\": \"WHICH SPORTS HAVE BEEN DROPPED?\", \"from\": 3027, \"to\": 3058, \"entities\": []}, {\"sentence\": \"Having made its Olympic debut at Tokyo 2020, karate was not included in the 2024 Games.\", \"from\": 3060, \"to\": 3147, \"entities\": [{\"begin\": 3093, \"end\": 3098, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.9935929139914746, \"rank\": 0.006448358572849138, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}]}, {\"sentence\": \"Baseball-softball has also been dropped for Paris but will return at Los Angeles 2028.\", \"from\": 3148, \"to\": 3234, \"entities\": [{\"begin\": 3192, \"end\": 3197, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 3.7927017962776926e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 3217, \"end\": 3233, \"title\": \"http://dbpedia.org/resource/2028_Summer_Olympics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Los Angeles 2028\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2028_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2028_Summer_Olympics\"}]}, {\"sentence\": \"REUTERS  Olympics  Sport climbing  New York  E-paper  Newsletters  Podcasts  RSS Feed  About Us  Terms & Conditions  Personal Data Protection Notice  Need help?\", \"from\": 3235, \"to\": 3395, \"entities\": [{\"begin\": 3235, \"end\": 3242, \"title\": \"http://dbpedia.org/resource/Reuters\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"REUTERS\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Reuters\", \"dbpedia\": \"http://dbpedia.org/resource/Reuters\"}, {\"begin\": 3270, \"end\": 3278, \"title\