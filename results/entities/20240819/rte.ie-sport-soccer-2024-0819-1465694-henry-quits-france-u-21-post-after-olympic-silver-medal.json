"{\"uid\": \"rte.ie-sport-soccer-2024-0819-1465694-henry-quits-france-u-21-post-after-olympic-silver-medal\", \"entities\": [{\"sentence\": \"Thierry Henry has stepped down as France U-21 coach after winning an Olympic silver medal in Paris earlier this month.\", \"from\": 0, \"to\": 118, \"entities\": [{\"begin\": 0, \"end\": 13, \"title\": \"http://dbpedia.org/resource/Thierry_Henry\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Thierry Henry\", \"types\": [\"Q729\", \"Q628099\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Thierry_Henry\", \"dbpedia\": \"http://dbpedia.org/resource/Thierry_Henry\"}, {\"begin\": 34, \"end\": 45, \"title\": \"http://dbpedia.org/resource/France_national_under-21_football_team\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"France U-21\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/France_national_under-21_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/France_national_under-21_football_team\"}, {\"begin\": 93, \"end\": 98, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999998913438184, \"rank\": 1.0865630528305612e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"The 47-year-old was contracted until next summer but has opted to leave his position after just a year in the job.\", \"from\": 120, \"to\": 234, \"entities\": []}, {\"sentence\": \"\\\"Winning the silver medal at the Olympic Games for my country will remain one of the greatest prides of my life,\\\" said Henry.\", \"from\": 236, \"to\": 361, \"entities\": []}, {\"sentence\": \"\\\"I am incredibly grateful to the federation, the players, the staff and the supporters who allowed me to live a magical experience.\\\"\", \"from\": 363, \"to\": 495, \"entities\": []}, {\"sentence\": \"Prior to his appointment by France, Henry had worked as assistant coach of Belgium with managerial jobs at Monaco and Major League Soccer side Montreal Impact.\", \"from\": 497, \"to\": 656, \"entities\": [{\"begin\": 525, \"end\": 531, \"title\": \"http://dbpedia.org/resource/France_national_football_team\", \"score\": 0.9999903756408214, \"rank\": 7.006647392669388e-06, \"text\": \"France\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/France_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/France_national_football_team\"}, {\"begin\": 572, \"end\": 579, \"title\": \"http://dbpedia.org/resource/Belgium_national_football_team\", \"score\": 0.9993350219038566, \"rank\": 0.0005467434089909916, \"text\": \"Belgium\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Belgium_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Belgium_national_football_team\"}, {\"begin\": 604, \"end\": 610, \"title\": \"http://dbpedia.org/resource/AS_Monaco_FC\", \"score\": 0.9999959731225451, \"rank\": 4.026624233818483e-06, \"text\": \"Monaco\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/AS_Monaco_FC\", \"dbpedia\": \"http://dbpedia.org/resource/AS_Monaco_FC\"}, {\"begin\": 615, \"end\": 634, \"title\": \"http://dbpedia.org/resource/Major_League_Soccer\", \"score\": 0.9999999530873549, \"rank\": 4.67199545314327e-08, \"text\": \"Major League Soccer\", \"types\": [\"Q623109\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Major_League_Soccer\", \"dbpedia\": \"http://dbpedia.org/resource/Major_League_Soccer\"}]}, {\"sentence\": \"\\\"On behalf of the FFF (French Football Federation), I would like to thank Thierry Henry for all the work he has accomplished at the head of the under-21 and Olympic teams,\\\" said FFF president Philippe Diallo.\", \"from\": 658, \"to\": 866, \"entities\": [{\"begin\": 676, \"end\": 679, \"title\": \"http://dbpedia.org/resource/French_Football_Federation\", \"score\": 1.0, \"rank\": 8.431347874196716e-16, \"text\": \"FFF\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/French_Football_Federation\", \"dbpedia\": \"http://dbpedia.org/resource/French_Football_Federation\"}, {\"begin\": 681, \"end\": 707, \"title\": \"http://dbpedia.org/resource/French_Football_Federation\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"French Football Federation\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/French_Football_Federation\", \"dbpedia\": \"http://dbpedia.org/resource/French_Football_Federation\"}, {\"begin\": 732, \"end\": 745, \"title\": \"http://dbpedia.org/resource/Thierry_Henry\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Thierry Henry\", \"types\": [\"Q729\", \"Q628099\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Thierry_Henry\", \"dbpedia\": \"http://dbpedia.org/resource/Thierry_Henry\"}, {\"begin\": 836, \"end\": 839, \"title\": \"http://dbpedia.org/resource/French_Football_Federation\", \"score\": 1.0, \"rank\": 8.431347874196716e-16, \"text\": \"FFF\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/French_Football_Federation\", \"dbpedia\": \"http://dbpedia.org/resource/French_Football_Federation\"}, {\"begin\": 859, \"end\": 865, \"title\": \"http://dbpedia.org/resource/Killing_of_Amadou_Diallo\", \"score\": 0.999999968383691, \"rank\": 1.905277085443612e-08, \"text\": \"Diallo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Killing_of_Amadou_Diallo\", \"dbpedia\": \"http://dbpedia.org/resource/Killing_of_Amadou_Diallo\"}]}, {\"sentence\": \"\\\"We obviously regret this decision because Thierry Henry was able to achieve the objectives that had been set for him by winning a silver medal at the Paris Olympics, 40 years after the Olympic medal in Los Angeles.\", \"from\": 868, \"to\": 1083, \"entities\": [{\"begin\": 911, \"end\": 924, \"title\": \"http://dbpedia.org/resource/Thierry_Henry\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Thierry Henry\", \"types\": [\"Q729\", \"Q628099\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Thierry_Henry\", \"dbpedia\": \"http://dbpedia.org/resource/Thierry_Henry\"}, {\"begin\": 1071, \"end\": 1082, \"title\": \"http://dbpedia.org/resource/Los_Angeles\", \"score\": 0.9950710488540483, \"rank\": 0.00495072105832561, \"text\": \"Los Angeles\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Los_Angeles\", \"dbpedia\": \"http://dbpedia.org/resource/Los_Angeles\"}]}, {\"sentence\": \"\\\"Having followed him throughout this campaign, I was able to discover his great professionalism, his rigour and his love of the blue jersey.\", \"from\": 1085, \"to\": 1225, \"entities\": []}, {\"sentence\": \"\\\"We wish him good luck for the rest of his career.\\\"\", \"from\": 1227, \"to\": 1278, \"entities\": []}, {\"sentence\": \"Listen to the RT\\u00c9 Soccer podcast onApple Podcasts,Spotifyorwherever you get your podcasts.\", \"from\": 1282, \"to\": 1372, \"entities\": [{\"begin\": 1296, \"end\": 1299, \"title\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\", \"score\": 0.9835080660478983, \"rank\": 0.013767790549921992, \"text\": \"RT\\u00c9\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\", \"dbpedia\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\"}]}, {\"sentence\": \"Source:PA    \\u00a9 RT\\u00c9 2026.\", \"from\": 1374, \"to\": 1398, \"entities\": []}, {\"sentence\": \"RT\\u00c9.ie is the website of Raidi\\u00f3 Teilif\\u00eds \\u00c9ireann, Ireland's National Public Service Media.\", \"from\": 1399, \"to\": 1489, \"entities\": [{\"begin\": 1424, \"end\": 1447, \"title\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\", \"score\": 0.9993664851268295, \"rank\": 0.0006339164685885233, \"text\": \"Raidi\\u00f3 Teilif\\u