\": [], \"wikid\": \"http://dbpedia.org/resource/Sophie_Scholl\", \"dbpedia\": \"http://dbpedia.org/resource/Sophie_Scholl\"}, {\"begin\": 4412, \"end\": 4420, \"title\": \"http://dbpedia.org/resource/Alfred_Malherbe\", \"score\": 0.9999962885027098, \"rank\": 3.651731775467969e-06, \"text\": \"Malherbe\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Alfred_Malherbe\", \"dbpedia\": \"http://dbpedia.org/resource/Alfred_Malherbe\"}]}, {\"sentence\": \"\\\"This will involve securing the fleet during the parade, as well as securing the Seine river bank,\\\" she added.\", \"from\": 4473, \"to\": 4583, \"entities\": [{\"begin\": 4554, \"end\": 4559, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999999999809006, \"rank\": 1.9023995161142753e-11, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}]}, {\"sentence\": \"Paris' police chief Laurent Nunez has announced plans to deploy around 30,000 police officers each day, including armed police, with a peak of 45,000 for the opening ceremony on the river Seine.\", \"from\": 4585, \"to\": 4779, \"entities\": [{\"begin\": 4585, \"end\": 4590, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999929514, \"rank\": 7.083897663905021e-12, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"The police will be supported by the military, with about 18,000 members of the army involved during the competition.\", \"from\": 4781, \"to\": 4897, \"entities\": []}, {\"sentence\": \"About 220,000 invited and security-screened spectators are expected to fill the upper tiers of the river's banks, and another 100,000 paying spectators will watch from the lower riverside and around the Trocad\\u00e9ro plaza.\", \"from\": 4899, \"to\": 5118, \"entities\": []}, {\"sentence\": \"Browse today's tags\", \"from\": 5124, \"to\": 5143, \"entities\": []}]}"