"{\"uid\": \"jamaicaobserver.com-2024-07-26-judo-athlete-mckenzie-leads-charge-jamaica-olympics\", \"entities\": [{\"sentence\": \"PARIS, France - Jamaica's Judo competitor Ashley McKenzie will be the country's athlete in action at the Olympic Games when he takes on Yemen's Hesham Malabar in the first round of the men's 60kg event at the Champ de Mars Arena in Paris on Saturday.\", \"from\": 0, \"to\": 250, \"entities\": [{\"begin\": 7, \"end\": 13, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.97979766470936, \"rank\": 0.008928975740089742, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 16, \"end\": 23, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.7628761847952227, \"rank\": 0.31059980670990184, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}, {\"begin\": 26, \"end\": 30, \"title\": \"http://dbpedia.org/resource/Judo\", \"score\": 0.41397699222916906, \"rank\": 0.6339516989909856, \"text\": \"Judo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Judo\", \"dbpedia\": \"http://dbpedia.org/resource/Judo\"}, {\"begin\": 42, \"end\": 57, \"title\": \"http://dbpedia.org/resource/Ashley_McKenzie\", \"score\": 0.9999999999797637, \"rank\": 2.0183317624075344e-11, \"text\": \"Ashley McKenzie\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ashley_McKenzie\", \"dbpedia\": \"http://dbpedia.org/resource/Ashley_McKenzie\"}, {\"begin\": 136, \"end\": 141, \"title\": \"http://dbpedia.org/resource/Yemen\", \"score\": 0.9944680473414618, \"rank\": 0.003842416948174782, \"text\": \"Yemen\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Yemen\", \"dbpedia\": \"http://dbpedia.org/resource/Yemen\"}, {\"begin\": 151, \"end\": 158, \"title\": \"http://dbpedia.org/resource/Chera_dynasty\", \"scor