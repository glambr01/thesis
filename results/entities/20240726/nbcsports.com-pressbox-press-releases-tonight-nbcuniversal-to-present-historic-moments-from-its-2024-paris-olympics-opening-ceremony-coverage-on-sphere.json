a.org/resource/NBC_Sports\"}, {\"begin\": 3262, \"end\": 3269, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.9999999999872671, \"rank\": 1.1009109344491663e-11, \"text\": \"Peacock\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Peafowl\", \"dbpedia\": \"http://dbpedia.org/resource/Peafowl\"}]}, {\"sentence\": \"Telemundo will provide Spanish-language coverage beginning at 1 p.m.\", \"from\": 3361, \"to\": 3429, \"entities\": [{\"begin\": 3361, \"end\": 3370, \"title\": \"http://dbpedia.org/resource/Telemundo\", \"score\": 0.9999997531668063, \"rank\": 2.4681557680868944e-07, \"text\": \"Telemundo\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/Telemundo\", \"dbpedia\": \"http://dbpedia.org/resource/Telemundo\"}]}, {\"sentence\": \"ET.\", \"from\": 3430, \"to\": 3433, \"entities\": []}, {\"sentence\": \"Primetime coverage will begin at 7:30 p.m. ET/PT on NBC and Peacock.\", \"from\": 3434, \"to\": 3502, \"entities\": [{\"begin\": 3486, \"end\": 3489, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.9983040404477801, \"rank\": 0.0016977616159276846, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}, {\"begin\": 3494, \"end\": 3501, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.9999999999872671, \"rank\": 1.1009109344491663e-11, \"text\": \"Peacock\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Peafowl\", \"dbpedia\": \"http://dbpedia.org/resource/Peafowl\"}]}, {\"sentence\": \"The NBC broadcast network and streaming service Peacock will be the company's primary platforms for its coverage of the Olympic Games Paris 2024, scheduled for July 26-Aug. 11.\", \"from\": 3503, \"to\": 3679, \"entities\": [{\"begin\": 3507, \"end\": 3510, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.9983040404477801, \"rank\": 0.0016977616159276846, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}]}, {\"sentence\": \"Clickherefor all the ways to watch NBCUniversal's coverage.\", \"from\": 3680, \"to\": 3739, \"entities\": [{\"begin\": 3715, \"end\": 3727, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 0.9999999930637387, \"rank\": 6.936369684545584e-09, \"text\": \"NBCUniversal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}]}, {\"sentence\": \"NBCU owns the U.S. media rights to the Olympic Games through 2032, which are scheduled for Paris (2024), Milan Cortina (2026), Los Angeles (2028) and Brisbane (2032).\", \"from\": 3740, \"to\": 3906, \"entities\": [{\"begin\": 3740, \"end\": 3744, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"NBCU\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}, {\"begin\": 3831, \"end\": 3836, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 2.7646748655043633e-17, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 3845, \"end\": 3850, \"title\": \"http://dbpedia.org/resource/Milan\", \"score\": 0.999999989166554, \"rank\": 1.0832751605059191e-08, \"text\": \"Milan\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Milan\", \"dbpedia\": \"http://dbpedia.org/resource/Milan\"}, {\"begin\": 3851, \"end\": 3858, \"title\": \"http://dbpedia.org/resource/Cortina_d'Ampezzo\", \"score\": 0.9999999999990905, \"rank\": 7.481544983710331e-13, \"text\": \"Cortina\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/reso