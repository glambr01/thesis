"{\"uid\": \"dailypost.ng-2024-07-17-paris-2024-super-falcons-pumped-up-to-play-at-olympics-ajibade\", \"entities\": [{\"sentence\": \"Published  on  By  Rasheedat Ajibade says the Super Falcons can not wait to play at the 2024 Olympic Games, DAILY POST reports.\", \"from\": 0, \"to\": 127, \"entities\": [{\"begin\": 19, \"end\": 36, \"title\": \"http://dbpedia.org/resource/Rasheedat_Ajibade\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Rasheedat Ajibade\", \"types\": [\"Q937857\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Rasheedat_Ajibade\", \"dbpedia\": \"http://dbpedia.org/resource/Rasheedat_Ajibade\"}, {\"begin\": 46, \"end\": 59, \"title\": \"http://dbpedia.org/resource/Nigeria_women's_national_football_team\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Super Falcons\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Nigeria_women's_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Nigeria_women's_national_football_team\"}, {\"begin\": 108, \"end\": 118, \"title\": \"http://dbpedia.org/resource/Liverpool_Daily_Post\", \"score\": 0.9999999999986358, \"rank\": 1.2691016056662205e-12, \"text\": \"DAILY POST\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/Liverpool_Daily_Post\", \"dbpedia\": \"http://dbpedia.org/resource/Liverpool_Daily_Post\"}]}, {\"sentence\": \"The West Africans are making a return to the Olympics after a 16-year absence.\", \"from\": 129, \"to\": 207, \"entities\": []}, {\"sentence\": \"Veteran goalkeeper, Tochukwu Oluehi is the only member of the current squad that has featured at Olympics in the past.\", \"from\": 209, \"to\": 327, \"entities\": []}, {\"sentence\": \"Captain Ajibade stated that Super Falcons can not wait to step on the pitch in Paris.\", \"from\": 329, \"to\": 414, \"entities\": [{\"begin\": 357, \"end\": 370, \"title\": \"http://dbpedia.org/resource/Nigeria_women's_national_football_team\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Super Falcons\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Nigeria_women's_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Nigeria_women's_national_football_team\"}, {\"begin\": 408, \"end\": 413, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.99999888886662, \"rank\": 1.111134598608877e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"\\\"Yes, Olympics, it's the first time for most of us.\", \"from\": 416, \"to\": 467, \"entities\": []}, {\"sentence\": \"We are excited, maybe that's why we all pumped up.\", \"from\": 468, \"to\": 518, \"entities\": []}, {\"sentence\": \"We are ready, we can not wait to be there,\\\" the Atletico Madrid winger told NFF TV.\", \"from\": 519, \"to\": 602, \"entities\": [{\"begin\": 576, \"end\": 582, \"title\": \"http://dbpedia.org/resource/Real_Madrid_CF\", \"score\": 0.9999999906069661, \"rank\": 9.39313431337409e-09, \"text\": \"Madrid\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Real_Madrid_CF\", \"dbpedia\": \"http://dbpedia.org/resource/Real_Madrid_CF\"}]}, {\"sentence\": \"\\\"It's a dream come true, I believe a lot of players in their career want to be in this kind of atmosphere , get to this level but they never achieve that.\", \"from\": 604, \"to\": 758, \"entities\": []}, {\"sentence\": \"\\\"For us, achieving this feat is great.\", \"from\": 760, \"to\": 798, \"entities\": []}, {\"sentence\": \"Playing at the World Cup, and now getting the chance to play at the Olympics, is a dream come true for me and my teammates.\\\"\", \"from\": 799, \"to\": 923, \"entities\": []}, {\"sentence\": \"The Super Falcons will face Spain, Japan and Brazil in Group C.  Randy Waldrum's side will face Brazil in their opening fixture in Bordeaux next week Thursday.\", \"from\": 925, \"to\": 1084, \"entities\": [{\"begin\": 929, \"end\": 942, \"title\": \"http://dbpedia.org/resource/Nigeria_women's_national_football_team\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Super Falcons\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Nigeria_women's_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Nigeria_women's_national_football_team\"}, {\"begin\": 953, \"end\": 958, \"title\": \"http://dbpedia.org/resource/Spain_national_football_team\", \"score\": 0.9999999999972715, \"rank\": 1.5683335732717797e-12, \"text\": \"Spain\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Spain_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Spain_national_football_team\"}, {\"begin\": 960, \"end\": 965, \"title\": \"http://dbpedia.org/resource/Japan_national_football_team\", \"score\": 0.9998758846177085, \"rank\": 0.00012408452731562964, \"text\": \"Japan\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Japan_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Japan_national_football_team\"}, {\"begin\": 970, \"end\": 976, \"title\": \"http://dbpedia.org/resource/Brazil_national_football_team\", \"score\": 0.9999993962332614, \"rank\": 5.773899650841723e-07, \"text\": \"Brazil\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Brazil_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Brazil_national_football_team\"}, {\"begin\": 980, \"end\": 987, \"title\": \"http://dbpedia.org/resource/UEFA_Euro_2012_Group_C\", \"score\": 0.9946065272518331, \"rank\": 0.005138836850536925, \"text\": \"Group C\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/UEFA_Euro_2012_Group_C\", \"dbpedia\": \"http://dbpedia.org/resource