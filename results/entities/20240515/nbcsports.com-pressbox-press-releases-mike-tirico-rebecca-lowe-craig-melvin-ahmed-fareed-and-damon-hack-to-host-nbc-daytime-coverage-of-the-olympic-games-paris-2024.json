ia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}, {\"begin\": 777, \"end\": 784, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.9999999989058779, \"rank\": 1.094003551006012e-09, \"text\": \"Peacock\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Peafowl\", \"dbpedia\": \"http://dbpedia.org/resource/Peafowl\"}, {\"begin\": 790, \"end\": 799, \"title\": \"http://dbpedia.org/resource/Telemundo\", \"score\": 0.9999999999699867, \"rank\": 2.9965947047297703e-11, \"text\": \"Telemundo\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/Telemundo\", \"dbpedia\": \"http://dbpedia.org/resource/Telemundo\"}]}, {\"sentence\": \"Lowe and Melvin will host daily coverage in Paris on NBC, from mid-morning (afterTODAY) to early afternoon ET, followed by Tirico, who in addition to serving as NBC's primetime host, will anchor NBC coverage in the afternoon.\", \"from\": 802, \"to\": 1027, \"entities\": [{\"begin\": 846, \"end\": 851, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.7277511079891377e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 855, \"end\": 858, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.9986796152334732, \"rank\": 0.0012571074793368356, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}, {\"begin\": 963, \"end\": 966, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.9986796152334732, \"rank\": 0.0012571074793368356, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}, {\"begin\": 997, \"end\": 1000, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.9986796152334732, \"rank\": 0.0012571074793368356, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}]}, {\"sentence\": \"Melvin, the news anchor and 3rd-hour co-host ofTODAY, will continue in hisTODAYrole throughout the Paris Olympics.\", \"from\": 1028, \"to\": 1142, \"entities\": []}, {\"sentence\": \"Fareed will host the final portion of NBC's daytime show, while also reporting live from around Paris earlier each day.\", \"from\": 1144, \"to\": 1263, \"entities\": [{\"begin\": 1182, \"end\": 1185, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.9986796152334732, \"rank\": 0.0012571074793368356, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}, {\"begin\": 1240, \"end\": 1245, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.7277511079891377e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"In addition, he will co-host with Lowe on select days when Melvin is on assignment for NBC News.\", \"from\": 1264, \"to\": 1360, \"entities\": [{\"begin\": 1351, \"end\": 1359, \"title\": \"http://dbpedia.org/resource/NBC\", \"score\": 0.9999273152984978, \"rank\": 7.268144958973524e-05, \"text\": \"NBC News\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/NBC\", \"dbpedia\": \"http://dbpedia.org/resource/NBC\"}]}, {\"sentence\": \"Hack will host daily late afternoon coverage for NBC west coast stations.\", \"from\": 1362, \"to\": 1435, \"entities\": [{\"begin\": 1411, \"end\": 1414, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.9986796152334732, \"rank\": 0.0012571074793368356, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}]}, {\"sentence\": \"Specific times for NBC daytime hosts may shift as event timing dictates.\", \"from\": 1437, \"to\": 1509, \"entities\": [{\"begin\": 1456, \"end\": 1467, \"title\": \"http://dbpedia.org/resource/NBC_Daytime\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"NBC daytime\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Daytime\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Daytime\"}]}, {\"sentence\": \"From July 27 - Aug. 11, NBC will provide Olympic fans with at least nine hours of daytime coverage of the Summer Games' most exciting events, including live finals coverage of swimming, gymnastics, track & field, and more.\", \"from\": 1511, \"to\": 1733, \"entities\": [{\"begin\": 1535, \"end\": 1538, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.9986796152334732, \"rank\": 0.0012571074793368356, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}]}, {\"sentence\": \"With Paris six hours ahead of the United States' eastern time zone, the daytime takeover will feature that day's most popular events live on NBC in the morning and afternoon.\", \"from\": 1734, \"to\": 1908, \"entities\": [{\"begin\": 1739, \"end\": 1744, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.7277511079891377e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 1768, \"end\": 1781, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999999631122598, \"rank\": 3.053365677659205e-08, \"text\": \"United States\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 1875, \"end\": 1878, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.9986796152334732, \"rank\": 0.0012571074793368356, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}]}, {\"sentence\": \"Programming on NBC will air from 9 a.m.-6 p.m.\", \"from\": 1910, \"to\": 1956, \"entities\": [{\"begin\": 1925, \"end\": 1928, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.9986796152334732, \"rank\": 0.0012571074793368356, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}]}, {\"sentence\": \"ET and PT, and from 8 a.m-5 p.m. CT and MT every weekday, with the Noon-6 p.m.\", \"from\": 1957, \"to\": 2035, \"entities\": [{\"begin\": 1990, \"end\": 1992, \"title\": \"http://dbpedia.org/resource/Central_Time_Zone\", \"score\": 1.0, \"rank\": 1.5244012460869415e-15, \"text\": \"CT\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Central_Time_Zone\", \"dbpedia\": \"http://dbpedia.org/resource/Central_Time_Zone\"}, {\"begin\": 1997, \"end\": 1999, \"title\": \"http://dbpedia.org/resource/Mountain_Time_Zone\", \"score\": 1.0, \"rank\": 3.188291512047691e-22, \"text\": \"MT\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Mountain_Time_Zone\", \"dbpedia\": \"http://dbpedia.org/resource/Mountain_Time_Zone\"}]}, {\"sentence\": \"ET window live across the country.\", \"from\": 2036, \"to\": 2070, \"entities\": []}, {\"sentence\": \"On weekends, NBC programming expands, beginning as early as 5 a.m.\", \"from\": 2071, \"to\": 2137, \"entities\": [{\"begin\": 2084, \"end\": 2087, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.9986796152334732, \"rank\": 0.0012571074793368356, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}]}, {\"sentence\": \"ET, with extended hours live across the country.\", \"from\": 2138, \"to\": 2186, \"entities\": []}, {\"sentence\": \"Paris 2024 will have more programming hours on the NBC broadcast network than any previous Olympics.\", \"from\": 2187, \"to\": 2287, \"entities\": [{\"begin\": 2187, \"end\": 2197, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 3.221200995978031e-36, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 2238, \"end\": 2241, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.9986796152334732, \"rank\": 0.0012571074793368356, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}]}, {\"sentence\": \"All NBC coverage will be streamed on Peacock.\", \"from\": 2288, \"to\": 2333, \"entities\": [{\"begin\": 2292, \"end\": 2295, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.9986796152334732, \"rank\": 0.0012571074793368356, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}, {\"begin\": 2325, \"end\": 2332, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.9999999989058779, \"rank\": 1.094003551006012e-09, \"text\": \"Peacock\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Peafowl\", \"dbpedia\": \"http://dbpedia.org/resource/Peafowl\"}]}, {\"sentence\": \"\\\"We are excited to have a strong group of hosts throughout NBC's daytime coverage, guiding viewers through all of the day's excitement live as events unfold in Paris,\\\" saidRebecca Chatman, Vice President and Coordinating Producer of NBC Olympics Production.\", \"from\": 2335, \"to\": 2592, \"entities\": [{\"begin\": 2394, \"end\": 2397, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.9986796152334732, \"rank\": 0.0012571074793368356, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}, {\"begin\": 2495, \"end\": 2500, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.7277511079891377e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"Following is a closer look at the hosts:  Mike Tirico      Rebecca Lowe        Craig Melvin        Ahmed Fareed      Damon Hack    ***  In Paris this summer, the world's greatest athletes will compete against the backdrop of one of the most beautiful cities in the world where the modern Olympic Games were conceived 130 years ago.\", \"from\": 2594, \"to\": 2925, \"entities\": [{\"begin\": 2693, \"end\": 2705, \"title\": \"http://dbpedia.org/resource/Ahmed_Fareed\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Ahmed Fareed\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Ahmed_Fareed\", \"dbpedia\": \"http://dbpedia.org/resource/Ahmed_Fareed\"}, {\"begin\": 2711, \"end\": 2716, \"title\": \"http://dbpedia.org/resource/Matt_Damon\", \"score\": 0.9999999345409399, \"rank\": 6.545872180249315e-08, \"text\": \"Damon\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Matt_Damon\", \"dbpedia\": \"http://dbpedia.org/resource/Matt_Damon\"}, {\"begin\": 2733, \"end\": 2738, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.7277511079891377e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"This will be the third time Paris has hosted the Olympics (1900 and 1924), tying London for the most as a Summer Games host.\", \"from\": 2926, \"to\": 3050, \"entities\": [{\"begin\": 2954, \"end\": 2959, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.7277511079891377e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 3007, \"end\": 3013, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9999994570727377, \"rank\": 3.328102403233603e-07, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}]}, {\"sentence\": \"Los Angeles (1932, 1984) will tie those two cities when it hosts the first Summer Games in the U.S. in 32 years in 2028.\", \"from\": 3051, \"to\": 3171, \"entities\": [{\"begin\": 3051, \"end\": 3062, \"title\": \"http://dbpedia.org/resource/Los_Angeles\", \"score\": 0.9999999982169356, \"rank\": 1.4048784900528133e-09, \"text\": \"Los Angeles\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Los_Angeles\", \"dbpedia\": \"http://dbpedia.org/resource/Los_Angeles\"}]}, {\"sentence\": \"The organizers of Paris 2024 are reimagining the Games to make them more accessible to the public and to showcase their city to the world.\", \"from\": 3173, \"to\": 3311, \"entities\": []}, {\"sentence\": \"In a first, competitions will be held amidst iconic Parisian landmarks - beach volleyball at the Eiffel Tower, equestrian at the Palace of Versailles, and urban sports at Place de la Concorde.\", \"from\": 3312, \"to\": 3504, \"entities\": [{\"begin\": 3483, \"end\": 3503, \"title\": \"http://dbpedia.org/resource/Place_de_la_Concorde\", \"score\": 1.0, \"rank\": 6.517668045462373e-14, \"text\": \"Place de la Concorde\", \"types\": [\"Q34442\"], \"wikid\": \"http://dbpedia.org/resource/Place_de_la_Concorde\", \"dbpedia\": \"http://dbpedia.org/resource/Place_de_la_Concorde\"}]}, {\"sentence\": \"Clickherefor more linear programming information andherefor more about the Olympic experience on Peacock.\", \"from\": 3506, \"to\": 3611, \"entities\": [{\"begin\": 3603, \"end\": 3610, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.9999999989058779, \"rank\": 1.094003551006012e-09, \"text\": \"Peacock\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Peafowl\", \"dbpedia\": \"http://dbpedia.org/resource/Peafowl\"}]}, {\"sentence\": \"NBC and Peacock will present live coverage of the Opening Ceremony on Friday, July 26, beginning at Noon ET.\", \"from\": 3613, \"to\": 3721, \"entities\": [{\"begin\": 3613, \"end\": 3616, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.9986796152334732, \"rank\": 0.0012571074793368356, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}, {\"begin\": 3621, \"end\": 3628, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.9999999989058779, \"rank\": 1.094003551006012e-09, \"text\": \"Peacock\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Peafowl\", \"dbpedia\": \"http://dbpedia.org/resource/Peafowl\"}, {\"begin\": 3663, \"end\": 3679, \"title\": \"http://dbpedia.org/resource/Olympic_Games_ceremony\", \"score\": 0.9998659156997048, \"rank\": 0.00011047141411533032, \"text\": \"Opening Ceremony\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games_ceremony\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games_ceremony\"}]}, {\"sentence\": \"Telemundo will provide Spanish-language coverage beginning at 1 p.m.\", \"from\": 3722, \"to\": 3790, \"entities\": [{\"begin\": 3722, \"end\": 3731, \"title\": \"http://dbpedia.org/resource/Telemundo\", \"score\": 0.9999999999699867, \"rank\": 2.9965947047297703e-11, \"text\": \"Telemundo\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/Telemundo\", \"dbpedia\": \"http://dbpedia.org/resource/Telemundo\"}]}, {\"se