86224e-16, \"text\": \"McIntosh\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/McIntosh_Laboratory\", \"dbpedia\": \"http://dbpedia.org/resource/McIntosh_Laboratory\"}, {\"begin\": 3872, \"end\": 3885, \"title\": \"http://dbpedia.org/resource/L\\u00e9on_Marchand\", \"score\": 0.9999997803534156, \"rank\": 0.0, \"text\": \"L\\u00e9on Marchand\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/L\\u00e9on_Marchand\", \"dbpedia\": \"http://dbpedia.org/resource/L\\u00e9on_Marchand\"}]}, {\"sentence\": \"McIntosh also won gold medals in the 200 butterfly and 400 IM, plus a silver in the 400 freestyle.\", \"from\": 3900, \"to\": 3998, \"entities\": [{\"begin\": 3900, \"end\": 3908, \"title\": \"http://dbpedia.org/resource/McIntosh_Laboratory\", \"score\": 1.0, \"rank\": 1.0821849162286224e-16, \"text\": \"McIntosh\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/McIntosh_Laboratory\", \"dbpedia\": \"http://dbpedia.org/resource/McIntosh_Laboratory\"}]}, {\"sentence\": \"She fell just 0.88 seconds - the margin of her loss to Titmus - shy of matching Marchand's four individual golds.\", \"from\": 3999, \"to\": 4112, \"entities\": [{\"begin\": 4079, \"end\": 4087, \"title\": \"http://dbpedia.org/resource/Brad_Marchand\", \"score\": 1.0, \"rank\": 7.27008346879594e-17, \"text\": \"Marchand\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q11774891\"], \"wikid\": \"http://dbpedia.org/resource/Brad_Marchand\", \"dbpedia\": \"http://dbpedia.org/resource/Brad_Marchand\"}]}, {\"sentence\": \"\\\"It's pretty surreal,\\\" said McIntosh, who became the first Canadian athlete to win three golds in a single Olympics.\", \"from\": 4114, \"to\": 4230, \"entities\": [{\"begin\": 4142, \"end\": 4150, \"title\": \"http://dbpedia.org/resource/McIntosh_Laboratory\", \"score\": 1.0, \"rank\": 1.0821849162286224e-16, \"text\": \"McIntosh\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/McIntosh_Laboratory\", \"dbpedia\": \"http://dbpedia.org/resource/McIntosh_Laboratory\"}, {\"begin\": 4173, \"end\": 4181, \"title\": \"http://dbpedia.org/resource/Canadians\", \"score\": 0.9999999853098417, \"rank\": 1.4690483601034163e-08, \"text\": \"Canadian\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Canadians\", \"dbpedia\": \"http://dbpedia.org/resource/Canadians\"}]}, {\"sentence\": \"\\\"I am just so proud of myself and how I have been able to recover and manage events.\\\"\", \"from\": 4231, \"to\": 4316, \"entities\": []}, {\"sentence\": \"US sets world record in mixed relay  The United States made up for a disappointing showing in Tokyo by setting a world record in the 4x100 mixed medley relay.\", \"from\": 4318, \"to\": 4476, \"entities\": [{\"begin\": 4318, \"end\": 4320, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 0.9999999831279639, \"rank\": 1.687212141320509e-08, \"text\": \"US\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\"}, {\"begin\": 4359, \"end\": 4372, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 0.9998979710137974, \"rank\": 0.00010184452952450748, \"text\": \"United States\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\"}, {\"begin\": 4412, \"end\": 4417, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 1.0, \"rank\": 4.875305294466866e-14, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}]}, {\"sentence\": \"Ryan Murphy, Nic Fink, Gretchen Walsh and Torri Huske held off China for a winning time of 3:37.43, breaking the mark of 3:37.58 set by Britain when it won gold in the wild and woolly event's Olympic debut three years ago.\", \"from\": 4478, \"to\": 4700, \"entities\": [{\"begin\": 4478, \"end\": 4489, \"title\": \"http://dbpedia.org/resource/San_Francisco_Giants_minor_league_players\", \"score\": 1.0, \"rank\": 2.123810870954183e-24, \"text\": \"Ryan Murphy\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/San_Francisco_Giants_minor_league_players\", \"dbpedia\": \"http://dbpedia.org/resource/San_Francisco_Giants_minor_league_players\"}, {\"begin\": 4541, \"end\": 4546, \"title\": \"http://dbpedia.org/resource/China_national_football_team\", \"score\": 0.9999998993826062, \"rank\": 1.0061737391406296e-07, \"text\": \"China\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/China_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/China_national_football_team\"}, {\"begin\": 4614, \"end\": 4621, \"title\": \"http://dbpedia.org/resource/Great_Britain\", \"score\": 0.9999722017135616, \"rank\": 2.7799059233864696e-05, \"text\": \"Britain\", \"types\": [\"Q23442\"], \"wikid\": \"http://dbpedia.org/resource/Great_Britain\", \"dbpedia\": \"http://dbpedia.org/resource/Great_Britain\"}]}, {\"sentence\": \"With each team picking two men and two women, the US and China both went with their male swimmers in the first two legs.\", \"from\": 4702, \"to\": 4822, \"entities\": [{\"begin\": 4752, \"end\": 4754, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 0.9999999831279639, \"rank\": 1.687212141320509e-08, \"text\": \"US\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_nat