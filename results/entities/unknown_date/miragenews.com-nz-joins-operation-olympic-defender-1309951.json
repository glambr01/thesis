"{\"uid\": \"miragenews.com-nz-joins-operation-olympic-defender-1309951\", \"entities\": [{\"sentence\": \"New Zealand has accepted an invitation to join US-led multi-national space initiative Operation Olympic Defender, Defence Minister Judith Collins announced today.\", \"from\": 0, \"to\": 162, \"entities\": [{\"begin\": 131, \"end\": 145, \"title\": \"http://dbpedia.org/resource/Judith_Collins\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Judith Collins\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Judith_Collins\", \"dbpedia\": \"http://dbpedia.org/resource/Judith_Collins\"}]}, {\"sentence\": \"Operation Olympic Defender is designed to coordinate the space capabilities of member nations, enhance the resilience of space-based systems, deter hostile actions in space and reduce the spread of debris in orbit.\", \"from\": 164, \"to\": 378, \"entities\": [{\"begin\": 182, \"end\": 190, \"title\": \"http://dbpedia.org/resource/Land_Rover_Defender\", \"score\": 0.9434996348373603, \"rank\": 0.05988382301139246, \"text\": \"Defender\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Land_Rover_Defender\", \"dbpedia\": \"http://dbpedia.org/resource/Land_Rover_Defender\"}]}, {\"sentence\": \"The current membership of the operation is the US, the UK, Canada and Australia.\", \"from\": 379, \"to\": 459, \"entities\": [{\"begin\": 426, \"end\": 428, \"title\": \"http://dbpedia.org/resource/United_States_Armed_Forces\", \"score\": 0.9767572686991606, \"rank\": 0.023503543602657863, \"text\": \"US\", \"types\": [\"Q43229\", \"Q24229398\", \"Q176799\"], \"wikid\": \"http://dbpedia.org/resource/United_States_Armed_Forces\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_Armed_Forces\"}, {\"begin\": 434, \"end\": 436, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9999999976255367, \"rank\": 1.5347337875144036e-09, \"text\": \"UK\", \"types\": [\"Q6256\"], \"wikid\": \"ht