"entities\": [{\"begin\": 1695, \"end\": 1706, \"title\": \"http://dbpedia.org/resource/Jordy_Smith\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Jordy Smith\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Jordy_Smith\", \"dbpedia\": \"http://dbpedia.org/resource/Jordy_Smith\"}]}, {\"sentence\": \"Fully healthy, the 35-year-old will be extra motivated to make his mark when surfing makes its second Olympic appearance in Paris.\", \"from\": 1819, \"to\": 1949, \"entities\": [{\"begin\": 1943, \"end\": 1948, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.9278896936620858e-13, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"Look for Smith to be a podium contender as he represents South Africa on the waves in 2024.\", \"from\": 1951, \"to\": 2042, \"entities\": [{\"begin\": 2008, \"end\": 2020, \"title\": \"http://dbpedia.org/resource/South_Africa\", \"score\": 0.9999999994579412, \"rank\": 5.420176106656668e-10, \"text\": \"South Africa\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/South_Africa\", \"dbpedia\": \"http://dbpedia.org/resource/South_Africa\"}]}, {\"sentence\": \"28-year-old Christiaan Bezuidenhout has been a steady presence on the DP World Tour and PGA Tour in recent years.\", \"from\": 2044, \"to\": 2157, \"entities\": [{\"begin\": 2056, \"end\": 2079, \"title\": \"http://dbpedia.org/resource/Christiaan_Bezuidenhout\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Christiaan Bezuidenhout\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q13156709\"], \"wikid\": \"http://dbpedia.org/resource/Christiaan_Bezuidenhout\", \"dbpedia\": \"http://dbpedia.org/resource/Christiaan_Bezuidenhout\"}, {\"begin\": 2114, \"end\": 2122, \"title\": \"http://dbpedia.org/resource/DP_World\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"DP World\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24