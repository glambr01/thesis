e\", \"score\": 1.0, \"rank\": 1.2941998124536567e-36, \"text\": \"Horoscope\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Horoscope\", \"dbpedia\": \"http://dbpedia.org/resource/Horoscope\"}, {\"begin\": 5344, \"end\": 5352, \"title\": \"http://dbpedia.org/resource/Manchester_City_F.C.\", \"score\": 1.0, \"rank\": 1.7782332099175707e-14, \"text\": \"Man City\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Manchester_City_F.C.\", \"dbpedia\": \"http://dbpedia.org/resource/Manchester_City_F.C.\"}, {\"begin\": 5430, \"end\": 5437, \"title\": \"http://dbpedia.org/resource/Arsenal_F.C.\", \"score\": 0.9998347288501364, \"rank\": 0.0001652984689644074, \"text\": \"Arsenal\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Arsenal_F.C.\", \"dbpedia\": \"http://dbpedia.org/resource/Arsenal_F.C.\"}, {\"begin\": 5444, \"end\": 5452, \"title\": \"http://dbpedia.org/resource/Manchester_City_F.C.\", \"score\": 1.0, \"rank\": 1.7782332099175707e-14, \"text\": \"Man City\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Manchester_City_F.C.\", \"dbpedia\": \"http://dbpedia.org/resource/Manchester_City_F.C.\"}]}]}"