"{\"uid\": \"standard.co.uk-comment-podcasts-team-gb-s-gold-medal-rush-begins-at-paris-2024-olympics-b1173579.html\", \"entities\": [{\"sentence\": \"To use the search feature, we need your consent to load Google Custom Search, which may use cookies or similar technologies.\", \"from\": 0, \"to\": 124, \"entities\": [{\"begin\": 56, \"end\": 76, \"title\": \"http://dbpedia.org/resource/Google_Programmable_Search_Engine\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Google Custom Search\", \"types\": [\"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Google_Programmable_Search_Engine\", \"dbpedia\": \"http://dbpedia.org/resource/Google_Programmable_Search_Engine\"}]}, {\"sentence\": \"Please click 'Allow and Continue' below to enable search.\", \"from\": 125, \"to\": 182, \"entities\": []}, {\"sentence\": \"See our privacy policy for more information.\", \"from\": 183, \"to\": 227, \"entities\": []}, {\"sentence\": \"Comment|Podcasts  Listen here on your chosen podcast platform.\", \"from\": 229, \"to\": 291, \"entities\": []}, {\"sentence\": \"Great Britain's gold rush begins with our victory of Paris 2024 as Ros Canter, Tom McEwen and Laura Collett triumph in equestrian team eventing at the Ch\\u00e2teau de Versailles.\", \"from\": 293, \"to\": 466, \"entities\": [{\"begin\": 293, \"end\": 306, \"title\": \"http://dbpedia.org/resource/Great_Britain\", \"score\": 0.5696747036147756, \"rank\": 0.615254396480353, \"text\": \"Great Britain\", \"types\": [\"Q23442\"], \"wikid\": \"http://dbpedia.org/resource/Great_Britain\", \"dbpedia\": \"http://dbpedia.org/resource/Great_Britain\"}, {\"begin\": 346, \"end\": 356, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.6626786344798391e-21, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 372, \"end\": 382, \"title\": \"http://dbped