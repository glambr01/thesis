"{\"uid\": \"interaksyon.philstar.com-trends-spotlights-2024-08-12-281424-olympics-wrestling-lion-king-kiyooka-and-kagami-underline-japans-mat-mastery-in-paris\", \"entities\": [{\"sentence\": \"PARIS -Wrestling powerhouse Japan bagged two freestyle golds through Kotaro Kiyooka and Yuka Kagami on the final day at the Paris Olympics on Sunday to boost their bumper harvest at the Champ de Mars Arena.\", \"from\": 0, \"to\": 206, \"entities\": [{\"begin\": 28, \"end\": 33, \"title\": \"http://dbpedia.org/resource/Japan\", \"score\": 0.7358033789056619, \"rank\": 0.21943609414794224, \"text\": \"Japan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Japan\", \"dbpedia\": \"http://dbpedia.org/resource/Japan\"}, {\"begin\": 88, \"end\": 92, \"title\": \"http://dbpedia.org/resource/Yuka_(singer)\", \"score\": 0.8783247127167418, \"rank\": 0.08330366678532805, \"text\": \"Yuka\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Yuka_(singer)\", \"dbpedia\": \"http://dbpedia.org/resource/Yuka_(singer)\"}]}, {\"sentence\": \"The Asian nation finished their campaign with eight golds - three more than in Tokyo three years ago - with Iran, Bulgaria and the United States all trailing far behind on the medal table with two apiece.\", \"from\": 208, \"to\": 412, \"entities\": [{\"begin\": 212, \"end\": 217, \"title\": \"http://dbpedia.org/resource/Asian_Games\", \"score\": 0.9999999997642135, \"rank\": 2.357209535556102e-10, \"text\": \"Asian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Asian_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Asian_Games\"}, {\"begin\": 287, \"end\": 292, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 1.0, \"rank\": 3.786333023434479e-14, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}, {\"begin\": 316, \"end\": 320, \"title\": \"http://dbpedia.org/resource/Iran_national_football_team\", \"score\": 0.9133007197003831, \"rank\": 0.09492467750230005, \"text\": \"Iran\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Iran_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Iran_national_football_team\"}, {\"begin\": 322, \"end\": 330, \"title\": \"http://dbpedia.org/resource/Bulgaria\", \"score\": 0.6970033028151219, \"rank\": 0.43470836230140014, \"text\": \"Bulgaria\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Bulgaria\", \"dbpedia\": \"http://dbpedia.org/resource/Bulgaria\"}, {\"begin\": 339, \"end\": 352, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 0.9998968985228285, \"rank\": 0.0001014265903641098, \"text\": \"United States\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\"}]}, {\"sentence\": \"Bahrain's Akhmed Tazhudinov, who competed for Russia until 2022, won Sunday's other gold confirming his growing stature in the 97kg class.\", \"from\": 414, \"to\": 552, \"entities\": [{\"begin\": 414, \"end\": 421, \"title\": \"http://dbpedia.org/resource/Bahrain_national_football_team\", \"score\": 0.9989629405417907, \"rank\": 0.001036468779971955, \"text\": \"Bahrain\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Bahrain_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Bahrain_national_football_team\"}, {\"begin\": 460, \"end\": 466, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999267835884789, \"rank\": 7.300061464762805e-05, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}]}, {\"sentence\": \"Kiyooka was under pressure to deliver having beaten compatriot and Tokyo gold medallist Takuto Otoguro in the wrestle-off for a place in Paris.\", \"from\": 554, \"to\": 697, \"entities\": [{\"begin\": 621, \"end\": 626, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 1.0, \"rank\": 3.786333023434479e-14, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}, {\"begin\": 642, \"end\": 656, \"title\": \"http://dbpedia.org/resource/Takuto_Otoguro\", \"score\": 0.9999999933734216, \"rank\": 0.0, \"text\": \"Takuto Otoguro\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Takuto_Otoguro\", \"dbpedia\": \"http://dbpedia.org/resource/Takuto_Otoguro\"}, {\"begin\": 691, \"end\": 696, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999994402186733, \"rank\": 5.597815331435662e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"The 23-year-old with a mop of bristling hair did not disappoint as he beat Iran's Rahman Amouzadkhalili 10-3 in the gold medal bout.\", \"from\": 699, \"to\": 831, \"entities\": [{\"begin\": 774, \"end\": 778, \"title\": \"http://dbpedia.org/resource/Iran_national_football_team\", \"score\": 0.9133007197003831, \"rank\": 0.09492467750230005, \"text\": \"Iran\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Iran_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Iran_national_football_team\"}]}, {\"sentence\": \"Amouzadkhalili was the first to open his account but Kiyooka killed the contest stone-dead in the first period when he scored a takedown and four turns for a 10-1 lead.\", \"from\": 833, \"to\": 1001, \"entities\": []}, {\"sentence\": \"\\\"There was a certain degree of pressure on me having defeated the Tokyo champion,\\\" Kiyooka told reporters.\", \"from\": 1003, \"to\": 1109, \"entities\": [{\"begin\": 1069, \"end\": 1074, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 1.0, \"rank\": 3.786333023434479e-14, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}]}, {\"sentence\": \"\\\"But I think that pressure actually helped me a bit.\\\"\", \"from\": 1111, \"to\": 1164, \"entities\": []}, {\"sentence\": \"The new Olympic champion has no plans to change his hairstyle, which is quite popular on social media.\", \"from\": 1166, \"to\": 1268, \"entities\": []}, {\"sentence\": \"\\\"I think my hairstyle makes me look like a lion.\", \"from\": 1270, \"to\": 1318, \"entities\": []}, {\"sentence\": \"So I am going to keep it.\\\"\", \"from\": 1319, \"to\": 1345, \"entities\": []}, {\"sentence\": \"Sebastian Rivera of Puerto Rico and Albania's Islam Dudaev took bronze.\", \"from\": 1347, \"to\": 1418, \"entities\": [{\"begin\": 1347, \"end\": 1356, \"title\": \"http://dbpedia.org/resource/Timbaland\", \"score\": 0.8715468410008365, \"rank\": 0.14504035225120657, \"text\": \"Sebastian\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Timbaland\", \"dbpedia\": \"http://dbpedia.org/resource/Timbaland\"}, {\"begin\": 1357, \"end\": 1363, \"title\": \"http://dbpedia.org/resource/Mariano_Rivera\", \"score\": 0.9998325801196231, \"rank\": 0.00015214512853448415, \"text\": \"Rivera\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Mariano_Rivera\", \"dbpedia\": \"http://dbpedia.org/resource/Mariano_Rivera\"}, {\"begin\": 1383, \"end\": 1390, \"title\": \"http://dbpedia.org/resource/Albania_national_football_team\", \"score\": 0.9905079161206556, \"rank\": 0.009296139799635688, \"text\": \"Albania\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Albania_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Albania_national_football_team\"}]}, {\"sentence\": \"Kagami, who trains with male wrestlers at Toyo University to be at her sharpest, won the women's 76kg gold by beating Kennedy Blades of the U.S. 3-1.\", \"from\": 1420, \"to\": 1569, \"entities\": [{\"begin\": 1462, \"end\": 1477, \"title\": \"http://dbpedia.org/resource/Toyo_University\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Toyo University\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/Toyo_University\", \"dbpedia\": \"http://dbpedia.org/resource/Toyo_University\"}, {\"begin\": 1560, \"end\": 1566, \"title\": \"http://dbpedia.org/resource/U.S._Route_3\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"U.S. 3\", \"types\": [\"Q34442\"], \"wikid\": \"http://dbpedia.org/resource/U.S._Route_3\", \"dbpedia\": \"http://dbpedia.org/resource/U.S._Route_3\"}]}, {\"sentence\": \"Kagami scored a takedown out of bounds in the second period and hung on to it despite desperate efforts by her opponent in the remainder of the bout.\", \"from\": 1571, \"to\": 1720, \"entities\": []}, {\"sentence\": \"Milaimy Marin of Cuba and Tatiana Renteria of Colombia won bronze.\", \"from\": 1722, \"to\": 1788, \"entities\": [{\"begin\": 1739, \"end\": 1743, \"title\": \"http://dbpedia.org/resource/Cuba_national_baseball_team\", \"score\": 0.9981748200230744, \"rank\": 0.0018170349851164473, \"text\": \"Cuba\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Cuba_national_baseball_team\", \"dbpedia\": \"http://dbpedia.org/resource/Cuba_national_baseball_team\"}]}, {\"sentence\": \"In the men's 97kg, Georgia's Givi Matcharashvili had to settle for silver as world champion Tazhudinov won the final by pinfall.\", \"from\": 1790, \"to\": 1918, \"entities\": [{\"begin\": 1809, \"end\": 1816, \"title\": \"http://dbpedia.org/resource/Georgia_national_football_team\", \"score\": 0.659082534578575, \"rank\": 0.4764222862849472, \"text\": \"Georgia\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Georgia_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Georgia_national_football_team\"}, {\"begin\": 1819, \"end\": 1838, \"title\": \"http://dbpedia.org/resource/Givi_Matcharashvili\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Givi Matcharashvili\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Givi_Matcharashvili\", \"dbpedia\": \"http://dbpedia.org/resource/Givi_Matcharashvili\"}]}, {\"sentence\": \"\\\"There was a counterattack, and I caught him on this move,\\\" Tazhudinov said.\", \"from\": 1920, \"to\": 1996, \"entities\": []}, {\"sentence\": \"\\\"This is Olympic Games, and all my fights were quite difficult.\\\"\", \"from\": 1998, \"to\": 2062, \"entities\": []}, {\"sentence\": \"\\\"My objective here was to win the gold and it's hard to believe that I am an Olympic champion.\\\"\", \"from\": 2064, \"to\": 2159, \"entities\": []}, {\"sentence\": \"Magomedkhan Magomedov of Azerbaijan and Iran's Amirali Azarpira took bronze.\", \"from\": 2161, \"to\": 2237, \"entities\": [{\"begin\": 2161, \"end\": 2182, \"title\": \"http://dbpedia.org/resource/Magomedkhan_Magomedov\", \"score\": 0.9999999858559933, \"rank\": 0.0, \"text\": \"Magomedkhan Magomedov\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Magomedkhan_Magomedov\", \"dbpedia\": \"http://dbpedia.org/resource/Magomedkhan_Magomedov\"}, {\"begin\": 2186, \"end\": 2196, \"title\": \"http://dbpedia.org/resource/Azerbaijan\", \"score\": 0.9998160639844368, \"rank\": 0.00018033735587635422, \"text\": \"Azerbaijan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Azerbaijan\", \"dbpedia\": \"http://dbpedia.org/resource/Azerbaijan\"}, {\"begin\": 2201, \"end\": 2205, \"title\": \"http://dbpedia.org/resource/Iran_national_football_team\", \"score\": 0.9133007197003831, \"rank\": 0.09492467750230005, \"text\": \"Iran\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Iran_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Iran_national_football_team\"}]}, {\"sentence\": \"-Reporting by Amlan Chakraborty in Paris; Editing by Hugh Lawson\", \"from\": 2239, \"to\": 2303, \"entities\": [{\"begin\": 2253, \"end\": 2258, \"title\": \"http://dbpedia.org/resource/Amlan\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Amlan\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Amlan\", \"dbpedia\": \"http://dbpedia.org/resource/Amlan\"}, {\"begin\": 2274, \"end\": 2279, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999994402186733, \"rank\": 5.597815331435662e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 2297, \"end\": 2303, \"title\": \"http://dbpedia.org/resource/Henry_Lawson\", \"score\": 0.9999938312563883, \"rank\": 5.446874477996206e-06, \"text\": \"Lawson\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Henry_Lawson\", \"dbpedia\": \"http://dbpedia.org/resource/Henry_Lawson\"}]}]}"