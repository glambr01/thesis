org/resource/Rachael_Ray\"}, {\"begin\": 242, \"end\": 248, \"title\": \"http://dbpedia.org/resource/Raygun\", \"score\": 1.0, \"rank\": 4.883347372197476e-19, \"text\": \"Raygun\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Raygun\", \"dbpedia\": \"http://dbpedia.org/resource/Raygun\"}, {\"begin\": 347, \"end\": 352, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9939392151468075, \"rank\": 0.006097741955347399, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"Raygun, who did not earn a single point across her three routines on Friday at the Paris Olympics, has become a meme for her bizarre moves which have been likened to Chris Lilley's Summer Heights High character Mr G.  \\\"I feel for Raygun,\\\" Kyle said on his KIIS radio show on Monday morning.\", \"from\": 367, \"to\": 657, \"entities\": [{\"begin\": 533, \"end\": 545, \"title\": \"http://dbpedia.org/resource/Chris_Lilley_(comedian)\", \"score\": 0.9823943636081104, \"rank\": 0.017919799498746503, \"text\": \"Chris Lilley\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Chris_Lilley_(comedian)\", \"dbpedia\": \"http://dbpedia.org/resource/Chris_Lilley_(comedian)\"}, {\"begin\": 597, \"end\": 603, \"title\": \"http://dbpedia.org/resource/Raygun\", \"score\": 1.0, \"rank\": 4.883347372197476e-19, \"text\": \"Raygun\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Raygun\", \"dbpedia\": \"http://dbpedia.org/resource/Raygun\"}, {\"begin\": 606, \"end\": 610, \"title\": \"http://dbpedia.org/resource/Kyle_Broflovski\", \"score\": 0.9086273852114318, \"rank\": 0.09486240313851746, \"text\": \"Kyle\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Kyle_Broflovski\", \"dbpedia\": \"http://dbpedia.org/resource/Kyle_Broflovski\"}]}, {\"sentence\": \"His co-host Jackie O questioned whether he should \\\"feel for her\\\" since she had become \\\"huge\\\" since her Paris performance, but Kyle quipped that it was not the kind of success one could be proud of.\", \"from\": 659, \"to\": 856, \"entities\": [{\"begin\": 671, \"end\": 679, \"title\": \"http://dbpedia.org/resource/Jacqueline_Kennedy_Onassis\", \"score\": 1.0, \"rank\": 1.4954811780014252e-17, \"text\": \"Jackie O\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jacqueline_Kennedy_Onassis\", \"dbpedia\": \"http://dbpedia.org/resource/Jacqueline_Kennedy_Onassis\"}, {\"begin\": 762, \"end\": 767, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9939392151468075, \"rank\": 0.006097741955347399, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 785, \"end\": 789, \"title\": \"http://dbpedia.org/resource/Kyle_Broflovski\", \"score\": 0.9086273852114318, \"rank\": 0.09486240313851746, \"text\": \"Kyle\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Kyle_Broflovski\", \"dbpedia\": \"http://dbpedia.org/resource/Kyle_Broflovski\"}]}, {\"sentence\": \"\\\"'What do you mean, huge?\", \"from\": 858, \"to\": 883, \"entities\": []}, {\"sentence\": \"In what way?\\\"\", \"from\": 884, \"to\": 897, \"entities\": []}, {\"sentence\": \"Kyle said.\", \"from\": 898, \"to\": 908, \"entities\": [{\"begin\": 898, \"end\": 902, \"title\": \"http://dbpedia.org/resource/Kyle_Broflovski\", \"score\": 0.9086273852114318, \"rank\": 0.09486240313851746, \"text\": \"Kyle\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Kyle_Broflovski\", \"dbpedia\": \"http://dbpedia.org/resource/Kyle_Broflovski\"}]}, {\"sentence\": \"\\\"Like an embarrassment and a joke of the world?\", \"from\": 910, \"to\": 957, \"entities\": []}, {\"sentence\": \"Yeah.\", \"from\": 958, \"to\": 963, \"entities\": []}, {\"sentence\": \"It's embarrassing.\\\"\", \"from\": 964, \"to\": 983, \"entities\": []}, {\"sentence\": \"Kyle went on to reveal to listeners she was a university lecturer with a \\\"PhD in dance\\\".\", \"from\": 985, \"to\": 1073, \"entities\": []}, {\"sentence\": \"\\\"Which must not be too hard to get,\\\" Kyle said.\", \"from\": 1075, \"to\": 1122, \"entities\": [{\"begin\": 1112, \"end\": 1116, \"title\": \"http://dbpedia.org/resource/Kyle_Broflovski\", \"score\": 0.9086273852114318, \"rank\": 0.09486240313851746, \"text\": \"Kyle\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Kyle_Broflovski\", \"dbpedia\": \"http://dbpedia.org/resource/Kyle_Broflovski\"}]}, {\"sentence\": \"\\\"And listen, she threw a couple of weird moves out there trying to be unique.\", \"from\": 1124, \"to\": 1201, \"entities\": []}, {\"sentence\": \"Got zero points.\", \"from\": 1202, \"to\": 1218, \"entities\": []}, {\"sentence\": \"No one liked it.\", \"from\": 1219, \"to\": 1235, \"entities\": []}, {\"sentence\": \"It was embarrassing for her.\\\"\", \"from\": 1236, \"to\": 1265, \"entities\": []}, {\"sentence\": \"Gunn, 36, is a lecturer at Macquarie University's Department of Media and Communications where she received her bachelor in contemporary music and PhD in cultural studies, specialising in street dance, hip-hop and youth culture, politics of gender and ethnography.\", \"from\": 1267, \"to\": 1531, \"entities\": [{\"begin\": 1267, \"end\": 1271, \"title\": \"http://dbpedia.org/resource/Clan_Gunn\", \"score\": 0.999084703979317, \"rank\": 0.0007564311115278985, \"text\": \"Gunn\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Clan_Gunn\", \"dbpedia\": \"http://dbpedia.org/resource/Clan_Gunn\"}]}, {\"sentence\": \"Her PhD thesis was titled 'Deterritorializing Gender in Sydney's Breakdancing Scene: a B-girl's experience of B-boying'.\", \"from\": 1533, \"to\": 1653, \"entities\": [{\"begin\": 1589, \"end\": 1595, \"title\": \"http://dbpedia.org/resource/Sydney\", \"score\": 0.9999999218371189, \"rank\": 7.652819628556229e-08, \"text\": \"Sydney\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Sydney\", \"dbpedia\": \"http://dbpedia.org/resource/Sydney\"}]}, {\"sentence\": \"The thesis critically investigated how \\\"masculinist practices of breakdancing\\\" provided an environment to challenge gender norms.\", \"from\": 1655, \"to\": 1784, \"entities\": []}, {\"sentence\": \"\\\"Drawing on my own experiences as a female within the male-dominated breakdancing scene in Sydney, first as a spectator, then as an active crewmember, this thesis questions why so few female participants engage in this creative space, and how breakdancing might be a space to displace and deterritorialise gender,\\\" Dr Gunn wrote.\", \"from\": 1786, \"to\": 2115, \"entities\": [{\"begin\": 1877, \"end\": 1883, \"title\": \"http://dbpedia.org/resource/Sydney\", \"score\": 0.9999999218371189, \"rank\": 7.652819628556229e-08, \"text\": \"Sydney\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Sydney\", \"dbpedia\": \"http://dbpedia.org/resource/Sydney\"}, {\"begin\": 2104, \"end\": 2108, \"title\": \"http://dbpedia.org/resource/Clan_Gunn\", \"score\": 0.999084703979317, \"rank\": 0.0007564311115278985, \"text\": \"Gunn\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Clan_Gunn\", \"dbpedia\": \"http://dbpedia.org/resource/Clan_Gunn\"}]}, {\"sentence\": \"Kyle relayed to his listeners he watched The Project on Sunday night and saw \\\"another B-boy on there\\\" who defended Raygun.\", \"from\": 2117, \"to\": 2239, \"entities\": [{\"begin\": 2117, \"end\": 2121, \"title\": \"http://dbpedia.org/resource/Kyle_Broflovski\", \"score\": 0.9086273852114318, \"rank\": 0.09486240313851746, \"text\": \"Kyle\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Kyle_Broflovski\", \"dbpedia\": \"http://dbpedia.org/resource/Kyle_Broflovski\"}, {\"begin\": 2232, \"end\": 2238, \"title\": \"http://dbpedia.org/resource/Raygun\", \"score\": 1.0, \"rank\": 4.883347372197476e-19, \"text\": \"Raygun\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Raygun\", \"dbpedia\": \"http://dbpedia.org/resource/Raygun\"}]}, {\"sentence\": \"\\\"I do not know where they got this B-boy from, but he said he's seen her win and he's seen her lose and he would not comment,\\\" he said.\", \"from\": 2241, \"to\": 2376, \"entities\": []}, {\"sentence\": \"\\\"It was like a B-boy protection zone going on.\", \"from\": 2378, \"to\": 2424, \"entities\": []}, {\"sentence\": \"He would not diss her, which is fine.\\\"\", \"from\": 2425, \"to\": 2463, \"entities\": []}, {\"sentence\": \"Kyle was asked by KIIS newsreader Brooklyn Ross what he thought about Raygun's performance itself being an \\\"old breakdancer\\\" himself.\", \"from\": 2465, \"to\": 2598, \"entities\": [{\"begin\": 2465, \"end\": 2469, \"title\": \"http://dbpedia.org/resource/Kyle_Broflovski\", \"score\": 0.9086273852114318, \"rank\": 0.09486240313851746, \"text\": \"Kyle\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Kyle_Broflovski\", \"dbpedia\": \"http://dbpedia.org/resource/Kyle_Broflovski\"}, {\"begin\": 2499, \"end\": 2507, \"title\": \"http://dbpedia.org/resource/Brooklyn\", \"score\": 0.999999959832622, \"rank\": 3.97055024516637e-08, \"text\": \"Brooklyn\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Brooklyn\", \"dbpedia\": \"http://dbpedia.org/resource/Brooklyn\"}, {\"begin\": 2508, \"end\": 2512, \"title\": \"http://dbpedia.org/resource/Ross_Geller\", \"score\": 0.9999999996557563, \"rank\": 3.4422005943036035e-10, \"text\": \"Ross\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Ross_Geller\", \"dbpedia\": \"http://dbpedia.org/resource/Ross_Geller\"}, {\"begin\": 2535, \"end\": 2541, \"title\": \"http://dbpedia.org/resource/Raygun\", \"score\": 1.0, \"rank\": 4.883347372197476e-19, \"text\": \"Raygun\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Raygun\", \"dbpedia\": \"http://dbpedia.org/resource/Raygun\"}]}, {\"sentence\": \"\\\"I thought when I saw that, I could have represented Australia myself,\\\" Kyle said.\", \"from\": 2600, \"to\": 2682, \"entities\": [{\"begin\": 2653, \"end\": 2662, \"title\": \"http://dbpedia.org/resource/Australia\", \"score\": 0.9999930560495691, \"rank\": 5.027738824779568e-06, \"text\": \"Australia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Australia\", \"dbpedia\": \"http://dbpedia.org/resource/Australia\"}, {\"begin\": 2672, \"end\": 2676, \"title\": \"http://dbpedia.org/resource/Kyle_Broflovski\", \"score\": 0.9086273852114318, \"rank\": 0.09486240313851746, \"text\": \"Kyle\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Kyle_Broflovski\", \"dbpedia\": \"http://dbpedia.org/resource/Kyle_Broflovski\"}]}, {\"sentence\": \"To join the conversation, pleaselog in.Do not have an account?Register  Join the conversation, you are commenting asLogout  Our Apps\", \"from\": 2684, \"to\": 2816, \"entities\": []}]}"