"{\"uid\": \"standard.co.uk-sport-sport-olympics-olympics-2024-team-gb-mens-four-rowing-bronze-medal-b1174195.html\", \"entities\": [{\"sentence\": \"To use the search feature, we need your consent to load Google Custom Search, which may use cookies or similar technologies.\", \"from\": 0, \"to\": 124, \"entities\": [{\"begin\": 56, \"end\": 76, \"title\": \"http://dbpedia.org/resource/Google_Programmable_Search_Engine\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Google Custom Search\", \"types\": [\"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Google_Programmable_Search_Engine\", \"dbpedia\": \"http://dbpedia.org/resource/Google_Programmable_Search_Engine\"}]}, {\"sentence\": \"Please click 'Allow and Continue' below to enable search.\", \"from\": 125, \"to\": 182, \"entities\": []}, {\"sentence\": \"See our privacy policy for more information.\", \"from\": 183, \"to\": 227, \"entities\": []}, {\"sentence\": \"Sport|Olympics  Team GBwon bronze in the men's four at theParis Olympics.\", \"from\": 229, \"to\": 302, \"entities\": []}, {\"sentence\": \"The quartet of Oli Wilkes, David Ambler, Matt Aldridge and Freddie Davidson got off to a poor start but produced a patient race, coming right through most of the field.\", \"from\": 304, \"to\": 472, \"entities\": [{\"begin\": 323, \"end\": 329, \"title\": \"http://dbpedia.org/resource/John_Wilkes\", \"score\": 0.9991592588387216, \"rank\": 0.0008414005158212425, \"text\": \"Wilkes\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/John_Wilkes\", \"dbpedia\": \"http://dbpedia.org/resource/John_Wilkes\"}, {\"begin\": 331, \"end\": 343, \"title\": \"http://dbpedia.org/resource/David_Ambler\", \"score\": 0.9999435957730194, \"rank\": 0.0, \"text\": \"David Ambler\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/David_Ambler\", \"dbpedia\": \"http://dbpedia.org/resource/David_Ambler\"}, {\"begin\": 350, \"end\": 358, \"title\": \"http://dbpedia.org/resource/