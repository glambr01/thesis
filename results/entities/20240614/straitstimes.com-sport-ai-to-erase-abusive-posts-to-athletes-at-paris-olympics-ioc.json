dbpedia.org/resource/Hamas\", \"score\": 0.9999999951028258, \"rank\": 4.8972237152829056e-09, \"text\": \"Hamas\", \"types\": [\"Q7278\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Hamas\", \"dbpedia\": \"http://dbpedia.org/resource/Hamas\"}, {\"begin\": 655, \"end\": 661, \"title\": \"http://dbpedia.org/resource/Israel\", \"score\": 0.9999999995363851, \"rank\": 2.9965196080197853e-10, \"text\": \"Israel\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Israel\", \"dbpedia\": \"http://dbpedia.org/resource/Israel\"}, {\"begin\": 665, \"end\": 669, \"title\": \"http://dbpedia.org/resource/Gaza_Strip\", \"score\": 0.5860781935683065, \"rank\": 0.7062569653131159, \"text\": \"Gaza\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Gaza_Strip\", \"dbpedia\": \"http://dbpedia.org/resource/Gaza_Strip\"}]}, {\"sentence\": \"The Olympics kick off on July 26 with more than 10,500 athletes competing across 32 sports, and is expected to generate more than half a billion social media engagements during the 16 days of the event, according to the IOC.\", \"from\": 737, \"to\": 961, \"entities\": [{\"begin\": 957, \"end\": 960, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 9.767351313544932e-20, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}]}, {\"sentence\": \"\\\"The IOC will use AI at Paris in different areas,\\\" Bach told a press conference.\", \"from\": 963, \"to\": 1043, \"entities\": [{\"begin\": 968, \"end\": 971, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 9.767351313544932e-20, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 981, \"end\": 983, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 0.999999498286696, \"rank\": 5.015386964323953e-07, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}, {\"begin\": 987, \"end\": 992, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999159579183, \"rank\": 8.404218314930645e-08, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 1014, \"end\": 1018, \"title\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"score\": 0.9999999985786872, \"rank\": 1.421266867240922e-09, \"text\": \"Bach\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"dbpedia\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\"}]}, {\"sentence\": \"\\\"One is safeguarding, since we expect half a billion social media posts during these Games.\", \"from\": 1045, \"to\": 1136, \"entities\": []}, {\"sentence\": \"If someone were to take only one second to read each post it would take them 16 years to go through,\\\" he said.\", \"from\": 1137, \"to\": 1247, \"entities\": []}, {\"sentence\": \"\\\"The IOC will instead provide a pro-active AI safeguarding tool to protect athletes from cyberabuse.\", \"from\": 1249, \"to\": 1349, \"entities\": [{\"begin\": 1254, \"end\": 1257, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 9.767351313544932e-20, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 1292, \"end\": 1294, \"title\": \"http:/