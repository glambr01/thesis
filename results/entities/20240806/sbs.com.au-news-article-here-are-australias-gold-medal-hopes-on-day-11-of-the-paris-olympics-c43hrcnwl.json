"entities\": [{\"begin\": 996, \"end\": 998, \"title\": \"http://dbpedia.org/resource/Eastern_Wu\", \"score\": 0.5821012387743564, \"rank\": 0.48297917661219697, \"text\": \"Wu\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Eastern_Wu\", \"dbpedia\": \"http://dbpedia.org/resource/Eastern_Wu\"}, {\"begin\": 1022, \"end\": 1027, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.99989462626646, \"rank\": 0.00010538483215779526, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}]}, {\"sentence\": \"Cole will aim to better her sixth-place semi-final finish.\", \"from\": 1097, \"to\": 1155, \"entities\": []}, {\"sentence\": \"The platform final is scheduled for 11pm AEST.\", \"from\": 1157, \"to\": 1203, \"entities\": []}, {\"sentence\": \"Australian Kurtis Mathews is also set to make his Olympic debut when the men's 3m springboard competition starts at 6pm AEST.\", \"from\": 1205, \"to\": 1330, \"entities\": [{\"begin\": 1205, \"end\": 1215, \"title\": \"http://dbpedia.org/resource/Australians\", \"score\": 0.9999999736146495, \"rank\": 2.638519751364913e-08, \"text\": \"Australian\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Australians\", \"dbpedia\": \"http://dbpedia.org/resource/Australians\"}]}, {\"sentence\": \"At just 14 years old, Australian skateboarder Arisa Trew will be looking to make her first podium, with some of her stiffest competition coming from 15-year-old teammate Ruby Trew (no relation) in the women's park competition at Le Concorde.\", \"from\": 1332, \"to\": 1573, \"entities\": [{\"begin\": 1354, \"end\": 1364, \"title\": \"http://dbpedia.org/resource/Australians\", \"score\": 0.9999999736146495, \"rank\": 2.638519751364913e-08, \"text\": \"Australian\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Australians\", \"dbpedia\": \"http://dbpedia.org/resource/Australia