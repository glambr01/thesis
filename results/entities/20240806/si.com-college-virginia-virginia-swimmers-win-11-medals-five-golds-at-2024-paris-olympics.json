"{\"uid\": \"si.com-college-virginia-virginia-swimmers-win-11-medals-five-golds-at-2024-paris-olympics\", \"entities\": [{\"sentence\": \"The swimming competition at the 2024 Paris Olympic Games came to an end on Sunday and the Virginia swimming program put on a show, with current or former UVA swimmers winning a combined 11 medals, including five gold medals, for Team USA.\", \"from\": 0, \"to\": 238, \"entities\": [{\"begin\": 90, \"end\": 98, \"title\": \"http://dbpedia.org/resource/Virginia_Cavaliers_men's_basketball\", \"score\": 0.9855518598532035, \"rank\": 0.008956376717488815, \"text\": \"Virginia\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Virginia_Cavaliers_men's_basketball\", \"dbpedia\": \"http://dbpedia.org/resource/Virginia_Cavaliers_men's_basketball\"}, {\"begin\": 154, \"end\": 157, \"title\": \"http://dbpedia.org/resource/Virginia_Cavaliers_men's_basketball\", \"score\": 0.8685551703688126, \"rank\": 0.151292686526443, \"text\": \"UVA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Virginia_Cavaliers_men's_basketball\", \"dbpedia\": \"http://dbpedia.org/resource/Virginia_Cavaliers_men's_basketball\"}, {\"begin\": 229, \"end\": 237, \"title\": \"http://dbpedia.org/resource/United_States_national_team\", \"score\": 0.9136440514912074, \"rank\": 0.09451811535912369, \"text\": \"Team USA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_national_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_national_team\"}]}, {\"sentence\": \"Kate Douglass and Gretchen Walsh, who have combined to win each of the last three CSCAA Women's Swimmer of the Year Awards and 23 NCAA event titles, both leave Paris with two gold medals and two silvers, while Paige Madden won a silver and a bronze and Emma Weber won a gold medal.\", \"from\": 239, \"to\": 520, \"entities\": [{\"begin\": 239, \"end\": 252, \"title\": \"http://dbpedia.org/resource/Kate_Douglass\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Kate Douglass\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Kate_Douglass\", \"dbpedia\": \"http://dbpedia.org/resource/Kate_Douglass\"}, {\"begin\": 257, \"end\": 271, \"title\": \"http://dbpedia.org/resource/Gretchen_Walsh\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Gretchen Walsh\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Gretchen_Walsh\", \"dbpedia\": \"http://dbpedia.org/resource/Gretchen_Walsh\"}, {\"begin\": 369, \"end\": 373, \"title\": \"http://dbpedia.org/resource/NCAA_Division_I_men's_swimming_and_diving_championships\", \"score\": 0.9999996186180214, \"rank\": 3.813821102119134e-07, \"text\": \"NCAA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NCAA_Division_I_men's_swimming_and_diving_championships\", \"dbpedia\": \"http://dbpedia.org/resource/NCAA_Division_I_men's_swimming_and_diving_championships\"}, {\"begin\": 399, \"end\": 404, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999629944802, \"rank\": 3.7005636484315635e-08, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 449, \"end\": 461, \"title\": \"http://dbpedia.org/resource/Paige_Madden\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Paige Madden\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Paige_Madden\", \"dbpedia\": \"http://dbpedia.org/resource/Paige_Madden\"}, {\"begin\": 492, \"end\": 496, \"title\": \"http://dbpedia.org/resource/Tenille_Dashwood\", \"score\": 0.9998723578029746, \"rank\": 9.238376572593803e-05, \"text\": \"Emma\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q13474373\"], \"wikid\": \"http://dbpedia.org/resource/Tenille_Dashwood\", \"dbpedia\": \"http://dbpedia.org/resource/Tenille_Dashwood\"}, {\"begin\": 497, \"en