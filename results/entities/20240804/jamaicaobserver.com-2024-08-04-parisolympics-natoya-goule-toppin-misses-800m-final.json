"{\"uid\": \"jamaicaobserver.com-2024-08-04-parisolympics-natoya-goule-toppin-misses-800m-final\", \"entities\": [{\"sentence\": \"KINGSTON, Jamaica- Natoya Goule-Toppin just missed making it to back-to-back finals in the Olympic games after she faded late in her semi-finals of the women's 800m on Sunday at the Stade de France in Paris.\", \"from\": 0, \"to\": 207, \"entities\": [{\"begin\": 201, \"end\": 206, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999673569023498, \"rank\": 3.2644163220085296e-05, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"The many time Jamaican national champion and record holder, led most of the way but faded to sixth in 1:59.14 as World Champion Mary Moraa of Kenya won in 1:57.86 ahead of Ethiopia's Worknesh Mesele- 1:58.06 seconds and Cuba's Daily Cooper Gaspar- 1:58.39 seconds, the last two both running lifetime bests.\", \"from\": 209, \"to\": 515, \"entities\": [{\"begin\": 337, \"end\": 341, \"title\": \"http://dbpedia.org/resource/Mary_II_of_England\", \"score\": 0.5400522043867191, \"rank\": 0.6192608487736596, \"text\": \"Mary\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Mary_II_of_England\", \"dbpedia\": \"http://dbpedia.org/resource/Mary_II_of_England\"}, {\"begin\": 351, \"end\": 356, \"title\": \"http://dbpedia.org/resource/Kenya\", \"score\": 0.961488890055144, \"rank\": 0.0323556830447144, \"text\": \"Kenya\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Kenya\", \"dbpedia\": \"http://dbpedia.org/resource/Kenya\"}, {\"begin\": 381, \"end\": 389, \"title\": \"http://dbpedia.org/resource/Ethiopia\", \"score\": 0.942044985598322, \"rank\": 0.061519207204881785, \"text\": \"Ethiopia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ethiopia\", \"dbpedia\": \"http://dbpedia.org/resource/Ethiopia\"}, {\"begin\": 429, \"end\": 433, \"title\": \"http://dbpedia.org/resource/Cuba_national_football_team\", \"score\": 0.9880566410226883, \"rank\": 0.01013137573311312, \"text\": \"Cuba\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Cuba_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Cuba_national_football_team\"}]}, {\"sentence\": \"Goule-Toppin, who had won her first round heat in 1:58.66 seconds on Friday, finished 18th\\u00a0overall.\", \"from\": 517, \"to\": 616, \"entities\": []}, {\"sentence\": \"St Vincent's Shafiqua Maloney ran a national record 1:57.59 seconds and booked a spot in her first major global final.\", \"from\": 618, \"to\": 736, \"entities\": [{\"begin\": 618, \"end\": 628, \"title\": \"http://dbpedia.org/resource/Saint_Vincent_and_the_Grenadines\", \"score\": 0.9999781255522132, \"rank\": 2.187492555353595e-05, \"text\": \"St Vincent\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Saint_Vincent_and_the_Grenadines\", \"dbpedia\": \"http://dbpedia.org/resource/Saint_Vincent_and_the_Grenadines\"}, {\"begin\": 631, \"end\": 647, \"title\": \"http://dbpedia.org/resource/Shafiqua_Maloney\", \"score\": 0.9999999999131433, \"rank\": 0.0, \"text\": \"Shafiqua Maloney\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Shafiqua_Maloney\", \"dbpedia\": \"http://dbpedia.org/resource/Shafiqua_Maloney\"}]}, {\"sentence\": \"-Paul A Reid  Tags:  HOUSE RULES\", \"from\": 738, \"to\": 770, \"entities\": []}]}"