"{\"uid\": \"dailyexcelsior.com-chiara-leone-wins-womens-50-meter-rifle-3-positions-shooting-for-1st-swiss-gold-at-paris-olympics\", \"entities\": [{\"sentence\": \"CHATEAUROUX (FRANCE), Aug 2: Chiara Leone has earned Switzerland's first gold medal at the Paris Olympics, winning women's 50-meter rifle three positions shooting on Friday.\", \"from\": 0, \"to\": 173, \"entities\": [{\"begin\": 29, \"end\": 35, \"title\": \"http://dbpedia.org/resource/Chiara_Siracusa\", \"score\": 0.937791572199919, \"rank\": 0.06325812154540228, \"text\": \"Chiara\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Chiara_Siracusa\", \"dbpedia\": \"http://dbpedia.org/resource/Chiara_Siracusa\"}, {\"begin\": 53, \"end\": 64, \"title\": \"http://dbpedia.org/resource/Switzerland\", \"score\": 0.9586554528283378, \"rank\": 0.03944408780322523, \"text\": \"Switzerland\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Switzerland\", \"dbpedia\": \"http://dbpedia.org/resource/Switzerland\"}]}, {\"sentence\": \"Leone narrowly edged Sagen Maddalena of the United States by 1.4 points in the final.\", \"from\": 175, \"to\": 260, \"entities\": [{\"begin\": 196, \"end\": 211, \"title\": \"http://dbpedia.org/resource/Sagen_Maddalena\", \"score\": 0.99999989668982, \"rank\": 0.0, \"text\": \"Sagen Maddalena\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Sagen_Maddalena\", \"dbpedia\": \"http://dbpedia.org/resource/Sagen_Maddalena\"}, {\"begin\": 219, \"end\": 232, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 0.9837029519106041, \"rank\": 0.016261845018843847, \"text\": \"United States\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\"}]}, {\"sentence\": \"China's Zhang Qiongyue was third for bronze in the event that involved shooting while kneeling, prone and standing.\", \"from\": 261, \"to\": 376, \"entities\": [{\"begin\": 261, \"end\": 266, \"title\": \"http://dbpedia.org/resource/China_women's_national_football_team\", \"score\": 0.987753531622374, \"rank\": 0.007905875092192989, \"text\": \"China\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/China_women's_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/China_women's_national_football_team\"}]}, {\"sentence\": \"\\\"I knew I could win,\\\" Leone said.\", \"from\": 378, \"to\": 411, \"entities\": []}, {\"sentence\": \"\\\"I wanted a medal.\", \"from\": 412, \"to\": 430, \"entities\": []}, {\"sentence\": \"I wanted a piece of the Eiffel Tower in my hands, and winning is just - I can not describe how I feel.\\\"\", \"from\": 431, \"to\": 534, \"entities\": []}, {\"sentence\": \"Maddalena's silver is the first US shooting medal on the seventh day of competition, ending what was tied with 1988 for the country's longest drought in the sport at a single Olympics.\", \"from\": 536, \"to\": 720, \"entities\": [{\"begin\": 568, \"end\": 570, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 0.9974286398599176, \"rank\": 0.0025677053203089694, \"text\": \"US\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\"}]}, {\"sentence\": \"\\\"I made a couple of mistakes,\\\" said Maddalena, who set a qualifying round Olympic record on Thursday.\", \"from\": 722, \"to\": 823, \"entities\": []}, {\"sentence\": \"\\\"We are all amazing shooters, but it is the pressure in finals that makes it hard to get the mind right.\", \"from\": 824, \"to\": 928, \"entities\": []}, {\"sentence\": \"I am going to take this, learn from it, keep working on my headspace and enjoy the ride.\\\"\", \"from\": 929, \"to\": 1018, \"entities\": []}, {\"sentence\": \"Leone, 26, shot a 464.4 to break the Olympic record of 463.9 set by fellow Swiss shooter Nina Christen at the Tokyo Games three years ago.\", \"from\": 1020, \"to\": 1158, \"entities\": [{\"begin\": 1095, \"end\": 1100, \"title\": \"http://dbpedia.org/resource/Switzerland\", \"score\": 0.9893435796928575, \"rank\": 0.010770523834572863, \"text\": \"Swiss\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Switzerland\", \"dbpedia\": \"http://dbpedia.org/resource/Switzerland\"}]}, {\"sentence\": \"She said she was also inspired by countrywoman Audrey Gogniat winning bronze in women's 10-meter air rifle earlier in the week.\", \"from\": 1160, \"to\": 1287, \"entities\": [{\"begin\": 1207, \"end\": 1213, \"title\": \"http://dbpedia.org/resource/Audrey_Horne\", \"score\": 0.8377083158474825, \"rank\": 0.19371272986963542, \"text\": \"Audrey\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Audrey_Horne\", \"dbpedia\": \"http://dbpedia.org/resource/Audrey_Horne\"}]}, {\"sentence\": \"Now, they can celebrate together.\", \"from\": 1288, \"to\": 1321, \"entities\": []}, {\"sentence\": \"\\\"We will have a big party,\\\" Leone said.\", \"from\": 1323, \"to\": 1362, \"entities\": []}, {\"sentence\": \"\\\"I do not know when or where, but we will celebrate.\\\"\", \"from\": 1363, \"to\": 1416, \"entities\": []}, {\"sentence\": \"(AP)    As a subscriber, you will have full access to all of our Newsletters and News Bulletins.\", \"from\": 1417, \"to\": 1513, \"entities\": [{\"begin\": 1418, \"end\": 1420, \"title\": \"http://dbpedia.org/resource/Associated_Press\", \"score\": 0.998094209102023, \"rank\": 0.0018824881515177787, \"text\": \"AP\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Associated_Press\", \"dbpedia\": \"http://dbpedia.org/resource/Associated_Press\"}]}, {\