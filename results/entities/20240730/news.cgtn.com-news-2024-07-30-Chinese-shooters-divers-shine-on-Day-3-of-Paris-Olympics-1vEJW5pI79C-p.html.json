 []}, {\"sentence\": \"Diving  Lian Junjie and Yang Hao triumphed in the men's synchronized 10m platform to gift China the second diving gold and the fourth overall at Paris 2024, scoring 490.35 points.\", \"from\": 1382, \"to\": 1561, \"entities\": [{\"begin\": 1390, \"end\": 1401, \"title\": \"http://dbpedia.org/resource/Lian_Junjie\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Lian Junjie\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Lian_Junjie\", \"dbpedia\": \"http://dbpedia.org/resource/Lian_Junjie\"}, {\"begin\": 1406, \"end\": 1414, \"title\": \"http://dbpedia.org/resource/Yang_Hao_(Sui_dynasty)\", \"score\": 0.5916864370256529, \"rank\": 0.40495867768596194, \"text\": \"Yang Hao\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Yang_Hao_(Sui_dynasty)\", \"dbpedia\": \"http://dbpedia.org/resource/Yang_Hao_(Sui_dynasty)\"}, {\"begin\": 1472, \"end\": 1477, \"title\": \"http://dbpedia.org/resource/China_national_football_team\", \"score\": 0.6076213841625421, \"rank\": 0.6453770483597346, \"text\": \"China\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/China_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/China_national_football_team\"}]}, {\"sentence\": \"Yang Hao (L) and Lian Junjie pose with gold medals of men's synchronized 10m platform at Paris Olympics in Paris, France, July 29, 2024.\", \"from\": 1563, \"to\": 1699, \"entities\": [{\"begin\": 1563, \"end\": 1571, \"title\": \"http://dbpedia.org/resource/Yang_Hao_(Sui_dynasty)\", \"score\": 0.5916864370256529, \"rank\": 0.40495867768596194, \"text\": \"Yang Hao\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Yang_Hao_(Sui_dynasty)\", \"dbpedia\": \"http://dbpedia.org/resource/Yang_Hao_(Sui_dynasty)\"}, {\"begin\": 1580, \"end\": 1591, \"title\": \"http://dbpedia.org/resource/Lian_Junjie\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Lian Junjie\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Lian_Junjie\", \"dbpedia\": \"http://dbpedia.org/resource/Lian_Junjie\"}, {\"begin\": 1670, \"end\": 1675, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999831743, \"rank\": 1.6916668689175997e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 1677, \"end\": 1683, \"title\": \"http://dbpedia.org/resource/France_national_football_team\", \"score\": 0.9979417287686881, \"rank\": 0.002062514671127416, \"text\": \"France\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/France_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/France_national_football_team\"}]}, {\"sentence\": \"/CFP  Nicknamed \\\"Dream Team\\\", the Chinese diving squad are en route of a golden sweep in Paris this time.\", \"from\": 1700, \"to\": 1805, \"entities\": [{\"begin\": 1734, \"end\": 1741, \"title\": \"http://dbpedia.org/resource/Chinese_language\", \"score\": 0.9628852263289228, \"rank\": 0.037042530848101884, \"text\": \"Chinese\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Chinese_language\", \"dbpedia\": \"http://dbpedia.org/resource/Chinese_language\"}, {\"begin\": 1789, \"end\": 1794, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999831743, \"rank\": 1.6916668689175997e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"Three years ago in Tokyo, they bagged seven of eight golds, missing out on the men's synchronized 10m platform, which was won by Britain's Tom Daley and Matty Lee.\", \"from\": 1806, \"to\": 1969, \"entities\": [{\"begin\": 1825, \"end\": 1830