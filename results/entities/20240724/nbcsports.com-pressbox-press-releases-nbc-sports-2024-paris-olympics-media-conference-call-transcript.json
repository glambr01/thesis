"{\"uid\": \"nbcsports.com-pressbox-press-releases-nbc-sports-2024-paris-olympics-media-conference-call-transcript\", \"entities\": [{\"sentence\": \"NBC SPORTS 2024 PARIS OLYMPICS MEDIA CONFERENCE CALL TRANSCRIPT  Wednesday, July 24, 2024  MODERATOR: Thank you.\", \"from\": 0, \"to\": 112, \"entities\": [{\"begin\": 0, \"end\": 10, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.998872658120767, \"rank\": 0.0006668537675577213, \"text\": \"NBC SPORTS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}]}, {\"sentence\": \"Depending upon where you are, good morning, good afternoon, and good evening, and thank you for joining us today.\", \"from\": 113, \"to\": 226, \"entities\": []}, {\"sentence\": \"In a moment, we will hear from our three speakers, NBC Olympics and Paralympics executive producer Molly Solomon, our prime time in Paris and daytime host Mike Tirico, and our prime-time correspondent, Snoop Dogg.\", \"from\": 227, \"to\": 440, \"entities\": [{\"begin\": 278, \"end\": 290, \"title\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"NBC Olympics\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\"}, {\"begin\": 326, \"end\": 331, \"title\": \"http://dbpedia.org/resource/Molly_Hayes\", \"score\": 0.9624638830284854, \"rank\": 0.03899894384530974, \"text\": \"Molly\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Molly_Hayes\", \"dbpedia\": \"http://dbpedia.org/resource/Molly_Hayes\"}, {\"begin\": 359, \"end\": 364, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999988891226426, \"rank\": 1.1108786120302873e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 382, \"end\": 393, \"title\": \"http://dbpedia.org/resource/Mike_Tirico\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Mike Tirico\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Mike_Tirico\", \"dbpedia\": \"http://dbpedia.org/resource/Mike_Tirico\"}, {\"begin\": 429, \"end\": 439, \"title\": \"http://dbpedia.org/resource/Snoop_Dogg\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Snoop Dogg\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Snoop_Dogg\", \"dbpedia\": \"http://dbpedia.org/resource/Snoop_Dogg\"}]}, {\"sentence\": \"Molly will make opening remarks, and then we will open it up for questions.\", \"from\": 442, \"to\": 517, \"entities\": []}, {\"sentence\": \"Now I will turn it over to Molly Solomon.\", \"from\": 518, \"to\": 559, \"entities\": [{\"begin\": 545, \"end\": 550, \"title\": \"http://dbpedia.org/resource/Molly_Hayes\", \"score\": 0.9624638830284854, \"rank\": 0.03899894384530974, \"text\": \"Molly\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Molly_Hayes\", \"dbpedia\": \"http://dbpedia.org/resource/Molly_Hayes\"}]}, {\"sentence\": \"MOLLY SOLOMON: Thanks, Chris.\", \"from\": 561, \"to\": 590, \"entities\": []}, {\"sentence\": \"Hello from Paris.\", \"from\": 591, \"to\": 608, \"entities\": [{\"begin\": 602, \"end\": 607, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999988891226426, \"rank\": 1.1108786120302873e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"After years of planning, it's just so amazing to think that the Opening Ceremony is just two days away and that the Olympic competition is actually already happening right now.\", \"from\": 609, \"to\": 785, \"entities\": [{\"begin\": 673, \"end\": 689, \"title\": \"http://dbpedia.org/resource/Olympic_Games_ceremony\", \"score\": 0.9685977326399653, \"rank\": 0.03201837747202212, \"text\": \"Opening Ceremony\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games_ceremony\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games_ceremony\"}]}, {\"sentence\": \"Mike Tirico, who is here with us, took us on the air two hours ago on USA Network and Peacock, and we welcomed viewers to really what promises to be one of the most spectacular Olympic Games ever, and we are here to showcase all of it for the American audience with more than 7,000 hours of coverage.\", \"from\": 787, \"to\": 1087, \"entities\": [{\"begin\": 787, \"end\": 798, \"title\": \"http://dbpedia.org/resource/Mike_Tirico\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Mike Tirico\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Mike_Tirico\", \"dbpedia\": \"http://dbpedia.org/resource/Mike_Tirico\"}, {\"begin\": 857, \"end\": 868, \"title\": \"http://dbpedia.org/resource/USA_Network\", \"score\": 0.55699160869125, \"rank\": 0.7953591825098848, \"text\": \"USA Network\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/USA_Network\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Network\"}, {\"begin\": 873, \"end\": 880, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.9997484822474999, \"rank\": 0.00025157946854395834, \"text\": \"Peacock\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Peafowl\", \"dbpedia\": \"http://dbpedia.org/resource/Peafowl\"}, {\"begin\": 1030, \"end\": 1038, \"title\": \"http://dbpedia.org/resource/Television_in_the_United_States\", \"score\": 0.9999831133492485, \"rank\": 1.6886267631110396e-05, \"text\": \"American\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Television_in_the_United_States\", \"dbpedia\": \"http://dbpedia.org/resource/Television_in_the_United_States\"}]}, {\"sentence\": \"As we have been saying for more than a year, all the best content will be live across the country on NBC in daytime, and we are re-imagining the prime-time show to provide the in-depth storytelling about the best events of the day, and Peacock has everything, all 329 medal events, plus replays and all the original programming we have been talking about and so much more.\", \"from\": 1089, \"to\": 1461, \"entities\": [{\"begin\": 1190, \"end\": 1193, \"title\": \"http://dbpedia.org/resource/NBC\", \"score\": 0.9986860936791093, \"rank\": 0.0012488547706709136, \"text\": \"NBC\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/NBC\", \"dbpedia\": \"http://dbpedia.org/resource/NBC\"}, {\"begin\": 1325, \"end\": 1332, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.9891517422902012, \"rank\": 0.010965650888292202, \"text\": \"Peacock\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Peafowl\", \"dbpedia\": \"http://dbpedia.org/resource/Peafowl\"}]}, {\"sentence\": \"As we have also said, we have taken a [very] different approach to these Games by bringing in some nontraditional voices with expert communicators to provide their perspective on Paris 2024: Kelly Clarkson and Peyton Manning on the Opening Ceremony, Jimmy Fallon on the closing, watch parties with podcaster Alex Cooper, and the most comprehensive whip-around show ever in Olympic history with \\\"Gold Zone\\\" anchored by Scott Hanson and company.\", \"from\": 1463, \"to\": 1906, \"entities\": [{\"begin\": 1642, \"end\": 1652, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 0.9999999737888178, \"rank\": 2.6211212906906176e-08, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 1654, \"end\": 1668, \"title\": \"http://dbpedia.org/resource/Kelly_Clarkson\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Kelly Clarkson\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kelly_Clarkson\", \"dbpedia\": \"http://dbpedia.org/resource/Kelly_Clarkson\"}, {\"begin\": 1673, \"end\": 1687, \"title\": \"http://dbpedia.org/resource/Peyton_Manning\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Peyton Manning\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q14128148\"], \"wikid\": \"http://dbpedia.org/resource/Peyton_Manning\", \"dbpedia\": \"http://dbpedia.org/resource/Peyton_Manning\"}, {\"begin\": 1695, \"end\": 1711, \"title\": \"http://dbpedia.org/resource/2012_Summer_Olympics_opening_ceremony\", \"score\": 0.5363274997917826, \"rank\": 0.7206469299639048, \"text\": \"Opening Ceremony\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/2012_Summer_Olympics_opening_ceremony\", \"dbpedia\": \"http://dbpedia.org/resource/2012_Summer_Olympics_opening_ceremony\"}, {\"begin\": 1713, \"end\": 1725, \"title\": \"http://dbpedia.org/resource/Jimmy_Fallon\", \"score\": 0.9999797023591548, \"rank\": 2.0298052841172042e-05, \"text\": \"Jimmy Fallon\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jimmy_Fallon\", \"dbpedia\": \"http://dbpedia.org/resource/Jimmy_Fallon\"}, {\"begin\": 1771, \"end\": 1782, \"title\": \"http://dbpedia.org/resource/Alex_Cooper_(footballer)\", \"score\": 0.8607573575017976, \"rank\": 0.16176470588235564, \"text\": \"Alex Cooper\", \"types\": [\"Q937857\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Alex_Cooper_(footballer)\", \"dbpedia\": \"http://dbpedia.org/resource/Alex_Cooper_(footballer)\"}, {\"begin\": 1881, \"end\": 1893, \"title\": \"http://dbpedia.org/resource/Scott_Hanson\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Scott Hanson\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Scott_Hanson\", \"dbpedia\": \"http://dbpedia.org/resource/Scott_Hanson\"}]}, {\"sentence\": \"And on Peacock we are also going to have all of these contributors, plus Leslie Jones is going to be joining us for social coverage, and she's coming the second week of the Games to bring it on home.\", \"from\": 1908, \"to\": 2107, \"entities\": [{\"begin\": 1981, \"end\": 1993, \"title\": \"http://dbpedia.org/resource/Leslie_Ronald_Jones\", \"score\": 0.9959779475579327, \"rank\": 0.003978011815429592, \"text\": \"Leslie Jones\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Leslie_Ronald_Jones\", \"dbpedia\": \"http://dbpedia.org/resource/Leslie_Ronald_Jones\"}]}, {\"sentence\": \"Also, of course, joining us in prime time is a man who needs no introduction, Snoop Dogg.\", \"from\": 2109, \"to\": 2198, \"entities\": [{\"begin\": 2187, \"end\": 2197, \"title\": \"http://dbpedia.org/resource/Snoop_Dogg\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Snoop Dogg\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Snoop_Dogg\", \"dbpedia\": \"http://dbpedia.org/resource/Snoop_Dogg\"}]}, {\"sentence\": \"His general love of the Olympics and respect for the athletes has been shining bright for months, and now here in the host city, I can not wait for you to hear about his experiences so far in Paris.\", \"from\": 2199, \"to\": 2397, \"entities\": [{\"begin\": 2391, \"end\": 2396, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9998505024932408, \"rank\": 0.00014951985791875552, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"We know that viewers can not wait to see his daily adventures here in Paris.\", \"from\": 2398, \"to\": 2474, \"entities\": [{\"begin\": 2468, \"end\": 2473, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9998505024932408, \"rank\": 0.00014951985791875552, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"That's enough from me.\", \"from\": 2476, \"to\": 2498, \"entities\": []}, {\"sentence\": \"I think you want to hear from two other guys, Mike Tirico and Snoop Dogg.\", \"from\": 2499, \"to\": 2572, \"entities\": [{\"begin\": 2545, \"end\": 2556, \"title\": \"http://dbpedia.org/resource/Mike_Tirico\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Mike Tirico\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Mike_Tirico\", \"dbpedia\": \"http://dbpedia.org/resource/Mike_Tirico\"}, {\"begin\": 2561, \"end\": 2571, \"title\": \"http://dbpedia.org/resource/Snoop_Dogg\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Snoop Dogg\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Snoop_Dogg\", \"dbpedia\": \"http://dbpedia.org/resource/Snoop_Dogg\"}]}, {\"sentence\": \"So let us get started with your questions.\", \"from\": 2573, \"to\": 2615, \"entities\": []}, {\"sentence\": \"Q.Molly, we will start with you.\", \"from\": 2617, \"to\": 2649, \"entities\": []}, {\"sentence\": \"Two years ago at the Winter Olympic Games, you made the call to have all the play-by-play and the color commentary people not go to Beijing because of issues with the Chinese government, other things too, and do it from the NBC Sports studios in Stamford, Connecticut.\", \"from\": 2650, \"to\": 2918, \"entities\": [{\"begin\": 2782, \"end\": 2789, \"title\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"score\": 0.8053076835413298, \"rank\": 0.2417436840072371, \"text\": \"Beijing\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2008_Summer_Olympics\"}, {\"begin\": 2817, \"end\": 2835, \"title\": \"http://dbpedia.org/resource/Government_of_China\", \"score\": 0.9990267332091131, \"rank\": 0.0004939331374312455, \"text\": \"Chinese government\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Government_of_China\", \"dbpedia\": \"http://dbpedia.org/resource/Government_of_China\"}, {\"begin\": 2874, \"end\": 2884, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.9988005125095527, \"rank\": 0.0010865859931874077, \"text\": \"NBC Sports\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}, {\"begin\": 2896, \"end\": 2917, \"title\": \"http://dbpedia.org/resource/Stamford,_Connecticut\", \"score\": 0.9999999999998863, \"rank\": 0.0, \"text\": \"Stamford, Connecticut\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Stamford,_Connecticut\", \"dbpedia\": \"http://dbpedia.org/resource/Stamford,_Connecticut\"}, {\"begin\": 2896, \"end\": 2917, \"title\": \"http://dbpedia.org/resource/Stamford,_Connecticut\", \"score\": 0.9999999999998863, \"rank\": 0.0, \"text\": \"Stamford, Connecticut\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Stamford,_Connecticut\", \"dbpedia\": \"http://dbpedia.org/resource/Stamford,_Connecticut\"}]}, {\"sentence\": \"It looks like the majority of play-by-play people and color commentary people are doing the same thing again.\", \"from\": 2919, \"to\": 3028, \"entities\": []}, {\"sentence\": \"There are some play-by-play people that will be in Paris the entire time, for gymnastics, for swimming and so forth.\", \"from\": 3029, \"to\": 3145, \"entities\": [{\"begin\": 3080, \"end\": 3085, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9998505024932408, \"rank\": 0.00014951985791875552, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"Why that?\", \"from\": 3146, \"to\": 3155, \"entities\": []}, {\"sentence\": \"Why this move?\", \"from\": 3156, \"to\": 3170, \"entities\": []}, {\"sentence\": \"Given the fact the pandemic is over, it must be easier to go to Paris rather than Beijing, why that determination?\", \"from\": 3171, \"to\": 3285, \"entities\": [{\"begin\": 3235, \"end\": 3240, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9998505024932408, \"rank\": 0.00014951985791875552, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 3253, \"end\": 3260, \"title\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"score\": 0.8053076835413298, \"rank\": 0.2417436840072371, \"text\": \"Beijing\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2008_Summer_Olympics\"}]}, {\"sentence\": \"MOLLY SOLOMON: Actually, our mix is the same as it was in Rio way back in 2016.\", \"from\": 3287, \"to\": 3366, \"entities\": []}, {\"sentence\": \"You are right that COVID prevented us from sending a lot of our commentators to Beijing, but we are back with so many of the popular sports.\", \"from\": 3367, \"to\": 3507, \"entities\": [{\"begin\": 3447, \"end\": 3454, \"title\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"score\": 0.9738858620482451, \"rank\": 0.02679346872344413, \"text\": \"Beijing\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2008_Summer_Olympics\"}]}, {\"sentence\": \"We have got play-by-play and analysts here.\", \"from\": 3508, \"to\": 3551, \"entities\": []}, {\"sentence\": \"We have nearly 70 commentators and announcers on the ground, plus we have reporters able to go to any sport and cover any sport that happens.\", \"from\": 3552, \"to\": 3693, \"entities\": []}, {\"sentence\": \"So we are really excited about everybody we have got here.\", \"from\": 3695, \"to\": 3753, \"entities\": []}, {\"sentence\": \"It's, like I said, almost 100 announcers on the ground here in Paris.\", \"from\": 3754, \"to\": 3823, \"entities\": [{\"begin\": 3817, \"end\": 3822, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999133070264388, \"rank\": 8.670048825343275e-05, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"Q.Another one for Molly.\", \"from\": 3825, \"to\": 3849, \"entities\": [{\"begin\": 3843, \"end\": 3848, \"title\": \"http://dbpedia.org/resource/Molly_Hayes\", \"score\": 0.9716734576316229, \"rank\": 0.029152287682213444, \"text\": \"Molly\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Molly_Hayes\", \"dbpedia\": \"http://dbpedia.org/resource/Molly_Hayes\"}]}, {\"sentence\": \"Molly, you took this role in November of 2019, and we obviously know what happened after that with COVID and delayed games and higher security around games.\", \"from\": 3850, \"to\": 4006, \"entities\": []}, {\"sentence\": \"How much more has this experience felt like maybe what you thought this job might feel like when you first took it back in 2019?\", \"from\": 4007, \"to\": 4135, \"entities\": []}, {\"sentence\": \"MOLLY SOLOMON: I could not be more excited about Paris, and what I love about working on the Olympics is every time you start to begin on a new city and a new four-year cycle, it's a blank slate.\", \"from\": 4137, \"to\": 4332, \"entities\": [{\"begin\": 4186, \"end\": 4191, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999133070264388, \"rank\": 8.670048825343275e-05, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"So when we realized we had Paris 2024, the first thing we thought about, how can we take advantage of the time zone and show all the most popular sports live on NBC in the daytime?\", \"from\": 4334, \"to\": 4514, \"entities\": [{\"begin\": 4361, \"end\": 4371, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 0.9999999992502353, \"rank\": 7.497761578628941e-10, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 4495, \"end\": 4498, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.5316971308152941, \"rank\": 0.6304089131928028, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}]}, {\"sentence\": \"And you see that on our coverage on NBC and Peacock.\", \"from\": 4516, \"to\": 4568, \"entities\": [{\"begin\": 4552, \"end\": 4555, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.5316971308152941, \"rank\": 0.6304089131928028, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}, {\"begin\": 4560, \"end\": 4567, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.9910435488636691, \"rank\": 0.009037213219163624, \"text\": \"Peacock\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Peafowl\", \"dbpedia\": \"http://dbpedia.org/resource/Peafowl\"}]}, {\"sentence\": \"We will start right out with the \\\"Today\\\" show at 9:00 and go all the way to 6:00 Eastern with live sports across the board.\", \"from\": 4569, \"to\": 4692, \"entities\": []}, {\"sentence\": \"Then, of course, there is Paris.\", \"from\": 4694, \"to\": 4726, \"entities\": [{\"begin\": 4720, \"end\": 4725, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999982448342039, \"rank\": 1.7551965508022133e-05, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"I think you are really going to see Paris interwoven in everything we do.\", \"from\": 4727, \"to\": 4800, \"entities\": [{\"begin\": 4763, \"end\": 4768, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999982448342039, \"rank\": 1.7551965508022133e-05, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"You harken back to some Games of old, and what I remember, particularly in Beijing, London, I could go all the way back to Barcelona when I started, and the host city was always the co-star.\", \"from\": 4801, \"to\": 4991, \"entities\": [{\"begin\": 4876, \"end\": 4883, \"title\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"score\": 0.8491893485429064, \"rank\": 0.17754631579452015, \"text\": \"Beijing\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2008_Summer_Olympics\"}, {\"begin\": 4885, \"end\": 4891, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.998840235994232, \"rank\": 0.00045664104965826484, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}, {\"begin\": 4924, \"end\": 4933, \"title\": \"http://dbpedia.org/resource/Barcelona\", \"score\": 0.9642980502811818, \"rank\": 0.03619467487235594, \"text\": \"Barcelona\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Barcelona\", \"dbpedia\": \"http://dbpedia.org/resource/Barcelona\"}]}, {\"sentence\": \"That's where we are elevating Paris, back to that point, and we just can not wait.\", \"from\": 4992, \"to\": 5074, \"entities\": [{\"begin\": 5022, \"end\": 5027, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999982448342039, \"rank\": 1.7551965508022133e-05, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"This job is everything I hoped for in 2019, and I just can not wait for the audience to experience what NBC Olympics has planned.\", \"from\": 5076, \"to\": 5205, \"entities\": [{\"begin\": 5180, \"end\": 5192, \"title\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"NBC Olympics\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\"}]}, {\"sentence\": \"Q.Hi, I do not mean to ignore the others, but I had a question for Molly as well.\", \"from\": 5207, \"to\": 5288, \"entities\": []}, {\"sentence\": \"You talked a bit about how you are going to differentiate the prime-time broadcast from the daytime live showings throughout by making a more produced situation in storytelling.\", \"from\": 5289, \"to\": 5466, \"entities\": []}, {\"sentence\": \"What's the situation going to be for the Opening Ceremonies?\", \"from\": 5467, \"to\": 5527, \"entities\": []}, {\"sentence\": \"Are you going to do just a strict run of the Opening Ceremony?\", \"from\": 5528, \"to\": 5590, \"entities\": [{\"begin\": 5573, \"end\": 5589, \"title\": \"http://dbpedia.org/resource/Olympic_Games_ceremony\", \"score\": 0.5550859234480507, \"rank\": 0.46172037682776396, \"text\": \"Opening Ceremony\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games_ceremony\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games_ceremony\"}]}, {\"sentence\": \"Are you concerned that not as many people would want to watch it in the evening because it's been on in the afternoon?\", \"from\": 5591, \"to\": 5709, \"entities\": []}, {\"sentence\": \"MOLLY SOLOMON: We love what we have done showing the live ceremony in the afternoon, and if you are a huge fan of the Olympics [who's] available in the afternoon, it's going to be there for you live.\", \"from\": 5711, \"to\": 5910, \"entities\": []}, {\"sentence\": \"But a lot of people are on vacation, they are at work during the day, they do not have access to be able to watch it.\", \"from\": 5911, \"to\": 6028, \"entities\": []}, {\"sentence\": \"So of course we are going to package it again in prime time.\", \"from\": 6029, \"to\": 6089, \"entities\": []}, {\"sentence\": \"When you are live, this is a movable feat.\", \"from\": 6091, \"to\": 6133, \"entities\": []}, {\"sentence\": \"The parade is continuing live on the air.\", \"from\": 6134, \"to\": 6175, \"entities\": []}, {\"sentence\": \"It's really hard to include some elements -- for example, we are going to have Maria Taylor on the U.S. boat, so we will be able to include even more of her interviews with the U.S.\", \"from\": 6176, \"to\": 6357, \"entities\": [{\"begin\": 6255, \"end\": 6267, \"title\": \"http://dbpedia.org/resource/Maria_Jane_Taylor\", \"score\": 0.6622027282637533, \"rank\": 0.5080338153161872, \"text\": \"Maria Taylor\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Maria_Jane_Taylor\", \"dbpedia\": \"http://dbpedia.org/resource/Maria_Jane_Taylor\"}]}, {\"sentence\": \"Team.\", \"from\": 6358, \"to\": 6363, \"entities\": []}, {\"sentence\": \"We have got some special storytelling planned, but I can not give away those surprises.\", \"from\": 6365, \"to\": 6452, \"entities\": []}, {\"sentence\": \"So, yes, I would say that the prime-time presentation is going to be enhanced.\", \"from\": 6453, \"to\": 6531, \"entities\": []}, {\"sentence\": \"I'd watch it twice.\", \"from\": 6532, \"to\": 6551, \"entities\": []}, {\"sentence\": \"Q.My question is for Snoop.\", \"from\": 6553, \"to\": 6580, \"entities\": []}, {\"sentence\": \"Snoop, let us say there was an Olympic event for rapping.\", \"from\": 6581, \"to\": 6638, \"entities\": []}, {\"sentence\": \"Who would be four American rappers you'd take with you to represent the U.S. for the Olympic Games?\", \"from\": 6639, \"to\": 6738, \"entities\": [{\"begin\": 6657, \"end\": 6665, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9986973213791418, \"rank\": 0.0009049170857437347, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}]}, {\"sentence\": \"And that could be from any era.\", \"from\": 6739, \"to\": 6770, \"entities\": []}, {\"sentence\": \"SNOOP DOGG: That's a great question.\", \"from\": 6772, \"to\": 6808, \"entities\": []}, {\"sentence\": \"This is rap Olympics you are talking about, right?\", \"from\": 6809, \"to\": 6859, \"entities\": []}, {\"sentence\": \"Q.Yes.\", \"from\": 6861, \"to\": 6867, \"entities\": []}, {\"sentence\": \"SNOOP DOGG: I definitely would take Eminem.\", \"from\": 6869, \"to\": 6912, \"entities\": [{\"begin\": 6905, \"end\": 6911, \"title\": \"http://dbpedia.org/resource/Eminem\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Eminem\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Eminem\", \"dbpedia\": \"http://dbpedia.org/resource/Eminem\"}]}, {\"sentence\": \"Got to have that global experience.\", \"from\": 6913, \"to\": 6948, \"entities\": []}, {\"sentence\": \"Then I definitely would take Rakim from the old school.\", \"from\": 6949, \"to\": 7004, \"entities\": [{\"begin\": 6978, \"end\": 6983, \"title\": \"http://dbpedia.org/resource/Rakim\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Rakim\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Rakim\", \"dbpedia\": \"http://dbpedia.org/resource/Rakim\"}]}, {\"sentence\": \"Then I would go grab a female, I would grab Queen Latifah because that's where I have got some loyalty.\", \"from\": 7005, \"to\": 7108, \"entities\": [{\"begin\": 7049, \"end\": 7062, \"title\": \"http://dbpedia.org/resource/Queen_Latifah\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Queen Latifah\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Queen_Latifah\", \"dbpedia\": \"http://dbpedia.org/resource/Queen_Latifah\"}]}, {\"sentence\": \"And naturally I have got to take Snoop Dogg.\", \"from\": 7109, \"to\": 7153, \"entities\": [{\"begin\": 7142, \"end\": 7152, \"title\": \"http://dbpedia.org/resource/Snoop_Dogg\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Snoop Dogg\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Snoop_Dogg\", \"dbpedia\": \"http://dbpedia.org/resource/Snoop_Dogg\"}]}, {\"sentence\": \"Come on, man, what are we talking about?\", \"from\": 7154, \"to\": 7194, \"entities\": []}, {\"sentence\": \"What do you mean, dream team?\", \"from\": 7195, \"to\": 7224, \"entities\": []}, {\"sentence\": \"Let us go.\", \"from\": 7225, \"to\": 7235, \"entities\": []}, {\"sentence\": \"Q.Question for Snoop.\", \"from\": 7237, \"to\": 7258, \"entities\": []}, {\"sentence\": \"Some people who do not know you are probably surprised to see you covering sports and covering the Olympics.\", \"from\": 7259, \"to\": 7367, \"entities\": []}, {\"sentence\": \"Have you done anything to train for this?\", \"from\": 7368, \"to\": 7409, \"entities\": []}, {\"sentence\": \"Have you talked to anyone who's done it before to get some tips?\", \"from\": 7410, \"to\": 7474, \"entities\": []}, {\"sentence\": \"Tell me about your preparation for prime time.\", \"from\": 7475, \"to\": 7521, \"entities\": []}, {\"sentence\": \"SNOOP DOGG: My preparation for prime time is being me.\", \"from\": 7523, \"to\": 7577, \"entities\": []}, {\"sentence\": \"Google me.\", \"from\": 7578, \"to\": 7588, \"entities\": []}, {\"sentence\": \"Look me up, dog.\", \"from\": 7589, \"to\": 7605, \"entities\": []}, {\"sentence\": \"I have done fighting a bit.\", \"from\": 7606, \"to\": 7633, \"entities\": []}, {\"sentence\": \"I have done sporting events.\", \"from\": 7634, \"to\": 7662, \"entities\": []}, {\"sentence\": \"This is what I do.\", \"from\": 7663, \"to\": 7681, \"entities\": []}, {\"sentence\": \"I have been doing this since you all have been goldfish.\", \"from\": 7682, \"to\": 7738, \"entities\": []}, {\"sentence\": \"What they are going to find out is I know the sport, I know the angle, I know the conversations.\", \"from\": 7739, \"to\": 7835, \"entities\": []}, {\"sentence\": \"Tune in so you can be a part of it.\", \"from\": 7836, \"to\": 7871, \"entities\": []}, {\"sentence\": \"MOLLY SOLOMON: I have got to jump in.\", \"from\": 7873, \"to\": 7910, \"entities\": []}, {\"sentence\": \"Snoop got here ten days before the Opening Ceremonies, and I have seen his schedule.\", \"from\": 7911, \"to\": 7995, \"entities\": []}, {\"sentence\": \"He's been at the team performance center, meeting athletes, creating deep relationships.\", \"from\": 7996, \"to\": 8084, \"entities\": []}, {\"sentence\": \"So next week he will be able to communicate with all of them, be on the ground with them.\", \"from\": 8085, \"to\": 8174, \"entities\": []}, {\"sentence\": \"But you have got to tell them what you have been working on.\", \"from\": 8176, \"to\": 8236, \"entities\": []}, {\"sentence\": \"SNOOP DOGG: Just so you know, I have been sliding into the practice facilities with different teams, whether it was judo, weightlifting, 3-on-3 basketball, fencing.\", \"from\": 8238, \"to\": 8402, \"entities\": []}, {\"sentence\": \"I am one of those individuals that likes to get involved.\", \"from\": 8403, \"to\": 8460, \"entities\": []}, {\"sentence\": \"Not only do I communicate and talk with them, I may try the event.\", \"from\": 8461, \"to\": 8527, \"entities\": []}, {\"sentence\": \"[I am] learning the backstory of these athletes and their families, and then learning the backstory of some of these events -- these sporting events I have no clue about -- but [I am] learning and loving them at the same time.\", \"from\": 8529, \"to\": 8755, \"entities\": []}, {\"sentence\": \"It's going to be a great experience because the way I speak it, you tend to want to pay attention to it because it's going to be something different, and it's going to be a little bit more insightful because I have spent time with these athletes and some of their family members as well.\", \"from\": 8757, \"to\": 9044, \"entities\": []}, {\"sentence\": \"Q.My question is for Snoop Dogg.\", \"from\": 9046, \"to\": 9078, \"entities\": [{\"begin\": 9067, \"end\": 9077, \"title\": \"http://dbpedia.org/resource/Snoop_Dogg\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Snoop Dogg\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Snoop_Dogg\", \"dbpedia\": \"http://dbpedia.org/resource/Snoop_Dogg\"}]}, {\"sentence\": \"I was wondering how hip-hop now got into the Games because there has not been any [presence] for lots of years, I think.\", \"from\": 9079, \"to\": 9199, \"entities\": []}, {\"sentence\": \"And now we have you, Snoop, carrying the Olympic torch, MC Solaar carrying the Olympic torch, Flavor Flav pushing the U.S. water polo team.\", \"from\": 9200, \"to\": 9339, \"entities\": [{\"begin\": 9256, \"end\": 9265, \"title\": \"http://dbpedia.org/resource/MC_Solaar\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"MC Solaar\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/MC_Solaar\", \"dbpedia\": \"http://dbpedia.org/resource/MC_Solaar\"}, {\"begin\": 9294, \"end\": 9305, \"title\": \"http://dbpedia.org/resource/Flavor_Flav\", \"score\": 1.0, \"rank\": 2.5863161995221115e-24, \"text\": \"Flavor Flav\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Flavor_Flav\", \"dbpedia\": \"http://dbpedia.org/resource/Flavor_Flav\"}]}, {\"sentence\": \"What's your opinion on that?\", \"from\": 9340, \"to\": 9368, \"entities\": []}, {\"sentence\": \"Why has it become so big in hip-hop?\", \"from\": 9369, \"to\": 9405, \"entities\": []}, {\"sentence\": \"Have you been in contact with Flavor Flav?\", \"from\": 9406, \"to\": 9448, \"entities\": [{\"begin\": 9436, \"end\": 9447, \"title\": \"http://dbpedia.org/resource/Flavor_Flav\", \"score\": 1.0, \"rank\": 3.483872211667327e-24, \"text\": \"Flavor Flav\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Flavor_Flav\", \"dbpedia\": \"http://dbpedia.org/resource/Flavor_Flav\"}]}, {\"sentence\": \"Will you give him a call or something?\", \"from\": 9449, \"to\": 9487, \"entities\": []}, {\"sentence\": \"Is there anything planned?\", \"from\": 9488, \"to\": 9514, \"entities\": []}, {\"sentence\": \"SNOOP DOGG: Just so you know, entertainment and sports go hand for hand.\", \"from\": 9516, \"to\": 9588, \"entities\": []}, {\"sentence\": \"So a lot of times, a lot of these entertainers dream of being athletes, and a lot of those athletes dream of being entertainers.\", \"from\": 9589, \"to\": 9717, \"entities\": []}, {\"sentence\": \"So when we come together, we hang out, we chill, we enjoy each other's company.\", \"from\": 9718, \"to\": 9797, \"entities\": []}, {\"sentence\": \"When it comes to hip-hop in the Olympics, I believe that hip-hop has always been a part of the Olympics.\", \"from\": 9799, \"to\": 9903, \"entities\": []}, {\"sentence\": \"It's just now being recognized because it's global.\", \"from\": 9904, \"to\": 9955, \"entities\": []}, {\"sentence\": \"Breakdancing is in the Olympics this year, and it's on a global scale because breakdancing is one of the first elements of hip-hop.\", \"from\": 9956, \"to\": 10087, \"entities\": []}, {\"sentence\": \"So hip-hop and the Olympics have always had a great relationship.\", \"from\": 10089, \"to\": 10154, \"entities\": []}, {\"sentence\": \"Now is the time because the world that we are living in now, a lot of the people that are in the top positions in their country were raised off hip-hop.\", \"from\": 10155, \"to\": 10307, \"entities\": []}, {\"sentence\": \"So hip-hop is a part of their life, so it makes sense for it to be connected to the Olympics.\", \"from\": 10308, \"to\": 10401, \"entities\": []}, {\"sentence\": \"And what's cooler than hip-hop in the Olympics?\", \"from\": 10403, \"to\": 10450, \"entities\": []}, {\"sentence\": \"I mean, it is what it is.\", \"from\": 10451, \"to\": 10476, \"entities\": []}, {\"sentence\": \"It's peanut butter and jelly, you know what I am talking about?\", \"from\": 10477, \"to\": 10540, \"entities\": []}, {\"sentence\": \"Over here it's coffee and biscuits.\", \"from\": 10541, \"to\": 10576, \"entities\": []}, {\"sentence\": \"That's what that is.\", \"from\": 10577, \"to\": 10597, \"entities\": []}, {\"sentence\": \"It's a great mix.\", \"from\": 10598, \"to\": 10615, \"entities\": []}, {\"sentence\": \"Q.And what about Flavor Flav?\", \"from\": 10617, \"to\": 10646, \"entities\": [{\"begin\": 10634, \"end\": 10645, \"title\": \"http://dbpedia.org/resource/Flavor_Flav\", \"score\": 1.0, \"rank\": 4.0365318897972006e-25, \"text\": \"Flavor Flav\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Flavor_Flav\", \"dbpedia\": \"http://dbpedia.org/resource/Flavor_Flav\"}]}, {\"sentence\": \"SNOOP DOGG: Flavor Flav, that's my homeboy.\", \"from\": 10648, \"to\": 10691, \"entities\": []}, {\"sentence\": \"We have got a spot together in Vegas.\", \"from\": 10692, \"to\": 10729, \"entities\": []}, {\"sentence\": \"We stayed two blocks from each other.\", \"from\": 10730, \"to\": 10767, \"entities\": []}, {\"sentence\": \"He's with the water polo team, he's handling that, making sure they are underwater and boogying.\", \"from\": 10768, \"to\": 10864, \"entities\": []}, {\"sentence\": \"I am handling the track and field and other events.\", \"from\": 10865, \"to\": 10916, \"entities\": []}, {\"sentence\": \"What we are going to do is spread ourselves around so we are making sure that every athlete in every section of the Olympics has attention, and we want to pay attention to everybody.\", \"from\": 10918, \"to\": 11100, \"entities\": []}, {\"sentence\": \"We do not want to leave nobody behind.\", \"from\": 11101, \"to\": 11139, \"entities\": []}, {\"sentence\": \"So while he's over there doing that, I might be over there with volleyball, with weightlifting.\", \"from\": 11141, \"to\": 11236, \"entities\": []}, {\"sentence\": \"We want to make sure we are touching all the athletes and their families because this is a hell of an experience for people who have been waiting for four years to get here.\", \"from\": 11237, \"to\": 11410, \"entities\": []}, {\"sentence\": \"So it's more about them than about us.\", \"from\": 11411, \"to\": 11449, \"entities\": []}, {\"sentence\": \"We are just here to cover.\", \"from\": 11450, \"to\": 11476, \"entities\": []}, {\"sentence\": \"Q.My question is for Snoop Dogg.\", \"from\": 11478, \"to\": 11510, \"entities\": [{\"begin\": 11499, \"end\": 11509, \"title\": \"http://dbpedia.org/resource/Snoop_Dogg\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Snoop Dogg\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Snoop_Dogg\", \"dbpedia\": \"http://dbpedia.org/resource/Snoop_Dogg\"}]}, {\"sentence\": \"I know you just said that Flavor Flav is over covering water polo.\", \"from\": 11511, \"to\": 11577, \"entities\": [{\"begin\": 11537, \"end\": 11548, \"title\": \"http://dbpedia.org/resource/Flavor_Flav\", \"score\": 1.0, \"rank\": 1.9644653861574492e-23, \"text\": \"Flavor Flav\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Flavor_Flav\", \"dbpedia\": \"http://dbpedia.org/resource/Flavor_Flav\"}]}, {\"sentence\": \"I was curious if you or him would be going over to hang out with the swimmers and if you guys might be getting in the pool.\", \"from\": 11578, \"to\": 11701, \"entities\": []}, {\"sentence\": \"Just curious about that.\", \"from\": 11702, \"to\": 11726, \"entities\": []}, {\"sentence\": \"SNOOP DOGG: I am supposed to get a visit from one of my friends, you know him as Aquaman, but some of them call him Michael Phelps.\", \"from\": 11728, \"to\": 11859, \"entities\": [{\"begin\": 11809, \"end\": 11816, \"title\": \"http://dbpedia.org/resource/Aquaman\", \"score\": 0.9999999999949978, \"rank\": 4.140207631555613e-12, \"text\": \"Aquaman\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Aquaman\", \"dbpedia\": \"http://dbpedia.org/resource/Aquaman\"}, {\"begin\": 11844, \"end\": 11858, \"title\": \"http://dbpedia.org/resource/Michael_Phelps\", \"score\": 1.0, \"rank\": 7.449315553467345e-20, \"text\": \"Michael Phelps\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Michael_Phelps\", \"dbpedia\": \"http://dbpedia.org/resource/Michael_Phelps\"}]}, {\"sentence\": \"Me and Michael Phelps have a session we may do where I may jump in the pool and learn how to do the 25 meters, something to that effect.\", \"from\": 11860, \"to\": 11996, \"entities\": [{\"begin\": 11867, \"end\": 11881, \"title\": \"http://dbpedia.org/resource/Michael_Phelps\", \"score\": 1.0, \"rank\": 7.449315553467345e-20, \"text\": \"Michael Phelps\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Michael_Phelps\", \"dbpedia\": \"http://dbpedia.org/resource/Michael_Phelps\"}]}, {\"sentence\": \"Like I said, I am an athlete.\", \"from\": 11998, \"to\": 12027, \"entities\": []}, {\"sentence\": \"One thing about me, when I am around these Olympians, I feel like I am just as good as them or might give it a chance.\", \"from\": 12028, \"to\": 12146, \"entities\": []}, {\"sentence\": \"So I will be trying it.\", \"from\": 12147, \"to\": 12170, \"entities\": []}, {\"sentence\": \"MOLLY SOLOMON: As you know, the USA-Australia rivalry is one of the fiercest of the Games.\", \"from\": 12172, \"to\": 12262, \"entities\": []}, {\"sentence\": \"We can not wait to see what happens night one of swimming, and I would not be surprised if we saw Snoop out there.\", \"from\": 12263, \"to\": 12377, \"entities\": []}, {\"sentence\": \"SNOOP DOGG: And me and Russell Crowe got a little wager.\", \"from\": 12379, \"to\": 12435, \"entities\": [{\"begin\": 12402, \"end\": 12415, \"title\": \"http://dbpedia.org/resource/Russell_Crowe\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Russell Crowe\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Russell_Crowe\", \"dbpedia\": \"http://dbpedia.org/resource/Russell_Crowe\"}]}, {\"sentence\": \"USA all day, baby.\", \"from\": 12436, \"to\": 12454, \"entities\": []}, {\"sentence\": \"Q.This is for Mike.\", \"from\": 12456, \"to\": 12475, \"entities\": []}, {\"sentence\": \"Snoop's going to jump in the pool, he's been playing some 3-on-3.\", \"from\": 12476, \"to\": 12541, \"entities\": []}, {\"sentence\": \"Any chance you are getting out there and showing your skills with some of the Olympic sports?\", \"from\": 12542, \"to\": 12635, \"entities\": []}, {\"sentence\": \"SNOOP DOGG: Come on, Mike.\", \"from\": 12637, \"to\": 12663, \"entities\": []}, {\"sentence\": \"MIKE TIRICO: I am inspired by a lot of things Snoop does.\", \"from\": 12665, \"to\": 12722, \"entities\": []}, {\"sentence\": \"At 57, I am not inspired by trying to be an athlete again.\", \"from\": 12723, \"to\": 12781, \"entities\": []}, {\"sentence\": \"Better leave that all to Snoop.\", \"from\": 12782, \"to\": 12813, \"entities\": []}, {\"sentence\": \"In all seriousness, spending time around Snoop at the track and field trials and in the buildup to this, it's so genuine and so real, which is what he is, and I think viewers are going to see just a different side of the athletes, the sports, and the places he goes to.\", \"from\": 12815, \"to\": 13084, \"entities\": []}, {\"sentence\": \"If you think about bringing the world together, that's what the Olympics are about, the opportunity to see things through a different light, through a different set of glasses.\", \"from\": 13086, \"to\": 13262, \"entities\": []}, {\"sentence\": \"Snoop brings dedication and passion to everything he does and world-class execution, and I think you are going to see that through this process.\", \"from\": 13264, \"to\": 13408, \"entities\": []}, {\"sentence\": \"I can not tell you how excited all of us are and how energized we have been from having Snoop around our group as we have prepared and arrived here in Paris.\", \"from\": 13409, \"to\": 13566, \"entities\": [{\"begin\": 13560, \"end\": 13565, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999886553978323, \"rank\": 1.134473080409074e-05, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"It's going to be a great time, and we are just happy to have him.\", \"from\": 13568, \"to\": 13633, \"entities\": []}, {\"sentence\": \"I am going to leave everything athletic to him.\", \"from\": 13634, \"to\": 13681, \"entities\": []}, {\"sentence\": \"Q.Just wondering, Mike, relative to U.S. men's basketball, they beat South Sudan by a point.\", \"from\": 13683, \"to\": 13775, \"entities\": [{\"begin\": 13719, \"end\": 13723, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.998783670172909, \"rank\": 0.001017665517802567, \"text\": \"U.S.\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}]}, {\"sentence\": \"They struggled also against Germany.\", \"from\": 13776, \"to\": 13812, \"entities\": [{\"begin\": 13804, \"end\": 13811, \"title\": \"http://dbpedia.org/resource/Nazi_Germany\", \"score\": 0.6189168644066299, \"rank\": 0.24537003378809014, \"text\": \"Germany\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Nazi_Germany\", \"dbpedia\": \"http://dbpedia.org/resource/Nazi_Germany\"}]}, {\"sentence\": \"Are we going to see more attention brought to that team?\", \"from\": 13813, \"to\": 13869, \"entities\": []}, {\"sentence\": \"I think the idea was that they are going to cruise, just as the women may.\", \"from\": 13870, \"to\": 13944, \"entities\": []}, {\"sentence\": \"So, expectations for higher viewing on basketball given the results of the exhibition tour?\", \"from\": 13945, \"to\": 14036, \"entities\": []}, {\"sentence\": \"MIKE TIRICO: Well, I think you start with the name value of the players, and I would gather that you are probably never going to see in a significant tournament setting LeBron, Steph, Kevin Durant, Tatum, et cetera, on the same team.\", \"from\": 14038, \"to\": 14271, \"entities\": [{\"begin\": 14215, \"end\": 14220, \"title\": \"http://dbpedia.org/resource/Steph_Stokes\", \"score\": 0.9541085613713979, \"rank\": 0.0480626396997049, \"text\": \"Steph\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Steph_Stokes\", \"dbpedia\": \"http://dbpedia.org/resource/Steph_Stokes\"}, {\"begin\": 14228, \"end\": 14234, \"title\": \"http://dbpedia.org/resource/Kevin_Durant\", \"score\": 0.9999993795431343, \"rank\": 6.204017780089075e-07, \"text\": \"Durant\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kevin_Durant\", \"dbpedia\": \"http://dbpedia.org/resource/Kevin_Durant\"}, {\"begin\": 14236, \"end\": 14241, \"title\": \"http://dbpedia.org/resource/Art_Tatum\", \"score\": 0.9275612653982138, \"rank\": 0.07769379145200335, \"text\": \"Tatum\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Art_Tatum\", \"dbpedia\": \"http://dbpedia.org/resource/Art_Tatum\"}]}, {\"sentence\": \"So I think just the presence, especially of those veteran guys, heighten the awareness coming into this Olympic cycle.\", \"from\": 14272, \"to\": 14390, \"entities\": []}, {\"sentence\": \"Those exhibition games opened everyone's eyes to what the basketball world knows and has been saying for years, that the gap between the U.S. and the rest of the world is smaller, from Don\\u010di\\u0107 not here, but Joki\\u0107, Shai Gilgeous-Alexander.\", \"from\": 14392, \"to\": 14629, \"entities\": []}, {\"sentence\": \"International stars are some of the best players in the NBA.\", \"from\": 14630, \"to\": 14690, \"entities\": [{\"begin\": 14686, \"end\": 14689, \"title\": \"http://dbpedia.org/resource/National_Basketball_Association\", \"score\": 0.9999998847864684, \"rank\": 1.1518568603317184e-07, \"text\": \"NBA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/National_Basketball_Association\", \"dbpedia\": \"http://dbpedia.org/resource/National_Basketball_Association\"}]}, {\"sentence\": \"It's no surprise now that those teams have gotten deeper and better.\", \"from\": 14691, \"to\": 14759, \"entities\": []}, {\"sentence\": \"Maybe South Sudan was a wake-up call to this group, which has happened in prior exhibition runs up to Olympic Games, but it also might be eye opening to the rest of the world that the USA is not this undefeated behemoth that it was from the Dream Team days.\", \"from\": 14761, \"to\": 15018, \"entities\": [{\"begin\": 14945, \"end\": 14948, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9973744505155435, \"rank\": 0.0014903679090688007, \"text\": \"USA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 15002, \"end\": 15012, \"title\": \"http://dbpedia.org/resource/1992_United_States_men's_Olympic_basketball_team\", \"score\": 0.608712729241028, \"rank\": 0.6428110524931874, \"text\": \"Dream Team\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/1992_United_States_men's_Olympic_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/1992_United_States_men's_Olympic_basketball_team\"}]}, {\"sentence\": \"SNOOP DOGG: Remember when the Dream Team was formed, in those days of the Olympics, there was probably two players from across the water that were in the NBA.\", \"from\": 15020, \"to\": 15178, \"entities\": [{\"begin\": 15050, \"end\": 15060, \"title\": \"http://dbpedia.org/resource/1992_United_States_men's_Olympic_basketball_team\", \"score\": 0.608712729241028, \"rank\": 0.6428110524931874, \"text\": \"Dream Team\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/1992_United_States_men's_Olympic_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/1992_United_States_men's_Olympic_basketball_team\"}, {\"begin\": 15174, \"end\": 15177, \"title\": \"http://dbpedia.org/resource/National_Basketball_Association\", \"score\": 0.9999998847864684, \"rank\": 1.1518568603317184e-07, \"text\": \"NBA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/National_Basketball_Association\", \"dbpedia\": \"http://dbpedia.org/resource/National_Basketball_Association\"}]}, {\"sentence\": \"Now there is 40-something players in the NBA as we speak.\", \"from\": 15179, \"to\": 15236, \"entities\": [{\"begin\": 15220, \"end\": 15223, \"title\": \"http://dbpedia.org/resource/National_Basketball_Association\", \"score\": 0.9999998847864684, \"rank\": 1.1518568603317184e-07, \"text\": \"NBA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/National_Basketball_Association\", \"dbpedia\": \"http://dbpedia.org/resource/National_Basketball_Association\"}]}, {\"sentence\": \"So what that means is there is more competition coming from over the water, there is more players that are All-Stars that are from different countries.\", \"from\": 15237, \"to\": 15388, \"entities\": []}, {\"sentence\": \"When you get three or four of them on one team, then you can have the access of actually knocking off an American team because you have got All-Stars on your team.\", \"from\": 15389, \"to\": 15552, \"entities\": [{\"begin\": 15494, \"end\": 15502, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9277322229627972, \"rank\": 0.07529053862745758, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}]}, {\"sentence\": \"So the surface has changed as far as global approach with NBA basketball.\", \"from\": 15554, \"to\": 15627, \"entities\": [{\"begin\": 15612, \"end\": 15615, \"title\": \"http://dbpedia.org/resource/National_Basketball_Association\", \"score\": 0.9999997469995243, \"rank\": 2.525795566159807e-07, \"text\": \"NBA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/National_Basketball_Association\", \"dbpedia\": \"http://dbpedia.org/resource/National_Basketball_Association\"}]}, {\"sentence\": \"There is so many superstars that are not from America that, when you put them against America, it's sort of even because there is talent everywhere now.\", \"from\": 15628, \"to\": 15780, \"entities\": []}, {\"sentence\": \"MIKE TIRICO: You are right, and we are lucky in America because the best league in a lot of those major sports is in our backyard, and the aspirational part -- that's why the Dream Team is one of the great teams in the history of any sport because not only were they terrific and dominant, they also helped open the door for the globalization of the NBA.\", \"from\": 15782, \"to\": 16136, \"entities\": [{\"begin\": 15957, \"end\": 15967, \"title\": \"http://dbpedia.org/resource/1992_United_States_men's_Olympic_basketball_team\", \"score\": 0.9997830796655206, \"rank\": 0.00021696708440872408, \"text\": \"Dream Team\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/1992_United_States_men's_Olympic_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/1992_United_States_men's_Olympic_basketball_team\"}, {\"begin\": 16132, \"end\": 16135, \"title\": \"http://dbpedia.org/resource/National_Basketball_Association\", \"score\": 0.9999997469995243, \"rank\": 2.525795566159807e-07, \"text\": \"NBA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/National_Basketball_Association\", \"dbpedia\": \"http://dbpedia.org/resource/National_Basketball_Association\"}]}, {\"sentence\": \"And the late commissioner David Stern and current commissioner Adam Silver have helped follow those international ties.\", \"from\": 16138, \"to\": 16257, \"entities\": [{\"begin\": 16164, \"end\": 16175, \"title\": \"http://dbpedia.org/resource/David_Stern\", \"score\": 1.0, \"rank\": 5.633819139713647e-20, \"text\": \"David Stern\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/David_Stern\", \"dbpedia\": \"http://dbpedia.org/resource/David_Stern\"}, {\"begin\": 16201, \"end\": 16212, \"title\": \"http://dbpedia.org/resource/Adam_Silver\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Adam Silver\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Adam_Silver\", \"dbpedia\": \"http://dbpedia.org/resource/Adam_Silver\"}]}, {\"sentence\": \"Like Snoop said, every team has an international player on their roster.\", \"from\": 16258, \"to\": 16330, \"entities\": []}, {\"sentence\": \"Most of them are significant contributors.\", \"from\": 16331, \"to\": 16373, \"entities\": []}, {\"sentence\": \"You look at the Canadian roster, they are very good.\", \"from\": 16374, \"to\": 16426, \"entities\": [{\"begin\": 16390, \"end\": 16405, \"title\": \"http://dbpedia.org/resource/Canada_men's_national_ice_hockey_team\", \"score\": 0.9999994949222494, \"rank\": 5.025342831401853e-07, \"text\": \"Canadian roster\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Canada_men's_national_ice_hockey_team\", \"dbpedia\": \"http://dbpedia.org/resource/Canada_men's_national_ice_hockey_team\"}]}, {\"sentence\": \"To your point, I am sure basketball will tell its own story in terms of ratings and everyone watching, but no guaranteed big victory part of this is something that will keep everyone watching when Team USA plays in men's basketball.\", \"from\": 16428, \"to\": 16660, \"entities\": [{\"begin\": 16625, \"end\": 16633, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 0.6056732451816427, \"rank\": 0.581056905764099, \"text\": \"Team USA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\"}]}, {\"sentence\": \"SNOOP DOGG: One thing about a gold medal, you have got to earn it.\", \"from\": 16662, \"to\": 16728, \"entities\": []}, {\"sentence\": \"They do not give you those.\", \"from\": 16729, \"to\": 16756, \"entities\": []}, {\"sentence\": \"I tried to get one, they would not give it to me.\", \"from\": 16757, \"to\": 16806, \"entities\": []}, {\"sentence\": \"Q.This question is for Snoop.\", \"from\": 16808, \"to\": 16837, \"entities\": []}, {\"sentence\": \"I might be asking something that might have been asked already, but I was wondering, I spoke with you a few months ago before your junket for Underdog, and I remember I asked you about representation for the Olympics.\", \"from\": 16838, \"to\": 17055, \"entities\": [{\"begin\": 16980, \"end\": 16988, \"title\": \"http://dbpedia.org/resource/Underdog\", \"score\": 0.9999999999999432, \"rank\": 6.466261891518248e-14, \"text\": \"Underdog\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Underdog\", \"dbpedia\": \"http://dbpedia.org/resource/Underdog\"}]}, {\"sentence\": \"I am wondering, with you being the torch bearer, what does that mean for you when it comes to representation, and what does it mean for you to really -- to be out there in the forefront for the United States and being the face for it?\", \"from\": 17056, \"to\": 17290, \"entities\": [{\"begin\": 17250, \"end\": 17263, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9294358135116323, \"rank\": 0.04613169720941283, \"text\": \"United States\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}]}, {\"sentence\": \"SNOOP DOGG: First of all, what's crackalackin'?\", \"from\": 17292, \"to\": 17339, \"entities\": []}, {\"sentence\": \"It says a whole lot about America, man, about as far as where we are at in this world, like what do we want to present?\", \"from\": 17340, \"to\": 17459, \"entities\": []}, {\"sentence\": \"And then at the same time, it says a lot about France as far as connecting the dots and allowing me to do it.\", \"from\": 17460, \"to\": 17569, \"entities\": [{\"begin\": 17507, \"end\": 17513, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.99898215658343, \"rank\": 0.00042398101690056773, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}]}, {\"sentence\": \"So I look at this as a prestigious honor and something that I truly respect.\", \"from\": 17571, \"to\": 17647, \"entities\": []}, {\"sentence\": \"I would have never dreamed of nothing like this.\", \"from\": 17648, \"to\": 17696, \"entities\": []}, {\"sentence\": \"I am going to be on my best behavior.\", \"from\": 17697, \"to\": 17734, \"entities\": []}, {\"sentence\": \"I am going to be on my best athleticism.\", \"from\": 17735, \"to\": 17775, \"entities\": []}, {\"sentence\": \"I will be able to breathe slow to walk fast and hold the torch with a smile on my face because I realize how prestigious this event is.\", \"from\": 17776, \"to\": 17911, \"entities\": []}, {\"sentence\": \"I was thinking about Muhammad Ali, when Muhammad Ali was holding it, that was just -- it was emotional for all of us to see that, to see the champ holding that torch and walking it up there.\", \"from\": 17913, \"to\": 18103, \"entities\": [{\"begin\": 17934, \"end\": 17946, \"title\": \"http://dbpedia.org/resource/Muhammad_Ali\", \"score\": 0.999892685785656, \"rank\": 0.00010585674547084683, \"text\": \"Muhammad Ali\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Muhammad_Ali\", \"dbpedia\": \"http://dbpedia.org/resource/Muhammad_Ali\"}, {\"begin\": 17953, \"end\": 17965, \"title\": \"http://dbpedia.org/resource/Muhammad_Ali\", \"score\": 0.999892685785656, \"rank\": 0.00010585674547084683, \"text\": \"Muhammad Ali\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Muhammad_Ali\", \"dbpedia\": \"http://dbpedia.org/resource/Muhammad_Ali\"}]}, {\"sentence\": \"That's what this feels like to me, you know, my own version of it.\", \"from\": 18104, \"to\": 18170, \"entities\": []}, {\"sentence\": \"I do not want to get too emotional, but I know that this is special, and I really appreciate it.\", \"from\": 18172, \"to\": 18268, \"entities\": []}, {\"sentence\": \"I am going to show you why they made me the man to do it.\", \"from\": 18269, \"to\": 18326, \"entities\": []}, {\"sentence\": \"I am going to put all of the resources and all of the energy around it with love, peace, and harmony because that's what the Olympics is about.\", \"from\": 18327, \"to\": 18470, \"entities\": []}, {\"sentence\": \"I feel like that's why they chose me because that's what I represent: Peace, love, and unity.\", \"from\": 18471, \"to\": 18564, \"entities\": []}, {\"sentence\": \"Thank you, brother.\", \"from\": 18566, \"to\": 18585, \"entities\": []}, {\"sentence\": \"I will have to pay you later for calling in.\", \"from\": 18586, \"to\": 18630, \"entities\": []}, {\"sentence\": \"I appreciate it.\", \"from\": 18631, \"to\": 18647, \"entities\": []}, {\"sentence\": \"(Laughter.)\", \"from\": 18649, \"to\": 18660, \"entities\": []}, {\"sentence\": \"Q.This question is also for Snoop.\", \"from\": 18662, \"to\": 18696, \"entities\": []}, {\"sentence\": \"I am curious about your approach in engaging with Gen-Z audiences for the Olympics.\", \"from\": 18697, \"to\": 18780, \"entities\": [{\"begin\": 18747, \"end\": 18752, \"title\": \"http://dbpedia.org/resource/Generation_Z\", \"score\": 1.0, \"rank\": 3.899169710927958e-18, \"text\": \"Gen-Z\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Generation_Z\", \"dbpedia\": \"http://dbpedia.org/resource/Generation_Z\"}]}, {\"sentence\": \"Specifically, I wonder if you have any plans to collab with some of the influencers that NBC is sending over to Paris.\", \"from\": 18781, \"to\": 18899, \"entities\": [{\"begin\": 18870, \"end\": 18873, \"title\": \"http://dbpedia.org/resource/NBC\", \"score\": 0.9992506000922473, \"rank\": 0.00028584010544664164, \"text\": \"NBC\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/NBC\", \"dbpedia\": \"http://dbpedia.org/resource/NBC\"}, {\"begin\": 18893, \"end\": 18898, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9996781724910747, \"rank\": 0.0003219311133520977, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"SNOOP DOGG: Yeah, but remember I have got kids that are Gen-Z.\", \"from\": 18901, \"to\": 18963, \"entities\": []}, {\"sentence\": \"Remember me, I have got a house full of them, and then I have got a football league of Gen-Zs and grandkids.\", \"from\": 18964, \"to\": 19072, \"entities\": []}, {\"sentence\": \"This is my world.\", \"from\": 19073, \"to\": 19090, \"entities\": []}, {\"sentence\": \"I love speaking their language and getting on the same page with them.\", \"from\": 19091, \"to\": 19161, \"entities\": []}, {\"sentence\": \"I am an old dog that can learn new tricks.\", \"from\": 19163, \"to\": 19205, \"entities\": []}, {\"sentence\": \"Whenever I am with that generation, I let them give me too legit information, and I take it and make it work.\", \"from\": 19206, \"to\": 19315, \"entities\": []}, {\"sentence\": \"So I am looking forward to working with whoever NBC puts me in front of.\", \"from\": 19316, \"to\": 19388, \"entities\": [{\"begin\": 19364, \"end\": 19367, \"title\": \"http://dbpedia.org/resource/NBC\", \"score\": 0.7650214192381627, \"rank\": 0.2087308258041101, \"text\": \"NBC\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/NBC\", \"dbpedia\": \"http://dbpedia.org/resource/NBC\"}]}, {\"sentence\": \"It does not matter if it's athletes, Gen-X, I am here to do whatever I have got to do.\", \"from\": 19389, \"to\": 19475, \"entities\": []}, {\"sentence\": \"Follow the Dogg, baby.\", \"from\": 19476, \"to\": 19498, \"entities\": []}, {\"sentence\": \"Q.This one's for Mike.\", \"from\": 19500, \"to\": 19522, \"entities\": []}, {\"sentence\": \"As the prime-time host, you are essentially the chief storyteller in this thing.\", \"from\": 19523, \"to\": 19603, \"entities\": []}, {\"sentence\": \"As Molly mentioned, the best Olympics are ones where the host city is a supporting character, and obviously Paris is a beautiful one.\", \"from\": 19604, \"to\": 19737, \"entities\": [{\"begin\": 19712, \"end\": 19717, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9998668475339442, \"rank\": 0.0001331701948426797, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"After two Olympic Games that was maybe harder to explore through the cities for various reasons, how different, if at all, do you expect your job to be this time around?\", \"from\": 19738, \"to\": 19907, \"entities\": []}, {\"sentence\": \"MIKE TIRICO: Well, I can go walk for a cup of coffee.\", \"from\": 19909, \"to\": 19962, \"entities\": []}, {\"sentence\": \"I could not do that in Beijing.\", \"from\": 19963, \"to\": 19994, \"entities\": [{\"begin\": 19986, \"end\": 19993, \"title\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"score\": 0.6397146774194236, \"rank\": 0.5631904994760359, \"text\": \"Beijing\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2008_Summer_Olympics\"}]}, {\"sentence\": \"So we will start there.\", \"from\": 19995, \"to\": 20018, \"entities\": []}, {\"sentence\": \"It is so different.\", \"from\": 20020, \"to\": 20039, \"entities\": []}, {\"sentence\": \"I can not tell you how different it is.\", \"from\": 20040, \"to\": 20079, \"entities\": []}, {\"sentence\": \"And it's a shame because I think Tokyo could have been an incredible Olympic experience, and Beijing was, the prior time with the Summer Games.\", \"from\": 20080, \"to\": 20223, \"entities\": [{\"begin\": 20113, \"end\": 20118, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.9800529781155878, \"rank\": 0.019864590423071225, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}, {\"begin\": 20173, \"end\": 20180, \"title\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"score\": 0.6397146774194236, \"rank\": 0.5631904994760359, \"text\": \"Beijing\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2008_Summer_Olympics\"}]}, {\"sentence\": \"It's unfortunate that it wasn't with the Winter Games for a variety of reasons.\", \"from\": 20224, \"to\": 20303, \"entities\": []}, {\"sentence\": \"Paris is one of two things.\", \"from\": 20305, \"to\": 20332, \"entities\": [{\"begin\": 20305, \"end\": 20310, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999997230381352, \"rank\": 2.7687860242852923e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"You have either been here and can not wait to come back, or you have never been here, and you are dying to get here.\", \"from\": 20333, \"to\": 20449, \"entities\": []}, {\"sentence\": \"As someone who's in the category of having been here a few times, especially in the lead-up, there is nothing like walking around Paris, and because they have made the choice to put the venues right next to some of the iconic spots.\", \"from\": 20450, \"to\": 20682, \"entities\": [{\"begin\": 20580, \"end\": 20585, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999997230381352, \"rank\": 2.7687860242852923e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"Things you will probably see in the Opening Ceremony on Friday, Paris is just a massive co-star in these Games.\", \"from\": 20684, \"to\": 20795, \"entities\": [{\"begin\": 20720, \"end\": 20736, \"title\": \"http://dbpedia.org/resource/Olympic_Games_ceremony\", \"score\": 0.9999975452225842, \"rank\": 1.8274779030320014e-06, \"text\": \"Opening Ceremony\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games_ceremony\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games_ceremony\"}, {\"begin\": 20748, \"end\": 20753, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999997230381352, \"rank\": 2.7687860242852923e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"Nothing is bigger than the athletes and the competition, but Paris is pretty darn close second to that, I will tell you.\", \"from\": 20796, \"to\": 20916, \"entities\": [{\"begin\": 20857, \"end\": 20862, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999997230381352, \"rank\": 2.7687860242852923e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"It's going to add to it, and I think the athletes will feel it.\", \"from\": 20918, \"to\": 20981, \"entities\": []}, {\"sentence\": \"There will be a lot of American fans here, which has not happened the last few games.\", \"from\": 20982, \"to\": 21067, \"entities\": [{\"begin\": 21005, \"end\": 21013, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.8502782097128417, \"rank\": 0.15954512648179942, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}]}, {\"sentence\": \"Remember Rio and the Zika virus.\", \"from\": 21068, \"to\": 21100, \"entities\": []}, {\"sentence\": \"Pyeongchang was hard for folks to get to.\", \"from\": 21101, \"to\": 21142, \"entities\": [{\"begin\": 21101, \"end\": 21112, \"title\": \"http://dbpedia.org/resource/Pyeongchang_County\", \"score\": 0.9612568004904016, \"rank\": 0.032323983722118754, \"text\": \"Pyeongchang\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Pyeongchang_County\", \"dbpedia\": \"http://dbpedia.org/resource/Pyeongchang_County\"}]}, {\"sentence\": \"You mentioned the last two, Tokyo and Beijing.\", \"from\": 21143, \"to\": 21189, \"entities\": [{\"begin\": 21171, \"end\": 21176, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.6658484078295765, \"rank\": 0.5013962152828025, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}, {\"begin\": 21181, \"end\": 21188, \"title\": \"http://dbpedia.org/resource/Beijing\", \"score\": 0.9949224468834251, \"rank\": 0.005103409797231371, \"text\": \"Beijing\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Beijing\", \"dbpedia\": \"http://dbpedia.org/resource/Beijing\"}]}, {\"sentence\": \"So for American athletes, athletes from around the world, they will feel the energy of the fans, they will feel the passion of Paris, and I think it will lead us to a Games that may rival London in 2012 for excitement and enthusiasm.\", \"from\": 21191, \"to\": 21424, \"entities\": [{\"begin\": 21198, \"end\": 21206, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9989889626529381, \"rank\": 0.0008161324158830472, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 21318, \"end\": 21323, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999962188158953, \"rank\": 3.781198440090492e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 21379, \"end\": 21385, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9993231277044947, \"rank\": 0.0004167401604910449, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}]}, {\"sentence\": \"People still talk about those Games and how great they were.\", \"from\": 21425, \"to\": 21485, \"entities\": []}, {\"sentence\": \"Everything is in position for that to happen here this time around.\", \"from\": 21486, \"to\": 21553, \"entities\": []}, {\"sentence\": \"I hope it does.\", \"from\": 21554, \"to\": 21569, \"entities\": []}, {\"sentence\": \"MOLLY SOLOMON: Again, I would just add this opening ceremony is going to showcase the city.\", \"from\": 21571, \"to\": 21662, \"entities\": []}, {\"sentence\": \"We were just in a press briefing, and really there is 12 themes, there is 12 stages.\", \"from\": 21663, \"to\": 21747, \"entities\": []}, {\"sentence\": \"It's all across four miles of the Seine River, and the whole Opening Ceremony is embedded in the heart of the city.\", \"from\": 21748, \"to\": 21863, \"entities\": [{\"begin\": 21809, \"end\": 21825, \"title\": \"http://dbpedia.org/resource/Olympic_Games_ceremony\", \"score\": 0.8362770785171181, \"rank\": 0.1714795752150031, \"text\": \"Opening Ceremony\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games_ceremony\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games_ceremony\"}]}, {\"sentence\": \"So we are going to kick off with almost a tutorial, a very artistic tutorial on the city, and it promises to be just magnificent.\", \"from\": 21865, \"to\": 21994, \"entities\": []}, {\"sentence\": \"Q.Molly, are you able to comment on any speculation around Celine Dion taking part in the Olympic Ceremonies of any kind?\", \"from\": 21996, \"to\": 22117, \"entities\": [{\"begin\": 22055, \"end\": 22066, \"title\": \"http://dbpedia.org/resource/Celine_Dion\", \"score\": 1.0, \"rank\": 1.4482621962686447e-19, \"text\": \"Celine Dion\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Celine_Dion\", \"dbpedia\": \"http://dbpedia.org/resource/Celine_Dion\"}]}, {\"sentence\": \"MOLLY SOLOMON: We are hearing all the same rumors, and we are so excited to see if they are true.\", \"from\": 22119, \"to\": 22216, \"entities\": []}, {\"sentence\": \"We are all waiting.\", \"from\": 22217, \"to\": 22236, \"entities\": []}, {\"sentence\": \"They have kept all of the details very close to the vest, and we are waiting to find out too.\", \"from\": 22237, \"to\": 22330, \"entities\": []}, {\"sentence\": \"We are reading your publication and everything else, but we are very excited to see what happens.\", \"from\": 22331, \"to\": 22428, \"entities\": []}, {\"sentence\": \"MODERATOR: Thank you, everyone, for joining us today.\", \"from\": 22430, \"to\": 22483, \"entities\": []}, {\"sentence\": \"A reminder our live coverage of the Opening Ceremony begins Friday at noon Eastern on NBC and Peacock, 1:00 p.m. on Telemundo, and prime-time coverage begins at 7:30 p.m. Eastern and Pacific on NBC and Peacock.\", \"from\": 22485, \"to\": 22695, \"entities\": [{\"begin\": 22521, \"end\": 22537, \"title\": \"http://dbpedia.org/resource/Opening_ceremony\", \"score\": 0.9268072956308824, \"rank\": 0.0635852807753343, \"text\": \"Opening Ceremony\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Opening_ceremony\", \"dbpedia\": \"http://dbpedia.org/resource/Opening_ceremony\"}, {\"begin\": 22571, \"end\": 22574, \"title\": \"http://dbpedia.org/resource/NBC\", \"score\": 0.9723295611130893, \"rank\": 0.026821084595119542, \"text\": \"NBC\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/NBC\", \"dbpedia\": \"http://dbpedia.org/resource/NBC\"}, {\"begin\": 22579, \"end\": 22586, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.999944245190394, \"rank\": 5.5728138865237627e-05, \"text\": \"Peacock\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Peafowl\", \"dbpedia\": \"http://dbpedia.org/resource/Peafowl\"}, {\"begin\": 22601, \"end\": 22610, \"title\": \"http://dbpedia.org/resource/Telemundo\", \"score\": 0.9998772693254975, \"rank\": 7.496615588763036e-05, \"text\": \"Telemundo\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/Telemundo\", \"dbpedia\": \"http://dbpedia.org/resource/Telemundo\"}, {\"begin\": 22679, \"end\": 22682, \"title\": \"http://dbpedia.org/resource/NBC\", \"score\": 0.9723295611130893, \"rank\": 0.026821084595119542, \"text\": \"NBC\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/NBC\", \"dbpedia\": \"http://dbpedia.org/resource/NBC\"}, {\"begin\": 22687, \"end\": 22694, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.999944245190394, \"rank\": 5.5728138865237627e-05, \"text\": \"Peacock\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Peafowl\", \"dbpedia\": \"http://dbpedia.org/resource/Peafowl\"}]}, {\"sentence\": \"A Division ofNBCUniversal.\", \"from\": 22697, \"to\": 22723, \"entities\": [{\"begin\": 22697, \"end\": 22707, \"title\": \"http://dbpedia.org/resource/Scottish_Football_League\", \"score\": 0.9999990504870726, \"rank\": 7.054304820011566e-07, \"text\": \"A Division\", \"types\": [\"Q623109\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Scottish_Football_League\", \"dbpedia\": \"http://dbpedia.org/resource/Scottish_Football_League\"}]}, {\"sentence\": \"DISCLAIMER: This site and the products offered are for entertainment purposes only, and there is no gambling offered on this site.\", \"from\": 22725, \"to\": 22855, \"entities\": []}, {\"sentence\": \"This service is intended for adult audiences.\", \"from\": 22856, \"to\": 22901, \"entities\": []}, {\"sentence\": \"No guarantees are made for any specific outcome.\", \"from\": 22902, \"to\": 22950, \"entities\": []}, {\"sentence\": \"If you or someone you know has a gambling problem, please call 1-800-GAMBLER.\", \"from\": 22951, \"to\": 23028, \"entities\": []}, {\"sentence\": \"\\u24b8 2024 NBC Universal\", \"from\": 23030, \"to\": 23050, \"entities\": []}]}"