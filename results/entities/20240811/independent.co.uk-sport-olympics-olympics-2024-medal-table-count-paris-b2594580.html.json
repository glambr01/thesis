title\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"score\": 0.9999999363440131, \"rank\": 6.365595500464249e-08, \"text\": \"Beijing\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2008_Summer_Olympics\"}, {\"begin\": 1033, \"end\": 1035, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 0.9999997919328724, \"rank\": 2.0806609352354757e-07, \"text\": \"US\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\"}]}, {\"sentence\": \"Japan backed up their third place finish in Tokyo by taking the final podium spot in Paris while Australia's 18 golds were enough to put them in fourth.\", \"from\": 1092, \"to\": 1244, \"entities\": [{\"begin\": 1092, \"end\": 1097, \"title\": \"http://dbpedia.org/resource/Japan_national_baseball_team\", \"score\": 0.8998045431055876, \"rank\": 0.10617225225106093, \"text\": \"Japan\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Japan_national_baseball_team\", \"dbpedia\": \"http://dbpedia.org/resource/Japan_national_baseball_team\"}, {\"begin\": 1136, \"end\": 1141, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.9960067409771014, \"rank\": 0.004008965132073956, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}, {\"begin\": 1177, \"end\": 1182, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999999953843145, \"rank\": 4.615683566840106e-08, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 1189, \"end\": 1198, \"t