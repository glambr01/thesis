.org/resource/Eccles_Line\"}, {\"begin\": 1324, \"end\": 1337, \"title\": \"http://dbpedia.org/resource/Great_Britain_at_the_Olympics\", \"score\": 0.9997855477372563, \"rank\": 0.00021449804351999748, \"text\": \"Great Britain\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Great_Britain_at_the_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Great_Britain_at_the_Olympics\"}, {\"begin\": 1398, \"end\": 1402, \"title\": \"http://dbpedia.org/resource/Irish_Athletic_Boxing_Association\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"IABA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Irish_Athletic_Boxing_Association\", \"dbpedia\": \"http://dbpedia.org/resource/Irish_Athletic_Boxing_Association\"}, {\"begin\": 1426, \"end\": 1436, \"title\": \"http://dbpedia.org/resource/Broadhurst_Theatre\", \"score\": 0.9999999771896457, \"rank\": 2.2810461230801948e-08, \"text\": \"Broadhurst\", \"types\": [\"Q41176\", \"Q24354\"], \"wikid\": \"http://dbpedia.org/resource/Broadhurst_Theatre\", \"dbpedia\": \"http://dbpedia.org/resource/Broadhurst_Theatre\"}, {\"begin\": 1482, \"end\": 1495, \"title\": \"http://dbpedia.org/resource/Great_Britain_at_the_Olympics\", \"score\": 0.9997855477372563, \"rank\": 0.00021449804351999748, \"text\": \"Great Britain\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Great_Britain_at_the_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Great_Britain_at_the_Olympics\"}, {\"begin\": 1619, \"end\": 1633, \"title\": \"http://dbpedia.org/resource/Amy_Broadhurst\", \"score\": 0.9999949375263346, \"rank\": 0.0, \"text\": \"Amy Broadhurst\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Amy_Broadhurst\", \"dbpedia\": \"http://dbpedia.org/resource/Amy_Broadhurst\"}]}, {\"sentence\": \"\\\"We have discussed this with OFI and Sport Ireland and have expressed our disappointment, while wanting to ensure that she understands the full ramifications of this request and the advice she might be receiving if she decides to go ahead with it.\", \"from\": 1750, \"to\": 1997, \"entities\": [{\"begin\": 1779, \"end\": 1782, \"title\": \"http://dbpedia.org/resource/OFI_Crete_F.C.\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"OFI\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/OFI_Crete_F.C.\", \"dbpedia\": \"http://dbpedia.org/resource/OFI_Crete_F.C.\"}, {\"begin\": 1787, \"end\": 1800, \"title\": \"http://dbpedia.org/resource/Sport_Ireland\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Sport Ireland\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Sport_Ireland\", \"dbpedia\": \"http://dbpedia.org/resource/Sport_Ireland\"}]}, {\"sentence\": \"\\\"We have indicated that if she really thinks that is best for her as a person and an athlete after these discussions that we will not stand in her way.\", \"from\": 1997, \"to\": 2148, \"entities\": []}, {\"sentence\": \"\\\"The BBC claim Broadhurst favours trying to qualify for the 60kg weight category.Amy Broadhurst won gold at the 2022 World Championships|GETTYThe switch in allegiance will need to be ratified by the IOC before the final qualifier in Bangkok.Broadhurst spoke out against the IABA after being informed she would not be assessed for the second World Qualifying tournament in Bangkok.\", \"from\": 2148, \"to\": 2528, \"entities\": [{\"begin\": 2153, \"end\": 2156, \"title\": \"http://dbpedia.org/resource/BBC_Sport\", \"score\": 0.995655871434092, \"rank\": 0.003560761228140035, \"text\": \"BBC\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/BBC_Sport\", \"dbpedia\": \"http://dbpedia.org/resource/BBC_Sport\"}, {\"begin\": 2163, \"end\": 2173, \"title\": \"http://dbpedia.org/resource/Broadhurst_Theatre\", \"score\": 0.9999999771896457, \"rank\": 2.2810461230801948e-08, \"text\": \"Broadhurst\", \"types\": [\"Q41176\", \"Q24354\"], \"wikid\": \"http://dbpedia.org/resource/Broadhurst_Theatre\", \"dbpedia\": \"http://dbpedia.org/resource/Broadhurst_Theatre\"}, {\"begin\": 2233, \"end\": 2243, \"title\": \"http://dbpedia.org/resource/Broadhurst_Theatre\", \"score\": 0.9999999771896457, \"rank\": 2.2810461230801948e-08, \"text\": \"Broadhurst\", \"types\": [\"Q41176\", \"Q24354\"], \"wikid\": \"http://dbpedia.org/resource/Broadhurst_Theatre\", \"dbpedia\": \"http://dbpedia.org/resource/Broadhurst_Theatre\"}, {\"begin\": 2347, \"end\": 2350, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 3.411237186034203e-21, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 2422, \"end\": 2426, \"title\": \"http://dbpedia.org/resource/Irish_Athletic_Boxing_Association\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"IABA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Irish_Athletic_Boxing_Association\", \"dbpedia\": \"http://dbpedia.org/resource/Irish_Athletic_Boxing_Association\"}, {\"begin\": 2520, \"end\": 2527, \"title\": \"http://dbpedia.org/resource/Bangkok\", \"score\": 0.9754929778432572, \"rank\": 0.021955668780095177, \"text\": \"Bangkok\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Bangkok\", \"dbpedia\": \"http://dbpedia.org/resource/Bangkok\"}]}, {\"sentence\": \"\\\"It's a bit of a mess and I am struggling to wrap my head around what is going on,\\\" she told BBC Sport NI.LATEST SPORT NEWS:Christian Horner position 'strengthened' after recent Red Bull meeting with plans for change devisedSebastian Vettel makes Christian Horner stance clear as Lewis Hamilton sent message over Ferrari moveLuke Littler jokingly accuses Luke Humphries of 'slacking' ahead of crunch Premier League clashAmy Broadhurst (right) with Katie Taylor at the undisputed super lightweight championship fight|GETTY\\\"I have