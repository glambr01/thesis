"{\"uid\": \"kpcw.org-park-city-2024-07-22-park-city-to-celebrate-2034-olympics-announcement\", \"entities\": [{\"sentence\": \"The International Olympic Committee is expected to award the 2034 Olympic and Paralympic Games to Salt Lake City on July 24 in Paris.\", \"from\": 0, \"to\": 133, \"entities\": [{\"begin\": 4, \"end\": 35, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 98, \"end\": 112, \"title\": \"http://dbpedia.org/resource/Salt_Lake_City\", \"score\": 0.9999999991077857, \"rank\": 7.941763975603326e-10, \"text\": \"Salt Lake City\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Salt_Lake_City\", \"dbpedia\": \"http://dbpedia.org/resource/Salt_Lake_City\"}, {\"begin\": 127, \"end\": 132, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999992770513357, \"rank\": 7.229492276353437e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"The IOC is expected to vote around 3:30 a.m. MT.\", \"from\": 135, \"to\": 183, \"entities\": [{\"begin\": 139, \"end\": 142, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 0.9999999996987299, \"rank\": 2.7225627591334693e-10, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}]}, {\"sentence\": \"And Utahns can watch the announcement live at a party outside the Salt Lake City and County Building.\", \"from\": 184, \"to\": 285, \"entities\": [{\"begin\": 250, \"end\": 264, \"title\": \"http://dbpedia.org/resource/Salt_Lake_City\", \"score\": 0.9999999991077857, \"rank\": 7.941763975603326e-10, \"text\": \"Salt Lake City\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Salt_Lake_City\", \"dbpedia\": \"http://dbpedia.org/resource/Salt_Lake_City\"}]}, {\"sentence\": \"Park City will gather to celebrate later Wednesday.\", \"from\": 287, \"to\": 338, \"entities\": [{\"begin\": 287, \"end\": 296, \"title\": \"http://dbpedia.org/resource/Park_City_Mountain_Resort\", \"score\": 0.9999964802946675, \"rank\": 3.519717824248765e-06, \"text\": \"Park City\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Park_City_Mountain_Resort\", \"dbpedia\": \"http://dbpedia.org/resource/Park_City_Mountain_Resort\"}]}, {\"sentence\": \"The Utah Olympic Park will host festivities including live music, vendors, giveaways, pin trading and an Olympic and Paralympian meet and greet.\", \"from\": 340, \"to\": 484, \"entities\": [{\"begin\": 344, \"end\": 361, \"title\": \"http://dbpedia.org/resource/Utah_Olympic_Park\", \"score\": 1.0, \"rank\": 6.924599494459878e-16, \"text\": \"Utah Olympic Park\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Utah_Olympic_Park\", \"dbpedia\": \"http://dbpedia.org/resource/Utah_Olympic_Park\"}, {\"begin\": 457, \"end\": 468, \"title\": \"http://dbpedia.org/resource/Paralympic_Games\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Paralympian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Paralympic_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Paralympic_Games\"}]}, {\"sentence\": \"The event runs from 4 p.m. to 9 p.m.\", \"from\": 485, \"to\": 521, \"entities\": []}, {\"sentence\": \"The Flying Ace All-Stars Freestyle show is free at 6:30 p.m., but tickets are sold out.\", \"from\": 523, \"to\": 610, \"entities\": []}, {\"sentence\": \"Park City Economic Development Program Manager Jenny Diersen said no parking is available on site.\", \"from\": 612, \"to\": 710, \"entities\": [{\"begin\": 612, \"end\": 621, \"title\": \"http://dbpedia.org/resource/Park_City_Mountain_Resort\", \"score\": 0.9999964802946675, \"rank\": 3.519717824248765e-06, \"text\": \"Park City\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Park_City_Mountain_Resort\", \"dbpedia\": \"http://dbpedia.org/resource/Park_City_Mountain_Resort\"}, {\"begin\": 643, \"end\": 658, \"title\": \"http://dbpedia.org/resource/Program_Manager\", \"score\": 0.9633389168242115, \"rank\": 0.038056267151133485, \"text\": \"Program Manager\", \"types\": [\"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Program_Manager\", \"dbpedia\": \"http://dbpedia.org/resource/Program_Manager\"}, {\"begin\": 659, \"end\": 664, \"title\": \"http://dbpedia.org/resource/Jenny_Lake\", \"score\": 0.9999032356084961, \"rank\": 9.666641310867109e-05, \"text\": \"Jenny\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Jenny_Lake\", \"dbpedia\": \"http://dbpedia.org/resource/Jenny_Lake\"}]}, {\"sentence\": \"\\\"Both Park City Transit as well as High Valley Transit are partnering and providing transit to the event,\\\" Diersen.\", \"from\": 712, \"to\": 827, \"entities\": [{\"begin\": 718, \"end\": 727, \"title\": \"http://dbpedia.org/resource/Park_City_Mountain_Resort\", \"score\": 0.9999964802946675, \"rank\": 3.519717824248765e-06, \"text\": \"Park City\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Park_City_Mountain_Resort\", \"dbpedia\": \"http://dbpedia.org/resource/Park_City_Mountain_Resort\"}]}, {\"sentence\": \"\\\"You can park at Richardson Flat park-and-ride.\", \"from\": 828, \"to\": 875, \"entities\": [{\"begin\": 845, \"end\": 855, \"title\": \"http://dbpedia.org/resource/Samuel_Richardson\", \"score\": 0.9549881717897403, \"rank\": 0.04706493659077366, \"text\": \"Richardson\", \"types\": [\"Q729\", \"Q5\", \"Q36180\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Samuel_Richardson\", \"dbpedia\": \"http://dbpedia.org/resource/Samuel_Richardson\"}]}, {\"sentence\": \"You can park at Canyon's Cabriolet lot.\", \"from\": 876, \"to\": 915, \"entities\": [{\"begin\": 901, \"end\": 910, \"title\": \"http://dbpedia.org/resource/Convertible\", \"score\": 0.9998296309907387, \"rank\": 0.00017039803976991454, \"text\": \"Cabriolet\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Convertible\", \"dbpedia\": \"http://dbpedia.org/resource/Convertible\"}]}, {\"sentence\": \"Or you can park at Woodward to come to the event.\", \"from\": 916, \"to\": 965, \"entities\": [{\"begin\": 935, \"end\": 943, \"title\": \"http://dbpedia.org/resource/Lower_Woodward_Avenue_Historic_District\", \"score\": 0.8081798227392196, \"rank\": 0.2276422918889137, \"text\": \"Woodward\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Lower_Woodward_Avenue_Historic_District\", \"dbpedia\": \"http://dbpedia.org/resource/Lower_Woodward_Avenue_Historic_District\"}]}, {\"sentence\": \"And from there, they will be running shuttles up to the UOP.\\\"\", \"from\": 966, \"to\": 1027, \"entities\": [{\"begin\": 1022, \"end\": 1025, \"title\": \"http://dbpedia.org/resource/University_of_Portsmouth\", \"score\": 0.9997661735214821, \"rank\": 0.00023388116551231904, \"text\": \"UOP\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/University_of_Portsmouth\", \"dbpedia\": \"http://dbpedia.org/resource/University_of_Portsmouth\"}]}, {\"sentence\": \"Buses will run from 3 p.m. to 10 p.m.  Rideshares and hotel shuttles will drop riders at the Skullcandy building.\", \"from\": 1029, \"to\": 1142, \"entities\": [{\"begin\": 1122, \"end\": 1132, \"title\": \"http://dbpedia.org/resource/Skullcandy\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Skullcandy\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Skullcandy\", \"dbpedia\": \"http://dbpedia.org/resource/Skullcandy\"}]}, {\"sentence\": \"Attendees can then board a bus at the Kimball Junction Transit Center to get to the celebration.\", \"from\": 1143, \"to\": 1239, \"entities\": [{\"begin\": 1181, \"end\": 1197, \"title\": \"http://dbpedia.org/resource/Park_City,_Utah\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Kimball Junction\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Park_City,_Utah\", \"dbpedia\": \"http://dbpedia.org/resource/Park_City,_Utah\"}]}, {\"sentence\": \"A bike valet will also be available.\", \"from\": 1241, \"to\": 1277, \"entities\": []}, {\"sentence\": \"Park City Municipal, Summit County and the Park City Chamber have partnered to put on the local event.\", \"from\": 1279, \"to\": 1381, \"entities\": [{\"begin\": 1322, \"end\": 1331, \"title\": \"http://dbpedia.org/resource/Park_City_Mountain_Resort\", \"score\": 0.9999964802946675, \"rank\": 3.519717824248765e-06, \"text\": \"Park City\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Park_City_Mountain_Resort\", \"dbpedia\": \"http://dbpedia.org/resource/Park_City_Mountain_Resort\"}]}, {\"sentence\": \"Celebrations are also planned in Provo at the Peaks Ice Arena and in Charleston alongside Pioneer Day festivities.\", \"from\": 1383, \"to\": 1497, \"entities\": [{\"begin\": 1416, \"end\": 1421, \"title\": \"http://dbpedia.org/resource/Marriott_Center\", \"score\": 0.9935473632125779, \"rank\": 0.0061220468539920836, \"text\": \"Provo\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Marriott_Center\", \"dbpedia\": \"http://dbpedia.org/resource/Marriott_Center\"}, {\"begin\": 1429, \"end\": 1444, \"title\": \"http://dbpedia.org/resource/Peaks_Ice_Arena\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Peaks Ice Arena\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Peaks_Ice_Arena\", \"dbpedia\": \"http://dbpedia.org/resource/Peaks_Ice_Arena\"}, {\"begin\": 1452, \"end\": 1462, \"title\": \"http://dbpedia.org/resource/Charleston_Open\", \"score\": 0.662471833