"{\"uid\": \"si.com-college-pennstate-wrestling-penn-state-wrestling-roman-bravo-young-qualifies-2024-summer-olympics-paris\", \"entities\": [{\"sentence\": \"Penn State wrestling has its first 2024 Olympian.\", \"from\": 0, \"to\": 49, \"entities\": [{\"begin\": 0, \"end\": 10, \"title\": \"http://dbpedia.org/resource/Penn_State_Nittany_Lions_wrestling\", \"score\": 1.0, \"rank\": 2.4443138780515507e-20, \"text\": \"Penn State\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Penn_State_Nittany_Lions_wrestling\", \"dbpedia\": \"http://dbpedia.org/resource/Penn_State_Nittany_Lions_wrestling\"}, {\"begin\": 40, \"end\": 48, \"title\": \"http://dbpedia.org/resource/Olympic_Games\", \"score\": 0.9999999976171239, \"rank\": 2.38292233035684e-09, \"text\": \"Olympian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games\"}]}, {\"sentence\": \"Roman Bravo-Young, a two-time NCAA wrestling champion for the Nittany Lions, will represent Mexico at the 2024 Summer Olympics in Paris.\", \"from\": 50, \"to\": 186, \"entities\": [{\"begin\": 50, \"end\": 67, \"title\": \"http://dbpedia.org/resource/Roman_Bravo-Young\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Roman Bravo-Young\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Roman_Bravo-Young\", \"dbpedia\": \"http://dbpedia.org/resource/Roman_Bravo-Young\"}, {\"begin\": 80, \"end\": 84, \"title\": \"http://dbpedia.org/resource/NCAA_Division_I_Wrestling_Championships\", \"score\": 0.9995199085275002, \"rank\": 0.00048032206943300247, \"text\": \"NCAA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NCAA_Division_I_Wrestling_Championships\", \"dbpedia\": \"http://dbpedia.org/resource/NCAA_Division_I_Wrestling_Championships\"}, {\"begin\": 112, \"end\": 125, \"title\": \"http://dbpedia.org/resource/Penn_State_Nittany_Lions\", \"score\": 0.9822655278126499, \"rank\": 0.017990331531622262, \"text\": \"Nittany Lions\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/Penn_State_Nittany_Lions\", \"dbpedia\": \"http://dbpedia.org/resource/Penn_State_Nittany_Lions\"}, {\"begin\": 142, \"end\": 148, \"title\": \"http://dbpedia.org/resource/Mexico_national_football_team\", \"score\": 0.8826765806028899, \"rank\": 0.1328996838573313, \"text\": \"Mexico\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Mexico_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Mexico_national_football_team\"}, {\"begin\": 180, \"end\": 185, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999406954903, \"rank\": 5.93044308173607e-08, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"Bravo-Young qualified for the Summer Games by winning three bouts at the Pan-American qualifying tournament in Acapulco, Mexico.\", \"from\": 187, \"to\": 315, \"entities\": [{\"begin\": 260, \"end\": 272, \"title\": \"http://dbpedia.org/resource/Pan_American_Games\", \"score\": 0.9999999954952727, \"rank\": 4.504651282268312e-09, \"text\": \"Pan-American\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Pan_American_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Pan_American_Games\"}, {\"begin\": 298, \"end\": 314, \"title\": \"http://dbpedia.org/resource/2022_Pan_American_Wrestling_Championships\", \"score\": 0.9999999921160452, \"rank\": 7.883772041796566e-09, \"text\": \"Acapulco, Mexico\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/2022_Pan_American_Wrestling_Championships\", \"dbpedia\": \"http://dbpedia.org/resource/2022_Pan_American_Wrestling_Championships\"}, {\"begin\": 298, \"end\": 314, \"title\": \"http://dbpedia.org/resource/2022_Pan_American_Wrestling_Championships\", \"score\": 0.9999999921160452, \"rank\": 7.883772041796566e-09, \"text\": \"Acapulco, Mexico\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/2022_Pan_American_Wrestling_Championships\", \"dbpedia\": \"http://dbpedia.org/resource/2022_Pan_American_Wrestling_Championships\"}]}, {\"sentence\": \"Bravo-Young outscored his three opponents by a combined score of 35-10 in the 57 kg freestyle weight class.\", \"from\": 316, \"to\": 423, \"entities\": []}, {\"sentence\": \"Bravo-Young technically qualified Mexico for the weight at the Olympics.\", \"from\": 425, \"to\": 497, \"entities\": [{\"begin\": 459, \"end\": 465, \"title\": \"http://dbpedia.org/resource/Mexico_national_football_team\", \"score\": 0.8826765806028899, \"rank\": 0.1328996838573313, \"text\": \"Mexico\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Mexico_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Mexico_national_football_team\"}]}, {\"sentence\": \"But Mexico's qualifying procedures differ from the U.S., meaning Bravo-Young also earned the spot on Mexico's Olympic team.\", \"from\": 498, \"to\": 621, \"entities\": [{\"begin\": 502, \"end\": 508, \"title\": \"http://dbpedia.org/resource/Mexico_national_football_team\", \"score\": 0.8826765806028899, \"rank\": 0.1328996838573313, \"text\": \"Mexico\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Mexico_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Mexico_national_football_team\"}, {\"begin\": 599, \"end\": 605, \"title\": \"http://dbpedia.org/resource/Mexico_national_football_team\", \"score\": 0.8826765806028899, \"rank\": 0.1328996838573313, \"text\": \"Mexico\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Mexico_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Mexico_national_football_team\"}]}, {\"sentence\": \"\\\"It feels amazing,\\\" Bravo-Young toldFloWrestling in an interviewafter qualifying.\", \"from\": 623, \"to\": 704, \"entities\": []}, {\"sentence\": \"\\\"A lot of people do not really know what I come from, but it's a dream come true.\", \"from\": 705, \"to\": 786, \"entities\": []}, {\"sentence\": \"Obviously trying to bring back a medal for Mexico, but it's a surreal moment.\", \"from\": 787, \"to\": 864, \"entities\": [{\"begin\": 830, \"end\": 836, \"title\": \"http://dbpedia.org/resource/Mexico_national_football_team\", \"score\": 0.8826765806028899, \"rank\": 0.1328996838573313, \"text\": \"Mexico\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Mexico_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Mexico_national_football_team\"}]}, {\"sentence\": \"I am an Olympian, and that sticks with me forever.\\\"\", \"from\": 865, \"to\": 916, \"entities\": [{\"begin\": 873, \"end\": 881, \"title\": \"http://dbpedia.org/resource/Olympic_Games\", \"score\": 0.9999999976171239, \"rank\": 2.38292233035684e-09, \"text\": \"Olympian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games\"}]}, {\"sentence\": \"I\\u00e2\\u0080\\u0099m an Olympian \\u00f0\\u009f\\u0087\\u00b2\\u00f0\\u009f\\u0087\\u00bd  Bravo-Young came to Penn State from Tucson, Arizona, where he went 182-0 and won four state titles.\", \"from\": 918, \"to\": 1045, \"entities\": [{\"begin\": 927, \"end\": 935, \"title\": \"http://dbpedia.org/resource/Olympic_Games\", \"score\": 0.9999999976171239, \"rank\": 2.38292233035684e-09, \"text\": \"Olympian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games\"}, {\"begin\": 966, \"end\": 976, \"title\": \"http://dbpedia.org/resource/Penn_State_Nittany_Lions_wrestling\", \"score\": 1.0, \"rank\": 2.4443138780515507e-20, \"text\": \"Penn State\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Penn_State_Nittany_Lions_wrestling\", \"dbpedia\": \"http://dbpedia.org/resource/Penn_State_Nittany_Lions_wrestling\"}, {\"begin\": 982, \"end\": 997, \"title\": \"http://dbpedia.org/resource/Arizona_Stadium\", \"score\": 0.9999381254099786, \"rank\": 6.187841598201287e-05, \"text\": \"Tucson, Arizona\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Arizona_Stadium\", \"dbpedia\": \"http://dbpedia.org/resource/Arizona_Stadium\"}, {\"begin\": 982, \"end\": 997, \"title\": \"http://dbpedia.org/resource/Arizona_Stadium\", \"score\": 0.9999381254099786, \"rank\": 6.187841598201287e-05, \"text\": \"Tucson, Arizona\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Arizona_Stadium\", \"dbpedia\": \"http://dbpedia.org/resource/Arizona_Stadium\"}]}, {\"sentence\": \"At Penn State, Bravo-Young compiled a 101-10 record, winning NCAA titles at 133 pounds in 2021 and '22.\", \"from\": 1046, \"to\": 1149, \"entities\": [{\"begin\": 1049, \"end\": 1059, \"title\": \"http://dbpedia.org/resource/Penn_State_Nittany_Lions_wrestling\", \"score\": 1.0, \"rank\": 2.4443138780515507e-20, \"text\": \"Penn State\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Penn_State_Nittany_Lions_wrestling\", \"dbpedia\": \"http://dbpedia.org/resource/Penn_State_Nittany_Lions_wrestling\"}, {\"begin\": 1107, \"end\": 1111, \"title\": \"http://dbpedia.org/resource/NCAA_Division_I_Wrestling_Championships\", \"score\": 0.9995199085275002, \"rank\": 0.00048032206943300247, \"text\": \"NCAA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NCAA_Division_I_Wrestling_Championships\", \"dbpedia\": \"http://dbpedia.org/resource/NCAA_Division_I_Wrestling_Championships\"}]}, {\"sentence\": \"He placed second in 2023, losing just once in the NCAA final to Cornell's Vito Arujau, and was a four-time All-American.\", \"from\": 1150, \"to\": 1270, \"entities\": [{\"begin\": 1214, \"end\": 1221, \"title\": \"http://dbpedia.org/resource/Cornell_Big_Red_football\", \"score\": 0.9954406888287413, \"rank\": 0.0032131686689253905, \"text\": \"Cornell\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Cornell_Big_Red_football\", \"dbpedia\": \"http://dbpedia.org/resource/Cornell_Big_Red_football\"}, {\"begin\": 1224, \"end\": 1235, \"title\": \"http://dbpedia.org/resource/Vito_Arujau\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Vito Arujau\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Vito_Arujau\", \"dbpedia\": \"http://dbpedia.org/resource/Vito_Arujau\"}]}, {\"sentence\": \"\\\"Just a kid from Tucson, Arizona, now we are going to Paris,\\\" Bravo-Young told FloWrestling.\", \"from\": 1272, \"to\": 1364, \"entities\": [{\"begin\": 1289, \"end\": 1304, \"title\": \"http://dbpedia.org/resource/Arizona_Stadium\", \"score\": 0.9999381254099786, \"rank\": 6.187841598201287e-05, \"text\": \"Tucson, Arizona\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Arizona_Stadium\", \"dbpedia\": \"http://dbpedia.org/resource/Arizona_Stadium\"}, {\"begin\": 1289, \"end\": 1304, \"title\": \"http://dbpedia.org/resource/Arizona_Stadium\", \"score\": 0.9999381254099786, \"rank\": 6.187841598201287e-05, \"text\": \"Tucson, Arizona\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Arizona_Stadium\", \"dbpedia\": \"http://dbpedia.org/resource/Arizona_Stadium\"}, {\"begin\": 1326, \"end\": 1331, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999406954903, \"rank\": 5.93044308173607e-08, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 1351, \"end\": 1363, \"title\": \"http://dbpedia.org/resource/FloSports\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"FloWrestling\", \"types\": [\"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/FloSports\", \"dbpedia\": \"http://dbpedia.org/resource/FloSports\"}]}, {\"sentence