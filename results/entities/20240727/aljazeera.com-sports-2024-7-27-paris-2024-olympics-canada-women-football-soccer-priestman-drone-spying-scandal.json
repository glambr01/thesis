"{\"uid\": \"aljazeera.com-sports-2024-7-27-paris-2024-olympics-canada-women-football-soccer-priestman-drone-spying-scandal\", \"entities\": [{\"sentence\": \"The Canadian women's football team, who gold won at Tokyo 2020, have been stripped of six points by FIFA, while coach Bev Priestman is banned from all football for one year.\", \"from\": 0, \"to\": 173, \"entities\": [{\"begin\": 4, \"end\": 12, \"title\": \"http://dbpedia.org/resource/Canadians\", \"score\": 0.7925340524813548, \"rank\": 0.26164240383337617, \"text\": \"Canadian\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Canadians\", \"dbpedia\": \"http://dbpedia.org/resource/Canadians\"}, {\"begin\": 100, \"end\": 104, \"title\": \"http://dbpedia.org/resource/FIFA\", \"score\": 0.9999999998606199, \"rank\": 1.2570137160606723e-10, \"text\": \"FIFA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/FIFA\", \"dbpedia\": \"http://dbpedia.org/resource/FIFA\"}, {\"begin\": 118, \"end\": 131, \"title\": \"http://dbpedia.org/resource/Bev_Priestman\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Bev Priestman\", \"types\": [\"Q729\", \"Q628099\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Bev_Priestman\", \"dbpedia\": \"http://dbpedia.org/resource/Bev_Priestman\"}]}, {\"sentence\": \"Save  Share  FIFA deducted six points fromCanadain the Paris Olympics women's football tournament and banned three coaches for one year each in adrone spying scandal.\", \"from\": 175, \"to\": 341, \"entities\": []}, {\"sentence\": \"The stunning swath of punishments, announced late on Saturday, includes a 200,000-Swiss-franc ($226,000) fine for the Canadian football federation in a case that has spiralled at theSummer Games.\", \"from\": 343, \"to\": 538, \"entities\": [{\"begin\": 461, \"end\": 469, \"title\": \"http://dbpedia.org/resource/Canadians\", \"score\": 0.7925340524813548, \"rank\": 0.26164240383337617, \"text\": \"Canadian\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Canadians\", \"dbpedia\": \"http://dbpedia.org/resource/Canadians\"}]}, {\"sentence\": \"Two assistant coaches were caught using drones to spy on opponent New Zealand's practices before theiropening gameon Wednesday.\", \"from\": 540, \"to\": 667, \"entities\": [{\"begin\": 606, \"end\": 617, \"title\": \"http://dbpedia.org/resource/New_Zealand_women's_national_football_team\", \"score\": 0.9853375159889478, \"rank\": 0.014777417508182426, \"text\": \"New Zealand\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/New_Zealand_women's_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/New_Zealand_women's_national_football_team\"}]}, {\"sentence\": \"Head coach Bev Priestman, who led Canada to the Olympic title in Tokyo in 2021, already was suspended by the national football federation and then removed from theOlympic tournament.\", \"from\": 669, \"to\": 851, \"entities\": [{\"begin\": 680, \"end\": 693, \"title\": \"http://dbpedia.org/resource/Bev_Priestman\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Bev Priestman\", \"types\": [\"Q729\", \"Q628099\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Bev_Priestman\", \"dbpedia\": \"http://dbpedia.org/resource/Bev_Priestman\"}, {\"begin\": 703, \"end\": 709, \"title\": \"http://dbpedia.org/resource/Canada_women's_national_soccer_team\", \"score\": 0.9999999604744979, \"rank\": 2.079814675519805e-08, \"text\": \"Canada\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Canada_women's_national_soccer_team\", \"dbpedia\": \"http://dbpedia.org/resource/Canada_women's_national_soccer_team\"}, {\"begin\": 734, \"end\": 739, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.785946936206796, \"rank\": 0.27219407917548344, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}, {\"begin\": 787, \"end\": 795, \"title\": \"http://dbpedia.org/resource/Association_football\", \"score\": 0.9999772774407132, \"rank\": 2.2714242096551922e-05, \"text\": \"football\", \"types\": [\"Q349\", \"Q1914636\"], \"wikid\": \"http://dbpedia.org/resource/Association_football\", \"dbpedia\": \"http://dbpedia.org/resource/Association_football\"}]}, {\"sentence\": \"She is now banned from all football by FIFA for one year.\", \"from\": 852, \"to\": 909, \"entities\": [{\"begin\": 891, \"end\": 895, \"title\": \"http://dbpedia.org/resource/FIFA\", \"score\": 0.9999999998606199, \"rank\": 1.2570137160606723e-10, \"text\": \"FIFA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/FIFA\", \"dbpedia\": \"http://dbpedia.org/resource/FIFA\"}]}, {\"sentence\": \"FIFA fast-tracked its own disciplinary process by asking its appeals judges to handle the case.\", \"from\": 911, \"to\": 1006, \"entities\": []}, {\"sentence\": \"The judges found Priestman and her two assistants \\\"were each found responsible for offensive behaviour and violation of the principles of fair play.\\\"\", \"from\": 1008, \"to\": 1157, \"entities\": []}, {\"sentence\": \"The Canadian federation was held responsible for not ensuring its staff complied with tournament rules.\", \"from\": 1159, \"to\": 1262, \"entities\": [{\"begin\": 1163, \"end\": 1182, \"title\": \"http://dbpedia.org/resource/Canada\", \"score\": 0.9998643487316424, \"rank\": 0.00010047460897425801, \"text\": \"Canadian federation\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Canada\", \"dbpedia\": \"http://dbpedia.org/resource/Canada\"}]}, {\"sentence\": \"The coaches and the Canadian federation can challenge their sanctions at the Court of Arbitration for Sport's (CAS) special Olympic court in Paris.\", \"from\": 1264, \"to\": 1411, \"entities\": [{\"begin\": 1284, \"end\": 1303, \"title\": \"http://dbpedia.org/resource/Canada\", \"score\": 0.9998643487316424, \"rank\": 0.00010047460897425801, \"text\": \"Canadian federation\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Canada\", \"dbpedia\": \"http://dbpedia.org/resource/Canada\"}, {\"begin\": 1375, \"end\": 1378, \"title\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"score\": 1.0, \"rank\": 4.888878179199329e-31, \"text\": \"CAS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"dbpedia\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\"}, {\"begin\": 1405, \"end\": 1410, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999997120190033, \"rank\": 2.8798112435675383e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"That tribunal is set up for urgent hearings and verdicts at the Olympics.\", \"from\": 1412, \"to\": 1485, \"entities\": []}, {\"sentence\": \"The 38-year-old Priestman is from England and was hired in 2020 to coach Canada.\", \"from\": 1487, \"to\": 1567, \"entities\": [{\"begin\": 1521, \"end\": 1528, \"title\": \"http://dbpedia.org/resource/England_women's_national_football_team\", \"score\": 0.8050541263571049, \"rank\": 0.1976521228583816, \"text\": \"England\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/England_women's_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/England_women's_national_football_team\"}, {\"begin\": 1554, \"end\": 1566, \"title\": \"http://dbpedia.org/resource/Coach_Canada\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"coach Canada\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Coach_Canada\", \"dbpedia\": \"http://dbpedia.org/resource/Coach_Canada\"}]}, {\"sentence\": \"She is under contract through the 2027 Women's World Cup.\", \"from\": 1568, \"to\": 1625, \"entities\": []}, {\"sentence\": \"Priestman had stepped aside from the defending champions' Olympic opener against New Zealand on Wednesday after the scandal was revealed.\", \"from\": 1627, \"to\": 1764, \"entities\": [{\"begin\": 1708, \"end\": 1719, \"title\": \"http://dbpedia.org/resource/New_Zealand_women's_national_football_team\", \"score\": 0.9853375159889478, \"rank\": 0.014777417508182426, \"text\": \"New Zealand\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/New_Zealand_women's_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/New_Zealand_women's_national_football_team\"}]}, {\"sentence\": \"Canadian officials suspect the spying has been systemic over the years.\", \"from\": 1765, \"to\": 1836, \"entities\": [{\"begin\": 1765, \"end\": 1773, \"title\": \"http://dbpedia.org/resource/Canadians\", \"score\": 0.7925340524813548, \"rank\": 0.26164240383337617, \"text\": \"Canadian\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Canadians\", \"dbpedia\": \"http://dbpedia.org/resource/Canadians\"}]}, {\"sentence\": \"Her two staffers were sent home for allegedly using a drone to spy on New Zealand in training.\", \"from\": 1838, \"to\": 1932, \"entities\": [{\"begin\": 1908, \"end\": 1919, \"title\": \"http://dbpedia.org/resource/New_Zealand_women's_national_football_team\", \"score\": 0.9853375159889478, \"rank\": 0.014777417508182426, \"text\": \"New Zealand\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/New_Zealand_women's_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/New_Zealand_women's_national_football_team\"}]}, {\"sentence\": \"Canada won the game 2-1 with interim coach Andy Spence in charge.\", \"from\": 1933, \"to\": 1998, \"entities\": [{\"begin\": 1933, \"end\": 1939, \"title\": \"http://dbpedia.org/resource/Canada_women's_national_soccer_team\", \"score\": 0.99