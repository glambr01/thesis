"{\"uid\": \"hola.com-us-royals-20240727709422-king-felipe-queen-letizia-selfie-paris-olympics-opening-ceremony\", \"entities\": [{\"sentence\": \"Smiles from the City of Love!\", \"from\": 0, \"to\": 29, \"entities\": []}, {\"sentence\": \"Spain'sKing FelipeandQueen Letiziawere pictured grinning from ear to ear in a new selfie taken at the Olympics Opening Ceremony in Paris.\", \"from\": 30, \"to\": 167, \"entities\": [{\"begin\": 161, \"end\": 166, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999767014744, \"rank\": 2.329858314801718e-08, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"The Spanish Royal House included the cheerful image in an Instagram carousel featuring photos from Friday's ceremony, including one of His Majesty snapping the selfie with his wife, who recycled a Carolina Herrera dress for the occasion.\", \"from\": 169, \"to\": 406, \"entities\": [{\"begin\": 173, \"end\": 192, \"title\": \"http://dbpedia.org/resource/Spanish_royal_family\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Spanish Royal House\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Spanish_royal_family\", \"dbpedia\": \"http://dbpedia.org/resource/Spanish_royal_family\"}, {\"begin\": 173, \"end\": 192, \"title\": \"http://dbpedia.org/resource/Spanish_royal_family\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Spanish Royal House\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Spanish_royal_family\", \"dbpedia\": \"http://dbpedia.org/resource/Spanish_royal_family\"}, {\"begin\": 227, \"end\": 236, \"title\": \"http://dbpedia.org/resource/Instagram\", \"score\": 1.0, \"rank\": 2.5998380250652996e-14, \"text\": \"Instagram\", \"types\": [\"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Instagram\", \"dbpedia\": \"http://dbpedia.org/resource/Instagram\"}, 