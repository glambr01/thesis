"{\"uid\": \"nbcsports.com-olympics-news-alise-willoughby-bmx-world-championships-2024-rock-hill\", \"entities\": [{\"sentence\": \"American Alise Willoughby won a record-tying third world title in BMX racing and qualified for a fourth Olympics in Paris this summer.\", \"from\": 0, \"to\": 134, \"entities\": [{\"begin\": 0, \"end\": 8, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.999934837635181, \"rank\": 5.918312534503951e-05, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 9, \"end\": 25, \"title\": \"http://dbpedia.org/resource/Alise_Willoughby\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Alise Willoughby\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Alise_Willoughby\", \"dbpedia\": \"http://dbpedia.org/resource/Alise_Willoughby\"}, {\"begin\": 66, \"end\": 76, \"title\": \"http://dbpedia.org/resource/BMX_racing\", \"score\": 0.9999999999988631, \"rank\": 1.2343300767332634e-12, \"text\": \"BMX racing\", \"types\": [\"Q349\", \"Q1914636\"], \"wikid\": \"http://dbpedia.org/resource/BMX_racing\", \"dbpedia\": \"http://dbpedia.org/resource/BMX_racing\"}, {\"begin\": 116, \"end\": 121, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999973613285, \"rank\": 2.638661248292637e-09, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"Willoughby, 33, won the world championship in Rock Hill, South Carolina, on Saturday.\", \"from\": 136, \"to\": 221, \"entities\": [{\"begin\": 182, \"end\": 207, \"title\": \"http://dbpedia.org/resource/Rock_Hill,_South_Carolina\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Rock Hill, South Carolina\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Rock_Hill,_South_Carolina\", \"dbpedia\": \"http://dbpedia.org/resource/Rock_Hill,_South_Carolina\"}, {\"begin\": 182, \"end\": 207, \"title\": \"http://dbpedia.org/resource/Rock_Hill,_South_Carolina\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Rock Hill, South Carolina\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Rock_Hill,_South_Carolina\", \"dbpedia\": \"http://dbpedia.org/resource/Rock_Hill,_South_Carolina\"}]}, {\"sentence\": \"She was followed by Swiss Zoe Claessens and American Daleny Vaughn, who qualified for her first U.S. Olympic team.\", \"from\": 222, \"to\": 336, \"entities\": [{\"begin\": 242, \"end\": 247, \"title\": \"http://dbpedia.org/resource/Switzerland\", \"score\": 0.945060244389051, \"rank\": 0.05653779782836552, \"text\": \"Swiss\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Switzerland\", \"dbpedia\": \"http://dbpedia.org/resource/Switzerland\"}, {\"begin\": 248, \"end\": 251, \"title\": \"http://dbpedia.org/resource/Renault_Zoe\", \"score\": 0.9868109632787101, \"rank\": 0.007676533156490519, \"text\": \"Zoe\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Renault_Zoe\", \"dbpedia\": \"http://dbpedia.org/resource/Renault_Zoe\"}, {\"begin\": 266, \"end\": 274, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.999934837635181, \"rank\": 5.918312534503951e-05, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}]}, {\"sentence\": \"\\\"I always say this place is a special place in my heart,\\\" said Willoughby, who also won at the last worlds to be held in Rock Hill in 2017.\", \"from\": 338, \"to\": 477, \"entities\": [{\"begin\": 401, \"end\": 411, \"title\": \"http://dbpedia.org/resource/City_of_Willoughby\", \"score\": 0.9999999720032524, \"rank\": 2.7631383170729682e-08, \"text\": \"Willoughby\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/City_of_Willoughby\", \"dbpedia\": \"http://dbpedia.org/resource/City_of_Willoughby\"}, {\"begin\": 459, \"end\": 468, \"title\": \"http://dbpedia.org/resource/Rock_Hill_Chiefs\", \"score\": 0.9999787998572984, \"rank\": 2.1167236996658564e-05, \"text\": \"Rock Hill\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Rock_Hill_Chiefs\", \"dbpedia\": \"http://dbpedia.org/resource/Rock_Hill_Chiefs\"}]}, {\"sentence\": \"\\\"I wanted to deliver here.\", \"from\": 478, \"to\": 504, \"entities\": []}, {\"sentence\": \"\\\"I am just so proud to say that I am still rising to potential in the latter part of my career, and I just want to keep digging.\\\"\", \"from\": 506, \"to\": 635, \"entities\": []}, {\"sentence\": \"Willoughby is set to tie Kristin Armstrong's record for the most Olympic appearances for a U.S. female cyclist, according to the OlyMADMen.\", \"from\": 637, \"to\": 776, \"entities\": [{\"begin\": 662, \"end\": 669, \"title\": \"http://dbpedia.org/resource/Kristin_Shepard\", \"score\": 0.9288544111763535, \"rank\": 0.033804556677316744, \"text\": \"Kristin\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Kristin_Shepard\", \"dbpedia\": \"http://dbpedia.org/resource/Kristin_Shepard\"}, {\"begin\": 670, \"end\": 679, \"title\": \"http://dbpedia.org/resource/Lance_Armstrong\", \"score\": 0.999999999998181, \"rank\": 1.6749426934834811e-12, \"text\": \"Armstrong\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Lance_Armstrong\", \"dbpedia\": \"http://dbpedia.org/resource/Lance_Armstrong\"}]}, {\"sentence\": \"Willoughby won silver at the 2016 Rio Olympics, then crashed twice in the semifinals in Tokyo as reigning world champion.\", \"from\": 778, \"to\": 899, \"entities\": [{\"begin\": 866, \"end\": 871, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.9989884046759585, \"rank\": 0.001011673260582844, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}]}, {\"sentence\": \"She previously won world titles in 2017 and 2019.\", \"from\": 900, \"to\": 949, \"entities\": []}, {\"sentence\": \"On Saturday, she tied the record for most women's world titles held by Argentine Gabriela Diaz, Brit Shanaze Reade and Colombian Mariana Paj\\u00f3n.\", \"from\": 951, \"to\": 1094, \"entities\": [{\"begin\": 1022, \"end\": 1031, \"title\": \"http://dbpedia.org/resource/Argentines\", \"score\": 0.971441938463361, \"rank\": 0.028843978313027846, \"text\": \"Argentine\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Argentines\", \"dbpedia\": \"http://dbpedia.org/resource/Argentines\"}, {\"begin\": 1052, \"end\": 1065, \"title\": \"http://dbpedia.org/resource/Shanaze_Reade\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Shanaze Reade\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Shanaze_Reade\", \"dbpedia\": \"http://dbpedia.org/resource/Shanaze_Reade\"}]}, {\"sentence\": \"Willoughby also won her seventh career world medal, extending a women's record she already owned.\", \"from\": 1095, \"to\": 1192, \"entities\": []}, {\"sentence\": \"Brit Bethany Shriever and Paj\\u00f3n, the last two Olympic champions, crashed out of the same semifinal.\", \"from\": 1194, \"to\": 1293, \"entities\": []}, {\"sentence\": \"In Saturday's men's race, France's Joris Daudet won his third world title ahead of Tokyo Olympic gold medalist Niek Kimmann.\", \"from\": 1295, \"to\": 1419, \"entities\": [{\"begin\": 1321, \"end\": 1327, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9695314641536318, \"rank\": 0.028856814696621512, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 1330, \"end\": 1342, \"title\": \"http://dbpedia.org/resource/Joris_Daudet\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Joris Daudet\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Joris_Daudet\", \"dbpedia\": \"http://dbpedia.org/resource/Joris_Daudet\"}, {\"begin\": 1378, \"end\": 1383, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.9989884046759585, \"rank\": 0.001011673260582844, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}, {\"begin\": 1406, \"end\": 1418, \"title\": \"http://dbpedia.org/resource/Niek_Kimmann\", \"score\": 0.9999999991200639, \"rank\": 0.0, \"text\": \"Niek Kimmann\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Niek_Kimmann\", \"dbpedia\": \"http://dbpedia.org/resource/Niek_Kimmann\"}]}, {\"sentence\": \"Cameron Wood, the highest-ranked American man, was taken out of his quarterfinal when another rider crashed into him.\", \"from\": 1421, \"to\": 1538, \"entities\": [{\"begin\": 1421, \"end\": 1433, \"title\": \"http://dbpedia.org/resource/Cameron_Wood\", \"score\": 0.9999999999959073, \"rank\": 0.0, \"text\": \"Cameron Wood\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q13414980\"], \"wikid\": \"http://dbpedia.org/resource/Cameron_Wood\", \"dbpedia\": \"http://dbpedia.org/resource/Cameron_Wood\"}, {\"begin\": 1454, \"end\": 1462, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.999934837635181, \"rank\": 5.918312534503951e-05, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}]}, {\"sentence\": \"Wood was OK afterward, according to USA Cycling, and qualified for the Olympicsvia national team point standings.\", \"from\": 1539, \"to\": 1652, \"entities\": [{\"begin\": 1575, \"end\": 1586, \"title\": \"http://dbpedia.org/resource/USA_Cycling\", \"score\": 1.0, \"rank\": 2.834663716318189e-17, \"text\": \"USA Cycling\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/USA_Cycling\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Cycling\"}]}, {\"sentence\": \"Wood missed last August's world championships after left shoulder surgery, then reinjured the shoulder in February and returned to competition in April.\", \"from\": 1654, \"to\": 1806, \"entities\": []}, {\"sentence\": \"A Division ofNBCUniversal.\", \"from\": 1810, \"to\": 1836, \"entities\": [{\"begin\": 1810, \"end\": 1820, \"title\": \"http://dbpedia.org/resource/Scottish_Football_League\", \"score\": 0.9999973688318787, \"rank\": 2.6311748744424074e-06, \"text\": \"A Division\", \"types\": [\"Q623109\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Scottish_Football_League\", \"dbpedia\": \"http://dbpedia.org/resource/Scottish_Football_League\"}]}, {\"sentence\": \"DISCLAIMER: This site and the products offered are for entertainment purposes only, and there is no gambling offered on this site.\", \"from\": 1838, \"to\": 1968, \"entities\": []}, {\"sentence\": \"This service is intended for adult audiences.\", \"from\": 1969, \"to\": 2014, \"entities\": []}, {\"sentence\": \"No guarantees are made for any specific outcome.\", \"from\": 2015, \"to\": 2063, \"entities\": []}, {\"sentence\": \"If you or someone you know has a gambling problem, please call 1-800-GAMBLER.\", \"from\": 2064, \"to\": 2141, \"entities\": []}, {\"sentence\": \"\\u24b8 2024 NBC Universal\", \"from\": 2143, \"to\": 2163, \"entities\": []}]}"