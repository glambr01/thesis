"{\"uid\": \"nbcsports.com-olympics-news-usa-womens-sitting-volleyball-team-roster-paralympics-paris\", \"entities\": [{\"sentence\": \"The U.S. women's sitting volleyball team for Paris includes 11 returning gold medalists and three moms.\", \"from\": 0, \"to\": 103, \"entities\": [{\"begin\": 45, \"end\": 50, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999974589539303, \"rank\": 2.5410524733431402e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"The 12-player squad will try to become the first U.S. volleyball team to win three consecutive titles at a Paralympics or an Olympics.\", \"from\": 105, \"to\": 239, \"entities\": []}, {\"sentence\": \"The roster was announced Wednesday.\", \"from\": 241, \"to\": 276, \"entities\": []}, {\"sentence\": \"The three moms are five-time medalist Lora Webster-Bargellini, who competed in Tokyo while pregnant with her fourth child; four-time medalist Katie Holloway Bridge, the Tokyo Paralympic MVP, and three-time medalist Kaleo Kanahele Maclay, named best setter at the Tokyo Games.\", \"from\": 278, \"to\": 553, \"entities\": [{\"begin\": 316, \"end\": 320, \"title\": \"http://dbpedia.org/resource/Lora_prison_camp\", \"score\": 0.9999748118712377, \"rank\": 1.0711546273916777e-05, \"text\": \"Lora\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Lora_prison_camp\", \"dbpedia\": \"http://dbpedia.org/resource/Lora_prison_camp\"}, {\"begin\": 357, \"end\": 362, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.9960391191816368, \"rank\": 0.003976279182810898, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}, {\"begin\": 426, \"end\": 434, \"title\": \"http://dbpedia.org/resource/HM_Prison_Holloway\", \"score\": 0.9998831559113556, \"rank\": 0.000114400766555052