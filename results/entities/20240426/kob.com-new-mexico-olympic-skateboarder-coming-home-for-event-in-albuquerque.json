"{\"uid\": \"kob.com-new-mexico-olympic-skateboarder-coming-home-for-event-in-albuquerque\", \"entities\": [{\"sentence\": \"ALBUQUERQUE, N.M. - An Albuquerque native and Olympic skateboarder will appear at a skate and food truck event Saturday in the South Valley.\", \"from\": 0, \"to\": 140, \"entities\": [{\"begin\": 0, \"end\": 17, \"title\": \"http://dbpedia.org/resource/Albuquerque,_New_Mexico\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"ALBUQUERQUE, N.M.\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Albuquerque,_New_Mexico\", \"dbpedia\": \"http://dbpedia.org/resource/Albuquerque,_New_Mexico\"}]}, {\"sentence\": \"Mariah Duran will appear at the South Valley Skate and Food Truck Fest, April 27.\", \"from\": 142, \"to\": 223, \"entities\": [{\"begin\": 142, \"end\": 154, \"title\": \"http://dbpedia.org/resource/Mariah_Duran\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Mariah Duran\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Mariah_Duran\", \"dbpedia\": \"http://dbpedia.org/resource/Mariah_Duran\"}]}, {\"sentence\": \"It's happening at the Rio Bravo Skate Park from 11 a.m. to 2 p.m., and is open to the public.\", \"from\": 224, \"to\": 317, \"entities\": [{\"begin\": 246, \"end\": 255, \"title\": \"http://dbpedia.org/resource/Rio_Grande\", \"score\": 0.9999999997778559, \"rank\": 2.2211426596116515e-10, \"text\": \"Rio Bravo\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Rio_Grande\", \"dbpedia\": \"http://dbpedia.org/resource/Rio_Grande\"}]}, {\"sentence\": \"U.S. Eagle Federal Credit Union will host Duran.\", \"from\": 319, \"to\": 367, \"entities\": [{\"begin\": 345, \"end\": 350, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999994970072649, \"rank\": 4.984583056121473e-07, \"text\": \"Union\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}]}, {\"sentence\": \"She will hold a skateboard clinic, teach tips and tricks to skateboarders, showcase skateboarding styles and meet with the community and sign autographs.\", \"from\": 368, \"to\": 521, \"entities\": []}, {\"sentence\": \"Guests are encouraged to bring nonperishable food items to support the Rio Grande Food Project, the largest food pantry on Albuquerque's West Side.\", \"from\": 523, \"to\": 670, \"entities\": [{\"begin\": 594, \"end\": 604, \"title\": \"http://dbpedia.org/resource/Rio_Grande\", \"score\": 0.9999992649602946, \"rank\": 4.1803374540448155e-07, \"text\": \"Rio Grande\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Rio_Grande\", \"dbpedia\": \"http://dbpedia.org/resource/Rio_Grande\"}, {\"begin\": 646, \"end\": 657, \"title\": \"http://dbpedia.org/resource/Albuquerque_International_Sunport\", \"score\": 0.9946828121810061, \"rank\": 0.00484218309433139, \"text\": \"Albuquerque\", \"types\": [\"Q1248784\"], \"wikid\": \"http://dbpedia.org/resource/Albuquerque_International_Sunport\", \"dbpedia\": \"http://dbpedia.org/resource/Albuquerque_International_Sunport\"}]}, {\"sentence\": \"The event will also feature prizes and food trucks for attendees.\", \"from\": 671, \"to\": 736, \"entities\": []}, {\"sentence\": \"Duran will compete in the Paris Olympics as a part of the USA Skateboarding Team.\", \"from\": 738, \"to\": 819, \"entities\": [{\"begin\": 796, \"end\": 813, \"title\": \"http://dbpedia.org/resource/USA_Skateboarding_National_Team\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"USA Skateboarding\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/USA_Skateboarding_National_Team\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Skateboarding_National_Team\"}]}, {\"sentence\": \"Already she has won gold in the X Games and competed in the inaugural USA Skateboarding Team during the 2020 Tokyo Games.\", \"from\": 820, \"to\": 941, \"entities\": [{\"begin\": 890, \"en