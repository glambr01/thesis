d1b076af982df1154830425c10f4d&focal=0%2C0&width=90&height=60", "https://www.deseret.com/resizer/v2/M4VMHMTUIRBWNPVUZZAOF25F5A.JPG?auth=a68b0dc7a3ffff733ffd6d830a2fe6db405f9abbba6876d263ce5bf9cafd9239&focal=0%2C0&width=90&height=60", "https://www.deseret.com/resizer/v2/B2NEXNZUP5HV3AWNOOSTCCTTWQ.JPG?auth=ce062dc957fdd075589396a94f436486f2cb794009769d0453b5c7ea49cc3d47&focal=0%2C0&width=90&height=60", "https://uploads.deseret.com/deseretnews/icons/shop.svg?d=317"], "publication-date": "2024-07-24", "text": "The International Olympic Committee made it official Wednesday. The Winter Olympics areheaded backto Salt Lake City.\n\nWhile Utah’s delegation made its final pitch before the IOC vote in Paris for the2034 Winter Games,a crowd was gathering in Washington Squareawaiting the announcement.\n\nThe decision came in at 4:21 a.m. MDT.\n\nDeseret News videographers and photojournalists were there to capture the historic moment when Utah was awarded the Winter Games for the second time.", "title": "Video: Watch Salt Lake City celebrate 2034 Olympics announcement – Deseret News", "top-image": "https://www.deseret.com/resizer/v2/5D4B3K4PSNBZ3NN46LPGVKFWQA.JPG?auth=dbec9c28320880621dc9a5edcb882ff874b8d429fb1758bcab4c2181dc971c57&focal=0%2C0&width=800&height=533", "domain": "www.deseret.com", "lang": "en", "author": "", "description": "IOC awards 2034 Olympics to Salt Lake City. Watch footage from downtown Salt Lake as IOC announcement is played.", "keywords": "olympics,news-feed-local"}