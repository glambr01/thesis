]}, {\"sentence\": \"Denilson arrived today (yesterday).\", \"from\": 917, \"to\": 952, \"entities\": [{\"begin\": 917, \"end\": 925, \"title\": \"http://dbpedia.org/resource/Den\\u00edlson_(footballer,_born_1976)\", \"score\": 0.5188401434638829, \"rank\": 0.8333333333332769, \"text\": \"Denilson\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Den\\u00edlson_(footballer,_born_1976)\", \"dbpedia\": \"http://dbpedia.org/resource/Den\\u00edlson_(footballer,_born_1976)\"}]}, {\"sentence\": \"We are expecting Paige later on today (yesterday).\", \"from\": 953, \"to\": 1003, \"entities\": [{\"begin\": 970, \"end\": 975, \"title\": \"http://dbpedia.org/resource/Satchel_Paige\", \"score\": 0.6332343978315815, \"rank\": 0.5781807450504726, \"text\": \"Paige\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Satchel_Paige\", \"dbpedia\": \"http://dbpedia.org/resource/Satchel_Paige\"}]}, {\"sentence\": \"\\\"We also have the physiotherapist, Abigail Mnikwa.\", \"from\": 1005, \"to\": 1055, \"entities\": [{\"begin\": 1040, \"end\": 1047, \"title\": \"http://dbpedia.org/resource/Abigail_Adams\", \"score\": 0.995156392442007, \"rank\": 0.004856017955427515, \"text\": \"Abigail\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Abigail_Adams\", \"dbpedia\": \"http://dbpedia.org/resource/Abigail_Adams\"}]}, {\"sentence\": \"And I have the swimming coach (Masi Takaedza), who arrived yesterday (Sunday),\\\" he said.\", \"from\": 1056, \"to\": 1144, \"entities\": []}, {\"sentence\": \"Mapondera said they were expecting to have a complement of five in the next two, three days.\", \"from\": 1146, \"to\": 1238, \"entities\": []}, {\"sentence\": \"Besides attending the official opening ceremony, VP Chiwenga has a number of business meetings lined up as the Second Republic continues to further its engagement and re-engagement diplomatic offensive.\", \"fr