"{\"uid\": \"nbcsports.com-pressbox-press-releases-nbcuniversal-enhances-accessibility-for-its-coverage-of-the-olympic-games-paris-2024\", \"entities\": [{\"sentence\": \"NBCU to Offer Closed Captioning, Audio Description, and Web Content Accessibility    Closed Captioning to be Provided for All Coverage with Commentary in English and Spanish    2024 Paris Olympics to Feature More Audio Description than Ever Before, Including All Coverage on NBC and theGold ZoneWhip-Around Show on Peacock  STAMFORD, Conn. - June 25, 2024 -NBCUniversal's coverage of the Olympic Games Paris 2024 will be accessible to more viewers of all abilities than ever before, providing the excitement of the Olympic with enhanced closed captioning, expanded audio description, and improved digital content accessibility.\", \"from\": 0, \"to\": 627, \"entities\": [{\"begin\": 0, \"end\": 4, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"NBCU\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}, {\"begin\": 275, \"end\": 278, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.683950296634214, \"rank\": 0.46209454807483813, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}, {\"begin\": 324, \"end\": 332, \"title\": \"http://dbpedia.org/resource/Stamford_Transportation_Center\", \"score\": 0.9999999993192432, \"rank\": 6.80802739444144e-10, \"text\": \"STAMFORD\", \"types\": [\"Q719456\"], \"wikid\": \"http://dbpedia.org/resource/Stamford_Transportation_Center\", \"dbpedia\": \"http://dbpedia.org/resource/Stamford_Transportation_Center\"}]}, {\"sentence\": \"Closed captioning, which provides text of the coverage audio for viewers who are Deaf or hard of hearing, will be available for all Olympic events airing across NBCU's broadcast and cable networks.\", \"from\": 629, \"to\": 826, \"entities\": [{\"begin\": 790, \"end\": 794, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"NBCU\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}]}, {\"sentence\": \"NBCUniversal will also provide closed captioning for all digital livestreams with commentary across Peacock, NBCSports.com and the NBC Sports app.\", \"from\": 827, \"to\": 973, \"entities\": [{\"begin\": 827, \"end\": 839, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 1.0, \"rank\": 1.4954560922230907e-17, \"text\": \"NBCUniversal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}, {\"begin\": 927, \"end\": 934, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.9999999998844942, \"rank\": 1.1540400888144691e-10, \"text\": \"Peacock\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Peafowl\", \"dbpedia\": \"http://dbpedia.org/resource/Peafowl\"}, {\"begin\": 936, \"end\": 949, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"NBCSports.com\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}, {\"begin\": 958, \"end\": 968, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.9999902292120029, \"rank\": 9.770784259316898e-06, \"text\": \"NBC Sports\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}]}, {\"sentence\": \"More audio description services - interspersing broadcast audio with skilled voices describing Olympic scenes and context - will be available for viewers who are blind or visually impaired for the Paris Olympics than any previous Games.\", \"from\": 975, \"to\": 1211, \"entities\": []}, {\"sentence\": \"All coverage on NBC, including daytime, primetime, and late night, and theGold Zonewhip-around showon Peacock, will feature audio description provided by Descriptive Video Works.\", \"from\": 1212, \"to\": 1390, \"entities\": [{\"begin\": 1228, \"end\": 1231, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.683950296634214, \"rank\": 0.46209454807483813, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}]}, {\"sentence\": \"In a first for a U.S. broadcaster, audio description services for NBC coverage will be provided in stereo, enhancing the quality of sound for viewers.\", \"from\": 1391, \"to\": 1541, \"entities\": [{\"begin\": 1457, \"end\": 1460, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.683950296634214, \"rank\": 0.46209454807483813, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}]}, {\"sentence\": \"Additionally, improved web content accessibility, including keyboard navigation, color contrast and support for screen readers, will be available on NBCOlympics.com, NBC.com, the NBC Sports app, and Peacock.\", \"from\": 1543, \"to\": 1750, \"entities\": [{\"begin\": 1709, \"end\": 1716, \"title\": \"http://dbpedia.org/resource/NBC\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"NBC.com\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/NBC\", \"dbpedia\": \"http://dbpedia.org/resource/NBC\"}, {\"begin\": 1722, \"end\": 1732, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.9999902292120029, \"rank\": 9.770784259316898e-06, \"text\": \"NBC Sports\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}, {\"begin\": 1742, \"end\": 1749, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.9999999998844942, \"rank\": 1.1540400888144691e-10, \"text\": \"Peacock\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Peafowl\", \"dbpedia\": \"http://dbpedia.org/resource/Peafowl\"}]}, {\"sentence\": \"Livestreams and replays which offer audio description will have English audio description as a language choice within the players on these digital platforms.\", \"from\": 1751, \"to\": 1908, \"entities\": [{\"begin\": 1815, \"end\": 1822, \"title\": \"http://dbpedia.org/resource/English_language\", \"score\": 0.9999999999931788, \"rank\": 2.8501157103151255e-12, \"text\": \"English\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/English_language\", \"dbpedia\": \"http://dbpedia.org/resource/English_language\"}]}, {\"sentence\": \"To easily find all events with audio description, clickhere.\", \"from\": 1909, \"to\": 1969, \"entities\": []}, {\"sentence\": \"To contact NBCUniversal about issues related to closed captions, please send an email to CCFeedback@nbcuni.com.\", \"from\": 1971, \"to\": 2082, \"entities\": []}, {\"sentence\": \"For audio description issues, email ADFeedback@nbcuni.com  \\\"We are excited to provide all viewers with more accessibility to our Olympics coverage than ever before,\\\" saidGary Zenkel, President, NBC Olympics.\", \"from\": 2083, \"to\": 2290, \"entities\": [{\"begin\": 2277, \"end\": 2289, \"title\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"NBC Olympics\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\"}]}, {\"sentence\": \"\\\"With the goal of enabling all viewers to enjoy the unprecedented excitement of the Olympic Games in Paris, we are proud to provide closed captioning on all live coverage and the most audio description ever.\\\"\", \"from\": 2291, \"to\": 2499, \"entities\": [{\"begin\": 2392, \"end\": 2397, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.462873003403436e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"All of this audio description and closed captioning will be available to Comcast Xfinity customers who experience the Games on the Xfinity X1 platform, including on the live Olympic Games coverage delivered in 4K, on Xfinity Stream, and on Xfinity Flex.\", \"from\": 2501, \"to\": 2754, \"entities\": [{\"begin\": 2574, \"end\": 2589, \"title\": \"http://dbpedia.org/resource/Comcast\", \"score\": 0.9999999999872671, \"rank\": 1.285090974996118e-11, \"text\": \"Comcast Xfinity\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Comcast\", \"dbpedia\": \"http://dbpedia.org/resource/Comcast\"}, {\"begin\": 2718, \"end\": 2725, \"title\": \"http://dbpedia.org/resource/Comcast\", \"score\": 0.9999999999345164, \"rank\": 6.546120694229028e-11, \"text\": \"Xfinity\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Comcast\", \"dbpedia\": \"http://dbpedia.org/resource/Comcast\"}, {\"begin\": 2741, \"end\": 2753, \"title\": \"http://dbpedia.org/resource/Xfinity_Flex\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Xfinity Flex\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Xfinity_Flex\", \"dbpedia\": \"http://dbpedia.org/resource/Xfinity_Flex\"}]}, {\"sentence\": \"\\\"For over a decade, Comcast NBCUniversal has been committed to connecting people to moments that matter,\\\" saidTom Wlodkowski, Vice President of Accessibility at Comcast.\", \"from\": 2756, \"to\": 2925, \"entities\": [{\"begin\": 2784, \"end\": 2796, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 1.0, \"rank\": 1.4954560922230907e-17, \"text\": \"NBCUniversal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}]}, {\"sentence\": \"\\\"NBCUniversal's accessible coverage for this year's Olympic Games is an important part of our mission.\", \"from\": 2926, \"to\": 3028, \"entities\": [{\"begin\": 2927, \"end\": 2939, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 1.0, \"rank\": 1.4954560922230907e-17, \"text\": \"NBCUniversal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}]}, {\"sentence\": \"As a consumer of Olympics programming with audio description, I could not be more excited to share in the joy that these Paris Summer Games will bring.\\\"\", \"from\": 3029, \"to\": 3181, \"entities\": []}, {\"sentence\": \"***  In Paris this summer, the world's greatest athletes will compete against the backdrop of one of the most beautiful cities in the world where the modern Olympic Games were conceived 130 years ago.\", \"from\": 3183, \"to\": 3383, \"entities\": [{\"begin\": 3191, \"end\": 3196, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.462873003403436e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"This will be the third time Paris has hosted the Olympics (1900 and 1924), tying London for the most as a Summer Games host.\", \"from\": 3384, \"to\": 3508, \"entities\": [{\"begin\": 3412, \"end\": 3417, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.462873003403436e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 3465, \"end\": 3471, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9999998777634648, \"rank\": 8.780368622985548e-08, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}]}, {\"sentence\": \"Los Angeles (1932, 1984) will tie those two cities when it hosts the first Summer Games in the U.S. in 32 years in 2028.\", \"from\": 3509, \"to\": 3629, \"entities\": [{\"begin\": 3509, \"end\": 3520, \"title\": \"http://dbpedia.org/resource/Los_Angeles\", \"score\": 0.9999999995088729, \"rank\": 4.846088198028359e-10, \"text\": \"Los Angeles\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Los_Angeles\", \"dbpedia\": \"http://dbpedia.org/resource/Los_Angeles\"}]}, {\"sentence\": \"The Paris organizers are reimagining the Games to make them more accessible to the public and to showcase their city to the world.\", \"from\": 3631, \"to\": 3761, \"entities\": [{\"begin\": 3635, \"end\": 3640, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.462873003403436e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"In a first, competitions will be held amidst iconic Parisian landmarks - beach volleyball at the Eiffel Tower, equestrian at the Palace of Versailles, and urban sports at Place de la Concorde.\", \"from\": 3762, \"to\": 3954, \"entities\": [{\"begin\": 3933, \"end\": 3953, \"title\": \"http://dbpedia.org/resource/Place_de_la_Concorde\", \"score\": 0.999999999996362, \"rank\": 3.703348723783083e-12, \"text\": \"Place de la Concorde\", \"types\": [\"Q34442\"], \"wikid\": \"http://dbpedia.org/resource/Place_de_la_Concorde\", \"dbpedia\": \"http://dbpedia.org/resource/Place_de_la_Concorde\"}]}, {\"sentence\": \"The surfing competition will take place nearly 10,000 miles from Paris in Tahiti, a part of French Polynesia.\", \"from\": 3955, \"to\": 4064, \"entities\": [{\"begin\": 4020, \"end\": 4025, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.462873003403436e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 4029, \"end\": 4035, \"title\": \"http://dbpedia.org/resource/Tahiti\", \"score\": 0.9999992891469245, \"rank\": 7.108337005475302e-07, \"text\": \"Tahiti\", \"types\": [\"Q23442\"], \"wikid\": \"http://dbpedia.org/resource/Tahiti\", \"dbpedia\": \"http://dbpedia.org/resource/Tahiti\"}]}, {\"sentence\": \"The NBC broadcast network and streaming service Peacock will be the company's primary platforms for its coverage of the Olympic Games Paris 2024, scheduled for July 26-Aug. 11.\", \"from\": 4066, \"to\": 4242, \"entities\": [{\"begin\": 4070, \"end\": 4073, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.683950296634214, \"rank\": 0.46209454807483813, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}]}, {\"sentence\": \"Clickherefor more linear programming information andherefor more about the Olympic experience on Peacock.\", \"from\": 4243, \"to\": 4348, \"entities\": [{\"begin\": 4340, \"end\": 4347, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.9999999998844942, \"rank\": 1.1540400888144691e-10, \"text\": \"Peacock\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Peafowl\", \"dbpedia\": \"http://dbpedia.org/resource/Peafowl\"}]}, {\"sentence\": \"NBC and Peacock will present live coverage of theOpening Ceremonyon Friday, July 26, beginning at Noon ET.\", \"from\": 4349, \"to\": 4455, \"entities\": [{\"begin\": 4349, \"end\": 4352, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.683950296634214, \"rank\": 0.46209454807483813, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}, {\"begin\": 4357, \"end\": 4364, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.9999999998844942, \"rank\": 1.1540400888144691e-10, \"text\": \"Peacock\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Peafowl\", \"dbpedia\": \"http://dbpedia.org/resource/Peafowl\"}]}, {\"sentence\": \"Telemundo will provide Spanish-language coverage beginning at 1 p.m.\", \"from\": 4456, \"to\": 4524, \"entities\": [{\"begin\": 4456, \"end\": 4465, \"title\": \"http://dbpedia.org/resource/Telemundo\", \"score\": 0.9999999999222382, \"rank\": 7.789618188106175e-11, \"text\": \"Telemundo\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/Telemundo\", \"dbpedia\": \"http://dbpedia.org/resource/Telemundo\"}]}, {\"sentence\": \"ET.\", \"from\": 4525, \"to\": 4528, \"entities\": []}, {\"sentence\": \"Primetime coverage will begin at 7:30 p.m. ET/PT on NBC and Peacock.\", \"from\": 4529, \"to\": 4597, \"entities\": [{\"begin\": 4581, \"end\": 4584, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.683950296634214, \"rank\": 0.46209454807483813, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}, {\"begin\": 4589, \"end\": 4596, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.9999999998844942, \"rank\": 1.1540400888144691e-10, \"text\": \"Peacock\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Peafowl\", \"dbpedia\": \"http://dbpedia.org/resource/Peafowl\"}]}, {\"sentence\": \"NBCUniversal owns the U.S. media rights to the Olympic Games through 2032, which are scheduled for Paris (2024), Milan Cortina (2026), Los Angeles (2028) and Brisbane (2032).\", \"from\": 4599, \"to\": 4773, \"entities\": [{\"begin\": 4599, \"end\": 4611, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 1.0, \"rank\": 1.4954560922230907e-17, \"text\": \"NBCUniversal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}, {\"begin\": 4698, \"end\": 4703, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.462873003403436e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"The host city for the 2030 Olympic Winter Games has not yet been chosen.\", \"from\": 4774, \"to\": 4846, \"entities\": []}, {\"sentence\": \"ABOUT NBCUNIVERSAL  NBCUniversal is one of the world's leading media and entertainment companies.\", \"from\": 4848, \"to\": 4945, \"entities\": [{\"begin\": 4854, \"end\": 4866, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 1.0, \"rank\": 1.4954560922230907e-17, \"text\": \"NBCUNIVERSAL\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}, {\"begin\": 4868, \"end\": 4880, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 1.0, \"rank\": 1.4954560922230907e-17, \"text\": \"NBCUniversal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}]}, {\"sentence\": \"We create world-class content, which we distribute across our portfolio of film, television, and streaming, and bring to life through our theme parks and consumer experiences.\", \"from\": 4946, \"to\": 5121, \"entities\": []}, {\"sentence\": \"We own and operate leading entertainment and news brands, including NBC, NBC News, MSNBC, CNBC, NBC Sports, Telemundo, NBC Local Stations, Bravo, USA Network, and Peacock, our premium ad-supported streaming service.\", \"from\": 5122, \"to\": 5337, \"entities\": [{\"begin\": 5190, \"end\": 5193, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.683950296634214, \"rank\": 0.46209454807483813, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}]}, {\"sentence\": \"We produce and distribute premier filmed entertainment and programming through Universal Filmed Entertainment Group and Universal Studio Group, and have world-renowned theme parks and attractions through Universal Destinations & Experiences.\", \"from\": 5338, \"to\": 5579, \"entities\": [{\"begin\": 5417, \"end\": 5453, \"title\": \"http://dbpedia.org/resource/Universal_Pictures\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Universal Filmed Entertainment Group\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Universal_Pictures\", \"dbpedia\": \"http://dbpedia.org/resource/Universal_Pictures\"}, {\"begin\": 5458, \"end\": 5480, \"title\": \"http://dbpedia.org/resource/NBCUniversal_Television_and_Streaming\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Universal Studio Group\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal_Television_and_Streaming\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal_Television_and_Streaming\"}]}, {\"sentence\": \"NBCUniversal is a subsidiary of Comcast Corporation.\", \"from\": 5580, \"to\": 5632, \"entities\": [{\"begin\": 5580, \"end\": 5592, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 1.0, \"rank\": 1.4954560922230907e-17, \"text\": \"NBCUniversal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}, {\"begin\": 5612, \"end\": 5631, \"title\": \"http://dbpedia.org/resource/Comcast\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Comcast Corporation\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Comcast\", \"dbpedia\": \"http://dbpedia.org/resource/Comcast\"}]}, {\"sentence\": \"--NBC OLYMPICS-  A Division ofNBCUniversal.\", \"from\": 5636, \"to\": 5679, \"entities\": [{\"begin\": 5653, \"end\": 5663, \"title\": \"http://dbpedia.org/resource/Scottish_Football_League\", \"score\": 0.9999999999859028, \"rank\": 1.3963858359708867e-11, \"text\": \"A Division\", \"types\": [\"Q623109\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Scottish_Football_League\", \"dbpedia\": \"http://dbpedia.org/resource/Scottish_Football_League\"}]}, {\"sentence\": \"DISCLAIMER: This site and the products offered are for entertainment purposes only, and there is no gambling offered on this site.\", \"from\": 5681, \"to\": 5811, \"entities\": []}, {\"sentence\": \"This service is intended for adult audiences.\", \"from\": 5812, \"to\": 5857, \"entities\": []}, {\"sentence\": \"No guarantees are made for any specific outcome.\", \"from\": 5858, \"to\": 5906, \"entities\": []}, {\"sentence\": \"If you or someone you know has a gambling problem, please call 1-800-GAMBLER.\", \"from\": 5907, \"to\": 5984, \"entities\": []}, {\"sentence\": \"\\u24b8 2024 NBC Universal\", \"from\": 5986, \"to\": 6006, \"entities\": []}]}"