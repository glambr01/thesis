\"}, {\"begin\": 1860, \"end\": 1863, \"title\": \"http://dbpedia.org/resource/LSU_Tigers_football\", \"score\": 0.9037137725420928, \"rank\": 0.08831438456066913, \"text\": \"LSU\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/LSU_Tigers_football\", \"dbpedia\": \"http://dbpedia.org/resource/LSU_Tigers_football\"}, {\"begin\": 1864, \"end\": 1873, \"title\": \"http://dbpedia.org/resource/Tennessee_Volunteers\", \"score\": 0.9998713205669498, \"rank\": 0.00012120831071991252, \"text\": \"Tennessee\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/Tennessee_Volunteers\", \"dbpedia\": \"http://dbpedia.org/resource/Tennessee_Volunteers\"}, {\"begin\": 1875, \"end\": 1883, \"title\": \"http://dbpedia.org/resource/Arkansas_Razorbacks\", \"score\": 0.9999597870555803, \"rank\": 2.4484306743386782e-05, \"text\": \"Arkansas\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/Arkansas_Razorbacks\", \"dbpedia\": \"http://dbpedia.org/resource/Arkansas_Razorbacks\"}]}, {\"sentence\": \"The other three are now Big Ten institutions (USC,Michigan, UCLA).\", \"from\": 1886, \"to\": 1952, \"entities\": [{\"begin\": 1932, \"end\": 1935, \"title\": \"http://dbpedia.org/resource/USC_Trojans\", \"score\": 0.9986858385478579, \"rank\": 0.0013158230335256545, \"text\": \"USC\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/USC_Trojans\", \"dbpedia\": \"http://dbpedia.org/resource/USC_Trojans\"}, {\"begin\": 1946, \"end\": 1950, \"title\": \"http://dbpedia.org/resource/UCLA_Bruins\", \"score\": 0.9997732693399989, \"rank\": 0.00022674127800476244, \"text\": \"UCLA\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/UCLA_Bruins\", \"dbpedia\": \"http://dbpedia.org/resource/UCLA_Bruins\"}]}, {\"sentence\": \"The first Big 12 school we get to is Arizona State at No.\", \"from\": 1953, \"to\":