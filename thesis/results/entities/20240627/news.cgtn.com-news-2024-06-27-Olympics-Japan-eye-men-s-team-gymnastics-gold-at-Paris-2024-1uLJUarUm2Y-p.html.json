"{\"uid\": \"news.cgtn.com-news-2024-06-27-Olympics-Japan-eye-men-s-team-gymnastics-gold-at-Paris-2024-1uLJUarUm2Y-p.html\", \"entities\": [{\"sentence\": \"Our Privacy Statement & Cookie Policy  By continuing to browse our site you agree to our use of cookies, revised Privacy Policy and Terms of Use.\", \"from\": 0, \"to\": 145, \"entities\": []}, {\"sentence\": \"You can change your cookie settings through your browser.\", \"from\": 146, \"to\": 203, \"entities\": []}, {\"sentence\": \"Sports Scene  Copied  Having missed the men's gymnastics team title by a hair at the Tokyo Summer Olympics, Japan are determined to beat their biggest rivals China and take gold in Paris, setting that goal as their top priority with less than one month left until the Games begin.\", \"from\": 205, \"to\": 485, \"entities\": [{\"begin\": 313, \"end\": 318, \"title\": \"http://dbpedia.org/resource/Japan\", \"score\": 0.9999999999990905, \"rank\": 3.76747469383612e-13, \"text\": \"Japan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Japan\", \"dbpedia\": \"http://dbpedia.org/resource/Japan\"}, {\"begin\": 363, \"end\": 368, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9381970247967566, \"rank\": 0.06192129563232307, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}, {\"begin\": 386, \"end\": 391, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999167812, \"rank\": 8.321650772081032e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"During the Tokyo Olympics, Russia beat Japan by 0.103 points \\u00e2\\u0080\\u0093 a sliver of a number that etched itself into the minds of the three Japanese gymnasts and their head coach, who will be returning to the Games looking to erase those painful memories.\", \"from\": 487, \"to\": 735, \"entities\": [{\"begin\": 514, \"end\": 520, \"title\": \"http://dbpedia.org/resource/Russia_men's_national_ice_hockey_team\", \"score\": 0.9679922930235372, \"rank\": 0.03299959483863384, \"text\": \"Russia\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Russia_men's_national_ice_hockey_team\", \"dbpedia\": \"http://dbpedia.org/resource/Russia_men's_national_ice_hockey_team\"}, {\"begin\": 526, \"end\": 531, \"title\": \"http://dbpedia.org/resource/Japan\", \"score\": 0.9999999999990905, \"rank\": 3.76747469383612e-13, \"text\": \"Japan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Japan\", \"dbpedia\": \"http://dbpedia.org/resource/Japan\"}, {\"begin\": 620, \"end\": 637, \"title\": \"http://dbpedia.org/resource/Japan_at_the_1952_Summer_Olympics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Japanese gymnasts\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Japan_at_the_1952_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Japan_at_the_1952_Summer_Olympics\"}]}, {\"sentence\": \"\\\"We had the bitter experience of losing by the narrowest of margins, by 0.103,\\\" all-around titleholder Daiki Hashimoto told Reuters after a team training session in Tokyo last week.\", \"from\": 737, \"to\": 918, \"entities\": [{\"begin\": 840, \"end\": 855, \"title\": \"http://dbpedia.org/resource/Daiki_Hashimoto\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Daiki Hashimoto\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Daiki_Hashimoto\", \"dbpedia\": \"http://dbpedia.org/resource/Daiki_Hashimoto\"}, {\"begin\": 861, \"end\": 868, \"title\": \"http://dbpedia.org/resource/Reuters\", \"score\": 0.9999999683709581, \"rank\": 3.162887275192046e-08, \"text\": \"Reuters\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Reuters\", \"dbpedia\": \"http://dbpedia.org/resource/Reuters\"}, {\"begin\": 902, \"end\": 907, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 1.0, \"rank\": 1.4937983910032014e-18, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}]}, {\"sentence\": \"\\\"I want us to win that gold and enjoy the view from the podium.\\\"\", \"from\": 919, \"to\": 983, \"entities\": []}, {\"sentence\": \"\\\"After losing to Russia by 0.103 in Tokyo, we have been working hard towards Paris fueled by a sense of revenge, so there is a part of me that's a bit sad that they will not be there,\\\" said Japan head coach Hisashi Mizutori, a former team gold medalist.\", \"from\": 985, \"to\": 1238, \"entities\": [{\"begin\": 1002, \"end\": 1008, \"title\": \"http://dbpedia.org/resource/Russia_men's_national_ice_hockey_team\", \"score\": 0.9679922930235372, \"rank\": 0.03299959483863384, \"text\": \"Russia\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Russia_men's_national_ice_hockey_team\", \"dbpedia\": \"http://dbpedia.org/resource/Russia_men's_national_ice_hockey_team\"}, {\"begin\": 1021, \"end\": 1026, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 1.0, \"rank\": 1.4937983910032014e-18, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}, {\"begin\": 1062, \"end\": 1067, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999167812, \"rank\": 8.321650772081032e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 1175, \"end\": 1180, \"title\": \"http://dbpedia.org/resource/Japan\", \"score\": 0.9999999999990905, \"rank\": 3.76747469383612e-13, \"text\": \"Japan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Japan\", \"dbpedia\": \"http://dbpedia.org/resource/Japan\"}, {\"begin\": 1192, \"end\": 1208, \"title\": \"http://dbpedia.org/resource/Hisashi_Mizutori\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Hisashi Mizutori\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Hisashi_Mizutori\", \"dbpedia\": \"http://dbpedia.org/resource/Hisashi_Mizutori\"}]}, {\"sentence\": \"\\\"Still, it's a big chance for us to grab that medal, so we will do what we need to do.\\\"\", \"from\": 1239, \"to\": 1326, \"entities\": []}, {\"sentence\": \"A victory by Japan this summer would extend the country's record to eight team golds.\", \"from\": 1328, \"to\": 1413, \"entities\": [{\"begin\": 1341, \"end\": 1346, \"title\": \"http://dbpedia.org/resource/Japan\", \"score\": 0.9999999999990905, \"rank\": 3.76747469383612e-13, \"text\": \"Japan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Japan\", \"dbpedia\": \"http://dbpedia.org/resource/Japan\"}]}, {\"sentence\": \"The Japanese squad said they have full confidence in being able to do so, thanks to a well-balanced team and their superior collective difficulty score (or \\\"D-score\\\") over China.\", \"from\": 1414, \"to\": 1592, \"entities\": [{\"begin\": 1418, \"end\": 1426, \"title\": \"http://dbpedia.org/resource/Japan\", \"score\": 0.9999999980568646, \"rank\": 1.9001275881520847e-09, \"text\": \"Japanese\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Japan\", \"dbpedia\": \"http://dbpedia.org/resource/Japan\"}, {\"begin\": 1586, \"end\": 1591, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9381970247967566, \"rank\": 0.06192129563232307, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}]}, {\"sentence\": \"Based on simulations of the teams' routines on the six apparatuses, Japan's D-score tally was likely to top China's, according to Mizutori.\", \"from\": 1594, \"to\": 1733, \"entities\": [{\"begin\": 1662, \"end\": 1667, \"title\": \"http://dbpedia.org/resource/Japan\", \"score\": 0.9999999999990905, \"rank\": 3.76747469383612e-13, \"text\": \"Japan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Japan\", \"dbpedia\": \"http://dbpedia.org/resource/Japan\"}, {\"begin\": 1702, \"end\": 1707, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9381970247967566, \"rank\": 0.06192129563232307, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}]}, {\"sentence\": \"That means the key over the remaining weeks might be to simply polish their routines and minimize any mistakes.\", \"from\": 1734, \"to\": 1845, \"entities\": []}, {\"sentence\": \"\\\"That was quite a surprise, since China had long had a higher D-score than Japan,\\\" said Kazuma Kaya, who won bronze in the pommel horse in Tokyo.\", \"from\": 1847, \"to\": 1992, \"entities\": [{\"begin\": 1881, \"end\": 1886, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9381970247967566, \"rank\": 0.06192129563232307, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}, {\"begin\": 1922, \"end\": 1927, \"title\": \"http://dbpedia.org/resource/Japan\", \"score\": 0.9999999999990905, \"rank\": 3.76747469383612e-13, \"text\": \"Japan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Japan\", \"dbpedia\": \"http://dbpedia.org/resource/Japan\"}, {\"begin\": 1935, \"end\": 1946, \"title\": \"http://dbpedia.org/resource/Kazuma_Kaya\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Kazuma Kaya\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kazuma_Kaya\", \"dbpedia\": \"http://dbpedia.org/resource/Kazuma_Kaya\"}, {\"begin\": 1986, \"end\": 1991, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 1.0, \"rank\": 1.4937983910032014e-18, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}]}, {\"sentence\": \"\\\"In that sense, we have the strongest five members this time.\\\"\", \"from\": 1993, \"to\": 2055, \"entities\": []}, {\"sentence\": \"Led by Hashimoto, Japan took the title at the World Championships last October with a total score of 255.594 points \\u00e2\\u0080\\u0093 nearly two points ahead of China \\u00e2\\u0080\\u0093 although the runners-up competed without their ace all-arounder Zhang Boheng.\", \"from\": 2057, \"to\": 2291, \"entities\": [{\"begin\": 2075, \"end\": 2080, \"title\": \"http://dbpedia.org/resource/Japan\", \"score\": 0.9999999999990905, \"rank\": 3.76747469383612e-13, \"text\": \"Japan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Japan\", \"dbpedia\": \"http://dbpedia.org/resource/Japan\"}, {\"begin\": 2204, \"end\": 2209, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9381970247967566, \"rank\": 0.06192129563232307, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}, {\"begin\": 2278, \"end\": 2290, \"title\": \"http://dbpedia.org/resource/Zhang_Boheng\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Zhang Boheng\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Zhang_Boheng\", \"dbpedia\": \"http://dbpedia.org/resource/Zhang_Boheng\"}]}, {\"sentence\": \"With the 24-year-old Zhang added to the Olympic roster this time, China will be a formidable force, Mizutori warned, leaving Japan little room for error.\", \"from\": 2293, \"to\": 2446, \"entities\": [{\"begin\": 2359, \"end\": 2364, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9381970247967566, \"rank\": 0.06192129563232307, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}, {\"begin\": 2418, \"end\": 2423, \"title\": \"http://dbpedia.org/resource/Japan\", \"score\": 0.9999999999990905, \"rank\": 3.76747469383612e-13, \"text\": \"Japan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Japan\", \"dbpedia\": \"http://dbpedia.org/resource/Japan\"}]}, {\"sentence\": \"Zhang is also set to give Hashimoto a run for his money, with the latter still nursing a finger injury that he said put him at 60 percent at last week's training session.\", \"from\": 2448, \"to\": 2618, \"entities\": [{\"begin\": 2474, \"end\": 2483, \"title\": \"http://dbpedia.org/resource/Daiki_Hashimoto\", \"score\": 1.0, \"rank\": 6.554729998596519e-58, \"text\": \"Hashimoto\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Daiki_Hashimoto\", \"dbpedia\": \"http://dbpedia.org/resource/Daiki_Hashimoto\"}]}, {\"sentence\": \"\\\"I do not think the pain will disappear completely, but I want to get as close to 100 percent as possible before Paris,\\\" he said, adding that he is aiming to defend his all-around and horizontal bar titles, for a total haul of three golds.\", \"from\": 2620, \"to\": 2859, \"entities\": [{\"begin\": 2733, \"end\": 2738, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999167812, \"rank\": 8.321650772081032e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"Mizutori said he saw the makeup of the Paris squad as being similar to the group who topped the podium at Rio 2016.\", \"from\": 2861, \"to\": 2976, \"entities\": [{\"begin\": 2900, \"end\": 2905, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999167812, \"rank\": 8.321650772081032e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"That five-man team featured four members who missed out on gold in London in 2012 and a younger addition in Kenzo Shirai.\", \"from\": 2977, \"to\": 3098, \"entities\": [{\"begin\": 3044, \"end\": 3050, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9709383199103192, \"rank\": 0.029931535713400015, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}, {\"begin\": 3085, \"end\": 3097, \"title\": \"http://dbpedia.org/resource/Kenz\\u014d_Shirai\", \"score\": 0.999999991716777, \"rank\": 0.0, \"text\": \"Kenzo Shirai\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kenz\\u014d_Shirai\", \"dbpedia\": \"http://dbpedia.org/resource/Kenz\\u014d_Shirai\"}]}, {\"sentence\": \"\\\"We have experienced members and new members this time, so it's relatively similar and the balance is really good,\\\" the coach said.\", \"from\": 3100, \"to\": 3231, \"entities\": []}, {\"sentence\": \"\\\"And just as the team in Rio had (seven-time Olympic medalist Kohei) Uchimura, we have Hashimoto, so I think we can expect a similar result.\\\"\", \"from\": 3232, \"to\": 3373, \"entities\": [{\"begin\": 3257, \"end\": 3260, \"title\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"score\": 0.9999999999995453, \"rank\": 2.321585684386772e-13, \"text\": \"Rio\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2016_Summer_Olympics\"}, {\"begin\": 3319, \"end\": 3328, \"title\": \"http://dbpedia.org/resource/Daiki_Hashimoto\", \"score\": 1.0, \"rank\": 6.554729998596519e-58, \"text\": \"Hashimoto\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Daiki_Hashimoto\", \"dbpedia\": \"http://dbpedia.org/resource/Daiki_Hashimoto\"}]}, {\"sentence\": \"Hashimoto and Kaya will be joined by Wataru Tanigawa, Takaaki Sugino and 20-year-old Shinnosuke Oka.\", \"from\": 3375, \"to\": 3475, \"entities\": [{\"begin\": 3412, \"end\": 3427, \"title\": \"http://dbpedia.org/resource/Wataru_Tanigawa\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Wataru Tanigawa\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Wataru_Tanigawa\", \"dbpedia\": \"http://dbpedia.org/resource/Wataru_Tanigawa\"}, {\"begin\": 3429, \"end\": 3443, \"title\": \"http://dbpedia.org/resource/Takaaki_Sugino\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Takaaki Sugino\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Takaaki_Sugino\", \"dbpedia\": \"http://dbpedia.org/resource/Takaaki_Sugino\"}, {\"begin\": 3460, \"end\": 3474, \"title\": \"http://dbpedia.org/resource/Shinnosuke_Oka\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Shinnosuke Oka\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Shinnosuke_Oka\", \"dbpedia\": \"http://dbpedia.org/resource/Shinnosuke_Oka\"}]}, {\"sentence\": \"Artistic gymnastics will run from July 27 to August 5, with the men's team final scheduled for July 29.\", \"from\": 3477, \"to\": 3580, \"entities\": []}, {\"sentence\": \"SITEMAP  EXPLORE MORE  DOWNLOAD OUR APP  Copyright \\u00c2\\u00a9 2024 CGTN.\\u00e4\\u00ba\\u00acICP\\u00e5\\u00a4\\u008720000184\\u00e5\\u008f\\u00b7  Disinformation report hotline: 010-85061466  SITEMAP  EXPLORE MORE  DOWNLOAD OUR APP  Copyright \\u00c2\\u00a9 2024 CGTN.\\u00e4\\u00ba\\u00acICP\\u00e5\\u00a4\\u008720000184\\u00e5\\u008f\\u00b7  Disinformation report hotline: 010-85061466\", \"from\": 3582, \"to\": 3842, \"entities\": []}]}"