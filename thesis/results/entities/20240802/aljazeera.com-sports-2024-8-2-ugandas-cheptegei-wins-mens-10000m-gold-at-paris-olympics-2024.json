"{\"uid\": \"aljazeera.com-sports-2024-8-2-ugandas-cheptegei-wins-mens-10000m-gold-at-paris-olympics-2024\", \"entities\": [{\"sentence\": \"Cheptegei stormed to the finish line in 26min 43.14 seconds, ahead of Ethiopia's Berihu Aregawi and USA's Grant Fisher.\", \"from\": 0, \"to\": 119, \"entities\": [{\"begin\": 70, \"end\": 78, \"title\": \"http://dbpedia.org/resource/Ethiopia\", \"score\": 0.999999994677637, \"rank\": 5.322433633326202e-09, \"text\": \"Ethiopia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ethiopia\", \"dbpedia\": \"http://dbpedia.org/resource/Ethiopia\"}, {\"begin\": 81, \"end\": 95, \"title\": \"http://dbpedia.org/resource/Berihu_Aregawi\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Berihu Aregawi\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Berihu_Aregawi\", \"dbpedia\": \"http://dbpedia.org/resource/Berihu_Aregawi\"}, {\"begin\": 100, \"end\": 103, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.6351724434056422, \"rank\": 0.4361162790539384, \"text\": \"USA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}]}, {\"sentence\": \"Save  Share  Uganda's Joshua Cheptegei withstood surging Ethiopian team tactics to claim gold in the men's Olympic 10,000-metre at the Stade de France.\", \"from\": 121, \"to\": 272, \"entities\": [{\"begin\": 134, \"end\": 140, \"title\": \"http://dbpedia.org/resource/Uganda\", \"score\": 0.9999999799488253, \"rank\": 2.003745257558488e-08, \"text\": \"Uganda\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Uganda\", \"dbpedia\": \"http://dbpedia.org/resource/Uganda\"}, {\"begin\": 143, \"end\": 159, \"title\": \"http://dbpedia.org/resource/Joshua_Cheptegei\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Joshua Cheptegei\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Joshua_Cheptegei\", \"dbpedia\": \"http://dbpedia.org/resource/Joshua_Cheptegei\"}, {\"begin\": 178, \"end\": 187, \"title\": \"http://dbpedia.org/resource/Ethiopia\", \"score\": 0.9200504672083483, \"rank\": 0.08689689929091661, \"text\": \"Ethiopian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ethiopia\", \"dbpedia\": \"http://dbpedia.org/resource/Ethiopia\"}, {\"begin\": 256, \"end\": 271, \"title\": \"http://dbpedia.org/resource/Stade_de_France\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Stade de France\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Stade_de_France\", \"dbpedia\": \"http://dbpedia.org/resource/Stade_de_France\"}]}, {\"sentence\": \"The three-time world champion timed an Olympic record of 26 minutes and 43.14 seconds for victory on Friday.\", \"from\": 274, \"to\": 382, \"entities\": []}, {\"sentence\": \"Ethiopia's Berihu Aregawi edged American Grant Fisher by two-hundredths of a second to take silver in 26:43.44.\", \"from\": 384, \"to\": 495, \"entities\": [{\"begin\": 384, \"end\": 392, \"title\": \"http://dbpedia.org/resource/Ethiopia\", \"score\": 0.999999994677637, \"rank\": 5.322433633326202e-09, \"text\": \"Ethiopia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ethiopia\", \"dbpedia\": \"http://dbpedia.org/resource/Ethiopia\"}, {\"begin\": 395, \"end\": 409, \"title\": \"http://dbpedia.org/resource/Berihu_Aregawi\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Berihu Aregawi\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Berihu_Aregawi\", \"dbpedia\": \"http://dbpedia.org/resource/Berihu_Aregawi\"}, {\"begin\": 416, \"end\": 424, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9612528882624801, \"rank\": 0.0403035051159314, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 425, \"end\": 437, \"title\": \"http://dbpedia.org/resource/Grant_Fisher\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Grant Fisher\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Grant_Fisher\", \"dbpedia\": \"http://dbpedia.org/resource/Grant_Fisher\"}]}, {\"sentence\": \"The world record holder added the Olympic 10,000 metres title to his remarkable haul to take the Games' first track gold.\", \"from\": 497, \"to\": 618, \"entities\": []}, {\"sentence\": \"The Ugandan, who took silver in Tokyo and gold over 5,000 metres, produced a devastating last 600 metres and his finishing time took 18 seconds off Kenenisa Bekele's 2008 Olympic record.\", \"from\": 620, \"to\": 806, \"entities\": [{\"begin\": 624, \"end\": 631, \"title\": \"http://dbpedia.org/resource/Uganda\", \"score\": 0.9999999970686986, \"rank\": 2.9309664635799717e-09, \"text\": \"Ugandan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Uganda\", \"dbpedia\": \"http://dbpedia.org/resource/Uganda\"}, {\"begin\": 652, \"end\": 657, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.9890928965687791, \"rank\": 0.010874071986451288, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}, {\"begin\": 768, \"end\": 783, \"title\": \"http://dbpedia.org/resource/Kenenisa_Bekele\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Kenenisa Bekele\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kenenisa_Bekele\", \"dbpedia\": \"http://dbpedia.org/resource/Kenenisa_Bekele\"}]}, {\"sentence\": \"Aregawi, who had been part of a three-pronged Ethiopian front-running group almost from the start, finished strongly.\", \"from\": 808, \"to\": 925, \"entities\": [{\"begin\": 854, \"end\": 863, \"title\": \"http://dbpedia.org/resource/Ethiopia\", \"score\": 0.9200504672083483, \"rank\": 0.08689689929091661, \"text\": \"Ethiopian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ethiopia\", \"dbpedia\": \"http://dbpedia.org/resource/Ethiopia\"}]}, {\"sentence\": \"A pack of 13 athletes ran the last two-thirds of the race together and, remarkably, all of them finished in under 27 minutes.\", \"from\": 927, \"to\": 1052, \"entities\": []}, {\"sentence\": \"The first surge came after just two laps of the 25-lap race, defending champion Selemon Barega and Ethiopian teammate Yomif Kejelcha accelerating away to split the field.\", \"from\": 1054, \"to\": 1224, \"entities\": [{\"begin\": 1134, \"end\": 1148, \"title\": \"http://dbpedia.org/resource/Selemon_Barega\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Selemon Barega\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Selemon_Barega\", \"dbpedia\": \"http://dbpedia.org/resource/Selemon_Barega\"}, {\"begin\": 1153, \"end\": 1162, \"title\": \"http://dbpedia.org/resource/Ethiopia\", \"score\": 0.9200504672083483, \"rank\": 0.08689689929091661, \"text\": \"Ethiopian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ethiopia\", \"dbpedia\": \"http://dbpedia.org/resource/Ethiopia\"}, {\"begin\": 1172, \"end\": 1186, \"title\": \"http://dbpedia.org/resource/Yomif_Kejelcha\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Yomif Kejelcha\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Yomif_Kejelcha\", \"dbpedia\": \"http://dbpedia.org/resource/Yomif_Kejelcha\"}]}, {\"sentence\": \"The 25-strong field dissipated but all runners held on.\", \"from\": 1226, \"to\": 1281, \"entities\": []}, {\"sentence\": \"Aregawi had his turn after Kejelcha as the Ethiopian trio dictated the pace in front of a noisy near-capacity 69,000 crowd at the Stade de France in perfect warm conditions.\", \"from\": 1283, \"to\": 1456, \"entities\": [{\"begin\": 1326, \"end\": 1335, \"title\": \"http://dbpedia.org/resource/Ethiopia\", \"score\": 0.9200504672083483, \"rank\": 0.08689689929091661, \"text\": \"Ethiopian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ethiopia\", \"dbpedia\": \"http://dbpedia.org/resource/Ethiopia\"}]}, {\"sentence\": \"Cheptegei and Jacob Kiplimo saw their team tactics take a dent when Martin Magengo Kiprotich fell off the pace early on.\", \"from\": 1458, \"to\": 1578, \"entities\": [{\"begin\": 1472, \"end\": 1485, \"title\": \"http://dbpedia.org/resource/Jacob_Kiplimo\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Jacob Kiplimo\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jacob_Kiplimo\", \"dbpedia\": \"http://dbpedia.org/resource/Jacob_Kiplimo\"}, {\"begin\": 1526, \"end\": 1532, \"title\": \"http://dbpedia.org/resource/Glenn_L._Martin_Company\", \"score\": 0.9946668381223872, \"rank\": 0.004176800369505612, \"text\": \"Martin\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Glenn_L._Martin_Company\", \"dbpedia\": \"http://dbpedia.org/resource/Glenn_L._Martin_Company\"}, {\"begin\": 1541, \"end\": 1550, \"title\": \"http://dbpedia.org/resource/Kiprotich\", \"score\": 0.999999999863121, \"rank\": 0.0, \"text\": \"Kiprotich\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Kiprotich\", \"dbpedia\": \"http://dbpedia.org/resource/Kiprotich\"}]}, {\"sentence\": \"Aregawi and Kejelcha again increased the rhythm through the halfway stage, the main pack now cut to 15.\", \"from\": 1580, \"to\": 1683, \"entities\": []}, {\"sentence\": \"Barega was back at the helm with 10 laps to run, Canada's Mohammed Ahmed and Kenya's Benard Kibet muscling their way through to sit on Kejelcha's shoulder.\", \"from\": 1685, \"to\": 1840, \"entities\": [{\"begin\": 1734, \"end\": 1740, \"title\": \"http://dbpedia.org/resource/Canada_men's_national_ice_hockey_team\", \"score\": 0.8089328776894655, \"rank\": 0.1718118264155707, \"text\": \"Canada\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Canada_men's_national_ice_hockey_team\", \"dbpedia\": \"http://dbpedia.org/resource/Canada_men's_national_ice_hockey_team\"}, {\"begin\": 1743, \"end\": 1757, \"title\": \"http://dbpedia.org/resource/Syed_Mohammad_Ahmed\", \"score\": 0.9999862039213776, \"rank\": 1.3796246421936011e-05, \"text\": \"Mohammed Ahmed\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Syed_Mohammad_Ahmed\", \"dbpedia\": \"http://dbpedia.org/resource/Syed_Mohammad_Ahmed\"}, {\"begin\": 1762, \"end\": 1767, \"title\": \"http://dbpedia.org/resource/Kenya\", \"score\": 0.9995984010104846, \"rank\": 0.00040176031694509574, \"text\": \"Kenya\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Kenya\", \"dbpedia\": \"http://dbpedia.org/resource/Kenya\"}, {\"begin\": 1777, \"end\": 1782, \"title\": \"http://dbpedia.org/resource/Aiki_language\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Kibet\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Aiki_language\", \"dbpedia\": \"http://dbpedia.org/resource/Aiki_language\"}]}, {\"sentence\": \"As Cheptegei and Fisher made their way up through a bunching pack, Kejelcha was again on hand to offer a spurt of acceleration.\", \"from\": 1842, \"to\": 1969, \"entities\": [{\"begin\": 1859, \"end\": 1865, \"title\": \"http://dbpedia.org/resource/Division_of_Fisher\", \"score\": 0.8029303170609334, \"rank\": 0.12044852377431581, \"text\": \"Fisher\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Division_of_Fisher\", \"dbpedia\": \"http://dbpedia.org/resource/Division_of_Fisher\"}]}, {\"sentence\": \"Into the last kilometre, Aregawi took up the running, but the race promised a pulsating finish as the pack of 12 all clung on.\", \"from\": 1971, \"to\": 2097, \"entities\": []}, {\"sentence\": \"Just before the bell rang for the final 400 metres, Cheptegei surged to the front and the race to the line was on.\", \"from\": 2099, \"to\": 2213, \"entities\": []}, {\"sentence\": \"Ahmed followed and Fisher fell off the pace, but made a remarkable recovery to medal.\", \"from\": 2215, \"to\": 2300, \"entities\": [{\"begin\": 2234, \"end\": 2240, \"title\": \"http://dbpedia.org/resource/Division_of_Fisher\", \"score\": 0.8029303170609334, \"rank\": 0.12044852377431581, \"text\": \"Fisher\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Division_of_Fisher\", \"dbpedia\": \"http://dbpedia.org/resource/Division_of_Fisher\"}]}, {\"sentence\": \"There was no coup de grace for Barega, however, as Cheptegei held on for victory in the first medal event at France's national stadium.\", \"from\": 2302, \"to\": 2437, \"entities\": [{\"begin\": 2411, \"end\": 2417, \"title\": \"http://dbpedia.org/resource/France_national_football_team\", \"score\": 0.9986290025178417, \"rank\": 0.0012553027073707614, \"text\": \"France\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/France_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/France_national_football_team\"}]}, {\"sentence\": \"Barega eventually finished seventh in 26:44.48, one spot behind Kejelcha, with Ahmed taking fourth and Kibet fifth.\", \"from\": 2439, \"to\": 2554, \"entities\": []}, {\"sentence\": \"Earlier on the purple track, the USA broke their own world record in the 4\\u00d7400 mixed relay in the opening heats, crossing the line in three minutes 7.41 seconds amid a party atmosphere.\", \"from\": 2556, \"to\": 2741, \"entities\": [{\"begin\": 2589, \"end\": 2592, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.6351724434056422, \"rank\": 0.4361162790539384, \"text\": \"USA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}]}, {\"sentence\": \"They set the previous mark of 3:08.80 at the 2023 World Championships in Budapest.\", \"from\": 2743, \"to\": 2825, \"entities\": [{\"begin\": 2816, \"end\": 2824, \"title\": \"http://dbpedia.org/resource/Budapest\", \"score\": 0.8879642081279483, \"rank\": 0.12617151763427348, \"text\": \"Budapest\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Budapest\", \"dbpedia\": \"http://dbpedia.org/resource/Budapest\"}]}, {\"sentence\": \"Team USA led midway through the second lap in a textbook performance, overcoming a fast field in the opening heat in which four national records were broken as well as the world mark.\", \"from\": 2827, \"to\": 3010, \"entities\": [{\"begin\": 2827, \"end\": 2835, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 0.9481792210274924, \"rank\": 0.04190561894462662, \"text\": \"Team USA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\"}]}, {\"sentence\": \"\\\"I always knew we were going to run fast, and we talked about how it was going to take a record to win a medal,\\\" said American Shamier Little.\", \"from\": 3012, \"to\": 3154, \"entities\": [{\"begin\": 3130, \"end\": 3138, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9612528882624801, \"rank\": 0.0403035051159314, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 3139, \"end\": 3153, \"title\": \"http://dbpedia.org/resource/Shamier_Little\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Shamier Little\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Shamier_Little\", \"dbpedia\": \"http://dbpedia.org/resource/Shamier_Little\"}]}, {\"sentence\": \"\\\"It took a record to win our prelim.\\\"\", \"from\": 3155, \"to\": 3192, \"entities\": []}, {\"sentence\": \"The French team were willed across the finish by a partisan home crowd, as they held off Belgium (3:10.74) and Jamaica (3:11.06) to finish second in 3:10.60 in the rarely contested event.\", \"from\": 3194, \"to\": 3381, \"entities\": [{\"begin\": 3198, \"end\": 3204, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.7102392747876589, \"rank\": 0.29781724949407584, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 3283, \"end\": 3290, \"title\": \"http://dbpedia.org/resource/Belgium_national_football_team\", \"score\": 0.9581913855542664, \"rank\": 0.04363254778887173, \"text\": \"Belgium\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Belgium_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Belgium_national_football_team\"}]}, {\"sentence\": \"The crowd had to be shushed as they chanted for the French team on the first day of the athletics programme at the Stade de France and they broke into a loud roar as France took a slender lead.\", \"from\": 3383, \"to\": 3576, \"entities\": [{\"begin\": 3435, \"end\": 3441, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.7102392747876589, \"rank\": 0.29781724949407584, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 3549, \"end\": 3555, \"title\": \"http://dbpedia.org/resource/France_national_football_team\", \"score\": 0.9986290025178417, \"rank\": 0.0012553027073707614, \"text\": \"France\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/France_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/France_national_football_team\"}]}, {\"sentence\": \"Little pulled ahead for the US, however, and Bryce Deadmon extended the lead.\", \"from\": 3578, \"to\": 3655, \"entities\": [{\"begin\": 3606, \"end\": 3608, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 0.9030680461669685, \"rank\": 0.07746985182651316, \"text\": \"US\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\"}, {\"begin\": 3623, \"end\": 3628, \"title\": \"http://dbpedia.org/resource/Bryce_Dessner\", \"score\": 0.9999627973287736, \"rank\": 2.7235705615976208e-05, \"text\": \"Bryce\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Bryce_Dessner\", \"dbpedia\": \"http://dbpedia.org/resource/Bryce_Dessner\"}]}, {\"sentence\": \"The Americans were eager to avoid the drama of three years ago, when they were disqualified from the Olympic final - and later reinstated due to an official's error - before eventually claiming bronze.\", \"from\": 3657, \"to\": 3858, \"entities\": [{\"begin\": 3657, \"end\": 3670, \"title\": \"http://dbpedia.org/resource/The_Americans\", \"score\": 1.0, \"rank\": 2.9526881944419146e-15, \"text\": \"The Americans\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/The_Americans\", \"dbpedia\": \"http://dbpedia.org/resource/The_Americans\"}]}, {\"sentence\": \"Follow Al Jazeera English:\", \"from\": 3878, \"to\": 3904, \"entities\": []}]}"