a.org/resource/Independent_Broadcasting_Authority\"}, {\"begin\": 1313, \"end\": 1316, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.761493896225758e-23, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 1419, \"end\": 1424, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999981876044, \"rank\": 1.8124481860099612e-09, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"The IOC said the IBA decision to disqualify the boxers last year was arbitrary and the main cause for the furor that has seen people like British author J. K. Rowling and billionaire Elon Musk voice their opposition to them competing in the Games.\", \"from\": 1427, \"to\": 1674, \"entities\": [{\"begin\": 1431, \"end\": 1434, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.761493896225758e-23, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 1444, \"end\": 1447, \"title\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\", \"score\": 0.9438182150883073, \"rank\": 0.059522249479986265, \"text\": \"IBA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\", \"dbpedia\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\"}, {\"begin\": 1565, \"end\": 1572, \"title\": \"http://dbpedia.org/resource/British_Boxing_Board_of_Control\", \"score\": 0.9998188347791489, \"rank\": 0.00018104905076868417, \"text\": \"British\