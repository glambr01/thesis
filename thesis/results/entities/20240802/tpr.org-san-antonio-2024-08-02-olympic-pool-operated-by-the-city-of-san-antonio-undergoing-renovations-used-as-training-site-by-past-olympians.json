"{\"uid\": \"tpr.org-san-antonio-2024-08-02-olympic-pool-operated-by-the-city-of-san-antonio-undergoing-renovations-used-as-training-site-by-past-olympians\", \"entities\": [{\"sentence\": \"The City of San Antonio is pumping $3 million dollars into the only Olympic-sized pool it operates and that was used by some local Olympians to train for past world games.\", \"from\": 0, \"to\": 171, \"entities\": [{\"begin\": 16, \"end\": 23, \"title\": \"http://dbpedia.org/resource/Antonio_Vivarini\", \"score\": 0.9536890939631582, \"rank\": 0.04749985029329972, \"text\": \"Antonio\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Antonio_Vivarini\", \"dbpedia\": \"http://dbpedia.org/resource/Antonio_Vivarini\"}]}, {\"sentence\": \"The San Antonio Natatorium on West C\\u00e9sar E. Ch\\u00e1vez Boulevard on the West Side is getting renovated locker rooms, a lobby, and a retractable roof.\", \"from\": 173, \"to\": 318, \"entities\": []}, {\"sentence\": \"The roof was damaged a while back by a storm.\", \"from\": 320, \"to\": 365, \"entities\": []}, {\"sentence\": \"The natatorium's 36,000 annual visitors will see a new lobby and a new locker room.\", \"from\": 367, \"to\": 450, \"entities\": []}, {\"sentence\": \"Shanea Allen, the city's parks and recreation manager, said the Olympic-sized pool the natatorium houses was used as a training site by some past local Olympians.\", \"from\": 452, \"to\": 614, \"entities\": [{\"begin\": 459, \"end\": 464, \"title\": \"http://dbpedia.org/resource/Ray_Allen\", \"score\": 0.8062455315322551, \"rank\": 0.24031514634096346, \"text\": \"Allen\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Ray_Allen\", \"dbpedia\": \"http://dbpedia.org/resource/Ray_Allen\"}]}, {\"sentence\": \"\\\"The San Antonio Natatorium has its own Olympic history, \\\" she said.\", \"from\": 616, \"to\": 684, \"entities\": [{\"begin\": 625, \"end\": 632, \"title\": \"http://dbpedia.org/resource/Antonio_Vivarini\", \"score\": 0.9536890939631582, \"rank\": 0.04749985029329972, \"text\": \"Antonio\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Antonio_Vivarini\", \"dbpedia\": \"http://dbpedia.org/resource/Antonio_Vivarini\"}, {\"begin\": 633, \"end\": 643, \"title\": \"http://dbpedia.org/resource/Natatorium\", \"score\": 1.0, \"rank\": 8.564695392887739e-35, \"text\": \"Natatorium\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Natatorium\", \"dbpedia\": \"http://dbpedia.org/resource/Natatorium\"}]}, {\"sentence\": \"\\\"We have been home to several highly competitive swimmers, including Josh Davis and Adrian Montoya.\\\"\", \"from\": 685, \"to\": 785, \"entities\": [{\"begin\": 754, \"end\": 758, \"title\": \"http://dbpedia.org/resource/Josh_Lyman\", \"score\": 0.9986790141442194, \"rank\": 0.0013208415872569524, \"text\": \"Josh\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Josh_Lyman\", \"dbpedia\": \"http://dbpedia.org/resource/Josh_Lyman\"}]}, {\"sentence\": \"In the 1990s, Davis won three gold medals in swimming, and Montoya was an Olympic qualifier.\", \"from\": 787, \"to\": 879, \"entities\": []}, {\"sentence\": \"Davis won other Olympic medals too.\", \"from\": 880, \"to\": 915, \"entities\": []}, {\"sentence\": \"Once construction work is completed, the natatorium will reopen for future Olympic dreamers later this summer.\", \"from\": 917, \"to\": 1027, \"entities\": []}, {\"sentence\": \"Allen said the natatorium is a joint venture between the city and the San Antonio Independent School District and first opened in 1981.\", \"from\": 1029, \"to\": 1164, \"entities\": [{\"begin\": 1029, \"end\": 1034, \"title\": \"http://dbpedia.org/resource/Ray_Allen\", \"score\": 0.8062455315322551, \"rank\": 0.24031514634096346, \"text\": \"Allen\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Ray_Allen\", \"dbpedia\": \"http://dbpedia.org/resource/Ray_Allen\"}, {\"begin\": 1103, \"end\": 1110, \"title\": \"http://dbpedia.org/resource/Antonio_Vivarini\", \"score\": 0.9536890939631582, \"rank\": 0.04749985029329972, \"text\": \"Antonio\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Antonio_Vivarini\", \"dbpedia\": \"http://dbpedia.org/resource/Antonio_Vivarini\"}, {\"begin\": 1111, \"end\": 1122, \"title\": \"http://dbpedia.org/resource/Independent_politician\", \"score\": 0.9167698925412162, \"rank\": 0.051033988566826366, \"text\": \"Independent\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Independent_politician\", \"dbpedia\": \"http://dbpedia.org/resource/Independent_politician\"}]}, {\"sentence\": \"It sits on school district property, but the city maintains and operates it.\", \"from\": 1165, \"to\": 1241, \"entities\": []}, {\"sentence\": \"The natatorium hosts SAISD-related swim competitions.\", \"from\": 1243, \"to\": 1296, \"entities\": []}, {\"sentence\": \"Allen said the parks and recreation department offers swim-related programs for residents, including water exercises.\", \"from\": 1297, \"to\": 1414, \"entities\": [{\"begin\": 1297, \"end\": 1302, \"title\": \"http://dbpedia.org/resource/Ray_Allen\", \"score\": 0.8062455315322551, \"rank\": 0.24031514634096346, \"text\": \"Allen\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Ray_Allen\", \"dbpedia\": \"http://dbpedia.org/resource/Ray_Allen\"}]}]}"