ities\": []}, {\"sentence\": \"He was released on Monday and the Norwegian Royal Court has referred all comments to his law team.\", \"from\": 1288, \"to\": 1386, \"entities\": [{\"begin\": 1322, \"end\": 1331, \"title\": \"http://dbpedia.org/resource/Norway\", \"score\": 0.9851776546181131, \"rank\": 0.015045058967353388, \"text\": \"Norwegian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Norway\", \"dbpedia\": \"http://dbpedia.org/resource/Norway\"}, {\"begin\": 1332, \"end\": 1343, \"title\": \"http://dbpedia.org/resource/Royal_court\", \"score\": 0.9967373960018641, \"rank\": 0.0032037421696716676, \"text\": \"Royal Court\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Royal_court\", \"dbpedia\": \"http://dbpedia.org/resource/Royal_court\"}]}, {\"sentence\": \"H\\u00f8iby does not carry out official duties on behalf of the Norwegian Crown and has, since he reached his majority, lived as a private citizen out of the spotlight.\", \"from\": 1388, \"to\": 1550, \"entities\": [{\"begin\": 1446, \"end\": 1461, \"title\": \"http://dbpedia.org/resource/Monarchy_of_Norway\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Norwegian Crown\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Monarchy_of_Norway\", \"dbpedia\": \"http://dbpedia.org/resource/Monarchy_of_Norway\"}]}, {\"sentence\": \"Crown Prince Haakon and Crown Princess Mette-Marit had been due to attend the Olympic Games through 10 August, following a holiday break.\", \"from\": 1552, \"to\": 1689, \"entities\": [{\"begin\": 1576, \"end\": 1602, \"title\": \"http://dbpedia.org/resource/Mette-Marit,_Crown_Princess_of_Norway\", \"score\": 0.9999999999254214, \"rank\": 0.0, \"text\": \"Crown Princess Mette-Marit\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Mette-Marit,_Crown_Princess_of_Norway\", \"dbpedia\": \"http://dbpedia.org/resource/Mette-Marit,_Crown_Princess_of_Norway\"}, {\"begin\": 1576, \"end\": 1602, \"title\"