262620577062, \"rank\": 0.0015860959508201438, \"text\": \"Isabel\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Isabella_II_of_Spain\", \"dbpedia\": \"http://dbpedia.org/resource/Isabella_II_of_Spain\"}, {\"begin\": 254, \"end\": 261, \"title\": \"http://dbpedia.org/resource/Reuters\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"REUTERS\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Reuters\", \"dbpedia\": \"http://dbpedia.org/resource/Reuters\"}, {\"begin\": 271, \"end\": 282, \"title\": \"http://dbpedia.org/resource/Philippines\", \"score\": 0.9966946511955731, \"rank\": 0.003180111438597467, \"text\": \"Philippines\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Philippines\", \"dbpedia\": \"http://dbpedia.org/resource/Philippines\"}, {\"begin\": 353, \"end\": 364, \"title\": \"http://dbpedia.org/resource/Philippines\", \"score\": 0.9966946511955731, \"rank\": 0.003180111438597467, \"text\": \"Philippines\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Philippines\", \"dbpedia\": \"http://dbpedia.org/resource/Philippines\"}]}, {\"sentence\": \"A nagging shoulder injury took its toll on Ceniza as he endured a quick end to his Paris Games run after he failed to make a lift in the snatch portion of the men's 61kg division at the South Paris Arena on Wednesday, August 7.\", \"from\": 439, \"to\": 666, \"entities\": []}, {\"sentence\": \"Setting his starting weight at 125kg, Ceniza registered a DNF (did not finish) as he used up his three attempts in the round without making a successful clearance.\", \"from\": 668, \"to\": 831, \"entities\": []}, {\"sentence\": \"He broke into tears backstage after getting eliminated.\", \"from\": 833, \"to\": 888, \"entities\": []}, {\"sentence\": \"\\\"My adrenaline shot up, but the pain from my injury prevailed.\", \"from\": 890, \"to\": 952, \"entities\": []}, {\"sentence\": \"No matter how hard I focused, I cannot control the pain,\\\" said Ceniza in Filipino in an interview with Olympic broadcaster Cignal.\", \"from\": 953, \"to\": 1083, \"entities\": [{\"begin\": 1076, \"end\": 1082, \"title\": \"http://dbpedia.org/resource/Cignal_TV\", \"score\": 0.9989347857399908, \"rank\": 0.0010618038959121898, \"text\": \"Cignal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Cignal_TV\", \"dbpedia\": \"http://dbpedia.org/resource/Cignal_TV\"}]}, {\"sentence\": \"\\\"But I still tried to compete for the Philippines.\", \"from\": 1085, \"to\": 1135, \"entities\": [{\"begin\": 1123, \"end\": 1134, \"title\": \"http://dbpedia.org/resource/Philippines\", \"score\": 0.9966946511955731, \"rank\": 0.003180111438597467, \"text\": \"Philippines\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Philippines\", \"dbpedia\": \"http://dbpedia.org/resource/Philippines\"}]}, {\"sentence\": \"I continue to fight despite my injury.\", \"from\": 1136, \"to\": 1174, \"entities\": []}, {\"sentence\": \"I continue to fight for the Philippines.\\\"\", \"from\": 1175, \"to\": 1216, \"entities\": [{\"begin\": 1203, \"end\": 1214, \"title\": \"http://dbpedia.org/resource/Philippines\", \"score\": 0.9966946511955731, \"rank\": 0.003180111438597467, \"text\": \"Philippines\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Philippines\", \"dbpedia\": \"http://dbpedia.org/resource/Philippines\"}]}, {\"sentence\": \"It was a frustrating turn of events for Ceniza, considering he finished fifth in the Olympic Qualification Ranking of the International Weightlifting Federation (IWF).\", \"from\": 1218, \"to\": 1385, \"entities\": [{\"begin\": 1340, \"end\": 1378, \"title\": \"http://dbpedia.org/resource/International_Weightlifting_Federation\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Weightlifting Federation\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Weightlifting_Federation\", \"dbpedia\": \"http://dbpedia.org/resource/International_Weightlifting_Federation\"}]}, {\"sentence\": \"The 26-year-old Cebuano cleared 132kg in snatch and 168kg in clean and jerk for a total of 300kg in theIWF World Cupin Phuket, Thailand, in April to punch his Olympic ticket.\", \"from\": 1387, \"to\": 1561, \"entities\": [{\"begin\": 1403, \"end\": 1410, \"title\": \"http://dbpedia.org/resource/Cebuano_language\", \"score\": 0.9998494187778325, \"rank\": 0.00015060390035848863, \"text\": \"Cebuano\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Cebuano_language\", \"dbpedia\": \"http://dbpedia.org/resource/Cebuano_language\"}, {\"begin\": 1500, \"end\": 1505, \"title\": \"http://dbpedia.org/resource/Cupin_superfamily\", \"score\": 0.9999999460692394, \"rank\": 0.0, \"text\": \"Cupin\", \"types\": [\"Q8054\", \"Q206229\"], \"wikid\": \"http://dbpedia.org/resource/Cupin_superfamily\", \"dbpedia\": \"http://dbpedia.org/resource/Cupin_superfamily\"}, {\"begin\": 1506, \"end\": 1512, \"title\": \"http://dbpedia.org/resource/Phuket_province\", \"score\": 0.9999940814113941, \"rank\": 5.918621998241817e-06, \"text\": \"Phuket\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Phuket_province\", \"dbpedia\": \"http://dbpedia.org/resource/Phuket_province\"}]}, {\"sentence\": \"His 300kg total would have netted an Olympic bronze.\", \"from\": 1563, \"to\": 1615, \"entities\": []}, {\"sentence\": \"China's Li Fabin defended his crown with a 310kg total, Thailand's Theerapong Silachai bagged silver with 303kg, while the USA's Hampton Morris claimed bronze with 298kg.\", \"from\": 1617, \"to\": 1787, \"entities\": [{\"begin\": 1617, \"end\": 1622, \"title\": \"http://dbpedia.org/resource/China_national_football_team\", \"score\": 0.9790132229227051, \"rank\": 0.02048135990271561, \"text\": \"China\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/