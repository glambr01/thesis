\": [{\"begin\": 585, \"end\": 592, \"title\": \"http://dbpedia.org/resource/Belgium\", \"score\": 0.9995412742304225, \"rank\": 0.00043700618774104714, \"text\": \"Belgian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Belgium\", \"dbpedia\": \"http://dbpedia.org/resource/Belgium\"}]}, {\"sentence\": \"Details of her illness were not provided by Paris 2024 organizers or the Belgium National Olympic Committee, citing the athlete's right to privacy.\", \"from\": 637, \"to\": 784, \"entities\": [{\"begin\": 681, \"end\": 691, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.2502073560621562e-20, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 710, \"end\": 717, \"title\": \"http://dbpedia.org/resource/Belgium\", \"score\": 0.9997430046314413, \"rank\": 0.00025643193842591467, \"text\": \"Belgium\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Belgium\", \"dbpedia\": \"http://dbpedia.org/resource/Belgium\"}, {\"begin\": 718, \"end\": 744, \"title\": \"http://dbpedia.org/resource/National_Olympic_Committee\", \"score\": 0.9999999986068815, \"rank\": 1.194701409093864e-09, \"text\": \"National Olympic Committee\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/National_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/National_Olympic_Committee\"}]}, {\"sentence\": \"\\\"I am gradually doing better and I returned home to Belgium today,\\\" Michel wrote on Instagram on Tuesday.\", \"from\": 786, \"to\": 891, \"entities\": [{\"begin\": 838, \"end\": 845, \"title\": \"http://dbpedia.org/resource/Belgium\", \"score\": 0.9997430046314413, \"rank\": 0.00025643193842591467, \"text\": \"Belgium\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Belgium\", \"dbpedia\": \"http://dbpedia.org/resource/Belgium\"}, {\"begin\": 870, \"end\": 879, \"title\": \"http://dbpedia.org/resource/Instagram\", \"score\": 1.0, \"rank\": 3.46368830639722e-15, \"text\": \"Instagram\", \"types\": [\"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Instagram\", \"dbpedia\": \"http://dbpedia.org/resource/Instagram\"}]}, {\"sentence\": \"\\\"Blood tests showed that I contracted a virus (not E. Coli).\", \"from\": 893, \"to\": 953, \"entities\": []}, {\"sentence\": \"After three days of vomiting and diarrhea, which left me quite empty, on Sunday I ended up needing more significant medical attention at the clinic (in the Olympic Village).\\\"\", \"from\": 954, \"to\": 1128, \"entities\": [{\"begin\": 1110, \"end\": 1125, \"title\": \"http://dbpedia.org/resource/Olympic_Village\", \"score\": 0.9999999999995453, \"rank\": 4.2110077871804295e-13, \"text\": \"Olympic Village\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Village\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Village\"}]}, {\"sentence\": \"The marathon swimming familiarization session scheduled for Tuesday, August 6, in the river Seine has been cancelled because of water pollution concerns, the international federation said.\", \"from\": 1130, \"to\": 1318, \"entities\": [{\"begin\": 1222, \"end\": 1227, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999994008371208, \"rank\": 5.987553123849992e-07, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}]}, {\"sentence\": \"\\\"After the daily situation meeting this morning between Ville de Paris, Paris 2024 and World Aquatics, it has been decided that the familiarization session to take place today, 6 August 2024, is cancelled,\\\" World Aquatics said in a statement.\", \"from\": 1320, \"to\": 1562, \"entities\": []}, {\"sentence\": \"While the E. Coli bacteria levels were within the acceptable threshold, the levels of another bacteria, Enterococci, were not.\", \"from\": 1564, \"to\": 1690, \"entities\": [{\"begin\": 1668, \"end\": 1679, \"title\": \"http://dbpedia.org/resource/Enterococcus\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Enterococci\", \"types\": [\"Q12136\"], \"wikid\": \"http://dbpedia.org/resource/Enterococcus\", \"dbpedia\": \"http://dbpedia.org/resource/Enterococcus\"}]}, {\"sentence\": \"\\\"The water quality review showed E. coli levels ranged from 326 to 517 (considered \\\"very good\\\" to \\\"good\\\") at the four collection points taken on 5 August between 5:00 and 6:00 a.m.,\\\" World Aquatics added.\", \"from\": 1692, \"to\": 1896, \"entities\": []}, {\"sentence\": \"\\\"However, Enterococci levels exceeded World Aquatics maximum thresholds during the morning review.\", \"from\": 1898, \"to\": 1996, \"entities\": [{\"begin\": 1908, \"end\": 1919, \"title\": \"http://dbpedia.org/resource/Enterococcus\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Enterococci\", \"types\": [\"Q12136\"], \"wikid\": \"http://dbpedia.org/resource/Enterococcus\", \"dbpedia\": \"http://dbpedia.org/resource/Enterococcus\"}]}, {\"sentence\": \"The latest Enterococci samples (taken between 12:30 and 13:20 on 4 August) showed levels exceeding the maximum acceptable World Aquatics thresholds.\\\"\", \"from\": 1997, \"to\": 2146, \"entities\": [{\"begin\": 2008, \"end\": 2019, \"title\": \"http://dbpedia.org/resource/Enterococcus\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Enterococci\", \"types\": [\"Q12136\"], \"wikid\": \"http://dbpedia.org/resource/Enterococcus\", \"dbpedia\": \"http://dbpedia.org/resource/Enterococcus\"}]}, {\"sentence\": \"Paris 2024 organizers said it was a \\\"cautious\\\" decision made by World Aquatics and spokesperson Anne Descamps added another familiarization session was scheduled for Wednesday, August 7.\", \"from\": 2148, \"to\": 2334, \"entities\": [{\"begin\": 2148, \"end\": 2158, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.2502073560621562e-20, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 2249, \"end\": 2257, \"title\": \"http://dbpedia.org/resource/Jean-Baptiste_Descamps\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Descamps\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Jean-Baptiste_Descamps\", \"dbpedia\": \"http://dbpedia.org/resource/Jean-Baptiste_Descamps\"}]}, {\"sentence\": \"\\\"We are confident the events will go ahead as planned given the weather tendency,\\\" she said.\", \"from\": 2336, \"to\": 2428, \"entities\": []}, {\"sentence\": \"Training sessions for the swim leg of the triathlon were also cancelled and the men's race was postponed at the last minute because bacteria levels in the river were too high.\", \"from\": 2430, \"to\": 2605, \"entities\": []}, {\"sentence\": \"The triathlon mixed relay went ahead as scheduled on Monday, August 5, after organizers gave the all clear the day before, acknowledging athletes' demands for more certainty.\", \"from\": 2607, \"to\": 2781, \"entities\": []}, {\"sentence\": \"French authorities have spent 1.4 billion euros ($1.53 billion) on upgrading the capital's sewage systems, promising the river will be clean enough for residents to swim in by next summer.\", \"from\": 2783, \"to\": 2971, \"entities\": [{\"begin\": 2783, \"end\": 2789, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.5736599148065592, \"rank\": 0.7407853047065377, \"text\": \"French\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}]}, {\"sentence\": \"The women's and men's marathon swim races are scheduled for Thursday, August 8, and Friday.\", \"from\": 2973, \"to\": 3064, \"entities\": []}, {\"sentence\": \"Should the water not be suitable for swimming, organizers would activate what they called a \\\"fallback plan\\\" based at the Vaires-sur-Marne Nautical Stadium, where rowing and canoeing competitions take place.- Rappler.com  How does this make you feel?\", \"from\": 3066, \"to\": 3315, \"entities\": [{\"begin\": 3187, \"end\": 3203, \"title\": \"http://dbpedia.org/resource/Vaires-sur-Marne\", \"score\": 1.0, \"rank\": 7.558999472174074e-16, \"text\": \"Vaires-sur-Marne\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Vaires-sur-Marne\", \"dbpedia\": \"http://dbpedia.org/resource/Vaires-sur-Marne\"}]}, {\"sentence\": \"follow us\", \"from\": 3317, \"to\": 3326, \"entities\": []}]}"