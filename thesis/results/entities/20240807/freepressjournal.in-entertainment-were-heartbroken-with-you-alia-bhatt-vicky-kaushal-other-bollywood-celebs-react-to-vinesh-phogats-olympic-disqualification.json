"{\"uid\": \"freepressjournal.in-entertainment-were-heartbroken-with-you-alia-bhatt-vicky-kaushal-other-bollywood-celebs-react-to-vinesh-phogats-olympic-disqualification\", \"entities\": [{\"sentence\": \"Indian wrestler Vinesh Phogat created history after she became the first Indian woman wrestler to reach the final of the Paris 2024 Olympics.\", \"from\": 0, \"to\": 141, \"entities\": [{\"begin\": 0, \"end\": 6, \"title\": \"http://dbpedia.org/resource/Cinema_of_India\", \"score\": 0.9998907748403225, \"rank\": 0.00010923708958268663, \"text\": \"Indian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Cinema_of_India\", \"dbpedia\": \"http://dbpedia.org/resource/Cinema_of_India\"}, {\"begin\": 16, \"end\": 29, \"title\": \"http://dbpedia.org/resource/Vinesh_Phogat\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Vinesh Phogat\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Vinesh_Phogat\", \"dbpedia\": \"http://dbpedia.org/resource/Vinesh_Phogat\"}, {\"begin\": 73, \"end\": 79, \"title\": \"http://dbpedia.org/resource/Cinema_of_India\", \"score\": 0.9998907748403225, \"rank\": 0.00010923708958268663, \"text\": \"Indian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Cinema_of_India\", \"dbpedia\": \"http://dbpedia.org/resource/Cinema_of_India\"}]}, {\"sentence\": \"However, she was disqualified after she was found overweight.\", \"from\": 142, \"to\": 203, \"entities\": []}, {\"sentence\": \"After the disqualification, several Bollywood celebrities, including Alia Bhatt, Kareena Kapoor Khan, and Vicky Kaushal, among others, took to their social media handles to extend support to Vinesh.\", \"from\": 205, \"to\": 403, \"entities\": [{\"begin\": 241, \"end\": 250, \"title\": \"http://dbpedia.org/resource/Bollywood\", \"score\": 0.999999999956799, \"rank\": 4.330837321692368e-11, \"text\": \"Bollywood\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Bollywood\", \"dbpedia\": \"http://dbpedia.org/resource/Bollywood\"}, {\"begin\": 274, \"end\": 284, \"title\": \"http://dbpedia.org/resource/Alia_Bhatt\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Alia Bhatt\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Alia_Bhatt\", \"dbpedia\": \"http://dbpedia.org/resource/Alia_Bhatt\"}, {\"begin\": 286, \"end\": 305, \"title\": \"http://dbpedia.org/resource/Kareena_Kapoor\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Kareena Kapoor Khan\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kareena_Kapoor\", \"dbpedia\": \"http://dbpedia.org/resource/Kareena_Kapoor\"}, {\"begin\": 311, \"end\": 324, \"title\": \"http://dbpedia.org/resource/Vicky_Kaushal\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Vicky Kaushal\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Vicky_Kaushal\", \"dbpedia\": \"http://dbpedia.org/resource/Vicky_Kaushal\"}, {\"begin\": 396, \"end\": 402, \"title\": \"http://dbpedia.org/resource/Vinesh_Phogat\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Vinesh\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Vinesh_Phogat\", \"dbpedia\": \"http://dbpedia.org/resource/Vinesh_Phogat\"}]}, {\"sentence\": \"Check it out:  Alia Bhatt:\\\"Vinesh Phogat you are an inspiration to the entire nation.\", \"from\": 405, \"to\": 490, \"entities\": []}, {\"sentence\": \"Nothing can take away your resilience, nothing can take away your courage & nothing can take away the hardships you have been through to create history!\", \"from\": 491, \"to\": 643, \"entities\": []}, {\"sentence\": \"Today you must be heartbroken to say the least and we are heartbroken with you.\", \"from\": 644, \"to\": 723, \"entities\": []}, {\"sentence\": \"But woman you are gold - you are iron and you are steel!!!!!!!\", \"from\": 724, \"to\": 786, \"entities\": []}, {\"sentence\": \"AND NOTHING CAN TAKE THAT AWAY FROM YOU!\", \"from\": 787, \"to\": 827, \"entities\": []}, {\"sentence\": \"A champion for the ages!\", \"from\": 828, \"to\": 852, \"entities\": []}, {\"sentence\": \"There is no one like you @vineshphogat.\\\"\", \"from\": 853, \"to\": 893, \"entities\": []}, {\"sentence\": \"Kareena Kapoor Khan:\\\"Vinesh phogat.\", \"from\": 895, \"to\": 930, \"entities\": [{\"begin\": 895, \"end\": 914, \"title\": \"http://dbpedia.org/resource/Kareena_Kapoor\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Kareena Kapoor Khan\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kareena_Kapoor\", \"dbpedia\": \"http://dbpedia.org/resource/Kareena_Kapoor\"}]}, {\"sentence\": \"Living legend.\", \"from\": 931, \"to\": 945, \"entities\": []}, {\"sentence\": \"Paris Olympics 2024 @vineshphogat.\\\"\", \"from\": 946, \"to\": 981, \"entities\": [{\"begin\": 946, \"end\": 960, \"title\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Paris Olympics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/1924_Summer_Olympics\"}]}, {\"sentence\": \"Sonakshi Sinha:\\\"UNBELIEVABLE!!!!!\", \"from\": 983, \"to\": 1016, \"entities\": []}, {\"sentence\": \"I cant imagine how you are feeling right now and do not know what to say except.\", \"from\": 1017, \"to\": 1097, \"entities\": []}, {\"sentence\": \"You were, are and always will be a champion!!!!\\\"\", \"from\": 1098, \"to\": 1146, \"entities\": []}, {\"sentence\": \"Vicky Kaushal:\\\"A winner beyond medals!\", \"from\": 1148, \"to\": 1186, \"entities\": [{\"begin\": 1148, \"end\": 1161, \"title\": \"http://dbpedia.org/resource/Vicky_Kaushal\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Vicky Kaushal\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Vicky_Kaushal\", \"dbpedia\": \"http://dbpedia.org/resource/Vicky_Kaushal\"}]}, {\"sentence\": \"@vineshphogat.\\\"\", \"from\": 1187, \"to\": 1202, \"entities\": []}, {\"sentence\": \"Taapsee Pannu:\\\"This is heartbreaking but honestly this woman has already made her mark beyond gold by now!\", \"from\": 1204, \"to\": 1310, \"entities\": []}, {\"sentence\": \"@fayedsoe @vineshphogat.\\\"\", \"from\": 1311, \"to\": 1336, \"entities\": []}, {\"sentence\": \"Sophie Choudry:\\\"Am heartbroken and so angry at the same time!!\", \"from\": 1338, \"to\": 1400, \"entities\": [{\"begin\": 1338, \"end\": 1352, \"title\": \"http://dbpedia.org/resource/Sophie_Choudry\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Sophie Choudry\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Sophie_Choudry\", \"dbpedia\": \"http://dbpedia.org/resource/Sophie_Choudry\"}]}, {\"sentence\": \"This is so wrong!!!!\", \"from\": 1401, \"to\": 1421, \"entities\": []}, {\"sentence\": \"0.1kg???\", \"from\": 1422, \"to\": 1430, \"entities\": []}, {\"sentence\": \"Cannot imagine how she must be feeling #vineshphogat.\\\"\", \"from\": 1431, \"to\": 1485, \"entities\": []}, {\"sentence\": \"Let us know!\", \"from\": 1487, \"to\": 1499, \"entities\": []}, {\"sentence\": \"\\ud83d\\udc42What type of content would you like to see from us this year?\", \"from\": 1500, \"to\": 1562, \"entities\": []}, {\"sentence\": \"Farhan Akhtar:\\\"Dear @vineshphogat .. One can only try and imagine how devastated you must be but still not fully understand.\", \"from\": 1564, \"to\": 1688, \"entities\": [{\"begin\": 1565, \"end\": 1578, \"title\": \"http://dbpedia.org/resource/Farhan_Akhtar\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Farhan Akhtar\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Farhan_Akhtar\", \"dbpedia\": \"http://dbpedia.org/resource/Farhan_Akhtar\"}]}, {\"sentence\": \"Heartbroken for you that the quest ended like this.\", \"from\": 1689, \"to\": 1740, \"entities\": []}, {\"sentence\": \"But please know that we are all very proud of you and all you have done for the sport.\", \"from\": 1741, \"to\": 1827, \"entities\": []}, {\"sentence\": \"You will always be a champion and an inspiration to millions.\", \"from\": 1828, \"to\": 1889, \"entities\": []}, {\"sentence\": \"Keep your chin up.\\\"\", \"from\": 1890, \"to\": 1909, \"entities\": []}, {\"sentence\": \"A post shared by Farhan Akhtar (@faroutakhtar)  Samantha Ruth Prabhu:\\\"At times, the most resilient individuals encounter the toughest obstacles.\", \"from\": 1911, \"to\": 2055, \"entities\": [{\"begin\": 1929, \"end\": 1942, \"title\": \"http://dbpedia.org/resource/Farhan_Akhtar\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Farhan Akhtar\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Farhan_Akhtar\", \"dbpedia\": \"http://dbpedia.org/resource/Farhan_Akhtar\"}]}, {\"sentence\": \"Remember that you are not alone, a higher power is watching over you.\", \"from\": 2056, \"to\": 2125, \"entities\": []}, {\"sentence\": \"Your remarkable ability to persist in the midst of difficulties is truly admirable.\", \"from\": 2126, \"to\": 2209, \"entities\": []}, {\"sentence\": \"We will always stand by you through all your highs and lows.\", \"from\": 2210, \"to\": 2270, \"entities\": []}, {\"sentence\": \"@vineshphogat.\\\"\", \"from\": 2271, \"to\": 2286, \"entities\": []}, {\"sentence\": \"A post shared by Samantha (@samantharuthprabhuoffl)  Aparshakti Khurana:\\\"Truly disheartened with what happened with Vinesh, but that does not make us any less proud of this girl.\", \"from\": 2288, \"to\": 2466, \"entities\": [{\"begin\": 2306, \"end\": 2314, \"title\": \"http://dbpedia.org/resource/Samantha_Ruth_Prabhu\", \"score\": 0.9999999999972715, \"rank\": 2.777058869527893e-12, \"text\": \"Samantha\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Samantha_Ruth_Prabhu\", \"dbpedia\": \"http://dbpedia.org/resource/Samantha_Ruth_Prabhu\"}, {\"begin\": 2405, \"end\": 2411, \"title\": \"http://dbpedia.org/resource/Vinesh_Phogat\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Vinesh\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Vinesh_Phogat\", \"dbpedia\": \"http://dbpedia.org/resource/Vinesh_Phogat\"}]}, {\"sentence\": \"Vinesh, you are not defined by this episode.\", \"from\": 2467, \"to\": 2511, \"entities\": []}, {\"sentence\": \"You are the strength you showcased in the ring!\", \"from\": 2512, \"to\": 2559, \"entities\": []}, {\"sentence\": \"You are the person who young girls will look at and say 'I want to be her'.\", \"from\": 2560, \"to\": 2635, \"entities\": []}, {\"sentence\": \"Today, every Indian is sad, but each one of us is still celebrating you, and will continue to do so.\\\"\", \"from\": 2636, \"to\": 2737, \"entities\": [{\"begin\": 2650, \"end\": 2656, \"title\": \"http://dbpedia.org/resource/Cinema_of_India\", \"score\": 0.9998907748403225, \"rank\": 0.00010923708958268663, \"text\": \"Indian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Cinema_of_India\", \"dbpedia\": \"http://dbpedia.org/resource/Cinema_of_India\"}]}, {\"sentence\": \"A post shared by Aparshakti Khurana (@aparshakti_khurana)  Preity Zinta:\\\"Dear @vineshphogat You are pure Gold to every Indian rooting for you.\", \"from\": 2739, \"to\": 2881, \"entities\": [{\"begin\": 2757, \"end\": 2775, \"title\": \"http://dbpedia.org/resource/Aparshakti_Khurana\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Aparshakti Khurana\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Aparshakti_Khurana\", \"dbpedia\": \"http://dbpedia.org/resource/Aparshakti_Khurana\"}, {\"begin\": 2859, \"end\": 2865, \"title\": \"http://dbpedia.org/resource/Cinema_of_India\", \"score\": 0.9998907748403225, \"rank\": 0.00010923708958268663, \"text\": \"Indian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Cinema_of_India\", \"dbpedia\": \"http://dbpedia.org/resource/Cinema_of_India\"}]}, {\"sentence\": \"A champion of champions & a hero to all the women of India.\", \"from\": 2882, \"to\": 2941, \"entities\": [{\"begin\": 2936, \"end\": 2941, \"title\": \"http://dbpedia.org/resource/India\", \"score\": 0.999990072198384, \"rank\": 9.133599016153004e-06, \"text\": \"India\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/India\", \"dbpedia\": \"http://dbpedia.org/resource/India\"}]}, {\"sentence\": \"I am so sorry for how things turned out for you.\", \"from\": 2942, \"to\": 2990, \"entities\": []}, {\"sentence\": \"Chin up & be strong.\", \"from\": 2991, \"to\": 3011, \"entities\": [{\"begin\": 2992, \"end\": 2996, \"title\": \"http://dbpedia.org/resource/Chin_people\", \"score\": 0.9547519395073661, \"rank\": 0.03718908285465314, \"text\": \"Chin\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Chin_people\", \"dbpedia\": \"http://dbpedia.org/resource/Chin_people\"}]}, {\"sentence\": \"Life is not always fair.\", \"from\": 3012, \"to\": 3036, \"entities\": []}, {\"sentence\": \"Tough times do not last but tough people do.\", \"from\": 3037, \"to\": 3081, \"entities\": []}, {\"sentence\": \"Wish I could give you a tight hug right now & tell you that we are So Proud of you.\", \"from\": 3082, \"to\": 3165, \"entities\": []}, {\"sentence\": \"Come back stronger & more power to you.\", \"from\": 3166, \"to\": 3205, \"entities\": []}, {\"sentence\": \"#heartbroken #champion #parisolympics2024.\\\"\", \"from\": 3206, \"to\": 3249, \"entities\": []}, {\"sentence\": \"A post shared by Preity G Zinta (@realpz)    RECENT STORIES\", \"from\": 3251, \"to\": 3310, \"entities\": []}]}"