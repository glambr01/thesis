.org/resource/Roger_Federer\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Roger Federer\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Roger_Federer\", \"dbpedia\": \"http://dbpedia.org/resource/Roger_Federer\"}, {\"begin\": 4388, \"end\": 4400, \"title\": \"http://dbpedia.org/resource/Rafael_Nadal\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Rafael Nadal\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Rafael_Nadal\", \"dbpedia\": \"http://dbpedia.org/resource/Rafael_Nadal\"}]}, {\"sentence\": \"Djokovic has often struggled to win fans round like his rivals, however, despite everything he's achieved.\", \"from\": 4403, \"to\": 4509, \"entities\": [{\"begin\": 4403, \"end\": 4411, \"title\": \"http://dbpedia.org/resource/Novak_Djokovic\", \"score\": 0.9936738871723535, \"rank\": 0.00636638731220017, \"text\": \"Djokovic\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Novak_Djokovic\", \"dbpedia\": \"http://dbpedia.org/resource/Novak_Djokovic\"}]}, {\"sentence\": \"And Murray, speaking to CNN, has admitted he feels for the Serb - insisting it's been 'difficult' for his rival at times.\", \"from\": 4511, \"to\": 4632, \"entities\": [{\"begin\": 4515, \"end\": 4521, \"title\": \"http://dbpedia.org/resource/Andy_Murray\", \"score\": 1.0, \"rank\": 7.996677835685413e-32, \"text\": \"Murray\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Andy_Murray\", \"dbpedia\": \"http://dbpedia.org/resource/Andy_Murray\"}, {\"begin\": 4535, \"end\": 4538, \"title\": \"http://dbpedia.org/resource/CNN\", \"score\": 0.9999999998490239, \"rank\": 1.5025412810791176e-10, \"text\": \"CNN\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/CNN\", \"dbpedia\": \"http://dbpedia.org/resource/CNN\"}]}, {\"sentence\": \"\\\"I think it's obviously at times been difficult for him because Nadal and Federer before Novak became the best player in the world in terms of titles and everything, the best male player, he's won the most grand slams and had an unbelievable career that Rafa and Roger were so loved and had a brilliant rivalry,\\\" he said.\", \"from\": 4634, \"to\": 4955, \"entities\": [{\"begin\": 4698, \"end\": 4703, \"title\": \"http://dbpedia.org/resource/Rafael_Nadal\", \"score\": 0.9999527358269363, \"rank\": 4.726640697131482e-05, \"text\": \"Nadal\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Rafael_Nadal\", \"dbpedia\": \"http://dbpedia.org/resource/Rafael_Nadal\"}, {\"begin\": 4888, \"end\": 4892, \"title\": \"http://dbpedia.org/resource/Rafah\", \"score\": 0.9999999931615093, \"rank\": 6.744291675120867e-09, \"text\": \"Rafa\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Rafah\", \"dbpedia\": \"http://dbpedia.org/resource/Rafah\"}]}, {\"sentence\": \"JUST IN:LIV Golf star Bryson DeChambeau makes Kamala Harris offer after Donald Trump collaboration  \\\"I think Novak [Djokovic ] has huge support around the world.\", \"from\": 4957, \"to\": 5118, \"entities\": [{\"begin\": 4965, \"end\": 4973, \"title\": \"http://dbpedia.org/resource/LIV_Golf\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"LIV Golf\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/LIV_Golf\", \"dbpedia\": \"http://dbpedia.org/resource/LIV_Golf\"}, {\"begin\": 4986, \"end\": 4996, \"title\": \"http://dbpedia.org/resource/Bryson_DeChambeau\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"DeChambeau\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q13156709\"], \"wikid\": \"http://dbpedia.org/resource/Bryson_DeChambeau\", \"dbpedia\": \"http://dbpedia.org/resource/Bryson_DeChambeau\"}, {\"begin\": 5003, \"end\": 5009, \"title\": \"http://dbpedia.org/resource