"{\"uid\": \"theproducenews.com-headlines-wakefern-shoprite-sponsor-special-olympics-new-jersey-summer-games\", \"entities\": [{\"sentence\": \"  Nearly 500 ShopRite and Wakefern Food Corp. team members and their families volunteered at the 2024 Special Olympics New Jersey Summer Games at The College of New Jersey.\", \"from\": 0, \"to\": 172, \"entities\": [{\"begin\": 26, \"end\": 34, \"title\": \"http://dbpedia.org/resource/Wakefern_Food_Corporation\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Wakefern\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Wakefern_Food_Corporation\", \"dbpedia\": \"http://dbpedia.org/resource/Wakefern_Food_Corporation\"}]}, {\"sentence\": \"ShopRite and Wakefern have been sponsors of Special Olympics New Jersey for more than 30 years, providing meals, activities and volunteer contributions each year.\", \"from\": 173, \"to\": 335, \"entities\": [{\"begin\": 217, \"end\": 233, \"title\": \"http://dbpedia.org/resource/Special_Olympics\", \"score\": 0.9999999999997726, \"rank\": 2.289121125198889e-13, \"text\": \"Special Olympics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Special_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Special_Olympics\"}, {\"begin\": 234, \"end\": 244, \"title\": \"http://dbpedia.org/resource/New_Jersey\", \"score\": 0.9999999974666025, \"rank\": 2.076229553541793e-09, \"text\": \"New Jersey\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/New_Jersey\", \"dbpedia\": \"http://dbpedia.org/resource/New_Jersey\"}]}, {\"sentence\": \"\\\"It is an honor to work with Special Olympics New Jersey, an organization that supports incredibly talented athletes and inspires us all,\\\" said Mike Stigers, president of Wakefern Food Corp., the retailer-owned cooperative and logistics and merchandising arm for ShopRite stores.\", \"from\": 337, \"to\": 616, \"entities\": [{\"begin\": 383, \"end\": 393, \"title\": \"http://dbpedia.org/resource/New_Jersey\", \"score\": 0.9999999974666025, \"rank\": 2.076229553541793e-09, \"text\": \"New Jersey\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/New_Jersey\", \"dbpedia\": \"http://dbpedia.org/resource/New_Jersey\"}, {\"begin\": 508, \"end\": 516, \"title\": \"http://dbpedia.org/resource/Wakefern_Food_Corporation\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Wakefern\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Wakefern_Food_Corporation\", \"dbpedia\": \"http://dbpedia.org/resource/Wakefern_Food_Corporation\"}, {\"begin\": 600, \"end\": 608, \"title\": \"http://dbpedia.org/resource/Shoprite_Holdings_Ltd\", \"score\": 1.0, \"rank\": 4.7495879472078646e-18, \"text\": \"ShopRite\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Shoprite_Holdings_Ltd\", \"dbpedia\": \"http://dbpedia.org/resource/Shoprite_Holdings_Ltd\"}]}, {\"sentence\": \"\\\"The Summer Games are an annual tradition that our team members look forward to volunteering at each June and we are grateful for the opportunity to make an impact.\\\"\", \"from\": 617, \"to\": 782, \"entities\": []}, {\"sentence\": \"Stigers joined Wakefern team members and their families who were assisting with events, preparing lunches and providing snacks, giveaways and games for the athletes to enjoy during their downtime.\", \"from\": 784, \"to\": 980, \"entities\": []}, {\"sentence\": \"Wakefern supplied the athletes, their families and volunteers with approximately 10,000 meals last weekend.\", \"from\": 982, \"to\": 1089, \"entities\": []}, {\"sentence\": \"Special Olympics New Jersey kicked off on Friday, June 7 with the annual Law Enforcement Torch Run, which raises funds and awareness for the Special Olympics program.\", \"from\": 1091, \"to\": 1257, \"entities\": [{\"begin\": 1108, \"end\": 1118, \"title\": \"http://dbpedia.org/resource/New_Jersey\", \"score\": 0.9999999974666025, \"rank\": 2.076229553541793e-09, \"text\": \"New Jersey\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/New_Jersey\", \"dbpedia\": \"http://dbpedia.org/resource/New_Jersey\"}, {\"begin\": 1164, \"end\": 1189, \"title\": \"http://dbpedia.org/resource/Law_Enforcement_Torch_Run\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Law Enforcement Torch Run\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Law_Enforcement_Torch_Run\", \"dbpedia\": \"http://dbpedia.org/resource/Law_Enforcement_Torch_Run\"}, {\"begin\": 1232, \"end\": 1248, \"title\": \"http://dbpedia.org/resource/Special_Olympics\", \"score\": 0.9999999999997726, \"rank\": 2.289121125198889e-13, \"text\": \"Special Olympics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Special_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Special_Olympics\"}]}, {\"sentence\": \"The run stops at more than 40 ShopRite supermarkets throughout the state, where ShopRite provides water, ice and fresh fruit for the participants.\", \"from\": 1258, \"to\": 1404, \"entities\": [{\"begin\": 1288, \"end\": 1296, \"title\": \"http://dbpedia.org/resource/Shoprite_Holdings_Ltd\", \"score\": 1.0, \"rank\": 4.7495879472078646e-18, \"text\": \"ShopRite\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Shoprite_Holdings_Ltd\", \"dbpedia\": \"http://dbpedia.org/resource/Shoprite_Holdings_Ltd\"}, {\"begin\": 1338, \"end\": 1346, \"title\": \"http://dbpedia.org/resource/Shoprite_Holdings_Ltd\", \"score\": 1.0, \"rank\": 4.7495879472078646e-18, \"text\": \"ShopRite\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Shoprite_Holdings_Ltd\", \"dbpedia\": \"http://dbpedia.org/resource/Shoprite_Holdings_Ltd\"}]}, {\"sentence\": \"HeadlinesCurrent IssuePrint ArchivesContactUsSubscriptionsSearch  Please Share Your News With UsDigital or Print Advertising Options  Search  Connect With Us    Copyright \\u00a9 2025 The Produce News \\u2022 Covering Fresh Produce Around the Globe Since 1897\", \"from\": 1406, \"to\": 1653, \"entities\": []}]}"