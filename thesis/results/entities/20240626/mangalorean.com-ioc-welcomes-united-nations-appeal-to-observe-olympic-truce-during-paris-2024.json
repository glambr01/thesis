"{\"uid\": \"mangalorean.com-ioc-welcomes-united-nations-appeal-to-observe-olympic-truce-during-paris-2024\", \"entities\": [{\"sentence\": \"IOC welcomes United Nations' appeal to observe Olympic Truce during Paris 2024  New York:With just one month to go for the start of the Olympic Games 2024 in Paris, the chief of the United Nations General Assembly on Tuesday made a solemn appeal to the UN Member States for the observance of the Olympic Truce.\", \"from\": 0, \"to\": 310, \"entities\": [{\"begin\": 0, \"end\": 3, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.3690774546462037e-17, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 13, \"end\": 27, \"title\": \"http://dbpedia.org/resource/United_Nations\", \"score\": 0.9999999998087787, \"rank\": 1.8591448292494633e-10, \"text\": \"United Nations\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Nations\", \"dbpedia\": \"http://dbpedia.org/resource/United_Nations\"}, {\"begin\": 68, \"end\": 78, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 6.644589505112482e-14, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 80, \"end\": 88, \"title\": \"http://dbpedia.org/resource/New_York_City\", \"score\": 0.9995614515469875, \"rank\": 0.00043837634049469215, \"text\": \"New York\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/New_York_City\", \"dbpedia\": \"http://dbpedia.org/resource/New_York_City\"}, {\"begin\": 158, \"end\": 163, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999987426684758, \"rank\": 1.2573331731050964e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 182, \"end\": 213, \"title\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"score\": 0.9999517260527481, \"rank\": 4.794151561634909e-05, \"text\": \"United Nations General Assembly\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"dbpedia\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\"}, {\"begin\": 253, \"end\": 269, \"title\": \"http://dbpedia.org/resource/Member_states_of_the_United_Nations\", \"score\": 0.9999687314848583, \"rank\": 3.126949293141775e-05, \"text\": \"UN Member States\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Member_states_of_the_United_Nations\", \"dbpedia\": \"http://dbpedia.org/resource/Member_states_of_the_United_Nations\"}]}, {\"sentence\": \"The President of the United Nations General Assembly (UNGA), Dennis Francis, on Tuesday called on all warring parties around the world to agree to \\\"true mutual ceasefires\\\" for the duration of the Truce.\", \"from\": 311, \"to\": 513, \"entities\": [{\"begin\": 332, \"end\": 363, \"title\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"score\": 0.9999517260527481, \"rank\": 4.794151561634909e-05, \"text\": \"United Nations General Assembly\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"dbpedia\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\"}, {\"begin\": 365, \"end\": 369, \"title\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"UNGA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"dbpedia\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\"}, {\"begin\": 372, \"end\": 386, \"title\": \"http://dbpedia.org/resource/Dennis_Francis\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Dennis Francis\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Dennis_Francis\", \"dbpedia\": \"http://dbpedia.org/resource/Dennis_Francis\"}]}, {\"sentence\": \"The resolution for the observance of the Olympic Truce for the Olympic and Paralympic Games Paris 2024 was formally adopted by the UN in November last year, calling for the Olympic Truce to be respected from seven days before the start of the Olympic Games until seven days after the Paralympic Games.\", \"from\": 515, \"to\": 816, \"entities\": [{\"begin\": 646, \"end\": 648, \"title\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"score\": 0.9370170675816948, \"rank\": 0.06721629197241535, \"text\": \"UN\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"dbpedia\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\"}, {\"begin\": 688, \"end\": 701, \"title\": \"http://dbpedia.org/resource/Olympic_Truce\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Olympic Truce\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Truce\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Truce\"}]}, {\"sentence\": \"\\\"I solemnly appeal to all Member States to demonstrate their commitment to the Olympic Truce for the 2024 Paris Olympic and Paralympic Games and to undertake concrete actions at the local, national, regional and world levels to promote and strengthen a culture of peace and harmony based on the spirit of the Truce,\\\" said UNGA President Francis.\", \"from\": 818, \"to\": 1163, \"entities\": [{\"begin\": 1140, \"end\": 1144, \"title\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"UNGA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"dbpedia\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\"}, {\"begin\": 1155, \"end\": 1162, \"title\": \"http://dbpedia.org/resource/Pope_Francis\", \"score\": 0.9999056887444773, \"rank\": 9.414001346848355e-05, \"text\": \"Francis\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19546\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Pope_Francis\", \"dbpedia\": \"http://dbpedia.org/resource/Pope_Francis\"}]}, {\"sentence\": \"\\\"I also call upon all warring parties of current armed conflicts around the world to boldly agree to true mutual ceasefires for the duration of the Olympic Truce, thus providing an opportunity to settle disputes peacefully.\\\"\", \"from\": 1165, \"to\": 1389, \"entities\": [{\"begin\": 1313, \"end\": 1326, \"title\": \"http://dbpedia.org/resource/Olympic_Truce\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Olympic Truce\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Truce\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Truce\"}]}, {\"sentence\": \"The Paris Olympic Games will be held in the French capital from July 26 to August 11, 2024.\", \"from\": 1391, \"to\": 1482, \"entities\": [{\"begin\": 1435, \"end\": 1441, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.7600277193004258, \"rank\": 0.2316206164458123, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}]}, {\"sentence\": \"Francis also noted that Paris 2024 would be \\\"breaking new ground in gender equality and inclusivity\\\" by allocating the same number of quota places to male and female athletes and emphasised that the participation of the Refugee Olympic Team would be \\\"a powerful symbol of inclusion and our shared humanity\\\".\", \"from\": 1484, \"to\": 1791, \"entities\": [{\"begin\": 1484, \"end\": 1491, \"title\": \"http://dbpedia.org/resource/Pope_Francis\", \"score\": 0.9999056887444773, \"rank\": 9.414001346848355e-05, \"text\": \"Francis\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19546\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Pope_Francis\", \"dbpedia\": \"http://dbpedia.org/resource/Pope_Francis\"}, {\"begin\": 1508, \"end\": 1518, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 6.644589505112482e-14, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 1704, \"end\": 1724, \"title\": \"http://dbpedia.org/resource/IOC_Refugee_Olympic_Team_at_the_2020_Summer_Olympics\", \"score\": 0.9988374256678073, \"rank\": 0.0011638341541377998, \"text\": \"Refugee Olympic Team\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/IOC_Refugee_Olympic_Team_at_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/IOC_Refugee_Olympic_Team_at_the_2020_Summer_Olympics\"}]}, {\"sentence\": \"International Olympic Committee (IOC) President Thomas Bach welcomed the UN's appeal while emphasising the enduring significance of the Olympic Truce.\", \"from\": 1793, \"to\": 1943, \"entities\": [{\"begin\": 1793, \"end\": 1830, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee (IOC)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 1841, \"end\": 1852, \"title\": \"http://dbpedia.org/resource/Thomas_Bach\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Thomas Bach\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Thomas_Bach\", \"dbpedia\": \"http://dbpedia.org/resource/Thomas_Bach\"}, {\"begin\": 1866, \"end\": 1868, \"title\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"score\": 0.9370170675816948, \"rank\": 0.06721629197241535, \"text\": \"UN\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\", \"dbpedia\": \"http://dbpedia.org/resource/United_Nations_General_Assembly\"}]}, {\"sentence\": \"\\\"The Olympic Truce represents the very essence of what the Olympic Games stand for - peace, unity and the hope of building a better world.\", \"from\": 1945, \"to\": 2083, \"entities\": []}, {\"sentence\": \"In these difficult times, when we are all facing so much confrontation, division and polarisation, the Olympic Truce is more relevant than ever.\", \"from\": 2084, \"to\": 2228, \"entities\": [{\"begin\": 2187, \"end\": 2200, \"title\": \"http://dbpedia.org/resource/Olympic_Truce\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Olympic Truce\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Truce\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Truce\"}]}, {\"sentence\": \"And, as an event that unites the world in peaceful competition, the Olympic Games Paris 2024 will be a powerful reminder that we can all come together peacefully, even in times of wars and crises,\\\" he said.\", \"from\": 2229, \"to\": 2435, \"entities\": []}, {\"sentence\": \"The IOC has suspended the membership of Russia and Belarus for the war in Ukraine and sportspersons from these two countries will be participating in Paris Olympics as neutral athletes.\", \"from\": 2437, \"to\": 2622, \"entities\": [{\"begin\": 2441, \"end\": 2444, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.3690774546462037e-17, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 2477, \"end\": 2483, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999627256678072, \"rank\": 3.440557573173518e-05, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}, {\"begin\": 2488, \"end\": 2495, \"title\": \"http://dbpedia.org/resource/Belarus\", \"score\": 0.9979142609386378, \"rank\": 0.002089901559089094, \"text\": \"Belarus\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Belarus\", \"dbpedia\": \"http://dbpedia.org/resource/Belarus\"}, {\"begin\": 2511, \"end\": 2518, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 0.9972776991709043, \"rank\": 0.0027086116402528985, \"text\": \"Ukraine\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Ukraine\"}]}, {\"sentence\": \"Connect over WhatsApp for more details  Subscribe to WhatsApp Channel  A password will be e-mailed to you.\", \"from\": 2628, \"to\": 2734, \"entities\": [{\"begin\": 2641, \"end\": 2649, \"title\": \"http://dbpedia.org/resource/WhatsApp\", \"score\": 0.9999813502572257, \"rank\": 1.8650090673181765e-05, \"text\": \"WhatsApp\", \"types\": [\"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/WhatsApp\", \"dbpedia\": \"http://dbpedia.org/resource/WhatsApp\"}, {\"begin\": 2681, \"end\": 2689, \"title\": \"http://dbpedia.org/resource/WhatsApp\", \"score\": 0.9999813502572257, \"rank\": 1.8650090673181765e-05, \"text\": \"WhatsApp\", \"types\": [\"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/WhatsApp\", \"dbpedia\": \"http://dbpedia.org/resource/WhatsApp\"}]}, {\"sentence\": \"Username  E-mail\", \"from\": 2736, \"to\": 2752, \"entities\": []}]}"