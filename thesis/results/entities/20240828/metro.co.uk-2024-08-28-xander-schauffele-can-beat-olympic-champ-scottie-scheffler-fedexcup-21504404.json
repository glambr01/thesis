": 440, \"entities\": [{\"begin\": 370, \"end\": 379, \"title\": \"http://dbpedia.org/resource/Scottie_Scheffler\", \"score\": 1.0, \"rank\": 2.8761221566330806e-46, \"text\": \"Scheffler\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q13156709\"], \"wikid\": \"http://dbpedia.org/resource/Scottie_Scheffler\", \"dbpedia\": \"http://dbpedia.org/resource/Scottie_Scheffler\"}]}, {\"sentence\": \"Scheffler has won six PGA Tour events with Schauffele, who do not forget was Olympic champion in Tokyo three years ago, claiming two.\", \"from\": 442, \"to\": 575, \"entities\": [{\"begin\": 442, \"end\": 451, \"title\": \"http://dbpedia.org/resource/Scottie_Scheffler\", \"score\": 1.0, \"rank\": 2.8761221566330806e-46, \"text\": \"Scheffler\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q13156709\"], \"wikid\": \"http://dbpedia.org/resource/Scottie_Scheffler\", \"dbpedia\": \"http://dbpedia.org/resource/Scottie_Scheffler\"}, {\"begin\": 464, \"end\": 472, \"title\": \"http://dbpedia.org/resource/PGA_Tour\", \"score\": 1.0, \"rank\": 2.450444123980662e-15, \"text\": \"PGA Tour\", \"types\": [\"Q623109\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/PGA_Tour\", \"dbpedia\": \"http://dbpedia.org/resource/PGA_Tour\"}, {\"begin\": 539, \"end\": 544, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.999986494508244, \"rank\": 1.296653782630753e-05, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}]}, {\"sentence\": \"It's amazing to think they put golfers of the highest calibre like Rory McIlroy, Collin Morikawa, Patrick Cantlay and Hideki Matsuyama in the shade.\", \"from\": 576, \"to\": 724, \"entities\": [{\"begin\": 643, \"end\": 655, \"title\": \"http://dbpedia.org/resource/Rory_McIlroy\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Rory McIlroy\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q13156709\"], \"wikid\": \"http://dbpedia.org/resource/Rory_McIlroy\", \"dbpedia\": \"http://dbpedia.org/resource/Rory_McIlroy\"}, {\"begin\": 657, \"end\": 672, \"title\": \"http://dbpedia.org/resource/Collin_Morikawa\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Collin Morikawa\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q13156709\"], \"wikid\": \"http://dbpedia.org/resource/Collin_Morikawa\", \"dbpedia\": \"http://dbpedia.org/resource/Collin_Morikawa\"}, {\"begin\": 674, \"end\": 681, \"title\": \"http://dbpedia.org/resource/Danica_Patrick\", \"score\": 0.9999835733241028, \"rank\": 1.5248821736293101e-05, \"text\": \"Patrick\", \"types\": [\"Q729\", \"Q5\", \"Q378622\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Danica_Patrick\", \"dbpedia\": \"http://dbpedia.org/resource/Danica_Patrick\"}, {\"begin\": 694, \"end\": 710, \"title\": \"http://dbpedia.org/resource/Hideki_Matsuyama\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Hideki Matsuyama\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q13156709\"], \"wikid\": \"http://dbpedia.org/resource/Hideki_Matsuyama\", \"dbpedia\": \"http://dbpedia.org/resource/Hideki_Matsuyama\"}]}, {\"sentence\": \"The post-season format means Scheffler heads into the Tour Championship at East Lake at ten under despite finishing tied 33rd in last week's BMW Championship at Castle Pines in Colorado.\", \"from\": 726, \"to\": 912, \"entities\": [{\"begin\": 755, \"end\": 764, \"title\": \"http://dbpedia.org/resource/Scottie_Scheffler\", \"score\": 1.0, \"rank\": 2.8761221566330806e-46, \"text\": \"Scheffler\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q13156709\"], \"wikid\": \"http://dbpedia.org/resource/Scottie_Scheffler\", \"dbpedia\": \"http://dbpedia.org/resource/Scottie_Scheffler\"}, {\"begin\": 867, \"end\": 883, \"title\": \"http://dbpedia.org/resource/BMW_PGA_Championship\", \"score\": 1.0, \"rank\": 6.20471233308477e-36, \"text\": \"BMW Championship\", \"types\": [\"