a.org/resource/Robert_Retherford\"}, {\"begin\": 2827, \"end\": 2835, \"title\": \"http://dbpedia.org/resource/Alexander_Scriabin\", \"score\": 1.0, \"rank\": 6.81584250082374e-19, \"text\": \"Skriabin\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Alexander_Scriabin\", \"dbpedia\": \"http://dbpedia.org/resource/Alexander_Scriabin\"}]}, {\"sentence\": \"After the break, Skriabin took an errant shot which was stymied by Retherford for another takedown.\", \"from\": 2964, \"to\": 3063, \"entities\": [{\"begin\": 2981, \"end\": 2989, \"title\": \"http://dbpedia.org/resource/Alexander_Scriabin\", \"score\": 1.0, \"rank\": 6.81584250082374e-19, \"text\": \"Skriabin\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Alexander_Scriabin\", \"dbpedia\": \"http://dbpedia.org/resource/Alexander_Scriabin\"}, {\"begin\": 3031, \"end\": 3041, \"title\": \"http://dbpedia.org/resource/Robert_Retherford\", \"score\": 0.9999999150713883, \"rank\": 0.0, \"text\": \"Retherford\", \"types\": [\"Q901\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Robert_Retherford\", \"dbpedia\": \"http://dbpedia.org/resource/Robert_Retherford\"}]}, {\"sentence\": \"From that point, Retherford battered Skriabin from par terre.\", \"from\": 3064, \"to\": 3125, \"entities\": [{\"begin\": 3081, \"end\": 3091, \"title\": \"http://dbpedia.org/resource/Robert_Retherford\", \"score\": 0.9999999150713883, \"rank\": 0.0, \"text\": \"Retherford\", \"types\": [\"Q901\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Robert_Retherford\", \"dbpedia\": \"http://dbpedia.org/resource/Robert_Retherford\"}, {\"begin\": 3101, \"end\": 3109, \"title\": \"http://dbpedia.org/resource/Alexander_Scriabin\", \"score\": 1.0, \"rank\": 6.81584250082374e-19, \"text\": \"Skriabin\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Alexander_Scriabin\", \"dbpedia\": \"http://dbpedia.org/resource/Alexander_Scriabin\"}]}, {\"sentence\": \"One turn from Retherford put him up 7-0, which is how the match would end.\", \"from\": 3126, \"to\": 3200, \"entities\": [{\"begin\": 3140, \"end\": 3150, \"title\": \"http://dbpedia.org/resource/Robert_Retherford\", \"score\": 0.9999999150713883, \"rank\": 0.0, \"text\": \"Retherford\", \"types\": [\"Q901\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Robert_Retherford\", \"dbpedia\": \"http://dbpedia.org/resource/Robert_Retherford\"}]}, {\"sentence\": \"Four hard-fought wins later, Retherford was headed to Paris.\", \"from\": 3202, \"to\": 3262, \"entities\": [{\"begin\": 3231, \"end\": 3241, \"title\": \"http://dbpedia.org/resource/Robert_Retherford\", \"score\": 0.9999999150713883, \"rank\": 0.0, \"text\": \"Retherford\", \"types\": [\"Q901\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Robert_Retherford\", \"dbpedia\": \"http://dbpedia.org/resource/Robert_Retherford\"}, {\"begin\": 3256, \"end\": 3261, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999997330633, \"rank\": 2.669653909817553e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"There are no comments to display.\", \"from\": 3264, \"to\": 3297, \"entities\": []}, {\"sentence\": \"You need to be a member in order to leave a comment  Sign up for a new account in our community.\", \"from\": 3299, \"to\": 3395, \"entities\": []}, {\"sentence\": \"It's easy!\", \"from\": 3396, \"to\": 3406, \"entities\": []}, {\"sentence\": \"Already have an account?\", \"from\": 3408, \"to\": 3432, \"entities\": []}, {\"sentence\": \"Sign in here.\", \"from\": 3433, \"to\": 3446, \"entities\": []}, {\"sentence\": \"Show all categori