dividual_time_trial\"}, {\"begin\": 1330, \"end\": 1335, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999995453, \"rank\": 2.866806012183754e-13, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 1388, \"end\": 1404, \"title\": \"http://dbpedia.org/resource/British_Chess_Championship\", \"score\": 0.9988227041259904, \"rank\": 0.001178634010501693, \"text\": \"British Champion\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/British_Chess_Championship\", \"dbpedia\": \"http://dbpedia.org/resource/British_Chess_Championship\"}, {\"begin\": 1517, \"end\": 1522, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.7712611773708502, \"rank\": 0.29657763219887506, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}, {\"begin\": 1540, \"end\": 1552, \"title\": \"http://dbpedia.org/resource/Team_pursuit\", \"score\": 1.0, \"rank\": 2.361618897947369e-30, \"text\": \"Team Pursuit\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Team_pursuit\", \"dbpedia\": \"http://dbpedia.org/resource/Team_pursuit\"}]}, {\"sentence\": \"Hayter will be joined on track by Charlie Tanfield, Ollie Wood, Dan Bigham and Israel-Premier Tech's Ethan Vernon as the Brits look to unseat the defending Team Pursuit champions Italy.\", \"from\": 1555, \"to\": 1740, \"entities\": [{\"begin\": 1589, \"end\": 1605, \"title\": \"http://dbpedia.org/resource/Charlie_Tanfield\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Charlie Tanfield\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Charlie_Tanfield\", \"dbpedia\": \"http://dbpedia.org/resource/Charlie_Tanfield\"}, {\"begin\": 1656, \"end\": 1668, \"title\": \"h