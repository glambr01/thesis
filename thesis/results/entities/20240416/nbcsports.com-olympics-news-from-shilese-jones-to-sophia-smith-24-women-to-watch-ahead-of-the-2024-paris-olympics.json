\", \"score\": 1.0, \"rank\": 5.872817440897398e-16, \"text\": \"Naomi\", \"types\": [\"Q729\", \"Q5\", \"Q4610556\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Naomi_Campbell\", \"dbpedia\": \"http://dbpedia.org/resource/Naomi_Campbell\"}, {\"begin\": 1804, \"end\": 1809, \"title\": \"http://dbpedia.org/resource/Baker\", \"score\": 0.9999999955998646, \"rank\": 4.396513505943314e-09, \"text\": \"Baker\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Baker\", \"dbpedia\": \"http://dbpedia.org/resource/Baker\"}, {\"begin\": 1825, \"end\": 1830, \"title\": \"http://dbpedia.org/resource/Getty_Images\", \"score\": 0.9999755252750363, \"rank\": 2.4474497043636707e-05, \"text\": \"Getty\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Getty_Images\", \"dbpedia\": \"http://dbpedia.org/resource/Getty_Images\"}]}, {\"sentence\": \"She is a two-time Olympian and two-time Olympic medalist, with all-around silver and vault gold medals from the Tokyo Olympics.\", \"from\": 1919, \"to\": 2046, \"entities\": [{\"begin\": 1937, \"end\": 1945, \"title\": \"http://dbpedia.org/resource/Olympic_Games\", \"score\": 0.9999999999736247, \"rank\": 2.6779689328311968e-11, \"text\": \"Olympian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games\"}]}, {\"sentence\": \"Andrade also made history at worlds last year when she became the first Brazilian woman to win the world all-around title.\", \"from\": 2047, \"to\": 2169, \"entities\": [{\"begin\": 2047, \"end\": 2054, \"title\": \"http://dbpedia.org/resource/Andrade_El_Idolo\", \"score\": 1.0, \"rank\": 3.9032632921975876e-24, \"text\": \"Andrade\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q13474373\"], \"wikid\": \"http://dbpedia.org/resource/Andrade_El_Idolo\", \"dbpedia\": \"http://dbpedia.org/resource/Andrade_El_Idolo\"}]}, {\"sentence\": \"TOKYO, JAPAN August 8