172, \"to\": 2491, \"entities\": [{\"begin\": 2234, \"end\": 2242, \"title\": \"http://dbpedia.org/resource/Athletissima\", \"score\": 1.0, \"rank\": 2.4918729573245156e-26, \"text\": \"Lausanne\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Athletissima\", \"dbpedia\": \"http://dbpedia.org/resource/Athletissima\"}, {\"begin\": 2261, \"end\": 2278, \"title\": \"http://dbpedia.org/resource/Emmanuel_Wanyonyi\", \"score\": 0.9999947311428166, \"rank\": 0.0, \"text\": \"Emmanuel Wanyonyi\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emmanuel_Wanyonyi\", \"dbpedia\": \"http://dbpedia.org/resource/Emmanuel_Wanyonyi\"}, {\"begin\": 2282, \"end\": 2287, \"title\": \"http://dbpedia.org/resource/Kenya\", \"score\": 0.9999977791660162, \"rank\": 1.909899223002568e-06, \"text\": \"Kenya\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Kenya\", \"dbpedia\": \"http://dbpedia.org/resource/Kenya\"}, {\"begin\": 2367, \"end\": 2377, \"title\": \"http://dbpedia.org/resource/Marco_Arop\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Marco Arop\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Marco_Arop\", \"dbpedia\": \"http://dbpedia.org/resource/Marco_Arop\"}, {\"begin\": 2381, \"end\": 2387, \"title\": \"http://dbpedia.org/resource/Canada_women's_national_soccer_team\", \"score\": 0.9283824400748908, \"rank\": 0.07713308839908925, \"text\": \"Canada\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Canada_women's_national_soccer_team\", \"dbpedia\": \"http://dbpedia.org/resource/Canada_women's_national_soccer_team\"}, {\"begin\": 2434, \"end\": 2439, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.26260607922686e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\"