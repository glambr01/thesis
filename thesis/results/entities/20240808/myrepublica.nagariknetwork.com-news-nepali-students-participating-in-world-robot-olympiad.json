"{\"uid\": \"myrepublica.nagariknetwork.com-news-nepali-students-participating-in-world-robot-olympiad\", \"entities\": [{\"sentence\": \"Subscribe Now  KATHMANDU, Sept 22: Two teams of students each from Uniglobe Secondary School and Nepal Police School are participating in the World Robot Olympiad 2018 scheduled to be held in Bangkok, Thailand from November 16-18.\", \"from\": 0, \"to\": 230, \"entities\": [{\"begin\": 192, \"end\": 199, \"title\": \"http://dbpedia.org/resource/Suvarnabhumi_Airport\", \"score\": 0.9988213015319674, \"rank\": 0.0010139306838600635, \"text\": \"Bangkok\", \"types\": [\"Q1248784\"], \"wikid\": \"http://dbpedia.org/resource/Suvarnabhumi_Airport\", \"dbpedia\": \"http://dbpedia.org/resource/Suvarnabhumi_Airport\"}, {\"begin\": 201, \"end\": 209, \"title\": \"http://dbpedia.org/resource/Thailand\", \"score\": 0.9999952627568631, \"rank\": 3.4173435380546692e-06, \"text\": \"Thailand\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Thailand\", \"dbpedia\": \"http://dbpedia.org/resource/Thailand\"}]}, {\"sentence\": \"Three students from each group will demonstrate their innovations at the Olympiad.\", \"from\": 232, \"to\": 314, \"entities\": []}, {\"sentence\": \"Gaurav Chapagain, Swikar Adhikari and Arun Chaudhary of Uniglobe College and Lucky Sah, Utshab Raj Kandel and Ritik Sah of Police School have been selected for the robotic competition.\", \"from\": 316, \"to\": 500, \"entities\": [{\"begin\": 393, \"end\": 398, \"title\": \"http://dbpedia.org/resource/Lucky_Stores\", \"score\": 0.8826759564630399, \"rank\": 0.13265637232978475, \"text\": \"Lucky\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Lucky_Stores\", \"dbpedia\": \"http://dbpedia.org/resource/Lucky_Stores\"}, {\"begin\": 399, \"end\": 402, \"title\": \"http://dbpedia.org/resource/Shah\", \"score\": 1.0, \"rank\": 9.126340829682908e-17, \"text\": \"Sah\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Shah\", \"dbpedia\": \"http://d