}]}, {\"sentence\": \"Ivanka Trump, the U.S. president's daughter and adviser, will also attend the ceremony.\", \"from\": 260, \"to\": 347, \"entities\": [{\"begin\": 278, \"end\": 292, \"title\": \"http://dbpedia.org/resource/President_of_the_United_States\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"U.S. president\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/President_of_the_United_States\", \"dbpedia\": \"http://dbpedia.org/resource/President_of_the_United_States\"}]}, {\"sentence\": \"The North's delegation is headed by Kim Yong Chol, whom Seoul has accused of being behind two attacks on the South that killed 50 people in 2010.\", \"from\": 349, \"to\": 494, \"entities\": [{\"begin\": 385, \"end\": 388, \"title\": \"http://dbpedia.org/resource/Kim_Kardashian\", \"score\": 0.99767541173983, \"rank\": 0.0023299986882254803, \"text\": \"Kim\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kim_Kardashian\", \"dbpedia\": \"http://dbpedia.org/resource/Kim_Kardashian\"}, {\"begin\": 394, \"end\": 398, \"title\": \"http://dbpedia.org/resource/Ch\\u02bcol_language\", \"score\": 0.9936888658887968, \"rank\": 0.0, \"text\": \"Chol\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Ch\\u02bcol_language\", \"dbpedia\": \"http://dbpedia.org/resource/Ch\\u02bcol_language\"}, {\"begin\": 405, \"end\": 410, \"title\": \"http://dbpedia.org/resource/Seoul\", \"score\": 0.9999999999931788, \"rank\": 6.670089281650477e-12, \"text\": \"Seoul\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Seoul\", \"dbpedia\": \"http://dbpedia.org/resource/Seoul\"}]}, {\"sentence\": \"Kim was head of the North's military intelligence when the attacks took place and is currently a vice chairman of the ruling party's central committee tasked with inter-Korea relations.\", \"from\": 495, \"to\": 680, \"entities\": [{\"begin\": 495, \"end\": 498, \"title\": \"http://dbpedia.org/resource/Kim_Kardashian\", \"score\": 0.99767541173983, \"rank\": 0.0023299986882254803, \"text\": \"Kim\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kim_Kardashian\", \"dbpedia\": \"http://dbpedia.org/resource/Kim_Kardashian\"}]}, {\"sentence\": \"With decades of experience, he is one of the most powerful people in the North's ruling regime.\", \"from\": 682, \"to\": 777, \"entities\": []}, {\"sentence\": \"Seoul decided to temporarily take him off of a blacklist to allow the visit.\", \"from\": 778, \"to\": 854, \"entities\": [{\"begin\": 778, \"end\": 783, \"title\": \"http://dbpedia.org/resource/Seoul\", \"score\": 0.9999999999931788, \"rank\": 6.670089281650477e-12, \"text\": \"Seoul\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Seoul\", \"dbpedia\": \"http://dbpedia.org/resource/Seoul\"}]}, {\"sentence\": \"South Korea is hoping to ease tensions by allowing the North to participate in the games and send senior delegations.\", \"from\": 856, \"to\": 973, \"entities\": [{\"begin\": 856, \"end\": 867, \"title\": \"http://dbpedia.org/resource/South_Korea\", \"score\": 1.0, \"rank\": 4.842303654992655e-19, \"text\": \"South Korea\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/South_Korea\", \"dbpedia\": \"http://dbpedia.org/resource/South_Korea\"}]}, {\"sentence\": \"Kim Jong Un's sister, Kim Yo Jong, attended the opening ceremony in an historic first - no member of the ruling Kim family had ever traveled to the South before.\", \"from\": 975, \"to\": 1136, \"entities\": [{\"begin\": 975, \"end\": 986, \"title\": \"http://dbpedia.org/resource/Kim_Jong-un\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Kim Jong Un\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kim_Jong-un\", \"dbpedia\": \"http://dbpedia.org/resource/Kim_Jong-un\"}, {\"begin\": 997, \"end\": 1008, \"title\": \"http://dbpedia.org/resource/Kim_