": [{\"begin\": 2231, \"end\": 2252, \"title\": \"http://dbpedia.org/resource/Elaine_Thompson-Herah\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Elaine Thompson-Herah\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Elaine_Thompson-Herah\", \"dbpedia\": \"http://dbpedia.org/resource/Elaine_Thompson-Herah\"}, {\"begin\": 2295, \"end\": 2315, \"title\": \"http://dbpedia.org/resource/Sha'Carri_Richardson\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Sha'Carri Richardson\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Sha'Carri_Richardson\", \"dbpedia\": \"http://dbpedia.org/resource/Sha'Carri_Richardson\"}]}, {\"sentence\": \"\\\"You have to think about the next generation that's coming after you and give them the opportunity to also dream \\u00e2\\u0080\\u0093 and dream big.\\\"\", \"from\": 2409, \"to\": 2541, \"entities\": []}, {\"sentence\": \"SITEMAP  EXPLORE MORE  DOWNLOAD OUR APP  Copyright \\u00c2\\u00a9 2024 CGTN.\\u00e4\\u00ba\\u00acICP\\u00e5\\u00a4\\u008720000184\\u00e5\\u008f\\u00b7  Disinformation report hotline: 010-85061466  SITEMAP  EXPLORE MORE  DOWNLOAD OUR APP  Copyright \\u00c2\\u00a9 2024 CGTN.\\u00e4\\u00ba\\u00acICP\\u00e5\\u00a4\\u008720000184\\u00e5\\u008f\\u00b7  Disinformation report hotline: 010-85061466\", \"from\": 2543, \"to\": 2803, \"entities\": []}]}"