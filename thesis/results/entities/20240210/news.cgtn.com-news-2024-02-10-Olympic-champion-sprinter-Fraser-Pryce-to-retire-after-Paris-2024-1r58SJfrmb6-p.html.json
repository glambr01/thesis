to\": 641, \"entities\": [{\"begin\": 453, \"end\": 476, \"title\": \"http://dbpedia.org/resource/Shelly-Ann_Fraser-Pryce\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Shelly-Ann Fraser-Pryce\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Shelly-Ann_Fraser-Pryce\", \"dbpedia\": \"http://dbpedia.org/resource/Shelly-Ann_Fraser-Pryce\"}, {\"begin\": 480, \"end\": 487, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.9999996152956386, \"rank\": 3.420355615946671e-07, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}, {\"begin\": 567, \"end\": 572, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999559238414, \"rank\": 4.407622415161934e-08, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 613, \"end\": 624, \"title\": \"http://dbpedia.org/resource/Essence_(magazine)\", \"score\": 0.9988159927504948, \"rank\": 0.0, \"text\": \"Essence.com\", \"types\": [\"Q41298\", \"Q386724\", \"Q234460\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/Essence_(magazine)\", \"dbpedia\": \"http://dbpedia.org/resource/Essence_(magazine)\"}]}, {\"sentence\": \"\\\"There is not a day I am getting up to go practice and I am like, 'I am over this,'\\\" Fraser-Pryce said.\", \"from\": 643, \"to\": 746, \"entities\": []}, {\"sentence\": \"\\\"My son needs me.\", \"from\": 747, \"to\": 764, \"entities\": []}, {\"sentence\": \"My husband and I have been together since before I won in 2008.\", \"from\": 765, \"to\": 828, \"entities\": []}, {\"sentence\": \"He has sacrificed for me.\", \"from\": 829, \"to\": 854, \"entities\": []}, {\"sentence\": \"We are a partnership, a team.\", \"from\": 855, \"to\": 884, \"entities\": []}, {\"sentence\": \"And it's because of that support that I am able to do the things that I have been doing for all these years.\", \"from\": 885, \"to\": 993, \"entities\": []}, {\"sentence\": \"And I think I now owe it to them to do something else.\\\"\", \"from\": 994, \"to\": 1049, \"entities\": []}, {\"sentence\": \"Having made her Olympic debut in 2008 in Beijing, Fraser-Pryce won eight medals, including three golds, four silvers and one bronze in the women's 100-meter, 200-meter and 4x100-meter relay events in Beijing, London, Rio de Janeiro and Tokyo.\", \"from\": 1051, \"to\": 1293, \"entities\": [{\"begin\": 1092, \"end\": 1099, \"title\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"score\": 0.9999999999965894, \"rank\": 3.2991770991211546e-12, \"text\": \"Beijing\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2008_Summer_Olympics\"}, {\"begin\": 1251, \"end\": 1258, \"title\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"score\": 0.9999999999965894, \"rank\": 3.2991770991211546e-12, \"text\": \"Beijing\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2008_Summer_Olympics\"}, {\"begin\": 1260, \"end\": 1266, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9993317996568811, \"rank\": 0.000668183984048738, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}, {\"begin\": 1268, \"end\": 1282, \"title\": \"http://dbpedia.org/resource/Rio_de_Janeiro\", \"score\": 0.9999999999936335, \"rank\": 6.4282816237758356e-12, \"text\": \"Rio de Janeiro\", \"types\": [\"Q486972\", \"Q3957\"], \"wikid\": \"http://dbpedia.org/resource/Rio_de_Janeiro\", \"dbpedia\": \"http://dbpedia.org/resource/Rio_de_Janeiro\"}, {\"begin\": 1287, \"end\": 1292, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.9999272600848157, \"rank\": 7.274520531004178e-05, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}]}, {\"sentence\": \"She is also the first 100-meter sprinter to win individual medals in four straight editions of the Olympic Games.\", \"from\": 1294, \"to\": 1407, \"entities\": []}, {\"sentence\": \"Shelly-Ann Fraser-Pryce of Jamaica poses with the women's 100-meter silver medal after competing in the event's final at the Olympic Games in Tokyo, Japan, August 1, 2021.\", \"from\": 1409, \"to\": 1580, \"entities\": [{\"begin\": 1409, \"end\": 1432, \"title\": \"http://dbpedia.org/resource/Shelly-Ann_Fraser-Pryce\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Shelly-Ann Fraser-Pryce\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Shelly-Ann_Fraser-Pryce\", \"dbpedia\": \"http://dbpedia.org/resource/Shelly-Ann_Fraser-Pryce\"}, {\"begin\": 1436, \"end\": 1443, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.9999996152956386, \"rank\": 3.420355615946671e-07, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}, {\"begin\": 1551, \"end\": 1556, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.9999272600848157, \"rank\": 7.274520531004178e-05, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}]}, {\"sentence\": \"/CFP  Fraser-Pryce also secured 10 titles at the World Athletics Championships and became the oldest woman to win the 100-meter gold at the World Championships in Doha, Qatar, in 2019.\", \"from\": 1581, \"to\": 1765, \"entitie