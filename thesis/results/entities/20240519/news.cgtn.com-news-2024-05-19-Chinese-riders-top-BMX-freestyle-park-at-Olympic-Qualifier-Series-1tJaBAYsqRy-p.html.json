21, \"entities\": [{\"begin\": 1274, \"end\": 1279, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999998149178, \"rank\": 1.8490751472677372e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"Anthony Jeanjean of France won in the men's category with a superb first run, followed by Olympic champion Logan Martin of Australia and reigning world champion Darren David Kieran Reilly of Britain.\", \"from\": 1323, \"to\": 1522, \"entities\": [{\"begin\": 1343, \"end\": 1349, \"title\": \"http://dbpedia.org/resource/France_national_rugby_union_team\", \"score\": 0.9840947388832275, \"rank\": 0.00834687389763966, \"text\": \"France\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/France_national_rugby_union_team\", \"dbpedia\": \"http://dbpedia.org/resource/France_national_rugby_union_team\"}, {\"begin\": 1436, \"end\": 1442, \"title\": \"http://dbpedia.org/resource/Martin_Crane\", \"score\": 0.9126984903965106, \"rank\": 0.09565204182200306, \"text\": \"Martin\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Martin_Crane\", \"dbpedia\": \"http://dbpedia.org/resource/Martin_Crane\"}, {\"begin\": 1446, \"end\": 1455, \"title\": \"http://dbpedia.org/resource/Australia_women's_national_soccer_team\", \"score\": 0.8369226002901049, \"rank\": 0.11258741532070796, \"text\": \"Australia\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Australia_women's_national_soccer_team\", \"dbpedia\": \"http://dbpedia.org/resource/Australia_women's_national_soccer_team\"}, {\"begin\": 1497, \"end\": 1503, \"title\": \"http://dbpedia.org/resource/Kieran_Culkin\", \"score\": 0.8681958598465325, \"rank\": 0.15167403253269418, \"text\": \"Kieran\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kieran_Culkin\", \"dbp