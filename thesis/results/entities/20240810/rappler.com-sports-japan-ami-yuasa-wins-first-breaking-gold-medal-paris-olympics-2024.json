"{\"uid\": \"rappler.com-sports-japan-ami-yuasa-wins-first-breaking-gold-medal-paris-olympics-2024\", \"entities\": [{\"sentence\": \"  SUMMARY  This is AI generated summarization, which may have errors.\", \"from\": 0, \"to\": 69, \"entities\": [{\"begin\": 19, \"end\": 21, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 0.9999698908753964, \"rank\": 3.0110022147604447e-05, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}]}, {\"sentence\": \"For context, always refer to the full article.\", \"from\": 70, \"to\": 116, \"entities\": []}, {\"sentence\": \"BREAKING THROUGH.\", \"from\": 118, \"to\": 135, \"entities\": []}, {\"sentence\": \"Ami Yuasa of Japan in action.\", \"from\": 136, \"to\": 165, \"entities\": [{\"begin\": 149, \"end\": 154, \"title\": \"http://dbpedia.org/resource/Japan\", \"score\": 0.9998845662421753, \"rank\": 9.596121187297495e-05, \"text\": \"Japan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Japan\", \"dbpedia\": \"http://dbpedia.org/resource/Japan\"}]}, {\"sentence\": \"Angelika Warmuth/Reuters  PARIS, France - Japan's Ami Yuasa blended artistry and athleticism to win a battle against Lithuania's Dominika Banevic and dance her way to the first Olympic gold medal ever awarded for breaking on Friday, August 9.\", \"from\": 167, \"to\": 409, \"entities\": [{\"begin\": 184, \"end\": 191, \"title\": \"http://dbpedia.org/resource/Reuters\", \"score\": 0.9999999987462616, \"rank\": 6.95817986632185e-10, \"text\": \"Reuters\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Reuters\", \"dbpedia\": \"http://dbpedia.org/resource/Reuters\"}, {\"begin\": 200, \"end\": 206, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9377530585054916, \"rank\": 0.05329132815830998, \"text\": \"France\", \"types\": [\"Q6256\"], \"wik