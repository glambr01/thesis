"{\"uid\": \"rappler.com-sports-football-canada-women-team-loses-points-coach-banned-drone-scandal-paris-olympics-2024\", \"entities\": [{\"sentence\": \"  SUMMARY  This is AI generated summarization, which may have errors.\", \"from\": 0, \"to\": 69, \"entities\": [{\"begin\": 19, \"end\": 21, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 0.9999762573637866, \"rank\": 2.3718739819745595e-05, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}]}, {\"sentence\": \"For context, always refer to the full article.\", \"from\": 70, \"to\": 116, \"entities\": []}, {\"sentence\": \"STUMBLING.\", \"from\": 118, \"to\": 128, \"entities\": []}, {\"sentence\": \"Adriana Leon of Canada (left) in action with Ali Riley of New Zealand.\", \"from\": 129, \"to\": 199, \"entities\": [{\"begin\": 129, \"end\": 141, \"title\": \"http://dbpedia.org/resource/Adriana_Leon\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Adriana Leon\", \"types\": [\"Q937857\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Adriana_Leon\", \"dbpedia\": \"http://dbpedia.org/resource/Adriana_Leon\"}, {\"begin\": 145, \"end\": 151, \"title\": \"http://dbpedia.org/resource/Canada_women's_national_soccer_team\", \"score\": 1.0, \"rank\": 1.4020104389966974e-14, \"text\": \"Canada\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Canada_women's_national_soccer_team\", \"dbpedia\": \"http://dbpedia.org/resource/Canada_women's_national_soccer_team\"}, {\"begin\": 174, \"end\": 183, \"title\": \"http://dbpedia.org/resource/Ali_Riley\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Ali Riley\", \"types\": [\"Q937857\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Ali_Riley\", \"dbpedia\": \"http://dbpedia.org/resource/Ali_Riley\"}, {\"begin\": 187, \"end\": 198, \"title\": \"http://dbpedia.org/resource/New_Zealand_women's_national_football_team\", \"score\": 0.9998681534380276, \"rank\": 0.00013163187464341157, \"text\": \"New Zealand\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/New_Zealand_women's_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/New_Zealand_women's_national_football_team\"}]}, {\"sentence\": \"Thaier Al-Sudani/Reuters  PARIS, France - Canada was deducted six points in the Olympic women's football tournament and their head coach Bev Priestman banned for a year, global governing body FIFA said on Saturday, July 27, following a drone spying scandal that has tainted their gold medal defense.\", \"from\": 201, \"to\": 500, \"entities\": [{\"begin\": 234, \"end\": 240, \"title\": \"http://dbpedia.org/resource/France_national_football_team\", \"score\": 0.9948634410013342, \"rank\": 0.00515270431339254, \"text\": \"France\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/France_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/France_national_football_team\"}, {\"begin\": 243, \"end\": 249, \"title\": \"http://dbpedia.org/resource/Canada_women's_national_soccer_team\", \"score\": 1.0, \"rank\": 1.4020104389966974e-14, \"text\": \"Canada\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Canada_women's_national_soccer_team\", \"dbpedia\": \"http://dbpedia.org/resource/Canada_women's_national_soccer_team\"}, {\"begin\": 338, \"end\": 351, \"title\": \"http://dbpedia.org/resource/Bev_Priestman\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Bev Priestman\", \"types\": [\"Q729\", \"Q628099\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Bev_Priestman\", \"dbpedia\": \"http://dbpedia.org/resource/Bev_Priestman\"}, {\"begin\": 393, \"end\": 397, \"title\": \"http://dbpedia.org/resource/FIFA\", \"score\": 0.9999999954170562, \"rank\": 4.526293134276259e-09, \"text\": \"FIFA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/FIFA\", \"dbpedia\": \"http://dbpedia.org/resource/FIFA\"}]}, {\"sentence\": \"The Canadian Soccer Association, which said it was exploring how it could appeal the six-point deduction, was also fined 200,000 Swiss francs ($226,346) in a case that rocked the Paris Games.\", \"from\": 502, \"to\": 693, \"entities\": [{\"begin\": 506, \"end\": 533, \"title\": \"http://dbpedia.org/resource/Canadian_Soccer_Association\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Canadian Soccer Association\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Canadian_Soccer_Association\", \"dbpedia\": \"http://dbpedia.org/resource/Canadian_Soccer_Association\"}]}, {\"sentence\": \"Priestman, who has coached the team since 2020 and led them to the Olympic title in Tokyo a year later, and Canadian officials Joseph Lombardi and Jasmine Mander have been banned from any football-related activity for one year for \\\"offensive behavior and violation of the principles of fair play\\\", FIFA said.\", \"from\": 695, \"to\": 1003, \"entities\": [{\"begin\": 779, \"end\": 784, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.9999544719413013, \"rank\": 4.553003887144775e-05, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}, {\"begin\": 803, \"end\": 811, \"title\": \"http://dbpedia.org/resource/Canadians\", \"score\": 0.9967433968316364, \"rank\": 0.003154868970599479, \"text\": \"Canadian\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Canadians\", \"dbpedia\": \"http://dbpedia.org/resource/Canadians\"}, {\"begin\": 822, \"end\": 828, \"title\": \"http://dbpedia.org/resource/Saint_Joseph\", \"score\": 0.86731424456