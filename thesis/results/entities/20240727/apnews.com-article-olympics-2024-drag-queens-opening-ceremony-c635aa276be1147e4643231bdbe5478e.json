"{\"uid\": \"apnews.com-article-olympics-2024-drag-queens-opening-ceremony-c635aa276be1147e4643231bdbe5478e\", \"entities\": [{\"sentence\": \"Copyright 2025 The Associated Press.\", \"from\": 0, \"to\": 36, \"entities\": []}, {\"sentence\": \"All Rights Reserved.\", \"from\": 37, \"to\": 57, \"entities\": []}, {\"sentence\": \"Copyright 2025 The Associated Press.\", \"from\": 59, \"to\": 95, \"entities\": []}, {\"sentence\": \"All Rights Reserved.\", \"from\": 96, \"to\": 116, \"entities\": []}, {\"sentence\": \"Controversial social media personality Andrew Tate and his brother Tristan held a demonstration near the French Embassy in Bucharest on Sunday.\", \"from\": 118, \"to\": 261, \"entities\": [{\"begin\": 164, \"end\": 168, \"title\": \"http://dbpedia.org/resource/Tate\", \"score\": 0.9999998424455168, \"rank\": 8.743151618256243e-08, \"text\": \"Tate\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tate\", \"dbpedia\": \"http://dbpedia.org/resource/Tate\"}, {\"begin\": 185, \"end\": 192, \"title\": \"http://dbpedia.org/resource/Tristan\", \"score\": 0.9999979611564279, \"rank\": 2.038847472871036e-06, \"text\": \"Tristan\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tristan\", \"dbpedia\": \"http://dbpedia.org/resource/Tristan\"}, {\"begin\": 241, \"end\": 250, \"title\": \"http://dbpedia.org/resource/Bucharest\", \"score\": 1.0, \"rank\": 3.507539423471144e-15, \"text\": \"Bucharest\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Bucharest\", \"dbpedia\": \"http://dbpedia.org/resource/Bucharest\"}]}, {\"sentence\": \"The pair were protesting the opening ceremony of the 2024 Paris Olympics, claiming the Last Supper parody during the ceremony \\\"mocked Christianity\\\".\", \"from\": 262, \"to\": 410, \"entities\": [{\"begin\": 396, \"end\": 408, \"title\": \"http://dbpedia.org/resource/Christianity\", \"score\": 0.9999992718947319, \"rank\": 6.95208490453977e-07, \"text\": \"Christianity\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Christianity\", \"dbpedia\": \"http://dbpedia.org/resource/Christianity\"}]}, {\"sentence\": \"(AP video shot by Nicolae Dumitrache)  Drag queen Piche prepares to perform, at the Debilly Bridge in Paris, during the opening ceremony of the 2024 Summer Olympics, Friday, July 26, 2024.\", \"from\": 411, \"to\": 599, \"entities\": [{\"begin\": 412, \"end\": 414, \"title\": \"http://dbpedia.org/resource/Associated_Press\", \"score\": 1.0, \"rank\": 9.023714212890955e-19, \"text\": \"AP\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Associated_Press\", \"dbpedia\": \"http://dbpedia.org/resource/Associated_Press\"}, {\"begin\": 437, \"end\": 447, \"title\": \"http://dbpedia.org/resource/Florea_Dumitrache\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Dumitrache\", \"types\": [\"Q937857\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Florea_Dumitrache\", \"dbpedia\": \"http://dbpedia.org/resource/Florea_Dumitrache\"}, {\"begin\": 450, \"end\": 460, \"title\": \"http://dbpedia.org/resource/Drag_queen\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Drag queen\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Drag_queen\", \"dbpedia\": \"http://dbpedia.org/resource/Drag_queen\"}, {\"begin\": 513, \"end\": 518, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.1582185077868634e-22, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"(AP Photo/Tsvangirayi Mukwazhi)  Floriane Issert, a Gendarmerie non-commissioned officer of the National Gendarmerie, rides on a horse while leading volunteers carrying flags of Olympic teams on the Iena Bridge in Paris, France, during the opening ceremony of the 2024 Summer Olympics, Friday, July 26, 2024.\", \"from\": 600, \"to\": 908, \"entities\": [{\"begin\": 601, \"end\": 603, \"title\": \"http://dbpedia.org/resource/Associated_Press\", \"score\": 1.0, \"rank\": 9.023714212890955e-19, \"text\": \"AP\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Associated_Press\", \"dbpedia\": \"http://dbpedia.org/resource/Associated_Press\"}, {\"begin\": 652, \"end\": 663, \"title\": \"http://dbpedia.org/resource/Gendarmerie\", \"score\": 0.9999000147220667, \"rank\": 9.999520792667133e-05, \"text\": \"Gendarmerie\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Gendarmerie\", \"dbpedia\": \"http://dbpedia.org/resource/Gendarmerie\"}, {\"begin\": 696, \"end\": 716, \"title\": \"http://dbpedia.org/resource/Gendarmerie\", \"score\": 0.9341106633947994, \"rank\": 0.0705369705318826, \"text\": \"National Gendarmerie\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Gendarmerie\", \"dbpedia\": \"http://dbpedia.org/resource/Gendarmerie\"}, {\"begin\": 814, \"end\": 819, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.1582185077868634e-22, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 821, \"end\": 827, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9999088956540176, \"rank\": 4.967847310195369e-05, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}]}, {\"sentence\": \"(Ludovic Marin/Pool Photo via AP)  Drag queens prepare to perform on the Debilly Bridge in Paris, during the opening ceremony of the 2024 Summer Olympics, Friday, July 26, 2024.\", \"from\": 909, \"to\": 1086, \"entities\": [{\"begin\": 910, \"end\": 917, \"title\": \"http://dbpedia.org/resource/Ludovic_Stewart,_2nd_Duke_of_Lennox\", \"score\": 0.9117849635256159, \"rank\": 0.0755857898714761, \"text\": \"Ludovic\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Ludovic_Stewart,_2nd_Duke_of_Lennox\", \"dbpedia\": \"http://dbpedia.org/resource/Ludovic_Stewart,_2nd_Duke_of_Lennox\"}, {\"begin\": 939, \"end\": 941, \"title\": \"http://dbpedia.org/resource/Associated_Press\", \"score\": 1.0, \"rank\": 9.023714212890955e-19, \"text\": \"AP\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Associated_Press\", \"dbpedia\": \"http://dbpedia.org/resource/Associated_Press\"}, {\"begin\": 944, \"end\": 955, \"title\": \"http://dbpedia.org/resource/Drag_queen\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Drag queens\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Drag_queen\", \"dbpedia\": \"http://dbpedia.org/resource/Drag_queen\"}, {\"begin\": 1000, \"end\": 1005, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.1582185077868634e-22, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"(AP Photo/Tsvangirayi Mukwazhi)                  PARIS (AP) - In an unprecedented display of inclusivity, drag queens took center stage at theParis Olympics opening ceremony,showcasing the vibrant and influential role of the French LGBTQ+ community - while also attracting criticism over a tableau reminiscent of \\\"The Last Supper.\\\"\", \"from\": 1087, \"to\": 1418, \"entities\": [{\"begin\": 1088, \"end\": 1090, \"title\": \"http://dbpedia.org/resource/Associated_Press\", \"score\": 1.0, \"rank\": 9.023714212890955e-19, \"text\": \"AP\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Associated_Press\", \"dbpedia\": \"http://dbpedia.org/resource/Associated_Press\"}, {\"begin\": 1143, \"end\": 1145, \"title\": \"http://dbpedia.org/resource/Associated_Press\", \"score\": 1.0, \"rank\": 9.023714212890955e-19, \"text\": \"AP\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Associated_Press\", \"dbpedia\": \"http://dbpedia.org/resource/Associated_Press\"}, {\"begin\": 1312, \"end\": 1318, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.5324573301318009, \"rank\": 0.8368643140828711, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}]}, {\"sentence\": \"Held along the Seine River, thespectacular four-hour eventfeatured global stars such asCeline DionandLady Gaga,both considered queer icons.\", \"from\": 1420, \"to\": 1559, \"entities\": [{\"begin\": 1526, \"end\": 1530, \"title\": \"http://dbpedia.org/resource/Lady_Gaga\", \"score\": 1.0, \"rank\": 1.0533854554272324e-40, \"text\": \"Gaga\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Lady_Gaga\", \"dbpedia\": \"http://dbpedia.org/resource/Lady_Gaga\"}]}, {\"sentence\": \"The ceremony blendedhistoric and modern French culturewith a touch of kitsch, culminating in a flotilla of barges carrying thousands of Olympians.\", \"from\": 1560, \"to\": 1706, \"entities\": [{\"begin\": 1600, \"end\": 1606, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.5324573301318009, \"rank\": 0.8368643140828711, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}]}, {\"sentence\": \"Nicky Doll, known for competing on the 12th season of \\\"RuPaul's Drag Race\\\" and hosting \\\"Drag Race France,\\\" participated in a high-octane fashion runway segment along with \\\"Drag Race France\\\" Season 1 winner Paloma, Season 3's Piche, and Giselle Palmer.\", \"from\": 1708, \"to\": 1959, \"entities\": [{\"begin\": 1708, \"end\": 1718, \"title\": \"http://dbpedia.org/resource/Nicky_Doll\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Nicky Doll\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Nicky_Doll\", \"dbpedia\": \"http://dbpedia.org/resource/Nicky_Doll\"}, {\"begin\": 1914, \"end\": 1920, \"title\": \"http://dbpedia.org/resource/Paloma_Picasso\", \"score\": 0.9999999996575752, \"rank\": 3.424749152196896e-10, \"text\": \"Paloma\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Paloma_Picasso\", \"dbpedia\": \"http://dbpedia.org/resource/Paloma_Picasso\"}, {\"begin\": 1944, \"end\": 1951, \"title\": \"http://dbpedia.org/resource/Giselle\", \"score\": 0.9999859676838707, \"rank\": 1.4032513096642252e-05, \"text\": \"Giselle\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Giselle\", \"dbpedia\": \"http://dbpedia.org/resource/Giselle\"}, {\"begin\": 1952, \"end\": 1958, \"title\": \"http://dbpedia.org/resource/Palmer_River\", \"score\": 0.9764913485403335, \"rank\": 0.023630618271720003, \"text\": \"Palmer\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Palmer_River\", \"dbpedia\": \"http://dbpedia.org/resource/Palmer_River\"}]}, {\"sentence\": \"Initially, they stood alongside the runway, gazing fiercely at the strutting models.\", \"from\": 1960, \"to\": 2044, \"entities\": []}, {\"sentence\": \"Later, they joined in, showcasing their own style.\", \"from\": 2045, \"to\": 2095, \"entities\": []}, {\"sentence\": \"Le Filip, the recent winner of \\\"Drag Race France,\\\" expressed their positive \\\"surprise\\\" and \\\"pride\\\" at the ceremony's scale and representation.\", \"from\": 2097, \"to\": 2239, \"entities\": []}, {\"sentence\": \"\\\"I thought it would be a five-minute drag event with queer representation.\", \"from\": 2241, \"to\": 2315, \"entities\": []}, {\"sentence\": \"I was amazed.\", \"from\": 2316, \"to\": 2329, \"entities\": []}, {\"sentence\": \"It started with Lady Gaga, then we had drag queens, a huge rave, and a fire in the sky,\\\" they said.\", \"from\": 2330, \"to\": 2429, \"entities\": [{\"begin\": 2346, \"end\": 2355, \"title\": \"http://dbpedia.org/resource/Lady_Gaga\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Lady Gaga\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Lady_Gaga\", \"dbpedia\": \"http://dbpedia.org/resource/Lady_Gaga\"}]}, {\"sentence\": \"\\\"It felt like a crowning all over again.\", \"from\": 2430, \"to\": 2470, \"entities\": []}, {\"sentence\": \"I am proud to see my friends and queer people on the world stage.\\\"\", \"from\": 2471, \"to\": 2537, \"entities\": []}, {\"sentence\": \"Among their bold performanceswas a scene that seemed to evoke Leonardo da Vinci's \\\"The Last Supper,\\\" featuring the drag queens and other performers in a configuration reminiscent of Jesus Christ and his apostles.\", \"from\": 2541, \"to\": 2753, \"entities\": [{\"begin\": 2603, \"end\": 2620, \"title\": \"http://dbpedia.org/resource/Leonardo_da_Vinci\", \"score\": 1.0, \"rank\": 1.6154336922469288e-29, \"text\": \"Leonardo da Vinci\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Leonardo_da_Vinci\", \"dbpedia\": \"http://dbpedia.org/resource/Leonardo_da_Vinci\"}, {\"begin\": 2723, \"end\": 2735, \"title\": \"http://dbpedia.org/resource/Jesus\", \"score\": 0.999999782161036, \"rank\": 2.1783905233272907e-07, \"text\": \"Jesus Christ\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jesus\", \"dbpedia\": \"http://dbpedia.org/resource/Jesus\"}]}, {\"sentence\": \"This segment drew significant attention - and mixed reactions.\", \"from\": 2754, \"to\": 2816, \"entities\": []}, {\"sentence\": \"\\\"The (French) government knows what it's doing.\", \"from\": 2818, \"to\": 2865, \"entities\": [{\"begin\": 2824, \"end\": 2830, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.5324573301318009, \"rank\": 0.8368643140828711, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}]}, {\"sentence\": \"They want to show themselves in the best way possible.\", \"from\": 2866, \"to\": 2920, \"entities\": []}, {\"sentence\": \"They showed no restraints in expression,\\\" Le Filip told The Associated Press.\", \"from\": 2921, \"to\": 2998, \"entities\": [{\"begin\": 2981, \"end\": 2997, \"title\": \"http://dbpedia.org/resource/Associated_Press\", \"score\": 0.9992743871564282, \"rank\": 0.0007261397396742324, \"text\": \"Associated Press\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Associated_Press\", \"dbpedia\": \"http://dbpedia.org/resource/Associated_Press\"}]}, {\"sentence\": \"On the other hand, prominentfar-right politician Marion Mar\\u00e9chaldenounced the performance on social media.\", \"from\": 3000, \"to\": 3106, \"entities\": []}, {\"sentence\": \"\\\"To all the Christians of the world who are watching the Paris 2024 ceremony and felt insulted by this drag queen parody of the Last Supper, know that it is not France that is speaking but a left-wing minority ready for any provocation,\\\" she posted on the social platform X, a sentiment that was echoed by religious conservatives internationally.\", \"from\": 3108, \"to\": 3454, \"entities\": [{\"begin\": 3120, \"end\": 3130, \"title\": \"http://dbpedia.org/resource/Christians\", \"score\": 0.9683008743556835, \"rank\": 0.032736648296005005, \"text\": \"Christians\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Christians\", \"dbpedia\": \"http://dbpedia.org/resource/Christians\"}, {\"begin\": 3165, \"end\": 3175, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 9.379903169231521e-17, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 3269, \"end\": 3275, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9999088956540176, \"rank\": 4.967847310195369e-05, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}]}, {\"sentence\": \"\\\"... because decapitating Habsburgs and ridiculising central Christian events are really the FIRST two things that spring to mind when you think of #OlympicGames,\\\"Eduard Habsburg,Hungary's ambassador to the Vatican, posted on X, also referencing a scene depicting the beheading of Marie Antoinette.\", \"from\": 3456, \"to\": 3754, \"entities\": [{\"begin\": 3482, \"end\": 3491, \"title\": \"http://dbpedia.org/resource/House_of_Habsburg\", \"score\": 0.9999874093924972, \"rank\": 1.256404468629107e-05, \"text\": \"Habsburgs\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/House_of_Habsburg\", \"dbpedia\": \"http://dbpedia.org/resource/House_of_Habsburg\"}, {\"begin\": 3517, \"end\": 3526, \"title\": \"http://dbpedia.org/resource/Christians\", \"score\": 0.6783968758606359, \"rank\": 0.4740633919956488, \"text\": \"Christian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Christians\", \"dbpedia\": \"http://dbpedia.org/resource/Christians\"}, {\"begin\": 3626, \"end\": 3634, \"title\": \"http://dbpedia.org/resource/House_of_Habsburg\", \"score\": 0.9988446880273796, \"rank\": 0.0011203552941610386, \"text\": \"Habsburg\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/House_of_Habsburg\", \"dbpedia\": \"http://dbpedia.org/resource/House_of_Habsburg\"}, {\"begin\": 3635, \"end\": 3642, \"title\": \"http://dbpedia.org/resource/Hungary\", \"score\": 0.9935939967741335, \"rank\": 0.006130260717212384, \"text\": \"Hungary\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Hungary\", \"dbpedia\": \"http://dbpedia.org/resource/Hungary\"}, {\"begin\": 3737, \"end\": 3753, \"title\": \"http://dbpedia.org/resource/Marie_Antoinette\", \"score\": 1.0, \"rank\": 6.93258006778665e-37, \"text\": \"Marie Antoinette\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Marie_Antoinette\", \"dbpedia\": \"http://dbpedia.org/resource/Marie_Antoinette\"}]}, {\"sentence\": \"Thomas Jolly, the artistic director of the opening ceremony,afterward drew attention away from \\\"The Last Supper\\\" references, saying that had not been his intention.\", \"from\": 3756, \"to\": 3920, \"entities\": [{\"begin\": 3756, \"end\": 3762, \"title\": \"http://dbpedia.org/resource/Thomas_the_Apostle\", \"score\": 0.9946787003834167, \"rank\": 0.004132769181198916, \"text\": \"Thomas\", \"types\": [\"Q729\", \"Q5\", \"Q43115\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Thomas_the_Apostle\", \"dbpedia\": \"http://dbpedia.org/resource/Thomas_the_Apostle\"}]}, {\"sentence\": \"Le Filip responded to the criticism of the scene with a touch of humor and sorrow.\", \"from\": 3922, \"to\": 4004, \"entities\": []}, {\"sentence\": \"\\\"It feels like the words of somebody who did not get on the guest list.\", \"from\": 4006, \"to\": 4077, \"entities\": []}, {\"sentence\": \"We could all be laughing together.\", \"from\": 4078, \"to\": 4112, \"entities\": []}, {\"sentence\": \"It's sad to me, honestly,\\\" they said.\", \"from\": 4113, \"to\": 4150, \"entities\": []}, {\"sentence\": \"Inter-LGBT President James Leperlier was more circumspect, arguing that France still hassignificant strides to makein inclusivity.\", \"from\": 4152, \"to\": 4282, \"entities\": [{\"begin\": 4152, \"end\": 4162, \"title\": \"http://dbpedia.org/resource/Inter-LGBT\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Inter-LGBT\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Inter-LGBT\", \"dbpedia\": \"http://dbpedia.org/resource/Inter-LGBT\"}, {\"begin\": 4224, \"end\": 4230, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9999088956540176, \"rank\": 4.967847310195369e-05, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}]}, {\"sentence\": \"\\\"We know in the LGBTQ community in France we are far from what the ceremony showed.\", \"from\": 4284, \"to\": 4367, \"entities\": [{\"begin\": 4319, \"end\": 4325, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9999088956540176, \"rank\": 4.967847310195369e-05, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}]}, {\"sentence\": \"There is much progress to do in society regarding transgender people.\", \"from\": 4368, \"to\": 4437, \"entities\": []}, {\"sentence\": \"It's terrible that to legally change their identity they are forced to be on trial,\\\" Leperlier said.\", \"from\": 4438, \"to\": 4538, \"entities\": []}, {\"sentence\": \"He also highlighted the disparity in acceptance, saying that the community is not visible in other official ceremonies and \\\"has difficulty being heard.\\\"\", \"from\": 4540, \"to\": 4692, \"entities\": []}, {\"sentence\": \"\\\"If you saw the opening ceremony last night you'd think it was like that normally, but it's not.\", \"from\": 4694, \"to\": 4790, \"entities\": []}, {\"sentence\": \"France tried to show what it should be and not what it is,\\\" he said.\", \"from\": 4791, \"to\": 4859, \"entities\": [{\"begin\": 4791, \"end\": 4797, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9999088956540176, \"rank\": 4.967847310195369e-05, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}]}, {\"sentence\": \"Theopening ceremonycame as drag and the voguing nightclub scene in France has experienced a revival.\", \"from\": 4861, \"to\": 4961, \"entities\": [{\"begin\": 4928, \"end\": 4934, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9999088956540176, \"rank\": 4.967847310195369e-05, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}]}, {\"sentence\": \"The cabaret club Madame Arthur, founded in 1946 in the ashes of World War II, is one of the world's oldest continually running LGBTQ+ theaters.\", \"from\": 4962, \"to\": 5105, \"entities\": [{\"begin\": 4986, \"end\": 4992, \"title\": \"http://dbpedia.org/resource/King_Arthur\", \"score\": 0.9999999999868123, \"rank\": 1.3315739876111325e-11, \"text\": \"Arthur\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/King_Arthur\", \"dbpedia\": \"http://dbpedia.org/resource/King_Arthur\"}]}, {\"sentence\": \"It opened as Europe was only just beginning to understand the extent of the widespread murder of members of the queer community in WWII and is currently experiencing a massive renaissance.\", \"from\": 5106, \"to\": 5294, \"entities\": []}, {\"sentence\": \"Drag is not just a pastime; for many minority French communities who feel alienated over tensions arising from divisive politics and scars from the anti-gay marriage protests a decade ago, it's a statement of defiance.\", \"from\": 5296, \"to\": 5514, \"entities\": [{\"begin\": 5342, \"end\": 5348, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.5324573301318009, \"rank\": 0.8368643140828711, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}]}, {\"sentence\": \"Many gay Black and Arab youths - especially those from Paris' less affluent and religiously conservative suburbs - and others who feel a sense of disconnect with French societyfind voguing and drag events safe placeswhere their identities can be expressed without fear of reprisal.\", \"from\": 5515, \"to\": 5796, \"entities\": [{\"begin\": 5534, \"end\": 5538, \"title\": \"http://dbpedia.org/resource/Arab_world\", \"score\": 0.9994876400603074, \"rank\": 0.0005081509591278919, \"text\": \"Arab\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Arab_world\", \"dbpedia\": \"http://dbpedia.org/resource/Arab_world\"}, {\"begin\": 5570, \"end\": 5575, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.1582185077868634e-22, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 5677, \"end\": 5683, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.5324573301318009, \"rank\": 0.8368643140828711, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}]}, {\"sentence\": \"Despite the backlash, Le Filip believes the opening ceremony will ultimately transcend controversy.\", \"from\": 5798, \"to\": 5897, \"entities\": []}, {\"sentence\": \"\\\"The message of the show is freedom, and it's a good postcard for France,\\\" they concluded.\", \"from\": 5899, \"to\": 5989, \"entities\": [{\"begin\": 5965, \"end\": 5971, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9999088956540176, \"rank\": 4.967847310195369e-05, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}]}, {\"sentence\": \"___  Associated Press journalist John Leicester contributed reporting.\", \"from\": 5991, \"to\": 6061, \"entities\": [{\"begin\": 5996, \"end\": 6012, \"title\": \"http://dbpedia.org/resource/Associated_Press\", \"score\": 0.9992743871564282, \"rank\": 0.0007261397396742324, \"text\": \"Associated Press\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Associated_Press\", \"dbpedia\": \"http://dbpedia.org/resource/Associated_Press\"}, {\"begin\": 6029, \"end\": 6038, \"title\": \"http://dbpedia.org/resource/Leicester\", \"score\": 0.9999997899112935, \"rank\": 1.9768117615870315e-07, \"text\": \"Leicester\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Leicester\", \"dbpedia\": \"http://dbpedia.org/resource/Leicester\"}]}, {\"sentence\": \"___  For more coverage of the Paris Olympics, visithttps://apnews.com/hub/2024-paris-olympic-games.\", \"from\": 6063, \"to\": 6162, \"entities\": []}, {\"sentence\": \"Copyright 2025 The Associated Press.\", \"from\": 6172, \"to\": 6208, \"entities\": []}, {\"sentence\": \"All Rights Reserved.\", \"from\": 6209, \"to\": 6229, \"entities\": []}]}"