0e2\\u0080\\u0099s won.\", \"from\": 262, \"to\": 347, \"entities\": []}, {\"sentence\": \"It was also his third goal medal in this event.\", \"from\": 348, \"to\": 395, \"entities\": []}, {\"sentence\": \"TEAM USA STRIKES GOLD.\", \"from\": 397, \"to\": 419, \"entities\": [{\"begin\": 397, \"end\": 405, \"title\": \"http://dbpedia.org/resource/United_States_national_team\", \"score\": 0.9548284472213237, \"rank\": 0.047308553328360974, \"text\": \"TEAM USA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_national_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_national_team\"}, {\"begin\": 414, \"end\": 418, \"title\": \"http://dbpedia.org/resource/Genomes_OnLine_Database\", \"score\": 0.9968121465142001, \"rank\": 0.003196348665152485, \"text\": \"GOLD\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Genomes_OnLine_Database\", \"dbpedia\": \"http://dbpedia.org/resource/Genomes_OnLine_Database\"}]}, {\"sentence\": \"\\u00f0\\u009f\\u0092\\u00aaCAELEB DRESSEL BRINGS IT HOME IN THE MEN'S 4X100 FREE RELAY.#ParisOlympicspic.twitter.com/rJwrSEWhps  The anchor of the group, Dressel notched a 47.53-second 100-meter individual swim to seal the top spot.\", \"from\": 420, \"to\": 629, \"entities\": []}, {\"sentence\": \"As a group, the United States\\u00e2\\u0080\\u0099 medley team finished with an overall time of 3:09.28, beating out rivals Australia (silver) and Italy (bronze).\", \"from\": 630, \"to\": 774, \"entities\": [{\"begin\": 736, \"end\": 745, \"title\": \"http://dbpedia.org/resource/Australia_women's_national_soccer_team\", \"score\": 0.9598835348240444, \"rank\": 0.04151769785216614, \"text\": \"Australia\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Australia_women's_national_soccer_team\", \"dbpedia\": \"http://dbpedia.org/resource/Australia_women's_national_soccer_team\"}, {\"begin\": 759, \"end\": 764, \"title\": \"http://dbpedia.org/resource/Italy_national_rugby_union_team\", \"score\": 0.9816072536143913, \"rank\": 0.010319723579118359, \"text\": \"Italy\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Italy_national_rugby_union_team\", \"dbpedia\": \"http://dbpedia.org/resource/Italy_national_rugby_union_team\"}]}, {\"sentence\": \"Next, Dressel will compete in the 50-meter freestyle on Aug. 2.\", \"from\": 776, \"to\": 839, \"entities\": []}, {\"sentence\": \"He\\u00e2\\u0080\\u0099ll also compete in the 100-meter butterfly the following day and the 4x100-meter medley relay on Aug. 4.\", \"from\": 840, \"to\": 949, \"entities\": []}, {\"sentence\": \"Dressel won gold medals in all of those events in Tokyo in 2021.\\u00c2  Dressel wasn\\u00e2\\u0080\\u0099t the only Gator to be a finalist in the event.\", \"from\": 950, \"to\": 1079, \"entities\": [{\"begin\": 1000, \"end\": 1005, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.938166803534039, \"rank\": 0.06590853149851543, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}]}, {\"sentence\": \"Josh Liendo (2022-present) anchored Canada to a sixth-place finish.\\u00c2  Other Gators of Note  Two more UF swimmers began Olympic play on Saturday.\\u00c2  Venezuela\\u00e2\\u0080\\u0099s Alfonso Mestre (2019-2023) and the United States\\u00e2\\u0080\\u0099 Kieran Smith (2018-2022) each finished sixth in their respective heats for the 400-meter freestyle and did not advance to the finals.\", \"from\": 1080, \"to\": 1426, \"entities\": [{\"begin\": 1080, \"end\": 1084, \"title\": \"http://dbpedia.org/resource/Josh_Lyman\", \"score\": 0.9966459474738947, \"rank\": 0.002436032154147372, \"text\": \"Josh\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Josh_Lyman\", \"dbpedia\": \"http://dbpedia.org/resource/Josh_Lyman\"}, {\"begin\": 1116, \"end\": 1122, \"title\": \"http://dbpedia.org/resource/Canada_men's_n