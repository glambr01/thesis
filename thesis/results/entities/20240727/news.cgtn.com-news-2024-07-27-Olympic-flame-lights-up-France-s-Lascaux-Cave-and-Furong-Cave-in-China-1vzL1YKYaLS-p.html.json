ies\": [{\"begin\": 717, \"end\": 738, \"title\": \"http://dbpedia.org/resource/Upper_Paleolithic\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Upper Paleolithic era\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Upper_Paleolithic\", \"dbpedia\": \"http://dbpedia.org/resource/Upper_Paleolithic\"}]}, {\"sentence\": \"They stand as some of humanity's earliest artistic expressions.\", \"from\": 802, \"to\": 865, \"entities\": []}, {\"sentence\": \"To protect the site, the original cave was closed to the public in 1963.\", \"from\": 867, \"to\": 939, \"entities\": []}, {\"sentence\": \"Visitors can now explore a replica, Lascaux Cave II.\", \"from\": 940, \"to\": 992, \"entities\": [{\"begin\": 976, \"end\": 988, \"title\": \"http://dbpedia.org/resource/Lascaux\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Lascaux Cave\", \"types\": [\"Q9259\"], \"wikid\": \"http://dbpedia.org/resource/Lascaux\", \"dbpedia\": \"http://dbpedia.org/resource/Lascaux\"}, {\"begin\": 989, \"end\": 991, \"title\": \"http://dbpedia.org/resource/World_War_II\", \"score\": 0.9999668759259819, \"rank\": 3.137714821872814e-05, \"text\": \"II\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/World_War_II\", \"dbpedia\": \"http://dbpedia.org/resource/World_War_II\"}]}, {\"sentence\": \"A file photo shows a view of Furong Cave in Wulong, southwest China's Chongqing.\", \"from\": 994, \"to\": 1074, \"entities\": [{\"begin\": 1023, \"end\": 1034, \"title\": \"http://dbpedia.org/resource/Furong_Cave\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Furong Cave\", \"types\": [\"Q35509\"], \"wikid\": \"http://dbpedia.org/resource/Furong_Cave\", \"dbpedia\": \"http://dbpedia.org/resource/Furong_Cave\"}]}, {\"sentence\": \"/CFP  Located in Wulong, Chongqing, Furong Cave is now a national-level tourist attraction in China.\", \"from\": 1075, \"to\": 1175, \"entities\": [{\"begin\": 1100, \"end\": 1109, \"title\": \"http://dbpedia.org/resource/Chongqing\", \"score\": 0.99999999999