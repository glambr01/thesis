"{\"uid\": \"express.co.uk-celebrity-news-1928179-hazel-irvine-age-marriage-children-olympics\", \"entities\": [{\"sentence\": \"  The Paris Olympics have kicked off in 2024 keeping us all captivated whether we are tuning in from the comfort of our homes or enjoying a pint at the local pub.\", \"from\": 0, \"to\": 162, \"entities\": []}, {\"sentence\": \"Hazel Irvine, the Scottish sports host who has covered everything from snooker and golf to the Olympics marks her fifth time presenting the Olympics - she previously hosted the 2014 Sochi Winter Olympics, the 2016 Rio Olympics, the 2018 Winter Olympics and the Tokyo Olympics in 2021.\", \"from\": 163, \"to\": 447, \"entities\": [{\"begin\": 169, \"end\": 175, \"title\": \"http://dbpedia.org/resource/Clan_Irvine\", \"score\": 0.9993863011852349, \"rank\": 0.0006140634723382764, \"text\": \"Irvine\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Clan_Irvine\", \"dbpedia\": \"http://dbpedia.org/resource/Clan_Irvine\"}, {\"begin\": 181, \"end\": 189, \"title\": \"http://dbpedia.org/resource/Scottish_Television\", \"score\": 0.8378340328772659, \"rank\": 0.1683669559805355, \"text\": \"Scottish\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\", \"Q141683\"], \"wikid\": \"http://dbpedia.org/resource/Scottish_Television\", \"dbpedia\": \"http://dbpedia.org/resource/Scottish_Television\"}, {\"begin\": 372, \"end\": 389, \"title\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"score\": 0.9999999999583906, \"rank\": 4.0329305275350574e-11, \"text\": \"2016 Rio Olympics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2016_Summer_Olympics\"}, {\"begin\": 424, \"end\": 438, \"title\": \"http://dbpedia.org/resource/2020_Summer_Olympics\", \"score\": 0.9999999680196657, \"rank\": 3.197998793786465e-08, \"text\": \"Tokyo Olympics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2020_Summer_Olympi