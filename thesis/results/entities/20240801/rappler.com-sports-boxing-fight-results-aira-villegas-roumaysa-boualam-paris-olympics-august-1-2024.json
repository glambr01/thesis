": [{\"begin\": 572, \"end\": 579, \"title\": \"http://dbpedia.org/resource/Algeria\", \"score\": 0.9800808067306656, \"rank\": 0.020150587550074834, \"text\": \"Algeria\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Algeria\", \"dbpedia\": \"http://dbpedia.org/resource/Algeria\"}, {\"begin\": 665, \"end\": 671, \"title\": \"http://dbpedia.org/resource/Manila\", \"score\": 0.999837310948456, \"rank\": 0.00016263975734496432, \"text\": \"Manila\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Manila\", \"dbpedia\": \"http://dbpedia.org/resource/Manila\"}]}, {\"sentence\": \"\\\"This is the best gift ever to myself.\", \"from\": 680, \"to\": 718, \"entities\": []}, {\"sentence\": \"I will remember this for the rest of my life.\", \"from\": 719, \"to\": 764, \"entities\": []}, {\"sentence\": \"This is a gift to my younger self and to my future self.\", \"from\": 765, \"to\": 821, \"entities\": []}, {\"sentence\": \"I heard [fans singing happy birthday].\", \"from\": 822, \"to\": 860, \"entities\": []}, {\"sentence\": \"I am very grateful,\\\" Villegas told reporters.\", \"from\": 861, \"to\": 906, \"entities\": []}, {\"sentence\": \"Getting the nod of all five judges by scores of 30-27, 30-27, 29-28, 29-28, 29-28, Villegas moved within a victory of a guaranteed medal.\", \"from\": 908, \"to\": 1045, \"entities\": []}, {\"sentence\": \"The pride of Tacloban City clinched the first and third rounds to set up a date with home bet Wassila Lkhadiri of France as they lock horns for a spot in the semifinals on Saturday, August 3 (Sunday, August 4, Manila time).\", \"from\": 1047, \"to\": 1270, \"entities\": [{\"begin\": 1060, \"end\": 1073, \"title\": \"http://dbpedia.org/resource/Tacloban\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Tacloban City\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tacloban\", \"dbpedia\": \"http://dbpedia.org/resource/Tacloban\"}, {\"begin\": 1161, \"end\": 1167, \"title\": \"http://dbpedia.org/resource/France_national_football_team\", \"score\": 0.8590562512235238, \"rank\": 0.10336543572194946, \"text\": \"France\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/France_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/France_national_football_team\"}, {\"begin\": 1257, \"end\": 1263, \"title\": \"http://dbpedia.org/resource/Manila\", \"score\": 0.999837310948456, \"rank\": 0.00016263975734496432, \"text\": \"Manila\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Manila\", \"dbpedia\": \"http://dbpedia.org/resource/Manila\"}]}, {\"sentence\": \"All four semifinalists are assured of at least a bronze.\", \"from\": 1272, \"to\": 1328, \"entities\": []}, {\"sentence\": \"\\\"I am very proud of myself,\\\" Villegas said.\", \"from\": 1330, \"to\": 1373, \"entities\": []}, {\"sentence\": \"\\\"At the moment, a medal is just only a dream.\", \"from\": 1374, \"to\": 1419, \"entities\": []}, {\"sentence\": \"But I am here.\", \"from\": 1420, \"to\": 1434, \"entities\": []}, {\"sentence\": \"And I am very proud that I can be here.\\\"\", \"from\": 1435, \"to\": 1475, \"entities\": []}, {\"sentence\": \"Boualam, a two-time African Games champion, kept the result in the balance when she won the second round, 3-2, but slowed down in the final round as Villegas landed the clearer shots to nail the unanimous decision win.\", \"from\": 1477, \"to\": 1695, \"entities\": [{\"begin\": 1497, \"end\": 1510, \"title\": \"http://dbpedia.org/resource/2019_African_Games\", \"score\": 0.9950301567030015, \"rank\": 0.004994626396493829, \"text\": \"African Games\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2019_African_Games\", \"dbpedia\": \"http://dbpedia.org/resource/2019_African_Games\"}]}, {\"sentence\": \"Villegas' triumph marked her second over a foe from the African continent after she beat Morocco's Yasmine Mouttaki in the round of 32, also viaunanimous decision.\", \"from\": 1697, \"to\": 1860, \"entities\": [{\"begin\": 1786, \"end\": 1793, \"title\": \"http://dbpedia.org/resource/Morocco_national_football_team\", \"score\": 0.8262071127334359, \"rank\": 0.21021291978823106, \"text\": \"Morocco\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Morocco_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Morocco_national_football_team\"}]}, {\"sentence\": \"Reaching the semifinals, though, will not come easy for Villegas as she faces a challenging opponent in Lkhadiri, who bagged bronze in the previous IBA Women's World Boxing Championships.\", \"from\": 1862, \"to\": 2049, \"entities\": [{\"begin\": 2010, \"end\": 2013, \"title\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\", \"score\": 0.9809336481633136, \"rank\": 0.015405024402558297, \"text\": \"IBA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\", \"dbpedia\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\"}, {\"begin\": 2028, \"end\": 2034, \"title\": \"http://dbpedia.org/resource/Boxing\", \"score\": 0.9999999199480986, \"rank\": 8.005162500711672e-08, \"text\": \"Boxing\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Boxing\", \"dbpedia\": \"http://dbpedia.org/resource/Boxing\"}]}, {\"sentence\": \"Lkhadiri, who drew a first-round bye as the seventh seed, reached the quarterfinals following a 4-1 victory over Ireland's Daina Moorehouse in the round of 16.\", \"from\": 2051, \"to\": 2210, \"entities\": [{\"begin\": 2164, \"end\": 2171, \"title\": \"http://dbpedia.org/resource/Ireland_national_rugby_union_team\", \"score\": 0.7572628271919974, \"rank\": 0.3031360840767618, \"text\": \"Ireland\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ireland_national_rugby_union_team\", \"dbpedia\": \"http://dbpedia.org/resource/Ireland_national_rugby_union_team\"}]