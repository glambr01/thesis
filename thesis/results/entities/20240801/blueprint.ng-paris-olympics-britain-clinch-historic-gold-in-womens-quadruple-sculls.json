.org/resource/United_Kingdom\"}]}, {\"sentence\": \"Earlier, Team GB's men finished fourth in the same event with the Netherlands successfully defending their title from Tokyo.\", \"from\": 711, \"to\": 835, \"entities\": [{\"begin\": 720, \"end\": 727, \"title\": \"http://dbpedia.org/resource/Team_GB\", \"score\": 1.0, \"rank\": 3.2241062473272834e-15, \"text\": \"Team GB\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Team_GB\", \"dbpedia\": \"http://dbpedia.org/resource/Team_GB\"}, {\"begin\": 777, \"end\": 788, \"title\": \"http://dbpedia.org/resource/Netherlands\", \"score\": 0.9047066110638147, \"rank\": 0.09937527939431676, \"text\": \"Netherlands\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Netherlands\", \"dbpedia\": \"http://dbpedia.org/resource/Netherlands\"}, {\"begin\": 829, \"end\": 834, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.9999459834795077, \"rank\": 5.401077383531359e-05, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}]}, {\"sentence\": \"Tom Barras was the only remaining rower from the GB team that won silver in 2021, with Callum Dixon, Matthew Haywood and Graeme Thomas completing the quartet that finished almost two seconds behind Poland in third, with Italy claiming silver.\", \"from\": 837, \"to\": 1079, \"entities\": [{\"begin\": 837, \"end\": 847, \"title\": \"http://dbpedia.org/resource/Tom_Barras\", \"score\": 0.9999999983151611, \"rank\": 1.6843675343881797e-09, \"text\": \"Tom Barras\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Tom_Barras\", \"dbpedia\": \"http://dbpedia.org/resource/Tom_Barras\"}, {\"begin\": 886, \"end\": 888, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9042578916784302, \"rank\": 0.10587920680833945, \"text\": \"GB\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}, {\"begin\": 924, \"end\": 936, \"title\": \"http://dbpedia.org/resource/Callum_Dixon\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Callum Dixon\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Callum_Dixon\", \"dbpedia\": \"http://dbpedia.org/resource/Callum_Dixon\"}, {\"begin\": 946, \"end\": 953, \"title\": \"http://dbpedia.org/resource/Hurley_Haywood\", \"score\": 0.5441763471678558, \"rank\": 0.8376395903193855, \"text\": \"Haywood\", \"types\": [\"Q729\", \"Q5\", \"Q378622\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Hurley_Haywood\", \"dbpedia\": \"http://dbpedia.org/resource/Hurley_Haywood\"}, {\"begin\": 958, \"end\": 971, \"title\": \"http://dbpedia.org/resource/Graeme_Thomas\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Graeme Thomas\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Graeme_Thomas\", \"dbpedia\": \"http://dbpedia.org/resource/Graeme_Thomas\"}, {\"begin\": 1035, \"end\": 1041, \"title\": \"http://dbpedia.org/resource/Poland\", \"score\": 0.7590159069594898, \"rank\": 0.3014959687738331, \"text\": \"Poland\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Poland\", \"dbpedia\": \"http://dbpedia.org/resource/Poland\"}, {\"begin\": 1057, \"end\": 1062, \"title\": \"http://dbpedia.org/resource/Italy\", \"score\": 0.934630687694906, \"rank\": 0.06991874789496567, \"text\": \"Italy\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Italy\", \"dbpedia\": \"http://dbpedia.org/resource/Italy\"}]}, {\"sentence\": \"It is the first time Team GB have won the quadruple sculls in the Olympics and is the latest emotional instalment in the lives of some of the quartet.\", \"from\": 1081, \"to\": 1231, \"entities\": [{\"begin\": 1097, \"end\": 1106, \"title\": \"http://dbpedia.org/resource/Time_Team\", \"score\