"rank\": 0.0, \"text\": \"Amalie Dideriksen\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Amalie_Dideriksen\", \"dbpedia\": \"http://dbpedia.org/resource/Amalie_Dideriksen\"}, {\"begin\": 3780, \"end\": 3787, \"title\": \"http://dbpedia.org/resource/Denmark\", \"score\": 0.9982134593809405, \"rank\": 0.0017833253618068376, \"text\": \"Denmark\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Denmark\", \"dbpedia\": \"http://dbpedia.org/resource/Denmark\"}, {\"begin\": 3811, \"end\": 3822, \"title\": \"http://dbpedia.org/resource/Netherlands\", \"score\": 0.9985387964679748, \"rank\": 0.0014081033510041398, \"text\": \"Netherlands\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Netherlands\", \"dbpedia\": \"http://dbpedia.org/resource/Netherlands\"}, {\"begin\": 3829, \"end\": 3841, \"title\": \"http://dbpedia.org/resource/Kirsten_Wild\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Kirsten Wild\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kirsten_Wild\", \"dbpedia\": \"http://dbpedia.org/resource/Kirsten_Wild\"}, {\"begin\": 3900, \"end\": 3906, \"title\": \"http://dbpedia.org/resource/Yvonne_Jeffries\", \"score\": 0.9999494323081519, \"rank\": 4.795095469430707e-05, \"text\": \"Yvonne\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Yvonne_Jeffries\", \"dbpedia\": \"http://dbpedia.org/resource/Yvonne_Jeffries\"}, {\"begin\": 3907, \"end\": 3915, \"title\": \"http://dbpedia.org/resource/Stenberg_v._Carhart\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Stenberg\", \"types\": [\"Q2334719\"], \"wikid\": \"http://dbpedia.org/resource/Stenberg_v._Carhart\", \"dbpedia\": \"http://dbpedia.org/resource/Stenberg_v._Carhart\"}, {\"begin\": 3917, \"end\": 3923, \"title\": \"http://dbpedia.org/resource/Norway_women's_national_football_team\", \"score\": 0.9672540263746034, \"rank\": 0.0338535962700147