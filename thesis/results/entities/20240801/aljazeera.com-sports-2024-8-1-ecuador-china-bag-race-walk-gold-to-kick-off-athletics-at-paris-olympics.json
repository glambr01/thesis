873882514509917, \"rank\": 0.006839814493797099, \"text\": \"Ecuador\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ecuador\", \"dbpedia\": \"http://dbpedia.org/resource/Ecuador\"}, {\"begin\": 143, \"end\": 156, \"title\": \"http://dbpedia.org/resource/Brian_Pintado\", \"score\": 0.9999756886936054, \"rank\": 0.0, \"text\": \"Brian Pintado\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Brian_Pintado\", \"dbpedia\": \"http://dbpedia.org/resource/Brian_Pintado\"}]}, {\"sentence\": \"Brazil's Caio Bonfim improved on his fourth-place finish in Rio de Janeiro in 2016 by taking silver, and Spain's world champion Alvaro Martin took the bronze as the track and field events got under way in the French capital on Thursday.\", \"from\": 278, \"to\": 514, \"entities\": [{\"begin\": 278, \"end\": 284, \"title\": \"http://dbpedia.org/resource/Brazil_national_football_team\", \"score\": 0.9999650820553256, \"rank\": 1.9386806771792554e-05, \"text\": \"Brazil\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Brazil_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Brazil_national_football_team\"}, {\"begin\": 287, \"end\": 298, \"title\": \"http://dbpedia.org/resource/Caio_Bonfim\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Caio Bonfim\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Caio_Bonfim\", \"dbpedia\": \"http://dbpedia.org/resource/Caio_Bonfim\"}, {\"begin\": 338, \"end\": 352, \"title\": \"http://dbpedia.org/resource/Rio_de_Janeiro\", \"score\": 1.0, \"rank\": 1.4146086639773436e-15, \"text\": \"Rio de Janeiro\", \"types\": [\"Q486972\", \"Q3957\"], \"wikid\": \"http://dbpedia.org/resource/Rio_de_Janeiro\", \"dbpedia\": \"http://dbpedia.org/resource/Rio_de_Janeiro\"}, {\"begin\": 383, \"end\": 388, \"title\": \"http://dbpedia.org/resource/Spain_national_football_team\", \"score\": 0.8354356924606374, \"rank\": 0.19694663638714338, \"text\": \"Spain\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Spain_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Spain_national_football_team\"}, {\"begin\": 413, \"end\": 419, \"title\": \"http://dbpedia.org/resource/Glenn_L._Martin_Company\", \"score\": 0.9708343584022106, \"rank\": 0.030041772195209236, \"text\": \"Martin\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Glenn_L._Martin_Company\", \"dbpedia\": \"http://dbpedia.org/resource/Glenn_L._Martin_Company\"}, {\"begin\": 487, \"end\": 493, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.6243830860682931, \"rank\": 0.46568836793494334, \"text\": \"French\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}]}, {\"sentence\": \"In the women's category, China's Yang Jiayu claimed gold by pulling away from the field after the 5km mark and barely looking back en route to a victory that fulfilled a promise made to her late father.\", \"from\": 516, \"to\": 718, \"entities\": [{\"begin\": 541, \"end\": 546, \"title\": \"http://dbpedia.org/resource/China_national_football_team\", \"score\": 0.9446718489097421, \"rank\": 0.05839486531279115, \"text\": \"China\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/China_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/China_national_football_team\"}, {\"begin\": 549, \"end\": 559, \"title\": \"http://dbpedia.org/resource/Yang_Jiayu\", \"score\": 0.9999925378334525, \"rank\": 0.0, \"text\": \"Yang Jiayu\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Yang_Jiayu\", \"dbpedia\": \"http://dbpedia.org/resource/Yang_Jiayu\"}]}, {\"sentence\": \"Yang crossed the finish line in one hour, 25 minutes and 54 seconds.\", \"from\": 720, \"to\": 788, \"entities\": []}, {\"sentence\": \"Spain's Maria Perez secured the silver medal in 1:26.19 and Australia's Jemima Montag won bronze in 1:26.25.\", \"from\": 789, \"to\": 897, \"entities\": [{\"begin\": 789, \"end\": 794, \"title\": \"http://dbpedia.org/resource/Spain_national_football_team\", \"score\": 0.8354356924606374, \"rank\": 0.19694663638714338, \"text\": \"Spain\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Spain_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Spain_national_football_team\"}, {\"begin\": 797, \"end\": 802, \"title\": \"http://dbpedia.org/resource/Hurricane_Maria\", \"score\": 0.9897870500483643, \"rank\": 0.009393877723970247, \"text\": \"Maria\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Hurricane_Maria\", \"dbpedia\": \"http://dbpedia.org/resource/Hurricane_Maria\"}, {\"begin\": 803, \"end\": 808, \"title\": \"http://dbpedia.org/resource/CJ_Perez\", \"score\": 0.9981491959801175, \"rank\": 0.0015103851767395587, \"text\": \"Perez\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/CJ_Perez\", \"dbpedia\": \"http://dbpedia.org/resource/CJ_Perez\"}, {\"begin\": 849, \"end\": 858, \"title\": \"http://dbpedia.org/resource/Australia_national_cricket_team\", \"score\": 0.9841734542648276, \"rank\": 0.00997840500404107, \"text\": \"Australia\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/Australia_national_cricket_team\", \"dbpedia\": \"http://dbpedia.org/resource/Australia_national_cricket_team\"}, {\"begin\": 861, \"end\": 874, \"title\": \"http://dbpedia.org/resource/Jemima_Montag\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Jemima Montag\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jemima_Montag\", \"dbpedia\": \"http://dbpedia.org/resource/Jemima_Montag\"}]}, {\"sentence\": \"\\\"I never mentioned this before, but I promised him [my father] I would win gold,\\\" Yang said.\", \"from\": 899, \"to\": 991, \"entities\": []}, {\"sentence\": \"\\\"Now I have finally done it.\", \"from\": 992, \"to\": 1020, \"entities\": []}, {\"sentence\": \"I am very proud of myself.\\\"\", \"from\": 1021, \"to\": 1048, \"entities\": []}, {\"sentence\": \"Yang is the fourth Chinese woman to win the event in the seven times it has been contested at the Olympics.\", \"from\": 1050, \"to\": 1157, \"entities\": [{\"begin\": 1069, \"end\": 1076, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.4725727819291306, \"rank\": 0.7600306938606662, \"text\": \"Chinese\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}]}, {\"sentence\": \"With her victory, Yang added Olympic champion to a sparkling resume that already included world record holder and 2017 world champion.\", \"from\": 1159, \"to\": 1293, \"entities\": []}, {\"sentence\": \"The 28-year-old's bold race tactics to surge into an early lead paid off in emphatic fashion as she already had half a minute on the field by the halfway mark.\", \"from\": 1295, \"to\": 1454, \"entities\": []}, {\"sentence\": \"Perez, the 2023 world champion who finished fourth at the 2020 Tokyo Olympics, threatened to chip away at the difference around the 18km mark, but Yang responded in spectacular fashion and was unchallenged the rest of the way.\", \"from\": 1456, \"to\": 1682, \"entities\": [{\"begin\": 1456, \"end\": 1461, \"title\": \"http://dbpedia.org/resource/CJ_Perez\", \"score\": 0.9981491959801175, \"rank\": 0.0015103851767395587, \"text\": \"Perez\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/CJ_Perez\", \"dbpedia\": \"http://dbpedia.org/resource/CJ_Perez\"}]}, {\"sentence\": \"Yang's father died while she was competing at the 2015 World University Games, and when she won the 2017 worlds in London, she dedicated the victory to her dad, saying: \\\"I wanted to make my father in heaven proud of me.\\\"\", \"from\": 1684, \"to\": 1904, \"entities\": [{\"begin\": 1799, \"end\": 1805, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9997136064560226, \"rank\": 0.0002864428693352564, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}]}, {\"sentence\": \"Earlier, Pintado won the first medal of the day and Ecuador's second Olympic title in the event after Jefferson Perez took gold in 1996.\", \"from\": 1906, \"to\": 2042, \"entities\": [{\"begin\": 1958, \"end\": 1965, \"title\": \"http://dbpedia.org/resource/Ecuador\", \"score\": 0.9873882514509917, \"rank\": 0.006839814493797099, \"text\": \"Ecuador\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ecuador\", \"dbpedia\": \"http://dbpedia.org/resource/Ecuador\"}, {\"begin\": 2008, \"end\": 2023, \"title\": \"http://dbpedia.org/resource/Jefferson_P\\u00e9rez\", \"score\": 0.9999992475575812, \"rank\": 0.0, \"text\": \"Jefferson Perez\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jefferson_P\\u00e9rez\", \"dbpedia\": \"http://dbpedia.org/resource/Jefferson_P\\u00e9rez\"}]}, {\"sentence\": \"As he crossed the finish line, Pintado was clutching a family photograph and was immediately linked via a TV feed with them.\", \"from\": 2044, \"to\": 2168, \"entities\": []}, {\"sentence\": \"The race was delayed half an hour due to a thunderstorm, but once the athletes started at the Trocadero, Bonfim took off as if he wanted to make up for the lost time.\", \"from\": 2170, \"to\": 2336, \"entities\": [{\"begin\": 2275, \"end\": 2281, \"title\": \"http://dbpedia.org/resource/Senhor_do_Bonfim\", \"score\": 0.9971367703631377, \"rank\": 0.002871451249702856, \"text\": \"Bonfim\", \"types\": [\"Q486972\", \"Q3957\"], \"wikid\": \"http://dbpedia.org/resource/Senhor_do_Bonfim\", \"dbpedia\": \"http://dbpedia.org/resource/Senhor_do_Bonfim\"}]}, {\"sentence\": \"He was gradually reeled in but stayed among the leaders and was ahead at the halfway mark.\", \"from\": 2338, \"to\": 2428, \"entities\": []}, {\"sentence\": \"He held only a slight advantage, and the lead began to change on a regular basis with China's Zhang Jun, Spaniard Paul McGrath, defending champion Massimo Stano from Italy and Martin all heading the pack at times.\", \"from\": 2430, \"to\": 2643, \"entities\": [{\"begin\": 2516, \"end\": 2521, \"title\": \"http://dbpedia.org/resource/China_national_football_team\", \"score\": 0.9446718489097421, \"rank\": 0.05839486531279115, \"text\": \"China\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/China_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/China_national_football_team\"}, {\"begin\": 2535, \"end\": 2543, \"title\": \"http://dbpedia.org/resource/Spain\", \"score\": 0.9991053800979758, \"rank\": 0.0005006731385373417, \"text\": \"Spaniard\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Spain\", \"dbpedia\": \"http://dbpedia.org/resource/Spain\"}, {\"begin\": 2544, \"end\": 2556, \"title\": \"http://dbpedia.org/resource/Paul_McGrath_(footballer)\", \"score\": 0.9171162073751313, \"rank\": 0.083333333333319, \"text\": \"Paul McGrath\", \"types\": [\"Q937857\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Paul_McGrath_(footballer)\", \"dbpedia\": \"http://dbpedia.org/resource/Paul_McGrath_(footballer)\"}, {\"begin\": 2577, \"end\": 2590, \"title\": \"http://dbpedia.org/resource/Massimo_Stano\", \"score\": 0.9999995819199249, \"rank\": 0.0, \"text\": \"Massimo Stano\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Massimo_Stano\", \"dbpedia\": \"http://dbpedia.org/resource/Massimo_Stano\"}, {\"begin\": 2596, \"end\": 2601, \"title\": \"http://dbpedia.org/resource/Italy_national_football_team\", \"score\": 0.9999947684869277, \"rank\": 5.006419150771092e-06, \"text\": \"Italy\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Italy_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Italy_national_football_team\"}, {\"begin\": 2606, \"end\": 2612, \"title\": \"http://dbpedia.org/resource/Glenn_L._Martin_Company\", \"score\": 0.9708343584022106, \"rank\": 0.030041772195209236, \"text\": \"Martin\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Glenn_L._Martin_Company\", \"dbpedia\": \"http://dbpedia.org/resource/Glenn_L._Martin_Company\"}]}, {\"sentence\": \"The field got strung out with many of the walkers getting on the wrong side of race judges and being put into the penalty zone.\", \"from\": 2645, \"to\": 2772, \"entities\": []}, {\"sentence\": \"The spectators who had turned out at an early hour to watch the event were a colourful bunch, including a vociferous group of sombrero-wearing Mexican supporters.\", \"from\": 2774, \"to\": 2936, \"entities\": [{\"begin\": 2917, \"end\": 2924, \"title\": \"http://dbpedia.org/resource/Mexico\", \"score\": 0.9999917695220039, \"rank\": 8.154425650174783e-06, \"text\": \"Mexican\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Mexico\", \"dbpedia\": \"http://dbpedia.org/resource/Mexico\"}]}, {\"sentence\": \"With under 6km to go, a group of 10 broke from the pack and spreadeagled the field.\", \"from\": 2938, \"to\": 3021, \"entities\": []}, {\"sentence\": \"Stano led at the 16km mark, but he too incurred the wrath of the judges and received a warning.\", \"from\": 3023, \"to\": 3118, \"entities\": []}, {\"sentence\": \"The irrepressible Bonfim, however, then injected some pace and split the leading pack.\", \"from\": 3120, \"to\": 3206, \"entities\": [{\"begin\": 3138, \"end\": 3144, \"title\": \"http://dbpedia.org/resource/Senhor_do_Bonfim\", \"score\": 0.9971367703631377, \"rank\": 0.002871451249702856, \"text\": \"Bonfim\", \"types\": [\"Q486972\", \"Q3957\"], \"wikid\": \"http://dbpedia.org/resource/Senhor_do_Bonfim\", \"dbpedia\": \"http://dbpedia.org/resource/Senhor_do_Bonfim\"}]}, {\"sentence\": \"Just three were able to go with him: Stano, Martin and Pintado.\", \"from\": 3208, \"to\": 3271, \"entities\": [{\"begin\": 3252, \"end\": 3258, \"title\": \"http://dbpedia.org/resource/Glenn_L._Martin_Company\", \"score\": 0.9708343584022106, \"rank\": 0.030041772195209236, \"text\": \"Martin\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Glenn_L._Martin_Company\", \"dbpedia\": \"http://dbpedia.org/resource/Glenn_L._Martin_Company\"}]}, {\"sentence\": \"On the penultimate lap, Stano's dreams of making history in becoming the first Olympic champion to successfully defend his title evaporated as Pintado moved up a gear.\", \"from\": 3273, \"to\": 3440, \"entities\": [{\"begin\": 3297, \"end\": 3302, \"title\": \"http://dbpedia.org/resource/Stano_(singer)\", \"score\": 0.7510311389500196, \"rank\": 0.18750000000000883, \"text\": \"Stano\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Stano_(singer)\", \"dbpedia\": \"http://dbpedia.org/resource/Stano_(singer)\"}]}, {\"sentence\": \"From then on, he ruthlessly dispensed with Bonfim and Martin, who had nothing left in the tank.\", \"from\": 3442, \"to\": 3537, \"entities\": [{\"begin\": 3485, \"end\": 3491, \"title\": \"http://dbpedia.org/resource/Senhor_do_Bonfim\", \"score\": 0.9971367703631377, \"rank\": 0.002871451249702856, \"text\": \"Bonfim\", \"types\": [\"Q486972\", \"Q3957\"], \"wikid\": \"http://dbpedia.org/resource/Senhor_do_Bonfim\", \"dbpedia\": \"http://dbpedia.org/resource/Senhor_do_Bonfim\"}, {\"begin\": 3496, \"end\": 3502, \"title\": \"http://dbpedia.org/resource/Glenn_L._Martin_Company\", \"score\": 0.9708343584022106, \"rank\": 0.030041772195209236, \"text\": \"Martin\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Glenn_L._Martin_Company\", \"dbpedia\": \"http://dbpedia.org/resource/Glenn_L._Martin_Company\"}]}, {\"sentence\": \"The athletics competition now shifts to Stade de France beginning on Friday.\", \"from\": 3539, \"to\": 3615, \"entities\": [{\"begin\": 3579, \"end\": 3594, \"title\": \"http://dbpedia.org/resource/Stade_de_France\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Stade de France\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Stade_de_France\", \"dbpedia\": \"http://dbpedia.org/resource/Stade_de_France\"}]}, {\"sentence\": \"Follow Al Jazeera English:\", \"from\": 3637, \"to\": 3663, \"entities\": []}]}"