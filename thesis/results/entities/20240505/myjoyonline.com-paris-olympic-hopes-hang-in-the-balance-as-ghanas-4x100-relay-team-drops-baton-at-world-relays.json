to\": 492, \"entities\": [{\"begin\": 443, \"end\": 448, \"title\": \"http://dbpedia.org/resource/Italy_national_football_team\", \"score\": 0.9994777700909409, \"rank\": 0.0004447698687993218, \"text\": \"Italy\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Italy_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Italy_national_football_team\"}]}, {\"sentence\": \"Ghana however finished the race in eighth place with a time of 42.70 seconds.\", \"from\": 494, \"to\": 571, \"entities\": [{\"begin\": 494, \"end\": 499, \"title\": \"http://dbpedia.org/resource/Ghana\", \"score\": 1.0, \"rank\": 7.119558853235318e-15, \"text\": \"Ghana\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ghana\", \"dbpedia\": \"http://dbpedia.org/resource/Ghana\"}]}, {\"sentence\": \"At the end of Day 1, no African Country qualified for the Olympic Games in the 4x100m relays, both men and women.\", \"from\": 573, \"to\": 686, \"entities\": []}, {\"sentence\": \"Team Ghana will have another opportunity to book a place at the Olympics on Day 2 of the World Relays.\", \"from\": 688, \"to\": 790, \"entities\": [{\"begin\": 688, \"end\": 698, \"title\": \"http://dbpedia.org/resource/Ghana_national_baseball_team\", \"score\": 0.9999999999968168, \"rank\": 0.0, \"text\": \"Team Ghana\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ghana_national_baseball_team\", \"dbpedia\": \"http://dbpedia.org/resource/Ghana_national_baseball_team\"}]}, {\"sentence\": \"The Multimedia Group  Advertise With Us  Contact Us  Terms of Use  Privacy Policy  Joy 99.7 FM  Adom 106.3 FM  Hitz 103.9 FM  Asempa 94.7 FM  Luv 99.5 FM  Nhyira 104.5 FM  Joy News  Adom TV  Joy Prime  MultiTVWorld.com  Adom TV (Audio)  Joy News (Audio)  YouTube  Facebook  Twitter  Instagram  LinkedIn  Infographics  Games  Habitat Fair  Impact Makers  Galamsey  Archives  Elections\", \"from\": 792, \"to\": 1175, \"entities\": [{\"begin\": 1017, \"end