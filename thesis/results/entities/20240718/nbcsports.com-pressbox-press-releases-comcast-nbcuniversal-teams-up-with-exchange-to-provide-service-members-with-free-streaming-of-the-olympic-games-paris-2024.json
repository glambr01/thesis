"{\"uid\": \"nbcsports.com-pressbox-press-releases-comcast-nbcuniversal-teams-up-with-exchange-to-provide-service-members-with-free-streaming-of-the-olympic-games-paris-2024\", \"entities\": [{\"sentence\": \"DALLAS - July 18, 2024- Once again, service members and honorably discharged Veterans worldwide will enjoy free access to NBCUniversal's full coverage of the 2024 Paris Olympic Games, courtesy of the Army & Air Force Exchange Service and Comcast NBCUniversal.\", \"from\": 0, \"to\": 259, \"entities\": [{\"begin\": 122, \"end\": 134, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 0.9999999621231843, \"rank\": 3.787698443300843e-08, \"text\": \"NBCUniversal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}, {\"begin\": 200, \"end\": 233, \"title\": \"http://dbpedia.org/resource/Army_&_Air_Force_Exchange_Service\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Army & Air Force Exchange Service\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Army_&_Air_Force_Exchange_Service\", \"dbpedia\": \"http://dbpedia.org/resource/Army_&_Air_Force_Exchange_Service\"}, {\"begin\": 246, \"end\": 258, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 0.9999999621231843, \"rank\": 3.787698443300843e-08, \"text\": \"NBCUniversal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}]}, {\"sentence\": \"Military members will be able to stream all the action from Paris using their personal devices and computers through ShopMyExchange.com.\", \"from\": 260, \"to\": 396, \"entities\": [{\"begin\": 320, \"end\": 325, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999999996610768, \"rank\": 3.389264274401518e-09, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"The Paris Olympics take place July 26 to Aug. 11.\", \"from\": 397, \"to\": 446, \"entities\": []}, {\"sentence\": \"More than 5,000 hours of the Paris Olympics will be available to U.S. service members and honorably discharged Veterans.\", \"from\": 448, \"to\": 568, \"entities\": []}, {\"sentence\": \"Throughout the Games, the comprehensive offering features live competition across all 39 sports and all 329 medal events, top stories and moments, as well as live streams of select practice and warm-up sessions and extensive video content including event recaps, highlights, viral moments, interviews and more.\", \"from\": 569, \"to\": 879, \"entities\": []}, {\"sentence\": \"\\\"We value our relationship with Comcast NBCUniversal and are thrilled to once again be able to team with them to bring the Olympic Games to service members and their families, wherever they are called to serve,\\\" said Air Force Chief Master Sgt.\", \"from\": 881, \"to\": 1125, \"entities\": [{\"begin\": 921, \"end\": 933, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 0.9999999621231843, \"rank\": 3.787698443300843e-08, \"text\": \"NBCUniversal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}]}, {\"sentence\": \"Rich Martinez, the Exchange's senior enlisted advisor.\", \"from\": 1126, \"to\": 1180, \"entities\": [{\"begin\": 1126, \"end\": 1130, \"title\": \"http://dbpedia.org/resource/Rich_Robinson\", \"score\": 0.834133500403629, \"rank\": 0.19852288178982933, \"text\": \"Rich\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Rich_Robinson\", \"dbpedia\": \"http://dbpedia.org/resource/Rich_Robinson\"}, {\"begin\": 1131, \"end\": 1139, \"title\": \"http://dbpedia.org/resource/Tippy_Martinez\", \"score\": 0.861549428701211, \"rank\": 0.1606985943836107, \"text\": \"Martinez\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Tippy_Martinez\", \"dbpedia\": \"http://dbpedia.org/resource/Tippy_Martinez\"}]}, {\"sentence\": \"\\\"The Olympics are one of the biggest events in the world, and we are excited to play a role in helping our military community cheer on Team USA.\\\"\", \"from\": 1181, \"to\": 1326, \"entities\": [{\"begin\": 1316, \"end\": 1324, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999999999972715, \"rank\": 2.0633542928277214e-12, \"text\": \"Team USA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}]}, {\"sentence\": \"\\\"We are thrilled to once again partner with The Exchange for the Olympic and Paralympic Games in Paris.\", \"from\": 1328, \"to\": 1431, \"entities\": [{\"begin\": 1372, \"end\": 1384, \"title\": \"http://dbpedia.org/resource/Newlyn_Art_Gallery\", \"score\": 0.999999152348114, \"rank\": 5.269245502773638e-07, \"text\": \"The Exchange\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Newlyn_Art_Gallery\", \"dbpedia\": \"http://dbpedia.org/resource/Newlyn_Art_Gallery\"}, {\"begin\": 1425, \"end\": 1430, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999999996610768, \"rank\": 3.389264274401518e-09, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"It's our privilege to provide unprecedented access to this historic event to U.S. military service members and veterans, where the world's greatest athletes will compete against the backdrop of one of the most beautiful cities in the world.\\\"\", \"from\": 1432, \"to\": 1673, \"entities\": [{\"begin\": 1509, \"end\": 1522, \"title\": \"http://dbpedia.org/resource/United_States_Armed_Forces\", \"score\": 0.9999972444735925, \"rank\": 2.7555339551300015e-06, \"text\": \"U.S. military\", \"types\": [\"Q43229\", \"Q24229398\", \"Q176799\"], \"wikid\": \"http://dbpedia.org/resource/United_States_Armed_Forces\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_Armed_Forces\"}]}, {\"sentence\": \"- Mona Dexter, VP of Military & Veteran Affairs at Comcast NBCUniversal.\", \"from\": 1674, \"to\": 1746, \"entities\": [{\"begin\": 1676, \"end\": 1680, \"title\": \"http://dbpedia.org/resource/Mona_Vanderwaal\", \"score\": 0.9999038442709447, \"rank\": 9.616367213861376e-05, \"text\": \"Mona\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Mona_Vanderwaal\", \"dbpedia\": \"http://dbpedia.org/resource/Mona_Vanderwaal\"}, {\"begin\": 1681, \"end\": 1687, \"title\": \"http://dbpedia.org/resource/Dexter_Morgan\", \"score\": 0.9999999992587618, \"rank\": 7.40730403483859e-10, \"text\": \"Dexter\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Dexter_Morgan\", \"dbpedia\": \"http://dbpedia.org/resource/Dexter_Morgan\"}, {\"begin\": 1733, \"end\": 1745, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 0.9999999621231843, \"rank\": 3.787698443300843e-08, \"text\": \"NBCUniversal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}]}, {\"sentence\": \"Service members can access NBCUniversal's coverage from their computers or personal devices by visiting NBCOlympics.com (desktop) and the NBC Sports App (U.S. only) and choosing the Exchange as their service provider.\", \"from\": 1748, \"to\": 1965, \"entities\": [{\"begin\": 1775, \"end\": 1787, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 0.9999999621231843, \"rank\": 3.787698443300843e-08, \"text\": \"NBCUniversal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}, {\"begin\": 1886, \"end\": 1896, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.9999999828419278, \"rank\": 1.5508179579972938e-08, \"text\": \"NBC Sports\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}]}, {\"sentence\": \"Because of content rights restrictions, an active ShopMyExchange.com account is required.\", \"from\": 1967, \"to\": 2056, \"entities\": []}, {\"sentence\": \"OCONUS viewers must also be physically located on-installation at a military location with internet service through an authorized internet service provider to gain access.\", \"from\": 2057, \"to\": 2228, \"entities\": []}, {\"sentence\": \"Authorized providers have partnered with the Exchange on technical solutions to allow streaming on U.S. military installations in OCONUS.\", \"from\": 2229, \"to\": 2366, \"entities\": [{\"begin\": 2328, \"end\": 2341, \"title\": \"http://dbpedia.org/resource/United_States_Armed_Forces\", \"score\": 0.9999972444735925, \"rank\": 2.7555339551300015e-06, \"text\": \"U.S. military\", \"types\": [\"Q43229\", \"Q24229398\", \"Q176799\"], \"wikid\": \"http://dbpedia.org/resource/United_States_Armed_Forces\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_Armed_Forces\"}, {\"begin\": 2359, \"end\": 2365, \"title\": \"http://dbpedia.org/resource/Contiguous_United_States\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"OCONUS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Contiguous_United_States\", \"dbpedia\": \"http://dbpedia.org/resource/Contiguous_United_States\"}]}, {\"sentence\": \"They include: 101 GLOBAL, Allied Telesis, Americable, Babtel, Basefix, Boingo, DHI/TravelWiFi, DSN, LG Uplus, Mediatti Broadband, Solutions by STC, Telecom Italia, TKS and US Wicom.\", \"from\": 2367, \"to\": 2548, \"entities\": [{\"begin\": 2462, \"end\": 2465, \"title\": \"http://dbpedia.org/resource/NASA_Deep_Space_Network\", \"score\": 0.9999999019783038, \"rank\": 9.206488611491954e-08, \"text\": \"DSN\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NASA_Deep_Space_Network\", \"dbpedia\": \"http://dbpedia.org/resource/NASA_Deep_Space_Network\"}, {\"begin\": 2467, \"end\": 2475, \"title\": \"http://dbpedia.org/resource/LG_Uplus\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"LG Uplus\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/LG_Uplus\", \"dbpedia\": \"http://dbpedia.org/resource/LG_Uplus\"}, {\"begin\": 2510, \"end\": 2513, \"title\": \"http://dbpedia.org/resource/Saudi_Telecom_Company\", \"score\": 0.9999478965173821, \"rank\": 5.210619512991375e-05, \"text\": \"STC\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Saudi_Telecom_Company\", \"dbpedia\": \"http://dbpedia.org/resource/Saudi_Telecom_Company\"}, {\"begin\": 2515, \"end\": 2529, \"title\": \"http://dbpedia.org/resource/Gruppo_TIM\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Telecom Italia\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Gruppo_TIM\", \"dbpedia\": \"http://dbpedia.org/resource/Gruppo_TIM\"}, {\"begin\": 2531, \"end\": 2534, \"title\": \"http://dbpedia.org/resource/TKS\", \"score\": 1.0, \"rank\": 2.5416638992173153e-20, \"text\": \"TKS\", \"types\": [\"Q728\"], \"wikid\": \"http://dbpedia.org/resource/TKS\", \"dbpedia\": \"http://dbpedia.org/resource/TKS\"}, {\"begin\": 2539, \"end\": 2541, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.8780336109309664, \"rank\": 0.13878568528237265, \"text\": \"US\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}]}, {\"sentence\": \"Additional information is available on the Exchange's online community Hub atShopMyExchange.com/community.\", \"from\": 2552, \"to\": 2658, \"entities\": []}, {\"sentence\": \"For more information on how to watch NBCUniversal's coverage of the 2024 Paris Olympics, clickhere.\", \"from\": 2662, \"to\": 2761, \"entities\": [{\"begin\": 2699, \"end\": 2711, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 0.9999999621231843, \"rank\": 3.787698443300843e-08, \"text\": \"NBCUniversal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}]}, {\"sentence\": \"--    Since 1895, the Army & Air Force Exchange Service (Exchange) has gone where Soldiers, Airmen, Guardians and their families go to improve the quality of their lives by providing valued goods and services at exclusive military pricing.\", \"from\": 2765, \"to\": 3004, \"entities\": []}, {\"sentence\": \"The Exchange is the 54th-largest retailer in the United States.\", \"from\": 3005, \"to\": 3068, \"entities\": [{\"begin\": 3005, \"end\": 3017, \"title\": \"http://dbpedia.org/resource/Newlyn_Art_Gallery\", \"score\": 0.999999152348114, \"rank\": 5.269245502773638e-07, \"text\": \"The Exchange\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Newlyn_Art_Gallery\", \"dbpedia\": \"http://dbpedia.org/resource/Newlyn_Art_Gallery\"}, {\"begin\": 3054, \"end\": 3067, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999972567080816, \"rank\": 2.7432993140178397e-06, \"text\": \"United States\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}]}, {\"sentence\": \"100% of Exchange earnings support military communities.\", \"from\": 3069, \"to\": 3124, \"entities\": []}, {\"sentence\": \"In the last 10 years, your Exchange benefit has provided $3.7 billion in earnings that support the military community, including through contributions to critical military Quality-of-Life programs.The Exchange is a non-appropriated fund entity of the Department of Defense and is directed by a Board of Directors.\", \"from\": 3125, \"to\": 3438, \"entities\": []}, {\"sentence\": \"The Exchange is a 50th Anniversary Vietnam War Commemorative Partner, planning and conducting events and activities that recognize the service, valor and sacrifice of Vietnam Veterans and their families in conjunction with the United States of America Vietnam War Commemoration.\", \"from\": 3439, \"to\": 3717, \"entities\": [{\"begin\": 3439, \"end\": 3451, \"title\": \"http://dbpedia.org/resource/Newlyn_Art_Gallery\", \"score\": 0.999999152348114, \"rank\": 5.269245502773638e-07, \"text\": \"The Exchange\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Newlyn_Art_Gallery\", \"dbpedia\": \"http://dbpedia.org/resource/Newlyn_Art_Gallery\"}, {\"begin\": 3606, \"end\": 3613, \"title\": \"http://dbpedia.org/resource/Vietnam_War\", \"score\": 0.9999998916659992, \"rank\": 1.0827810004959107e-07, \"text\": \"Vietnam\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/Vietnam_War\", \"dbpedia\": \"http://dbpedia.org/resource/Vietnam_War\"}]}, {\"sentence\": \"To find out more about the Exchange history and mission or to view recent press releases please visit our website athttp://www.shopmyexchange.comor follow us on X athttps://x.com/ExchangePAO.\", \"from\": 3718, \"to\": 3909, \"entities\": []}, {\"sentence\": \"ABOUT NBCUNIVERSAL  NBCUniversal is one of the world's leading media and entertainment companies.\", \"from\": 3913, \"to\": 4010, \"entities\": [{\"begin\": 3919, \"end\": 3931, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 0.9999999621231843, \"rank\": 3.787698443300843e-08, \"text\": \"NBCUNIVERSAL\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}, {\"begin\": 3933, \"end\": 3945, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 0.9999999621231843, \"rank\": 3.787698443300843e-08, \"text\": \"NBCUniversal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}]}, {\"sentence\": \"We create world-class content, which we distribute across our portfolio of film, television, and streaming, and bring to life through our theme parks and consumer experiences.\", \"from\": 4011, \"to\": 4186, \"entities\": []}, {\"sentence\": \"We own and operate leading entertainment and news brands, including NBC, NBC News, MSNBC, CNBC, NBC Sports, Telemundo, NBC Local Stations, Bravo, USA Network, and Peacock, our premium ad-supported streaming service.\", \"from\": 4187, \"to\": 4402, \"entities\": [{\"begin\": 4255, \"end\": 4258, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.9992670941462575, \"rank\": 0.0007334360317737728, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}]}, {\"sentence\": \"We produce and distribute premier filmed entertainment and programming through Universal Filmed Entertainment Group and Universal Studio Group, and have world-renowned theme parks and attractions through Universal Destinations & Experiences.\", \"from\": 4403, \"to\": 4644, \"entities\": [{\"begin\": 4482, \"end\": 4518, \"title\": \"http://dbpedia.org/resource/Universal_Pictures\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Universal Filmed Entertainment Group\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Universal_Pictures\", \"dbpedia\": \"http://dbpedia.org/resource/Universal_Pictures\"}, {\"begin\": 4523, \"end\": 4545, \"title\": \"http://dbpedia.org/resource/NBCUniversal_Television_and_Streaming\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Universal Studio Group\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal_Television_and_Streaming\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal_Television_and_Streaming\"}]}, {\"sentence\": \"NBCUniversal is a subsidiary of Comcast Corporation.\", \"from\": 4645, \"to\": 4697, \"entities\": [{\"begin\": 4645, \"end\": 4657, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 0.9999999621231843, \"rank\": 3.787698443300843e-08, \"text\": \"NBCUniversal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}, {\"begin\": 4677, \"end\": 4696, \"title\": \"http://dbpedia.org/resource/Comcast\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Comcast Corporation\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Comcast\", \"dbpedia\": \"http://dbpedia.org/resource/Comcast\"}]}, {\"sentence\": \"A Division ofNBCUniversal.\", \"from\": 4699, \"to\": 4725, \"entities\": [{\"begin\": 4699, \"end\": 4709, \"title\": \"http://dbpedia.org/resource/Scottish_Football_League\", \"score\": 0.9999999978322194, \"rank\": 2.1679568044241236e-09, \"text\": \"A Division\", \"types\": [\"Q623109\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Scottish_Football_League\", \"dbpedia\": \"http://dbpedia.org/resource/Scottish_Football_League\"}]}, {\"sentence\": \"DISCLAIMER: This site and the products offered are for entertainment purposes only, and there is no gambling offered on this site.\", \"from\": 4727, \"to\": 4857, \"entities\": []}, {\"sentence\": \"This service is intended for adult audiences.\", \"from\": 4858, \"to\": 4903, \"entities\": []}, {\"sentence\": \"No guarantees are made for any specific outcome.\", \"from\": 4904, \"to\": 4952, \"entities\": []}, {\"sentence\": \"If you or someone you know has a gambling problem, please call 1-800-GAMBLER.\", \"from\": 4953, \"to\": 5030, \"entities\": []}, {\"sentence\": \"\\u24b8 2024 NBC Universal\", \"from\": 5032, \"to\": 5052, \"entities\": []}]}"