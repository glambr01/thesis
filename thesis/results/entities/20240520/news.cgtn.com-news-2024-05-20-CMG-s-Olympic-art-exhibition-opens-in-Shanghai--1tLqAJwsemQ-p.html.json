om\": 1706, \"to\": 1820, \"entities\": [{\"begin\": 1811, \"end\": 1819, \"title\": \"http://dbpedia.org/resource/Shanghai\", \"score\": 0.9999991720645783, \"rank\": 8.278583429427485e-07, \"text\": \"Shanghai\", \"types\": [\"Q486972\", \"Q3957\"], \"wikid\": \"http://dbpedia.org/resource/Shanghai\", \"dbpedia\": \"http://dbpedia.org/resource/Shanghai\"}]}, {\"sentence\": \"Shanghai proposed to bid for the Olympics 79 years ago.\", \"from\": 1821, \"to\": 1876, \"entities\": [{\"begin\": 1821, \"end\": 1829, \"title\": \"http://dbpedia.org/resource/Shanghai\", \"score\": 0.9999991720645783, \"rank\": 8.278583429427485e-07, \"text\": \"Shanghai\", \"types\": [\"Q486972\", \"Q3957\"], \"wikid\": \"http://dbpedia.org/resource/Shanghai\", \"dbpedia\": \"http://dbpedia.org/resource/Shanghai\"}]}, {\"sentence\": \"Nowadays, Shanghai hosts the world's elite sporting events.\", \"from\": 1877, \"to\": 1936, \"entities\": [{\"begin\": 1887, \"end\": 1895, \"title\": \"http://dbpedia.org/resource/Shanghai\", \"score\": 0.9999991720645783, \"rank\": 8.278583429427485e-07, \"text\": \"Shanghai\", \"types\": [\"Q486972\", \"Q3957\"], \"wikid\": \"http://dbpedia.org/resource/Shanghai\", \"dbpedia\": \"http://dbpedia.org/resource/Shanghai\"}]}, {\"sentence\": \"The \\\"Walking with the Art\\\" section fully continues the exhibition style of the previous Paris-based exhibition.\", \"from\": 1938, \"to\": 2049, \"entities\": []}, {\"sentence\": \"The artworks encompass various art forms such as Chinese painting, calligraphy, and oil painting, demonstrating the commonality of sports and art as important components of human culture.\", \"from\": 2050, \"to\": 2237, \"entities\": [{\"begin\": 2099, \"end\": 2115, \"title\": \"http://dbpedia.org/resource/Chinese_painting\", \"score\": 0.9999803989482822, \"rank\": 1.9601436061680648e-05, \"text\": \"Chinese painting\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Chinese_painting\", \"dbpedia\": \"http://dbpedia.org/resour