 \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tunisian_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/Tunisian_Olympic_Committee\"}, {\"begin\": 529, \"end\": 535, \"title\": \"http://dbpedia.org/resource/Confederation_of_African_Football\", \"score\": 0.9999979697722811, \"rank\": 2.030224341934514e-06, \"text\": \"Africa\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Confederation_of_African_Football\", \"dbpedia\": \"http://dbpedia.org/resource/Confederation_of_African_Football\"}]}, {\"sentence\": \"However, the swimmer has refused to rule himself out completely.\", \"from\": 547, \"to\": 611, \"entities\": []}, {\"sentence\": \"\\\"I am currently suffering from an injury, and I do not know whether or not I will participate in the Olympics,\\\" the 21-year-old Tunisian swimmer told AFP news agency on Wednesday.\", \"from\": 613, \"to\": 792, \"entities\": [{\"begin\": 741, \"end\": 749, \"title\": \"http://dbpedia.org/resource/Tunisia\", \"score\": 0.7385187716446693, \"rank\": 0.32853713556996167, \"text\": \"Tunisian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Tunisia\", \"dbpedia\": \"http://dbpedia.org/resource/Tunisia\"}, {\"begin\": 763, \"end\": 778, \"title\": \"http://dbpedia.org/resource/Agence_France-Presse\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"AFP news agency\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Agence_France-Presse\", \"dbpedia\": \"http://dbpedia.org/resource/Agence_France-Presse\"}]}, {\"sentence\": \"He did not give details of the injury.\", \"from\": 794, \"to\": 832, \"entities\": []}, {\"sentence\": \"Boussayene said \\\"nothing is confirmed\\\", adding the swimmer had a \\\"developing injury\\\" in his comments to AFP.\", \"from\": 834, \"to\": 942, \"entities\": [{\"begin\": 938, \"end\": 941, \"title\": \"http://dbpedia.org/resource/Agence_France-Presse\", \"score\": 0.9999999558024238