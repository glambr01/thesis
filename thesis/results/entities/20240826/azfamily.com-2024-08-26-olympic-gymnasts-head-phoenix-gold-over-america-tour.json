"{\"uid\": \"azfamily.com-2024-08-26-olympic-gymnasts-head-phoenix-gold-over-america-tour\", \"entities\": [{\"sentence\": \"PHOENIX (AZFamily)- Highly decorated gymnasts are about to hit the road for theGold Over America Tour, and we will have a chance to see them right here in Phoenix!\", \"from\": 0, \"to\": 163, \"entities\": [{\"begin\": 155, \"end\": 162, \"title\": \"http://dbpedia.org/resource/Phoenix_Suns\", \"score\": 0.650436646655651, \"rank\": 0.5362394952535583, \"text\": \"Phoenix\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/Phoenix_Suns\", \"dbpedia\": \"http://dbpedia.org/resource/Phoenix_Suns\"}]}, {\"sentence\": \"Simone Biles will lead the Gold Over America Tour and perform alongside otherOlympic gymnastssuch as Jade Carey, Jordan Chiles, Hezly Rivera, Paul Juda, Fred Richard and more.\", \"from\": 165, \"to\": 340, \"entities\": [{\"begin\": 165, \"end\": 177, \"title\": \"http://dbpedia.org/resource/Simone_Biles\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Simone Biles\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Simone_Biles\", \"dbpedia\": \"http://dbpedia.org/resource/Simone_Biles\"}, {\"begin\": 266, \"end\": 276, \"title\": \"http://dbpedia.org/resource/Jade_Carey\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Jade Carey\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jade_Carey\", \"dbpedia\": \"http://dbpedia.org/resource/Jade_Carey\"}, {\"begin\": 278, \"end\": 291, \"title\": \"http://dbpedia.org/resource/Jordan_Chiles\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Jordan Chiles\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jordan_Chiles\", \"dbpedia\": \"http://dbpedia.org/resource/Jordan_Chiles\"}, {\"begin\": 299, \"end\": 305, \"title\": \"http://dbpedia.org/resource/Mariano_Rivera\", \"score\": 0.9999800162418507, \"rank