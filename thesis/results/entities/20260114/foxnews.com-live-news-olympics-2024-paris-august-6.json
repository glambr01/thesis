}]}, {\"sentence\": \"\\\"We need to give the best we possibly can.\", \"from\": 10726, \"to\": 10768, \"entities\": []}, {\"sentence\": \"Tokyo the food was incredible.\", \"from\": 10769, \"to\": 10799, \"entities\": []}, {\"sentence\": \"Rio was incredible.\", \"from\": 10800, \"to\": 10819, \"entities\": []}, {\"sentence\": \"But this time around?\", \"from\": 10820, \"to\": 10841, \"entities\": []}, {\"sentence\": \"There wasn't enough protein options, long queues, waiting 30 minutes for food because there is no queueing system.\\\"\", \"from\": 10842, \"to\": 10957, \"entities\": []}, {\"sentence\": \"Peaty added that the Paris Games' hopes of being as sustainable as possible has affected the food.\", \"from\": 10959, \"to\": 11057, \"entities\": []}, {\"sentence\": \"The Guardian\\u00a0reported that 60% of the meals served are meatless and at least 33% plant-based.\", \"from\": 11058, \"to\": 11151, \"entities\": [{\"begin\": 11058, \"end\": 11070, \"title\": \"http://dbpedia.org/resource/The_Guardian\", \"score\": 0.9999999762630981, \"rank\": 2.3523340583060093e-08, \"text\": \"The Guardian\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Guardian\", \"dbpedia\": \"http://dbpedia.org/resource/The_Guardian\"}]}, {\"sentence\": \"\\\"I like my fish and people are finding worms in the fish.\", \"from\": 11153, \"to\": 11210, \"entities\": []}, {\"sentence\": \"It's just not good enough.\", \"from\": 11211, \"to\": 11237, \"entities\": []}, {\"sentence\": \"The standard, we are looking at the best of the best in the world, and we are not feeding them the best,\\\" he added.\", \"from\": 11238, \"to\": 11353, \"entities\": []}, {\"sentence\": \"This is an excerpt from a report by Ryan Gaydos.\", \"from\": 11355, \"to\": 11403, \"entities\": [{\"begin\": 11391, \"end\": 11395, \"title\": \"http://dbpedia.org/resource/Nolan_Ryan\", \"score\": 0.6963833375081803, \"rank\": 0.43590856703490816, \"text\"