m\": 984, \"to\": 1166, \"entities\": [{\"begin\": 1016, \"end\": 1021, \"title\": \"http://dbpedia.org/resource/Jordan_Lyles\", \"score\": 0.9999999767810552, \"rank\": 2.3215431861099532e-08, \"text\": \"Lyles\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Jordan_Lyles\", \"dbpedia\": \"http://dbpedia.org/resource/Jordan_Lyles\"}, {\"begin\": 1098, \"end\": 1106, \"title\": \"http://dbpedia.org/resource/Klay_Thompson\", \"score\": 0.9993505772205638, \"rank\": 0.0006498448028235754, \"text\": \"Thompson\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Klay_Thompson\", \"dbpedia\": \"http://dbpedia.org/resource/Klay_Thompson\"}]}, {\"sentence\": \"After the race, both men waited anxiously to see the final result, and it was Lyles who was filled with elation as his first-place finish was confirmed.\", \"from\": 1168, \"to\": 1320, \"entities\": [{\"begin\": 1246, \"end\": 1251, \"title\": \"http://dbpedia.org/resource/Jordan_Lyles\", \"score\": 0.9999999767810552, \"rank\": 2.3215431861099532e-08, \"text\": \"Lyles\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Jordan_Lyles\", \"dbpedia\": \"http://dbpedia.org/resource/Jordan_Lyles\"}]}, {\"sentence\": \"Kerley ensured the US copped two medals in the final, as he grabbed third in 9.81.\", \"from\": 1322, \"to\": 1404, \"entities\": [{\"begin\": 1341, \"end\": 1343, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 0.9993256060405474, \"rank\": 0.0006745476807276108, \"text\": \"US\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\"}]}, {\"sentence\": \"South Africa's Akani Simbine ran a national record and placed fourth in 9.82