 \"Images Courtesy of Getty Images.\", \"from\": 2962, \"to\": 2994, \"entities\": [{\"begin\": 2981, \"end\": 2986, \"title\": \"http://dbpedia.org/resource/Getty_Images\", \"score\": 0.8999205341309361, \"rank\": 0.11062124036680175, \"text\": \"Getty\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Getty_Images\", \"dbpedia\": \"http://dbpedia.org/resource/Getty_Images\"}]}]}"