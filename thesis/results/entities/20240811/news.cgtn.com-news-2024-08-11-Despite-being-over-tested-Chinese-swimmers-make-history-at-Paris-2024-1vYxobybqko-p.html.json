"{\"uid\": \"news.cgtn.com-news-2024-08-11-Despite-being-over-tested-Chinese-swimmers-make-history-at-Paris-2024-1vYxobybqko-p.html\", \"entities\": [{\"sentence\": \"Our Privacy Statement & Cookie Policy  By continuing to browse our site you agree to our use of cookies, revised Privacy Policy and Terms of Use.\", \"from\": 0, \"to\": 145, \"entities\": []}, {\"sentence\": \"You can change your cookie settings through your browser.\", \"from\": 146, \"to\": 203, \"entities\": []}, {\"sentence\": \"Sports Scene  Copied  Pan Zhanle of China celebrates after winning the men's 100-meter freestyle gold medal at the 2024 Summer Olympics in Paris, France, July 31, 2024.\", \"from\": 205, \"to\": 373, \"entities\": [{\"begin\": 241, \"end\": 246, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9999884436123653, \"rank\": 1.13949189624034e-05, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}, {\"begin\": 344, \"end\": 349, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999693732211, \"rank\": 3.0626785469815044e-08, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 351, \"end\": 357, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.7065468155616693, \"rank\": 0.4026224602046268, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}]}, {\"sentence\": \"/CFP  Chinese swimmers claimed two gold, three silver, and seven bronze medals at the 2024 Paris Summer Olympics.\", \"from\": 374, \"to\": 487, \"entities\": [{\"begin\": 380, \"end\": 387, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9815822044393162, \"rank\": 0.018548583938161653, \"text\": \"Chinese\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}]}, {\"sentence\": \"The team's total of 12 medals established a new record for China in the sport at the Games.\", \"from\": 488, \"to\": 579, \"entities\": [{\"begin\": 547, \"end\": 552, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9999884436123653, \"rank\": 1.13949189624034e-05, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}]}, {\"sentence\": \"Pan Zhanle won the men's 100-meter freestyle title by setting a new world record of 46.4 seconds.\", \"from\": 581, \"to\": 678, \"entities\": []}, {\"sentence\": \"He also teamed up with Xu Jiayu, Qin Haiyang and Sun Jiajun to dominate the men's 4\\u00c3\\u0097100-meter medley relay final in 3:27.76, adding a second gold for the delegation.\", \"from\": 679, \"to\": 845, \"entities\": [{\"begin\": 702, \"end\": 710, \"title\": \"http://dbpedia.org/resource/Xu_Jiayu\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Xu Jiayu\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Xu_Jiayu\", \"dbpedia\": \"http://dbpedia.org/resource/Xu_Jiayu\"}, {\"begin\": 712, \"end\": 723, \"title\": \"http://dbpedia.org/resource/Qin_Haiyang\", \"score\": 0.9999938624996128, \"rank\": 0.0, \"text\": \"Qin Haiyang\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Qin_Haiyang\", \"dbpedia\": \"http://dbpedia.org/resource/Qin_Haiyang\"}, {\"begin\": 728, \"end\": 731, \"title\": \"http://dbpedia.org/resource/Sun_Microsystems\", \"score\": 0.9747915645911152, \"rank\": 0.025824937988395788, \"text\": \"Sun\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Sun_Microsystems\", \"dbpedia\": \"http://dbpedia.org/resource/Sun_Microsystems\"}, {\"begin\": 732, \"end\": 738, \"title\": \"http://dbpedia.org/resource/Jiajun\", \"score\": 0.8020135056823948, \"rank\": 0.0, \"text\": \"Jiajun\", \"types\": [\"Q486972\", \"Q3957\"], \"wikid\": \"http://dbpedia.org/resource/Jiajun\", \"dbpedia\": \"http://dbpedia.org/resource/Jiajun\"}]}, {\"sentence\": \"Tang Qianting and Xu earned silver medals in the women's 100-meter breaststroke and men's 100-meter backstroke, respectively.\", \"from\": 847, \"to\": 972, \"entities\": [{\"begin\": 847, \"end\": 860, \"title\": \"http://dbpedia.org/resource/Tang_Qianting\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Tang Qianting\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Tang_Qianting\", \"dbpedia\": \"http://dbpedia.org/resource/Tang_Qianting\"}]}, {\"sentence\": \"Xu, Qin, Zhang Yufei and Yang Junxuan also finished the mixed 4\\u00c3\\u0097100-meter medley relay final in 3:37.55, breaking the Asian record and securing silver.\", \"from\": 973, \"to\": 1125, \"entities\": [{\"begin\": 982, \"end\": 993, \"title\": \"http://dbpedia.org/resource/Zhang_Yufei_(swimmer)\", \"score\": 0.9727864122994488, \"rank\": 0.027972027972030022, \"text\": \"Zhang Yufei\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Zhang_Yufei_(swimmer)\", \"dbpedia\": \"http://dbpedia.org/resource/Zhang_Yufei_(swimmer)\"}, {\"begin\": 998, \"end\": 1010, \"title\": \"http://dbpedia.org/resource/Yang_Junxuan\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Yang Junxuan\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Yang_Junxuan\", \"dbpedia\": \"http://dbpedia.org/resource/Yang_Junxuan\"}]}, {\"sentence\": \"Zhang Yufei of China displays her women's 50-meter freestyle bronze medal at the 2024 Summer Olympics in Paris, France, August 4, 2024.\", \"from\": 1127, \"to\": 1262, \"entities\": [{\"begin\": 1127, \"end\": 1138, \"title\": \"http://dbpedia.org/r