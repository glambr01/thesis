"{\"uid\": \"si.com-tennis-carlos-alcaraz-rafael-nadal-to-play-doubles-for-spain-in-paris-olympics\", \"entities\": [{\"sentence\": \"Spain's Olympic men's tennis delegation this summer will feature a collision of the nation's past, present and future.\", \"from\": 0, \"to\": 118, \"entities\": [{\"begin\": 0, \"end\": 5, \"title\": \"http://dbpedia.org/resource/Spain\", \"score\": 0.9992016917956325, \"rank\": 0.0007985710991533902, \"text\": \"Spain\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Spain\", \"dbpedia\": \"http://dbpedia.org/resource/Spain\"}]}, {\"sentence\": \"Carlos Alcaraz and Rafael Nadal will play doubles together at the Paris Olympics in July and August, the Royal Spanish Tennis FederationannouncedWednesday.\", \"from\": 120, \"to\": 275, \"entities\": [{\"begin\": 120, \"end\": 134, \"title\": \"http://dbpedia.org/resource/Carlos_Alcaraz\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Carlos Alcaraz\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Carlos_Alcaraz\", \"dbpedia\": \"http://dbpedia.org/resource/Carlos_Alcaraz\"}, {\"begin\": 139, \"end\": 151, \"title\": \"http://dbpedia.org/resource/Rafael_Nadal\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Rafael Nadal\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Rafael_Nadal\", \"dbpedia\": \"http://dbpedia.org/resource/Rafael_Nadal\"}]}, {\"sentence\": \"The announcement came as Spain unveiled its five-man and two-woman roster for the Games.\", \"from\": 276, \"to\": 364, \"entities\": [{\"begin\": 301, \"end\": 306, \"title\": \"http://dbpedia.org/resource/Spain\", \"score\": 0.9992016917956325, \"rank\": 0.0007985710991533902, \"text\": \"Spain\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Spain\", \"dbpedia\": \"http://dbpedia.org/resource/Spain\"}]}, {\"sentence\": \"Nadal, 38, has won 14 French Open men's singles titles\\u00e2\\u0080\\u0094six more than any other player in history.\", \"from\": 366, \"to\": 465, \"entities\": [{\"begin\": 366, \"end\": 371, \"title\": \"http://dbpedia.org/resource/Rafael_Nadal\", \"score\": 0.999999999996362, \"rank\": 3.5910219827256627e-12, \"text\": \"Nadal\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Rafael_Nadal\", \"dbpedia\": \"http://dbpedia.org/resource/Rafael_Nadal\"}]}, {\"sentence\": \"The Olympic tennis competition will be held at Roland Garros, the home of that tournament.\", \"from\": 466, \"to\": 556, \"entities\": []}, {\"sentence\": \"Alcaraz, 21, won the French Open men's singles title\\u00e2\\u0080\\u0094his third career major championship\\u00e2\\u0080\\u0094on Sunday.\", \"from\": 558, \"to\": 661, \"entities\": [{\"begin\": 558, \"end\": 565, \"title\": \"http://dbpedia.org/resource/Alcaraz\", \"score\": 1.0, \"rank\": 1.2465051428412157e-18, \"text\": \"Alcaraz\", \"types\": [\"Q486972\", \"Q3957\"], \"wikid\": \"http://dbpedia.org/resource/Alcaraz\", \"dbpedia\": \"http://dbpedia.org/resource/Alcaraz\"}]}, {\"sentence\": \"Nadal\\u00e2\\u0080\\u0094who lost in the first round of this year's French Open\\u00e2\\u0080\\u0094previously won gold in men's singles in Beijing in 2008 and gold in men's doubles in Rio de Janeiro in 2016.\", \"from\": 663, \"to\": 836, \"entities\": [{\"begin\": 714, \"end\": 720, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9892592560784972, \"rank\": 0.010187363469370533, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 768, \"end\": 775, \"title\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"score\": 0.9999999365791175, \"rank\": 6.342094839931042e-08, \"text\": \"Beijing\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2008_Summer_O