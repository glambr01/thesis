es/media2/16x9/5784/648/0x598/90/c1682a95-ea33-430c-b643-94f4872677b0-FINALS3.jpg%22%20alt=%22%22%20/%3E%0A%20%20%20%20%20%20%20%20%3Cdiv%20class=%22sda-ImageEmbed-caption%22%3EPhoto%20byJoshua%20Schave/USA%20Shooting%3C/div%3E%0A%20%20%20%20%3C/div%3E\\\" data-embed-type=\\\"image\\\" contenteditable=\\\"false\\\"}{/sd-embed}  He also competed in 2012 in London and 2016 in Rio.\", \"from\": 1020, \"to\": 4354, \"entities\": [{\"begin\": 4331, \"end\": 4337, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9999674123981339, \"rank\": 3.243832231209539e-05, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}, {\"begin\": 4350, \"end\": 4353, \"title\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"score\": 0.9998951262890927, \"rank\": 0.00010488471070912746, \"text\": \"Rio\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2016_Summer_Olympics\"}]}, {\"sentence\": \"Sanderson says the competition keeps him coming back.\", \"from\": 4356, \"to\": 4409, \"entities\": [{\"begin\": 4356, \"end\": 4365, \"title\": \"http://dbpedia.org/resource/Frederick_William_Sanderson\", \"score\": 0.7819102661943991, \"rank\": 0.2756567536920536, \"text\": \"Sanderson\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Frederick_William_Sanderson\", \"dbpedia\": \"http://dbpedia.org/resource/Frederick_William_Sanderson\"}]}, {\"sentence\": \"\\\"Well, I have never done any drugs - well, anything more powerful than Benadryl or Aspirin, but I imagine that it's like heroin or crack or something, it's an addiction,\\\" he said.\", \"from\": 4411, \"to\": 4590, \"entities\": [{\"begin\": 4482, \"end\": 4490, \"title\": \"http://dbpedia.org/resource/Benadryl\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Benadryl\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Benadryl\", \"dbpedia\": \"http://dbpedia.org/resource/Benadryl\"}, {\"begin\": 4494, \"end\": 4501, \"title\": \"http://dbpedia.org/resource/Aspirin\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Aspirin\", \"types\": [\"Q8386\"], \"wikid\": \"http://dbpedia.org/resource/Aspirin\", \"dbpedia\": \"http://dbpedia.org/resource/Aspirin\"}]}, {\"sentence\": \"After graduating from Marshall, Sanderson joined the Marine Corps where he joined their shooting team.\", \"from\": 4592, \"to\": 4694, \"entities\": [{\"begin\": 4624, \"end\": 4633, \"title\": \"http://dbpedia.org/resource/Frederick_William_Sanderson\", \"score\": 0.7819102661943991, \"rank\": 0.2756567536920536, \"text\": \"Sanderson\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Frederick_William_Sanderson\", \"dbpedia\": \"http://dbpedia.org/resource/Frederick_William_Sanderson\"}, {\"begin\": 4645, \"end\": 4657, \"title\": \"http://dbpedia.org/resource/United_States_Marine_Corps\", \"score\": 0.9999999979272616, \"rank\": 2.044225776175358e-09, \"text\": \"Marine Corps\", \"types\": [\"Q43229\", \"Q24229398\", \"Q176799\"], \"wikid\": \"http://dbpedia.org/resource/United_States_Marine_Corps\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_Marine_Corps\"}]}, {\"sentence\": \"That is where he discovered and fell in love with the sport of shooting.\", \"from\": 4695, \"to\": 4767, \"entities\": []}, {\"sentence\": \"\\\"I am never going to beat Michael Phelps in the pool,\\\" he said.\", \"from\": 4769, \"to\": 4832, \"entities\": [{\"begin\": 4795, \"end\": 4809, \"title\": \"http://dbpedia.org/resource/Michael_Phelps\", \"score\": 1.0, \"rank\": 8.101578694145409e-27, \"text\": \"Michael Phelps\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Michael_Phelps\", \"dbpedia\": \"http://dbpedia.org/resource/Michael_Phelps\"}]}, {\"sentence\": \"\\\"I just do not have that genetic set of things that you need.\", \"from\": 4833, \"to\": 4894, \"entities\": []}, {\"sentence\": \"But shooting was weird because I was able to see from the very beginning in the Marine Corps that this is different than running or lifting weights or doing something else.\", \"from\": 4895, \"to\": 5067, \"entities\": [{\"begin\": 4975, \"end\": 4987, \"title\": \"http://dbpedia.org/resource/United_States_Marine_Corps\", \"score\": 0.9999999979272616, \"rank\": 2.044225776175358e-09, \"text\": \"Marine Corps\", \"types\": [\"Q43229\", \"Q24229398\", \"Q176799\"], \"wikid\": \"http://dbpedia.org/resource/United_States_Marine_Corps\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_Marine_Corps\"}]}, {\"sentence\": \"This is something where everyone is on an equal footing.\\\"\", \"from\": 5068, \"to\": 5125, \"entities\": []}, {\"sentence\": \"For years he got better and better and then in 2008 he got invited to the Olympics for the first time.\", \"from\": 5127, \"to\": 5229, \"entities\": []}, {\"sentence\": \"Photo by Brittany Nelson/USA Shooting  \\\"My most memorable experience was when I walked in to compete on my first day of competition, when I walked onto the field of play.\", \"from\": 5231, \"to\": 5401, \"entities\": [{\"begin\": 5240, \"end\": 5255, \"title\": \"http://dbpedia.org/resource/Brittany_Nelson\", \"score\": 0.9999983666425275, \"rank\": 0.0, \"text\": \"Brittany Nelson\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Brittany_Nelson\", \"dbpedia\": \"http://dbpedia.org/resource/Brittany_Nelson\"}, {\"begin\": 5256, \"end\": 5268, \"title\": \"http://dbpedia.org/resource/USA_Shooting\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"USA Shooting\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/USA_Shooting\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Shooting\"}]}, {\"sentence\": \"When I did it for the Olympics representing America, it was a different world.\\\"\", \"from\": 5402, \"to\": 5481, \"entities\": []}, {\"sentence\": \"Sanderson hit his peak in the years after those Olympics, eventually becoming number one in the world in the late ought's, but injuries, miscues, and a string of bad luck kept him from performing to his standards in the 2012 and 2016 games.\", \"from\": 5483, \"to\": 5723, \"entities\": []}, {\"sentence\": \"He says he has been improving day by day and thinks he is primed for a good showing in Paris.\", \"from\": 5725, \"to\": 5818, \"entities\": [{\"begin\": 5812, \"end\": 5817, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999928186298, \"rank\": 7.181374998633354e-09, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"He also says he has some simple advice for young aspiring Olympians.\", \"from\": 5820, \"to\": 5888, \"entities\": []}, {\"sentence\": \"\\\"Each day just suck less,\\\" he said semi-jokingly.\", \"from\": 5890, \"to\": 5939, \"entities\": []}, {\"sentence\": \"\\\"You do not have to be perfect, you just have to get better.\\\"\", \"from\": 5940, \"to\": 6001, \"entities\": []}, {\"sentence\": \"If you want to catch Sanderson and the rest of Team USA at the Olympics, he is competing in the 25 meter rapid fire pistol events.\", \"from\": 6003, \"to\": 6133, \"entities\": [{\"begin\": 6024, \"end\": 6033, \"title\": \"http://dbpedia.org/resource/Frederick_William_Sanderson\", \"score\": 0.7819102661943991, \"rank\": 0.2756567536920536, \"text\": \"Sanderson\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Frederick_William_Sanderson\", \"dbpedia\": \"http://dbpedia.org/resource/Frederick_William_Sanderson\"}, {\"begin\": 6050, \"end\": 6058, \"title\": \"http://dbpedia.org/resource/United_States_national_team\", \"score\": 0.9620793092401227, \"rank\": 0.03899730667831039, \"text\": \"Team USA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_national_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_national_team\"}]}, {\"sentence\": \"Pre-event training is on Saturday.\", \"from\": 6135, \"to\": 6169, \"entities\": []}, {\"sentence\": \"Stages one and two are on Sunday and the final, should he make it, is on Monday.\", \"from\": 6171, \"to\": 6251, \"entities\": []}, {\"sentence\": \"Catch all the action on News 4 San Antonio.\", \"from\": 6253, \"to\": 6296, \"entities\": [{\"begin\": 6288, \"end\": 6295, \"title\": \"http://dbpedia.org/resource/Antonio_Dawson\", \"score\": 0.7757529044937904, \"rank\": 0.28757760030770474, \"text\": \"Antonio\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Antonio_Dawson\", \"dbpedia\": \"http://dbpedia.org/resource/Antonio_Dawson\"}]}, {\"sentence\": \"2025Sinclair, Inc.\", \"from\": 6298, \"to\": 6316, \"entities\": []}]}"