dia.org/resource/Warne_Livesey\", \"score\": 0.9999999998153726, \"rank\": 1.8472807775696643e-10, \"text\": \"Livesey\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Warne_Livesey\", \"dbpedia\": \"http://dbpedia.org/resource/Warne_Livesey\"}, {\"begin\": 287, \"end\": 296, \"title\": \"http://dbpedia.org/resource/Australia\", \"score\": 0.9999926090013392, \"rank\": 6.460398152261915e-06, \"text\": \"Australia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Australia\", \"dbpedia\": \"http://dbpedia.org/resource/Australia\"}, {\"begin\": 304, \"end\": 310, \"title\": \"http://dbpedia.org/resource/Morris_Motors\", \"score\": 0.9991131470435448, \"rank\": 0.0008681099649284097, \"text\": \"Morris\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Morris_Motors\", \"dbpedia\": \"http://dbpedia.org/resource/Morris_Motors\"}, {\"begin\": 364, \"end\": 370, \"title\": \"http://dbpedia.org/resource/Israel\", \"score\": 0.9999957970209938, \"rank\": 4.2023661603989236e-06, \"text\": \"Israel\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Israel\", \"dbpedia\": \"http://dbpedia.org/resource/Israel\"}, {\"begin\": 433, \"end\": 442, \"title\": \"http://dbpedia.org/resource/Marseille\", \"score\": 0.9944915642856258, \"rank\": 0.0055389454692861715, \"text\": \"Marseille\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Marseille\", \"dbpedia\": \"http://dbpedia.org/resource/Marseille\"}]}, {\"sentence\": \"The 20-year-old Sydneysider was unable to catch Reuveny in the high-velocity dash while Dutchman Luuc van Opzeeland, looking for his country's fourth successive Olympic title in the event, took the bronze medal.\", \"from\": 445, \"to\": 656, \"entities\": [{\"begin\": 461, \"end\": 472, \"title\": \"http://dbpedia.org/resource/Sydney\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Sydneysider\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Sydney\", \"dbpedia\": \"http://dbpedia.org/resource/Sydney\"}]}, {\"sentence\": \"Morris becomes the first Australian to win a medal in windsurfing since Lars Kleppich brought home bronze from Barcelona in 1992.\", \"from\": 658, \"to\": 787, \"entities\": [{\"begin\": 658, \"end\": 664, \"title\": \"http://dbpedia.org/resource/Morris_Motors\", \"score\": 0.9991131470435448, \"rank\": 0.0008681099649284097, \"text\": \"Morris\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Morris_Motors\", \"dbpedia\": \"http://dbpedia.org/resource/Morris_Motors\"}, {\"begin\": 683, \"end\": 693, \"title\": \"http://dbpedia.org/resource/Australians\", \"score\": 0.8738452013345335, \"rank\": 0.14430820519134033, \"text\": \"Australian\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Australians\", \"dbpedia\": \"http://dbpedia.org/resource/Australians\"}, {\"begin\": 730, \"end\": 743, \"title\": \"http://dbpedia.org/resource/Lars_Kleppich\", \"score\": 0.9999985793402717, \"rank\": 0.0, \"text\": \"Lars Kleppich\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Lars_Kleppich\", \"dbpedia\": \"http://dbpedia.org/resource/Lars_Kleppich\"}, {\"begin\": 769, \"end\": 778, \"title\": \"http://dbpedia.org/resource/FC_Barcelona\", \"score\": 0.9725713205960617, \"rank\": 0.028202164691134235, \"text\": \"Barcelona\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/FC_Barcelona\", \"dbpedia\": \"http://dbpedia.org/resource/FC_Barcelona\"}]}, {\"sentence\": \"Competing in the new iQFOiL class, Morris was guaranteed a medal after topping the rankings after the 13-race qualifying series on the Mediterranean in southern France.\", \"from\": 789, \"to\": 957, \"entities\": [{\"begin\": 824, \"end\": 830, \"title\": \"http://dbpedia.org/resource/Morris_Motors\", \"score\": 0.9991131470435448, \"rank\": 0.0008681099649284097, \"text\": \"Morris\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Morris_Motors\", \"dbpedia\": \"http://dbpedia.org/resource/Morris_Motors\"}, {\"begin\": 950, \"end\": 956, \"title\": \"http://dbpedia.org/resource/France_national_football_team\", \"score\": 0.9786602027506228, \"rank\": 0.01517470364826993, \"text\": \"France\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/France_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/France_national_football_team\"}]}, {\"sentence\": \"Want more?Here's the full list of all our Olympics stories  That meant he moved straight into the final, awaiting his two competitors.\", \"from\": 959, \"to\": 1093, \"entities\": []}, {\"sentence\": \"World champion van Opzeeland won the quarter-final and semi-final earlier on Saturday with Reuveny, who was ranked second from qualifying, finishing second.\", \"from\": 1095, \"to\": 1251, \"entities\": []}, {\"sentence\": \"After the sailors were recalled for a second start, racing in the final got underway in perfect, top-end wind.\", \"from\": 1253, \"to\": 1363, \"entities\": []}, {\"sentence\": \"In iQFOiL windsurfing, the sailors fly off the water at high speed, the boards lifted by a foil with athletes pushing speeds well above 20 knots (37 kilometres per hour).\", \"from\": 1365, \"to\": 1535, \"entities\": []}, {\"sentence\": \"ABC Sport Daily is your daily sports conversation.\", \"from\": 1537, \"to\": 1587, \"entities\": [{\"begin\": 1537, \"end\": 1546, \"title\": \"http://dbpedia.org/resource/ABC_Radio_Grandstand\", \"score\": 0.9999963657817361, \"rank\": 3.6342313907408455e-06, \"text\": \"ABC Sport\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/ABC_Radio_Grandstand\", \"dbpedia\": \"http://dbpedia.org/resource/ABC_Radio_Grandstand\"}]}, {\"sentence\": \"We dive into the biggest story of the day and get you up to speed with everything else that's making headlines.\", \"from\": 1588, \"to\": 1699, \"entities\": []}, {\"sentence\": \"The three jostled for position in the early running with Morris just ahead at the first mark.\", \"from\": 1701, \"to\": 1794, \"entities\": [{\"begin\": 1758, \"end\": 1764, \"title\": \"http://dbpedia.org/resource/Morris_Motors\", \"score\": 0.9991131470435448, \"rank\": 0.0008681099649284097, \"text\": \"Morris\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Morris_Motors\", \"dbpedia\": \"http://dbpedia.org/resource/Morris_Motors\"}]}, {\"sentence\": \"But Reuveny made his move and emerged from the third buoy ahead of Morris, with the pair breaking clear of van Opzeeland.\", \"from\": 1796, \"to\": 1917, \"entities\": [{\"begin\": 1863, \"end\": 1869, \"title\": \"http://dbpedia.org/resource/Morris_Motors\", \"score\": 0.9991131470435448, \"rank\": 0.0008681099649284097, \"text\": \"Morris\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Morris_Motors\", \"dbpedia\": \"http://dbpedia.org/resource/Morris_Motors\"}]}, {\"sentence\": \"Reuveny, 24, built a healthy lead by gate four and managed to keep the Australian at bay, crossing the line in 6 minutes 43 seconds, 0.05 seconds in front.\", \"from\": 1919, \"to\": 2074, \"entities\": [{\"begin\": 1990, \"end\": 2000, \"title\": \"http://dbpedia.org/resource/Australians\", \"score\": 0.8738452013345335, \"rank\": 0.14430820519134033, \"text\": \"Australian\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Australians\", \"dbpedia\": \"http://dbpedia.org/resource/Australians\"}]}, {\"sentence\": \"While Morris appeared disappointed as he rode a dinghy back to shore, he was swamped by the Australian camp and chaired up the beach.\", \"from\": 2076, \"to\": 2209, \"entities\": [{\"begin\": 2082, \"end\": 2088, \"title\": \"http://dbpedia.org/resource/Morris_Motors\", \"score\": 0.9991131470435448, \"rank\": 0.0008681099649284097, \"text\": \"Morris\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Morris_Motors\", \"dbpedia\": \"htt