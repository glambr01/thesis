ung\"}, {\"begin\": 11013, \"end\": 11026, \"title\": \"http://dbpedia.org/resource/Samsung_Galaxy_Z_Flip\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Galaxy Z Flip\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Samsung_Galaxy_Z_Flip\", \"dbpedia\": \"http://dbpedia.org/resource/Samsung_Galaxy_Z_Flip\"}, {\"begin\": 11120, \"end\": 11126, \"title\": \"http://dbpedia.org/resource/Paralympic_symbols\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Agitos\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Paralympic_symbols\", \"dbpedia\": \"http://dbpedia.org/resource/Paralympic_symbols\"}, {\"begin\": 11170, \"end\": 11183, \"title\": \"http://dbpedia.org/resource/Samsung_Galaxy_Z_Flip\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Galaxy Z Flip\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Samsung_Galaxy_Z_Flip\", \"dbpedia\": \"http://dbpedia.org/resource/Samsung_Galaxy_Z_Flip\"}, {\"begin\": 11231, \"end\": 11238, \"title\": \"http://dbpedia.org/resource/Samsung\", \"score\": 1.0, \"rank\": 1.0145804755603644e-13, \"text\": \"Samsung\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Samsung\", \"dbpedia\": \"http://dbpedia.org/resource/Samsung\"}, {\"begin\": 11309, \"end\": 11320, \"title\": \"http://dbpedia.org/resource/France_national_baseball_team\", \"score\": 0.9999973597508254, \"rank\": 2.6230311892464947e-06, \"text\": \"Team France\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/France_national_baseball_team\", \"dbpedia\": \"http://dbpedia.org/resource/France_national_baseball_team\"}, {\"begin\": 11332, \"end\": 11342, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 0.9999999989295247, \"rank\": 1.0704818935517578e-09, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 11465, \"end\": 11472, \