"{\"uid\": \"cnn.com-2024-08-15-sport-jordan-chiles-cas-paris-olympics-spt-intl-index.html\", \"entities\": [{\"sentence\": \"Follow:  TheCourt of Arbitration for Sport (CAS)is standing by its ruling that Romania's Ana B\\u0103rbosu is the rightful third place finisher in floor exercise at the Paris Olympics.\", \"from\": 0, \"to\": 178, \"entities\": [{\"begin\": 79, \"end\": 86, \"title\": \"http://dbpedia.org/resource/Romania\", \"score\": 0.9999999253313973, \"rank\": 4.7864914960705594e-08, \"text\": \"Romania\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Romania\", \"dbpedia\": \"http://dbpedia.org/resource/Romania\"}, {\"begin\": 89, \"end\": 100, \"title\": \"http://dbpedia.org/resource/Ana_B\\u0103rbosu\", \"score\": 0.9999963232789303, \"rank\": 0.0, \"text\": \"Ana B\\u0103rbosu\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Ana_B\\u0103rbosu\", \"dbpedia\": \"http://dbpedia.org/resource/Ana_B\\u0103rbosu\"}]}, {\"sentence\": \"The decision led the International Olympic Committee (IOC) to request that American gymnastJordan Chilesreturn the bronze medal she was originally awarded.\", \"from\": 180, \"to\": 335, \"entities\": [{\"begin\": 201, \"end\": 238, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee (IOC)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}]}, {\"sentence\": \"Video came out Friday showing B\\u0103rbosu being awarded a bronze medal in an official ceremony at the Olympic Sports Association in Bucharest, conducted in front of the Romanian Olympic Committee and attended by the president of the Romanian Olympic and Sports Committee, Mihai Covaliu, and Romania's prime minister, Marcel Ciolacu, according to CNN affiliate Antena 3.\", \"from\": 337, \"to\": 702, \"entities\": [{\"begin\": 465, \"end\": 474, \"title\": \"http://dbpedia.org/resource/Bucharest\", \"score\": 0.9999999999890861, \"rank\": 1.1082595696099665e-11, \"text\": \"Bucharest\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Bucharest\", \"dbpedia\": \"http://dbpedia.org/resource/Bucharest\"}, {\"begin\": 502, \"end\": 528, \"title\": \"http://dbpedia.org/resource/Romanian_Olympic_and_Sports_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Romanian Olympic Committee\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Romanian_Olympic_and_Sports_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/Romanian_Olympic_and_Sports_Committee\"}, {\"begin\": 566, \"end\": 574, \"title\": \"http://dbpedia.org/resource/Romanian_language\", \"score\": 0.9330794901472845, \"rank\": 0.07171924857406467, \"text\": \"Romanian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Romanian_language\", \"dbpedia\": \"http://dbpedia.org/resource/Romanian_language\"}, {\"begin\": 605, \"end\": 618, \"title\": \"http://dbpedia.org/resource/Mihai_Covaliu\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Mihai Covaliu\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Mihai_Covaliu\", \"dbpedia\": \"http://dbpedia.org/resource/Mihai_Covaliu\"}, {\"begin\": 624, \"end\": 631, \"title\": \"http://dbpedia.org/resource/Romania\", \"score\": 0.9999999253313973, \"rank\": 4.7864914960705594e-08, \"text\": \"Romania\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Romania\", \"dbpedia\": \"http://dbpedia.org/resource/Romania\"}, {\"begin\": 650, \"end\": 664, \"title\": \"http://dbpedia.org/resource/Marcel_Ciolacu\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Marcel Ciolacu\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Marcel_Ciolacu\", \"dbpedia\": \"http://dbpedia.org/resource/Marcel_Ciolacu\"}, {\"begin\": 679, \"end\": 682, \"title\": \"http://dbpedia.org/resource/CNN\", \"score\": 1.0, \"rank\": 1.5937125638094626e-14, \"text\": \"CNN\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/CNN\", \"dbpedia\": \"http://dbpedia.org/resource/CNN\"}]}, {\"sentence\": \"In a media release on Wednesday, CAS maintains that, during its hearing with Romanian and US officials, there was never a dispute over USA Gymnastics (USAG) missing the one-minute deadline to challenge Chiles' floor exercise score.\", \"from\": 704, \"to\": 935, \"entities\": [{\"begin\": 737, \"end\": 740, \"title\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"score\": 1.0, \"rank\": 1.5019084338415087e-26, \"text\": \"CAS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"dbpedia\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\"}, {\"begin\": 781, \"end\": 789, \"title\": \"http://dbpedia.org/resource/Romanian_language\", \"score\": 0.9330794901472845, \"rank\": 0.07171924857406467, \"text\": \"Romanian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Romanian_language\", \"dbpedia\": \"http://dbpedia.org/resource/Romanian_language\"}, {\"begin\": 794, \"end\": 796, \"title\": \"http://dbpedia.org/resource/Federal_government_of_the_United_States\", \"score\": 0.9046975589075514, \"rank\": 0.1053408306043364, \"text\": \"US\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Federal_government_of_the_United_States\", \"dbpedia\": \"http://dbpedia.org/resource/Federal_government_of_the_United_States\"}, {\"begin\": 839, \"end\": 853, \"title\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"score\": 0.9999999793840291, \"rank\": 2.061586482037168e-08, \"text\": \"USA Gymnastics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Gymnastics\"}, {\"begin\": 855, \"end\": 859, \"title\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"USAG\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Gymnastics\"}]}, {\"sentence\": \"Olympic judges had inially revised Chiles' score, raising her into the bronze medal position and bumping B\\u0103rbosu off the podium.\", \"from\": 937, \"to\": 1065, \"entities\": []}, {\"sentence\": \"\\\"At the hearing, there was no dispute between the parties that Ms. Chiles' inquiry was submitted 1 minute and 4 seconds after her score was official [sic] displayed on the scoreboard,\\\" CASsaidin its release.\", \"from\": 1067, \"to\": 1274, \"entities\": []}, {\"sentence\": \"\\\"All parties accepted as clear and determinative the report prepared by Omega, the official timekeeper for the Olympic Games, and submitted by the FIG itself.\", \"from\": 1276, \"to\": 1434, \"entities\": [{\"begin\": 1348, \"end\": 1353, \"title\": \"http://dbpedia.org/resource/Omega_SA\", \"score\": 0.9988655129094266, \"rank\": 0.0011357073014722318, \"text\": \"Omega\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Omega_SA\", \"dbpedia\": \"http://dbpedia.org/resource/Omega_SA\"}, {\"begin\": 1423, \"end\": 1426, \"title\": \"http://dbpedia.org/resource/International_Gymnastics_Federation\", \"score\": 1.0, \"rank\": 1.5730634773352164e-31, \"text\": \"FIG\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Gymnastics_Federation\", \"dbpedia\": \"http://dbpedia.org/resource/International_Gymnastics_Federation\"}]}, {\"sentence\": \"No party sought the admittance of other evidence.\\\"\", \"from\": 1435, \"to\": 1485, \"entities\": []}, {\"sentence\": \"USAG has previously stated that it did not come into possession of video which it claims proves that its inquiry was submitted after just 47 seconds until after CAS had already made its ruling.\", \"from\": 1487, \"to\": 1680, \"entities\": [{\"begin\": 1487, \"end\": 1491, \"title\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"USAG\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Gymnastics\"}, {\"begin\": 1648, \"end\": 1651, \"title\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"score\": 1.0, \"rank\": 1.5019084338415087e-26, \"text\": \"CAS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"dbpedia\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\"}]}, {\"sentence\": \"\\\"The video footage provided was not available to USA Gymnastics prior to the tribunal's decision and thus USAG did not have the opportunity to previously submit it,\\\" USAG said Sunday.\", \"from\": 1682, \"to\": 1865, \"entities\": [{\"begin\": 1731, \"end\": 1745, \"title\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"score\": 0.9999999793840291, \"rank\": 2.061586482037168e-08, \"text\": \"USA Gymnastics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Gymnastics\"}, {\"begin\": 1788, \"end\": 1792, \"title\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"USAG\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Gymnastics\"}, {\"begin\": 1848, \"end\": 1852, \"title\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"USAG\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Gymnastics\"}]}, {\"sentence\": \"The US Olympic & Paralympic Committee (USOPC) and USAG also now claim that CAS initially sent \\\"crucial communications\\\" to the wrong email addresses, and as a result, the parties were not able to properly prepare for the hearing.\", \"from\": 1867, \"to\": 2095, \"entities\": [{\"begin\": 1917, \"end\": 1921, \"title\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"USAG\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Gymnastics\"}, {\"begin\": 1942, \"end\": 1945, \"title\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"score\": 1.0, \"rank\": 1.5019084338415087e-26, \"text\": \"CAS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"dbpedia\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\"}]}, {\"sentence\": \"\\\"The USOPC strongly contests the CAS decision due to significant procedural errors,\\\" USOPC told CNN Thursday.\", \"from\": 2097, \"to\": 2206, \"entities\": [{\"begin\": 2130, \"end\": 2133, \"title\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"score\": 1.0, \"rank\": 1.5019084338415087e-26, \"text\": \"CAS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"dbpedia\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\"}, {\"begin\": 2193, \"end\": 2196, \"title\": \"http://dbpedia.org/resource/CNN\", \"score\": 1.0, \"rank\": 1.5937125638094626e-14, \"text\": \"CNN\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/CNN\", \"dbpedia\": \"http://dbpedia.org/resource/CNN\"}]}, {\"sentence\": \"\\\"From August 6-9, CAS sent crucial communications to erroneous email addresses at USOPC and USAG, an error not corrected until August 9 - three days after filing, two days past the deadline to submit objections, and less than 24 hours before the hearing.\", \"from\": 2207, \"to\": 2461, \"entities\": [{\"begin\": 2225, \"end\": 2228, \"title\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"score\": 1.0, \"rank\": 1.5019084338415087e-26, \"text\": \"CAS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"dbpedia\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\"}, {\"begin\": 2299, \"end\": 2303, \"title\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"USAG\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Gymnastics\"}]}, {\"sentence\": \"\\\"This deprived us of adequate time to respond meaningfully or gather necessary evidence.\", \"from\": 2463, \"to\": 2551, \"entities\": []}, {\"sentence\": \"We informed CAS of our objections immediately.\\\"\", \"from\": 2552, \"to\": 2599, \"entities\": [{\"begin\": 2564, \"end\": 2567, \"title\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"score\": 1.0, \"rank\": 1.5019084338415087e-26, \"text\": \"CAS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"dbpedia\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\"}]}, {\"sentence\": \"Both parties say they will continue to appeal the matter.\", \"from\": 2601, \"to\": 2658, \"entities\": []}, {\"sentence\": \"\\\"Our pursuit of truth in this matter remains unwavering,\\\" the USOPC said.\", \"from\": 2660, \"to\": 2733, \"entities\": []}, {\"sentence\": \"Chilestook to InstagramThursday to say she was \\\"overwhelmed\\\" by the love and support she's received in the aftermath.\", \"from\": 2735, \"to\": 2852, \"entities\": []}, {\"sentence\": \"\\\"I am so incredibly grateful to my family, teammates, coaches, fans, USAG, and the USOPC for their unwavering support during this difficult time,\\\" she wrote.\", \"from\": 2854, \"to\": 3011, \"entities\": [{\"begin\": 2923, \"end\": 2927, \"title\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"USAG\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Gymnastics\"}]}, {\"sentence\": \"\\\"I have no words.\", \"from\": 3013, \"to\": 3030, \"entities\": []}, {\"sentence\": \"This decision feels unjust and comes as a significant blow, not just to me, but to everyone who has championed my journey,\\\" Chiles continued.\", \"from\": 3031, \"to\": 3172, \"entities\": []}, {\"sentence\": \"\\\"I have poured my heart and soul into this sport and I am so proud to represent my culture and my country.\\\"\", \"from\": 3173, \"to\": 3280, \"entities\": []}, {\"sentence\": \"\\\"I will approach this challenge as I have others - and will make every effort to ensure that justice is done.\\\"\", \"from\": 3282, \"to\": 3392, \"entities\": []}, {\"sentence\": \"On Monday, USAG said it would \\\"continue to pursue every possible avenue and appeal process, including to the Swiss Federal Tribunal, to ensure the just scoring, placement, and medal award for Jordan.\\\"\", \"from\": 3394, \"to\": 3594, \"entities\": [{\"begin\": 3405, \"end\": 3409, \"title\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"USAG\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Gymnastics\"}, {\"begin\": 3503, \"end\": 3525, \"title\": \"http://dbpedia.org/resource/Federal_Supreme_Court_of_Switzerland\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Swiss Federal Tribunal\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Federal_Supreme_Court_of_Switzerland\", \"dbpedia\": \"http://dbpedia.org/resource/Federal_Supreme_Court_of_Switzerland\"}, {\"begin\": 3586, \"end\": 3592, \"title\": \"http://dbpedia.org/resource/Jordan\", \"score\": 0.9552596518303889, \"rank\": 0.046589153086670804, \"text\": \"Jordan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jordan\", \"dbpedia\": \"http://dbpedia.org/resource/Jordan\"}]}, {\"sentence\": \"The national governing body has also voiced concerns about Dr. Hamid G. Gharavi, who has represented Romania in previous arbitration cases, chairing the CAS panel.\", \"from\": 3596, \"to\": 3759, \"entities\": [{\"begin\": 3659, \"end\": 3664, \"title\": \"http://dbpedia.org/resource/Abdul_Hamid_II\", \"score\": 0.9999999999990905, \"rank\": 6.311121396288767e-13, \"text\": \"Hamid\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Abdul_Hamid_II\", \"dbpedia\": \"http://dbpedia.org/resource/Abdul_Hamid_II\"}, {\"begin\": 3697, \"end\": 3704, \"title\": \"http://dbpedia.org/resource/Romania\", \"score\": 0.9999999253313973, \"rank\": 4.7864914960705594e-08, \"text\": \"Romania\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Romania\", \"dbpedia\": \"http://dbpedia.org/resource/Romania\"}, {\"begin\": 3749, \"end\": 3752, \"title\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"score\": 1.0, \"rank\": 1.5019084338415087e-26, \"text\": \"CAS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"dbpedia\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\"}]}, {\"sentence\": \"CAS says that none of the parties involved objected to Gharavi's appointment to the panel, but USAG claims that it was never informed of his ties to Romania.\", \"from\": 3760, \"to\": 3917, \"entities\": [{\"begin\": 3760, \"end\": 3763, \"title\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"score\": 1.0, \"rank\": 1.5019084338415087e-26, \"text\": \"CAS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"dbpedia\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\"}, {\"begin\": 3855, \"end\": 3859, \"title\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"USAG\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Gymnastics\"}, {\"begin\": 3909, \"end\": 3916, \"title\": \"http://dbpedia.org/resource/Romania\", \"score\": 0.9999999253313973, \"rank\": 4.7864914960705594e-08, \"text\": \"Romania\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Romania\", \"dbpedia\": \"http://dbpedia.org/resource/Romania\"}]}, {\"sentence\": \"\\\"CAS did not send the conflict-of-interest disclosures of any panelist to USA Gymnastics, nor have we seen the disclosures to date,\\\" its statement read.\", \"from\": 3919, \"to\": 4071, \"entities\": [{\"begin\": 3920, \"end\": 3923, \"title\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"score\": 1.0, \"rank\": 1.5019084338415087e-26, \"text\": \"CAS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"dbpedia\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\"}, {\"begin\": 3993, \"end\": 4007, \"title\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"score\": 0.9999999793840291, \"rank\": 2.061586482037168e-08, \"text\": \"USA Gymnastics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Gymnastics\"}]}, {\"sentence\": \"B\\u0103rbosu said Friday: \\\"The resolution of the case was possible thanks to the federation and the law firm that did not give up on us, the sportswomen, and fought for all of us and wanted there to be three bronze medals.\", \"from\": 4073, \"to\": 4290, \"entities\": []}, {\"sentence\": \"\\\"I thank them because they fought for us and continue to fight.\", \"from\": 4292, \"to\": 4355, \"entities\": []}, {\"sentence\": \"I am very happy to have this medal and I hope to continue to represent Romania at the highest level and bring back as many medals as possible.\", \"from\": 4356, \"to\": 4498, \"entities\": [{\"begin\": 4427, \"end\": 4434, \"title\": \"http://dbpedia.org/resource/Romania\", \"score\": 0.9999999253313973, \"rank\": 4.7864914960705594e-08, \"text\": \"Romania\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Romania\", \"dbpedia\": \"http://dbpedia.org/resource/Romania\"}]}, {\"sentence\": \"Thank you!\\\"\", \"from\": 4499, \"to\": 4510, \"entities\": []}, {\"sentence\": \"she added, per Reuters.\", \"from\": 4511, \"to\": 4534, \"entities\": [{\"begin\": 4526, \"end\": 4533, \"title\": \"http://dbpedia.org/resource/Reuters\", \"score\": 1.0, \"rank\": 5.082551903282987e-17, \"text\": \"Reuters\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Reuters\", \"dbpedia\": \"http://dbpedia.org/resource/Reuters\"}]}, {\"sentence\": \"Last week, Chiles posted four breaking hearts emojis on her Instagram story, explaining how she was \\\"taking this time and removing myself from social media for my mental health.\\\"\", \"from\": 4536, \"to\": 4714, \"entities\": [{\"begin\": 4596, \"end\": 4605, \"title\": \"http://dbpedia.org/resource/Instagram\", \"score\": 1.0, \"rank\": 3.164130305168294e-22, \"text\": \"Instagram\", \"types\": [\"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Instagram\", \"dbpedia\": \"http://dbpedia.org/resource/Instagram\"}]}, {\"sentence\": \"CNN's Thomas Schlachter contributed to reporting.\", \"from\": 4716, \"to\": 4765, \"entities\": [{\"begin\": 4716, \"end\": 4719, \"title\": \"http://dbpedia.org/resource/CNN\", \"score\": 1.0, \"rank\": 1.5937125638094626e-14, \"text\": \"CNN\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/CNN\", \"dbpedia\": \"http://dbpedia.org/resource/CNN\"}, {\"begin\": 4722, \"end\": 4728, \"title\": \"http://dbpedia.org/resource/Clarence_Thomas\", \"score\": 1.0, \"rank\": 1.7496061707055418e-14, \"text\": \"Thomas\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Clarence_Thomas\", \"dbpedia\": \"http://dbpedia.org/resource/Clarence_Thomas\"}]}, {\"sentence\": \"\\u00a9 2025 Cable News Network.\", \"from\": 4767, \"to\": 4793, \"entities\": []}, {\"sentence\": \"A Warner Bros.\", \"from\": 4794, \"to\": 4808, \"entities\": [{\"begin\": 4796, \"end\": 4802, \"title\": \"http://dbpedia.org/resource/WarnerMedia\", \"score\": 0.8191351629104319, \"rank\": 0.2207993075063724, \"text\": \"Warner\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/WarnerMedia\", \"dbpedia\": \"http://dbpedia.org/resource/WarnerMedia\"}]}, {\"sentence\": \"Discovery Company.\", \"from\": 4809, \"to\": 4827, \"entities\": [{\"begin\": 4809, \"end\": 4818, \"title\": \"http://dbpedia.org/resource/Discovery_Channel\", \"score\": 0.9999999993287929, \"rank\": 6.713173238268927e-10, \"text\": \"Discovery\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/Discovery_Channel\", \"dbpedia\": \"http://dbpedia.org/resource/Discovery_Channel\"}]}, {\"sentence\": \"All Rights Reserved.CNN Sans \\u2122 & \\u00a9 2016 Cable News Network.\", \"from\": 4828, \"to\": 4887, \"entities\": []}]}"