m\": 285, \"to\": 306, \"entities\": [{\"begin\": 293, \"end\": 296, \"title\": \"http://dbpedia.org/resource/Don_Draper\", \"score\": 0.9999429729135023, \"rank\": 5.597505666688034e-05, \"text\": \"Don\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Don_Draper\", \"dbpedia\": \"http://dbpedia.org/resource/Don_Draper\"}, {\"begin\": 297, \"end\": 305, \"title\": \"http://dbpedia.org/resource/Nate_McMillan\", \"score\": 0.9999990530316091, \"rank\": 8.668290479830072e-07, \"text\": \"McMillan\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Nate_McMillan\", \"dbpedia\": \"http://dbpedia.org/resource/Nate_McMillan\"}]}, {\"sentence\": \"This former chip designer has been doing his one-of-a-kind, PowerPoint-Driven comedy show for audiences for over 20 years.\", \"from\": 307, \"to\": 429, \"entities\": []}, {\"sentence\": \"His show is packed with graphs & charts & laughs.\", \"from\": 430, \"to\": 479, \"entities\": []}, {\"sentence\": \"He also was a finalist on America's Got Talent.\", \"from\": 480, \"to\": 527, \"entities\": []}, {\"sentence\": \"I am thrilled and proud to be headlining the Go For Gold Comedy Fundraiser to benefit Special Olympics Vermont.\", \"from\": 531, \"to\": 642, \"entities\": [{\"begin\": 634, \"end\": 641, \"title\": \"http://dbpedia.org/resource/Vermont\", \"score\": 0.9899861404162228, \"rank\": 0.008667288954737132, \"text\": \"Vermont\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Vermont\", \"dbpedia\": \"http://dbpedia.org/resource/Vermont\"}]}, {\"sentence\": \"They are a tremendous organization and Burlington, VT is my home away from home.\", \"from\": 643, \"to\": 723, \"entities\": [{\"begin\": 682, \"end\": 692, \"title\": \"http://dbpedia.org/resource/Burlington,_Vermont\", \"score\": 0.5070982472700225, \"rank\": 0.32541558596563785, \"text\": \"Burlington\", \"types\": [\"Q515\", \"Q486972\"], \"wikid