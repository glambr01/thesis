gin\": 593, \"end\": 598, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9999780578006624, \"rank\": 9.585829088465768e-06, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}, {\"begin\": 638, \"end\": 651, \"title\": \"http://dbpedia.org/resource/Li_Xiaoshuang\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Li Xiaoshuang\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Li_Xiaoshuang\", \"dbpedia\": \"http://dbpedia.org/resource/Li_Xiaoshuang\"}]}, {\"sentence\": \"\\\"Our team of coaches have issues.\", \"from\": 743, \"to\": 776, \"entities\": []}, {\"sentence\": \"Let us not put all responsibilities on athletes.\", \"from\": 777, \"to\": 825, \"entities\": []}, {\"sentence\": \"If they failed, the coaches did something wrong.\", \"from\": 826, \"to\": 874, \"entities\": []}, {\"sentence\": \"We need to tell the truth after we fail,\\\" 50-year-old Li said in an online live broadcast that went viral on Chinese social media.\", \"from\": 875, \"to\": 1005, \"entities\": [{\"begin\": 929, \"end\": 931, \"title\": \"http://dbpedia.org/resource/Hlai_people\", \"score\": 0.998183164212342, \"rank\": 0.0018201426879635712, \"text\": \"Li\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Hlai_people\", \"dbpedia\": \"http://dbpedia.org/resource/Hlai_people\"}, {\"begin\": 984, \"end\": 991, \"title\": \"http://dbpedia.org/resource/Chinese_language\", \"score\": 0.5933913994876433, \"rank\": 0.6791914234773473, \"text\": \"Chinese\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Chinese_language\", \"dbpedia\": \"http://dbpedia.org/resource/Chinese_language\"}]}, {\"sentence\": \"\\\"Our athletes are too old.\", \"from\": 1007, \"to\": 1033, \"entities\": []}, {\"sentence\": \"Sports needs young people.\", \"from\": 1034, \"to\": 1060, \"entities\": []}, {\"sentence\": \"We really need to change the way we train and select athletes,\\\" added Li, who won gold on the floor at the 1992 Barcelona Olympics and in the all-around at Atlanta four years later.\", \"from\": 1061, \"to\": 1242, \"entities\": [{\"begin\": 1131, \"end\": 1133, \"title\": \"http://dbpedia.org/resource/Hlai_people\", \"score\": 0.998183164212342, \"rank\": 0.0018201426879635712, \"text\": \"Li\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Hlai_people\", \"dbpedia\": \"http://dbpedia.org/resource/Hlai_people\"}, {\"begin\": 1168, \"end\": 1191, \"title\": \"http://dbpedia.org/resource/Gymnastics_at_the_1992_Summer_Olympics\", \"score\": 0.7199493380466403, \"rank\": 0.388986623278813, \"text\": \"1992 Barcelona Olympics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/Gymnastics_at_the_1992_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Gymnastics_at_the_1992_Summer_Olympics\"}, {\"begin\": 1173, \"end\": 1191, \"title\": \"http://dbpedia.org/resource/1992_Summer_Olympics\", \"score\": 0.9999999999834017, \"rank\": 1.275884687297338e-11, \"text\": \"Barcelona Olympics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/1992_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/1992_Summer_Olympics\"}, {\"begin\": 1217, \"end\": 1224, \"title\": \"http://dbpedia.org/resource/Atlanta\", \"score\": 0.9999999863196082, \"rank\": 1.2546524112391781e-08, \"text\": \"Atlanta\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Atlanta\", \"dbpedia\": \"http://dbpedia.org/resource/Atlanta\"}]}, {\"sentence\": \"China's five gymnasts in the team event in Paris had an average age of 26.2.\", \"from\": 1244, \"to\": 1320, \"entities\": [{\"begin\": 1244, \"end\": 1249, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9999780578006624, \"rank\": 9.585829088465768e-06, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}, {\"begin\": 1287, \"end\": 1292, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999395186, \"rank\": 6.057087738641804e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"Mistakes by 28-year-old Xiao Ruoteng and Su Weide, 24, on the high bar in the final rotation of Monday's all-around event cost China the gold after they had been ahead of Japan by three points after the first five apparatus.\", \"from\": 1322, \"to\": 1546, \"entities\": [{\"begin\": 1346, \"end\": 1358, \"title\": \"http://dbpedia.org/resource/Xiao_Ruoteng\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Xiao Ruoteng\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Xiao_Ruoteng\", \"dbpedia\": \"http://dbpedia.org/resource/Xiao_Ruoteng\"}, {\"begin\": 1449, \"end\": 1454, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9999780578006624, \"rank\": 9.585829088465768e-06, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}, {\"begin\": 1493, \"end\": 1498, \"title\": \"http://dbpedia.org/resource/Japan\", \"score\": 0.6540744204970188, \"rank\": 0.5216537823189736, \"text\": \"Japan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Japan\", \"dbpedia\": \"http://dbpedia.org/resource/Japan\"}]}, {\"sentence\": \"First Xiao landed on his knees from the bar, then Su twice fell to the floor, resulting in China's lowest score of the day and handing a surprise victory to Japan.\", \"from\": 1548, \"to\": 1711, \"entities\": [{\"begin\": 1639, \"end\": 1644, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9999780578006624, \"rank\": 9.585829088465768e-06, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}, {\"begin\": 1705, \"end\": 1710, \"title\": \"http://dbpedia.org/resource/Japan\", \"score\": 0.6540744204970188, \"rank\": 0.5216537823189736, \"text\": \"Japan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Japan\", \"dbpedia\": \"http://dbpedia.org/resource/Japan\"}]}, {\"sentence\": \"\\\"After watching the competition, I felt so much pain.\", \"from\": 1713, \"to\": 1766, \"entities\": []}, {\"sentence\": \"It was really painful.\", \"from\": 1767, \"to\": 1789, \"entities\": []}, {\"sentence\": \"Good soldiers need a good general.\", \"from\": 1790, \"to\": 1824, \"entities\": []}, {\"sentence\": \"China has a great gymnastics team but we lack leadership and that's a problem,\\\" Li said.\", \"from\": 1825, \"to\": 1913, \"entities\": [{\"begin\": 1825, \"end\": 1830, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9999780578006624, \"rank\": 9.585829088465768e-06, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}, {\"begin\": 1905, \"end\": 1907, \"title\": \"http://dbpedia.org/resource/Hlai_people\", \"score\": 0.998183164212342, \"rank\": 0.0018201426879635712, \"text\": \"Li\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Hlai_people\", \"dbpedia\": \"http://dbpedia.org/resource/Hlai_people\"}]}, {\"sentence\": \"\\\"Su got the job at the last minute and barely had any training.\", \"from\": 1915, \"to\": 1978, \"entities\": []}, {\"sentence\": \"We do not have anyone that is 18, 19 or 20 years old.\", \"from\": 1979, \"to\": 2032, \"entities\": []}, {\"sentence\": \"How are we going to make it to the next Olympics?\\\"\", \"from\": 2033, \"to\": 2083, \"entities\": []}, {\"sentence\": \"said Li, who was 18 when he won his first Olympic gold.\", \"from\": 2084, \"to\": 2139, \"entities\": [{\"begin\": 2089, \"end\": 2091, \"title\": \"http://dbpedia.org/resource/Hlai_people\", \"score\": 0.998183164212342, \"rank\": 0.0018201426879635712, \"text\": \"Li\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Hlai_people\", \"dbpedia\": \"http://dbpedia.org/resource/Hlai_people\"}]}, {\"sentence\": \"Li also criticised the way China's women gymnasts were trained, saying they were burned out too young.\", \"from\": 2141, \"to\": 2243, \"entities\": [{\"begin\": 2141, \"end\": 2143, \"title\": \"http://dbpedia.org/resource/Hlai_people\", \"score\": 0.998183164212342, \"rank\": 0.0018201426879635712, \"text\": \"Li\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Hlai_people\", \"dbpedia\": \"http://dbpedia.org/resource/Hlai_people\"}, {\"begin\": 2168, \"end\": 2173, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9999780578006624, \"rank\": 9.585829088465768e-06, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}]}, {\"sentence\": \"\\\"We should change our training methods.\", \"from\": 2245, \"to\": 2284, \"entities\": []}, {\"sentence\": \"Do not always say our bodies are not as strong as the Americans... give the girls a bit of time to grow.\", \"from\": 2285, \"to\": 2389, \"entities\": []}, {\"sentence\": \"We burn them out too soon,\\\" he said.\", \"from\": 2390, \"to\": 2426, \"entities\": []}, {\"sentence\": \"Li said China had not produced any good gymnasts on the vault since Cheng Fei, who won gold in the women's team event and bronze on vault at the Beijing Olympics 16 years ago.\", \"from\": 2428, \"to\": 2603, \"entities\": [{\"begin\": 2428, \"end\": 2430, \"title\": \"http://dbpedia.org/resource/Hlai_people\", \"score\": 0.998183164212342, \"rank\": 0.0018201426879635712, \"text\": \"Li\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Hlai_people\", \"dbpedia\": \"http://dbpedia.org/resource/Hlai_people\"}, {\"begin\": 2436, \"end\": 2441, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9999780578006624, \"rank\": 9.585829088465768e-06, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}, {\"begin\": 2496, \"end\": 2505, \"title\": \"http://dbpedia.org/resource/Cheng_Fei\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Cheng Fei\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Cheng_Fei\", \"dbpedia\": \"http://dbpedia.org/resource/Cheng_Fei\"}]}, {\"sentence\": \"\\\"We are good on the beam and not bad on the uneven bars but how come our vault -- I find it unacceptable!\", \"from\": 2605, \"to\": 2710, \"entities\": []}, {\"sentence\": \"The routines have not changed since '92,\\\" said Li.\", \"from\": 2711, \"to\": 2761, \"entities\": [{\"begin\": 2758, \"end\": 2760, \"title\": \"http://dbpedia.org/resource/Hlai_people\", \"score\": 0.998183164212342, \"rank\": 0.0018201426879635712, \"text\": \"Li\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Hlai_people\", \"dbpedia\": \"http://dbpedia.org/resource/Hlai_people\"}]}, {\"sentence\": \"REUTERS  China  Olympics  Gymnastics  E-paper  Newsletters  Podcasts  RSS Feed  About Us  Terms & Conditions  Personal Data Protection Notice  Need help?\", \"from\": 2762, \"to\": 2915, \"entities\": [{\"begin\": 2762, \"end\": 2769, \"title\": \"http://dbpedia.org/resource/Reuters\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"REUTERS\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Reuters\", \"dbpedia\": \"http://dbpedia.org/resource/Reuters\"}, {\"begin\": 2771, \"end\": 2776, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9999780578006624, \"rank\": 9.585829088465768e-06, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/