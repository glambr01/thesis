a.org/resource/Seine\", \"score\": 1.0, \"rank\": 5.50204504700196e-29, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}, {\"begin\": 2257, \"end\": 2265, \"title\": \"http://dbpedia.org/resource/Neustria\", \"score\": 0.999999970636964, \"rank\": 2.9363036079754043e-08, \"text\": \"Neustria\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Neustria\", \"dbpedia\": \"http://dbpedia.org/resource/Neustria\"}, {\"begin\": 2282, \"end\": 2287, \"title\": \"http://dbpedia.org/resource/Rouen\", \"score\": 1.0, \"rank\": 1.651279601713642e-18, \"text\": \"Rouen\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Rouen\", \"dbpedia\": \"http://dbpedia.org/resource/Rouen\"}, {\"begin\": 2306, \"end\": 2312, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9996102568115715, \"rank\": 0.0003898673783341592, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}]}, {\"sentence\": \"The river has influenced the numbering of Parisian streets, with perpendicular or oblique streets starting their numbers from the side closest to the Seine and parallel streets numbering in the direction of the current.\", \"from\": 2315, \"to\": 2534, \"entities\": [{\"begin\": 2465, \"end\": 2470, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 1.0, \"rank\": 5.50204504700196e-29, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}]}, {\"sentence\": \"Renowned for its scenic beauty, historic bridges, and romantic charm, the Seine remains central to Parisian culture and history, attracting tourists and artists worldwide.\", \"from\": 2536, \"to\": 2707, \"entities\": [{\"begin\": 2610, \"end\": 2615, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 1.0, \"rank\": 5.50204504700196e-29, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}]}, {\"sentence\": \"Swimming in the Seine has been banned since 1923 because of highpollutionlevels.\", \"from\": 2709, \"to\": 2789, \"entities\": [{\"begin\": 2725, \"end\": 2730, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 1.0, \"rank\": 5.50204504700196e-29, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}]}, {\"sentence\": \"However, ParisOlympics2024 preparations included a clean-up operation to make it usable for the Games and further showcase the city.\", \"from\": 2791, \"to\": 2923, \"entities\": []}, {\"sentence\": \"After the tests were carried out on July 26, results showed the water quality in the Seine was slightly below the standards needed to authorise swimming.\", \"from\": 2925, \"to\": 3078, \"entities\": [{\"begin\": 3010, \"end\": 3015, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 1.0, \"rank\": 5.50204504700196e-29, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}]}, {\"sentence\": \"Daily water quality tests measure levels of fecal bacteria known as E. coli.\", \"from\": 3080, \"to\": 3156, \"entities\": []}, {\"sentence\": \"Monitoring group Eau de Paris carried out the tests.\", \"from\": 3158, \"to\": 3210, \"entities\": [{\"begin\": 3175, \"end\": 3187, \"title\": \"http://dbpedia.org/resource/Eau_de_Paris\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Eau de Paris\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Eau_de_Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Eau_de_Paris\"}]}, {\"sentence\": \"These showed that at the Bras Marie, E. coli levels were then above the safe limit of 900 colony-forming units per 100 millilitres, determined by European rules,when Paris Mayor Anne Hidalgo took a dipon July 17.\", \"from\": 3211, \"to\": 3423, \"entities\": [{\"begin\": 3377, \"end\": 3388, \"title\": \"http://dbpedia.org/resource/List_of_mayors_of_Paris\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Paris Mayor\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/List_of_mayors_of_Paris\", \"dbpedia\": \"http://dbpedia.org/resource/List_of_mayors_of_Paris\"}, {\"begin\": 3389, \"end\": 3401, \"title\": \"http://dbpedia.org/resource/Anne_Hidalgo\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Anne Hidalgo\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Anne_Hidalgo\", \"dbpedia\": \"http://dbpedia.org/resource/Anne_Hidalgo\"}]}, {\"sentence\": \"The site reached a value of 985 on the day the mayor swam with Paris 2024 chief Tony Estanguet and the top government official for the Paris region, Marc Guillaume.\", \"from\": 3425, \"to\": 3589, \"entities\": [{\"begin\": 3488, \"end\": 3498, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 2.2279845578544893e-30, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 3505, \"end\": 3519, \"title\": \"http://dbpedia.org/resource/Tony_Estanguet\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Tony Estanguet\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Tony_Estanguet\", \"dbpedia\": \"http://dbpedia.org/resource/Tony_Estanguet\"}, {\"begin\": 3560, \"end\": 3565, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 4.861244752304596e-18, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org