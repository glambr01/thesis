"{\"uid\": \"kyivindependent.com-remembrance-is-not-a-violation-third-ukrainian-athlete-barred-from-wearing-helmet-at-olympics\", \"entities\": [{\"sentence\": \"Editor's note: Ukrainian skeleton racer VladyslavHeraskevych wasdisqualifiedon the morning of Feb. 12 after refusing to not wear a helmet that honors Ukrainian athletes killed by Russia's war.\", \"from\": 0, \"to\": 192, \"entities\": [{\"begin\": 15, \"end\": 24, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 1.0, \"rank\": 4.1450892164201624e-14, \"text\": \"Ukrainian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Ukraine\"}, {\"begin\": 150, \"end\": 159, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 1.0, \"rank\": 4.1450892164201624e-14, \"text\": \"Ukrainian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Ukraine\"}, {\"begin\": 179, \"end\": 185, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999999998644853, \"rank\": 1.355964882255244e-10, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}]}, {\"sentence\": \"Oleh Handei, a Ukrainian short track speed skater, said on Feb. 11 that he will not be allowed to wear his custom helmet at the Olympic Games in Milan because it is inscribed with a line of Ukrainian poetry.\", \"from\": 194, \"to\": 401, \"entities\": [{\"begin\": 194, \"end\": 198, \"title\": \"http://dbpedia.org/resource/Oleg_of_Novgorod\", \"score\": 1.0, \"rank\": 3.3356564524851264e-14, \"text\": \"Oleh\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Oleg_of_Novgorod\", \"dbpedia\": \"http://dbpedia.org/resource/Oleg_of_Novgorod\"}, {\"begin\": 209, \"end\": 218, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 1.0, \"rank\": 4.1450892164201624e-14, \"text\": \"Ukrainian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Ukraine\"}, {\"begin\": 339, \"end\": 344, \"title\": \"http://dbpedia.org/resource/Milan\", \"score\": 0.999999824003241, \"rank\": 1.3864955696785e-07, \"text\": \"Milan\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Milan\", \"dbpedia\": \"http://dbpedia.org/resource/Milan\"}, {\"begin\": 384, \"end\": 393, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 1.0, \"rank\": 4.1450892164201624e-14, \"text\": \"Ukrainian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Ukraine\"}]}, {\"sentence\": \"Handei is the thirdUkrainian Olympianwhose helmet has been barred from competition on the grounds of \\\"politicization.\\\"\", \"from\": 403, \"to\": 521, \"entities\": []}, {\"sentence\": \"The International Skating Union informed Handei of the helmet ban a few days before the start of the WinterOlympics, the athlete told the Ukrainian outlet Suspilne Sport.\", \"from\": 523, \"to\": 693, \"entities\": [{\"begin\": 549, \"end\": 554, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999999879892131, \"rank\": 1.201095280190738e-08, \"text\": \"Union\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 661, \"end\": 670, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 1.0, \"rank\": 4.1450892164201624e-14, \"text\": \"Ukrainian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Ukraine\"}, {\"begin\": 678, \"end\": 686, \"title\": \"http://dbpedia.org/resource/Public_Broadcasting_Company_of_Ukraine\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Suspilne\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Public_Broadcasting_Company_of_Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Public_Broadcasting_Company_of_Ukraine\"}]}, {\"sentence\": \"He was told he failed the inspection due to his helmet bearing a \\\"political slogan.\\\"\", \"from\": 694, \"to\": 778, \"entities\": []}, {\"sentence\": \"\\\"I have an inscription on my helmet by Lina Kostenko: 'Where there is heroism, there is no final defeat,'\\\" Handeisaid.\", \"from\": 780, \"to\": 898, \"entities\": [{\"begin\": 819, \"end\": 832, \"title\": \"http://dbpedia.org/resource/Lina_Kostenko\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Lina Kostenko\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Lina_Kostenko\", \"dbpedia\": \"http://dbpedia.org/resource/Lina_Kostenko\"}]}, {\"sentence\": \"\\\"They banned it, saying that it was a political slogan, that it was about war, that it was not allowed.\", \"from\": 900, \"to\": 1003, \"entities\": []}, {\"sentence\": \"I translated it word for word for them - no, it's not a political slogan.\", \"from\": 1004, \"to\": 1077, \"entities\": []}, {\"sentence\": \"These are just motivational words for me, for my team, and for my country.\\\"\", \"from\": 1078, \"to\": 1153, \"entities\": []}, {\"sentence\": \"The International Olympic Committee (IOC) has banned two other Ukrainians from wearing their helmets at the 2026 Games.\", \"from\": 1155, \"to\": 1274, \"entities\": [{\"begin\": 1159, \"end\": 1196, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee (IOC)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 1218, \"end\": 1228, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 1.0, \"rank\": 2.3146611921420163e-14, \"text\": \"Ukrainians\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Ukraine\"}]}, {\"sentence\": \"Kateryna Kotsar, a Ukrainian freestyle skier, said the IOCdisqualified her helmetfor the inscription \\\"Be Brave like Ukrainians.\\\"\", \"from\": 1276, \"to\": 1404, \"entities\": [{\"begin\": 1295, \"end\": 1304, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 1.0, \"rank\": 4.1450892164201624e-14, \"text\": \"Ukrainian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Ukraine\"}, {\"begin\": 1392, \"end\": 1402, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 1.0, \"rank\": 2.3146611921420163e-14, \"text\": \"Ukrainians\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Ukraine\"}]}, {\"sentence\": \"Skeleton racerVladyslav Heraskevychwas barred from wearing a helmet that honors Ukrainian athletes killed in Russia's war.\", \"from\": 1405, \"to\": 1527, \"entities\": [{\"begin\": 1485, \"end\": 1494, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 1.0, \"rank\": 4.1450892164201624e-14, \"text\": \"Ukrainian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Ukraine\"}, {\"begin\": 1514, \"end\": 1520, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999999998644853, \"rank\": 1.355964882255244e-10, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}]}, {\"sentence\": \"The IOC maintains that the Olympic Charter explicitlybansthe \\\"politicization of sport.\\\"\", \"from\": 1529, \"to\": 1616, \"entities\": [{\"begin\": 1533, \"end\": 1536, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 9.145327158438215e-28, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}]}, {\"sentence\": \"Handei, however, said thatKostenko'spoetry is \\\"not about politics.\\\"\", \"from\": 1618, \"to\": 1685, \"entities\": []}, {\"sentence\": \"\\\"A person whose words I respect, whom I follow, where there is no hint of war.\", \"from\": 1687, \"to\": 1765, \"entities\": []}, {\"sentence\": \"It's not allowed.\", \"from\": 1766, \"to\": 1783, \"entities\": []}, {\"sentence\": \"I tried to argue - they made it clear to me that it was better not to do so,\\\" Handei said.\", \"from\": 1784, \"to\": 1874, \"entities\": []}, {\"sentence\": \"Heraskevych, whose helmet was prohibited for depicting portraits of Ukrainian athletes killed in Russia's full-scale invasion, criticized the IOC for hypocrisy in aposton social media.\", \"from\": 1876, \"to\": 2060, \"entities\": [{\"begin\": 1944, \"end\": 1953, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 1.0, \"rank\": 4.1450892164201624e-14, \"text\": \"Ukrainian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Ukraine\"}, {\"begin\": 1973, \"end\": 1979, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999999998644853, \"rank\": 1.355964882255244e-10, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}, {\"begin\": 2018, \"end\": 2021, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 9.145327158438215e-28, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}]}, {\"sentence\": \"Heraskevych pointed out that Israeli skeleton racer Jared Firestone was allowed to participate in the Opening Ceremony wearing a kippah with the names of the 11 Israeli athletes and coaches killed in the terrorist attack at the 1972 Munich Olympics.\", \"from\": 2062, \"to\": 2311, \"entities\": [{\"begin\": 2091, \"end\": 2098, \"title\": \"http://dbpedia.org/resource/Israel_Defense_Forces\", \"score\": 0.9994151979601216, \"rank\": 0.0003540009859393649, \"text\": \"Israeli\", \"types\": [\"Q43229\", \"Q24229398\", \"Q176799\"], \"wikid\": \"http://dbpedia.org/resource/Israel_Defense_Forces\", \"dbpedia\": \"http://dbpedia.org/resource/Israel_Defense_Forces\"}, {\"begin\": 2120, \"end\": 2129, \"title\": \"http://dbpedia.org/resource/Firestone_Tire_and_Rubber_Company\", \"score\": 0.9966947269032297, \"rank\": 0.0033162341537524434, \"text\": \"Firestone\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Firestone_Tire_and_Rubber_Company\", \"dbpedia\": \"http://dbpedia.org/resource/Firestone_Tire_and_Rubber_Company\"}, {\"begin\": 2223, \"end\": 2230, \"title\": \"http://dbpedia.org/resource/Israel_Defense_Forces\", \"score\": 0.9994151979601216, \"rank\": 0.0003540009859393649, \"text\": \"Israeli\", \"types\": [\"Q43229\", \"Q24229398\", \"Q176799\"], \"wikid\": \"http://dbpedia.org/resource/Israel_Defense_Forces\", \"dbpedia\": \"http://dbpedia.org/resource/Israel_Defense_Forces\"}]}, {\"sentence\": \"\\\"In other words, the athlete literally placed the memory of the fallen on his head to honor them,\\\"Heraskevychsaid.\", \"from\": 2313, \"to\": 2427, \"entities\": []}, {\"sentence\": \"\\\"I honestly do not understand how these two cases are fundamentally different.\", \"from\": 2428, \"to\": 2506, \"entities\": []}, {\"sentence\": \"The IOC rules are the same for opening ceremonies, medal presentations, and competition venues.\", \"from\": 2507, \"to\": 2602, \"entities\": [{\"begin\": 2511, \"end\": 2514, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 9.145327158438215e-28, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}]}, {\"sentence\": \"Why such treatment towards Ukrainians?\\\"\", \"from\": 2603, \"to\": 2642, \"entities\": [{\"begin\": 2630, \"end\": 2640, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 1.0, \"rank\": 2.3146611921420163e-14, \"text\": \"Ukrainians\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Ukraine\"}]}, {\"sentence\": \"Oleksandr Syrskyi, commander in chief of Ukraine's Armed Forces, also expressed support for the athletes' tributes on social media.\", \"from\": 2644, \"to\": 2775, \"entities\": [{\"begin\": 2644, \"end\": 2661, \"title\": \"http://dbpedia.org/resource/Oleksandr_Syrskyi\", \"score\": 0.9999988339325205, \"rank\": 0.0, \"text\": \"Oleksandr Syrskyi\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Oleksandr_Syrskyi\", \"dbpedia\": \"http://dbpedia.org/resource/Oleksandr_Syrskyi\"}, {\"begin\": 2685, \"end\": 2692, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 1.0, \"rank\": 9.63387496619224e-20, \"text\": \"Ukraine\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Ukraine\"}]}, {\"sentence\": \"\\\"Remembrance is not a violation,\\\" hewroteabove a photo of Heraskevych's helmet.\", \"from\": 2777, \"to\": 2856, \"entities\": []}, {\"sentence\": \"Hundreds ofUkrainian athletes and coaches have been killedby Russia's all-out war, and hundreds of sports facilities have been destroyed by Russian missile and drone attacks.\", \"from\": 2858, \"to\": 3032, \"entities\": [{\"begin\": 2919, \"end\": 2925, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999999998644853, \"rank\": 1.355964882255244e-10, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}, {\"begin\": 2998, \"end\": 3005, \"title\": \"http://dbpedia.org/resource/Russian_Armed_Forces\", \"score\": 0.9999840481263105, \"rank\": 1.3950348287795484e-05, \"text\": \"Russian\", \"types\": [\"Q43229\", \"Q24229398\", \"Q176799\"], \"wikid\": \"http://dbpedia.org/resource/Russian_Armed_Forces\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_Armed_Forces\"}]}, {\"sentence\": \"While the Russian and Belarusian national teams are banned from the Olympic Games, athletes from both countries are allowed to compete in individual events under a \\\"neutral\\\" status.\", \"from\": 3034, \"to\": 3215, \"entities\": [{\"begin\": 3044, \"end\": 3051, \"title\": \"http://dbpedia.org/resource/Russian_Armed_Forces\", \"score\": 0.9999840481263105, \"rank\": 1.3950348287795484e-05, \"text\": \"Russian\", \"types\": [\"Q43229\", \"Q24229398\", \"Q176799\"], \"wikid\": \"http://dbpedia.org/resource/Russian_Armed_Forces\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_Armed_Forces\"}, {\"begin\": 3056, \"end\": 3066, \"title\": \"http://dbpedia.org/resource/Belarus\", \"score\": 1.0, \"rank\": 1.001974028313165e-13, \"text\": \"Belarusian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Belarus\", \"dbpedia\": \"http://dbpedia.org/resource/Belarus\"}]}, {\"sentence\": \"Still, many Russian athletes who compete as \\\"neutral\\\" participants in international competitions haveties to the Kremlinor have expressedsupport for the waragainst Ukraine.\", \"from\": 3216, \"to\": 3388, \"entities\": [{\"begin\": 3228, \"end\": 3235, \"title\": \"http://dbpedia.org/resource/Russian_Armed_Forces\", \"score\": 0.9999840481263105, \"rank\": 1.3950348287795484e-05, \"text\": \"Russian\", \"types\": [\"Q43229\", \"Q24229398\", \"Q176799\"], \"wikid\": \"http://dbpedia.org/resource/Russian_Armed_Forces\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_Armed_Forces\"}, {\"begin\": 3380, \"end\": 3387, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 1.0, \"rank\": 9.63387496619224e-20, \"text\": \"Ukraine\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Ukraine\"}]}, {\"sentence\": \"\\\"There are many provocations from Russia, from 'neutral' athletes,\\\" Handei said.\", \"from\": 3390, \"to\": 3470, \"entities\": [{\"begin\": 3424, \"end\": 3430, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999999998644853, \"rank\": 1.355964882255244e-10, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}]}, {\"sentence\": \"\\\"There are threats, certain manipulations, attempts to talk, to communicate.\\\"\", \"from\": 3471, \"to\": 3548, \"entities\": []}, {\"sentence\": \"Handei also expressed support for Heraskevych's memorial helmet and his public defiance of the IOC.\", \"from\": 3550, \"to\": 3649, \"entities\": [{\"begin\": 3645, \"end\": 3648, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 9.145327158438215e-28, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}]}, {\"sentence\": \"\\\"I hope he does not change his position and his words, because we have to fight.\", \"from\": 3651, \"to\": 3731, \"entities\": []}, {\"sentence\": \"And as long as we fight, we can win.\\\"\", \"from\": 3732, \"to\": 3769, \"entities\": []}, {\"sentence\": \"Senior News Editor  Abbey Fenbert is a senior news editor at the Kyiv Independent.\", \"from\": 3771, \"to