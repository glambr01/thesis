"{\"uid\": \"nbcsports.com-olympics-news-max-whitlock-retire-gymnastics-olympics-paris\", \"entities\": [{\"sentence\": \"Max Whitlock, the first and so far only British gymnast to win an Olympic gold medal, plans to make Paris his fourth and final Games, should he make the team.\", \"from\": 0, \"to\": 158, \"entities\": [{\"begin\": 0, \"end\": 12, \"title\": \"http://dbpedia.org/resource/Max_Whitlock\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Max Whitlock\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Max_Whitlock\", \"dbpedia\": \"http://dbpedia.org/resource/Max_Whitlock\"}, {\"begin\": 40, \"end\": 47, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9420843304787158, \"rank\": 0.03991847350808435, \"text\": \"British\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}, {\"begin\": 100, \"end\": 105, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999995962083825, \"rank\": 4.037932450051721e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}]}, {\"sentence\": \"\\\"I have decided that\\u2026 After a 24-year career, Paris will be my final Olympic Games,\\\"was posted on the 31-year-old Whitlock's social media.\", \"from\": 160, \"to\": 298, \"entities\": [{\"begin\": 206, \"end\": 211, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999995962083825, \"rank\": 4.037932450051721e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 274, \"end\": 282, \"title\": \"http://dbpedia.org/resource/Max_Whitlock\", \"score\": 1.0, \"rank\": 2.6858412762902847e-27, \"text\": \"Whitlock\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http: