"{\"uid\": \"kpcw.org-state-regional-2024-04-09-olympic-officials-visit-utah-to-tour-potential-2034-olympic-venues\", \"entities\": [{\"sentence\": \"The International Olympic Committee Future Host Commission is visiting sites in Salt Lake, Summit, Wasatch and Weber counties to check out potential 2034 Olympic venues.\", \"from\": 0, \"to\": 169, \"entities\": [{\"begin\": 4, \"end\": 35, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 99, \"end\": 106, \"title\": \"http://dbpedia.org/resource/Wasatch_Range\", \"score\": 1.0, \"rank\": 2.999795996697363e-17, \"text\": \"Wasatch\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Wasatch_Range\", \"dbpedia\": \"http://dbpedia.org/resource/Wasatch_Range\"}, {\"begin\": 111, \"end\": 116, \"title\": \"http://dbpedia.org/resource/Max_Weber\", \"score\": 0.9941977638504095, \"rank\": 0.002232739672012419, \"text\": \"Weber\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Max_Weber\", \"dbpedia\": \"http://dbpedia.org/resource/Max_Weber\"}]}, {\"sentence\": \"The trip begins Wednesday, April 10 in Salt Lake, moves to the Wasatch Back Thursday, April 11, hits northern Utah's Weber County Friday, April 12, and wraps up Saturday, April 13, back in Salt Lake.\", \"from\": 170, \"to\": 369, \"entities\": [{\"begin\": 280, \"end\": 284, \"title\": \"http://dbpedia.org/resource/Utah\", \"score\": 0.9999999997357918, \"rank\": 2.6266612673281294e-10, \"text\": \"Utah\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Utah\", \"dbpedia\": \"http://dbpedia.org/resource/Utah\"}, {\"begin\": 287, \"end\": 299, \"title\": \"http://dbpedia.org/resource/Weber_County,_Utah\", \"score\": 0.9999999999740794, \"rank\": 0.0, \"text\": \"Weber County\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Weber_County,_Utah\", \"dbpedia\": \"http://dbpedia.org/resource/Weber_County,_Utah\"}]}, {\"sentence\": \"First up on the tour, the University of Utah's Rice-Eccles Stadium followed by a ride on Utah Transit Authority's TRAX train to the Delta Center downtown.\", \"from\": 371, \"to\": 525, \"entities\": [{\"begin\": 460, \"end\": 482, \"title\": \"http://dbpedia.org/resource/Utah_Transit_Authority\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Utah Transit Authority\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Utah_Transit_Authority\", \"dbpedia\": \"http://dbpedia.org/resource/Utah_Transit_Authority\"}, {\"begin\": 503, \"end\": 515, \"title\": \"http://dbpedia.org/resource/Vivint_Arena\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Delta Center\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Vivint_Arena\", \"dbpedia\": \"http://dbpedia.org/resource/Vivint_Arena\"}]}, {\"sentence\": \"Tom Kelly, a spokesperson for Utah's Olympic Committee, said the 2002 Olympics were the catalyst for the construction of TRAX light rail and Frontrunner.\", \"from\": 527, \"to\": 680, \"entities\": [{\"begin\": 527, \"end\": 536, \"title\": \"http://dbpedia.org/resource/Tom_Kelly_(musician)\", \"score\": 0.799125854196736, \"rank\": 0.24283458829246402, \"text\": \"Tom Kelly\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tom_Kelly_(musician)\", \"dbpedia\": \"http://dbpedia.org/resource/Tom_Kelly_(musician)\"}, {\"begin\": 557, \"end\": 561, \"title\": \"http://dbpedia.org/resource/Utah\", \"score\": 0.9999999997357918, \"rank\": 2.6266612673281294e-10, \"text\": \"Utah\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Utah\", \"dbpedia\": \"http://dbpedia.org/resource/Utah\"}]}, {\"sentence\": \"Utah's bid committee wanted to showcase the rails to highlight the importance of transportation options and sustainability.\", \"from\": 681, \"to\": 804, \"entities\": [{\"begin\": 681, \"end\": 685, \"title\": \"http://dbpedia.org/resource/Utah\", \"score\": 0.9999999997357918, \"rank\": 2.6266612673281294e-10, \"text\": \"Utah\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Utah\", \"dbpedia\": \"http://dbpedia.org/resource/Utah\"}]}, {\"sentence\": \"\\\"Now that system is thriving, we have great light rail down in the valley.\", \"from\": 806, \"to\": 880, \"entities\": []}, {\"sentence\": \"We also have a great regional transportation network with Frontrunner,\\\" Kelly said.\", \"from\": 881, \"to\": 964, \"entities\": [{\"begin\": 953, \"end\": 958, \"title\": \"http://dbpedia.org/resource/Kelly_Osbourne\", \"score\": 0.9082126749789885, \"rank\": 0.10087057592064158, \"text\": \"Kelly\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kelly_Osbourne\", \"dbpedia\": \"http://dbpedia.org/resource/Kelly_Osbourne\"}]}, {\"sentence\": \"\\\"So we thought that we would give the IOC a little ride on a TRAX train.\\\"\", \"from\": 965, \"to\": 1038, \"entities\": [{\"begin\": 1003, \"end\": 1006, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.0954855241316807e-16, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}]}, {\"sentence\": \"Thursday, April 11, the commission starts with a forum on Utah's Olympic journey from 2002 to 2034.\", \"from\": 1040, \"to\": 1139, \"entities\": [{\"begin\": 1098, \"end\": 1102, \"title\": \"http://dbpedia.org/resource/Utah\", \"score\": 0.9999999997357918, \"rank\": 2.6266612673281294e-10, \"text\": \"Utah\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Utah\", \"dbpedia\": \"http://dbpedia.org/resource/Utah\"}]}, {\"sentence\": \"Next is the Wasatch Back for the Utah Olympic Park ski jumps and the 2002 Olympic Winter Games Museum.\", \"from\": 1140, \"to\": 1242, \"entities\": []}, {\"sentence\": \"The group ends the day touring Park City Mountain and Soldier Hollow.\", \"from\": 1243, \"to\": 1312, \"entities\": [{\"begin\": 1297, \"end\": 1311, \"title\": \"http://dbpedia.org/resource/Soldier_Hollow\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Soldier Hollow\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Soldier_Hollow\", \"dbpedia\": \"http://dbpedia.org/resource/Soldier_Hollow\"}]}, {\"sentence\": \"\\\"Down at Soldier Hollow in Midway, the IOC will have an opportunity to actually try the biathlon shooting range using laser rifles, so that should be a fun stop,\\\" Kelly said.\", \"from\": 1314, \"to\": 1488, \"entities\": [{\"begin\": 1341, \"end\": 1347, \"title\": \"http://dbpedia.org/resource/Midway_International_Airport\", \"score\": 0.9970185487871807, \"rank\": 0.002015325265509683, \"text\": \"Midway\", \"types\": [\"Q1248784\"], \"wikid\": \"http://dbpedia.org/resource/Midway_International_Airport\", \"dbpedia\": \"http://dbpedia.org/resource/Midway_International_Airport\"}, {\"begin\": 1353, \"end\": 1356, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.0954855241316807e-16, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 1477, \"end\": 1482, \"title\": \"http://dbpedia.org/resource/Kelly_Osbourne\", \"score\": 0.9082126749789885, \"rank\": 0.10087057592064158, \"text\": \"Kelly\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kelly_Osbourne\", \"dbpedia\": \"http://dbpedia.org/resource/Kelly_Osbourne\"}]}, {\"sentence\": \"Friday, April 12, starts in Weber County where the commission will ride Snowbasin's John Paul chairlift to see the men's and women's downhill tracks.\", \"from\": 1490, \"to\": 1639, \"entities\": [{\"begin\": 1518, \"end\": 1530, \"title\": \"http://dbpedia.org/resource/Weber_County,_Utah\", \"score\": 0.9999999724032026, \"rank\": 0.0, \"text\": \"Weber County\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Weber_County,_Utah\", \"dbpedia\": \"http://dbpedia.org/resource/Weber_County,_Utah\"}, {\"begin\": 1562, \"end\": 1571, \"title\": \"http://dbpedia.org/resource/Snowbasin\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Snowbasin\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Snowbasin\", \"dbpedia\": \"http://dbpedia.org/resource/Snowbasin\"}, {\"begin\": 1574, \"end\": 1583, \"title\": \"http://dbpedia.org/resource/John_Paul_McQueen\", \"score\": 0.9999953294088688, \"rank\": 4.670534650066903e-06, \"text\": \"John Paul\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/John_Paul_McQueen\", \"dbpedia\": \"http://dbpedia.org/resource/John_Paul_McQueen\"}]}, {\"sentence\": \"After that, it's the Utah Olympic Oval for skating facilities.\", \"from\": 1640, \"to\": 1702, \"entities\": []}, {\"sentence\": \"The visit ends Saturday, April 13, with a news conference in Salt Lake where the IOC future host commission and Utah's bid committee will share observations and discuss the venue options.\", \"from\": 1704, \"to\": 1891, \"entities\": [{\"begin\": 1785, \"end\": 1788, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.0954855241316807e-16, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 1816, \"end\": 1820, \"title\": \"http://dbpedia.org/resource/Utah\", \"score\": 0.9999999997357918, \"rank\": 2.6266612673281294e-10, \"text\": \"Utah\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Utah\", \"dbpedia\": \"http://dbpedia.org/resource/Utah\"}]}, {\"sentence\": \"Kelly noted this is more of a business discussion as Salt Lake City has already been selected as the preferred host for the 2034 Games and is the only official host being considered.\", \"from\": 1892, \"to\": 2074, \"entities\": [{\"begin\": 1892, \"end\": 1897, \"title\": \"http://dbpedia.org/resource/Kelly_Osbourne\", \"score\": 0.9082126749789885, \"rank\": 0.10087057592064158, \"text\": \"Kelly\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kelly_Osbourne\", \"dbpedia\": \"http://dbpedia.org/resource/Kelly_Osbourne\"}, {\"begin\": 1945, \"end\": 1959, \"title\": \"http://dbpedia.org/resource/Salt_Lake_City\", \"score\": 0.9375477686489586, \"rank\": 0.06661205684001548, \"text\": \"Salt Lake City\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Salt_Lake_City\", \"dbpedia\": \"http://dbpedia.org/resource/Salt_Lake_City\"}]}, {\"sentence\": \"The IOC will select a host for the 2034 Games on July 24 or Pioneer Day in Utah.\", \"from\": 2076, \"to\": 2156, \"entities\": [{\"begin\": 2080, \"end\": 2083, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.0954855241316807e-16, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 2151, \"end\": 2155, \"title\": \"http://dbpedia.org/resource/Utah\", \"score\": 0.9999999997357918, \"rank\": 2.6266612673281294e-10, \"text\": \"Utah\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Utah\", \"dbpedia\": \"http://dbpedia.org/resource/Utah\"}]}]}"