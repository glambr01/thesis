": [{\"begin\": 799, \"end\": 805, \"title\": \"http://dbpedia.org/resource/Canada\", \"score\": 0.9999999808405848, \"rank\": 1.7434258654545572e-08, \"text\": \"Canada\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Canada\", \"dbpedia\": \"http://dbpedia.org/resource/Canada\"}, {\"begin\": 824, \"end\": 828, \"title\": \"http://dbpedia.org/resource/Kate_Ramsay\", \"score\": 0.6843426161662595, \"rank\": 0.4612550932462213, \"text\": \"Kate\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Kate_Ramsay\", \"dbpedia\": \"http://dbpedia.org/resource/Kate_Ramsay\"}]}, {\"sentence\": \"China's Chen Yuxi and Quan Hongchan earned a dominant gold with a final score of 359.10 - beating the silver medal-winners by a whopping 43.2 points.\", \"from\": 1008, \"to\": 1157, \"entities\": [{\"begin\": 1008, \"end\": 1013, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.999151191802223, \"rank\": 0.0007547564626112277, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}, {\"begin\": 1016, \"end\": 1025, \"title\": \"http://dbpedia.org/resource/Chen_Yuxi\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Chen Yuxi\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Chen_Yuxi\", \"dbpedia\": \"http://dbpedia.org/resource/Chen_Yuxi\"}]}, {\"sentence\": \"North Korea's Kim Mi-Rae and Jo Jin-Mi won the silver with a score of 315.90, while the British nabbed bronze with 304.38.\", \"from\": 1158, \"to\": 1280, \"entities\": [{\"begin\": 1158, \"end\": 1169, \"title\": \"http://dbpedia.org/resource/North_Korea\", \"score\": 0.999995003252685, \"rank\": 4.996453059897078e-06, \"text\": \"North Korea\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/North_Korea\", \"dbpedia\": \"http://dbpedia.org/resource/North_Korea\"}, {\"begin\": 1172, \"end\": 1182, \"title\": \"