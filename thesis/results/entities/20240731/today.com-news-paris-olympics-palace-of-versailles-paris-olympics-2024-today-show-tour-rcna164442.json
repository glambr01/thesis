"{\"uid\": \"today.com-news-paris-olympics-palace-of-versailles-paris-olympics-2024-today-show-tour-rcna164442\", \"entities\": [{\"sentence\": \"A Michael Kors Bag, Suede Slippers and More Holiday Gifts at Walmart - Starting at $9    Drew Weisholtz  Athletes aremaking historyat the2024 Summer Olympics, while the TODAY crew is basking in history.\", \"from\": 0, \"to\": 202, \"entities\": [{\"begin\": 2, \"end\": 14, \"title\": \"http://dbpedia.org/resource/Michael_Kors\", \"score\": 0.999866404274431, \"rank\": 0.00013361357564786215, \"text\": \"Michael Kors\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Michael_Kors\", \"dbpedia\": \"http://dbpedia.org/resource/Michael_Kors\"}]}, {\"sentence\": \"TODAY's Savannah Guthrie, Hoda Kotb and Al Roker got to visit the Palace of Versailles and soak in its beauty and majesty.\", \"from\": 204, \"to\": 326, \"entities\": [{\"begin\": 212, \"end\": 228, \"title\": \"http://dbpedia.org/resource/Savannah_Guthrie\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Savannah Guthrie\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Savannah_Guthrie\", \"dbpedia\": \"http://dbpedia.org/resource/Savannah_Guthrie\"}, {\"begin\": 230, \"end\": 239, \"title\": \"http://dbpedia.org/resource/Hoda_Kotb\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Hoda Kotb\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Hoda_Kotb\", \"dbpedia\": \"http://dbpedia.org/resource/Hoda_Kotb\"}, {\"begin\": 244, \"end\": 252, \"title\": \"http://dbpedia.org/resource/Al_Roker\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Al Roker\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Al_Roker\", \"dbpedia\": \"http://dbpedia.org/resource/Al_Roker\"}]}, {\"sentence\": \"Located 10 miles outside of Paris, the Palace of Versailles was a hunting lodge that was transformed into a home for French royalty by Louis XIV in the 17th century.\", \"from\": 328, \"to\": 493, \"entities\": [{\"begin\": 356, \"end\": 361, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 2.110721645200387e-13, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 445, \"end\": 459, \"title\": \"http://dbpedia.org/resource/House_of_Orl\\u00e9ans\", \"score\": 0.9999940655414877, \"rank\": 0.0, \"text\": \"French royalty\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/House_of_Orl\\u00e9ans\", \"dbpedia\": \"http://dbpedia.org/resource/House_of_Orl\\u00e9ans\"}, {\"begin\": 463, \"end\": 472, \"title\": \"http://dbpedia.org/resource/Louis_XIV\", \"score\": 0.9469141558064142, \"rank\": 0.0560619383286327, \"text\": \"Louis XIV\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Louis_XIV\", \"dbpedia\": \"http://dbpedia.org/resource/Louis_XIV\"}]}, {\"sentence\": \"Kings and queens lived at Versailles for more than a century until the French Revolution did away with monarchy in France.\", \"from\": 494, \"to\": 616, \"entities\": [{\"begin\": 609, \"end\": 615, \"title\": \"http://dbpedia.org/resource/Kingdom_of_France\", \"score\": 0.6657388049774192, \"rank\": 0.44780288592098505, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Kingdom_of_France\", \"dbpedia\": \"http://dbpedia.org/resource/Kingdom_of_France\"}]}, {\"sentence\": \"\\\"Kings walked here right where we are walking.\", \"from\": 618, \"to\": 664, \"entities\": []}, {\"sentence\": \"Queens walked here right where we are walking,\\\" Hoda said in a segment that aired July 31, while she, Savannah and Al walked on the grounds outside.\", \"from\": 665, \"to\": 813, \"entities\": [{\"begin\": 713, \"end\": 717, \"title\": \"http://dbpedia.org/resource/Hoda_(given_name)\", \"score\": 0.5202438276363072, \"rank\": 0.6999999999999931, \"text\": \"Hoda\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Hoda_(given_name)\", \"dbpedia\": \"http://dbpedia.org/resource/Hoda_(given_name)\"}, {\"begin\": 767, \"end\": 775, \"title\": \"http://dbpedia.org/resource/Shawnee\", \"score\": 0.5506946106175558, \"rank\": 0.4049846963877253, \"text\": \"Savannah\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Shawnee\", \"dbpedia\": \"http://dbpedia.org/resource/Shawnee\"}]}, {\"sentence\": \"\\\"And now two more queens are walking - and a court jester,\\\" Al quipped about the trio.\", \"from\": 815, \"to\": 901, \"entities\": []}, {\"sentence\": \"The rooms are stunning, flush with gold and mirrors and paintings on the ceiling.\", \"from\": 903, \"to\": 984, \"entities\": []}, {\"sentence\": \"Marie Antoinette lived there, and her apartment blew away Savannah, Hoda and Al.\", \"from\": 985, \"to\": 1065, \"entities\": [{\"begin\": 985, \"end\": 1001, \"title\": \"http://dbpedia.org/resource/Marie_Antoinette\", \"score\": 1.0, \"rank\": 2.5306410623801376e-36, \"text\": \"Marie Antoinette\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Marie_Antoinette\", \"dbpedia\": \"http://dbpedia.org/resource/Marie_Antoinette\"}, {\"begin\": 1043, \"end\": 1051, \"title\": \"http://dbpedia.org/resource/Shawnee\", \"score\": 0.5506946106175558, \"rank\": 0.4049846963877253, \"text\": \"Savannah\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Shawnee\", \"dbpedia\": \"http://dbpedia.org/resource/Shawnee\"}, {\"begin\": 1053, \"end\": 1057, \"title\": \"http://dbpedia.org/resource/Hoda_(given_name)\", \"score\": 0.5202438276363072, \"rank\": 0.6999999999999931, \"text\": \"Hoda\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Hoda_(given_name)\", \"dbpedia\": \"http://dbpedia.org/resource/Hoda_(given_name)\"}]}, {\"sentence\": \"\\\"Oh, my!\\\"\", \"from\": 1067, \"to\": 1076, \"entities\": []}, {\"sentence\": \"Savannah and Hoda said in unison when seeing it.\", \"from\": 1077, \"to\": 1125, \"entities\": [{\"begin\": 1090, \"end\": 1094, \"title\": \"http://dbpedia.org/resource/Hoda_(given_name)\", \"score\": 0.5202438276363072, \"rank\": 0.6999999999999931, \"text\": \"Hoda\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Hoda_(given_name)\", \"dbpedia\": \"http://dbpedia.org/resource/Hoda_(given_name)\"}]}, {\"sentence\": \"\\\"That is insane,\\\" Hoda said while marveling at the canopy over the bed.\", \"from\": 1127, \"to\": 1198, \"entities\": [{\"begin\": 1145, \"end\": 1149, \"title\": \"http://dbpedia.org/resource/Hoda_(given_name)\", \"score\": 0.5202438276363072, \"rank\": 0.6999999999999931, \"text\": \"Hoda\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Hoda_(given_name)\", \"dbpedia\": \"http://dbpedia.org/resource/Hoda_(given_name)\"}]}, {\"sentence\": \"\\\"That's crazy,\\\" Al said.\", \"from\": 1200, \"to\": 1224, \"entities\": []}, {\"sentence\": \"A hall of mirrors accents the affluence of Versailles.\", \"from\": 1226, \"to\": 1280, \"entities\": []}, {\"sentence\": \"It's a long corridor filled with mirrors, which were a luxury hundreds of years ago.\", \"from\": 1281, \"to\": 1365, \"entities\": []}, {\"sentence\": \"\\\"This is incredible,\\\" Savannah said.\", \"from\": 1367, \"to\": 1403, \"entities\": [{\"begin\": 1389, \"end\": 1397, \"title\": \"http://dbpedia.org/resource/Shawnee\", \"score\": 0.5506946106175558, \"rank\": 0.4049846963877253, \"text\": \"Savannah\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Shawnee\", \"dbpedia\": \"http://dbpedia.org/resource/Shawnee\"}]}, {\"sentence\": \"\\\"Stunning.\", \"from\": 1405, \"to\": 1415, \"entities\": []}, {\"sentence\": \"Stunning,\\\" echoed Hoda.\", \"from\": 1416, \"to\": 1439, \"entities\": [{\"begin\": 1434, \"end\": 1438, \"title\": \"http://dbpedia.org/resource/Hoda_(given_name)\", \"score\": 0.5202438276363072, \"rank\": 0.6999999999999931, \"text\": \"Hoda\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Hoda_(given_name)\", \"dbpedia\": \"http://dbpedia.org/resource/Hoda_(given_name)\"}]}, {\"sentence\": \"Versailles director Laurent Salom\\u00e9 said the hall was not just decorative.\", \"from\": 1441, \"to\": 1514, \"entities\": [{\"begin\": 1469, \"end\": 1475, \"title\": \"http://dbpedia.org/resource/Salome\", \"score\": 1.0, \"rank\": 4.0378465701537096e-25, \"text\": \"Salom\\u00e9\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Salome\", \"dbpedia\": \"http://dbpedia.org/resource/Salome\"}]}, {\"sentence\": \"\\\"It was used mainly for diplomatic official events, sometimes for balls.\", \"from\": 1516, \"to\": 1588, \"entities\": []}, {\"sentence\": \"Everybody's come here.\", \"from\": 1589, \"to\": 1611, \"entities\": []}, {\"sentence\": \"All the artists, musicians, Mozart, everyone,\\\" he said.\", \"from\": 1612, \"to\": 1667, \"entities\": [{\"begin\": 1640, \"end\": 1646, \"title\": \"http://dbpedia.org/resource/Wolfgang_Amadeus_Mozart\", \"score\": 1.0, \"rank\": 1.1789751378552031e-27, \"text\": \"Mozart\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Wolfgang_Amadeus_Mozart\", \"dbpedia\": \"http://dbpedia.org/resource/Wolfgang_Amadeus_Mozart\"}]}, {\"sentence\": \"Salom\\u00e9 also said Versailles, which currently hosts the largest-ever art exhibition about horses, in honor of the Olympic equestrian venue there, is as large as it is opulent.\", \"from\": 1669, \"to\": 1843, \"entities\": [{\"begin\": 1669, \"end\": 1675, \"title\": \"http://dbpedia.org/resource/Salome\", \"score\": 1.0, \"rank\": 4.0378465701537096e-25, \"text\": \"Salom\\u00e9\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Salome\", \"dbpedia\": \"http://dbpedia.org/resource/Salome\"}, {\"begin\": 1686, \"end\": 1696, \"title\": \"http://dbpedia.org/resource/Palace_of_Versailles\", \"score\": 1.0, \"rank\": 6.839990326100189e-23, \"text\": \"Versailles\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Palace_of_Versailles\", \"dbpedia\": \"http://dbpedia.org/resource/Palace_of_Versailles\"}]}, {\"sentence\": \"\\\"Altogether it's 2,300 rooms.\", \"from\": 1845, \"to\": 1874, \"entities\": []}, {\"sentence\": \"I have been here seven years, and I am not sure I have seen all the rooms,\\\" he said.\", \"from\": 1875, \"to\": 1959, \"entities\": []}, {\"sentence\": \"Savannah, Hoda and Al were also given a key to open a door to a chapel, which Salom\\u00e9 helped them access.\", \"from\": 1961, \"to\": 2065, \"entities\": [{\"begin\": 1971, \"end\": 1975, \"title\": \"http://dbpedia.org/resource/Hoda_(given_name)\", \"score\": 0.5202438276363072, \"rank\": 0.6999999999999931, \"text\": \"Hoda\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Hoda_(given_name)\", \"dbpedia\": \"http://dbpedia.org/resource/Hoda_(given_name)\"}, {\"begin\": 2039, \"end\": 2045, \"title\": \"http://dbpedia.org/resource/Salome\", \"score\": 1.0, \"rank\": 4.0378465701537096e-25, \"text\": \"Salom\\u00e9\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Salome\", \"dbpedia\": \"http://dbpedia.org/resource/Salome\"}]}, {\"sentence\": \"\\\"It's beautiful,\\\" Savannah said when they walked in, while Al noticed\\u00a0the light beaming through.\", \"from\": 2067, \"to\": 2163, \"entities\": [{\"begin\": 2085, \"end\": 2093, \"title\": \"http://dbpedia.org/resource/Shawnee\", \"score\": 0.5506946106175558, \"rank\": 0.4049846963877253, \"text\": \"Savannah\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Shawnee\", \"dbpedia\": \"http://dbpedia.org/resource/Shawnee\"}]}, {\"sentence\": \"\\\"It's one of the most beautiful chapels in France, and probably in the world,\\\" Salom\\u00e9 said.\", \"from\": 2165, \"to\": 2256, \"entities\": [{\"begin\": 2208, \"end\": 2214, \"title\": \"http://dbpedia.org/resource/Kingdom_of_France\", \"score\": 0.6657388049774192, \"rank\": 0.44780288592098505, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Kingdom_of_France\", \"dbpedia\": \"http://dbpedia.org/resource/Kingdom_of_France\"}, {\"begin\": 2244, \"end\": 2250, \"title\": \"http://dbpedia.org/resource/Salome\", \"score\": 1.0, \"rank\": 4.0378465701537096e-25, \"text\": \"Salom\\u00e9\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Salome\", \"dbpedia\": \"http://dbpedia.org/resource/Salome\"}]}, {\"sentence\": \"Salom\\u00e9 then gave the TODAY trio another thrill when he let them open a window, \\\"which is something you normally do not do,\\\" he said.\", \"from\": 2258, \"to\": 2390, \"entities\": []}, {\"sentence\": \"\\\"No one's allowed to do this.\\\"\", \"from\": 2391, \"to\": 2421, \"entities\": []}, {\"sentence\": \"He let the TODAY crew open the door, giving them the opportunity to do something one very big name was not allowed to do during a recent visit.\", \"from\": 2423, \"to\": 2566, \"entities\": []}, {\"sentence\": \"\\\"Even the king of England recently,Charles III, we thought it was not appropriate to open that door.\", \"from\": 2568, \"to\": 2668, \"entities\": [{\"begin\": 2586, \"end\": 2593, \"title\": \"http://dbpedia.org/resource/England\", \"score\": 0.9295114804561028, \"rank\": 0.07575837948079729, \"text\": \"England\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/England\", \"dbpedia\": \"http://dbpedia.org/resource/England\"}]}, {\"sentence\": \"But I do not know.\", \"from\": 2669, \"to\": 2687, \"entities\": []}, {\"sentence\": \"Today is a special day.\", \"from\": 2688, \"to\": 2711, \"entities\": []}, {\"sentence\": \"The weather is nice.\", \"from\": 2712, \"to\": 2732, \"entities\": []}, {\"sentence\": \"You have the Olympics,\\\" he said.\", \"from\": 2733, \"to\": 2765, \"entities\": []}, {\"sentence\": \"Salom\\u00e9 pulled open the giant window and invited them to step out onto a balcony.\", \"from\": 2767, \"to\": 2847, \"entities\": [{\"begin\": 2767, \"end\": 2773, \"title\": \"http://dbpedia.org/resource/Salome\", \"score\": 1.0, \"rank\": 4.0378465701537096e-25, \"text\": \"Salom\\u00e9\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Salome\", \"dbpedia\": \"http://dbpedia.org/resource/Salome\"}]}, {\"sentence\": \"\\\"This is so crazy,\\\" Al said.\", \"from\": 2849, \"to\": 2877, \"entities\": []}, {\"sentence\": \"\\\"This is so cool,\\\" Hoda said.\", \"from\": 2879, \"to\": 2908, \"entities\": [{\"begin\": 2898, \"end\": 2902, \"title\": \"http://dbpedia.org/resource/Hoda_(given_name)\", \"score\": 0.5202438276363072, \"rank\": 0.6999999999999931, \"text\": \"Hoda\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Hoda_(given_name)\", \"dbpedia\": \"http://dbpedia.org/resource/Hoda_(given_name)\"}]}, {\"sentence\": \"\\\"Laurent, you have given us a moment we will never forget our whole lives,\\\" Savannah said.\", \"from\": 2910, \"to\": 3000, \"entities\": [{\"begin\": 2986, \"end\": 2994, \"title\": \"http://dbpedia.org/resource/Shawnee\", \"score\": 0.5506946106175558, \"rank\": 0.4049846963877253, \"text\": \"Savannah\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Shawnee\", \"dbpedia\": \"http://dbpedia.org/resource/Shawnee\"}]}, {\"sentence\": \"Drew Weisholtz is a reporter for TODAY Digital, focusing on pop culture, nostalgia and trending stories.\", \"from\": 3002, \"to\": 3106, \"entities\": []}, {\"sentence\": \"He has seen every episode of \\\"Saved by the Bell\\\" at least 50 times, longs to perfect the crane kick from \\\"The Karate Kid\\\" and performs stand-up comedy, while also cheering on the New York Yankees and New York Giants.\", \"from\": 3107, \"to\": 3323, \"entities\": [{\"begin\": 3295, \"end\": 3302, \"title\": \"http://dbpedia.org/resource/New_York_Yankees\", \"score\": 0.9416574015892628, \"rank\": 0.061932701612422626, \"text\": \"Yankees\", \"types\": [\"Q43229\", \"Q24