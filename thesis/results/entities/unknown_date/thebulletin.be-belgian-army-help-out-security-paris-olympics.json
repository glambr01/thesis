"{\"uid\": \"thebulletin.be-belgian-army-help-out-security-paris-olympics\", \"entities\": [{\"sentence\": \"The Belgian army will participate in the protection and security of the Paris Olympic Games this summer, according to the country's defence minister Ludivine Dedonder.\", \"from\": 0, \"to\": 167, \"entities\": [{\"begin\": 4, \"end\": 16, \"title\": \"http://dbpedia.org/resource/Belgian_Land_Component\", \"score\": 0.9486618674824473, \"rank\": 0.05411636566966736, \"text\": \"Belgian army\", \"types\": [\"Q43229\", \"Q24229398\", \"Q176799\"], \"wikid\": \"http://dbpedia.org/resource/Belgian_Land_Component\", \"dbpedia\": \"http://dbpedia.org/resource/Belgian_Land_Component\"}, {\"begin\": 149, \"end\": 166, \"title\": \"http://dbpedia.org/resource/Ludivine_Dedonder\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Ludivine Dedonder\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Ludivine_Dedonder\", \"dbpedia\": \"http://dbpedia.org/resource/Ludivine_Dedonder\"}]}, {\"sentence\": \"The number of troops that will be sent to France has not yet been confirmed, but Dedonder said the defence department has \\\"studied participation and concluded that a contribution can be envisaged as part of the 2024 Operations Plan\\\".\", \"from\": 169, \"to\": 402, \"entities\": [{\"begin\": 211, \"end\": 217, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9999053783567794, \"rank\": 5.526077957708129e-05, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 268, \"end\": 286, \"title\": \"http://dbpedia.org/resource/United_States_Department_of_Defense\", \"score\": 0.9999999469913533, \"rank\": 4.5328274563315796e-08, \"text\": \"defence department\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_States_Department_of_Defense\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_Department_of_Defense\"}]}, {\"sentence\": \"The Belgian soldiers would be called upon to carry out missions \\\"in the field of searching for and neutralising explosive devices\\\".\", \"from\": 404, \"to\": 535, \"entities\": [{\"begin\": 408, \"end\": 415, \"title\": \"http://dbpedia.org/resource/Belgium\", \"score\": 0.9998924256085436, \"rank\": 0.00010594580861402345, \"text\": \"Belgian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Belgium\", \"dbpedia\": \"http://dbpedia.org/resource/Belgium\"}]}, {\"sentence\": \"\\\"It's recognised that Belgian Defence has expertise in this field, and is regularly called upon for international interventions,\\\" said Dedonder.\", \"from\": 537, \"to\": 681, \"entities\": [{\"begin\": 559, \"end\": 574, \"title\": \"http://dbpedia.org/resource/Belgian_Armed_Forces\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Belgian Defence\", \"types\": [\"Q43229\", \"Q24229398\", \"Q176799\"], \"wikid\": \"http://dbpedia.org/resource/Belgian_Armed_Forces\", \"dbpedia\": \"http://dbpedia.org/resource/Belgian_Armed_Forces\"}]}, {\"sentence\": \"While the duration of the mission has not yet been specified, the Paris Olympic Games will run from 26 July to 11 August, followed by the Paralympic Games from 28 August to 8 September.\", \"from\": 683, \"to\": 868, \"entities\": []}, {\"sentence\": \"\\u00a9 1962-2020 The Bulletin\", \"from\": 870, \"to\": 894, \"entities\": []}]}"