\"wikid\": \"http://dbpedia.org/resource/Nigeria\", \"dbpedia\": \"http://dbpedia.org/resource/Nigeria\"}, {\"begin\": 3622, \"end\": 3638, \"title\": \"http://dbpedia.org/resource/Defence_minister\", \"score\": 0.9999999999990905, \"rank\": 7.997080727230313e-13, \"text\": \"Defence Minister\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Defence_minister\", \"dbpedia\": \"http://dbpedia.org/resource/Defence_minister\"}, {\"begin\": 3701, \"end\": 3710, \"title\": \"http://dbpedia.org/resource/WordPress\", \"score\": 0.9999993208550709, \"rank\": 6.791454427625038e-07, \"text\": \"WordPress\", \"types\": [\"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/WordPress\", \"dbpedia\": \"http://dbpedia.org/resource/WordPress\"}]}]}"