, \"from\": 7016, \"to\": 7132, \"entities\": []}, {\"sentence\": \"I do not want players who want to be the best in the world, I want players who want to win the World Cup,\\\" Ancelotti said.\", \"from\": 7133, \"to\": 7255, \"entities\": [{\"begin\": 7240, \"end\": 7249, \"title\": \"http://dbpedia.org/resource/Carlo_Ancelotti\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Ancelotti\", \"types\": [\"Q729\", \"Q628099\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Carlo_Ancelotti\", \"dbpedia\": \"http://dbpedia.org/resource/Carlo_Ancelotti\"}]}, {\"sentence\": \"Asked about his team's group, Ancelotti said Brazil can top it.\", \"from\": 7257, \"to\": 7320, \"entities\": [{\"begin\": 7287, \"end\": 7296, \"title\": \"http://dbpedia.org/resource/Carlo_Ancelotti\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Ancelotti\", \"types\": [\"Q729\", \"Q628099\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Carlo_Ancelotti\", \"dbpedia\": \"http://dbpedia.org/resource/Carlo_Ancelotti\"}, {\"begin\": 7302, \"end\": 7308, \"title\": \"http://dbpedia.org/resource/Brazil_national_football_team\", \"score\": 1.0, \"rank\": 1.1960583633259837e-22, \"text\": \"Brazil\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Brazil_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Brazil_national_football_team\"}]}, {\"sentence\": \"\\\"We can win all three matches, our idea is very clear.\", \"from\": 7322, \"to\": 7376, \"entities\": []}, {\"sentence\": \"We need to be competitive during the entire World Cup.\", \"from\": 7377, \"to\": 7431, \"entities\": []}, {\"sentence\": \"Our goal is to play in the final and for that to happen you need to face very strong teams anyway.\\\"\", \"from\": 7432, \"to\": 7531, \"entities\": []}, {\"sentence\": \"Brazil won the last of its five World Cup trophies in 2002.\", \"from\": 7533, \"to\": 7592, \"entities\": [{\"begin\": 