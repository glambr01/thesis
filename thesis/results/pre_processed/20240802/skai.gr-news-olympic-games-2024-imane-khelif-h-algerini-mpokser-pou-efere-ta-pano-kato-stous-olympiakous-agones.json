03b1\\u03b9\\u03c1\\u03bf \\u03b1\\u03c0\\u03cc \\u03c4\\u03b7\\u03bd \\u03c0\\u03c5\\u03b3\\u03bc\\u03b1\\u03c7\\u03af\\u03b1. \\u03a9\\u03c3\\u03c4\\u03cc\\u03c3\\u03bf, \\u03ae\\u03bc\\u03bf\\u03c5\\u03bd \\u03ba\\u03b1\\u03bb\\u03ae \\u03c3\\u03c4\\u03bf\\u03bd \\u03b1\\u03b8\\u03bb\\u03b7\\u03c4\\u03b9\\u03c3\\u03bc\\u03cc \\u03c3\\u03c4\\u03bf \\u03c3\\u03c7\\u03bf\\u03bb\\u03b5\\u03af\\u03bf \\u03bc\\u03bf\\u03c5 \\u03ba\\u03b1\\u03b9 \\u03bf \\u03b4\\u03ac\\u03c3\\u03ba\\u03b1\\u03bb\\u03cc\\u03c2 \\u03bc\\u03bf\\u03c5 \\u03bc\\u03b5 \\u03b5\\u03bd\\u03b8\\u03ac\\u03c1\\u03c1\\u03c5\\u03bd\\u03b5 \\u03bd\\u03b1 \\u03b3\\u03af\\u03bd\\u03c9 \\u03c0\\u03c5\\u03b3\\u03bc\\u03ac\\u03c7\\u03bf\\u03c2, \\u03bb\\u03cc\\u03b3\\u03c9 \\u03c4\\u03c9\\u03bd \\u03c3\\u03c9\\u03bc\\u03b1\\u03c4\\u03b9\\u03ba\\u03ce\\u03bd \\u03bc\\u03bf\\u03c5 \\u03c0\\u03c1\\u03bf\\u03c3\\u03cc\\u03bd\\u03c4\\u03c9\\u03bd\\u00bb, \\u03b5\\u03be\\u03ae\\u03b3\\u03b7\\u03c3\\u03b5. \\u0397 \\u039a\\u03b1\\u03bb\\u03af\\u03c6 \\u03b5\\u03c1\\u03c9\\u03c4\\u03b5\\u03cd\\u03c4\\u03b7\\u03ba\\u03b5 \\u03c4\\u03b7\\u03bd \\u03c0\\u03c5\\u03b3\\u03bc\\u03b1\\u03c7\\u03af\\u03b1 \\u03bc\\u03cc\\u03bb\\u03b9\\u03c2 \\u03bc\\u03c0\\u03ae\\u03ba\\u03b5 \\u03b3\\u03b9\\u03b1 \\u03c0\\u03c1\\u03ce\\u03c4\\u03b7 \\u03c6\\u03bf\\u03c1\\u03ac \\u03c3\\u03c4\\u03bf \\u03c1\\u03b9\\u03bd\\u03b3\\u03ba, \\u03cc\\u03c0\\u03c9\\u03c2 \\u03bb\\u03ad\\u03b5\\u03b9.    \\u03a0\\u03b5\\u03c1\\u03b9\\u03ad\\u03b3\\u03c1\\u03b1\\u03c8\\u03b5 \\u03c4\\u03b7\\u03bd \\u03c0\\u03b1\\u03b9\\u03b4\\u03b9\\u03ba\\u03ae \\u03c4\\u03b7\\u03c2 \\u03b7\\u03bb\\u03b9\\u03ba\\u03af\\u03b1 \\u03c9\\u03c2 \\u00ab\\u03c0\\u03c1\\u03b1\\u03b3\\u03bc\\u03b1\\u03c4\\u03b9\\u03ba\\u03ac \\u03b4\\u03cd\\u03c3\\u03ba\\u03bf\\u03bb\\u03b7\\u00bb, \\u03b5\\u03bd\\u03ce \\u03bc\\u03af\\u03bb\\u03b7\\u03c3\\u03b5, \\u03b5\\u03c0\\u03af\\u03c3\\u03b7\\u03c2, \\u03b3\\u03b9\\u03b1 \\u03c4\\u03bf \\u03b3\\u03b5\\u03b3\\u03bf\\u03bd\\u03cc\\u0