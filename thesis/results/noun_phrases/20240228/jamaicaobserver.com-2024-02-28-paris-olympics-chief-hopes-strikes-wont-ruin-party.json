: [{\"begin\": 679, \"end\": 685, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9825228533264931, \"rank\": 0.0067360356484963725, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"Trade unions\", \"from\": 638, \"to\": 650}, {\"ngram\": \"workers\", \"from\": 664, \"to\": 671}, {\"ngram\": \"bonuses\", \"from\": 726, \"to\": 733}, {\"ngram\": \"extra resources\", \"from\": 738, \"to\": 753}, {\"ngram\": \"their members\", \"from\": 758, \"to\": 771}, {\"ngram\": \"the summer holidays\", \"from\": 802, \"to\": 821}, {\"ngram\": \"the Games\", \"from\": 829, \"to\": 838}]}, {\"sentence\": \"Police officers and air traffic controllers have already agreed deals, but Paris metro employees, health workers, railways staff and street cleaners among others are staking demands.\", \"from\": 841, \"to\": 1023, \"entities\": [{\"begin\": 916, \"end\": 921, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999966883024, \"rank\": 3.3115998301391494e-09, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Police officers\", \"from\": 841, \"to\": 856}, {\"ngram\": \"air traffic controllers\", \"from\": 861, \"to\": 884}, {\"ngram\": \"deals\", \"from\": 905, \"to\": 910}, {\"ngram\": \"health workers\", \"from\": 939, \"to\": 953}, {\"ngram\": \"railways staff\", \"from\": 955, \"to\": 969}, {\"ngram\": \"street cleaners\", \"from\": 974, \"to\": 989}, {\"ngram\": \"others\", \"from\": 996, \"to\": 1002}, {\"ngram\": \"demands\", \"from\": 1015, \"to\": 1022}]}, {\"sentence\": \"Senior hard-left MP Mathilde Panot has encouraged unions to use the Games to secure pay hikes to compensate for increases in the cost of living due to inflation.\", \"from\": 1025, \"to\": 1186, \"entities\"