"{\"uid\": \"jamaicaobserver.com-2024-02-28-paris-olympics-chief-hopes-strikes-wont-ruin-party\", \"noun_phrases\": [{\"sentence\": \"PARIS (AFP) - The chief organiser of the Paris Olympics said on Wednesday he hoped trade unions would not \\\"ruin the party\\\" by calling strikes during the Games amid ongoing threats of industrial action.\", \"from\": 0, \"to\": 201, \"entities\": [{\"begin\": 41, \"end\": 55, \"title\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Paris Olympics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/1924_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"PARIS\", \"from\": 0, \"to\": 5}, {\"ngram\": \"(AFP\", \"from\": 6, \"to\": 10}, {\"ngram\": \"The chief organiser\", \"from\": 14, \"to\": 33}, {\"ngram\": \"Wednesday\", \"from\": 64, \"to\": 73}, {\"ngram\": \"trade unions\", \"from\": 83, \"to\": 95}, {\"ngram\": \"the party\", \"from\": 112, \"to\": 121}, {\"ngram\": \"strikes\", \"from\": 134, \"to\": 141}, {\"ngram\": \"the Games\", \"from\": 149, \"to\": 158}, {\"ngram\": \"ongoing threats\", \"from\": 164, \"to\": 179}, {\"ngram\": \"industrial action\", \"from\": 183, \"to\": 200}]}, {\"sentence\": \"Tony Estanguet, head of the Paris organising committee, said he was hoping for a \\\"social ceasefire\\\" during the Games which begin on July 26.\", \"from\": 203, \"to\": 343, \"entities\": [{\"begin\": 203, \"end\": 217, \"title\": \"http://dbpedia.org/resource/Tony_Estanguet\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Tony Estanguet\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Tony_Estanguet\", \"dbpedia\": \"http://dbpedia.org/resource/Tony_Estanguet\"}, {\"begin\": 231, \"end\": 236, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999966883024, \"rank\": 3.3115998301391494e-09, \"text\": \"Paris\", \"types\"