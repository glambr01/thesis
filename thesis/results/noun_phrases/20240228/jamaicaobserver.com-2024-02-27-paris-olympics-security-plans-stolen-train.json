"{\"uid\": \"jamaicaobserver.com-2024-02-27-paris-olympics-security-plans-stolen-train\", \"noun_phrases\": [{\"sentence\": \"PARIS, France (AFP)- A bag containing a computer and two USB memory sticks holding police security plans for the Paris Olympic Games was stolen on Monday evening from a train at the capital's Gare du Nord station, police sources said Tuesday.\", \"from\": 0, \"to\": 242, \"entities\": [{\"begin\": 7, \"end\": 13, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9973032413496552, \"rank\": 0.001818327329636057, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 57, \"end\": 60, \"title\": \"http://dbpedia.org/resource/USB_flash_drive\", \"score\": 0.918244806805253, \"rank\": 0.08902977239311986, \"text\": \"USB\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/USB_flash_drive\", \"dbpedia\": \"http://dbpedia.org/resource/USB_flash_drive\"}], \"noun_phrases\": [{\"ngram\": \"PARIS\", \"from\": 0, \"to\": 5}, {\"ngram\": \"A bag\", \"from\": 21, \"to\": 26}, {\"ngram\": \"a computer\", \"from\": 38, \"to\": 48}, {\"ngram\": \"police security plans\", \"from\": 83, \"to\": 104}, {\"ngram\": \"the Paris Olympic Games\", \"from\": 109, \"to\": 132}, {\"ngram\": \"Monday evening\", \"from\": 147, \"to\": 161}, {\"ngram\": \"a train\", \"from\": 167, \"to\": 174}, {\"ngram\": \"the capital's Gare du Nord station\", \"from\": 178, \"to\": 212}, {\"ngram\": \"police sources\", \"from\": 214, \"to\": 228}]}, {\"sentence\": \"The bag belonged to an engineer from Paris City Hall, the police said, confirming a report by BFM television, adding that he had put the bag in the luggage compartment above his seat.\", \"from\": 244, \"to\": 427, \"entities\": [{\"begin\": 338, \"end\": 341, \"title\": \"http://dbpedia.org/resource/BFM_TV\", \"score\": 0.7736235665918377, \"rank\": 0.29063548026758373, \"text\": \"BFM\", \"types\