"{\"uid\": \"themoscowtimes.com-2024-07-28-russia-says-journalists-stripped-of-olympic-accreditation-a85856\", \"noun_phrases\": [{\"sentence\": \"Russia's TASS state news agency said Sunday the Paris Olympics organizing committee had stripped four of its journalists of accreditation to cover the Games after they attended initial events.\", \"from\": 0, \"to\": 192, \"entities\": [{\"begin\": 0, \"end\": 6, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999981683466507, \"rank\": 1.4582519987317226e-06, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}, {\"begin\": 9, \"end\": 13, \"title\": \"http://dbpedia.org/resource/TASS\", \"score\": 1.0, \"rank\": 2.418066859589922e-36, \"text\": \"TASS\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/TASS\", \"dbpedia\": \"http://dbpedia.org/resource/TASS\"}], \"noun_phrases\": [{\"ngram\": \"the Paris Olympics\", \"from\": 44, \"to\": 62}, {\"ngram\": \"organizing committee\", \"from\": 63, \"to\": 83}, {\"ngram\": \"its journalists\", \"from\": 105, \"to\": 120}, {\"ngram\": \"accreditation\", \"from\": 124, \"to\": 137}, {\"ngram\": \"the Games\", \"from\": 147, \"to\": 156}, {\"ngram\": \"initial events\", \"from\": 177, \"to\": 191}]}, {\"sentence\": \"TASS said that the removal of the reporters' accreditation, essential to cover the Games, was \\\"completely unexpected\\\" after the journalists had entered France, received passes and attended the opening and several events.\", \"from\": 194, \"to\": 414, \"entities\": [{\"begin\": 194, \"end\": 198, \"title\": \"http://dbpedia.org/resource/TASS\", \"score\": 1.0, \"rank\": 2.418066859589922e-36, \"text\": \"TASS\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/TASS\", \"dbpedia\": \"http://dbpedia.org/resource/TASS\"}, {\"begin\": 346, \"end\": 352, \"title\": \"http://dbpedia.org/resource/French_Third_Republic\", \"score\": 0.753526565555699, \"rank\": 0.28936072576695765, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/French_Third_Republic\", \"dbpedia\": \"http://dbpedia.org/resource/French_Third_Republic\"}], \"noun_phrases\": [{\"ngram\": \"the removal\", \"from\": 209, \"to\": 220}, {\"ngram\": \"the reporters' accreditation\", \"from\": 224, \"to\": 252}, {\"ngram\": \"the Games\", \"from\": 273, \"to\": 282}, {\"ngram\": \"the journalists\", \"from\": 318, \"to\": 333}, {\"ngram\": \"passes\", \"from\": 363, \"to\": 369}, {\"ngram\": \"the opening\", \"from\": 383, \"to\": 394}, {\"ngram\": \"several events\", \"from\": 399, \"to\": 413}]}, {\"sentence\": \"\\\"The Paris 2024 Organizing Committee... cited the decision of the authorities of France, but did not mention any concrete grievances and reasons for such a decision,\\\" the agency said in a statement.\", \"from\": 416, \"to\": 614, \"entities\": [{\"begin\": 497, \"end\": 503, \"title\": \"http://dbpedia.org/resource/French_Third_Republic\", \"score\": 0.753526565555699, \"rank\": 0.28936072576695765, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/French_Third_Republic\", \"dbpedia\": \"http://dbpedia.org/resource/French_Third_Republic\"}], \"noun_phrases\": [{\"ngram\": \"\\\"The Paris 2024 Organizing Committee\", \"from\": 416, \"to\": 452}, {\"ngram\": \"the decision\", \"from\": 462, \"to\": 474}, {\"ngram\": \"the authorities\", \"from\": 478, \"to\": 493}, {\"ngram\": \"any concrete grievances\", \"from\": 525, \"to\": 548}, {\"ngram\": \"reasons\", \"from\": 553, \"to\": 560}, {\"ngram\": \"such a decision\", \"from\": 565, \"to\": 580}, {\"ngram\": \"the agency\", \"from\": 583, \"to\": 593}, {\"ngram\": \"a statement\", \"from\": 602, \"to\": 613}]}, {\"sentence\": \"One of the journalists, Artyom Kuznetsov, was covering his seventh Olympics, TASS said.\", \"from\": 616, \"to\": 703, \"entities\": [{\"begin\": 640, \"end\": 656, \"title\": \"http://dbpedia.org/resource/Artyom_Kuznetsov\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Artyom Kuznetsov\", \"types\": [\"Q847400\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Artyom_Kuznetsov\", \"dbpedia\": \"http://dbpedia.org/resource/Artyom_Kuznetsov\"}, {\"begin\": 693, \"end\": 697, \"title\": \"http://dbpedia.org/resource/TASS\", \"score\": 1.0, \"rank\": 2.418066859589922e-36, \"text\": \"TASS\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/TASS\", \"dbpedia\": \"http://dbpedia.org/resource/TASS\"}], \"noun_phrases\": [{\"ngram\": \"the journalists\", \"from\": 623, \"to\": 638}, {\"ngram\": \"his seventh Olympics\", \"from\": 671, \"to\": 691}]}, {\"sentence\": \"Contacted by AFP, the International Olympic Committee and the French Foreign Ministry did not immediately respond to requests for comment.\", \"from\": 705, \"to\": 843, \"entities\": [{\"begin\": 718, \"end\": 721, \"title\": \"http://dbpedia.org/resource/Agence_France-Presse\", \"score\": 1.0, \"rank\": 3.1256689345948224e-16, \"text\": \"AFP\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Agence_France-Presse\", \"dbpedia\": \"http://dbpedia.org/resource/Agence_France-Presse\"}, {\"begin\": 727, \"end\": 758, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 767, \"end\": 790, \"title\": \"http://dbpedia.org/resource/Ministry_for_Europe_and_Foreign_Affairs\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"French Foreign Ministry\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ministry_for_Europe_and_Foreign_Affairs\", \"dbpedia\": \"http://dbpedia.org/resource/Ministry_for_Europe_and_Foreign_Affairs\"}], \"noun_phrases\": [{\"ngram\": \"requests\", \"from\": 822, \"to\": 830}, {\"ngram\": \"comment\", \"from\": 835, \"to\": 842}]}, {\"sentence\": \"Earlier, some Russian journalists had accreditation requests denied, prompting Foreign Ministry spokeswoman Maria Zakharova to tell TASS that \\\"observing the rights of journalists and providing freedom of speech are just empty sounds for [President Emmanuel] Macron and his gang.\\\"\", \"from\": 845, \"to\": 1124, \"entities\": [{\"begin\": 924, \"end\": 940, \"title\": \"http://dbpedia.org/resource/Federal_Foreign_Office\", \"score\": 0.8214354370848955, \"rank\": 0.21616475797578075, \"text\": \"Foreign Ministry\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Federal_Foreign_Office\", \"dbpedia\": \"http://dbpedia.org/resource/Federal_Foreign_Office\"}, {\"begin\": 953, \"end\": 968, \"title\": \"http://dbpedia.org/resource/Maria_Zakharova\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Maria Zakharova\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Maria_Zakharova\", \"dbpedia\": \"http://dbpedia.org/resource/Maria_Zakharova\"}, {\"begin\": 977, \"end\": 981, \"title\": \"http://dbpedia.org/resource/TASS\", \"score\": 1.0, \"rank\": 2.418066859589922e-36, \"text\": \"TASS\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/TASS\", \"dbpedia\": \"http://dbpedia.org/resource/TASS\"}], \"noun_phrases\": [{\"ngram\": \"some Russian journalists\", \"from\": 854, \"to\": 878}, {\"ngram\": \"accreditation requests\", \"from\": 883, \"to\": 905}, {\"ngram\": \"the rights\", \"from\": 998, \"to\": 1008}, {\"ngram\": \"journalists\", \"from\": 1012, \"to\": 1023}, {\"ngram\": \"freedom\", \"from\": 1038, \"to\": 1045}, {\"ngram\": \"speech\", \"from\": 1049, \"to\": 1055}, {\"ngram\": \"empty sounds\", \"from\": 1065, \"to\": 1077}, {\"ngram\": \"[President Emmanuel\", \"from\": 1082, \"to\": 1101}, {\"ngram\": \"Macron\", \"from\": 1103, \"to\": 1109}, {\"ngram\": \"his gang\", \"from\": 1114, \"to\": 1122}]}, {\"sentence\": \"Just 15 Russian athletes have been accredited to compete at the Olympics as neutrals as most sports have banned Russians and their allies in response to Moscow's military operation in Ukraine.\", \"from\": 1126, \"to\": 1318, \"entities\": [{\"begin\": 1238, \"end\": 1246, \"title\": \"http://dbpedia.org/resource/Russians\", \"score\": 0.9256996839851892, \"rank\": 0.08026284502373299, \"text\": \"Russians\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Russians\", \"dbpedia\": \"http://dbpedia.org/resource/Russians\"}, {\"begin\": 1279, \"end\": 1285, \"title\": \"http://dbpedia.org/resource/Moscow\", \"score\": 0.9999999999974989, \"rank\": 2.380011676126187e-12, \"text\": \"Moscow\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Moscow\", \"dbpedia\": \"http://dbpedia.org/resource/Moscow\"}, {\"begin\": 1310, \"end\": 1317, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 0.9945152366985532, \"rank\": 0.0055150107756903955, \"text\": \"Ukraine\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Ukraine\"}], \"noun_phrases\": [{\"ngram\": \"Just 15 Russian athletes\", \"from\": 1126, \"to\": 1150}, {\"ngram\": \"the Olympics\", \"from\": 1186, \"to\": 1198}, {\"ngram\": \"neutrals\", \"from\": 1202, \"to\": 1210}, {\"ngram\": \"most sports\", \"from\": 1214, \"to\": 1225}, {\"ngram\": \"their allies\", \"from\": 1251, \"to\": 1263}, {\"ngram\": \"response\", \"from\": 1267, \"to\": 1275}]}, {\"sentence\": \"A few days before the opening of the Games, French police arrested a Russian man suspected of plotting acts of \\\"destabilization\\\" during the Paris Olympics.\", \"from\": 1320, \"to\": 1475, \"entities\": [{\"begin\": 1364, \"end\": 1377, \"title\": \"http://dbpedia.org/resource/Law_enforcement_in_France\", \"score\": 1.0, \"rank\": 7.495358170577632e-37, \"text\": \"French police\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Law_enforcement_in_France\", \"dbpedia\": \"http://dbpedia.org/resource/Law_enforcement_in_France\"}], \"noun_phrases\": [{\"ngram\": \"the opening\", \"from\": 1338, \"to\": 1349}, {\"ngram\": \"the Games\", \"from\": 1353, \"to\": 1362}, {\"ngram\": \"a Russian man\", \"from\": 1387, \"to\": 1400}, {\"ngram\": \"acts\", \"from\": 1423, \"to\": 1427}, {\"ngram\": \"\\\"destabilization\", \"from\": 1431, \"to\": 1447}, {\"ngram\": \"the Paris Olympics\", \"from\": 1456, \"to\": 1474}]}, {\"sentence\": \"French prosecutors said the man, born in 1984, was suspected of \\\"passing intelligence to a foreign power in order to arouse hostilities in France,\\\" a charge punishable by up to 30 years in prison.\", \"from\": 1477, \"to\": 1673, \"entities\": [{\"begin\": 1477, \"end\": 1483, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9859462859366447, \"rank\": 0.00953959501190289, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 1616, \"end\": 1622, \"title\": \"http://dbpedia.org/resource/French_Third_Republic\", \"score\": 0.753526565555699, \"rank\": 0.28936072576695765, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/French_Third_Republic\", \"dbpedia\": \"http://dbpedia.org/resource/French_Third_Republic\"}], \"noun_phrases\": [{\"ngram\": \"the man\", \"from\": 1501, \"to\": 1508}, {\"ngram\": \"intelligence\", \"from\": 1550, \"to\": 1562}, {\"ngram\": \"a foreign power\", \"from\": 1566, \"to\": 1581}, {\"ngram\": \"order\", \"from\": 1585, \"to\": 1590}, {\"ngram\": \"hostilities\", \"from\": 1601, \"to\": 1612}, {\"ngram\": \"a charge\", \"from\": 1625, \"to\": 1633}, {\"ngram\": \"up to 30 years\", \"from\": 1648, \"to\": 1662}, {\"ngram\": \"prison\", \"from\": 1666, \"to\": 1672}]}, {\"sentence\": \"Le Monde and other media named the suspect as Kirill Gryaznov, a chef originally from the city of Perm in the Urals.\", \"from\": 1675, \"to\": 1791, \"entities\": [{\"begin\": 1721, \"end\": 1727, \"title\": \"http://dbpedia.org/resource/Patriarch_Kirill_of_Moscow\", \"score\": 0.999999999891088, \"rank\": 1.0896361034523619e-10, \"text\": \"Kirill\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Patriarch_Kirill_of_Moscow\", \"dbpedia\": \"http://dbpedia.org/resource/Patriarch_Kirill_of_Moscow\"}, {\"begin\": 1773, \"end\": 1777, \"title\": \"http://dbpedia.org/resource/Perm_Oblast\", \"score\": 0.9886754388736951, \"rank\": 0.011270521083858476, \"text\": \"Perm\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Perm_Oblast\", \"dbpedia\": \"http://dbpedia.org/resource/Perm_Oblast\"}], \"noun_phrases\": [{\"ngram\": \"Le Monde\", \"from\": 1675, \"to\": 1683}, {\"ngram\": \"other media\", \"from\": 1688, \"to\": 1699}, {\"ngram\": \"the suspect\", \"from\": 1706, \"to\": 1717}, {\"ngram\": \"a chef\", \"from\": 1738, \"to\": 1744}, {\"ngram\": \"the city\", \"from\": 1761, \"to\": 1769}, {\"ngram\": \"the Urals\", \"from\": 1781, \"to\": 1790}]}, {\"sentence\": \"Russia gave the opening ceremony a critical reception, with Zakharova describing it as a \\\"massive failure.\\\"\", \"from\": 1793, \"to\": 1900, \"entities\": [{\"begin\": 1793, \"end\": 1799, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999981683466507, \"rank\": 1.4582519987317226e-06, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}], \"noun_phrases\": [{\"ngram\": \"the opening ceremony\", \"from\": 1805, \"to\": 1825}, {\"ngram\": \"a critical reception\", \"from\": 1826, \"to\": 1846}, {\"ngram\": \"Zakharova\", \"from\": 1853, \"to\": 1862}, {\"ngram\": \"a \\\"massive failure\", \"from\": 1880, \"to\": 1898}]}, {\"sentence\": \"TASS wrote the opening \\\"was notable for a number of awkward situations,\\\" noting gaffes such as the Olympic flag raised upside-down and viewers leaving early due to pouring rain.\", \"from\": 1902, \"to\": 2079, \"entities\": [{\"begin\": 1902, \"end\": 1906, \"title\": \"http://dbpedia.org/resource/TASS\", \"score\": 1.0, \"rank\": 2.418066859589922e-36, \"text\": \"TASS\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/TASS\", \"dbpedia\": \"http://dbpedia.org/resource/TASS\"}], \"noun_phrases\": [{\"ngram\": \"the opening\", \"from\": 1913, \"to\": 1924}, {\"ngram\": \"a number\", \"from\": 1942, \"to\": 1950}, {\"ngram\": \"awkward situations\", \"from\": 1954, \"to\": 1972}, {\"ngram\": \"gaffes\", \"from\": 1982, \"to\": 1988}, {\"ngram\": \"the Olympic flag\", \"from\": 1997, \"to\": 2013}, {\"ngram\": \"upside-down\", \"from\": 2021, \"to\": 2032}, {\"ngram\": \"viewers\", \"from\": 2037, \"to\": 2044}, {\"ngram\": \"rain\", \"from\": 2074, \"to\": 2078}]}, {\"sentence\": \"A Message from The Moscow Times: Dear readers, We are facing unprecedented challenges.\", \"from\": 2081, \"to\": 2169, \"entities\": [{\"begin\": 2096, \"end\": 2112, \"title\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"The Moscow Times\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"dbpedia\": \"http://dbpedia.org/resource/The_Moscow_Times\"}], \"noun_phrases\": [{\"ngram\": \"Dear readers\", \"from\": 2114, \"to\": 2126}, {\"ngram\": \"unprecedented challenges\", \"from\": 2142, \"to\": 2166}]}, {\"sentence\": \"Russia's Prosecutor General's Office has designated The Moscow Times as an \\\"undesirable\\\" organization, criminalizing our work and putting our staff at risk of prosecution.\", \"from\": 2170, \"to\": 2341, \"entities\": [{\"begin\": 2170, \"end\": 2176, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999981683466507, \"rank\": 1.4582519987317226e-06, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}, {\"begin\": 2179, \"end\": 2197, \"title\": \"http://dbpedia.org/resource/Prosecutor-General_of_Russia\", \"score\": 0.9999994086003355, \"rank\": 5.913768863516193e-07, \"text\": \"Prosecutor General\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Prosecutor-General_of_Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Prosecutor-General_of_Russia\"}, {\"begin\": 2222, \"end\": 2238, \"title\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"The Moscow Times\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"dbpedia\": \"http://dbpedia.org/resource/The_Moscow_Times\"}], \"noun_phrases\": [{\"ngram\": \"an \\\"undesirable\\\" organization\", \"from\": 2242, \"to\": 2271}, {\"ngram\": \"our work\", \"from\": 2287, \"to\": 2295}, {\"ngram\": \"our staff\", \"from\": 2308, \"to\": 2317}, {\"ngram\": \"risk\", \"from\": 2321, \"to\": 2325}, {\"ngram\": \"prosecution\", \"from\": 2329, \"to\": 2340}]}, {\"sentence\": \"This follows our earlier unjust labeling as a \\\"foreign agent.\\\"\", \"from\": 2342, \"to\": 2404, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"our earlier unjust labeling\", \"from\": 2355, \"to\": 2382}, {\"ngram\": \"a \\\"foreign agent\", \"from\": 2386, \"to\": 2402}]}, {\"sentence\": \"These actions are direct attempts to silence independent journalism in Russia.\", \"from\": 2406, \"to\": 2484, \"entities\": [{\"begin\": 2477, \"end\": 2483, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999981683466507, \"rank\": 1.4582519987317226e-06, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}], \"noun_phrases\": [{\"ngram\": \"These actions\", \"from\": 2406, \"to\": 2419}, {\"ngram\": \"direct attempts\", \"from\": 2424, \"to\": 2439}, {\"ngram\": \"independent journalism\", \"from\": 2451, \"to\": 2473}]}, {\"sentence\": \"The authorities claim our work \\\"discredits the decisions of the Russian leadership.\\\"\", \"from\": 2485, \"to\": 2569, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The authorities\", \"from\": 2485, \"to\": 2500}, {\"ngram\": \"our work\", \"from\": 2507, \"to\": 2515}, {\"ngram\": \"the decisions\", \"from\": 2528, \"to\": 2541}, {\"ngram\": \"the Russian leadership\", \"from\": 2545, \"to\": 2567}]}, {\"sentence\": \"We see things differently: we strive to provide accurate, unbiased reporting on Russia.\", \"from\": 2570, \"to\": 2657, \"entities\": [{\"begin\": 2650, \"end\": 2656, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999981683466507, \"rank\": 1.4582519987317226e-06, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}], \"noun_phrases\": [{\"ngram\": \"things\", \"from\": 2577, \"to\": 2583}, {\"ngram\": \"accurate, unbiased reporting\", \"from\": 2618, \"to\": 2646}]}, {\"sentence\": \"We, the journalists of The Moscow Times, refuse to be silenced.\", \"from\": 2659, \"to\": 2722, \"entities\": [{\"begin\": 2682, \"end\": 2698, \"title\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"The Moscow Times\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"dbpedia\": \"http://dbpedia.org/resource/The_Moscow_Times\"}], \"noun_phrases\": [{\"ngram\": \"the journalists\", \"from\": 2663, \"to\": 2678}]}, {\"sentence\": \"But to continue our work,we need your help.\", \"from\": 2723, \"to\": 2766, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"our work\", \"from\": 2739, \"to\": 2747}, {\"ngram\": \"your help\", \"from\": 2756, \"to\": 2765}]}, {\"sentence\": \"Your support, no matter how small, makes a world of difference.\", \"from\": 2768, \"to\": 2831, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Your support\", \"from\": 2768, \"to\": 2780}, {\"ngram\": \"a world\", \"from\": 2809, \"to\": 2816}, {\"ngram\": \"difference\", \"from\": 2820, \"to\": 2830}]}, {\"sentence\": \"If you can, please support us monthly starting from just$2.It's quick to set up, and every contribution makes a significant impact.\", \"from\": 2832, \"to\": 2963, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"us\", \"from\": 2859, \"to\": 2861}, {\"ngram\": \"every contribution\", \"from\": 2917, \"to\": 2935}, {\"ngram\": \"a significant impact\", \"from\": 2942, \"to\": 2962}]}, {\"sentence\": \"By supporting The Moscow Times, you are defending open, independent journalism in the face of repression.\", \"from\": 2965, \"to\": 3070, \"entities\": [{\"begin\": 2979, \"end\": 2995, \"title\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"The Moscow Times\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"dbpedia\": \"http://dbpedia.org/resource/The_Moscow_Times\"}], \"noun_phrases\": [{\"ngram\": \"open, independent journalism\", \"from\": 3015, \"to\": 3043}, {\"ngram\": \"the face\", \"from\": 3047, \"to\": 3055}, {\"ngram\": \"repression\", \"from\": 3059, \"to\": 3069}]}, {\"sentence\": \"Thank you for standing with us.\", \"from\": 3071, \"to\": 3102, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"us\", \"from\": 3099, \"to\": 3101}]}]}"