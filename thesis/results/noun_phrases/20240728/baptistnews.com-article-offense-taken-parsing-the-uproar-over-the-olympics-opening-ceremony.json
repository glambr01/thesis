rom\": 949, \"to\": 1252, \"entities\": [{\"begin\": 977, \"end\": 987, \"title\": \"http://dbpedia.org/resource/Christianity\", \"score\": 0.999999999998181, \"rank\": 2.2095310222856807e-12, \"text\": \"Christians\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Christianity\", \"dbpedia\": \"http://dbpedia.org/resource/Christianity\"}, {\"begin\": 1083, \"end\": 1085, \"title\": \"http://dbpedia.org/resource/Connecticut\", \"score\": 0.9999992907262609, \"rank\": 6.939889051633517e-07, \"text\": \"CT\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Connecticut\", \"dbpedia\": \"http://dbpedia.org/resource/Connecticut\"}], \"noun_phrases\": [{\"ngram\": \"someone\", \"from\": 954, \"to\": 961}, {\"ngram\": \"X\", \"from\": 965, \"to\": 966}, {\"ngram\": \"such satire\", \"from\": 1034, \"to\": 1045}, {\"ngram\": \"mockery\", \"from\": 1050, \"to\": 1057}, {\"ngram\": \"Mike Cosper\", \"from\": 1058, \"to\": 1069}, {\"ngram\": \"director\", \"from\": 1071, \"to\": 1079}, {\"ngram\": \"the suggestion\", \"from\": 1135, \"to\": 1149}, {\"ngram\": \"the moral equivalent\", \"from\": 1155, \"to\": 1175}, {\"ngram\": \"an abused wife\", \"from\": 1187, \"to\": 1201}, {\"ngram\": \"your husband\", \"from\": 1228, \"to\": 1240}]}, {\"sentence\": \"In his analogy, this means the opening ceremony would be the moral equivalent of a husband abusing his wife.\", \"from\": 1253, \"to\": 1361, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"his analogy\", \"from\": 1256, \"to\": 1267}, {\"ngram\": \"the opening ceremony\", \"from\": 1280, \"to\": 1300}, {\"ngram\": \"the moral equivalent\", \"from\": 1310, \"to\": 1330}, {\"ngram\": \"a husband\", \"from\": 1334, \"to\": 1343}, {\"ngram\": \"his wife\", \"from\": 1352, \"to\": 1360}]}, {\"sentence\": \"\\\"What we saw last night deliberately incorporated blasphemous imagery, pagan imagery, and sexualized imagery.\", \"from\": 1363, \"to\": 1472, \"entities\": [{\"begin\": 1434, \"end\": 1439, \