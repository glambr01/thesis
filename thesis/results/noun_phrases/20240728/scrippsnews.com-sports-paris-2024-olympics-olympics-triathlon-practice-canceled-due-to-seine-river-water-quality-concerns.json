"{\"uid\": \"scrippsnews.com-sports-paris-2024-olympics-olympics-triathlon-practice-canceled-due-to-seine-river-water-quality-concerns\", \"noun_phrases\": [{\"sentence\": \"The swimming segment of a triathlon practice at the Paris Olympics was canceled Sunday due to concerns over water quality in the Seine River.\", \"from\": 0, \"to\": 141, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The swimming segment\", \"from\": 0, \"to\": 20}, {\"ngram\": \"a triathlon practice\", \"from\": 24, \"to\": 44}, {\"ngram\": \"the Paris Olympics\", \"from\": 48, \"to\": 66}, {\"ngram\": \"concerns\", \"from\": 94, \"to\": 102}, {\"ngram\": \"water quality\", \"from\": 108, \"to\": 121}, {\"ngram\": \"the Seine River\", \"from\": 125, \"to\": 140}]}, {\"sentence\": \"Swimming in Paris' most famed waterway has been banned for over 100 years due to pollution from factory wastewater, sewage, and rain runoff.\", \"from\": 143, \"to\": 283, \"entities\": [{\"begin\": 155, \"end\": 160, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999978174782824, \"rank\": 2.1825264543411174e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"pollution\", \"from\": 224, \"to\": 233}, {\"ngram\": \"factory wastewater\", \"from\": 239, \"to\": 257}, {\"ngram\": \"sewage\", \"from\": 259, \"to\": 265}, {\"ngram\": \"rain runoff\", \"from\": 271, \"to\": 282}]}, {\"sentence\": \"However, the government has spent nearly $1.5 billion to prepare the Seine for the Olympics by fixing old pipes, limiting the amount of untreated wastewater going into the river, and building a wastewater and rainwater storage basin.\", \"from\": 285, \"to\": 518, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the government\", \"from\": 294, \"to\": 308}, {\"ngram\": \"the Seine\", \"from\": 350, \"to\": 359}, {\"ngram\": \"the Olympics\", \"from\": 364, \"to\": 376}, {\"ngram\": \"old pipes\", \"from\": 387, \"to\": 396}, {\"ngram\": \"the amount\", \"from\": 407, \"to\": 417}, {\"ngram\": \"untreated wastewater\", \"from\": 421, \"to\": 441}, {\"ngram\": \"the river\", \"from\": 453, \"to\": 462}, {\"ngram\": \"a wastewater and rainwater storage basin\", \"from\": 477, \"to\": 517}]}, {\"sentence\": \"RELATED STORY |Will the Seine River be safe to swim in for the Paris Olympics?\", \"from\": 520, \"to\": 598, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"RELATED STORY |Will\", \"from\": 520, \"to\": 539}, {\"ngram\": \"the Seine River\", \"from\": 540, \"to\": 555}, {\"ngram\": \"the Paris Olympics\", \"from\": 579, \"to\": 597}]}, {\"sentence\": \"A local governmentbulletin published in Junereported a degradation of water quality and increases in E. coli due to rain discharges upstream, raising concerns that the river would not be ready in time for the Olympic Games.\", \"from\": 600, \"to\": 823, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A local governmentbulletin\", \"from\": 600, \"to\": 626}, {\"ngram\": \"Junereported\", \"from\": 640, \"to\": 652}, {\"ngram\": \"a degradation\", \"from\": 653, \"to\": 666}, {\"ngram\": \"water quality\", \"from\": 670, \"to\": 683}, {\"ngram\": \"increases\", \"from\": 688, \"to\": 697}, {\"ngram\": \"E. coli\", \"from\": 701, \"to\": 708}, {\"ngram\": \"rain discharges\", \"from\": 716, \"to\": 731}, {\"ngram\": \"concerns\", \"from\": 750, \"to\": 758}, {\"ngram\": \"the river\", \"from\": 764, \"to\": 773}, {\"ngram\": \"time\", \"from\": 796, \"to\": 800}, {\"ngram\": \"the Olympic Games\", \"from\": 805, \"to\": 822}]}, {\"sentence\": \"But after tests earlier this month showed that conditions had improved, Paris Mayor Anne Hidalgo and other government officials went for a highly publicized dip in the Seine on July 17 to show that it was safe.\", \"from\": 824, \"to\": 1034, \"entities\": [{\"begin\": 896, \"end\": 907, \"title\": \"http://dbpedia.org/resource/List_of_mayors_of_Paris\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Paris Mayor\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/List_of_mayors_of_Paris\", \"dbpedia\": \"http://dbpedia.org/resource/List_of_mayors_of_Paris\"}, {\"begin\": 908, \"end\": 920, \"title\": \"http://dbpedia.org/resource/Anne_Hidalgo\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Anne Hidalgo\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Anne_Hidalgo\", \"dbpedia\": \"http://dbpedia.org/resource/Anne_Hidalgo\"}, {\"begin\": 992, \"end\": 997, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999537836500055, \"rank\": 4.621668003141909e-05, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"tests\", \"from\": 834, \"to\": 839}, {\"ngram\": \"conditions\", \"from\": 871, \"to\": 881}, {\"ngram\": \"other government officials\", \"from\": 925, \"to\": 951}, {\"ngram\": \"a highly publicized dip\", \"from\": 961, \"to\": 984}, {\"ngram\": \"July\", \"from\": 1001, \"to\": 1005}]}, {\"sentence\": \"Olympic organizers assured that despite heavy rains earlier this weekend, they expect water quality in the river will improve over the coming days.\", \"from\": 1036, \"to\": 1183, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Olympic organizers\", \"from\": 1036, \"to\": 1054}, {\"ngram\": \"heavy rains\", \"from\": 1076, \"to\": 1087}, {\"ngram\": \"water quality\", \"from\": 1122, \"to\": 1135}, {\"ngram\": \"the river\", \"from\": 1139, \"to\": 1148}, {\"ngram\": \"the coming days\", \"from\": 1167, \"to\": 1182}]}, {\"sentence\": \"The men's triathlon is currently scheduled to begin Tuesday, with the women slated to compete a day later.\", \"from\": 1184, \"to\": 1290, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The men's triathlon\", \"from\": 1184, \"to\": 1203}, {\"ngram\": \"the women\", \"from\": 1250, \"to\": 1259}]}, {\"sentence\": \"Officials said contingency plans are in place if needed.\", \"from\": 1292, \"to\": 1348, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Officials\", \"from\": 1292, \"to\": 1301}, {\"ngram\": \"contingency plans\", \"from\": 1307, \"to\": 1324}, {\"ngram\": \"place\", \"from\": 1332, \"to\": 1337}]}, {\"sentence\": \"About Scripps News\", \"from\": 1350, \"to\": 1368, \"entities\": [{\"begin\": 1356, \"end\": 1363, \"title\": \"http://dbpedia.org/resource/E._W._Scripps_Company\", \"score\": 0.9563653779395115, \"rank\": 0.03442292171245058, \"text\": \"Scripps\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/E._W._Scripps_Company\", \"dbpedia\": \"http://dbpedia.org/resource/E._W._Scripps_Company\"}], \"noun_phrases\": []}]}"