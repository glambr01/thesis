]}, {\"sentence\": \"Battling back from an anaphylactic shock caused by her allergies just days before the competition, Jung-Ruivivar still showed out.\", \"from\": 1078, \"to\": 1208, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an anaphylactic shock\", \"from\": 1097, \"to\": 1118}, {\"ngram\": \"her allergies\", \"from\": 1129, \"to\": 1142}, {\"ngram\": \"the competition\", \"from\": 1160, \"to\": 1175}, {\"ngram\": \"Jung-Ruivivar\", \"from\": 1177, \"to\": 1190}]}, {\"sentence\": \"Jung-Ruivivar, the youngest member of Team Philippines at 18 years old, posted 13.600 in vault, 13.200 in uneven bars (40th), 12.433 in floor exercise (54th), and 11.866 in balance beam (64th).\", \"from\": 1210, \"to\": 1403, \"entities\": [{\"begin\": 1253, \"end\": 1264, \"title\": \"http://dbpedia.org/resource/Philippines\", \"score\": 0.8252851002284216, \"rank\": 0.20943837585845548, \"text\": \"Philippines\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Philippines\", \"dbpedia\": \"http://dbpedia.org/resource/Philippines\"}], \"noun_phrases\": [{\"ngram\": \"Jung-Ruivivar\", \"from\": 1210, \"to\": 1223}, {\"ngram\": \"the youngest member\", \"from\": 1225, \"to\": 1244}, {\"ngram\": \"vault\", \"from\": 1299, \"to\": 1304}, {\"ngram\": \"uneven bars\", \"from\": 1316, \"to\": 1327}, {\"ngram\": \"floor exercise\", \"from\": 1346, \"to\": 1360}, {\"ngram\": \"balance beam\", \"from\": 1383, \"to\": 1395}, {\"ngram\": \"64th\", \"from\": 1397, \"to\": 1401}]}, {\"sentence\": \"Malabuyo netted 13.266 points in vault, 13.100 in floor exercise (25th), 12.500 in uneven bars (60th), and 12.233 in balance beam (57th), while Finnegan averaged 13.387 in vault (17th) and scored 12.733 in floor exercise (37th), 12.566 in uneven bars (58th), and 11.466 in balance beam (71st).\", \"from\": 1405, \"to\": 1698, \"entities\": [{\"begin\": 1549, \"end\": 1557, \"title\": \"http://dbpedia.org/resource/Kyle_Finnegan\", \"score\": 0.9998542183765958, \"rank\": 0.000145