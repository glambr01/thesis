\": \"the atmosphere\", \"from\": 161, \"to\": 175}, {\"ngram\": \"the present camp\", \"from\": 183, \"to\": 199}, {\"ngram\": \"the 2008 Games\", \"from\": 225, \"to\": 239}]}, {\"sentence\": \"\\\"Five days before the start of the track and field competition at the Paris 2024 games, the Jamaican team is looking in good stead,\\\" Wilson said in a report posted to Instagram on Saturday.\", \"from\": 253, \"to\": 442, \"entities\": [{\"begin\": 323, \"end\": 333, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 0.999999206855451, \"rank\": 7.931452188934395e-07, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 345, \"end\": 353, \"title\": \"http://dbpedia.org/resource/Jamaicans\", \"score\": 0.999583558279522, \"rank\": 0.00040796400010680505, \"text\": \"Jamaican\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Jamaicans\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaicans\"}, {\"begin\": 386, \"end\": 392, \"title\": \"http://dbpedia.org/resource/Wilson_Sporting_Goods\", \"score\": 0.9321636019753716, \"rank\": 0.05089562238405996, \"text\": \"Wilson\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Wilson_Sporting_Goods\", \"dbpedia\": \"http://dbpedia.org/resource/Wilson_Sporting_Goods\"}, {\"begin\": 420, \"end\": 429, \"title\": \"http://dbpedia.org/resource/Instagram\", \"score\": 0.9999999999345164, \"rank\": 6.551496976513199e-11, \"text\": \"Instagram\", \"types\": [\"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Instagram\", \"dbpedia\": \"http://dbpedia.org/resource/Instagram\"}], \"noun_phrases\": [{\"ngram\": \"the start\", \"from\": 271, \"to\": 280}, {\"ngram\": \"the track and field competition\", \"from\": 284, \"to\": 315}, {\"ngram\": \"good stead\", \"from\": 373, \"to\": 383}, {\"ngram\": \"a report\", \"from\": 401, \"to\": 409}, {\"ngram\": \"Saturday\", \"from\": 433, \"to\": 441}]}, {\"sentence\": \"Wilson said the make-up of the team, which includes at least two athletes with junior eligibility among 36 first-time Olympians, was a good blend of veterans and youngsters.\", \"from\": 444, \"to\": 617, \"entities\": [{\"begin\": 444, \"end\": 450, \"title\": \"http://dbpedia.org/resource/Wilson_Sporting_Goods\", \"score\": 0.9321636019753716, \"rank\": 0.05089562238405996, \"text\": \"Wilson\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Wilson_Sporting_Goods\", \"dbpedia\": \"http://dbpedia.org/resource/Wilson_Sporting_Goods\"}], \"noun_phrases\": [{\"ngram\": \"the make-up\", \"from\": 456, \"to\": 467}, {\"ngram\": \"the team\", \"from\": 471, \"to\": 479}, {\"ngram\": \"at least two athletes\", \"from\": 496, \"to\": 517}, {\"ngram\": \"junior eligibility\", \"from\": 523, \"to\": 541}, {\"ngram\": \"36 first-time Olympians\", \"from\": 548, \"to\": 571}, {\"ngram\": \"a good blend\", \"from\": 577, \"to\": 589}, {\"ngram\": \"veterans\", \"from\": 593, \"to\": 601}, {\"ngram\": \"youngsters\", \"from\": 606, \"to\": 616}]}, {\"sentence\": \"\\\"I can recall in 2008 (Beijing, China) when Shelley-Ann Fraser-Pryce made her first team (in an individual event) at the highest level and most of the team at that time were transitioning juniors taking over from the veterans, was the year where we saw some excellent performances from our sprinters and I am getting the same feeling this year that the Jamaican team is going to do extremely well,\\\" he said.\", \"from\": 619, \"to\": 1026, \"entities\": [{\"begin\": 642, \"end\": 649, \"title\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"score\": 0.9999046300763023, \"rank\": 9.537897486412143e-05, \"text\": \"Beijing\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"dbpedia\": \"http://db