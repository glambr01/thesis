 929}, {\"ngram\": \"a Ugandan-born athlete\", \"from\": 930, \"to\": 952}, {\"ngram\": \"elite training facilities\", \"from\": 985, \"to\": 1010}, {\"ngram\": \"critical condition\", \"from\": 1018, \"to\": 1036}, {\"ngram\": \"external and inhalation burns\", \"from\": 1042, \"to\": 1071}, {\"ngram\": \"MTRH CEO Dr.OwenMenachtold reportersoutside\", \"from\": 1073, \"to\": 1116}, {\"ngram\": \"the hospital\", \"from\": 1117, \"to\": 1129}]}, {\"sentence\": \"\\\"She is a high-profile patient,\\\" he added, \\\"and we are doing all we can to save her life.\\\"\", \"from\": 1132, \"to\": 1222, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a high-profile patient\", \"from\": 1140, \"to\": 1162}, {\"ngram\": \"her life\", \"from\": 1212, \"to\": 1220}]}, {\"sentence\": \"According to Kosiom, neighbors heard Cheptegei and Ndiema arguing on Sept. 1 at her home in Endebess, Kenya.\", \"from\": 1224, \"to\": 1332, \"entities\": [{\"begin\": 1316, \"end\": 1324, \"title\": \"http://dbpedia.org/resource/Endebess\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Endebess\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Endebess\", \"dbpedia\": \"http://dbpedia.org/resource/Endebess\"}, {\"begin\": 1326, \"end\": 1331, \"title\": \"http://dbpedia.org/resource/Kenya\", \"score\": 1.0, \"rank\": 2.030548585861967e-27, \"text\": \"Kenya\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Kenya\", \"dbpedia\": \"http://dbpedia.org/resource/Kenya\"}], \"noun_phrases\": [{\"ngram\": \"Kosiom\", \"from\": 1237, \"to\": 1243}, {\"ngram\": \"neighbors\", \"from\": 1245, \"to\": 1254}, {\"ngram\": \"Cheptegei\", \"from\": 1261, \"to\": 1270}, {\"ngram\": \"Ndiema\", \"from\": 1275, \"to\": 1281}, {\"ngram\": \"Sept.\", \"from\": 1293, \"to\": 1298}, {\"ngram\": \"her home\", \"from\": 1304, \"to\": 1312}]}, {\"sentence\": \"Then, the commander said, Ndiema left, purchased a 5-liter can of gasoline and returned to Cheptegei's residence.\", \"from\"