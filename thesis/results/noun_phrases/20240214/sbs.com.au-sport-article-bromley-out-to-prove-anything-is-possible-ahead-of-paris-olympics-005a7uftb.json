\"plenty\", \"from\": 3225, \"to\": 3231}, {\"ngram\": \"the way\", \"from\": 3235, \"to\": 3242}, {\"ngram\": \"national team experience\", \"from\": 3246, \"to\": 3270}, {\"ngram\": \"both the 2018 Commonwealth Games\", \"from\": 3291, \"to\": 3323}, {\"ngram\": \"2020 Olympics\", \"from\": 3328, \"to\": 3341}, {\"ngram\": \"current teammates\", \"from\": 3347, \"to\": 3364}, {\"ngram\": \"Lay\", \"from\": 3365, \"to\": 3368}, {\"ngram\": \"Tapper\", \"from\": 3373, \"to\": 3379}, {\"ngram\": \", two bronze medallists\", \"from\": 3379, \"to\": 3402}, {\"ngram\": \"the former's 2014 edition\", \"from\": 3408, \"to\": 3433}]}, {\"sentence\": \"Qualifying for the 2018 Commonwealth Games was particularly pleasing for Bromley, who, despite dominating as a junior, failed to make the respective Australian squads for Melbourne (2006), Delhi (2010), and Glasgow (2014).\", \"from\": 3447, \"to\": 3669, \"entities\": [{\"begin\": 3520, \"end\": 3527, \"title\": \"http://dbpedia.org/resource/Bromley\", \"score\": 0.6649350286297533, \"rank\": 0.5039061065322948, \"text\": \"Bromley\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Bromley\", \"dbpedia\": \"http://dbpedia.org/resource/Bromley\"}, {\"begin\": 3596, \"end\": 3606, \"title\": \"http://dbpedia.org/resource/Australians\", \"score\": 0.6987010689895599, \"rank\": 0.4299521676570035, \"text\": \"Australian\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Australians\", \"dbpedia\": \"http://dbpedia.org/resource/Australians\"}, {\"begin\": 3618, \"end\": 3627, \"title\": \"http://dbpedia.org/resource/Melbourne\", \"score\": 0.9999973748629496, \"rank\": 2.5265252450440816e-06, \"text\": \"Melbourne\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Melbourne\", \"dbpedia\": \"http://dbpedia.org/resource/Melbourne\"}, {\"begin\": 3636, \"end\": 3641, \"title\": \"http://dbpedia.org/resource/Delhi\", \"score\": 0.9017490710573897, \"rank\": 0.10246941