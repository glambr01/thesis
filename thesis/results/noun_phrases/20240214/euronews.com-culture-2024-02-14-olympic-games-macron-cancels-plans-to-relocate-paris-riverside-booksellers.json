es\": [{\"ngram\": \"local authorities\", \"from\": 4955, \"to\": 4972}, {\"ngram\": \"approximately 570 book boxes\", \"from\": 5016, \"to\": 5044}, {\"ngram\": \"almost 60%\", \"from\": 5064, \"to\": 5074}, {\"ngram\": \"their total presence\", \"from\": 5078, \"to\": 5098}, {\"ngram\": \"the river banks\", \"from\": 5105, \"to\": 5120}]}, {\"sentence\": \"Book box dismantling tests were even carried out in November.\", \"from\": 5122, \"to\": 5183, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Book box dismantling tests\", \"from\": 5122, \"to\": 5148}, {\"ngram\": \"November\", \"from\": 5174, \"to\": 5182}]}, {\"sentence\": \"Around 200 bouquinistes work in France's capital and for many of them the latest announcement comes as a relief.\", \"from\": 5185, \"to\": 5297, \"entities\": [{\"begin\": 5217, \"end\": 5223, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9989429997318483, \"rank\": 0.00047127364607367527, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"Around 200 bouquinistes\", \"from\": 5185, \"to\": 5208}, {\"ngram\": \"the latest announcement\", \"from\": 5255, \"to\": 5278}, {\"ngram\": \"a relief\", \"from\": 5288, \"to\": 5296}]}, {\"sentence\": \"\\\"For the last seven months we have put all our energy into campaigning against the decision to relocate us, this outcome comes as a relief,\\\" Pascal Corseaux, Vice-President of the Paris Association of Bouquinistes toldEuronews Cultureshortly after the announcement.\", \"from\": 5299, \"to\": 5564, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the last seven months\", \"from\": 5304, \"to\": 5325}, {\"ngram\": \"all our energy\", \"from\": 5338, \"to\": 5352}, {\"ngram\": \"the decision\", \"from\": 5378, \"to\": 5390}, {\"ngram\": \"us\", \"from\": 5403, \"to\": 5405}, {\"ngram\": \"this outcome\", \"from\": 5407, \"to\": 5419}, {\"ngra