"{\"uid\": \"jamaicaobserver.com-2024-02-11-smikle-distin-get-olympic-games-qualifying-standards\", \"noun_phrases\": [{\"sentence\": \"KINGSTON, Jamaica - Jamaica's Traves Smikle and Lamara Distin have achieved the Olympic Games qualifying standards in their individual events, the men's discus throw and women's high jump, respectively.\", \"from\": 0, \"to\": 202, \"entities\": [{\"begin\": 10, \"end\": 17, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.9980914162767831, \"rank\": 0.0017540223754035878, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}, {\"begin\": 30, \"end\": 43, \"title\": \"http://dbpedia.org/resource/Traves_Smikle\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Traves Smikle\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Traves_Smikle\", \"dbpedia\": \"http://dbpedia.org/resource/Traves_Smikle\"}], \"noun_phrases\": [{\"ngram\": \"KINGSTON\", \"from\": 0, \"to\": 8}, {\"ngram\": \"the Olympic Games qualifying standards\", \"from\": 76, \"to\": 114}, {\"ngram\": \"their individual events\", \"from\": 118, \"to\": 141}, {\"ngram\": \"the men's discus throw\", \"from\": 143, \"to\": 165}, {\"ngram\": \"women's high jump\", \"from\": 170, \"to\": 187}]}, {\"sentence\": \"Both achieved the feat during competitions on Saturday.\", \"from\": 204, \"to\": 259, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the feat\", \"from\": 218, \"to\": 226}, {\"ngram\": \"competitions\", \"from\": 234, \"to\": 246}, {\"ngram\": \"Saturday\", \"from\": 250, \"to\": 258}]}, {\"sentence\": \"Smikle won the men's discus throw with a world leading 67.57m mark at the King of the Rings event held at Excelsior High, almost a year to the date when he achieved the qualifying mark for the World Championships last year.\", \"from\": 261, \"to\": 484, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the men's discus throw\", \"from\": 272, \"to\": 294}, {\"ngram\": \"a world\", \"from\": 300, \"to\": 307}, {\"ngram\": \"67.57m mark\", \"from\": 316, \"to\": 327}, {\"ngram\": \"the King\", \"from\": 331, \"to\": 339}, {\"ngram\": \"the Rings event\", \"from\": 343, \"to\": 358}, {\"ngram\": \"Excelsior High\", \"from\": 367, \"to\": 381}, {\"ngram\": \"the date\", \"from\": 400, \"to\": 408}, {\"ngram\": \"the qualifying mark\", \"from\": 426, \"to\": 445}, {\"ngram\": \"the World Championships\", \"from\": 450, \"to\": 473}]}, {\"sentence\": \"The Commonwealth Games medallist had two throws over the 67.00m mark and also passed the Olympic Games qualifying standard of 67.20m.\", \"from\": 485, \"to\": 618, \"entities\": [{\"begin\": 489, \"end\": 507, \"title\": \"http://dbpedia.org/resource/Commonwealth_Games\", \"score\": 0.8841241751244848, \"rank\": 0.06484897436632028, \"text\": \"Commonwealth Games\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Commonwealth_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Commonwealth_Games\"}], \"noun_phrases\": [{\"ngram\": \"two throws\", \"from\": 522, \"to\": 532}, {\"ngram\": \"the 67.00m mark\", \"from\": 538, \"to\": 553}, {\"ngram\": \"the Olympic Games\", \"from\": 570, \"to\": 587}, {\"ngram\": \"qualifying standard\", \"from\": 588, \"to\": 607}, {\"ngram\": \"67.20m.\", \"from\": 611, \"to\": 618}]}, {\"sentence\": \"Distin, who represented Jamaica at the last two World Athletics Championships and was fifth in Budapest, Hungary last year, had a season best 1.97m to win the women's invitational at the Clemson Tiger Paw Invitational on Saturday, the exact qualifying mark for the Olympics.\", \"from\": 620, \"to\": 894, \"entities\": [{\"begin\": 644, \"end\": 651, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.9980914162767831, \"rank\": 0.0017540223754035878, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://d