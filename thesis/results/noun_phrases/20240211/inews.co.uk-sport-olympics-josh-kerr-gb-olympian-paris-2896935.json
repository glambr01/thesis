 \"entities\": [], \"noun_phrases\": [{\"ngram\": \"year\", \"from\": 1484, \"to\": 1488}]}, {\"sentence\": \"\\\"I am able to bottle those moments for myself, crossing the finishing line to become the best in the world.\", \"from\": 1512, \"to\": 1619, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"those moments\", \"from\": 1533, \"to\": 1546}, {\"ngram\": \"the finishing line\", \"from\": 1568, \"to\": 1586}, {\"ngram\": \"the world\", \"from\": 1609, \"to\": 1618}]}, {\"sentence\": \"That is the moment we live for.\", \"from\": 1620, \"to\": 1651, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the moment\", \"from\": 1628, \"to\": 1638}]}, {\"sentence\": \"But we move on.\", \"from\": 1652, \"to\": 1667, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"\\\"We need to run faster, get better and stronger.\", \"from\": 1669, \"to\": 1717, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"This is the most important year of my career.\", \"from\": 1718, \"to\": 1763, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the most important year\", \"from\": 1726, \"to\": 1749}, {\"ngram\": \"my career\", \"from\": 1753, \"to\": 1762}]}, {\"sentence\": \"That is the focus right now, short-term goals, step by step.\\\"\", \"from\": 1764, \"to\": 1825, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the focus\", \"from\": 1772, \"to\": 1781}, {\"ngram\": \"step\", \"from\": 1819, \"to\": 1823}]}, {\"sentence\": \"Kerr's first engagement of 2024 is the prestigious Millrose indoor meet on 11 February in New York, where he is targeting Mo Farah's two-mile world record, aiming to become the first human to dip under eight minutes at the distance.\", \"from\": 1827, \"to\": 2059, \"entities\": [{\"begin\": 1917, \"end\": 1925, \"title\": \"http://dbpedia.org/resource/New_York_City\", \"score\": 0.9999999994101927, \"rank\": 3.8171318536402046e-10, \"text\": \"New York\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/New_York_City\", \"dbpedia\": \"http://dbpedia.org/resource/New_York_City\"}], \"noun_phrases\": [{\"ngram\": \"Kerr's first engagement\", \"from\": 1827, \"to\": 1850}, {\"ngram\": \"11 February\", \"from\": 1902, \"to\": 1913}, {\"ngram\": \"Mo Farah's two-mile world record\", \"from\": 1949, \"to\": 1981}, {\"ngram\": \"the first human\", \"from\": 2000, \"to\": 2015}, {\"ngram\": \"eight minutes\", \"from\": 2029, \"to\": 2042}, {\"ngram\": \"the distance\", \"from\": 2046, \"to\": 2058}]}, {\"sentence\": \"\\\"You can not really plan for a race six months hence.\", \"from\": 2061, \"to\": 2114, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a race\", \"from\": 2090, \"to\": 2096}]}, {\"sentence\": \"We do indoors, then qualifying times, then the British Championships, training camps, get to the Olympics, go through the rounds then into the final.\", \"from\": 2115, \"to\": 2264, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"indoors\", \"from\": 2121, \"to\": 2128}, {\"ngram\": \"the British Championships\", \"from\": 2158, \"to\": 2183}, {\"ngram\": \"training camps\", \"from\": 2185, \"to\": 2199}, {\"ngram\": \"the Olympics\", \"from\": 2208, \"to\": 2220}, {\"ngram\": \"the rounds\", \"from\": 2233, \"to\": 2243}]}, {\"sentence\": \"It's a long year, but taken step by step it is manageable.\\\"\", \"from\": 2265, \"to\": 2324, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a long year\", \"from\": 2270, \"to\": 2281}, {\"ngram\": \"step\", \"from\": 2293, \"to\": 2297}, {\"ngram\": \"step\", \"from\": 2301, \"to\": 2305}]}, {\"sentence\": \"Ingebrigtsen's senior by three years, 26-year-old Kerr took the more conventional route via college athletics in the United States.\", \"from\": 2326, \"to\": 2457, \"entities\": [{\"begin\": 2443, \"end\": 2456, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999461878710553, \"rank\": 3.333778011081941e-05, \"text\": \"United States\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.o