}, {\"begin\": 992, \"end\": 1005, \"title\": \"http://dbpedia.org/resource/George_W._Romney\", \"score\": 1.0, \"rank\": 6.934627601631062e-47, \"text\": \"George Romney\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/George_W._Romney\", \"dbpedia\": \"http://dbpedia.org/resource/George_W._Romney\"}, {\"begin\": 1079, \"end\": 1085, \"title\": \"http://dbpedia.org/resource/Boston\", \"score\": 0.9999999995980033, \"rank\": 3.644220293577638e-10, \"text\": \"Boston\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Boston\", \"dbpedia\": \"http://dbpedia.org/resource/Boston\"}, {\"begin\": 1125, \"end\": 1139, \"title\": \"http://dbpedia.org/resource/Salt_Lake_City\", \"score\": 0.9999999996753104, \"rank\": 3.247603945517457e-10, \"text\": \"Salt Lake City\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Salt_Lake_City\", \"dbpedia\": \"http://dbpedia.org/resource/Salt_Lake_City\"}], \"noun_phrases\": [{\"ngram\": \"a half-hour\", \"from\": 843, \"to\": 854}, {\"ngram\": \"questions\", \"from\": 891, \"to\": 900}, {\"ngram\": \"his father\", \"from\": 928, \"to\": 938}, {\"ngram\": \"his own experiences\", \"from\": 1022, \"to\": 1041}, {\"ngram\": \"a venture capital firm\", \"from\": 1053, \"to\": 1075}, {\"ngram\": \"the2002\", \"from\": 1102, \"to\": 1109}, {\"ngram\": \"the ups\", \"from\": 1153, \"to\": 1160}, {\"ngram\": \"downs\", \"from\": 1165, \"to\": 1170}, {\"ngram\": \"politics\", \"from\": 1174, \"to\": 1182}]}, {\"sentence\": \"It's his family and hisfaithin The Church of Jesus Christ of Latter-day Saints, though, that Romney says have always come first.\", \"from\": 1185, \"to\": 1313, \"entities\": [{\"begin\": 1278, \"end\": 1284, \"title\": \"http://dbpedia.org/resource/Mitt_Romney\", \"score\": 0.9997663971539686, \"rank\": 0.00023354195848280423, \"text\": \"Romney\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Mitt_Romney\", \"dbpedia\": \"http://dbpedia.org/resource/Mitt_Romney\"}], \"noun_phrases\": [{\"ngram\": \"his family\", \"from\": 1190, \"to\": 1200}, {\"ngram\": \"hisfaithin The Church\", \"from\": 1205, \"to\": 1226}, {\"ngram\": \"Jesus Christ\", \"from\": 1230, \"to\": 1242}, {\"ngram\": \"Latter-day Saints\", \"from\": 1246, \"to\": 1263}]}, {\"sentence\": \"\\\"I guess that's because I found the most rewarding part of my life is my relationship with (wife)Annand my kids, and my commitment to my faith.\", \"from\": 1315, \"to\": 1458, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the most rewarding part\", \"from\": 1347, \"to\": 1370}, {\"ngram\": \"my life\", \"from\": 1374, \"to\": 1381}, {\"ngram\": \"my relationship\", \"from\": 1385, \"to\": 1400}, {\"ngram\": \"wife)Annand\", \"from\": 1407, \"to\": 1418}, {\"ngram\": \"my kids\", \"from\": 1419, \"to\": 1426}, {\"ngram\": \"my commitment\", \"from\": 1432, \"to\": 1445}, {\"ngram\": \"my faith\", \"from\": 1449, \"to\": 1457}]}, {\"sentence\": \"They do not fail.\", \"from\": 1459, \"to\": 1476, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Those things are there for me,\\\" Romney said.\", \"from\": 1477, \"to\": 1521, \"entities\": [{\"begin\": 1509, \"end\": 1515, \"title\": \"http://dbpedia.org/resource/Mitt_Romney\", \"score\": 0.9997663971539686, \"rank\": 0.00023354195848280423, \"text\": \"Romney\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Mitt_Romney\", \"dbpedia\": \"http://dbpedia.org/resource/Mitt_Romney\"}], \"noun_phrases\": [{\"ngram\": \"Those things\", \"from\": 1477, \"to\": 1489}]}, {\"sentence\": \"\\\"If I had a sense of personal accomplishment based on what happens politically day to day, gosh, I am not sure what my stock would be at this point.\\\"\", \"from\": 1522, \"to\": 1671, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a sense\", \"from\"