}, {\"ngram\": \"a lot\", \"from\": 1554, \"to\": 1559}, {\"ngram\": \"a result\", \"from\": 1563, \"to\": 1571}]}, {\"sentence\": \"So I ask you to please respect their privacy.\\\"\", \"from\": 1581, \"to\": 1627, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"their privacy\", \"from\": 1612, \"to\": 1625}]}, {\"sentence\": \"The Australian Olympic Committee (AOC) earlier on Thursday condemned an online petition calling for an investigation into Gunn's selection for the Paris Olympics, saying it contained falsehoods aimed at inciting hatred against her.\", \"from\": 1629, \"to\": 1860, \"entities\": [{\"begin\": 1629, \"end\": 1643, \"title\": \"http://dbpedia.org/resource/The_Australian\", \"score\": 1.0, \"rank\": 4.583002026877086e-24, \"text\": \"The Australian\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Australian\", \"dbpedia\": \"http://dbpedia.org/resource/The_Australian\"}, {\"begin\": 1633, \"end\": 1661, \"title\": \"http://dbpedia.org/resource/Australian_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Australian Olympic Committee\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Australian_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_Olympic_Committee\"}, {\"begin\": 1663, \"end\": 1666, \"title\": \"http://dbpedia.org/resource/Australian_Olympic_Committee\", \"score\": 0.9999267516552753, \"rank\": 7.325370938710213e-05, \"text\": \"AOC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Australian_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_Olympic_Committee\"}, {\"begin\": 1751, \"end\": 1755, \"title\": \"http://dbpedia.org/resource/Clan_Gunn\", \"score\": 0.9995841300807765, \"rank\": 0.00027614435350648643, \"text\": \"Gunn\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Clan_Gunn\", \"dbpedia\": \"http://dbpedia.org/resource/Clan_Gunn\"}], \"noun_phrases\": [{\"ngram\": \