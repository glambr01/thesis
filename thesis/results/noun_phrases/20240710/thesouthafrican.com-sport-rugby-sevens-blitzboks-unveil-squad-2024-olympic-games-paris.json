}, {\"begin\": 746, \"end\": 762, \"title\": \"http://dbpedia.org/resource/Siviwe_Soyizwapi\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Siviwe Soyizwapi\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q13415036\"], \"wikid\": \"http://dbpedia.org/resource/Siviwe_Soyizwapi\", \"dbpedia\": \"http://dbpedia.org/resource/Siviwe_Soyizwapi\"}, {\"begin\": 820, \"end\": 825, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.8502240050924854, \"rank\": 0.17615726655424283, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"The squad\", \"from\": 607, \"to\": 616}, {\"ngram\": \"2016 bronze medalist\", \"from\": 643, \"to\": 663}, {\"ngram\": \"part\", \"from\": 773, \"to\": 777}, {\"ngram\": \"the squad\", \"from\": 781, \"to\": 790}]}, {\"sentence\": \"Brown and Katlego Letebele were named as travelling reserves in the Paris squad and will only be called upon in case of injury to one of the 12 players allowed for the squad and residence in the Olympic village.\", \"from\": 828, \"to\": 1039, \"entities\": [{\"begin\": 896, \"end\": 901, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999458851, \"rank\": 5.41749945973407e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Brown\", \"from\": 828, \"to\": 833}, {\"ngram\": \"Katlego Letebele\", \"from\": 838, \"to\": 854}, {\"ngram\": \"travelling reserves\", \"from\": 869, \"to\": 888}, {\"ngram\": \"case\", \"from\": 940, \"to\": 944}, {\"ngram\": \"injury\", \"from\": 948, \"to\": 954}, {\"ngram\": \"the 12 players\", \"from\": 965, \"to\": 979}, {\"ngram\": \"the squad\", \"from\": 992, \"to\": 1001}, {\"ngram\": \"residence\", \"from\": 1006, \"to\": 1015}, {\"ngram\": \"the Olympic village\", \"from\": 1019, \"to\": 1038}]}, {\"sentence\": \"\\\"I could not fault the effort from the guys that went to Monaco, and it was only fair that they were rewarded for that,\\\" said Snyman.\", \"from\": 1041, \"to\": 1174, \"entities\": [{\"begin\": 1098, \"end\": 1104, \"title\": \"http://dbpedia.org/resource/Monaco\", \"score\": 0.9022989240747147, \"rank\": 0.10828016253804607, \"text\": \"Monaco\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Monaco\", \"dbpedia\": \"http://dbpedia.org/resource/Monaco\"}], \"noun_phrases\": [{\"ngram\": \"the effort\", \"from\": 1060, \"to\": 1070}, {\"ngram\": \"the guys\", \"from\": 1076, \"to\": 1084}, {\"ngram\": \"Snyman\", \"from\": 1167, \"to\": 1173}]}, {\"sentence\": \"\\\"The team missed out on qualifying for the Olympics during the normal series and at the African qualifiers, so the guys who did the job in Monaco deserved the opportunity.\", \"from\": 1176, \"to\": 1347, \"entities\": [{\"begin\": 1315, \"end\": 1321, \"title\": \"http://dbpedia.org/resource/Monaco\", \"score\": 0.9022989240747147, \"rank\": 0.10828016253804607, \"text\": \"Monaco\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Monaco\", \"dbpedia\": \"http://dbpedia.org/resource/Monaco\"}], \"noun_phrases\": [{\"ngram\": \"The team\", \"from\": 1177, \"to\": 1185}, {\"ngram\": \"the Olympics\", \"from\": 1215, \"to\": 1227}, {\"ngram\": \"the normal series\", \"from\": 1235, \"to\": 1252}, {\"ngram\": \"the African qualifiers\", \"from\": 1260, \"to\": 1282}, {\"ngram\": \"the guys\", \"from\": 1287, \"to\": 1295}, {\"ngram\": \"the job\", \"from\": 1304, \"to\": 1311}, {\"ngram\": \"the opportunity\", \"from\": 1331, \"to\": 1346}]}, {\"sentence\": \"\\\"Also, as a team we played really well and with good understanding of each other, so it would have been counterproductive to break that by bringing in different players.\", \"from\": 134