"ngram\": \"whose company\", \"from\": 1821, \"to\": 1834}, {\"ngram\": \"LW Pearl\", \"from\": 1835, \"to\": 1843}, {\"ngram\": \"couture embellishment\", \"from\": 1859, \"to\": 1880}, {\"ngram\": \"her embroidery\", \"from\": 1920, \"to\": 1934}, {\"ngram\": \"her husband's inauguration\", \"from\": 1971, \"to\": 1997}]}, {\"sentence\": \"She has worked with names like Rhianna, Kaia Gerber and Lily Aldridge and also with designers like Marc Jacobs, Proenza Schouler and Thom Browne among others.\", \"from\": 2008, \"to\": 2166, \"entities\": [{\"begin\": 2039, \"end\": 2046, \"title\": \"http://dbpedia.org/resource/Rhianna_Pratchett\", \"score\": 0.9999999999956799, \"rank\": 3.7638813020291935e-12, \"text\": \"Rhianna\", \"types\": [\"Q729\", \"Q5\", \"Q36180\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Rhianna_Pratchett\", \"dbpedia\": \"http://dbpedia.org/resource/Rhianna_Pratchett\"}, {\"begin\": 2048, \"end\": 2059, \"title\": \"http://dbpedia.org/resource/Kaia_Gerber\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Kaia Gerber\", \"types\": [\"Q729\", \"Q5\", \"Q4610556\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kaia_Gerber\", \"dbpedia\": \"http://dbpedia.org/resource/Kaia_Gerber\"}, {\"begin\": 2064, \"end\": 2077, \"title\": \"http://dbpedia.org/resource/Lily_Aldridge\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Lily Aldridge\", \"types\": [\"Q729\", \"Q5\", \"Q4610556\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Lily_Aldridge\", \"dbpedia\": \"http://dbpedia.org/resource/Lily_Aldridge\"}, {\"begin\": 2107, \"end\": 2118, \"title\": \"http://dbpedia.org/resource/Marc_Jacobs\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Marc Jacobs\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q3501317\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Marc_Jacobs\", \"dbpedia\": \"http://dbpedia.org/resource/Marc_Jacobs\"}, {\"begin\": 2120, \"end\": 2136, \"title\": \"http://d