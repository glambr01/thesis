 \"noun_phrases\": [{\"ngram\": \"that nice middle point\", \"from\": 3004, \"to\": 3026}, {\"ngram\": \"volumes\", \"from\": 3064, \"to\": 3071}, {\"ngram\": \"the climbing term\", \"from\": 3073, \"to\": 3090}, {\"ngram\": \"bigger surfaces\", \"from\": 3095, \"to\": 3110}, {\"ngram\": \"tiny footholds\", \"from\": 3147, \"to\": 3161}, {\"ngram\": \"Grupper\", \"from\": 3164, \"to\": 3171}]}, {\"sentence\": \"\\\"A lot of companies have moved toward creating softer shoes for the indoor market, but I like having a stiffer shoe for my quiver.\\\"\", \"from\": 3178, \"to\": 3309, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A lot\", \"from\": 3179, \"to\": 3184}, {\"ngram\": \"companies\", \"from\": 3188, \"to\": 3197}, {\"ngram\": \"softer shoes\", \"from\": 3225, \"to\": 3237}, {\"ngram\": \"the indoor market\", \"from\": 3242, \"to\": 3259}, {\"ngram\": \"a stiffer shoe\", \"from\": 3279, \"to\": 3293}, {\"ngram\": \"my quiver\", \"from\": 3298, \"to\": 3307}]}, {\"sentence\": \"Amazon Armaid In the past few months, Grupper has been dealing with a flexor tendon strain; earlier this year, he had to take a six-week break to allow his hands to recover.\", \"from\": 3313, \"to\": 3488, \"entities\": [{\"begin\": 3313, \"end\": 3319, \"title\": \"http://dbpedia.org/resource/Amazon_Prime_Video\", \"score\": 0.8056766195256114, \"rank\": 0.22760004117775132, \"text\": \"Amazon\", \"types\": [\"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Amazon_Prime_Video\", \"dbpedia\": \"http://dbpedia.org/resource/Amazon_Prime_Video\"}], \"noun_phrases\": [{\"ngram\": \"the past few months\", \"from\": 3330, \"to\": 3349}, {\"ngram\": \"Grupper\", \"from\": 3351, \"to\": 3358}, {\"ngram\": \"a flexor tendon strain\", \"from\": 3381, \"to\": 3403}, {\"ngram\": \"a six-week break\", \"from\": 3439, \"to\": 3455}, {\"ngram\": \"his hands\", \"from\": 3465, \"to\": 3474}]}, {\"sentence\": \"It was stressful, he says, though he is maintaining a positive attitude as Paris gets closer.\", \"from\": 3489, \"to\": 3582, \"entities\": [{\"begin\": 3564, \"end\": 3569, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.6901796978314001e-15, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"a positive attitude\", \"from\": 3541, \"to\": 3560}]}, {\"sentence\": \"\\\"I do not feel like I have to compare myself to others, or want to do that, because I am just trying to figure out where I am at.\", \"from\": 3583, \"to\": 3712, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"others\", \"from\": 3631, \"to\": 3637}]}, {\"sentence\": \"I am not in the best physical shape of my life, and that might change in the next month, but I am just trying to take it day by day.\\\"\", \"from\": 3713, \"to\": 3846, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the best physical shape\", \"from\": 3725, \"to\": 3748}, {\"ngram\": \"my life\", \"from\": 3752, \"to\": 3759}, {\"ngram\": \"the next month\", \"from\": 3786, \"to\": 3800}, {\"ngram\": \"day\", \"from\": 3841, \"to\": 3844}]}, {\"sentence\": \"The Armaid is a small, portable device that lets you massage trigger points-small, pressure-sensitive areas that can carry a lot of pain and stiffness.\", \"from\": 3848, \"to\": 3999, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The Armaid\", \"from\": 3848, \"to\": 3858}, {\"ngram\": \"a small, portable device\", \"from\": 3862, \"to\": 3886}, {\"ngram\": \"trigger\", \"from\": 3909, \"to\": 3916}, {\"ngram\": \"points-small, pressure-sensitive areas\", \"from\": 3917, \"to\": 3955}, {\"ngram\": \"a lot\", \"from\": 3971, \"to\": 3976}, {\"ngram\": \"pain\", \"from\": 3980, \"to\": 3984}]}, {\"sentence\": \"The Armaid consists of a nonskid base, a stationary arm, and an adjustable small arm with small roller balls.\", \"from\": 4000, \"to\": 4109, \"entities\": [], \"noun_phrases\": [{\"