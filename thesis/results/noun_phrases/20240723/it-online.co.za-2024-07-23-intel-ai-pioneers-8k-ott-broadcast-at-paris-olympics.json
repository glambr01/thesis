"{\"uid\": \"it-online.co.za-2024-07-23-intel-ai-pioneers-8k-ott-broadcast-at-paris-olympics\", \"noun_phrases\": [{\"sentence\": \"Jul 23, 2024 Watching live Olympic sport from the comfort of your home in 8K video resolution - the highest broadcast-grade viewing quality - would, before today, have been something of a pipe dream.\", \"from\": 0, \"to\": 200, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"live Olympic sport\", \"from\": 22, \"to\": 40}, {\"ngram\": \"the comfort\", \"from\": 46, \"to\": 57}, {\"ngram\": \"your home\", \"from\": 61, \"to\": 70}, {\"ngram\": \"8K video resolution\", \"from\": 74, \"to\": 93}, {\"ngram\": \"the highest broadcast-grade viewing quality\", \"from\": 96, \"to\": 139}, {\"ngram\": \"today\", \"from\": 156, \"to\": 161}, {\"ngram\": \"something\", \"from\": 173, \"to\": 182}, {\"ngram\": \"a pipe dream\", \"from\": 186, \"to\": 198}]}, {\"sentence\": \"At the Olympic Games Paris 2024, Intel will demonstrate how this vision is already reality thanks to long-standing collaborations among Intel, Olympic Broadcasting Services (OBS), and a handful of broadcasters and partners around the globe.\", \"from\": 202, \"to\": 442, \"entities\": [{\"begin\": 235, \"end\": 240, \"title\": \"http://dbpedia.org/resource/Intel\", \"score\": 1.0, \"rank\": 2.4471321806915276e-17, \"text\": \"Intel\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Intel\", \"dbpedia\": \"http://dbpedia.org/resource/Intel\"}, {\"begin\": 338, \"end\": 343, \"title\": \"http://dbpedia.org/resource/Intel\", \"score\": 1.0, \"rank\": 2.4471321806915276e-17, \"text\": \"Intel\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Intel\", \"dbpedia\": \"http://dbpedia.org/resource/Intel\"}, {\"begin\": 345, \"end\": 374, \"title\": \"http://dbpedia.org/resource/Olympic_Broadcasting_Services\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Olympic Broadcasting Services\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Olympic_Broadcasting_Services\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Broadcasting_Services\"}, {\"begin\": 376, \"end\": 379, \"title\": \"http://dbpedia.org/resource/OBS_Studio\", \"score\": 0.9999950485584834, \"rank\": 4.951465892506799e-06, \"text\": \"OBS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/OBS_Studio\", \"dbpedia\": \"http://dbpedia.org/resource/OBS_Studio\"}], \"noun_phrases\": [{\"ngram\": \"the Olympic Games Paris\", \"from\": 205, \"to\": 228}, {\"ngram\": \"this vision\", \"from\": 262, \"to\": 273}, {\"ngram\": \"reality thanks\", \"from\": 285, \"to\": 299}, {\"ngram\": \"long-standing collaborations\", \"from\": 303, \"to\": 331}, {\"ngram\": \"a handful\", \"from\": 386, \"to\": 395}, {\"ngram\": \"broadcasters\", \"from\": 399, \"to\": 411}, {\"ngram\": \"partners\", \"from\": 416, \"to\": 424}, {\"ngram\": \"the globe\", \"from\": 432, \"to\": 441}]}, {\"sentence\": \"Ravindra (Ravi) Velhal, global content technology strategist and 8K lead in the Software and Advanced Technology Group at Intel, explains the impact of Intel-led artificial intelligence activations at the Olympic Games Paris 2024.\", \"from\": 444, \"to\": 674, \"entities\": [{\"begin\": 454, \"end\": 458, \"title\": \"http://dbpedia.org/resource/Sunday\", \"score\": 0.9884733448470956, \"rank\": 0.011657783254988506, \"text\": \"Ravi\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Sunday\", \"dbpedia\": \"http://dbpedia.org/resource/Sunday\"}, {\"begin\": 537, \"end\": 562, \"title\": \"http://dbpedia.org/resource/Novell\", \"score\": 1.0, \"rank\": 1.776057505688643e-19, \"text\": \"Advanced Technology Group\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Novell\", \"dbpedia\": \"http://dbpedia.org/resource/Novell\"}, {\"begin\": 566, \"end\": 571, \"title\": \"http://dbpedia.org/resource/Intel\", \"score\": 1.0, \"rank\": 2.4471321806915276e-17, \"text\": \"Intel\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Intel\", \"dbpedia\": \"http://dbpedia.org/resource/Intel\"}], \"noun_phrases\": [{\"ngram\": \"global content technology strategist\", \"from\": 468, \"to\": 504}, {\"ngram\": \"8K lead\", \"from\": 509, \"to\": 516}, {\"ngram\": \"the impact\", \"from\": 582, \"to\": 592}, {\"ngram\": \"Intel-led artificial intelligence activations\", \"from\": 596, \"to\": 641}, {\"ngram\": \"the Olympic Games Paris\", \"from\": 645, \"to\": 668}]}, {\"sentence\": \"(Credit: Intel Corporation) As the Official Worldwide AI Platform Partner of the Olympic and Paralympic Games Paris 2024, Intel will introduce new AI experiences based on the company's hardware and software that enable next-generation engagement for fans, organisers, athletes and viewers around the world.\", \"from\": 675, \"to\": 982, \"entities\": [{\"begin\": 730, \"end\": 732, \"title\": \"http://dbpedia.org/resource/AI_accelerator\", \"score\": 0.8997705369182605, \"rank\": 0.11139447111127547, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/AI_accelerator\", \"dbpedia\": \"http://dbpedia.org/resource/AI_accelerator\"}, {\"begin\": 798, \"end\": 803, \"title\": \"http://dbpedia.org/resource/Intel\", \"score\": 1.0, \"rank\": 2.4471321806915276e-17, \"text\": \"Intel\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Intel\", \"dbpedia\": \"http://dbpedia.org/resource/Intel\"}, {\"begin\": 823, \"end\": 825, \"title\": \"http://dbpedia.org/resource/AI_accelerator\", \"score\": 0.8997705369182605, \"rank\": 0.11139447111127547, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/AI_accelerator\", \"dbpedia\": \"http://dbpedia.org/resource/AI_accelerator\"}], \"noun_phrases\": [{\"ngram\": \"(Credit\", \"from\": 675, \"to\": 682}, {\"ngram\": \"Intel Corporation\", \"from\": 684, \"to\": 701}, {\"ngram\": \"the Olympic and Paralympic Games\", \"from\": 752, \"to\": 784}, {\"ngram\": \"Paris\", \"from\": 785, \"to\": 790}, {\"ngram\": \"the company's hardware\", \"from\": 846, \"to\": 868}, {\"ngram\": \"software\", \"from\": 873, \"to\": 881}, {\"ngram\": \"next-generation engagement\", \"from\": 894, \"to\": 920}, {\"ngram\": \"fans\", \"from\": 925, \"to\": 929}, {\"ngram\": \"organisers\", \"from\": 931, \"to\": 941}, {\"ngram\": \"athletes\", \"from\": 943, \"to\": 951}, {\"ngram\": \"viewers\", \"from\": 956, \"to\": 963}, {\"ngram\": \"the world\", \"from\": 971, \"to\": 980}]}, {\"sentence\": \"Throughout the Olympic Games Paris 2024, AI-optimised broadcast servers will encode and compress OBS-produced 8K live signals that OBS will deliver to selected media rights holders across the open Internet.\", \"from\": 984, \"to\": 1190, \"entities\": [{\"begin\": 1115, \"end\": 1118, \"title\": \"http://dbpedia.org/resource/OBS_Studio\", \"score\": 0.9999950485584834, \"rank\": 4.951465892506799e-06, \"text\": \"OBS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/OBS_Studio\", \"dbpedia\": \"http://dbpedia.org/resource/OBS_Studio\"}], \"noun_phrases\": [{\"ngram\": \"the Olympic Games Paris\", \"from\": 995, \"to\": 1018}, {\"ngram\": \"AI-optimised broadcast servers\", \"from\": 1025, \"to\": 1055}, {\"ngram\": \"OBS-produced 8K live signals\", \"from\": 1081, \"to\": 1109}, {\"ngram\": \"selected media rights holders\", \"from\": 1135, \"to\": 1164}, {\"ngram\": \"the open Internet\", \"from\": 1172, \"to\": 1189}]}, {\"sentence\": \"The servers are powered by the latest 5th Gen Intel Xeon processors (Emerald Rapids) and 4th Gen Intel Xeon processors (Sapphire Rapids) with Intel AI accelerator (AMX), and Deep Learning Boost technology.\", \"from\": 1192, \"to\": 1397, \"entities\": [{\"begin\": 1261, \"end\": 1268, \"title\": \"http://dbpedia.org/resource/Emerald\", \"score\": 0.9999999999859028, \"rank\": 1.3904971471161804e-11, \"text\": \"Emerald\", \"types\": [\"Q7946\"], \"wikid\": \"http://dbpedia.org/resource/Emerald\", \"dbpedia\": \"http://dbpedia.org/resource/Emerald\"}, {\"begin\": 1312, \"end\": 1327, \"title\": \"http://dbpedia.org/resource/Sapphire_Rapids\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Sapphire Rapids\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Sapphire_Rapids\", \"dbpedia\": \"http://dbpedia.org/resource/Sapphire_Rapids\"}, {\"begin\": 1334, \"end\": 1339, \"title\": \"http://dbpedia.org/resource/Intel\", \"score\": 1.0, \"rank\": 2.4471321806915276e-17, \"text\": \"Intel\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Intel\", \"dbpedia\": \"http://dbpedia.org/resource/Intel\"}, {\"begin\": 1340, \"end\": 1354, \"title\": \"http://dbpedia.org/resource/AI_accelerator\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"AI accelerator\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/AI_accelerator\", \"dbpedia\": \"http://dbpedia.org/resource/AI_accelerator\"}, {\"begin\": 1356, \"end\": 1359, \"title\": \"http://dbpedia.org/resource/AMC_AMX\", \"score\": 0.8658742668059998, \"rank\": 0.15490101118293323, \"text\": \"AMX\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/AMC_AMX\", \"dbpedia\": \"http://dbpedia.org/resource/AMC_AMX\"}, {\"begin\": 1366, \"end\": 1385, \"title\": \"http://dbpedia.org/resource/DL_Boost\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Deep Learning Boost\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/DL_Boost\", \"dbpedia\": \"http://dbpedia.org/resource/DL_Boost\"}], \"noun_phrases\": [{\"ngram\": \"The servers\", \"from\": 1192, \"to\": 1203}, {\"ngram\": \"the latest 5th Gen\", \"from\": 1219, \"to\": 1237}, {\"ngram\": \"Intel Xeon processors\", \"from\": 1238, \"to\": 1259}, {\"ngram\": \"Intel Xeon processors\", \"from\": 1289, \"to\": 1310}]}, {\"sentence\": \"Compressing that data and decoding it on the other side of the world is by no means a simple feat: Intel is compressing live raw feeds measuring 48 gigabits per second (Gbps) into a VVC-enabled livestream measuring 40 megabits per second (Mbps) to 60Mbps - a compression ratio of 1 000 times - in under 400 milliseconds.\", \"from\": 1399, \"to\": 1719, \"entities\": [{\"begin\": 1498, \"end\": 1503, \"title\": \"http://dbpedia.org/resource/Intel\", \"score\": 1.0, \"rank\": 2.4471321806915276e-17, \"text\": \"Intel\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Intel\", \"dbpedia\": \"http://dbpedia.org/resource/Intel\"}, {\"begin\": 1568, \"end\": 1572, \"title\": \"http://dbpedia.org/resource/Data-rate_units\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Gbps\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Data-rate_units\", \"dbpedia\": \"http://dbpedia.org/resource/Data-rate_units\"}, {\"begin\": 1638, \"end\": 1642, \"title\": \"http://dbpedia.org/resource/Data-rate_units\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Mbps\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Data-rate_units\", \"dbpedia\": \"http://dbpedia.org/resource/Data-rate_units\"}], \"noun_phrases\": [{\"ngram\": \"that data\", \"from\": 1411, \"to\": 1420}, {\"ngram\": \"the other side\", \"from\": 1440, \"to\": 1454}, {\"ngram\": \"the world\", \"from\": 1458, \"to\": 1467}, {\"ngram\": \"no means\", \"from\": 1474, \"to\": 1482}, {\"ngram\": \"a simple feat\", \"from\": 1483, \"to\": 1496}, {\"ngram\": \"live raw feeds\", \"from\": 1519, \"to\": 1533}, {\"ngram\": \"48 gigabits\", \"from\": 1544, \"to\": 1555}, {\"ngram\": \"second\", \"from\": 1560, \"to\": 1566}, {\"ngram\": \"a VVC-enabled livestream\", \"from\": 1579, \"to\": 1603}, {\"ngram\": \"40 megabits\", \"from\": 1614, \"to\": 1625}, {\"ngram\": \"second\", \"from\": 1630, \"to\": 1636}, {\"ngram\": \"a compression ratio\", \"from\": 1656, \"to\": 1675}, {\"ngram\": \"400 milliseconds\", \"from\": 1702, \"to\": 1718}]}, {\"sentence\": \"The 8K over-the-top (OTT) broadcast will then be delivered by OBS around the world to 8K TVs connected to the latest Intel-enabled PCs.\", \"from\": 1721, \"to\": 1856, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the-top\", \"from\": 1733, \"to\": 1740}, {\"ngram\": \"OBS\", \"from\": 1783, \"to\": 1786}, {\"ngram\": \"the world\", \"from\": 1794, \"to\": 1803}, {\"ngram\": \"8K TVs\", \"from\": 1807, \"to\": 1813}, {\"ngram\": \"the latest Intel-enabled PCs\", \"from\": 1827, \"to\": 1855}]}, {\"sentence\": \"Intel has a long history in this space.\", \"from\": 1858, \"to\": 1897, \"entities\": [{\"begin\": 1858, \"end\": 1863, \"title\": \"http://dbpedia.org/resource/Intel\", \"score\": 1.0, \"rank\": 2.4471321806915276e-17, \"text\": \"Intel\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Intel\", \"dbpedia\": \"http://dbpedia.org/resource/Intel\"}], \"noun_phrases\": [{\"ngram\": \"a long history\", \"from\": 1868, \"to\": 1882}, {\"ngram\": \"this space\", \"from\": 1886, \"to\": 1896}]}, {\"sentence\": \"Partnering with OBS, broadcasters and technology providers, Intel has powered OBS to livestream 416 hours of live and recorded Olympic Games content and processed 4,7 petabytes of data at the Olympic Games Tokyo 2020 - about 333-times the volume of all data stored in the US Library of Congress.\", \"from\": 1899, \"to\": 2194, \"entities\": [{\"begin\": 1915, \"end\": 1918, \"title\": \"http://dbpedia.org/resource/OBS_Studio\", \"score\": 0.9999950485584834, \"rank\": 4.951465892506799e-06, \"text\": \"OBS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/OBS_Studio\", \"dbpedia\": \"http://dbpedia.org/resource/OBS_Studio\"}, {\"begin\": 1959, \"end\": 1964, \"title\": \"http://dbpedia.org/resource/Intel\", \"score\": 1.0, \"rank\": 2.4471321806915276e-17, \"text\": \"Intel\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Intel\", \"dbpedia\