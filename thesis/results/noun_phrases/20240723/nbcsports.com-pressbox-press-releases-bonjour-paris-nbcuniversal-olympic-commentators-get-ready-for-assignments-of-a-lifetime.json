gram\": \"a taste\", \"from\": 616, \"to\": 623}, {\"ngram\": \"our commentators\", \"from\": 632, \"to\": 648}, {\"ngram\": \"history\", \"from\": 721, \"to\": 728}, {\"ngram\": \"the Olympics\", \"from\": 734, \"to\": 746}, {\"ngram\": \"history\", \"from\": 751, \"to\": 758}]}, {\"sentence\": \"When you get a chance to witness it, to me, that's the most exciting thing you can do in sports.\", \"from\": 764, \"to\": 860, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a chance\", \"from\": 777, \"to\": 785}, {\"ngram\": \"the most exciting thing\", \"from\": 815, \"to\": 838}, {\"ngram\": \"sports\", \"from\": 853, \"to\": 859}]}, {\"sentence\": \"I have been to NBA games, World Cup finals, Super Bowls, and that's always part of the thrill - witnessing history.\", \"from\": 861, \"to\": 976, \"entities\": [{\"begin\": 876, \"end\": 879, \"title\": \"http://dbpedia.org/resource/National_Basketball_Association\", \"score\": 0.997602688403609, \"rank\": 0.002403002129804642, \"text\": \"NBA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/National_Basketball_Association\", \"dbpedia\": \"http://dbpedia.org/resource/National_Basketball_Association\"}], \"noun_phrases\": [{\"ngram\": \"World Cup finals\", \"from\": 887, \"to\": 903}, {\"ngram\": \"Super Bowls\", \"from\": 905, \"to\": 916}, {\"ngram\": \"part\", \"from\": 936, \"to\": 940}, {\"ngram\": \"the thrill - witnessing history\", \"from\": 944, \"to\": 975}]}, {\"sentence\": \"It's great to be able to say that you were there when something happened.\", \"from\": 977, \"to\": 1050, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"something\", \"from\": 1031, \"to\": 1040}]}, {\"sentence\": \"There is going to be lots of history in Paris, that's for sure, and certainly in track & field.\\\"\", \"from\": 1051, \"to\": 1147, \"entities\": [{\"begin\": 1091, \"end\": 1096, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 2.99615587488445e-17, \"text\": \"Paris\", \"types\":