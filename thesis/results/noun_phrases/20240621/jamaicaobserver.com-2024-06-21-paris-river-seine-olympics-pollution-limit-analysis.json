"{\"uid\": \"jamaicaobserver.com-2024-06-21-paris-river-seine-olympics-pollution-limit-analysis\", \"noun_phrases\": [{\"sentence\": \"PARIS, France (AFP) - Paris' river Seine was too dirty when tested on June 16 to allow the Olympic triathlon and open-water swimming events to be held there, an analysis showed Friday.\", \"from\": 0, \"to\": 184, \"entities\": [{\"begin\": 7, \"end\": 13, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9979524944218232, \"rank\": 0.0019072167392134378, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 22, \"end\": 27, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999306768383, \"rank\": 6.932320075440546e-08, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 35, \"end\": 40, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999979341810978, \"rank\": 1.898406020582049e-06, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"PARIS\", \"from\": 0, \"to\": 5}, {\"ngram\": \"AFP\", \"from\": 15, \"to\": 18}, {\"ngram\": \"June\", \"from\": 70, \"to\": 74}, {\"ngram\": \"the Olympic triathlon\", \"from\": 87, \"to\": 108}, {\"ngram\": \"open-water swimming events\", \"from\": 113, \"to\": 139}, {\"ngram\": \"an analysis\", \"from\": 158, \"to\": 169}]}, {\"sentence\": \"\\\"Samples from the Seine do not meet the standards we will have this summer\\\" for the river when the Olympic Games are held from July 26 to August 11, Paris region prefect Marc Guillaume said.\", \"from\": 186, \"to\": 376, \"entities\": [{\"begin\": 204, \"end\": 209, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999979341810978, \"rank\":