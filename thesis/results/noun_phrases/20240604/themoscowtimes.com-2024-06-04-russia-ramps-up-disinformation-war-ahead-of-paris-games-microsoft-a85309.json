rom\": 147, \"to\": 155}, {\"ngram\": \"this summer's games\", \"from\": 159, \"to\": 178}, {\"ngram\": \"a new report\", \"from\": 202, \"to\": 214}]}, {\"sentence\": \"According to Microsoft, the influence operations use a potent mix of fake videos, fictitious news stories, and AI-generated impersonations, including the faked voice of Hollywood star Tom Cruise.\", \"from\": 257, \"to\": 452, \"entities\": [{\"begin\": 270, \"end\": 279, \"title\": \"http://dbpedia.org/resource/Microsoft\", \"score\": 0.9999826952854419, \"rank\": 1.72578552682712e-05, \"text\": \"Microsoft\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Microsoft\", \"dbpedia\": \"http://dbpedia.org/resource/Microsoft\"}, {\"begin\": 426, \"end\": 435, \"title\": \"http://dbpedia.org/resource/Cinema_of_the_United_States\", \"score\": 0.9999999999809006, \"rank\": 1.8991019300473455e-11, \"text\": \"Hollywood\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Cinema_of_the_United_States\", \"dbpedia\": \"http://dbpedia.org/resource/Cinema_of_the_United_States\"}, {\"begin\": 441, \"end\": 451, \"title\": \"http://dbpedia.org/resource/Tom_Cruise\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Tom Cruise\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Tom_Cruise\", \"dbpedia\": \"http://dbpedia.org/resource/Tom_Cruise\"}], \"noun_phrases\": [{\"ngram\": \"the influence operations\", \"from\": 281, \"to\": 305}, {\"ngram\": \"a potent mix\", \"from\": 310, \"to\": 322}, {\"ngram\": \"fake videos\", \"from\": 326, \"to\": 337}, {\"ngram\": \"fictitious news stories\", \"from\": 339, \"to\": 362}, {\"ngram\": \"AI-generated impersonations\", \"from\": 368, \"to\": 395}, {\"ngram\": \"the faked voice\", \"from\": 407, \"to\": 422}]}, {\"sentence\": \"\\\"Russia is ramping up these malign campaigns against France, President (Emmanuel) Macron, the IOC, and the Paris Olympics,\\\" said Clint Watts, general manager of the Microsoft Threat Analysis Center, in a blog post Sunday.\", \"from\": 454, \"to\": 675, \"entities\": [{\"begin\": 455, \"end\": 461, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999999993906385, \"rank\": 3.910248679898894e-10, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}, {\"begin\": 507, \"end\": 513, \"title\": \"http://dbpedia.org/resource/French_Third_Republic\", \"score\": 0.9154083345484588, \"rank\": 0.09188263285757668, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/French_Third_Republic\", \"dbpedia\": \"http://dbpedia.org/resource/French_Third_Republic\"}, {\"begin\": 526, \"end\": 534, \"title\": \"http://dbpedia.org/resource/Immanuel\", \"score\": 0.998130267421205, \"rank\": 0.0018731456544703506, \"text\": \"Emmanuel\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Immanuel\", \"dbpedia\": \"http://dbpedia.org/resource/Immanuel\"}, {\"begin\": 536, \"end\": 542, \"title\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"score\": 1.0, \"rank\": 1.3056375327829387e-28, \"text\": \"Macron\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"dbpedia\": \"http://dbpedia.org/resource/Emmanuel_Macron\"}, {\"begin\": 548, \"end\": 551, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 6.7677901684527945e-22, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 583, \"end\": 594, \"title\": \"http://dbpedia.org/resource/Clint_Watts\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Clint Watts\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Clint_Watts\", \"dbpedia\": \"http://dbpedia.org/resource/Clint_Watts\"}, {\"begin\": 619, \"end\": 628, \"title\": \"http://dbpedia.org/resource/Microsoft\", \"score\": 0.9999826952854419, \"rank\": 1.72578552682712e-05, \"text\": \"Microsoft\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Microsoft\", \"dbpedia\": \"http://dbpedia.org/resource/Microsoft\"}], \"noun_phrases\": [{\"ngram\": \"these malign campaigns\", \"from\": 476, \"to\": 498}, {\"ngram\": \"the Paris Olympics\", \"from\": 557, \"to\": 575}, {\"ngram\": \"general manager\", \"from\": 596, \"to\": 611}, {\"ngram\": \"a blog post\", \"from\": 656, \"to\": 667}]}, {\"sentence\": \"\\\"While Russia has a decades-long history of targeting the Olympic Games, the Microsoft Threat Analysis Center has observed old tactics blending with artificial intelligence...that may intensify as the 2024 Paris opening ceremony approaches,\\\" he added.\", \"from\": 677, \"to\": 928, \"entities\": [{\"begin\": 684, \"end\": 690, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999999993906385, \"rank\": 3.910248679898894e-10, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}], \"noun_phrases\": [{\"ngram\": \"a decades-long history\", \"from\": 695, \"to\": 717}, {\"ngram\": \"the Olympic Games\", \"from\": 731, \"to\": 748}, {\"ngram\": \"the Microsoft Threat Analysis Center\", \"from\": 750, \"to\": 786}, {\"ngram\": \"old tactics\", \"from\": 800, \"to\": 811}, {\"ngram\": \"artificial intelligence\", \"from\": 826, \"to\": 849}]}, {\"sentence\": \"The report revealed that two prolific Russian cyber-actor groups, Storm-1679 and Doppelganger, have pivoted operations over the past year to target the Olympics directly.\", \"from\": 930, \"to\": 1100, \"entities\": [{\"begin\": 968, \"end\": 975, \"title\": \"http://dbpedia.org/resource/Russian_language\", \"score\": 0.9682496941559986, \"rank\": 0.03138645404003232, \"text\": \"Russian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Russian_language\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_language\"}, {\"begin\": 1011, \"end\": 1023, \"title\": \"http://dbpedia.org/resource/Doppelg\\u00e4nger\", \"score\": 0.8428834733004595, \"rank\": 0.0809302325581545, \"text\": \"Doppelganger\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Doppelg\\u00e4nger\", \"dbpedia\": \"http://dbpedia.org/resource/Doppelg\\u00e4nger\"}], \"noun_phrases\": [{\"ngram\": \"The report\", \"from\": 930, \"to\": 940}, {\"ngram\": \"Storm-1679\", \"from\": 996, \"to\": 1006}, {\"ngram\": \"operations\", \"from\": 1038, \"to\": 1048}, {\"ngram\": \"the past year\", \"from\": 1054, \"to\": 1067}, {\"ngram\": \"the Olympics\", \"from\": 1078, \"to\": 1090}]}, {\"sentence\": \"Their malicious activities escalated in June 2023 with the release on Telegram of a feature-length fake documentary titled \\\"Olympics Has Fallen.\\\"\", \"from\": 1102, \"to\": 1247, \"entities\": [{\"begin\": 1172, \"end\": 1180, \"title\": \"http://dbpedia.org/resource/Telegraphy\", \"score\": 1.0, \"rank\": 4.457113314152149e-16, \"text\": \"Telegram\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Telegraphy\", \"dbpedia\": \"http://dbpedia.org/resource/Telegraphy\"}], \"noun_phrases\": [{\"ngram\": \"Their malicious activities\", \"from\": 1102, \"to\": 1128}, {\"ngram\": \"June\", \"from\": 1142, \"to\": 1146}, {\"ngram\": \"the release\", \"from\": 1157, \"to\": 1168}, {\"ngram\": \"a feature-length fake documentary\", \"from\": 1184, \"to\": 1217}, {\"ngram\": \"\\\"Olympics\", \"from\": 1225, \"to\": 1234}, {\"ngram\": \"Has Fallen\", \"from\": 1235, \"to\": 1245}]}, {\"sentence\": \"Using AI-generated audio impersonating \\\"Top Gun\\\" actor Cruise, slick computer graphics, and a sophisticated marketing rollout, the film disparages the IOC in an apparent bid to erode global public support of the Games.\", \"from\": 1249, \"to\": 1467, \"entities\": [{\"begin\": 1400, \"end\": 1403, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 6.7677901684527945e-22, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"AI-generated audio\", \"from\": 1255, \"to\": 1273}, {\"ngram\": \"\\\"Top Gun\\\" actor Cruise\", \"from\": 1288, \"to\": 1310}, {\"ngram\": \"slick computer graphics\", \"from\": 1312, \"to\": 1335}, {\"ngram\": \"a sophisticated marketing rollout\", \"from\": 1341, \"to\": 1374}, {\"ngram\": \"the film\", \"from\": 1376, \"to\": 1384}, {\"ngram\": \"an apparent bid\", \"from\": 1407, \"to\": 1422}, {\"ngram\": \"global public support\", \"from\": 1432, \"to\": 1453}, {\"ngram\": \"the Games\", \"from\": 1457, \"to\": 1466}]}, {\"sentence\": \"Storm-1679 has also repeatedly produced and amplified fictionalized news clips, videos and press statements falsely claiming that fears of terrorism have sparked a wave of ticket cancellations and property insurance purchases among Parisians.\", \"from\": 1469, \"to\": 1711, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Storm-1679\", \"from\": 1469, \"to\": 1479}, {\"ngram\": \"fictionalized news clips\", \"from\": 1523, \"to\": 1547}, {\"ngram\": \"videos\", \"from\": 1549, \"to\": 1555}, {\"ngram\": \"press statements\", \"from\": 1560, \"to\": 1576}, {\"ngram\": \"fears\", \"from\": 1599, \"to\": 1604}, {\"ngram\": \"terrorism\", \"from\": 1608, \"to\": 1617}, {\"ngram\": \"a wave\", \"from\": 1631, \"to\": 1637}, {\"ngram\": \"ticket cancellations\", \"from\": 1641, \"to\": 1661}, {\"ngram\": \"property insurance purchases\", \"from\": 1666, \"to\": 1694}, {\"ngram\": \"Parisians\", \"from\": 1701, \"to\": 1710}]}, {\"sentence\": \"Meanwhile, threat group Doppelganger intensified anti-Olympics messaging across its network of 15 disinformation websites and forged content claiming to be from French news outlets, like Le Parisien, to smear Macron.\", \"from\": 1713, \"to\": 1929, \"entities\": [{\"begin\": 1874, \"end\": 1880, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9922365371569145, \"rank\": 0.006843889257448563, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 1900, \"end\": 1911, \"title\": \"http://dbpedia.org/resource/Le_Parisien\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Le Parisien\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/Le_Parisien\", \"dbpedia\": \"http://dbpedia.org/resource/Le_Parisien\"}, {\"begin\": 1922, \"end\": 1928, \"title\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"score\": 1.0, \"rank\": 1.3056375327829387e-28, \"text\": \"Macron\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"dbpedia\": \"http://dbpedia.org/resource/Emmanuel_Macron\"}], \"noun_phrases\": [{\"ngram\": \"threat group\", \"from\": 1724, \"to\": 1736}, {\"ngram\": \"Doppelganger\", \"from\": 1737, \"to\": 1749}, {\"ngram\": \"anti-Olympics\", \"from\": 1762, \"to\": 1775}, {\"ngram\": \"its network\", \"from\": 1793, \"to\": 1804}, {\"ngram\": \"15 disinformation websites\", \"from\": 1808, \"to\": 1834}, {\"ngram\": \"forged content\", \"from\": 1839, \"to\": 1853}]}, {\"sentence\": \"Microsoft said it suspected that Russian groups were also behind the circulation of fake images of graffiti threatening a repeat of the 1972 Munich Olympic massacre of Israeli athletes by Palestinian militants.\", \"from\": 1933, \"to\": 2143, \"entities\": [{\"begin\": 1933, \"end\": 1942, \"title\": \"http://dbpedia.org/resource/Microsoft\", \"score\": 0.9999826952854419, \"rank\": 1.72578552682712e-05, \"text\": \"Microsoft\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Microsoft\", \"dbpedia\": \"http://dbpedia.org/resource/Microsoft\"}, {\"begin\": 1966, \"end\": 1973, \"title\": \"http://dbpedia.org/resource/Russian_language\", \"score\": 0.9682496941559986, \"rank\": 0.03138645404003232, \"text\": \"Russian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Russian_language\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_language\"}, {\"begin\": 2074, \"end\": 2097, \"title\": \"http://dbpedia.org/resource/Munich_massacre\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Munich Olympic massacre\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Munich_massacre\", \"dbpedia\": \"http://dbpedia.org/resource/Munich_massacre\"}, {\"begin\": 2101, \"end\": 2108, \"title\": \"http://dbpedia.org/resource/Israel_Defense_Forces\", \"score\": 0.7930191792312876, \"rank\": 0.23062224789610944, \"text\": \"Israeli\", \"types\": [\"Q43229\", \"Q24229398\", \"Q176799\"], \"wikid\": \"http://dbpedia.org/resource/Israel_Defense_Forces\", \"dbpedia\": \"http://dbpedia.org/resource/Israel_Defense_Forces\"}, {\"begin\": 2121, \"end\": 2142, \"title\": \"http://dbpedia.org/resource/Hamas\", \"score\": 0.9998676641249442, \"rank\": 0.00012451632222845702, \"text\": \"Palestinian militants\", \"types\": [\"Q7278\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Hamas\", \"dbpedia\": \"http://dbpedia.org/resource/Hamas\"}], \"noun_phrases\": [{\"ngram\": \"the circulation\", \"from\": 1998, \"to\": 2013}, {\"ngram\": \"fake images\", \"from\": 2017, \"to\": 2028}, {\"ngram\": \"graffiti\", \"from\": 2032, \"to\": 2040}, {\"ngram\": \"a repeat\", \"from\": 2053, \"to\": 2061}]}, {\"sentence\": \"As the July 26 Opening Ceremony looms, Microsoft anticipates the Russian disinformation blitz will intensify across more languages and media formats.\", \"from\": 2145, \"to\": 2294, \"entities\": [{\"begin\": 2184, \"end\": 2193, \"title\": \"http://dbpedia.org/resource/Microsoft\", \"score\": 0.9999826952854419, \"rank\": 1.72578552682712e-05, \"text\": \"Microsoft\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Microsoft\", \"dbpedia\": \"http://dbpedia.org/resource/Microsoft\"}, {\"begin\": 2210, \"end\": 2232, \"title\": \"http://dbpedia.org/resource/Russian_interference_in_the_2020_United_States_elections\", \"score\": 0.8334671456109366, \"rank\": 0.1998073412564216, \"text\": \"Russian disinformation\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Russian_interference_in_the_2020_United_States_elections\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_interference_in_the_2020_United_States_elections\"}], \"noun_phrases\": [{\"ngram\": \"the July 26 Opening Ceremony\", \"from\": 2148, \"to\": 2176}, {\"ngram\": \"more languages\", \"from\": 2261, \"to\": 2275}, {\"ngram\": \"media formats\", \"from\": 2280, \"to\": 2293}]}, {\"sentence\": \"Watts warned the campaigns could even attempt real-world provocations near Olympic venues to sow further chaos.\", \"from\": 2296, \"to\": 2407, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Watts\", \"from\": 2296, \"to\": 2301}, {\"ngram\": \"the campaigns\", \"from\": 2309, \"to\": 2322}, {\"ngram\": \"real-world provocations\", \"from\": 2342, \"to\": 2365}, {\"ngram\": \"Olympic venues\", \"from\": 2371, \"to\": 2385}, {\"ngram\": \"further chaos\", \"from\": 2393, \"to\": 2406}]}, {\"sentence\": \"The campaign is not unexpected.\", \"from\": 2409, \"to\": 2440, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The campaign\", \"from\": 2409, \"to\": 2421}]}, {\"sentence\": \"Macron in April said he had \\\"no doubt\\\" Russia was targeting the Paris Olympics, including with disinformation.\", \"from\": 2442, \"to\": 2552, \"entities\": [{\"begin\": 2442, \"end\": 2448, \"title\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"score\": 1.0, \"rank\": 1.3056375327829387e-28, \"text\": \"Macron\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"dbpedia\": \"http://dbpedia.org/resource/Emmanuel_Macron\"}, {\"begin\": 2481, \"end\": 2487, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999999993906385, \"rank\": 3.910248679898894e-10, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}], \"noun_phrases\": [{\"ngram\": \"April\", \"from\": 2452, \"to\": 2457}, {\"ngram\": \"the Paris Olympics\", \"from\": 2502, \"to\": 2520}, {\"ngram\": \"disinformation\", \"from\": 2537, \"to\": 2551}]}, {\"sentence\": \"The Kremlin \\\"is feeding every day the idea that we can not do this or that, that there is a risk,\\\" he said.\", \"from\": 2554, \"to\": 2661, \"entities\": [{\"begin\": 2558, \"end\": 2565, \"title\": \"http://dbpedia.org/resource/Government_of_Russia\", \"score\": 0.9972655415947128, \"rank\": 0.0027419561702408343, \"text\": \"Kremlin\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Government_of_Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Government_of_Russia\"}], \"noun_phrases\": [{\"ngram\": \"a risk\", \"from\": 2644, \"to\": 2650}]}, {\"sentence\": \"The Kremlin dismissed the \\\"absolute slander\\\".\", \"from\": 2663, \"to\": 2708, \"entities\": [{\"begin\": 2667, \"end\": 2674, \"title\": \"http://dbpedia.org/resource/Government_of_Russia\", \"score\": 0.9972655415947128, \"rank\": 0.0027419561702408343, \"text\": \"Kremlin\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Government_of_Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Government_of_Russia\"}], \"noun_phrases\": [{\"ngram\": \"the \\\"absolute slander\", \"from\": 2685, \"to\": 2706}]}, {\"sentence\": \"\\\"This constitutes absolute slander and nothing more.\", \"from\": 2710, \"to\": 2762, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"absolute slander\", \"from\": 2728, \"to\": 2744}, {\"ngram\": \"nothing\", \"from\": 2749, \"to\": 2756}]}, {\"sentence\": \"It has nothing to do with reality,\\\" Kremlin spokesman Dmitry Peskov told reporters.\", \"from\": 2763, \"to\": 2846, \"entities\": [{\"begin\": 2799, \"end\": 2806, \"title\": \"http://dbpedia.org/resource/Government_of_Russia\", \"score\": 0.9972655415947128, \"rank\": 0.0027419561702408343, \"text\": \"Kremlin\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Government_of_Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Government_of_Russia\"}, {\"begin\": 2817, \"end\": 2830, \"title\": \"http://dbpedia.org/resource/Dmitry_Peskov\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Dmitry Peskov\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Dmitry_Peskov\", \"dbpedia\": \"http://dbpedia.org/resource/Dmitry_Peskov\"}], \"noun_phrases\": [{\"ngram\": \"nothing\", \"from\": 2770, \"to\": 2777}, {\"ngram\": \"reality\", \"from\": 2789, \"to\": 2796}, {\"ngram\": \"reporters\", \"from\": 2836, \"to\": 2845}]}, {\"sentence\": \"A Message from The Moscow Times: Dear readers, We are facing unprecedented challenges.\", \"from\": 2848, \"to\": 2936, \"entities\": [{\"begin\": 2863, \"end\": 2879, \"title\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"The Moscow Times\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"dbpedia\": \"http://dbpedia.org/resource/The_Moscow_Times\"}], \"noun_phrases\": [{\"ngram\": \"Dear readers\", \"from\": 2881, \"to\": 2893}, {\"ngram\": \"unprecedented challenges\", \"from\": 2909, \"to\": 2933}]}, {\"sentence\": \"Russia's Prosecutor General's Office has d