49}]}, {\"sentence\": \"Meanwhile, other countries such asMongolia, Haiti, and Czech Republic designed their opening ceremony uniforms with ques to their time-honored traditions woven throughout.\", \"from\": 1652, \"to\": 1823, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"other countries\", \"from\": 1663, \"to\": 1678}, {\"ngram\": \"their opening ceremony uniforms\", \"from\": 1731, \"to\": 1762}, {\"ngram\": \"ques\", \"from\": 1768, \"to\": 1772}, {\"ngram\": \"their time-honored traditions\", \"from\": 1776, \"to\": 1805}]}, {\"sentence\": \"Designers implemented purposeful threading and careful textile selection, ensuring aspects of each team's national heritage are apparent.\", \"from\": 1824, \"to\": 1961, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Designers\", \"from\": 1824, \"to\": 1833}, {\"ngram\": \"purposeful threading\", \"from\": 1846, \"to\": 1866}, {\"ngram\": \"careful textile selection\", \"from\": 1871, \"to\": 1896}, {\"ngram\": \"aspects\", \"from\": 1907, \"to\": 1914}, {\"ngram\": \"each team's national heritage\", \"from\": 1918, \"to\": 1947}]}, {\"sentence\": \"Here are six of the most interesting Paris 2024 Olympic opening ceremony uniforms.\", \"from\": 1963, \"to\": 2045, \"entities\": [{\"begin\": 2000, \"end\": 2010, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 0.9999999999977263, \"rank\": 2.2867863015992153e-12, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}], \"noun_phrases\": []}, {\"sentence\": \"Mongolia Treasured designers Michel Choigaalaa and Amazonka Choigaalaa craftedMongolia's Olympic uniformsfor the third time.\", \"from\": 2047, \"to\": 2172, \"entities\": [{\"begin\": 2047, \"end\": 2055, \"title\": \"http://dbpedia.org/resource/Mongolia\", \"score\": 0.9999999999990905, \"rank\": 8.369631274671225e-13, \"text\": \"Mongolia\", \"types\":