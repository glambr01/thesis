s\": [{\"ngram\": \"every sport\", \"from\": 6968, \"to\": 6979}, {\"ngram\": \"another\", \"from\": 7017, \"to\": 7024}]}, {\"sentence\": \"In Paris, the Yorkshire rider is hoping to double up in the mountain bike race and then the road race.\", \"from\": 7027, \"to\": 7129, \"entities\": [{\"begin\": 7030, \"end\": 7035, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 5.467021451949361e-27, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 7041, \"end\": 7056, \"title\": \"http://dbpedia.org/resource/Yorkshire_Rider\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Yorkshire rider\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Yorkshire_Rider\", \"dbpedia\": \"http://dbpedia.org/resource/Yorkshire_Rider\"}], \"noun_phrases\": [{\"ngram\": \"the mountain bike race\", \"from\": 7083, \"to\": 7105}, {\"ngram\": \"and then the road race\", \"from\": 7106, \"to\": 7128}]}, {\"sentence\": \"He won gold at Colline d'\\u00c9lancourt on Sunday, with that audacious late attack after fighting back from a puncture.\", \"from\": 7130, \"to\": 7244, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"gold\", \"from\": 7137, \"to\": 7141}, {\"ngram\": \"Colline d'\\u00c9lancourt\", \"from\": 7145, \"to\": 7164}, {\"ngram\": \"Sunday\", \"from\": 7168, \"to\": 7174}, {\"ngram\": \"that audacious late attack\", \"from\": 7181, \"to\": 7207}, {\"ngram\": \"a puncture\", \"from\": 7233, \"to\": 7243}]}, {\"sentence\": \"He is perhaps an outsider for the road race but has the talent to win two medals.\", \"from\": 7246, \"to\": 7327, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an outsider\", \"from\": 7260, \"to\": 7271}, {\"ngram\": \"the road race\", \"from\": 7276, \"to\": 7289}, {\"ngram\": \"the talent\", \"from\": 7298, \"to\": 7308}, {\"ngram\": \"two medals\", \"from\": 7316, \"to\": 7326}]}, {\"sentence\": \"He left the Tour de France due to COVID-19 but had time to recover and prepare for Paris.\", \"from\": 7329, \"to\": 7418, \"entities\": [{\"begin\": 7341, \"end\": 7355, \"title\": \"http://dbpedia.org/resource/Tour_de_France\", \"score\": 0.9999999992924131, \"rank\": 7.075281810730647e-10, \"text\": \"Tour de France\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tour_de_France\", \"dbpedia\": \"http://dbpedia.org/resource/Tour_de_France\"}, {\"begin\": 7363, \"end\": 7371, \"title\": \"http://dbpedia.org/resource/COVID-19_pandemic\", \"score\": 0.9999999999718057, \"rank\": 2.7809857303247366e-11, \"text\": \"COVID-19\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/COVID-19_pandemic\", \"dbpedia\": \"http://dbpedia.org/resource/COVID-19_pandemic\"}, {\"begin\": 7412, \"end\": 7417, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 5.467021451949361e-27, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"time\", \"from\": 7380, \"to\": 7384}]}, {\"sentence\": \"He is part of a strong Great Britain team that includes Ethan Hayter, Josh Tarling, Fred Wright and Stevie Williams.\", \"from\": 7419, \"to\": 7535, \"entities\": [{\"begin\": 7475, \"end\": 7487, \"title\": \"http://dbpedia.org/resource/Ethan_Hayter\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Ethan Hayter\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Ethan_Hayter\", \"dbpedia\": \"http://dbpedia.org/resource/Ethan_Hayter\"}, {\"begin\": 7489, \"end\": 7493, \"title\": \"http://dbpedia.org/resource/Josh_Ashworth\", \"score\": 0.9813050182529458, \"rank\": 0.01564753616242407, \"text\": \"Josh\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Josh_Ashworth\", \"dbpedia\": \"http://dbpedia.org/resource/Josh_Ashworth\"}, {\"begin\": 7503, \"end\": 7514, \"t