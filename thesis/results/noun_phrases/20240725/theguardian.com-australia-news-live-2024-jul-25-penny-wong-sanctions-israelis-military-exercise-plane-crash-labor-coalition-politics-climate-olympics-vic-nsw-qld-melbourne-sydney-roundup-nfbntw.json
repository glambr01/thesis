3}, {\"ngram\": \"this error\", \"from\": 5646, \"to\": 5656}, {\"ngram\": \"any hardship\", \"from\": 5661, \"to\": 5673}, {\"ngram\": \"challenges\", \"from\": 5675, \"to\": 5685}, {\"ngram\": \"stress\", \"from\": 5690, \"to\": 5696}]}, {\"sentence\": \"We value all our staff and the vital contribution they make to our operations as a world-class university and are deeply sorry that some staff have been impacted by this error.\", \"from\": 5720, \"to\": 5896, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"all our staff\", \"from\": 5729, \"to\": 5742}, {\"ngram\": \"the vital contribution\", \"from\": 5747, \"to\": 5769}, {\"ngram\": \"our operations\", \"from\": 5783, \"to\": 5797}, {\"ngram\": \"a world-class university\", \"from\": 5801, \"to\": 5825}, {\"ngram\": \"some staff\", \"from\": 5852, \"to\": 5862}, {\"ngram\": \"this error\", \"from\": 5885, \"to\": 5895}]}, {\"sentence\": \"ANU is taking immediate and comprehensive action to remedy this situation and to ensure it does not happen again.\", \"from\": 5898, \"to\": 6011, \"entities\": [{\"begin\": 5898, \"end\": 5901, \"title\": \"http://dbpedia.org/resource/Australian_National_University\", \"score\": 1.0, \"rank\": 6.005308012187671e-15, \"text\": \"ANU\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/Australian_National_University\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_National_University\"}], \"noun_phrases\": [{\"ngram\": \"immediate and comprehensive action\", \"from\": 5912, \"to\": 5946}, {\"ngram\": \"this situation\", \"from\": 5957, \"to\": 5971}]}, {\"sentence\": \"The university has voluntarily notified the Fair Work Ombudsman of the error, it said.\", \"from\": 6013, \"to\": 6099, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The university\", \"from\": 6013, \"to\": 6027}, {\"ngram\": \"the Fair Work Ombudsman\", \"from\": 6053, \"to\": 6076}, {\"ngram\": \"the error\", \"from\": 6080, \"to\": 6089}]}, {\"sentence\": \"Many thanks for joining me on the blog today,Nino Bucciwill be here to take you through the rest of our rolling coverage.\", \"from\": 6101, \"to\": 6222, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the blog\", \"from\": 6131, \"to\": 6139}, {\"ngram\": \"Nino Bucciwill\", \"from\": 6146, \"to\": 6160}, {\"ngram\": \"the rest\", \"from\": 6189, \"to\": 6197}, {\"ngram\": \"our rolling coverage\", \"from\": 6201, \"to\": 6221}]}, {\"sentence\": \"Take care.\", \"from\": 6223, \"to\": 6233, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"care\", \"from\": 6228, \"to\": 6232}]}, {\"sentence\": \"TheBureau of Meteorologyhas issued a severe weather update, with damaging winds expected to continue about the south-east of the country: Severe Weather Update: Strong to damaging winds to continue for south-east Australia.Video current: 1:00pm AEST 25 July 2024For the latest forecasts and warnings go to our websitehttps://t.co/4W35o8iFmhor the BOM Weather app.pic.twitter.com/vPpWSYjb0J Call for 'battery passport' for electric cars amid recycling crisis Australia's battery recycling industry is in \\\"crisis\\\" and unprepared for an influx of electric vehicles once they reach the end of their lives, a federal inquiry has been told.\", \"from\": 6235, \"to\": 6872, \"entities\": [{\"begin\": 6481, \"end\": 6485, \"title\": \"http://dbpedia.org/resource/Time_in_Australia\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"AEST\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Time_in_Australia\", \"dbpedia\": \"http://dbpedia.org/resource/Time_in_Australia\"}, {\"begin\": 6696, \"end\": 6705, \"title\": \"http://dbpedia.org/resource/Australia\", \"score\": 0.990706101962783, \"rank\": 0.009381084884001698, \"text\": \"Australia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Australia\", \"dbpedia\": \"http://dbpedia.org/resource/Australia\"}], \"noun_phrases\": [{\"ngram\": \"TheBureau\", \"from\": 6235, \"to\": 6244}, {\"ngram\": \"Meteorologyhas\", \"from\": 6248, \"to\": 6262}, {\"ngram\": \"a severe weather update\", \"from\": 6270, \"to\": 6293}, {\"ngram\": \"damaging winds\", \"from\": 6300, \"to\": 6314}, {\"ngram\": \"the south-east\", \"from\": 6342, \"to\": 6356}, {\"ngram\": \"the country\", \"from\": 6360, \"to\": 6371}, {\"ngram\": \"Severe Weather Update\", \"from\": 6373, \"to\": 6394}, {\"ngram\": \"winds\", \"from\": 6415, \"to\": 6420}, {\"ngram\": \"south-east Australia\", \"from\": 6437, \"to\": 6457}, {\"ngram\": \"Video current\", \"from\": 6458, \"to\": 6471}, {\"ngram\": \"the latest forecasts\", \"from\": 6501, \"to\": 6521}, {\"ngram\": \"warnings\", \"from\": 6526, \"to\": 6534}, {\"ngram\": \"our websitehttps://t.co/4W35o8iFmhor\", \"from\": 6541, \"to\": 6577}, {\"ngram\": \"Call\", \"from\": 6625, \"to\": 6629}, {\"ngram\": \"battery passport\", \"from\": 6635, \"to\": 6651}, {\"ngram\": \"electric cars\", \"from\": 6657, \"to\": 6670}, {\"ngram\": \"\\\"crisis\", \"from\": 6738, \"to\": 6745}, {\"ngram\": \"an influx\", \"from\": 6766, \"to\": 6775}, {\"ngram\": \"electric vehicles\", \"from\": 6779, \"to\": 6796}, {\"ngram\": \"the end\", \"from\": 6813, \"to\": 6820}, {\"ngram\": \"their lives\", \"from\": 6824, \"to\": 6835}, {\"ngram\": \"a federal inquiry\", \"from\": 6837, \"to\": 6854}]}, {\"sentence\": \"AsAAPreports, automotive and recycling industry representatives issued the warning today at the Transition to Electric Vehicles inquiry in Sydney, which also heard calls for a \\\"battery passport\\\" for electric cars, similar to efforts in Europe.\", \"from\": 6874, \"to\": 7117, \"entities\": [{\"begin\": 7013, \"end\": 7019, \"title\": \"http://dbpedia.org/resource/Sydney\", \"score\": 0.9998017862363155, \"rank\": 0.00019825300195628918, \"text\": \"Sydney\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Sydney\", \"dbpedia\": \"http://dbpedia.org/resource/Sydney\"}], \"noun_phrases\": [{\"ngram\": \"AsAAPreports\", \"from\": 6874, \"to\": 6886}, {\"ngram\": \"automotive and recycling industry representatives\", \"from\": 6888, \"to\": 6937}, {\"ngram\": \"the warning\", \"from\": 6945, \"to\": 6956}, {\"ngram\": \"the Transition\", \"from\": 6966, \"to\": 6980}, {\"ngram\": \"Electric Vehicles inquiry\", \"from\": 6984, \"to\": 7009}, {\"ngram\": \"calls\", \"from\": 7038, \"to\": 7043}, {\"ngram\": \"a \\\"battery passport\", \"from\": 7048, \"to\": 7067}, {\"ngram\": \"electric cars\", \"from\": 7073, \"to\": 7086}, {\"ngram\": \"efforts\", \"from\": 7099, \"to\": 7106}, {\"ngram\": \"Europe\", \"from\": 7110, \"to\": 7116}]}, {\"sentence\": \"Recycling facilities were already struggling with too few collection points and a lack of guidance and standards about battery recycling, Australian Council of Recycling chief executiveSuzanne Toumbouroutold the inquiry: The recycling and the waste sectors ... are in a crisis relating to incorrectly disposed-of batteries that cause fires in all types of facilities\\u2026 We do not have a sufficient collection system, we do not have a sufficient extended producer responsibility system for batteries.\", \"from\": 7119, \"to\": 7617, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Recycling facilities\", \"from\": 7119, \"to\": 7139}, {\"ngram\": \"too few collection points\", \"from\": 7169, \"to\": 7194}, {\"ngram\": \"guidance\", \"from\": 7209, \"to\": 7217}, {\"ngram\": \"standards\", \"from\": 7222, \"to\": 7231}, {\"ngram\": \"battery recycling\", \"from\": 7238, \"to\": 7255}, {\"ngram\": \"Recycling chief\", \"from\": 7279, \"to\": 7294}, {\"ngram\": \"executiveSuzanne Toumbouroutold\", \"from\": 7295, \"to\": 7326}, {\"ngram\": \"the inquiry\", \"from\": 7327, \"to\": 7338}, {\"ngram\": \"The recycling\", \"from\": 7340, \"to\": 7353}, {\"ngram\": \"the waste sectors\", \"from\": 7358, \"to\": 7375}, {\"ngram\": \"a crisis\", \"from\": 7387, \"to\": 7395}, {\"ngram\": \"incorrectly disposed-of batteries\", \"from\": 7408, \"to\": 7441}, {\"ngram\": \"fires\", \"from\": 7453, \"to\": 7458}, {\"ngram\": \"all types\", \"from\": 7462, \"to\": 7471}, {\"ngram\": \"facilities\", \"from\": 7475, \"to\": 7485}, {\"ngram\": \"a sufficient collection system\", \"from\": 7502, \"to\": 7532}, {\"ngram\": \"a sufficient extended producer responsibility system\", \"from\": 7549, \"to\": 7601}, {\"ngram\": \"batteries\", \"from\": 7606, \"to\": 7615}]}, {\"sentence\": \"The nation needs clear rules on battery labelling, transport and disposal, including a ban on dumping them in landfill, before local facilities could break down and process electric vehicle batteries, Toumbourou said.\", \"from\": 7619, \"to\": 7836, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The nation\", \"from\": 7619, \"to\": 7629}, {\"ngram\": \"clear rules\", \"from\": 7636, \"to\": 7647}, {\"ngram\": \"battery labelling\", \"from\": 7651, \"to\": 7668}, {\"ngram\": \"transport\", \"from\": 7670, \"to\": 7679}, {\"ngram\": \"disposal\", \"from\": 7684, \"to\": 7692}, {\"ngram\": \"a ban\", \"from\": 7704, \"to\": 7709}, {\"ngram\": \"landfill\", \"from\": 7729, \"to\": 7737}, {\"ngram\": \"local facilities\", \"from\": 7746, \"to\": 7762}, {\"ngram\": \"electric vehicle batteries\", \"from\": 7792, \"to\": 7818}, {\"ngram\": \"Toumbourou\", \"from\": 7820, \"to\": 7830}]}, {\"sentence\": \"All batteries, including EV batteries, must be regulated.\", \"from\": 7838, \"to\": 7895, \"entities\": [{\"begin\": 7863, \"end\": 7865, \"title\": \"http://dbpedia.org/resource/Electric_vehicle\", \"score\": 1.0, \"rank\": 1.115980600995378e-14, \"text\": \"EV\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Electric_vehicle\", \"dbpedia\": \"http://dbpedia.org/resource/Electric_vehicle\"}], \"noun_phrases\": [{\"ngram\": \"All batteries\", \"from\": 7838, \"to\": 7851}]}, {\"sentence\": \"These standards must extend to handling, storage, transport and processing for batteries at end of use.\", \"from\": 7896, \"to\": 7999, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"These standards\", \"from\": 7896, \"to\": 7911}, {\"ngram\": \"handling\", \"from\": 7927, \"to\": 7935}, {\"ngram\": \"storage\", \"from\": 7937, \"to\": 7944}, {\"ngram\": \"transport\", \"from\": 7946, \"to\": 7955}, {\"ngram\": \"processing\", \"from\": 7960, \"to\": 7970}, {\"ngram\": \"batteries\", \"from\": 7975, \"to\": 7984}, {\"ngram\": \"end\", \"from\": 7988, \"to\": 7991}, {\"ngram\": \"use\", \"from\": 7995, \"to\": 7998}]}, {\"sentence\": \"In addition to ramping up recycling efforts, Australia should consider introducing regulations like those in Europe that label batteries and set a target for the recovery of critical minerals from them, the inquiry heard.\", \"from\": 8001, \"to\": 8222, \"entities\": [{\"begin\": 8046, \"end\": 8055, \"title\": \"http://dbpedia.org/resource/Australia\", \"score\": 0.990706101962783, \"rank\": 0.009381084884001698, \"text\": \"Australia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Australia\", \"dbpedia\": \"http://dbpedia.org/resource/Australia\"}], \"noun_phrases\": [{\"ngram\": \"addition\", \"from\": 8004, \"to\": 8012}, {\"ngram\": \"recycling efforts\", \"from\": 8027, \"to\": 8044}, {\"ngram\": \"regulations\", \"from\": 8084, \"to\": 8095}, {\"ngram\": \"Europe\", \"from\": 8110, \"to\": 8116}, {\"ngram\": \"a target\", \"from\": 8146, \"to\": 8154}, {\"ngram\": \"the recovery\", \"from\": 8159, \"to\": 8171}, {\"ngram\": \"critical minerals\", \"from\": 8175, \"to\": 8192}, {\"ngram\": \"the inquiry\", \"from\": 8204, \"to\": 8215}]}, {\"sentence\": \"Association for the Battery Recycling Industry chief executive,Katharine Hole,said \\\"we have got six years to really stand this industry up.\\\"\", \"from\": 8224, \"to\": 8364, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Association\", \"from\": 8224, \"to\": 8235}, {\"ngram\": \"the Battery Recycling Industry chief executive\", \"from\": 8240, \"to\": 8286}, {\"ngram\