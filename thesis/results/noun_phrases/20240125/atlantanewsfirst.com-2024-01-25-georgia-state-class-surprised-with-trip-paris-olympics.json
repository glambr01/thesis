\": [], \"noun_phrases\": [{\"ngram\": \"the sky\", \"from\": 1271, \"to\": 1278}, {\"ngram\": \"the limit\", \"from\": 1281, \"to\": 1290}]}, {\"sentence\": \"But I was not expecting to go to Paris,\\\" one student said.\", \"from\": 1292, \"to\": 1350, \"entities\": [{\"begin\": 1325, \"end\": 1330, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9910150196950023, \"rank\": 0.009066442108670296, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"one student\", \"from\": 1333, \"to\": 1344}]}, {\"sentence\": \"\\\"I was stunned.\", \"from\": 1352, \"to\": 1367, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"That was crazy.\", \"from\": 1368, \"to\": 1383, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Professor Mo is always pulling out all the stops in our classes, so I just love that they gave us tickets and a cute little beret to go with them.\\\"\", \"from\": 1384, \"to\": 1531, \"entities\": [{\"begin\": 1394, \"end\": 1396, \"title\": \"http://dbpedia.org/resource/Molybdenum\", \"score\": 0.9668681925316843, \"rank\": 0.03425049792795696, \"text\": \"Mo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Molybdenum\", \"dbpedia\": \"http://dbpedia.org/resource/Molybdenum\"}], \"noun_phrases\": [{\"ngram\": \"all the stops\", \"from\": 1419, \"to\": 1432}, {\"ngram\": \"our classes\", \"from\": 1436, \"to\": 1447}, {\"ngram\": \"us\", \"from\": 1479, \"to\": 1481}, {\"ngram\": \"tickets\", \"from\": 1482, \"to\": 1489}, {\"ngram\": \"a cute little beret\", \"from\": 1494, \"to\": 1513}]}, {\"sentence\": \"said another student.\", \"from\": 1532, \"to\": 1553, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"another student\", \"from\": 1537, \"to\": 1552}]}, {\"sentence\": \"So, this next generation of attorneys will be getting some pretty cool hands-on experience before they get their hands on a law degree.\", \"from\": 1555, \"to\": 1690, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this next generation\", \"from\": 1559, \"to\": 1579}, {\"ngram\": \"attorneys\", \"from\": 1583, \"to\": 1592}, {\"ngram\": \"some pretty cool hands-on experience\", \"from\": 1609, \"to\": 1645}, {\"ngram\": \"their hands\", \"from\": 1662, \"to\": 1673}, {\"ngram\": \"a law degree\", \"from\": 1677, \"to\": 1689}]}, {\"sentence\": \"\\\"The idea that we can put the work that we are learning in the classroom into actual practice on the ground in Paris is just like a dream come true because, for students, that's how they are able to tie the concepts together,\\\" said Ivory.\", \"from\": 1692, \"to\": 1930, \"entities\": [{\"begin\": 1803, \"end\": 1808, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9910150196950023, \"rank\": 0.009066442108670296, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"The idea\", \"from\": 1693, \"to\": 1701}, {\"ngram\": \"the work\", \"from\": 1718, \"to\": 1726}, {\"ngram\": \"the classroom\", \"from\": 1751, \"to\": 1764}, {\"ngram\": \"actual practice\", \"from\": 1770, \"to\": 1785}, {\"ngram\": \"the ground\", \"from\": 1789, \"to\": 1799}, {\"ngram\": \"a dream\", \"from\": 1822, \"to\": 1829}, {\"ngram\": \"students\", \"from\": 1853, \"to\": 1861}, {\"ngram\": \"the concepts\", \"from\": 1895, \"to\": 1907}, {\"ngram\": \"Ivory\", \"from\": 1924, \"to\": 1929}]}, {\"sentence\": \"If you are interested in sponsoring students for the Olympic Games, please contact Professor Mo Ivory atmivory@gsu.edu.\", \"from\": 1932, \"to\": 2051, \"entities\": [{\"begin\": 2025, \"end\": 2027, \"title\": \"http://dbpedia.org/resource/Molybdenum\", \"score\": 0.9668681925316843, \"rank\": 0.03425049792795696, \"text\": \"Mo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Molybde