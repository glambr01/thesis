9}]}, {\"sentence\": \"Security is a top priority and organisers and the government will need to liaise to make it work.\", \"from\": 1032, \"to\": 1129, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Security\", \"from\": 1032, \"to\": 1040}, {\"ngram\": \"a top priority\", \"from\": 1044, \"to\": 1058}, {\"ngram\": \"organisers\", \"from\": 1063, \"to\": 1073}, {\"ngram\": \"the government\", \"from\": 1078, \"to\": 1092}]}, {\"sentence\": \"\\\"We have contracted 70% of our needs in terms of private security at the end of 2023,\\\" Estanguet told Reuters.\", \"from\": 1131, \"to\": 1241, \"entities\": [{\"begin\": 1233, \"end\": 1240, \"title\": \"http://dbpedia.org/resource/Reuters\", \"score\": 0.9999999999961346, \"rank\": 3.914092494819714e-12, \"text\": \"Reuters\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Reuters\", \"dbpedia\": \"http://dbpedia.org/resource/Reuters\"}], \"noun_phrases\": [{\"ngram\": \"70%\", \"from\": 1151, \"to\": 1154}, {\"ngram\": \"our needs\", \"from\": 1158, \"to\": 1167}, {\"ngram\": \"terms\", \"from\": 1171, \"to\": 1176}, {\"ngram\": \"private security\", \"from\": 1180, \"to\": 1196}, {\"ngram\": \"the end\", \"from\": 1200, \"to\": 1207}, {\"ngram\": \"Estanguet\", \"from\": 1218, \"to\": 1227}]}, {\"sentence\": \"\\\"We have a last series of tenders that are ongoing to cover the remaining 30% in the first trimester, which will give us visibility and we will take it from there to see how we can develop private and public security to make the Games safe.\\\"\", \"from\": 1243, \"to\": 1484, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a last series\", \"from\": 1252, \"to\": 1265}, {\"ngram\": \"tenders\", \"from\": 1269, \"to\": 1276}, {\"ngram\": \"the remaining 30%\", \"from\": 1303, \"to\": 1320}, {\"ngram\": \"the first trimester\", \"from\": 1324, \"to\": 1343}, {\"ngram\": \"us\", \"from\": 1361, \"to\": 1363}, {\"ngram\": \"visibility\", \"from\": 1364, \"t