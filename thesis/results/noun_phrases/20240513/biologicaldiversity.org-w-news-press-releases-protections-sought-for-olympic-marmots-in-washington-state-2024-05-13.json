"{\"uid\": \"biologicaldiversity.org-w-news-press-releases-protections-sought-for-olympic-marmots-in-washington-state-2024-05-13\", \"noun_phrases\": [{\"sentence\": \"For Immediate Release, May 13, 2024 Contact: Noah Greenwald, (503) 484-7495,[email protected] Protections Sought for Olympic Marmots in Washington State Restoration of Wolves to Olympic National Park Needed to Save Adorable Mammals SEATTLE- The Center for Biological Diversity today filed apetitionwith the U.S.\", \"from\": 0, \"to\": 355, \"entities\": [{\"begin\": 86, \"end\": 90, \"title\": \"http://dbpedia.org/resource/Noah\", \"score\": 0.9979439454326934, \"rank\": 0.002046271131887577, \"text\": \"Noah\", \"types\": [\"Q729\", \"Q5\", \"Q43115\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Noah\", \"dbpedia\": \"http://dbpedia.org/resource/Noah\"}], \"noun_phrases\": [{\"ngram\": \"Immediate Release\", \"from\": 4, \"to\": 21}, {\"ngram\": \"Noah Greenwald\", \"from\": 45, \"to\": 59}, {\"ngram\": \"Olympic Marmots\", \"from\": 117, \"to\": 132}, {\"ngram\": \"Washington State Restoration\", \"from\": 136, \"to\": 164}, {\"ngram\": \"Wolves\", \"from\": 168, \"to\": 174}, {\"ngram\": \"Olympic National Park\", \"from\": 178, \"to\": 199}, {\"ngram\": \"The Center\", \"from\": 241, \"to\": 251}, {\"ngram\": \"Biological Diversity\", \"from\": 256, \"to\": 276}, {\"ngram\": \"the U.S.\", \"from\": 303, \"to\": 311}]}, {\"sentence\": \"Fish and Wildlife Service to protect Olympic marmots under the Endangered Species Act.\", \"from\": 356, \"to\": 442, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Fish\", \"from\": 356, \"to\": 360}, {\"ngram\": \"Wildlife Service\", \"from\": 365, \"to\": 381}, {\"ngram\": \"Olympic marmots\", \"from\": 393, \"to\": 408}, {\"ngram\": \"the Endangered Species Act\", \"from\": 415, \"to\": 441}]}, {\"sentence\": \"The rare marmots are found only on the Olympic Peninsula in Washington state.\", \"from\": 443, \"to\": 520, \"entities\": [{\"begin\": 503, \"end\": 513, \"title\": \"http://dbpedia.org/resource/George_Washington\", \"score\": 0.5658017648383122, \"rank\": 0.7674025526194916, \"text\": \"Washington\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/George_Washington\", \"dbpedia\": \"http://dbpedia.org/resource/George_Washington\"}], \"noun_phrases\": [{\"ngram\": \"The rare marmots\", \"from\": 443, \"to\": 459}, {\"ngram\": \"the Olympic Peninsula\", \"from\": 478, \"to\": 499}]}, {\"sentence\": \"\\\"These giant, fluffy denizens of alpine meadows are icons of the Pacific Northwest, but if we do not protect them, they could disappear,\\\" said Noah Greenwald, endangered species director at the Center.\", \"from\": 522, \"to\": 723, \"entities\": [{\"begin\": 587, \"end\": 604, \"title\": \"http://dbpedia.org/resource/Pacific_Northwest\", \"score\": 0.9999999997148734, \"rank\": 2.8504945277232673e-10, \"text\": \"Pacific Northwest\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Pacific_Northwest\", \"dbpedia\": \"http://dbpedia.org/resource/Pacific_Northwest\"}, {\"begin\": 665, \"end\": 669, \"title\": \"http://dbpedia.org/resource/Noah\", \"score\": 0.9979439454326934, \"rank\": 0.002046271131887577, \"text\": \"Noah\", \"types\": [\"Q729\", \"Q5\", \"Q43115\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Noah\", \"dbpedia\": \"http://dbpedia.org/resource/Noah\"}], \"noun_phrases\": [{\"ngram\": \"These giant, fluffy denizens\", \"from\": 523, \"to\": 551}, {\"ngram\": \"alpine meadows\", \"from\": 555, \"to\": 569}, {\"ngram\": \"icons\", \"from\": 574, \"to\": 579}, {\"ngram\": \"endangered species director\", \"from\": 681, \"to\": 708}, {\"ngram\": \"the Center\", \"from\": 712, \"to\": 722}]}, {\"sentence\": \"\\\"Climate change and the loss of wolves from the Olympic Peninsula have changed things in the mountains, and our beloved marmots are paying the price.\\\"\", \"from\": 724, \"to\": 874, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Climate change\", \"from\": 725, \"to\": 739}, {\"ngram\": \"the loss\", \"from\": 744, \"to\": 752}, {\"ngram\": \"wolves\", \"from\": 756, \"to\": 762}, {\"ngram\": \"the Olympic Peninsula\", \"from\": 768, \"to\": 789}, {\"ngram\": \"things\", \"from\": 803, \"to\": 809}, {\"ngram\": \"the mountains\", \"from\": 813, \"to\": 826}, {\"ngram\": \"our beloved marmots\", \"from\": 832, \"to\": 851}, {\"ngram\": \"the price\", \"from\": 863, \"to\": 872}]}, {\"sentence\": \"Olympic marmots are a unique species of large, ground-dwelling squirrels that live in alpine and subalpine meadows and rocky slopes, with most of their habitat falling within the Olympic National Park.\", \"from\": 876, \"to\": 1077, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Olympic marmots\", \"from\": 876, \"to\": 891}, {\"ngram\": \"a unique species\", \"from\": 896, \"to\": 912}, {\"ngram\": \"large, ground-dwelling squirrels\", \"from\": 916, \"to\": 948}, {\"ngram\": \"alpine\", \"from\": 962, \"to\": 968}, {\"ngram\": \"subalpine meadows\", \"from\": 973, \"to\": 990}, {\"ngram\": \"rocky slopes\", \"from\": 995, \"to\": 1007}, {\"ngram\": \"their habitat\", \"from\": 1022, \"to\": 1035}, {\"ngram\": \"the Olympic National Park\", \"from\": 1051, \"to\": 1076}]}, {\"sentence\": \"They spend up to eight months hibernating each year and then double their body weight during the summer.\", \"from\": 1078, \"to\": 1182, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"up to eight months\", \"from\": 1089, \"to\": 1107}, {\"ngram\": \"their body weight\", \"from\": 1146, \"to\": 1163}, {\"ngram\": \"the summer\", \"from\": 1171, \"to\": 1181}]}, {\"sentence\": \"Olympic marmots have the smallest range and population of any marmot species in the United States.\", \"from\": 1184, \"to\": 1282, \"entities\": [{\"begin\": 1268, \"end\": 1281, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9996657960774924, \"rank\": 0.00033431565226558786, \"text\": \"United States\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"Olympic marmots\", \"from\": 1184, \"to\": 1199}, {\"ngram\": \"the smallest range\", \"from\": 1205, \"to\": 1223}, {\"ngram\": \"population\", \"from\": 1228, \"to\": 1238}, {\"ngram\": \"any marmot species\", \"from\": 1242, \"to\": 1260}]}, {\"sentence\": \"Just 2,000 to 4,000 of the marmots are thought to be alive today.\", \"from\": 1283, \"to\": 1348, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the marmots\", \"from\": 1306, \"to\": 1317}]}, {\"sentence\": \"A severe population decline was observed in the 1990s.\", \"from\": 1350, \"to\": 1404, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A severe population decline\", \"from\": 1350, \"to\": 1377}]}, {\"sentence\": \"By 2006, 60% of known Olympic marmot colonies were unoccupied.\", \"from\": 1405, \"to\": 1467, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"60%\", \"from\": 1414, \"to\": 1417}, {\"ngram\": \"known Olympic marmot colonies\", \"from\": 1421, \"to\": 1450}]}, {\"sentence\": \"Predation by coyotes is believed to be the main reason for these declines.\", \"from\": 1468, \"to\": 1542, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Predation\", \"from\": 1468, \"to\": 1477}, {\"ngram\": \"coyotes\", \"from\": 1481, \"to\": 1488}, {\"ngram\": \"the main reason\", \"from\": 1507, \"to\": 1522}, {\"ngram\": \"these declines\", \"from\": 1527, \"to\": 1541}]}, {\"sentence\": \"In one study, coyotes accounted for 85% of all documented marmot predation events.\", \"from\": 1543, \"to\": 1625, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"one study\", \"from\": 1546, \"to\": 1555}, {\"ngram\": \"coyotes\", \"from\": 1557, \"to\": 1564}, {\"ngram\": \"85%\", \"from\": 1579, \"to\": 1582}, {\"ngram\": \"all documented marmot predation events\", \"from\": 1586, \"to\": 1624}]}, {\"sentence\": \"While the marmot population has stabilized since the mid-2000s, climate change and coyotes remain serious threats.\", \"from\": 1627, \"to\": 1741, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the marmot population\", \"from\": 1633, \"to\": 1654}, {\"ngram\": \"the mid-2000s\", \"from\": 1676, \"to\": 1689}, {\"ngram\": \"climate change\", \"from\": 1691, \"to\": 1705}, {\"ngram\": \"coyotes\", \"from\": 1710, \"to\": 1717}, {\"ngram\": \"serious threats\", \"from\": 1725, \"to\": 1740}]}, {\"sentence\": \"Coyotes were historically absent from the Olympic Peninsula, but moved in after wolves were eradicated from the area in the early 20th century.\", \"from\": 1743, \"to\": 1886, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Coyotes\", \"from\": 1743, \"to\": 1750}, {\"ngram\": \"the Olympic Peninsula\", \"from\": 1781, \"to\": 1802}, {\"ngram\": \"wolves\", \"from\": 1823, \"to\": 1829}, {\"ngram\": \"the area\", \"from\": 1851, \"to\": 1859}, {\"ngram\": \"the early 20th century\", \"from\": 1863, \"to\": 1885}]}, {\"sentence\": \"Coyotes hunt at higher elevations than wolves, including above the treeline, where marmots live.\", \"from\": 1887, \"to\": 1983, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Coyotes hunt\", \"from\": 1887, \"to\": 1899}, {\"ngram\": \"higher elevations\", \"from\": 1903, \"to\": 1920}, {\"ngram\": \"wolves\", \"from\": 1926, \"to\": 1932}, {\"ngram\": \"the treeline\", \"from\": 1950, \"to\": 1962}, {\"ngram\": \"marmots\", \"from\": 1970, \"to\": 1977}]}, {\"sentence\": \"Facilitating natural colonization or reintroducing wolves to the Olympic Peninsula from British Columbia, where coastal wolves likely represent the closest living relatives of the wolves formerly found on the peninsula, could give marmots a better chance at survival.\", \"from\": 1985, \"to\": 2252, \"entities\": [{\"begin\": 2073, \"end\": 2089, \"title\": \"http://dbpedia.org/resource/British_Columbia\", \"score\": 1.0, \"rank\": 1.653633407606053e-15, \"text\": \"British Columbia\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/British_Columbia\", \"dbpedia\": \"http://dbpedia.org/resource/British_Columbia\"}], \"noun_phrases\": [{\"ngram\": \"natural colonization\", \"from\": 1998, \"to\": 2018}, {\"ngram\": \"wolves\", \"from\": 2036, \"to\": 2042}, {\"ngram\": \"the Olympic Peninsula\", \"from\": 2046, \"to\": 2067}, {\"ngram\": \"coastal wolves\", \"from\": 2097, \"to\": 2111}, {\"ngram\": \"the closest living relatives\", \"from\": 2129, \"to\": 2157}, {\"ngram\": \"the wolves\", \"from\": 2161, \"to\": 2171}, {\"ngram\": \"the peninsula\", \"from\": 2190, \"to\": 2203}, {\"ngram\": \"marmots\", \"from\": 2216, \"to\": 2223}, {\"ngram\": \"a better chance\", \"from\": 2224, \"to\": 2239}, {\"ngram\": \"survival\", \"from\": 2243, \"to\": 2251}]}, {\"sentence\": \"Olympic marmots are also threatened by climate change, which is predicted to wipe out most alpine meadow habitat across the United States over the next century as trees move uphill to adapt to a warming climate.\", \"from\": 2254, \"to\": 2465, \"entities\": [{\"begin\": 2378, \"end\": 2391, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9996657960774924, \"rank\": 0.00033431565226558786, \"text\": \"United States\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"Olympic marmots\", \"from\": 2254, \"to\": 2269}, {\"ngram\": \"climate change\", \"from\": 2293, \"to\": 2307}, {\"ngram\": \"most alpine meadow habitat\", \"from\": 2340, \"to\": 2366}, {\"ngram\": \"the next century\", \"from\": 2397, \"to\": 2413}, {\"ngram\": \"trees\", \"from\": 2417, \"to\": 2422}, {\"ngram\": \"a warming climate\", \"from\": 2447, \"to\": 2464}]}, {\"sentence\": \"This will reduce and fragment the remaining meadow habitat where Olympic marmots live.\", \"from\": 2466, \"to\": 2552, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the remaining meadow habitat\", \"from\": 2496, \"to\": 2524}, {\"ngram\": \"Olympic marmots\", \"from\": 2531, \"to\": 2546}]}, {\"sentence\": \"Climate change is also resulting in less spring snowpack, which allows coyotes to occupy higher terrain, placing the marmots at even greater risk.\", \"from\": 2553, \"to\": 2699, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Climate change\", \"from\": 2553, \"to\": 2567}, {\"ngram\": \"less spring snowpack\", \"from\": 2589, \"to\": 2609}, {\"ngram\": \"coyotes\", \"from\": 2624, \"to\": 2631}, {\"ngram\": \"higher terrain\", \"from\": 2642, \"to\": 2656}, {\"ngram\": \"the marmots\", \"from\": 2666, \"to\": 2677}, {\"ngram\": \"even greater risk\", \"from\": 2681, \"to\": 2698}]}, {\"sentence\": \"\\\"Beautifully, flowered alpine meadows like those on Hurricane Ridge are yet another thing we are at risk of losing in our warming world,\\\" said Greenwald.\", \"from\": 2701, \"to\": 2854, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Beautifully, flowered alpine meadows\", \"from\": 2702, \"to\": 2738}, {\"ngram\": \"Hurricane Ridge\", \"from\": 2753, \"to\": 2768}, {\"ngram\": \"another thing\", \"from\": 2777, \"to\": 2790}, {\"ngram\": \"risk\", \"from\": 2801, \"to\": 2805}, {\"ngram\": \"our warming world\", \"from\": 2819, \"to\": 2836}, {\"ngram\": \"Greenwald\", \"from\": 2844, \"to\": 2853}]}, {\"sentence\": \"\\\"The time is now to dramatically reduce our greenhouse gas pollution to save the Olympic marmot and so much more.\\\"\", \"from\": 2855, \"to\": 2969, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The time\", \"from\": 2856, \"to\": 2864}, {\"ngram\": \"our greenhouse gas pollution\", \"from\": 2895, \"to\": 2923}, {\"ngram\": \"the Olympic marmot\", \"from\": 2932, \"to\": 2950}]}, {\"sentence\": \"Despite the threats they face, Olympic marmots are not harmed by tourism and are frequently seen sunbathing and foraging in popular hiking areas of the Olympic National Park, like Hurricane Ridge.\", \"from\": 2971, \"to\": 3167, \"entities\": [{\"begin\": 3151, \"end\": 3166, \"title\": \"http://dbpedia.org/resource/Hurricane_Ridge\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Hurricane Ridge\", \"types\": [\"Q8502\"], \"wikid\": \"http://dbpedia.org/resource/Hurricane_Ridge\", \"dbpedia\": \"http://dbpedia.org/resource/Hurricane_Ridge\"}], \"noun_phrases\": [{\"ngram\": \"the threats\", \"from\": 2979, \"to\": 2990}, {\"ngram\": \"Olympic marmots\", \"from\": 3002, \"to\": 3017}, {\"ngram\": \"tourism\", \"from\": 3036, \"to\": 3043}, {\"ngram\": \"popular hiking areas\", \"from\": 3095, \"to\": 3115}, {\"ngram\": \"the Olympic National Park\", \"from\": 3119, \"to\": 3144}]}, {\"sentence\": \"They were named as the state endemic mammal by the Washington State Legislature in 2009.\", \"from\": 3168, \"to\": 3256, \"entities\": [{\"begin\": 3219, \"end\": 3247, \"title\": \"http://dbpedia.org/resource/Washington_State_Legislature\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Washington State Legislature\", \"types\": [\"Q43229\", \"Q24229398\", \"Q11204\"], \"wikid\": \"http://dbpedia.org/resource/Washington_State_Legislature\", \"dbpedia\": \"http://dbpedia.org/resource/Washington_State_Legislature\"}], \"noun_phrases\": [{\"ngram\": \"the state\", \"from\": 3187, \"to\": 3196}]}, {\"sentence\": \"Endangered Species Act protection would allow the Service to craft strong safeguards and a recovery plan to ensure that Olympic marmots survive into the future.\", \"from\": 3258, \"to\": 3418, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Endangered Species Act protection\", \"from\": 3258, \"to\": 3291}, {\"ngram\": \"the Service\", \"from\": 3304, \"to\": 3315}, {\"ngram\": \"strong safeguards\", \"from\": 3325, \"to\": 3342}, {\"ngram\": \"a recovery plan\", \"from\": 3347, \"to\": 3362}, {\"ngram\": \"Olympic marmots\", \"from\": 3378, \"to\": 3393}, {\"ngram\": \"the future\", \"from\": 3407, \"to\": 3417}]}, {\"sentence\": \"The Service now has 90 days to decide whether protection for the Olympic marmot may be warranted.\", \"from\": 3419, \"to\": 3516, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The Service\", \"from\": 3419, \"to\": 3430}, {\"ngram\": \"90 days\", \"from\": 3439, \"to\": 3446}, {\"ngram\": \"protection\", \"from\": 3465, \"to\": 3475}, {\"ngram\": \"the Olympic marmot\", \"from\": 3480, \"to\": 3498}]}, {\"sentence\": \"The Center for Biological Diversity is a national, nonprofit conservation organization with more than 1.7 million members and online activists dedicated to the protection of endangered species and wild places.\", \"from\": 3518, \"to\": 3727, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The Center\", \"from\": 3518, \"to\": 3528}, {\"ngram\": \"Biological Diversity\", \"from\": 3533, \"to\": 3553}, {\"ngram\": \"a national, nonprofit conservation organization\", \"from\": 3557, \"to\": 3604}, {\"ngram\": \"more than 1.7 million members\", \"from\": 3610, \"to\": 3639}, {\"ngram\": \"online activists\", \"from\": 3644, \"to\": 3660}, {\"ngram\": \"the protection\", \"from\": 3674, \"to\": 3688}, {\"ngram\": \"endangered species\", \"from\": 3692, \"to\": 3710}, {\"ngram\": \"wild places\", \"from\": 3715, \"to\": 3726}]}, {\"sentence\": \"More Press Releases\", \"from\": 3729, \"to\": 3748, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"More Press Releases\", \"from\": 3729, \"to\": 3748}]}]}"