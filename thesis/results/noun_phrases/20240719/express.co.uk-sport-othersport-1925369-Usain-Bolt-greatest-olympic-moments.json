GB\", \"score\": 0.9996486920892899, \"rank\": 0.00035142959794967426, \"text\": \"Team GB\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Team_GB\", \"dbpedia\": \"http://dbpedia.org/resource/Team_GB\"}, {\"begin\": 861, \"end\": 870, \"title\": \"http://dbpedia.org/resource/Tom_Daley\", \"score\": 1.0, \"rank\": 4.492871510696135e-37, \"text\": \"Tom Daley\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tom_Daley\", \"dbpedia\": \"http://dbpedia.org/resource/Tom_Daley\"}, {\"begin\": 917, \"end\": 931, \"title\": \"http://dbpedia.org/resource/Michael_Phelps\", \"score\": 1.0, \"rank\": 8.086661783883188e-41, \"text\": \"Michael Phelps\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Michael_Phelps\", \"dbpedia\": \"http://dbpedia.org/resource/Michael_Phelps\"}, {\"begin\": 964, \"end\": 970, \"title\": \"http://dbpedia.org/resource/2004_Summer_Olympics\", \"score\": 0.9999795343021701, \"rank\": 2.0466116629587993e-05, \"text\": \"Athens\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2004_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2004_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"the list\", \"from\": 772, \"to\": 780}, {\"ngram\": \"a gold medal\", \"from\": 881, \"to\": 893}, {\"ngram\": \"diving\", \"from\": 897, \"to\": 903}, {\"ngram\": \"eight golds\", \"from\": 944, \"to\": 955}]}, {\"sentence\": \"According to the survey, 64% of respondents intend to watch the Paris 2024 Olympic Games on television, with athletics (55%), swimming (38%) and football (31%) being the preferred events.\", \"from\": 979, \"to\": 1166, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the survey\", \"from\": 992, \"to\": 1002}, {\"ngram\": \"64%\", \"from\": 1004, \"to\": 1007}, {\"ngram\": \"respondents\", \"from\": 1011, \"to\": 1022}, {\"ngram\": \"the Paris 2024 Olympic Games\", \"from\": 1039, \"to\": 1067}, {\"ngram\": \"television\",