"{\"uid\": \"rte.ie-news-business-2024-0719-1460848-paris-businesses-and-the-olympics\", \"noun_phrases\": [{\"sentence\": \"Paris shops, restaurants, bars and clubs are facing an \\\"unprecedented slump in business and footfall\\\", trade groups said today, blaming in part the \\\"heavy security measures\\\" imposed ahead of the Olympic Games starting July 26.\", \"from\": 0, \"to\": 226, \"entities\": [{\"begin\": 0, \"end\": 5, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999008651, \"rank\": 9.920413501163934e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"restaurants\", \"from\": 13, \"to\": 24}, {\"ngram\": \"bars\", \"from\": 26, \"to\": 30}, {\"ngram\": \"clubs\", \"from\": 35, \"to\": 40}, {\"ngram\": \"an \\\"unprecedented slump\", \"from\": 52, \"to\": 75}, {\"ngram\": \"business\", \"from\": 79, \"to\": 87}, {\"ngram\": \"trade groups\", \"from\": 103, \"to\": 115}, {\"ngram\": \"part\", \"from\": 139, \"to\": 143}, {\"ngram\": \"the \\\"heavy security measures\", \"from\": 144, \"to\": 172}, {\"ngram\": \"the Olympic Games\", \"from\": 191, \"to\": 208}]}, {\"sentence\": \"\\\"Despite optimistic forecasts, activity has been down since June, many professionals have seen their revenue fall by 30% compared with previous years,\\\" a group of restaurant, hotel, retail and nightspot unions said in a joint statement.\", \"from\": 228, \"to\": 464, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"optimistic forecasts\", \"from\": 237, \"to\": 257}, {\"ngram\": \"activity\", \"from\": 259, \"to\": 267}, {\"ngram\": \"June\", \"from\": 288, \"to\": 292}, {\"ngram\": \"many professionals\", \"from\": 294, \"to\": 312}, {\"ngram\": \"their revenue\", \"from\": 323, \"to\": 336}, {\"ngram\": \"30%\", \"from\": 345, \"to\": 348}, {\"ngram\": \"previous years\", \"from\": 363, \"to\": 377}, {\"ngram\": \"\\\" a group\", \"from\": 378, \"to\": 387}, {\"ngram\": \"restaurant, hotel, retail and nightspot unions\", \"from\": 391, \"to\": 437}, {\"ngram\": \"a joint statement\", \"from\": 446, \"to\": 463}]}, {\"sentence\": \"Their businesses are suffering from tourists avoiding the capital, unfavourable weather, inflation, a tense political situation after President Emmanuel Macron called snap elections and the Olympic security measures, they said.\", \"from\": 466, \"to\": 693, \"entities\": [{\"begin\": 610, \"end\": 625, \"title\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Emmanuel Macron\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"dbpedia\": \"http://dbpedia.org/resource/Emmanuel_Macron\"}], \"noun_phrases\": [{\"ngram\": \"Their businesses\", \"from\": 466, \"to\": 482}, {\"ngram\": \"tourists\", \"from\": 502, \"to\": 510}, {\"ngram\": \"the capital\", \"from\": 520, \"to\": 531}, {\"ngram\": \"unfavourable weather\", \"from\": 533, \"to\": 553}, {\"ngram\": \"inflation\", \"from\": 555, \"to\": 564}, {\"ngram\": \"a tense political situation\", \"from\": 566, \"to\": 593}, {\"ngram\": \"snap elections\", \"from\": 633, \"to\": 647}, {\"ngram\": \"the Olympic security measures\", \"from\": 652, \"to\": 681}]}, {\"sentence\": \"Combined, the headwinds are producing \\\"disastrous economic consequences\\\", they added.\", \"from\": 695, \"to\": 780, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the headwinds\", \"from\": 705, \"to\": 718}, {\"ngram\": \"\\\"disastrous economic consequences\", \"from\": 733, \"to\": 766}]}, {\"sentence\": \"The unions urged authorities to communicate more clearly in particular about the security measures, saying they were unable to plan around them without information.\", \"from\": 782, \"to\": 946, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The unions\", \"from\": 782, \"to\": 792}, {\"ngram\": \"authorities\", \"from\": 799, \"to\": 810}, {\"ngram\": \"the security measures\", \"from\": 859, \"to\": 880}, {\"ngram\": \"information\", \"from\": 934, \"to\": 945}]}, {\"sentence\": \"One example was the Trocadero square near the Eiffel Tower in western Paris, where restaurants are \\\"suffering access restrictions that have sent footfall plunging by 70%\\\", they said.\", \"from\": 948, \"to\": 1130, \"entities\": [{\"begin\": 1018, \"end\": 1023, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999008651, \"rank\": 9.920413501163934e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"One example\", \"from\": 948, \"to\": 959}, {\"ngram\": \"the Trocadero square\", \"from\": 964, \"to\": 984}, {\"ngram\": \"the Eiffel Tower\", \"from\": 990, \"to\": 1006}, {\"ngram\": \"restaurants\", \"from\": 1031, \"to\": 1042}, {\"ngram\": \"access restrictions\", \"from\": 1058, \"to\": 1077}, {\"ngram\": \"footfall\", \"from\": 1093, \"to\": 1101}, {\"ngram\": \"70%\", \"from\": 1114, \"to\": 1117}]}, {\"sentence\": \"Elsewhere, security barriers blighting otherwise picturesque streets in the capital are driving prospective customers away, the unions charge.\", \"from\": 1132, \"to\": 1274, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"security barriers\", \"from\": 1143, \"to\": 1160}, {\"ngram\": \"otherwise picturesque streets\", \"from\": 1171, \"to\": 1200}, {\"ngram\": \"the capital\", \"from\": 1204, \"to\": 1215}, {\"ngram\": \"prospective customers\", \"from\": 1228, \"to\": 1249}, {\"ngram\": \"the unions\", \"from\": 1256, \"to\": 1266}]}, {\"sentence\": \"\\\"Many small businesses risk shuttering for good,\\\" they said, calling for the government to set up compensation procedures.\", \"from\": 1276, \"to\": 1398, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Many small businesses\", \"from\": 1277, \"to\": 1298}, {\"ngram\": \"the government\", \"from\": 1349, \"to\": 1363}, {\"ngram\": \"compensation procedures\", \"from\": 1374, \"to\": 1397}]}, {\"sentence\": \"\\\"We insist that fair and swift compensation is necessary to make up for the inconvenience and losses suffered because of the Olympic Games,\\\" the unions said.\", \"from\": 1400, \"to\": 1557, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"fair and swift compensation\", \"from\": 1416, \"to\": 1443}, {\"ngram\": \"the inconvenience\", \"from\": 1472, \"to\": 1489}, {\"ngram\": \"losses\", \"from\": 1494, \"to\": 1500}, {\"ngram\": \"the Olympic Games\", \"from\": 1521, \"to\": 1538}, {\"ngram\": \"the unions\", \"from\": 1541, \"to\": 1551}]}, {\"sentence\": \"Source:AFP \\u00a9 RT\\u00c9 2026.\", \"from\": 1561, \"to\": 1584, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Source\", \"from\": 1561, \"to\": 1567}, {\"ngram\": \"AFP \\u00a9 RT\\u00c9\", \"from\": 1568, \"to\": 1577}]}, {\"sentence\": \"RT\\u00c9.ie is the website of Raidi\\u00f3 Teilif\\u00eds \\u00c9ireann, Ireland's National Public Service Media.\", \"from\": 1585, \"to\": 1675, \"entities\": [{\"begin\": 1610, \"end\": 1633, \"title\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\", \"score\": 0.9993664851268295, \"rank\": 0.0006339164685885233, \"text\": \"Raidi\\u00f3 Teilif\\u00eds \\u00c9ireann\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\", \"dbpedia\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\"}, {\"begin\": 1635, \"end\": 1642, \"title\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"score\": 0.9999999618316914, \"rank\": 3.816818031465674e-08, \"text\": \"Ireland\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"dbpedia\": \"http://dbpedia.org/resource/Republic_of_Ireland\"}], \"noun_phras