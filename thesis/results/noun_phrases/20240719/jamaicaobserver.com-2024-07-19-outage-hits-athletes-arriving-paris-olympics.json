ence\": \"\\\"Like a lot of organisations, we suffered this global Microsoft outage,\\\" chief organiser Tony Estanguet told reporters, a week before the opening ceremony of the Olympics.\", \"from\": 394, \"to\": 565, \"entities\": [{\"begin\": 448, \"end\": 457, \"title\": \"http://dbpedia.org/resource/Microsoft\", \"score\": 0.9999585762956166, \"rank\": 4.141931622675076e-05, \"text\": \"Microsoft\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Microsoft\", \"dbpedia\": \"http://dbpedia.org/resource/Microsoft\"}, {\"begin\": 483, \"end\": 497, \"title\": \"http://dbpedia.org/resource/Tony_Estanguet\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Tony Estanguet\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Tony_Estanguet\", \"dbpedia\": \"http://dbpedia.org/resource/Tony_Estanguet\"}], \"noun_phrases\": [{\"ngram\": \"a lot\", \"from\": 400, \"to\": 405}, {\"ngram\": \"organisations\", \"from\": 409, \"to\": 422}, {\"ngram\": \"reporters\", \"from\": 503, \"to\": 512}, {\"ngram\": \"the opening ceremony\", \"from\": 528, \"to\": 548}, {\"ngram\": \"the Olympics\", \"from\": 552, \"to\": 564}]}, {\"sentence\": \"\\\"All of our servers were affected this morning.\\\"\", \"from\": 567, \"to\": 615, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"our servers\", \"from\": 575, \"to\": 586}]}, {\"sentence\": \"By 5pm (1500 GMT), the organising committee said its operations were \\\"now running normally\\\", with the evening hours at its accreditation centre extended to help clear a backlog of demands.\", \"from\": 617, \"to\": 805, \"entities\": [{\"begin\": 630, \"end\": 633, \"title\": \"http://dbpedia.org/resource/Greenwich_Mean_Time\", \"score\": 1.0, \"rank\": 3.3252101563650932e-16, \"text\": \"GMT\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Greenwich_Mean_Time\", \"dbpedia\": \"http://dbpedia.org/resource/Greenwich_Mean_Time\"}], \"noun_phrases