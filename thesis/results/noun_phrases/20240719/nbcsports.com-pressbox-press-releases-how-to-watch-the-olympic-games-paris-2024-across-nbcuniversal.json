o\": 5309}, {\"ngram\": \"the Olympic\", \"from\": 5313, \"to\": 5324}, {\"ngram\": \"enhanced closed captioning, expanded audio description\", \"from\": 5333, \"to\": 5387}, {\"ngram\": \"digital content accessibility\", \"from\": 5402, \"to\": 5431}]}, {\"sentence\": \"Closed captioning, which provides text of the coverage audio for viewers who are Deaf or hard of hearing, will be available for all Olympic events airing across NBCU's broadcast and cable networks.\", \"from\": 5435, \"to\": 5632, \"entities\": [{\"begin\": 5596, \"end\": 5600, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"NBCU\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}], \"noun_phrases\": [{\"ngram\": \"Closed captioning\", \"from\": 5435, \"to\": 5452}, {\"ngram\": \"text\", \"from\": 5469, \"to\": 5473}, {\"ngram\": \"the coverage audio\", \"from\": 5477, \"to\": 5495}, {\"ngram\": \"viewers\", \"from\": 5500, \"to\": 5507}, {\"ngram\": \"Deaf\", \"from\": 5516, \"to\": 5520}, {\"ngram\": \"hearing\", \"from\": 5532, \"to\": 5539}, {\"ngram\": \"all Olympic events\", \"from\": 5563, \"to\": 5581}]}, {\"sentence\": \"NBCUniversal will also provide closed captioning for all digital livestreams with commentary across Peacock, NBCSports.com and the NBC Sports app.\", \"from\": 5633, \"to\": 5779, \"entities\": [{\"begin\": 5633, \"end\": 5645, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 0.9999999998144631, \"rank\": 1.8518993400094266e-10, \"text\": \"NBCUniversal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}, {\"begin\": 5733, \"end\": 5740, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.9999999999972715, \"rank\": 2.5204968560695345e-12, \"text\": \"Pe