, \"end\": 6037, \"title\": \"http://dbpedia.org/resource/NBC\", \"score\": 0.9819888074021589, \"rank\": 0.018341531831068333, \"text\": \"NBC\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/NBC\", \"dbpedia\": \"http://dbpedia.org/resource/NBC\"}], \"noun_phrases\": [{\"ngram\": \"All coverage\", \"from\": 6018, \"to\": 6030}, {\"ngram\": \"daytime\", \"from\": 6049, \"to\": 6056}, {\"ngram\": \"late night\", \"from\": 6073, \"to\": 6083}, {\"ngram\": \"theGold Zonewhip\", \"from\": 6089, \"to\": 6105}, {\"ngram\": \"audio description\", \"from\": 6141, \"to\": 6158}, {\"ngram\": \"Descriptive Video Works\", \"from\": 6172, \"to\": 6195}]}, {\"sentence\": \"In a first for a U.S. broadcaster, audio description services for NBC coverage will be provided in stereo, enhancing the quality of sound for viewers.\", \"from\": 6197, \"to\": 6347, \"entities\": [{\"begin\": 6263, \"end\": 6266, \"title\": \"http://dbpedia.org/resource/NBC\", \"score\": 0.9819888074021589, \"rank\": 0.018341531831068333, \"text\": \"NBC\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/NBC\", \"dbpedia\": \"http://dbpedia.org/resource/NBC\"}], \"noun_phrases\": [{\"ngram\": \"a U.S. broadcaster\", \"from\": 6212, \"to\": 6230}, {\"ngram\": \"audio description services\", \"from\": 6232, \"to\": 6258}, {\"ngram\": \"stereo\", \"from\": 6296, \"to\": 6302}, {\"ngram\": \"the quality\", \"from\": 6314, \"to\": 6325}, {\"ngram\": \"sound\", \"from\": 6329, \"to\": 6334}, {\"ngram\": \"viewers\", \"from\": 6339, \"to\": 6346}]}, {\"sentence\": \"CONTENT CREATORS AUDIO iHeartMedia: NBCUniversal has chosen iHeartMedia as its exclusive audio partner for the Olympic Games Paris 2024.\", \"from\": 6349, \"to\": 6487, \"entities\": [{\"begin\": 6387, \"end\": 6399, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 0.9999999998144631, \"rank\": 1.8518993400094266e-10, \"text\": \"NBCUniv