gram\": \"sustainability\", \"from\": 297, \"to\": 311}, {\"ngram\": \"the federation\", \"from\": 313, \"to\": 327}, {\"ngram\": \"the largest contingent\", \"from\": 378, \"to\": 400}, {\"ngram\": \"athletes\", \"from\": 404, \"to\": 412}, {\"ngram\": \"the Summer Games\", \"from\": 416, \"to\": 432}]}, {\"sentence\": \"\\\"As you can imagine, this is a period of time in which consistency and predictability is critical for Team USA's performance,\\\" Hirshland said.\", \"from\": 435, \"to\": 577, \"entities\": [{\"begin\": 537, \"end\": 545, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9980650494558153, \"rank\": 0.0013520628578486099, \"text\": \"Team USA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"a period\", \"from\": 464, \"to\": 472}, {\"ngram\": \"time\", \"from\": 476, \"to\": 480}, {\"ngram\": \"consistency\", \"from\": 490, \"to\": 501}, {\"ngram\": \"predictability\", \"from\": 506, \"to\": 520}, {\"ngram\": \"Hirshland\", \"from\": 562, \"to\": 571}]}, {\"sentence\": \"\\\"In our conversations with athletes, this was a very high priority and something that the athletes felt was a critical component in their performance capability.\\\"\", \"from\": 578, \"to\": 740, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"our conversations\", \"from\": 582, \"to\": 599}, {\"ngram\": \"athletes\", \"from\": 605, \"to\": 613}, {\"ngram\": \"a very high priority\", \"from\": 624, \"to\": 644}, {\"ngram\": \"something\", \"from\": 649, \"to\": 658}, {\"ngram\": \"the athletes\", \"from\": 664, \"to\": 676}, {\"ngram\": \"a critical component\", \"from\": 686, \"to\": 706}, {\"ngram\": \"their performance capability\", \"from\": 710, \"to\": 738}]}, {\"sentence\": \"The Washington Post reported earlier this month that Germany, Australia, Italy, Canada and Britain were among the other countries with plans t