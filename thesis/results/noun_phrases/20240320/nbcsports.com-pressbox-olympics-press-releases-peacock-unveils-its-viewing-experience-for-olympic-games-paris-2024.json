14, \"to\": 1132}, {\"ngram\": \"another major milestone\", \"from\": 1143, \"to\": 1166}, {\"ngram\": \"live streaming\", \"from\": 1195, \"to\": 1209}, {\"ngram\": \"an unprecedented viewing experience\", \"from\": 1215, \"to\": 1250}, {\"ngram\": \"our commitment\", \"from\": 1269, \"to\": 1283}, {\"ngram\": \"our customers\", \"from\": 1287, \"to\": 1300}, {\"ngram\": \"clients\", \"from\": 1302, \"to\": 1309}, {\"ngram\": \"partners\", \"from\": 1314, \"to\": 1322}, {\"ngram\": \"President\", \"from\": 1346, \"to\": 1355}, {\"ngram\": \"Peacock\", \"from\": 1357, \"to\": 1364}, {\"ngram\": \"Consumer\", \"from\": 1379, \"to\": 1387}]}, {\"sentence\": \"\\\"Following the Games, these new features will extend to other live events, joining the growing list of interactive elements and ad innovations that continue to set Peacock apart.\\\"\", \"from\": 1403, \"to\": 1582, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the Games\", \"from\": 1414, \"to\": 1423}, {\"ngram\": \"these new features\", \"from\": 1425, \"to\": 1443}, {\"ngram\": \"other live events\", \"from\": 1459, \"to\": 1476}, {\"ngram\": \"the growing list\", \"from\": 1486, \"to\": 1502}, {\"ngram\": \"interactive elements\", \"from\": 1506, \"to\": 1526}, {\"ngram\": \"ad innovations\", \"from\": 1531, \"to\": 1545}, {\"ngram\": \"Peacock\", \"from\": 1567, \"to\": 1574}]}, {\"sentence\": \"Peacock Live Actions Peacock Live Actions is a new interactive tool that lets fans choose their own viewing journey during live and primetime coverage, and follow the events they are most interested in watching.\", \"from\": 1584, \"to\": 1796, \"entities\": [{\"begin\": 1584, \"end\": 1591, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.9999999999995453, \"rank\": 4.769111267166681e-13, \"text\": \"Peacock\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Peafowl\", \"dbpedia\": \"http://dbpedia.org/resource/Peafowl\"}, {\"begin\": 1606, \"end\": 1613, \"title\": \"http://dbpedia.