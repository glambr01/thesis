"{\"uid\": \"rte.ie-sport-boxing-2024-0320-1438992-world-boxing-to-seek-ioc-recognition-for-2028-olympics\", \"noun_phrases\": [{\"sentence\": \"World Boxing will seek recognition from Olympic organisers to replace the Russian-led International Boxing Association and keep the troubled sport on the programme for the 2028 Los Angeles Game.\", \"from\": 0, \"to\": 194, \"entities\": [{\"begin\": 86, \"end\": 118, \"title\": \"http://dbpedia.org/resource/Women's_International_Boxing_Association\", \"score\": 1.0, \"rank\": 3.4592916057389906e-16, \"text\": \"International Boxing Association\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Women's_International_Boxing_Association\", \"dbpedia\": \"http://dbpedia.org/resource/Women's_International_Boxing_Association\"}], \"noun_phrases\": [{\"ngram\": \"World Boxing\", \"from\": 0, \"to\": 12}, {\"ngram\": \"recognition\", \"from\": 23, \"to\": 34}, {\"ngram\": \"Olympic organisers\", \"from\": 40, \"to\": 58}, {\"ngram\": \"the troubled sport\", \"from\": 128, \"to\": 146}, {\"ngram\": \"the programme\", \"from\": 150, \"to\": 163}, {\"ngram\": \"the 2028 Los Angeles Game\", \"from\": 168, \"to\": 193}]}, {\"sentence\": \"The International Olympic Committee (IOC) stripped the IBA of recognition last June after saying it had failed to complete reforms on governance, finance and ethical issues.\", \"from\": 196, \"to\": 369, \"entities\": [{\"begin\": 200, \"end\": 237, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee (IOC)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 200, \"end\": 237, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic C