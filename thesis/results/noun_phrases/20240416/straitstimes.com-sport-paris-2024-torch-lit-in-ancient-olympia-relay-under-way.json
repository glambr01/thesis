.\", \"from\": 917, \"to\": 1189, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"these difficult times\", \"from\": 921, \"to\": 942}, {\"ngram\": \"wars\", \"from\": 971, \"to\": 975}, {\"ngram\": \"conflicts\", \"from\": 980, \"to\": 989}, {\"ngram\": \"the rise\", \"from\": 993, \"to\": 1001}, {\"ngram\": \"people\", \"from\": 1003, \"to\": 1009}, {\"ngram\": \"all the hate\", \"from\": 1026, \"to\": 1038}, {\"ngram\": \"the aggression\", \"from\": 1040, \"to\": 1054}, {\"ngram\": \"negative news\", \"from\": 1059, \"to\": 1072}, {\"ngram\": \"IOC\", \"from\": 1143, \"to\": 1146}, {\"ngram\": \"his speech\", \"from\": 1178, \"to\": 1188}]}, {\"sentence\": \"\\\"We are longing for something which brings us together, something that is unifying, something that gives us hope.\", \"from\": 1191, \"to\": 1304, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"something\", \"from\": 1211, \"to\": 1220}, {\"ngram\": \"us\", \"from\": 1234, \"to\": 1236}, {\"ngram\": \"something\", \"from\": 1275, \"to\": 1284}, {\"ngram\": \"us\", \"from\": 1296, \"to\": 1298}, {\"ngram\": \"hope\", \"from\": 1299, \"to\": 1303}]}, {\"sentence\": \"The Olympic flame that we are lighting today is the symbol of this hope.\\\"\", \"from\": 1305, \"to\": 1378, \"entities\": [{\"begin\": 1309, \"end\": 1322, \"title\": \"http://dbpedia.org/resource/Olympic_flame\", \"score\": 1.0, \"rank\": 1.0251158718179285e-30, \"text\": \"Olympic flame\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_flame\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_flame\"}], \"noun_phrases\": [{\"ngram\": \"the symbol\", \"from\": 1353, \"to\": 1363}, {\"ngram\": \"this hope\", \"from\": 1367, \"to\": 1376}]}, {\"sentence\": \"The IOC has cleared the way for Russian and Belarusian athletes to compete at the Olympics despite the ongoing war in Ukraine but they will do so as neutral athletes with no national flag or anthem, a decision that angered Moscow.\", \"from\": 1380, \"to\": 1610, \