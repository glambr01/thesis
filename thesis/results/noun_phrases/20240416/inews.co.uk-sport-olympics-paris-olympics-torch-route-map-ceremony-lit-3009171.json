 1308}, {\"ngram\": \"an hour\", \"from\": 1327, \"to\": 1334}, {\"ngram\": \"a \\\"high priestess\", \"from\": 1348, \"to\": 1365}, {\"ngram\": \"other things\", \"from\": 1406, \"to\": 1418}, {\"ngram\": \"the flame\", \"from\": 1435, \"to\": 1444}]}, {\"sentence\": \"Apollo was clearly not feeling particularly helpful this year, as cloud cover meant the flame could not be lit.\", \"from\": 1446, \"to\": 1557, \"entities\": [{\"begin\": 1446, \"end\": 1452, \"title\": \"http://dbpedia.org/resource/Apollo\", \"score\": 0.9999999998899511, \"rank\": 1.0993745123553145e-10, \"text\": \"Apollo\", \"types\": [\"Q24229398\", \"Q178885\"], \"wikid\": \"http://dbpedia.org/resource/Apollo\", \"dbpedia\": \"http://dbpedia.org/resource/Apollo\"}], \"noun_phrases\": [{\"ngram\": \"cloud cover\", \"from\": 1512, \"to\": 1523}, {\"ngram\": \"the flame\", \"from\": 1530, \"to\": 1539}]}, {\"sentence\": \"The flame is supposed to be ignited by the sun's rays being captured by a parabolic mirror with combustible materials at the centre.\", \"from\": 1559, \"to\": 1691, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The flame\", \"from\": 1559, \"to\": 1568}, {\"ngram\": \"the sun's rays\", \"from\": 1598, \"to\": 1612}, {\"ngram\": \"a parabolic mirror\", \"from\": 1631, \"to\": 1649}, {\"ngram\": \"combustible materials\", \"from\": 1655, \"to\": 1676}, {\"ngram\": \"the centre\", \"from\": 1680, \"to\": 1690}]}, {\"sentence\": \"Yet under grey skies, the organisers had to resort to their back-up option - a pre-lit flame from one of the practice ceremonies which took place over the previous days.\", \"from\": 1692, \"to\": 1861, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"grey skies\", \"from\": 1702, \"to\": 1712}, {\"ngram\": \"the organisers\", \"from\": 1714, \"to\": 1728}, {\"ngram\": \"their back-up option\", \"from\": 1746, \"to\": 1766}, {\"ngram\": \"a pre-lit flame\", \"from\": 1769, \"to\": 1784}, {\"ngram\": \"the practice ceremonies\", \"from\": 1797, \"to