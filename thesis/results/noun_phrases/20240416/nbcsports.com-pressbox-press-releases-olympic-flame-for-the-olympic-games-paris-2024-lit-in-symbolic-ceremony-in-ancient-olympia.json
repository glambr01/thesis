"{\"uid\": \"nbcsports.com-pressbox-press-releases-olympic-flame-for-the-olympic-games-paris-2024-lit-in-symbolic-ceremony-in-ancient-olympia\", \"noun_phrases\": [{\"sentence\": \"On the eve of 100 days to go, the flame for theOlympic Games Paris 2024has been lit.\", \"from\": 0, \"to\": 84, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the eve\", \"from\": 3, \"to\": 10}, {\"ngram\": \"100 days\", \"from\": 14, \"to\": 22}, {\"ngram\": \"the flame\", \"from\": 30, \"to\": 39}, {\"ngram\": \"theOlympic Games Paris\", \"from\": 44, \"to\": 66}]}, {\"sentence\": \"It was ignited at the historic birthplace of the Olympic Games in Ancient Olympia in Greece.\", \"from\": 85, \"to\": 177, \"entities\": [{\"begin\": 170, \"end\": 176, \"title\": \"http://dbpedia.org/resource/Greece\", \"score\": 0.9999999905894583, \"rank\": 9.410572181826294e-09, \"text\": \"Greece\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Greece\", \"dbpedia\": \"http://dbpedia.org/resource/Greece\"}], \"noun_phrases\": [{\"ngram\": \"the historic birthplace\", \"from\": 103, \"to\": 126}, {\"ngram\": \"the Olympic Games\", \"from\": 130, \"to\": 147}, {\"ngram\": \"Ancient Olympia\", \"from\": 151, \"to\": 166}]}, {\"sentence\": \"The Olympic flame, embodying peace and hope, will now journey across Greece before coming to France.\", \"from\": 178, \"to\": 278, \"entities\": [{\"begin\": 182, \"end\": 195, \"title\": \"http://dbpedia.org/resource/Olympic_flame\", \"score\": 1.0, \"rank\": 1.2254379260692183e-43, \"text\": \"Olympic flame\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_flame\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_flame\"}, {\"begin\": 247, \"end\": 253, \"title\": \"http://dbpedia.org/resource/Greece\", \"score\": 0.9999999905894583, \"rank\": 9.410572181826294e-09, \"text\": \"Greece\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Greece\", \"dbpedia\": \"http://dbpedia.org/resource/Greece\"}, {\"begin\": 271, \"end\": 277, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.999996994554718, \"rank\": 3.0050388316864524e-06, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"peace\", \"from\": 207, \"to\": 212}, {\"ngram\": \"hope\", \"from\": 217, \"to\": 221}]}, {\"sentence\": \"After arriving in Marseille on 8 May, it will travel across the entire country, and some French overseas territories, arriving at the Opening Ceremony in Paris on 26 July.\", \"from\": 279, \"to\": 450, \"entities\": [{\"begin\": 297, \"end\": 306, \"title\": \"http://dbpedia.org/resource/Marseille\", \"score\": 0.9999999999986358, \"rank\": 1.4322555902504356e-12, \"text\": \"Marseille\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Marseille\", \"dbpedia\": \"http://dbpedia.org/resource/Marseille\"}, {\"begin\": 368, \"end\": 395, \"title\": \"http://dbpedia.org/resource/Overseas_France\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"French overseas territories\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Overseas_France\", \"dbpedia\": \"http://dbpedia.org/resource/Overseas_France\"}, {\"begin\": 433, \"end\": 438, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.456537331566479e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"8 May\", \"from\": 310, \"to\": 315}, {\"ngram\": \"the entire country\", \"from\": 339, \"to\": 357}, {\"ngram\": \"the Opening Ceremony\", \"from\": 409, \"to\": 429}, {\"ngram\": \"26 July\", \"from\": 442, \"to\": 449}]}, {\"sentence\": \"Amongst the dignitaries attending thishistoric eventtoday were International Olympic Committee (IOC) President Thomas Bach, President of the Hellenic Republic, Her Excellency Katerina Sakellaropoulou, the Vice President of the European Commission, Margaritis Schinas, Paris 2024 Organising Committee President, Tony Estanguet, President of the French National Olympic Committee and IOC Member, David Lappartient, the IOC Members in France, Guy Drut and Jean-Christophe Rolland, the French Minister of Sports and the Olympic and Paralympic Games, Am\\u00e9lie Oud\\u00e9a-Cast\\u00e9ra, the Chair of the IOC's Paris 2024 Coordination Commission, Pierre-Olivier Beckers Vieujant and the Mayor of Paris, Anne Hidalgo.\", \"from\": 452, \"to\": 1148, \"entities\": [{\"begin\": 515, \"end\": 552, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee (IOC)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 563, \"end\": 574, \"title\": \"http://dbpedia.org/resource/Thomas_Bach\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Thomas Bach\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Thomas_Bach\", \"dbpedia\": \"http://dbpedia.org/resource/Thomas_Bach\"}, {\"begin\": 593, \"end\": 601, \"title\": \"http://dbpedia.org/resource/Greece\", \"score\": 0.9999567903573405, \"rank\": 4.190134592962419e-05, \"text\": \"Hellenic\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Greece\", \"dbpedia\": \"http://dbpedia.org/resource/Greece\"}, {\"begin\": 602, \"end\": 610, \"title\": \"http://dbpedia.org/resource/Republic\", \"score\": 0.9996554561082831, \"rank\": 0.00028556817556552364, \"text\": \"Republic\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Republic\", \"dbpedia\": \"http://dbpedia.org/resource/Republic\"}, {\"begin\": 627, \"end\": 651, \"title\": \"http://dbpedia.org/resource/Katerina_Sakellaropoulou\",