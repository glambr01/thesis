 249, \"to\": 386, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the 25-year-old's road\", \"from\": 258, \"to\": 280}, {\"ngram\": \"victory\", \"from\": 284, \"to\": 291}, {\"ngram\": \"agender identity rowthat\", \"from\": 306, \"to\": 330}, {\"ngram\": \"many demand\", \"from\": 335, \"to\": 346}, {\"ngram\": \"Khelif\", \"from\": 352, \"to\": 358}, {\"ngram\": \"the Games\", \"from\": 376, \"to\": 385}]}, {\"sentence\": \"Despite the outside noise, Khelif rose to the occasion to claim gold and will now put her amateur days behind her as she enters the paid ranks.\", \"from\": 388, \"to\": 531, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the outside noise\", \"from\": 396, \"to\": 413}, {\"ngram\": \"Khelif\", \"from\": 415, \"to\": 421}, {\"ngram\": \"the occasion\", \"from\": 430, \"to\": 442}, {\"ngram\": \"gold\", \"from\": 452, \"to\": 456}, {\"ngram\": \"her amateur days\", \"from\": 474, \"to\": 490}, {\"ngram\": \"the paid ranks\", \"from\": 516, \"to\": 530}]}, {\"sentence\": \"'I would like to hold a press conference today to share with you my success story with the media family and young women who watch me,' she said on Sunday.\", \"from\": 533, \"to\": 687, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a press conference\", \"from\": 555, \"to\": 573}, {\"ngram\": \"my success story\", \"from\": 598, \"to\": 614}, {\"ngram\": \"the media family\", \"from\": 620, \"to\": 636}, {\"ngram\": \"young women\", \"from\": 641, \"to\": 652}, {\"ngram\": \"Sunday\", \"from\": 680, \"to\": 686}]}, {\"sentence\": \"'There is a documentary being prepared about my success story and it will be shown on international platforms.\", \"from\": 689, \"to\": 799, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a documentary\", \"from\": 699, \"to\": 712}, {\"ngram\": \"my success story\", \"from\": 734, \"to\": 750}, {\"ngram\": \"international platforms\", \"from\": 775, \"to\": 798}]}, {\"sentence\": \"'I will soon enter the world of professional boxing, I have many offers.\", \"from\": 801, \"to\": 873, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the world\", \"from\": 820, \"to\": 829}, {\"ngram\": \"professional boxing\", \"from\": 833, \"to\": 852}, {\"ngram\": \"many offers\", \"from\": 861, \"to\": 872}]}, {\"sentence\": \"Currently, I have not made up my mind about where I will enter professional boxing.\", \"from\": 874, \"to\": 957, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my mind\", \"from\": 904, \"to\": 911}, {\"ngram\": \"professional boxing\", \"from\": 937, \"to\": 956}]}, {\"sentence\": \"'But very soon I will take this step, we as Algerians would like to see our level in the field of professionalism.'\", \"from\": 959, \"to\": 1074, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this step\", \"from\": 986, \"to\": 995}, {\"ngram\": \"Algerians\", \"from\": 1003, \"to\": 1012}, {\"ngram\": \"our level\", \"from\": 1031, \"to\": 1040}, {\"ngram\": \"the field\", \"from\": 1044, \"to\": 1053}, {\"ngram\": \"professionalism\", \"from\": 1057, \"to\": 1072}]}, {\"sentence\": \"Khelif's story came under scrutiny in Paris after she was disqualified from last year's Women's World Championships for allegedly failing gender eligibility rules set by the International Boxing Association.\", \"from\": 1076, \"to\": 1283, \"entities\": [{\"begin\": 1114, \"end\": 1119, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999998496425746, \"rank\": 1.5035745192947426e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 1250, \"end\": 1282, \"title\": \"http://dbpedia.org/resource/Women's_International_Boxing_Association\", \"score\": 1.0, \"rank\": 2.821466153704013e-20, \"text\": \"International Boxing Association\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Women's_International_Boxing_Association\", \"dbpedia\": \"http://db