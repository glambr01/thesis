edia.org/resource/Royal_Adelaide_Hospital\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Royal Adelaide Hospital\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Royal_Adelaide_Hospital\", \"dbpedia\": \"http://dbpedia.org/resource/Royal_Adelaide_Hospital\"}], \"noun_phrases\": [{\"ngram\": \"serious injuries\", \"from\": 3817, \"to\": 3833}]}, {\"sentence\": \"Judge Press emphasised that Dennis was not being held criminally responsible for his wife's death.\", \"from\": 3872, \"to\": 3970, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Judge Press\", \"from\": 3872, \"to\": 3883}, {\"ngram\": \"Dennis\", \"from\": 3900, \"to\": 3906}, {\"ngram\": \"his wife's death\", \"from\": 3953, \"to\": 3969}]}, {\"sentence\": \"During his interview with police, the Olympian - who had competed at the London 2012 Olympics, Rio in 2016 and Tokyo in 2021 - told officers he had no intention of harming his wife, adding that it was 'the last thing I'd ever bloody do'.\", \"from\": 3972, \"to\": 4209, \"entities\": [{\"begin\": 4010, \"end\": 4018, \"title\": \"http://dbpedia.org/resource/Olympic_Games\", \"score\": 0.9999673962733184, \"rank\": 3.260431783786115e-05, \"text\": \"Olympian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games\"}, {\"begin\": 4045, \"end\": 4065, \"title\": \"http://dbpedia.org/resource/2012_Summer_Olympics\", \"score\": 1.0, \"rank\": 7.378426547141433e-19, \"text\": \"London 2012 Olympics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2012_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2012_Summer_Olympics\"}, {\"begin\": 4067, \"end\": 4070, \"title\": \"http://dbpedia.org/resource/Rio_de_Janeiro\", \"score\": 0.9206242754165676, \"rank\": 0.08621945640726919, \"text\": \"Rio\", \"types\": [\"Q486972\", \"Q3957\"], \"wikid\": \"http://dbpedia.org/resource/Rio_de_Janeiro\", \"dbpedia\": \"http://dbpedia.org/resource/Rio_de_Janeiro\"}, {\"begin\": 4083, \"end\": 4088, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.9587688445391771, \"rank\": 0.042320574003391495, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"his interview\", \"from\": 3979, \"to\": 3992}, {\"ngram\": \"police\", \"from\": 3998, \"to\": 4004}, {\"ngram\": \"- told officers\", \"from\": 4097, \"to\": 4112}, {\"ngram\": \"no intention\", \"from\": 4120, \"to\": 4132}, {\"ngram\": \"his wife\", \"from\": 4144, \"to\": 4152}, {\"ngram\": \"the last thing\", \"from\": 4174, \"to\": 4188}]}, {\"sentence\": \"'We were yelling at each other, and I was just like 'I am out', as in like I am just gonna leave the house,' Dennis told officers.\", \"from\": 4211, \"to\": 4341, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the house\", \"from\": 4308, \"to\": 4317}, {\"ngram\": \"Dennis\", \"from\": 4320, \"to\": 4326}, {\"ngram\": \"officers\", \"from\": 4332, \"to\": 4340}]}, {\"sentence\": \"'As I was getting in my car, my wife Mel ran out and as I was moving she jumped in front and onto the bonnet.\", \"from\": 4343, \"to\": 4452, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my car\", \"from\": 4364, \"to\": 4370}, {\"ngram\": \"my wife\", \"from\": 4372, \"to\": 4379}, {\"ngram\": \"Mel\", \"from\": 4380, \"to\": 4383}, {\"ngram\": \"front\", \"from\": 4426, \"to\": 4431}, {\"ngram\": \"the bonnet\", \"from\": 4441, \"to\": 4451}]}, {\"sentence\": \"'So I kept driving slowly down the lane and was like just looking at her, saying, 'What are you doing?'\", \"from\": 4454, \"to\": 4557, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the lane\", \"from\": 4485, \"to\": 4493}]}, {\"sentence\": \"'Then we got to the end of Medindie Lane and I stopped and noticed Mel was looking to jump off basically\\u2026 and she jumped off.'\", \"from\": 4559, \"to\": 4685, \"entities\": [{\"begin\": 4586, \"end\": 4594, \"title\": \"http://dbpedia.org/resource/North_Adelaide_Football_Club\", \"score\": 1.0, \"rank\": 8.083589095480298e-27, \"text\": \"Medindie\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/North_Adelaide_Football_Club\", \"dbpedia\": \"http://dbpedia.org/resource/North_Adelaide_Football_Club\"}], \"noun_phrases\": [{\"ngram\": \"the end\", \"from\": 4575, \"to\": 4582}, {\"ngram\": \"Mel\", \"from\": 4626, \"to\": 4629}]}, {\"sentence\": \"Recounting the moment that Hoskins fell to the floor, Dennis told police officers: 'She attempted to grab the door handle, which I believe she got a handle on now and must have been running next to the car trying to get onto the footstep to the side.\", \"from\": 4687, \"to\": 4937, \"entities\": [{\"begin\": 4714, \"end\": 4721, \"title\": \"http://dbpedia.org/resource/Bob_Hoskins\", \"score\": 0.9999999993669917, \"rank\": 6.324916808449983e-10, \"text\": \"Hoskins\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Bob_Hoskins\", \"dbpedia\": \"http://dbpedia.org/resource/Bob_Hoskins\"}], \"noun_phrases\": [{\"ngram\": \"the moment\", \"from\": 4698, \"to\": 4708}, {\"ngram\": \"the floor\", \"from\": 4730, \"to\": 4739}, {\"ngram\": \"Dennis\", \"from\": 4741, \"to\": 4747}, {\"ngram\": \"police officers\", \"from\": 4753, \"to\": 4768}, {\"ngram\": \"the door handle\", \"from\": 4793, \"to\": 4808}, {\"ngram\": \"a handle\", \"from\": 4834, \"to\": 4842}, {\"ngram\": \"the car\", \"from\": 4885, \"to\": 4892}, {\"ngram\": \"the footstep\", \"from\": 4912, \"to\": 4924}, {\"ngram\": \"the side\", \"from\": 4928, \"to\": 4936}]}, {\"sentence\": \"Dennis's post risks bringing back horrible memories for Hoskins' parents Peter and Amanda (pictured outside court after he was sentenced in May 2025) Dennis (pictured with Hoskins on their wedding day) refused to answer when he was asked if he wanted to apologise for his role in his wife's death 'At this stage, I have realised that like, she's probably gonna try and get on and it's getting a little bit out of control.\", \"from\": 4939, \"to\": 5362, \"entities\": [{\"begin\": 4995, \"end\": 5002, \"title\": \"http://dbpedia.org/resource/Bob_Hoskins\", \"score\": 0.9999999993669917, \"rank\": 6.324916808449983e-10, \"text\": \"Hoskins\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Bob_Hoskins\", \"dbpedia\": \"http://dbpedia.org/resource/Bob_Hoskins\"}, {\"begin\": 5012, \"end\": 5017, \"title\": \"http://dbpedia.org/resource/Peter_Griffin\", \"score\": 0.9999999900974217, \"rank\": 9.896089437656461e-09, \"text\": \"Peter\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Peter_Griffin\", \"dbpedia\": \"http://dbpedia.org/resource/Peter_Griffin\"}, {\"begin\": 5022, \"end\": 5028, \"title\": \"http://dbpedia.org/resource/Amanda_Tanen\", \"score\": 0.9999135336747216, \"rank\": 8.647380251072054e-05, \"text\": \"Amanda\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Amanda_Tanen\", \"dbpedia\": \"http://dbpedia.org/resource/Amanda_Tanen\"}, {\"begin\": 5112, \"end\": 5119, \"title\": \"http://dbpedia.org/resource/Bob_Hoskins\", \"score\": 0.9999999993669917, \"rank\": 6.324916808449983e-10, \"text\": \"Hoskins\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Bob_Hoskins\", \"dbpedia\": \"http://dbpedia.org/resource/Bob_Hoskins\"}], \"noun_phrases\": [{\"ngram\": \"Dennis's post risks\", \"from\": 4939, \"to\": 4958}, {\"ngram\": \"horrible memories\", \"from\": 4973, \"to\": 4990}, {\"ngram\": \"outside court\", \"from\": 5039, \"to\": 5052}, {\"ngram\": \"May\", \"from\": 5079, \"to\": 5082}, {\"ngram\": \"Dennis\", \"from\": 5089, \"to\": 5095}, {\"ngram\": \"their wedding day\", \"from\": 5122, \"to\": 5139}, {\"ngram\": \"his role\", \"from\": 5207, \"to\": 5215}, {\"ngram\": \"his wife's death\", \"from\": 5219, \"to\": 5235}, {\"ngram\": \"this stage\", \"from\": 5240, \"to\": 5250}, {\"ngram\": \"control\", \"from\": 5352, \"to\": 5359}]}, {\"sentence\": \"'From memory, I let go of the accelerator but I heard a thump and I saw in my mirror that she was on the ground.'\", \"from\": 5364, \"to\": 5477, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"memory\", \"from\": 5370, \"to\": 5376}, {\"ngram\": \"the accelerator\", \"from\": 5390, \"to\": 5405}, {\"ngram\": \"a thump\", \"from\": 5418, \"to\": 5425}, {\"ngram\": \"my mirror\", \"from\": 5439, \"to\": 5448}, {\"ngram\": \"the ground\", \"from\": 5465, \"to\": 5475}]}, {\"sentence\": \"Unlike Dennis - who refused to answer when he was asked if he wanted to apologise outside the court - Hoskins' parents wanted to make a point about how the family should deal with the tragedy.\", \"from\": 5479, \"to\": 5671, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Dennis\", \"from\": 5486, \"to\": 5492}, {\"ngram\": \"the court - Hoskins' parents\", \"from\": 5569, \"to\": 5597}, {\"ngram\": \"a point\", \"from\": 5613, \"to\": 5620}, {\"ngram\": \"the family\", \"from\": 5631, \"to\": 5641}, {\"ngram\": \"the tragedy\", \"from\": 5659, \"to\": 5670}]}, {\"sentence\": \"'We are glad the trial is over, and shortened considerably by Rohan's guilty plea,' Peter Hoskins said through tears.\", \"from\": 5673, \"to\": 5790, \"entities\": [{\"begin\": 5735, \"end\": 5740, \"title\": \"http://dbpedia.org/resource/Characters_of_Dragon_Prince\", \"score\": 0.7215331278316905, \"rank\": 0.38590070293548145, \"text\": \"Rohan\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Characters_of_Dragon_Prince\", \"dbpedia\": \"http://dbpedia.org/resource/Characters_of_Dragon_Prince\"}, {\"begin\": 5757, \"end\": 5762, \"title\": \"http://dbpedia.org/resource/Peter_Gr