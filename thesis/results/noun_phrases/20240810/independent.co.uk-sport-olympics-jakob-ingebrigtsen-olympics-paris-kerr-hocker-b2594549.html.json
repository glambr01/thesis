": [{\"ngram\": \"the most anticipated races\", \"from\": 681, \"to\": 707}, {\"ngram\": \"ofParis\", \"from\": 708, \"to\": 715}, {\"ngram\": \"a medal\", \"from\": 739, \"to\": 746}, {\"ngram\": \"gold medallistCole Hocker\", \"from\": 776, \"to\": 801}, {\"ngram\": \"Kerrtaking silver\", \"from\": 818, \"to\": 835}, {\"ngram\": \"bronze\", \"from\": 861, \"to\": 867}]}, {\"sentence\": \"The Norwegian rebounded in the 5000m, thriving in a slow race to outkick his rivals to defend his title in 13 mins and 13.66 secs ahead of Ronald Kwemoi and Grant Fisher, before explaining how he responded to his 1500m setback.\", \"from\": 870, \"to\": 1097, \"entities\": [{\"begin\": 874, \"end\": 883, \"title\": \"http://dbpedia.org/resource/Norway\", \"score\": 0.7982755241699979, \"rank\": 0.25215554014055613, \"text\": \"Norwegian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Norway\", \"dbpedia\": \"http://dbpedia.org/resource/Norway\"}, {\"begin\": 1009, \"end\": 1022, \"title\": \"http://dbpedia.org/resource/Ronald_Kwemoi\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Ronald Kwemoi\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Ronald_Kwemoi\", \"dbpedia\": \"http://dbpedia.org/resource/Ronald_Kwemoi\"}, {\"begin\": 1027, \"end\": 1039, \"title\": \"http://dbpedia.org/resource/Grant_Fisher\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Grant Fisher\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Grant_Fisher\", \"dbpedia\": \"http://dbpedia.org/resource/Grant_Fisher\"}], \"noun_phrases\": [{\"ngram\": \"the 5000m\", \"from\": 897, \"to\": 906}, {\"ngram\": \"a slow race\", \"from\": 920, \"to\": 931}, {\"ngram\": \"his rivals\", \"from\": 943, \"to\": 953}, {\"ngram\": \"his title\", \"from\": 964, \"to\": 973}, {\"ngram\": \"13 mins\", \"from\": 977, \"to\": 984}, {\"ngram\": \"13.66 secs\", \"from\": 989, \"to\": 999}, {\"ngram\": \"his 1500m setback\", \"from\": 1079, \"to\": 1096}]}, {\"sentence\": \"\\\"I think one of the biggest confusions is that it's something you put behind you,\\\" Ingebrigtsen explained when asked how he put the 1500m defeat behind him.\", \"from\": 1099, \"to\": 1255, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the biggest confusions\", \"from\": 1115, \"to\": 1137}, {\"ngram\": \"something\", \"from\": 1151, \"to\": 1160}, {\"ngram\": \"Ingebrigtsen\", \"from\": 1182, \"to\": 1194}, {\"ngram\": \"the 1500m defeat\", \"from\": 1227, \"to\": 1243}]}, {\"sentence\": \"\\\"I still remember many of my losses in my junior career or even when I was very young and also in my World Championships in Doha.\", \"from\": 1256, \"to\": 1385, \"entities\": [{\"begin\": 1380, \"end\": 1384, \"title\": \"http://dbpedia.org/resource/Doha\", \"score\": 0.9999452319623957, \"rank\": 5.47710373110628e-05, \"text\": \"Doha\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Doha\", \"dbpedia\": \"http://dbpedia.org/resource/Doha\"}], \"noun_phrases\": [{\"ngram\": \"my losses\", \"from\": 1282, \"to\": 1291}, {\"ngram\": \"my junior career\", \"from\": 1295, \"to\": 1311}, {\"ngram\": \"my World Championships\", \"from\": 1354, \"to\": 1376}]}, {\"sentence\": \"\\\"These are things that will haunt me for the rest of my life.\", \"from\": 1387, \"to\": 1448, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"things\", \"from\": 1398, \"to\": 1404}, {\"ngram\": \"the rest\", \"from\": 1428, \"to\": 1436}, {\"ngram\": \"my life\", \"from\": 1440, \"to\": 1447}]}, {\"sentence\": \"It's why it's important to perform as we have that memory of losing and not accomplishing what we want.\", \"from\": 1449, \"to\": 1552, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"that memory\", \"from\": 1495, \"to\": 1506}]}, {\"sentence\": \"I think it's something that motivates us to put in work and do what's needed to perform.\", \"from\": 1553, \"to\": 1641, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"something\", \"from\": 1566, \"to\": 1575}, {\"ngram\": \"us\", \"from\": 1591, \"to\": 1593}, {\"ngram\": \"work\", \"from\": 1604, \"to\": 1608}]}, {\"sentence\": \"\\\"It's different to handle it, but it's always something that will be there.\", \"from\": 1643, \"to\": 1718, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"something\", \"from\": 1689, \"to\": 1698}]}, {\"sentence\": \"It's a big part of sports, I think many of the greatest athletes will have defeats that will haunt them for the rest of their lives, but hopefully, the reward of accomplishing things and creating memories outweighs them.\\\"\", \"from\": 1719, \"to\": 1940, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a big part\", \"from\": 1724, \"to\": 1734}, {\"ngram\": \"sports\", \"from\": 1738, \"to\": 1744}, {\"ngram\": \"the greatest athletes\", \"from\": 1762, \"to\": 1783}, {\"ngram\": \"defeats\", \"from\": 1794, \"to\": 1801}, {\"ngram\": \"the rest\", \"from\": 1827, \"to\": 1835}, {\"ngram\": \"their lives\", \"from\": 1839, \"to\": 1850}, {\"ngram\": \"the reward\", \"from\": 1867, \"to\": 1877}, {\"ngram\": \"things\", \"from\": 1895, \"to\": 1901}, {\"ngram\": \"memories\", \"from\": 1915, \"to\": 1923}]}, {\"sentence\": \"While Ingebrigtsen also discussed his mindset surrounding pressure to change his tactics after three successive defeats in major finals to Jake Wightman, Kerr and now Hocker.\", \"from\": 1942, \"to\": 2116, \"entities\": [{\"begin\": 2081, \"end\": 2094, \"title\": \"http://dbpedia.org/resource/Jake_Wightman\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Jake Wightman\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jake_Wightman\", \"dbpedia\": \"http://dbpedia.org/resource/Jake_Wightman\"}], \"noun_phrases\": [{\"ngram\": \"Ingebrigtsen\", \"from\": 1948, \"to\": 1960}, {\"ngram\": \"his mindset\", \"from\": 1976, \"to\": 1987}, {\"ngram\": \"surrounding pressure\", \"from\":