], \"noun_phrases\": [{\"ngram\": \"poem\", \"from\": 2449, \"to\": 2453}, {\"ngram\": \"Robert Browninghad\", \"from\": 2457, \"to\": 2475}, {\"ngram\": \"the story\", \"from\": 2483, \"to\": 2492}, {\"ngram\": \"Br\\u00e9al's contemporaries\", \"from\": 2504, \"to\": 2526}]}, {\"sentence\": \"Holding a race to echo that run, Br\\u00e9al thought, would connect the new Games to their ancient heritage.\", \"from\": 2529, \"to\": 2631, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a race\", \"from\": 2537, \"to\": 2543}, {\"ngram\": \"that run\", \"from\": 2552, \"to\": 2560}, {\"ngram\": \"Br\\u00e9al\", \"from\": 2562, \"to\": 2567}, {\"ngram\": \"the new Games\", \"from\": 2591, \"to\": 2604}, {\"ngram\": \"their ancient heritage\", \"from\": 2608, \"to\": 2630}]}, {\"sentence\": \"The idea of running such a long race was strange at the time.\", \"from\": 2635, \"to\": 2696, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The idea\", \"from\": 2635, \"to\": 2643}, {\"ngram\": \"such a long race\", \"from\": 2655, \"to\": 2671}, {\"ngram\": \"the time\", \"from\": 2687, \"to\": 2695}]}, {\"sentence\": \"Other than the marathon, the 1896 Games featured no runs longer than 1,500 meters-a footrace that tookbarely four and a half minutes.\", \"from\": 2697, \"to\": 2830, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the marathon\", \"from\": 2708, \"to\": 2720}, {\"ngram\": \"the 1896 Games\", \"from\": 2722, \"to\": 2736}, {\"ngram\": \"no runs\", \"from\": 2746, \"to\": 2753}, {\"ngram\": \"1,500 meters\", \"from\": 2766, \"to\": 2778}, {\"ngram\": \"a footrace\", \"from\": 2779, \"to\": 2789}]}, {\"sentence\": \"At the ancient-Greek Games, the longest race held, thedolichos, covered less ground than a Turkey Trot 5K.\", \"from\": 2831, \"to\": 2937, \"entities\": [{\"begin\": 2922, \"end\": 2933, \"title\": \"http://dbpedia.org/resource/Turkey_trot\", \"score\": 1.0, \"rank\": 5.148588226938514e-35, \"text\": \"Turkey Trot\", \"types\": [], \"wikid\": \"