: [], \"noun_phrases\": [{\"ngram\": \"an antique flavor\", \"from\": 1870, \"to\": 1887}]}, {\"sentence\": \"If we knew how long the Greek warrior took, we could set the standard.\", \"from\": 1889, \"to\": 1959, \"entities\": [{\"begin\": 1913, \"end\": 1918, \"title\": \"http://dbpedia.org/resource/Ancient_Greece\", \"score\": 0.9999547118801191, \"rank\": 4.528979804894772e-05, \"text\": \"Greek\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ancient_Greece\", \"dbpedia\": \"http://dbpedia.org/resource/Ancient_Greece\"}], \"noun_phrases\": [{\"ngram\": \"the standard\", \"from\": 1946, \"to\": 1958}]}, {\"sentence\": \"For my part, I would claim the honor of offering \\\"the Marathon Cup.\\\"\", \"from\": 1960, \"to\": 2028, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my part\", \"from\": 1964, \"to\": 1971}, {\"ngram\": \"the honor\", \"from\": 1987, \"to\": 1996}, {\"ngram\": \"the Marathon Cup\", \"from\": 2010, \"to\": 2026}]}, {\"sentence\": \"Br\\u00e9al, who wrote extensively aboutGreek myth, knew the story of the Battle of Marathon in 490 B.C.E., at which the Athenians crushed a much larger Persian army that had seemed unstoppable.\", \"from\": 2032, \"to\": 2220, \"entities\": [{\"begin\": 2147, \"end\": 2156, \"title\": \"http://dbpedia.org/resource/History_of_Athens\", \"score\": 0.9998411553098844, \"rank\": 0.00015886992579027714, \"text\": \"Athenians\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/History_of_Athens\", \"dbpedia\": \"http://dbpedia.org/resource/History_of_Athens\"}, {\"begin\": 2179, \"end\": 2186, \"title\": \"http://dbpedia.org/resource/Achaemenid_Empire\", \"score\": 0.9999999994397513, \"rank\": 5.603246750372758e-10, \"text\": \"Persian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Achaemenid_Empire\", \"dbpedia\": \"http://dbpedia.org/resource/Achaemenid_Empire\"}], \"noun_phrases\": [{\"ngram\": \"Br\\u00e9al\", \"from\": 2032, \"to\": 2037}, {\"ngram\": \"myth\", \"from\": 