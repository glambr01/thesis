n\", \"score\": 1.0, \"rank\": 1.5783113409206524e-39, \"text\": \"Lucian\", \"types\": [\"Q729\", \"Q5\", \"Q36180\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Lucian\", \"dbpedia\": \"http://dbpedia.org/resource/Lucian\"}], \"noun_phrases\": [{\"ngram\": \"his facts\", \"from\": 5486, \"to\": 5495}, {\"ngram\": \"the two stories\", \"from\": 5518, \"to\": 5533}, {\"ngram\": \"the version\", \"from\": 5561, \"to\": 5572}, {\"ngram\": \"Browning\", \"from\": 5597, \"to\": 5605}, {\"ngram\": \"Br\\u00e9al\", \"from\": 5610, \"to\": 5615}]}, {\"sentence\": \"But the sketchiness of the origin story was known at the time.The New York Times' 1896 articleon Spyridon Louis's victory took \\\"the risk of sacrificing a glorious bit of sentiment\\\" by noting that the tale \\\"sounds suspiciously like a combination of [Herodotus and Plutarch] to suit the dramatic occasion.\\\"\", \"from\": 5617, \"to\": 5921, \"entities\": [{\"begin\": 5683, \"end\": 5691, \"title\": \"http://dbpedia.org/resource/New_York_City\", \"score\": 0.9999999598717303, \"rank\": 4.0128097977563174e-08, \"text\": \"New York\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/New_York_City\", \"dbpedia\": \"http://dbpedia.org/resource/New_York_City\"}, {\"begin\": 5714, \"end\": 5728, \"title\": \"http://dbpedia.org/resource/Spyridon_Louis\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Spyridon Louis\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Spyridon_Louis\", \"dbpedia\": \"http://dbpedia.org/resource/Spyridon_Louis\"}, {\"begin\": 5866, \"end\": 5875, \"title\": \"http://dbpedia.org/resource/Herodotus\", \"score\": 1.0, \"rank\": 2.1263691322994237e-71, \"text\": \"Herodotus\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Herodotus\", \"dbpedia\": \"http://dbpedia.org/resource/Herodotus\"}], \"noun_phrases\": [{\"ngram\": \"the sketchiness\", 