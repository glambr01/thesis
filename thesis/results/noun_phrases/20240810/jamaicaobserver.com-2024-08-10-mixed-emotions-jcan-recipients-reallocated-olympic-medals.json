549}]}, {\"sentence\": \"Hammond Ross was upgraded to a bronze medal in the women's long jump in Beijing after a retest of then-silver medallist Tatyana Lebedeva of Russia, in 2017, revealed a banned substance, leading to her disqualification.\", \"from\": 1618, \"to\": 1836, \"entities\": [{\"begin\": 1618, \"end\": 1625, \"title\": \"http://dbpedia.org/resource/Richard_Hammond\", \"score\": 0.9798020259115281, \"rank\": 0.02060924070415339, \"text\": \"Hammond\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Richard_Hammond\", \"dbpedia\": \"http://dbpedia.org/resource/Richard_Hammond\"}, {\"begin\": 1626, \"end\": 1630, \"title\": \"http://dbpedia.org/resource/Ross_Geller\", \"score\": 1.0, \"rank\": 3.394709104191002e-14, \"text\": \"Ross\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Ross_Geller\", \"dbpedia\": \"http://dbpedia.org/resource/Ross_Geller\"}, {\"begin\": 1690, \"end\": 1697, \"title\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"score\": 1.0, \"rank\": 8.063287565966366e-14, \"text\": \"Beijing\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2008_Summer_Olympics\"}, {\"begin\": 1738, \"end\": 1754, \"title\": \"http://dbpedia.org/resource/Tatyana_Lebedeva\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Tatyana Lebedeva\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Tatyana_Lebedeva\", \"dbpedia\": \"http://dbpedia.org/resource/Tatyana_Lebedeva\"}, {\"begin\": 1758, \"end\": 1764, \"title\": \"http://dbpedia.org/resource/Russia_national_rugby_league_team\", \"score\": 0.5793263884058145, \"rank\": 0.7195048605788155, \"text\": \"Russia\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Russia_national_rugby_league_team\", \"dbpedia\": \"http://dbpedia.org/resource/Russia_national