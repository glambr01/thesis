rce/Government_of_Russia\"}, {\"begin\": 3179, \"end\": 3205, \"title\": \"http://dbpedia.org/resource/Russian_Anti-Doping_Agency\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Russian Anti-Doping Agency\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Russian_Anti-Doping_Agency\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_Anti-Doping_Agency\"}, {\"begin\": 3179, \"end\": 3205, \"title\": \"http://dbpedia.org/resource/Russian_Anti-Doping_Agency\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Russian Anti-Doping Agency\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Russian_Anti-Doping_Agency\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_Anti-Doping_Agency\"}], \"noun_phrases\": [{\"ngram\": \"The RADA legislation\", \"from\": 2962, \"to\": 2982}, {\"ngram\": \"the wake\", \"from\": 2998, \"to\": 3006}, {\"ngram\": \"therevelations\", \"from\": 3010, \"to\": 3024}, {\"ngram\": \"whistleblower Dr Grigory Rodchenkovthat\", \"from\": 3033, \"to\": 3072}, {\"ngram\": \"anti-doping processes\", \"from\": 3125, \"to\": 3146}, {\"ngram\": \"andWADA's failure\", \"from\": 3147, \"to\": 3164}, {\"ngram\": \"an imposed deadline\", \"from\": 3218, \"to\": 3237}]}, {\"sentence\": \"In 2015, the United States had exercised its extraterritorial powers by having 14 FIFA officials arrested in Switzerland overbribery allegationsrelated to broadcast rights.\", \"from\": 3247, \"to\": 3419, \"entities\": [{\"begin\": 3260, \"end\": 3273, \"title\": \"http://dbpedia.org/resource/Federal_government_of_the_United_States\", \"score\": 0.9999998413759511, \"rank\": 1.586238492792506e-07, \"text\": \"United States\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Federal_government_of_the_United_States\", \"dbpedia\": \"http://dbpedia.org/resource/Federal_government_of_the_United_States\"}, {\"begin\": 3329, \"end\": 3333, \"title\": \"http://dbpedia.org/resource/FIFA\", \"score\": 1.0, \"rank\": 7.