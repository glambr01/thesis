\": 673}]}, {\"sentence\": \"Daniel finished fifth at the World Athletics Championships two years ago and had high hopes heading into the 10,000m final.\", \"from\": 719, \"to\": 842, \"entities\": [{\"begin\": 748, \"end\": 777, \"title\": \"http://dbpedia.org/resource/2009_World_Championships_in_Athletics\", \"score\": 0.5416240038999044, \"rank\": 0.5653121627596486, \"text\": \"World Athletics Championships\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2009_World_Championships_in_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/2009_World_Championships_in_Athletics\"}], \"noun_phrases\": [{\"ngram\": \"Daniel\", \"from\": 719, \"to\": 725}, {\"ngram\": \"high hopes\", \"from\": 800, \"to\": 810}, {\"ngram\": \"the 10,000m\", \"from\": 824, \"to\": 835}]}, {\"sentence\": \"But she was not the only runner to pull out mid-race with Frenchwoman Alessia Zarbo exiting after falling over, which resulted in gasps from the home crowd.\", \"from\": 844, \"to\": 1000, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the only runner\", \"from\": 860, \"to\": 875}, {\"ngram\": \"mid\", \"from\": 888, \"to\": 891}, {\"ngram\": \"race\", \"from\": 892, \"to\": 896}, {\"ngram\": \"Frenchwoman Alessia Zarbo\", \"from\": 902, \"to\": 927}, {\"ngram\": \"gasps\", \"from\": 974, \"to\": 979}, {\"ngram\": \"the home crowd\", \"from\": 985, \"to\": 999}]}, {\"sentence\": \"The bronze medal went to Dutchwoman Sifan Hassan and Italy's Nadia Battocletti took silver with Kenya's Chebet finishing ahead of both of them.\", \"from\": 1002, \"to\": 1145, \"entities\": [{\"begin\": 1038, \"end\": 1050, \"title\": \"http://dbpedia.org/resource/Sifan_Hassan\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Sifan Hassan\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Sifan_Hassan\", \"dbpedia\": \"http://dbpedia.org/resource/Sifan_Hassan\"}, {\"begin\": 1063, \"end\": 1080, \"title\": \"http://dbpedia.org/resource/