rom\": 5484, \"to\": 5492}, {\"ngram\": \"only one member\", \"from\": 5506, \"to\": 5521}]}, {\"sentence\": \"Read: Seven books that will change how you watch the Olympics Three years later, on August 5, 1984, Benoit Samuelson quickly took the Olympic marathon's lead and held it.\", \"from\": 5554, \"to\": 5725, \"entities\": [{\"begin\": 5655, \"end\": 5661, \"title\": \"http://dbpedia.org/resource/Alex_Benoit\", \"score\": 0.9999269450483589, \"rank\": 7.306009703329532e-05, \"text\": \"Benoit\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q13219587\"], \"wikid\": \"http://dbpedia.org/resource/Alex_Benoit\", \"dbpedia\": \"http://dbpedia.org/resource/Alex_Benoit\"}, {\"begin\": 5662, \"end\": 5671, \"title\": \"http://dbpedia.org/resource/Paul_Samuelson\", \"score\": 1.0, \"rank\": 5.380556347192789e-15, \"text\": \"Samuelson\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q188094\"], \"wikid\": \"http://dbpedia.org/resource/Paul_Samuelson\", \"dbpedia\": \"http://dbpedia.org/resource/Paul_Samuelson\"}], \"noun_phrases\": [{\"ngram\": \"Seven books\", \"from\": 5560, \"to\": 5571}, {\"ngram\": \"the Olympics\", \"from\": 5603, \"to\": 5615}, {\"ngram\": \"August\", \"from\": 5638, \"to\": 5644}, {\"ngram\": \"the Olympic marathon's lead\", \"from\": 5684, \"to\": 5711}]}, {\"sentence\": \"Shecrossed the finish linein the Los Angeles Coliseum in 2:24:52, mere months after undergoing knee surgery.\", \"from\": 5726, \"to\": 5834, \"entities\": [{\"begin\": 5759, \"end\": 5779, \"title\": \"http://dbpedia.org/resource/Los_Angeles_Memorial_Coliseum\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Los Angeles Coliseum\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Los_Angeles_Memorial_Coliseum\", \"dbpedia\": \"http://dbpedia.org/resource/Los_Angeles_Memorial_Coliseum\"}], \"noun_phrases\": [{\"ngram\": \"the finish linein\", \"from\": 5737, \"to\": 5754}, {\"ngram\": \"knee surgery\", \"from\": 5821, \"to\": 5833}]}, {\"sen