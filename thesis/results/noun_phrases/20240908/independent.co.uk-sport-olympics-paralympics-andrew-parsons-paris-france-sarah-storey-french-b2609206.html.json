"}], \"noun_phrases\": [{\"ngram\": \"history\", \"from\": 2439, \"to\": 2446}, {\"ngram\": \"the first female triple rowing champion\", \"from\": 2468, \"to\": 2507}, {\"ngram\": \"her domination\", \"from\": 2541, \"to\": 2555}, {\"ngram\": \"wheelchair\", \"from\": 2559, \"to\": 2569}, {\"ngram\": \"an eighth career title\", \"from\": 2590, \"to\": 2612}]}, {\"sentence\": \"Like Cockroft, Britain's most successful Paralympian DameSarah Storeyboasts a proud unbeaten record, which was stretched to 14 cycling races as two road triumphs moved her on to 19 golds overall, including her swimming exploits.\", \"from\": 2639, \"to\": 2867, \"entities\": [{\"begin\": 2644, \"end\": 2652, \"title\": \"http://dbpedia.org/resource/Don_Cockroft\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Cockroft\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q14128148\"], \"wikid\": \"http://dbpedia.org/resource/Don_Cockroft\", \"dbpedia\": \"http://dbpedia.org/resource/Don_Cockroft\"}], \"noun_phrases\": [{\"ngram\": \"a proud unbeaten record\", \"from\": 2715, \"to\": 2738}, {\"ngram\": \"14 cycling races\", \"from\": 2763, \"to\": 2779}, {\"ngram\": \"two road triumphs\", \"from\": 2783, \"to\": 2800}, {\"ngram\": \"19 golds\", \"from\": 2817, \"to\": 2825}, {\"ngram\": \"her swimming exploits\", \"from\": 2845, \"to\": 2866}]}, {\"sentence\": \"The formidable pair could well be in California in four years' time to be joined by GB's many breakthrough stars.\", \"from\": 2869, \"to\": 2982, \"entities\": [{\"begin\": 2906, \"end\": 2916, \"title\": \"http://dbpedia.org/resource/California_Golden_Bears\", \"score\": 0.7472919638608828, \"rank\": 0.3381646273878048, \"text\": \"California\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/California_Golden_Bears\", \"dbpedia\": \"http://dbpedia.org/resource/California_Golden_Bears\"}, {\"begin\": 2953, \"end\": 2955, \"title\": \"http://dbpedia.org/resource/Great_Britain\", \"scor