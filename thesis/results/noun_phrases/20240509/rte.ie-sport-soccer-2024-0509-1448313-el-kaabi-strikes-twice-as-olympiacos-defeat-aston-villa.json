tle\": \"http://dbpedia.org/resource/Moussa_Diaby\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Moussa Diaby\", \"types\": [\"Q937857\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Moussa_Diaby\", \"dbpedia\": \"http://dbpedia.org/resource/Moussa_Diaby\"}, {\"begin\": 1311, \"end\": 1322, \"title\": \"http://dbpedia.org/resource/Leon_Bailey\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Leon Bailey\", \"types\": [\"Q937857\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Leon_Bailey\", \"dbpedia\": \"http://dbpedia.org/resource/Leon_Bailey\"}, {\"begin\": 1403, \"end\": 1415, \"title\": \"http://dbpedia.org/resource/Douglas_Luiz\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Douglas Luiz\", \"types\": [\"Q937857\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Douglas_Luiz\", \"dbpedia\": \"http://dbpedia.org/resource/Douglas_Luiz\"}], \"noun_phrases\": [{\"ngram\": \"the 30th minute\", \"from\": 1289, \"to\": 1304}, {\"ngram\": \"home goalkeeper Kostas Tzolakis\", \"from\": 1343, \"to\": 1374}, {\"ngram\": \"his effort\", \"from\": 1383, \"to\": 1393}, {\"ngram\": \"the free-kick\", \"from\": 1423, \"to\": 1436}, {\"ngram\": \"play\", \"from\": 1447, \"to\": 1451}]}, {\"sentence\": \"Tzolakis had to be at his best on the stroke of half-time to claw Bailey's deflected shot over as Villa pushed for one back before the break.\", \"from\": 1471, \"to\": 1612, \"entities\": [{\"begin\": 1537, \"end\": 1543, \"title\": \"http://dbpedia.org/resource/Trevor_Bailey\", \"score\": 0.9999999961924004, \"rank\": 2.957193690258985e-09, \"text\": \"Bailey\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Trevor_Bailey\", \"dbpedia\": \"http://dbpedia.org/resource/Trevor_Bailey\"}], \"noun_phrases\": [{\"ngram\": \"Tzolakis\", \"from\": 1471, \"to\": 1479}, {\"ngram\": \"the stroke\", \"from\": 1505, \"to\": 1515}, {