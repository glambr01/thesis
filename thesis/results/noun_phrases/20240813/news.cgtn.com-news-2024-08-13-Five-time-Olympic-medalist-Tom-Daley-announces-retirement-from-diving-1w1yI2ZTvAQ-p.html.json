, {\"sentence\": \"This is exactly why I did this.\", \"from\": 1173, \"to\": 1204, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"...\", \"from\": 1205, \"to\": 1208, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"It was emotional at the end, up there on the platform, knowing it was going to be my last competitive dive.\", \"from\": 1209, \"to\": 1316, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the end\", \"from\": 1229, \"to\": 1236}, {\"ngram\": \"the platform\", \"from\": 1250, \"to\": 1262}, {\"ngram\": \"my last competitive dive\", \"from\": 1291, \"to\": 1315}]}, {\"sentence\": \"But I have to make the decision at some point, and it feels like the right time.\", \"from\": 1317, \"to\": 1397, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the decision\", \"from\": 1336, \"to\": 1348}, {\"ngram\": \"some point\", \"from\": 1352, \"to\": 1362}, {\"ngram\": \"the right time\", \"from\": 1382, \"to\": 1396}]}, {\"sentence\": \"It's the right time to call it a day.\\u00e2\\u0080\\u009d Daley's gold came in the 10m synchronized event in Tokyo in 2021 alongside Matty Lee.\", \"from\": 1398, \"to\": 1525, \"entities\": [{\"begin\": 1491, \"end\": 1496, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.9702658470334056, \"rank\": 0.03064503810410011, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}, {\"begin\": 1515, \"end\": 1524, \"title\": \"http://dbpedia.org/resource/Matty_Lee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Matty Lee\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Matty_Lee\", \"dbpedia\": \"http://dbpedia.org/resource/Matty_Lee\"}], \"noun_phrases\": [{\"ngram\": \"the right time\", \"from\": 1403, \"to\": 1417}, {\"ngram\": \"a day.\\u00e2\\u0080\\u009d Daley's gold\", \"from\": 1429, \"to\": 1451}, {\"ngram\": \"the 10m synchronized event\",