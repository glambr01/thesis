042}]}, {\"sentence\": \"It was just back to normal life right after Tokyo,\\\" he said.\", \"from\": 3054, \"to\": 3114, \"entities\": [{\"begin\": 3098, \"end\": 3103, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.9977129458678059, \"rank\": 0.0022922963911560573, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}], \"noun_phrases\": [{\"ngram\": \"normal life\", \"from\": 3074, \"to\": 3085}]}, {\"sentence\": \"\\\"So this is a pretty surreal feeling, you know, it's, like, incredible.\\\"\", \"from\": 3116, \"to\": 3188, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a pretty surreal feeling\", \"from\": 3128, \"to\": 3152}]}, {\"sentence\": \"His words were echoed by Australian swimmer Kaylee McKeown, who reflected on another successful games in which she won two gold, a sliver and two bronze medals.\", \"from\": 3190, \"to\": 3350, \"entities\": [{\"begin\": 3215, \"end\": 3225, \"title\": \"http://dbpedia.org/resource/Australians\", \"score\": 0.9995245453129824, \"rank\": 0.000475675998376399, \"text\": \"Australian\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Australians\", \"dbpedia\": \"http://dbpedia.org/resource/Australians\"}, {\"begin\": 3234, \"end\": 3248, \"title\": \"http://dbpedia.org/resource/Kaylee_McKeown\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Kaylee McKeown\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Kaylee_McKeown\", \"dbpedia\": \"http://dbpedia.org/resource/Kaylee_McKeown\"}], \"noun_phrases\": [{\"ngram\": \"His words\", \"from\": 3190, \"to\": 3199}, {\"ngram\": \"another successful games\", \"from\": 3267, \"to\": 3291}, {\"ngram\": \"two gold\", \"from\": 3309, \"to\": 3317}, {\"ngram\": \"a sliver\", \"from\": 3319, \"to\": 3327}, {\"ngram\": \"two bronze medals\", \"from\": 3332, \"to\": 3349}]}, {\"sentence\": \"\\\"We are all pretty exhausted, but excited,\\\" she also told Sky News Australia.\", \"from\": 3352, \"to\": 3429, \"entities\": [{\"begin\": 3410, \"end\": 3428, \"title\": \"http://dbpedia.org/resource/Sky_News_Australia\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Sky News Australia\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/Sky_News_Australia\", \"dbpedia\": \"http://dbpedia.org/resource/Sky_News_Australia\"}], \"noun_phrases\": []}, {\"sentence\": \"\\\"Could not get much better than the atmosphere they had in Paris, I have never been in something like that before so it's pretty cool to basically be a little ant on pool deck just swimming my little heart out.\\\"\", \"from\": 3431, \"to\": 3642, \"entities\": [{\"begin\": 3490, \"end\": 3495, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 5.081334639895684e-16, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"the atmosphere\", \"from\": 3463, \"to\": 3477}, {\"ngram\": \"something\", \"from\": 3518, \"to\": 3527}, {\"ngram\": \"pool deck\", \"from\": 3597, \"to\": 3606}, {\"ngram\": \"my little heart\", \"from\": 3621, \"to\": 3636}]}, {\"sentence\": \"With the games now done and dusted, however, McKeown stressed her full focus was on getting a well deserved rest.\", \"from\": 3644, \"to\": 3757, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the games\", \"from\": 3649, \"to\": 3658}, {\"ngram\": \"McKeown\", \"from\": 3689, \"to\": 3696}, {\"ngram\": \"her full focus\", \"from\": 3706, \"to\": 3720}, {\"ngram\": \"a well deserved rest\", \"from\": 3736, \"to\": 3756}]}, {\"sentence\": \"Speaking to the crowd after the athletes had fully disembarked, Mr Albanese hailed the success of Team Australia, whether they won a medal or not.\", \"from\": 3759, \"to\": 3905, \"entities\": [{\