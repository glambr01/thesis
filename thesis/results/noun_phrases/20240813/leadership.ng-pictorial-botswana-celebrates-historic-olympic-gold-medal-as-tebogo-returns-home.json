"{\"uid\": \"leadership.ng-pictorial-botswana-celebrates-historic-olympic-gold-medal-as-tebogo-returns-home\", \"noun_phrases\": [{\"sentence\": \"Botswana erupted in celebration as Letsile Tebogo, the nation's first Olympic gold medalist, returned home on Tuesday.\", \"from\": 0, \"to\": 118, \"entities\": [{\"begin\": 0, \"end\": 8, \"title\": \"http://dbpedia.org/resource/Botswana\", \"score\": 1.0, \"rank\": 3.132475301223853e-18, \"text\": \"Botswana\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Botswana\", \"dbpedia\": \"http://dbpedia.org/resource/Botswana\"}], \"noun_phrases\": [{\"ngram\": \"celebration\", \"from\": 20, \"to\": 31}, {\"ngram\": \"Letsile Tebogo\", \"from\": 35, \"to\": 49}, {\"ngram\": \"the nation's first Olympic gold medalist\", \"from\": 51, \"to\": 91}, {\"ngram\": \"Tuesday\", \"from\": 110, \"to\": 117}]}, {\"sentence\": \"The 21-year-old sprinter made history by winning the men's 200m at the just-concluded 2024 Paris Olympics, becoming the first African to achieve this feat.\", \"from\": 120, \"to\": 275, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The 21-year-old sprinter\", \"from\": 120, \"to\": 144}, {\"ngram\": \"history\", \"from\": 150, \"to\": 157}, {\"ngram\": \"the men's 200m\", \"from\": 169, \"to\": 183}, {\"ngram\": \"the just-concluded 2024 Paris Olympics\", \"from\": 187, \"to\": 225}, {\"ngram\": \"the first African\", \"from\": 236, \"to\": 253}, {\"ngram\": \"this feat\", \"from\": 265, \"to\": 274}]}, {\"sentence\": \"As Tebogo and the Botswana Olympic team touched down in Gaborone, the capital city was awash with sky blue and black national flags.\", \"from\": 277, \"to\": 409, \"entities\": [{\"begin\": 295, \"end\": 303, \"title\": \"http://dbpedia.org/resource/Botswana\", \"score\": 1.0, \"rank\": 3.132475301223853e-18, \"text\": \"Botswana\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Botswana\", \"dbpedia\": \"http://dbpedia.org/resource/Botswana\"}, {\"begin