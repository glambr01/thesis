anese_language\"}], \"noun_phrases\": [{\"ngram\": \"The last Olympics\", \"from\": 2259, \"to\": 2276}, {\"ngram\": \"recycled metal\", \"from\": 2327, \"to\": 2341}, {\"ngram\": \"each medal\", \"from\": 2348, \"to\": 2358}, {\"ngram\": \"alloys\", \"from\": 2372, \"to\": 2378}, {\"ngram\": \"used consumer electronics\", \"from\": 2394, \"to\": 2419}, {\"ngram\": \"mobile phones\", \"from\": 2428, \"to\": 2441}, {\"ngram\": \"laptops\", \"from\": 2446, \"to\": 2453}]}, {\"sentence\": \"Though designed by Chaumet, the medals will be manufactured by the French national mint, which has strongly denied a recent report that it has struggled to find a non-toxic agent with which to coat each one.\", \"from\": 2456, \"to\": 2663, \"entities\": [{\"begin\": 2523, \"end\": 2529, \"title\": \"http://dbpedia.org/resource/French_people\", \"score\": 0.9427795219981607, \"rank\": 0.03755645754050907, \"text\": \"French\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/French_people\", \"dbpedia\": \"http://dbpedia.org/resource/French_people\"}], \"noun_phrases\": [{\"ngram\": \"Chaumet\", \"from\": 2475, \"to\": 2482}, {\"ngram\": \"the medals\", \"from\": 2484, \"to\": 2494}, {\"ngram\": \"a recent report\", \"from\": 2571, \"to\": 2586}, {\"ngram\": \"a non-toxic agent\", \"from\": 2617, \"to\": 2634}]}, {\"sentence\": \"The puddle iron used in the construction of the Eiffel Tower in particular needs protection from air and humidity to prevent it from oxidising.\", \"from\": 2665, \"to\": 2808, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The puddle iron\", \"from\": 2665, \"to\": 2680}, {\"ngram\": \"the construction\", \"from\": 2689, \"to\": 2705}, {\"ngram\": \"the Eiffel Tower\", \"from\": 2709, \"to\": 2725}, {\"ngram\": \"protection\", \"from\": 2746, \"to\": 2756}, {\"ngram\": \"air\", \"from\": 2762, \"to\": 2765}, {\"ngram\": \"humidity\", \"from\": 2770, \"to\": 2778}]}, {\"sentence\": \"\\\"We have not had any issue with this,\\\" Joachim Roncin, head of design for the Paris Games, told reporters.\", \"from\": 2810, \"to\": 2916, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"any issue\", \"from\": 2827, \"to\": 2836}, {\"ngram\": \"Joachim Roncin\", \"from\": 2849, \"to\": 2863}, {\"ngram\": \"head\", \"from\": 2865, \"to\": 2869}, {\"ngram\": \"design\", \"from\": 2873, \"to\": 2879}, {\"ngram\": \"the Paris Games\", \"from\": 2884, \"to\": 2899}, {\"ngram\": \"reporters\", \"from\": 2906, \"to\": 2915}]}, {\"sentence\": \"Chaumet, which counted tower designer Gustav Eiffel as a client as well as Napoleon's family, is one of more than 70 leading luxury brands owned by French conglomerate LVMH, a major Paris Olympics sponsor.\", \"from\": 2918, \"to\": 3123, \"entities\": [{\"begin\": 2956, \"end\": 2969, \"title\": \"http://dbpedia.org/resource/Gustave_Eiffel\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Gustav Eiffel\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Gustave_Eiffel\", \"dbpedia\": \"http://dbpedia.org/resource/Gustave_Eiffel\"}, {\"begin\": 2993, \"end\": 3001, \"title\": \"http://dbpedia.org/resource/Napoleon\", \"score\": 1.0, \"rank\": 4.3749772555906507e-35, \"text\": \"Napoleon\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Napoleon\", \"dbpedia\": \"http://dbpedia.org/resource/Napoleon\"}, {\"begin\": 3066, \"end\": 3072, \"title\": \"http://dbpedia.org/resource/French_people\", \"score\": 0.9427795219981607, \"rank\": 0.03755645754050907, \"text\": \"French\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/French_people\", \"dbpedia\": \"http://dbpedia.org/resource/French_people\"}, {\"begin\": 3086, \"end\": 3090, \"title\": \"http://dbpedia.org/resource/LVMH\", \"score\": 1.0, \"rank\": 8.474097353627338e-28, \"text\": \"LVMH\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/LVMH\", \"dbpedia\": \"http