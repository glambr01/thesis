 254, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9990201436982802, \"rank\": 0.0009790761603980054, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 264, \"end\": 271, \"title\": \"http://dbpedia.org/resource/Essence\", \"score\": 0.9999999969591045, \"rank\": 2.6641386902822237e-09, \"text\": \"Essence\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Essence\", \"dbpedia\": \"http://dbpedia.org/resource/Essence\"}], \"noun_phrases\": [{\"ngram\": \"Fraser-Pryce\", \"from\": 273, \"to\": 285}, {\"ngram\": \"age\", \"from\": 327, \"to\": 330}, {\"ngram\": \"more time\", \"from\": 343, \"to\": 352}, {\"ngram\": \"her family\", \"from\": 358, \"to\": 368}]}, {\"sentence\": \"\\\"My son needs me,\\\" Fraser-Pryce told the magazine.\", \"from\": 371, \"to\": 421, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My son\", \"from\": 372, \"to\": 378}, {\"ngram\": \"Fraser-Pryce\", \"from\": 390, \"to\": 402}, {\"ngram\": \"the magazine\", \"from\": 408, \"to\": 420}]}, {\"sentence\": \"\\\"My husband and I have been together since before I won in 2008.\", \"from\": 422, \"to\": 486, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My husband\", \"from\": 423, \"to\": 433}]}, {\"sentence\": \"He has sacrificed for me.\", \"from\": 487, \"to\": 512, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"We are a partnership, a team.\", \"from\": 513, \"to\": 542, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a partnership\", \"from\": 520, \"to\": 533}, {\"ngram\": \"a team\", \"from\": 535, \"to\": 541}]}, {\"sentence\": \"\\\"It's because of that support that I am able to do the things that I have been doing for all these years.\", \"from\": 544, \"to\": 649, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"that support\", \"from\": 561, \"to\": 573}, {\"ngram\": \"the things\", \"from\": 595, 