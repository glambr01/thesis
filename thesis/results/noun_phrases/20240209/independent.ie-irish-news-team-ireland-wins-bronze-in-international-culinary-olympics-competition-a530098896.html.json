rom\": 3214, \"to\": 3222}, {\"ngram\": \"terms\", \"from\": 3248, \"to\": 3253}, {\"ngram\": \"medals\", \"from\": 3257, \"to\": 3263}]}, {\"sentence\": \"\\\"Ireland's restaurant and food quality is on the rise.\", \"from\": 3266, \"to\": 3320, \"entities\": [{\"begin\": 3267, \"end\": 3274, \"title\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"score\": 0.9997009979749097, \"rank\": 0.0002990630245144608, \"text\": \"Ireland\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"dbpedia\": \"http://dbpedia.org/resource/Republic_of_Ireland\"}], \"noun_phrases\": [{\"ngram\": \"the rise\", \"from\": 3311, \"to\": 3319}]}, {\"sentence\": \"We have gained 15 or 16 Michelin stars in the last five years, which is phenomenal for such a small country.\", \"from\": 3321, \"to\": 3429, \"entities\": [{\"begin\": 3345, \"end\": 3353, \"title\": \"http://dbpedia.org/resource/Michelin_Guide\", \"score\": 1.0, \"rank\": 6.970718900896005e-17, \"text\": \"Michelin\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Michelin_Guide\", \"dbpedia\": \"http://dbpedia.org/resource/Michelin_Guide\"}], \"noun_phrases\": [{\"ngram\": \"the last five years\", \"from\": 3363, \"to\": 3382}, {\"ngram\": \"such a small country\", \"from\": 3408, \"to\": 3428}]}, {\"sentence\": \"\\\"With the right resources we can do a hell of a lot better next time around,\\\" he added.\", \"from\": 3431, \"to\": 3518, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the right resources\", \"from\": 3437, \"to\": 3456}, {\"ngram\": \"a hell\", \"from\": 3467, \"to\": 3473}]}]}"