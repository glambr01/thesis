rom\": 571, \"to\": 583}, {\"ngram\": \"four years\", \"from\": 606, \"to\": 616}, {\"ngram\": \"prison\", \"from\": 620, \"to\": 626}, {\"ngram\": \"three counts\", \"from\": 654, \"to\": 666}, {\"ngram\": \"rape\", \"from\": 670, \"to\": 674}, {\"ngram\": \"a child\", \"from\": 683, \"to\": 690}, {\"ngram\": \"Facebook\", \"from\": 707, \"to\": 715}, {\"ngram\": \"the incident\", \"from\": 722, \"to\": 734}, {\"ngram\": \"place\", \"from\": 742, \"to\": 747}, {\"ngram\": \"August\", \"from\": 751, \"to\": 757}]}, {\"sentence\": \"He was released from prison just 12 months into his four-year sentence.\", \"from\": 764, \"to\": 835, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"prison\", \"from\": 785, \"to\": 791}, {\"ngram\": \"his four-year sentence\", \"from\": 812, \"to\": 834}]}, {\"sentence\": \"After being released from prison, van de Velde resumed his volleyball career in 2018 and has since represented the Netherlands in multiple international tournaments \\\"following an intensive, professionally supervised trajectory\\\", according to the Dutch Olympic Committee (NOC).\", \"from\": 837, \"to\": 1113, \"entities\": [{\"begin\": 871, \"end\": 883, \"title\": \"http://dbpedia.org/resource/Charles_William_Meredith_van_de_Velde\", \"score\": 0.9928944299507352, \"rank\": 0.007156420496367784, \"text\": \"van de Velde\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Charles_William_Meredith_van_de_Velde\", \"dbpedia\": \"http://dbpedia.org/resource/Charles_William_Meredith_van_de_Velde\"}, {\"begin\": 952, \"end\": 963, \"title\": \"http://dbpedia.org/resource/Netherlands\", \"score\": 0.9991715688744466, \"rank\": 0.0008266106121202988, \"text\": \"Netherlands\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Netherlands\", \"dbpedia\": \"http://dbpedia.org/resource/Netherlands\"}, {\"begin\": 1083, \"end\": 1106, \"title\": \"http://dbpedia.org/resource/NOC*NSF\", \"score\": 1.0, \"rank