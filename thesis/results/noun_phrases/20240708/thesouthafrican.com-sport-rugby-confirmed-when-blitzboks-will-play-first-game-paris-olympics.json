ses\": [{\"ngram\": \"The competition format\", \"from\": 1718, \"to\": 1740}, {\"ngram\": \"all teams\", \"from\": 1746, \"to\": 1755}, {\"ngram\": \"three pool matches\", \"from\": 1761, \"to\": 1779}, {\"ngram\": \"eight teams\", \"from\": 1785, \"to\": 1796}, {\"ngram\": \"the quarter-finals\", \"from\": 1812, \"to\": 1830}, {\"ngram\": \"the evening session\", \"from\": 1834, \"to\": 1853}, {\"ngram\": \"the second day\", \"from\": 1857, \"to\": 1871}, {\"ngram\": \"competition\", \"from\": 1875, \"to\": 1886}, {\"ngram\": \"the third day\", \"from\": 1895, \"to\": 1908}, {\"ngram\": \"the semi\", \"from\": 1914, \"to\": 1922}, {\"ngram\": \"finals\", \"from\": 1923, \"to\": 1929}, {\"ngram\": \"the all-important medal matches\", \"from\": 1934, \"to\": 1965}, {\"ngram\": \"Olympic dreams\", \"from\": 1969, \"to\": 1983}]}, {\"sentence\": \"Rugby sevens is expected to be one of the highlights of Paris 2024, following the resounding success of Rugby World Cup 2023 in France.\", \"from\": 2010, \"to\": 2145, \"entities\": [{\"begin\": 2066, \"end\": 2076, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 8.275186710916357e-22, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 2138, \"end\": 2144, \"title\": \"http://dbpedia.org/resource/France_national_rugby_union_team\", \"score\": 0.9999999997253326, \"rank\": 2.7395134506639067e-10, \"text\": \"France\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/France_national_rugby_union_team\", \"dbpedia\": \"http://dbpedia.org/resource/France_national_rugby_union_team\"}], \"noun_phrases\": [{\"ngram\": \"Rugby\", \"from\": 2010, \"to\": 2015}, {\"ngram\": \"the highlights\", \"from\": 2048, \"to\": 2062}, {\"ngram\": \"the resounding success\", \"from\": 2088, \"to\": 2110}, {\"ngram\": \"Rugby World Cup\", \"from\": 2114, \"to\": 2129}]}, {\"sentence\": \"All the action will take place at Stade de France, which was the venue for the opening match and final of Rugby World Cup 2023.\", \"from\": 2146, \"to\": 2273, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"All the action\", \"from\": 2146, \"to\": 2160}, {\"ngram\": \"place\", \"from\": 2171, \"to\": 2176}, {\"ngram\": \"Stade de France\", \"from\": 2180, \"to\": 2195}, {\"ngram\": \"the venue\", \"from\": 2207, \"to\": 2216}, {\"ngram\": \"the opening match\", \"from\": 2221, \"to\": 2238}, {\"ngram\": \"Rugby World Cup\", \"from\": 2252, \"to\": 2267}]}, {\"sentence\": \"All six World Rugby regions are represented among the 24 teams who secured their spots in Paris via the HSBC SVNS Series, regional qualification competitions and the World Rugby Sevens Repechage.\", \"from\": 2275, \"to\": 2470, \"entities\": [{\"begin\": 2365, \"end\": 2370, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 2.9398469171800964e-15, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 2441, \"end\": 2452, \"title\": \"http://dbpedia.org/resource/World_Rugby\", \"score\": 1.0, \"rank\": 1.9010600367846638e-19, \"text\": \"World Rugby\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Rugby\", \"dbpedia\": \"http://dbpedia.org/resource/World_Rugby\"}], \"noun_phrases\": [{\"ngram\": \"All six World Rugby regions\", \"from\": 2275, \"to\": 2302}, {\"ngram\": \"the 24 teams\", \"from\": 2325, \"to\": 2337}, {\"ngram\": \"their spots\", \"from\": 2350, \"to\": 2361}, {\"ngram\": \"the HSBC SVNS Series\", \"from\": 2375, \"to\": 2395}, {\"ngram\": \"regional qualification competitions\", \"from\": 2397, \"to\": 2432}]}, {\"sentence\": \"World Rugby Chief Executive Alan Gilpin said: \\\"The unveiling of the match schedule is another exciting step on the road to Paris with just 16 days to go until rugby sevens kicks off the Olympic Games.\", \"from\": 2472, \"to\": 2672, \"entities\": [{\"begin\": 2505, \"end\": 2511, \"title\": \"http://dbpedia.org/resource/William_Sawrey_Gilpin\", \"score\": 0.9995887008867872, \"rank\": 0.0004114679693874848, \"text\": \"Gilpin\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/William_Sawrey_Gilpin\", \"dbpedia\": \"http://dbpedia.org/resource/William_Sawrey_Gilpin\"}, {\"begin\": 2595, \"end\": 2600, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 2.9398469171800964e-15, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"The unveiling\", \"from\": 2519, \"to\": 2532}, {\"ngram\": \"the match schedule\", \"from\": 2536, \"to\": 2554}, {\"ngram\": \"another exciting step\", \"from\": 2558, \"to\": 2579}, {\"ngram\": \"the road\", \"from\": 2583, \"to\": 2591}, {\"ngram\": \"just 16 days\", \"from\": 2606, \"to\": 2618}, {\"ngram\": \"rugby\", \"from\": 2631, \"to\": 2636}, {\"ngram\": \"kicks\", \"from\": 2644, \"to\": 2649}, {\"ngram\": \"the Olympic Games\", \"from\": 2654, \"to\": 2671}]}, {\"sentence\": \"The players, teams and fans can now mark their calendars and fine tune their preparations for what promises to be an incredible six days of fast paced, all action drama as some of the best athletes in the world showcase the speed, strength and skill of rugby sevens to a huge worldwide audience.\", \"from\": 2673, \"to\": 2968, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The players\", \"from\": 2673, \"to\": 2684}, {\"ngram\": \"teams\", \"from\": 2686, \"to\": 2691}, {\"ngram\": \"fans\", \"from\": 2696, \"to\": 2700}, {\"ngram\": \"their calendars\", \"from\": 2714, \"to\": 2729}, {\"ngram\": \"fine tune\", \"from\": 2734, \"to\": 2743}, {\"ngram\": \"their preparations\", \"from\": 2744, \"to\": 2762}, {\"ngram\": \"an inc