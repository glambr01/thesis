ram\": \"Paris Olympics\", \"from\": 239, \"to\": 253}, {\"ngram\": \"The sevens match schedule\", \"from\": 254, \"to\": 279}, {\"ngram\": \"the Paris Olympics\", \"from\": 303, \"to\": 321}, {\"ngram\": \"a challenging campaign\", \"from\": 351, \"to\": 373}]}, {\"sentence\": \"Earlier this year World Rugbyrevealedthe pools for the Paris Olympics 2024 sevens competitions, with the men's event set to take place from 24-27 July, while the women's tournament follows on 28-30 July.\", \"from\": 378, \"to\": 581, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Earlier this year World Rugbyrevealedthe pools\", \"from\": 378, \"to\": 424}, {\"ngram\": \"the Paris Olympics\", \"from\": 429, \"to\": 447}, {\"ngram\": \"competitions\", \"from\": 460, \"to\": 472}, {\"ngram\": \"the men's event\", \"from\": 479, \"to\": 494}, {\"ngram\": \"place\", \"from\": 507, \"to\": 512}, {\"ngram\": \"24-27 July\", \"from\": 518, \"to\": 528}, {\"ngram\": \"the women's tournament\", \"from\": 536, \"to\": 558}, {\"ngram\": \"28-30 July\", \"from\": 570, \"to\": 580}]}, {\"sentence\": \"The men's gold medal match on 27 July will see the first team sport gold medal of the Games awarded.\", \"from\": 583, \"to\": 683, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The men's gold medal match\", \"from\": 583, \"to\": 609}, {\"ngram\": \"27 July\", \"from\": 613, \"to\": 620}, {\"ngram\": \"the first team sport gold medal\", \"from\": 630, \"to\": 661}, {\"ngram\": \"the Games\", \"from\": 665, \"to\": 674}]}, {\"sentence\": \"The Blitzboks have been drawn in a challenging pool, and it's now been confirmed that they will face Ireland on 24 July in their opening game (kick off at 17:30 SA time).\", \"from\": 685, \"to\": 855, \"entities\": [{\"begin\": 786, \"end\": 793, \"title\": \"http://dbpedia.org/resource/Ireland_national_rugby_union_team\", \"score\": 1.0, \"rank\": 7.890446070253617e-16, \"text\": \"Ireland\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ireland_nat