"{\"uid\": \"jamaicaobserver.com-2024-07-08-french-airport-worker-unions-call-strike-week-paris-olympics\", \"noun_phrases\": [{\"sentence\": \"PARIS, France (AFP)- Unions representing workers at Paris' airports said Monday they had called for a strike the week before the Paris Olympics over a dispute about bonuses for staff.\", \"from\": 0, \"to\": 183, \"entities\": [{\"begin\": 7, \"end\": 13, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9975401747249135, \"rank\": 0.002417639242533147, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 15, \"end\": 18, \"title\": \"http://dbpedia.org/resource/Agence_France-Presse\", \"score\": 0.9997837446694938, \"rank\": 0.00019649696599812394, \"text\": \"AFP\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Agence_France-Presse\", \"dbpedia\": \"http://dbpedia.org/resource/Agence_France-Presse\"}, {\"begin\": 52, \"end\": 57, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999995453, \"rank\": 3.6953326552886833e-13, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"PARIS\", \"from\": 0, \"to\": 5}, {\"ngram\": \"workers\", \"from\": 41, \"to\": 48}, {\"ngram\": \"a strike\", \"from\": 100, \"to\": 108}, {\"ngram\": \"the Paris Olympics\", \"from\": 125, \"to\": 143}, {\"ngram\": \"a dispute\", \"from\": 149, \"to\": 158}, {\"ngram\": \"bonuses\", \"from\": 165, \"to\": 172}, {\"ngram\": \"staff\", \"from\": 177, \"to\": 182}]}, {\"sentence\": \"The CGT, CFDT, FO and UNSA unions called the strike on July 17 - nine days before the start of the Paris Games - to demand that all staff receive an Olympics bonus, denouncing \\\"unilateral decisions from the chief executive to pay a bonus to only some personnel.\\\"\", \"from\": 185, \"to\": 447, \"entities\": [{\"begin\": 189, \"end\": 192, \"title\": \"http://dbpedia.org/resource/General_Confederation_of_Labour_of_the_Argentines\", \"score\": 1.0, \"rank\": 1.9879133972544685e-14, \"text\": \"CGT\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/General_Confederation_of_Labour_of_the_Argentines\", \"dbpedia\": \"http://dbpedia.org/resource/General_Confederation_of_Labour_of_the_Argentines\"}, {\"begin\": 194, \"end\": 198, \"title\": \"http://dbpedia.org/resource/French_Democratic_Confederation_of_Labour\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"CFDT\", \"types\": [\"Q43229\", \"Q24229398\", \"Q178790\"], \"wikid\": \"http://dbpedia.org/resource/French_Democratic_Confederation_of_Labour\", \"dbpedia\": \"http://dbpedia.org/resource/French_Democratic_Confederation_of_Labour\"}], \"noun_phrases\": [{\"ngram\": \"FO\", \"from\": 200, \"to\": 202}, {\"ngram\": \"UNSA unions\", \"from\": 207, \"to\": 218}, {\"ngram\": \"the strike\", \"from\": 226, \"to\": 236}, {\"ngram\": \"July\", \"from\": 240, \"to\": 244}, {\"ngram\": \"the start\", \"from\": 267, \"to\": 276}, {\"ngram\": \"the Paris Games\", \"from\": 280, \"to\": 295}, {\"ngram\": \"all staff\", \"from\": 313, \"to\": 322}, {\"ngram\": \"an Olympics bonus\", \"from\": 331, \"to\": 348}, {\"ngram\": \"\\\"unilateral decisions\", \"from\": 361, \"to\": 382}, {\"ngram\": \"the chief executive\", \"from\": 388, \"to\": 407}, {\"ngram\": \"a bonus\", \"from\": 415, \"to\": 422}, {\"ngram\": \"only some personnel\", \"from\": 426, \"to\": 445}]}, {\"sentence\": \"Unions at state-controlled Groupe ADP, which runs Paris' main airports Charles de Gaulle and Orly, had previously called a strike on May 19, which did not cause major disruption.\", \"from\": 449, \"to\": 627, \"entities\": [{\"begin\": 476, \"end\": 486, \"title\": \"http://dbpedia.org/resource/Groupe_ADP\", \"score\": 1.0, \"rank\": 6.747739974944774e-23, \"text\": \"Groupe ADP\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Groupe_ADP\", \"dbpedia\": \"http://dbpedia.org/resource/Groupe_ADP\"}, {\"begin\": 499, \"end\": 504, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999995453, \"rank\": 3.6953326552886833e-13, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 520, \"end\": 537, \"title\": \"http://dbpedia.org/resource/Charles_de_Gaulle_Airport\", \"score\": 0.9589520926767806, \"rank\": 0.04280495158677869, \"text\": \"Charles de Gaulle\", \"types\": [\"Q1248784\"], \"wikid\": \"http://dbpedia.org/resource/Charles_de_Gaulle_Airport\", \"dbpedia\": \"http://dbpedia.org/resource/Charles_de_Gaulle_Airport\"}], \"noun_phrases\": [{\"ngram\": \"Unions\", \"from\": 449, \"to\": 455}, {\"ngram\": \"Orly\", \"from\": 542, \"to\": 546}, {\"ngram\": \"a strike\", \"from\": 570, \"to\": 578}, {\"ngram\": \"May\", \"from\": 582, \"to\": 585}, {\"ngram\": \"major disruption\", \"from\": 610, \"to\": 626}]}, {\"sentence\": \"The two airports will be the main gateways into France for foreign visitors to the Olympics, with up to 350,000 people expected to transit there daily, as well as most athletes and their equipment.\", \"from\": 629, \"to\": 826, \"entities\": [{\"begin\": 677, \"end\": 683, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9975401747249135, \"rank\": 0.002417639242533147, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"The two airports\", \"from\": 629, \"to\": 645}, {\"ngram\": \"the main gateways\", \"from\": 654, \"to\": 671}, {\"ngram\": \"foreign visitors\", \"from\": 688, \"to\": 704}, {\"ngram\": \"the Olympics\", \"from\": 708, \"to\": 720}, {\"ngram\": \"up to 350,000 people\", \"from\": 727, \"to\": 747}, {\"ngram\": \"most athletes\", \"from\": 792, \"to\": 805}, {\"ngram\": \"their equipment\", \"from\": 810, \"to\": 825}]}, {\"sentence\": \"Competitors are expected to begin arriving in large numbers from July 18, when the athletes' village opens, with a new temporary over-sized baggage terminal at Charles de Gaulle set up to handle equipment such as kayaks and bikes.\", \"from\": 828, \"to\": 1058, \"entities\": [{\"begin\": 988, \"end\": 1005, \"title\": \"http://dbpedia.org/resource/Charles_de_Gaulle_Airport\", \"score\": 0.9589520926767806, \"rank\": 0.04280495158677869, \"text\": \"Charles de Gaulle\", \"types\": [\"Q1248784\"], \"wikid\": \"http://dbpedia.org/resource/Charles_de_Gaulle_Airport\", \"dbpedia\": \"http://dbpedia.org/resource/Charles_de_Gaulle_Airport\"}], \"noun_phrases\": [{\"ngram\": \"Competitors\", \"from\": 828, \"to\": 839}, {\"ngram\": \"large numbers\", \"from\": 874, \"to\": 887}, {\"ngram\": \"July\", \"from\": 893, \"to\": 897}, {\"ngram\": \"the athletes' village\", \"from\": 907, \"to\": 928}, {\"ngram\": \"a new temporary over-sized baggage terminal\", \"from\": 941, \"to\": 984}, {\"ngram\": \"equipment\", \"from\": 1023, \"to\": 1032}, {\"ngram\": \"kayaks\", \"from\": 1041, \"to\": 1047}, {\"ngram\": \"bikes\", \"from\": 1052, \"to\": 1057}]}, {\"sentence\": \"Unions representing workers across the public sector in France have demanded extra pay or support for having to work over the July 26-August 11 Games, which fall during the traditional summer holiday in France.\", \"from\": 1060, \"to\": 1270, \"entities\": [{\"begin\": 1116, \"end\": 1122, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9975401747249135, \"rank\": 0.002417639242533147, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 1263, \"end\": 1269, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9975401747249135, \"rank\": 0.002417639242533147, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"Unions\", \"from\": 1060, \"to\": 1066}, {\"ngram\": \"workers\", \"from\": 1080, \"to\": 1087}, {\"ngram\": \"the public sector\", \"from\": 1095, \"to\": 1112}, {\"ngram\": \"extra pay\", \"from\": 1137, \"to\": 1146}, {\"ngram\": \"support\", \"from\": 1150, \"to\": 1157}, {\"ngram\": \"-August\", \"from\": 1193, \"to\": 1200}, {\"ngram\": \"the traditional summer holiday\", \"from\": 1229, \"to\": 1259}]}, {\"sentence\": \"As well as company-wide bonuses, the ADP unions want a \\\"massive\\\" recruitment plan for 1,000 extra staff and a guarantee that they can take holidays during the Olympics, which run from July 26-August 11, followed by the Paralympics from August 28-September 8.\", \"from\": 1272, \"to\": 1530, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"company-wide bonuses\", \"from\": 1283, \"to\": 1303}, {\"ngram\": \"the ADP unions\", \"from\": 1305, \"to\": 1319}, {\"ngram\": \"a \\\"massive\\\" recruitment plan\", \"from\": 1325, \"to\": 1353}, {\"ngram\": \"1,000 extra staff\", \"from\": 1358, \"to\": 1375}, {\"ngram\": \"a guarantee\", \"from\": 1380, \"to\": 1391}, {\"ngram\": \"holidays\", \"from\": 1411, \"to\": 1419}, {\"ngram\": \"the Olympics\", \"from\": 1427, \"to\": 1439}, {\"ngram\": \"July\", \"from\": 1456, \"to\": 1460}, {\"ngram\": \"-August\", \"from\": 1463, \"to\": 1470}, {\"ngram\": \"the Paralympics\", \"from\": 1487, \"to\": 1502}, {\"ngram\": \"August\", \"from\": 1508, \"to\": 1514}]}, {\"sentence\": \"\\\"All the trade unions have unilaterally denounced the divisive methods and choices of management,\\\" a joint statement from them said.\", \"from\": 1532, \"to\": 1664, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"All the trade unions\", \"from\": 1533, \"to\": 1553}, {\"ngram\": \"the divisive methods\", \"from\": 1582, \"to\": 1602}, {\"ngram\": \"choices\", \"from\": 1607, \"to\": 1614}, {\"ngram\": \"management\", \"from\": 1618, \"to\": 1628}, {\"ngram\": \"a joint statement\", \"from\": 1631, \"to\": 1648}]}, {\"sentence\": \"\\\"We have to conclude that the chief executive has dismissed our demands.\\\"\", \"from\": 1665, \"to\": 1738, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the chief executive\", \"from\": 1691, \"to\": 1710}, {\"ngram\": \"our demands\", \"from\": 1725, \"to\": 1736}]}, {\"sentence\": \"CEO Augustin de Romanet is set to step down after the Olympics.\", \"from\": 1740, \"to\": 1803, \"entities\": [{\"begin\": 1744, \"end\": 1763, \"title\": \"http://dbpedia.org/resource/Augustin_de_Romanet_de_Beaune\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Augustin de Romanet\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Augustin_de_Romanet_de_Beaune\", \"dbpedia\": \"http://dbpedia.org/resource/Augustin_de_Romanet_de_Beaune\"}], \"noun_phrases\": [{\"ngram\": \"the Olympics\", \"from\": 1790, \"to\": 1802}]}, {\"sentence\": \"The threat of strikes disrupting the Paris Games has been regularly discussed in France because of the country's often tension-filled industrial relations and militant trade unions.\", \"from\": 1805, \"to\": 1986, \"entities\": [{\"begin\": 1886, \"end\": 1892, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9975401747249135, \"rank\": 0.002417639242533147, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"The threat\", \"from\": 1805, \"to\": 1815}, {\"ngram\": \"strikes\", \"from\": 1819, \"to\": 1826}, {\"ngram\": \"the Paris Games\", \"from\": 1838, \"to\": 1853}, {\"ngram\": \"the country's often tension-filled industrial relations\", \"from\": 1904, \"to\": 1959}, {\"ngram\": \"militant trade unions\", \"from\