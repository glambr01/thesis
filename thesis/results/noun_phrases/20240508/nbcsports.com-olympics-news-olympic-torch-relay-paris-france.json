], \"noun_phrases\": [{\"ngram\": \"Tens of thousands\", \"from\": 652, \"to\": 669}, {\"ngram\": \"the arrival\", \"from\": 678, \"to\": 689}, {\"ngram\": \"the cordoned-off stage area\", \"from\": 693, \"to\": 720}, {\"ngram\": \"the shore\", \"from\": 724, \"to\": 733}, {\"ngram\": \"thousands\", \"from\": 737, \"to\": 746}, {\"ngram\": \"others\", \"from\": 750, \"to\": 756}, {\"ngram\": \"balconies\", \"from\": 768, \"to\": 777}, {\"ngram\": \"windows\", \"from\": 782, \"to\": 789}, {\"ngram\": \"the festivities\", \"from\": 802, \"to\": 817}]}, {\"sentence\": \"The torch relay began per tradition in the Ancient Olympic site of Olympia on April 16 and spent 11 days in Greece, including visiting Athens and the first modern Olympic Stadium from 1896.\", \"from\": 820, \"to\": 1009, \"entities\": [{\"begin\": 887, \"end\": 894, \"title\": \"http://dbpedia.org/resource/Olympia_London\", \"score\": 0.9999998854446014, \"rank\": 1.1455530879072446e-07, \"text\": \"Olympia\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Olympia_London\", \"dbpedia\": \"http://dbpedia.org/resource/Olympia_London\"}, {\"begin\": 928, \"end\": 934, \"title\": \"http://dbpedia.org/resource/Greece\", \"score\": 0.9999124495501919, \"rank\": 8.532944364103092e-05, \"text\": \"Greece\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Greece\", \"dbpedia\": \"http://dbpedia.org/resource/Greece\"}, {\"begin\": 955, \"end\": 961, \"title\": \"http://dbpedia.org/resource/2004_Summer_Olympics\", \"score\": 0.9996676274691341, \"rank\": 0.00033248303913951813, \"text\": \"Athens\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2004_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2004_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"The torch relay\", \"from\": 820, \"to\": 835}, {\"ngram\": \"tradition\", \"from\": 846, \"to\": 855}, {\"ngram\": \"the Ancient Olympic site\", \"from\": 859, \"to\": 883}, {\"ngram\": \"April\", \"from\": 898, \"to\": 903}, {\"ngram\": \"11 days\", \"from\": 917, \"to\": 924}, {\"ngram\": \"the first modern Olympic Stadium\", \"from\": 966, \"to\": 998}]}, {\"sentence\": \"It then crossed the Mediterranean Sea to reach France.\", \"from\": 1011, \"to\": 1065, \"entities\": [{\"begin\": 1058, \"end\": 1064, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9999999696390209, \"rank\": 2.8860277887112648e-08, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"the Mediterranean Sea\", \"from\": 1027, \"to\": 1048}]}, {\"sentence\": \"In France, the flame will visit more than 400 cities and towns across 64 territories.\", \"from\": 1067, \"to\": 1152, \"entities\": [{\"begin\": 1070, \"end\": 1076, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9999999696390209, \"rank\": 2.8860277887112648e-08, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"the flame\", \"from\": 1078, \"to\": 1087}, {\"ngram\": \"more than 400 cities\", \"from\": 1099, \"to\": 1119}, {\"ngram\": \"towns\", \"from\": 1124, \"to\": 1129}, {\"ngram\": \"64 territories\", \"from\": 1137, \"to\": 1151}]}, {\"sentence\": \"It will go by D-Day beaches, Mont Saint-Michel, the Palace of Versailles, Cannes, Roland Garros and more famous vineyards and museums.\", \"from\": 1153, \"to\": 1287, \"entities\": [{\"begin\": 1227, \"end\": 1233, \"title\": \"http://dbpedia.org/resource/Cannes\", \"score\": 0.9999994888591061, \"rank\": 5.074898490301505e-07, \"text\": \"Cannes\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Cannes\", \"dbpedia\": \"http://dbpedia.org/resource/Cannes\"}, {\"begin\": 1235, \"end\": 1248, \"title\": \"http://dbpedia.org/resource/French_Open\", \"score\":