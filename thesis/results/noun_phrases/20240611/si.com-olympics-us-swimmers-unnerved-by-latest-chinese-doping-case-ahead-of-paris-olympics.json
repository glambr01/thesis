phrases\": [{\"ngram\": \"two events\", \"from\": 6635, \"to\": 6645}]}, {\"sentence\": \"According to the World Aquatics database, she has never again swam a time within four seconds of her 400 IM gold-medal performance.\", \"from\": 6678, \"to\": 6809, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the World Aquatics database\", \"from\": 6691, \"to\": 6718}, {\"ngram\": \"four seconds\", \"from\": 6759, \"to\": 6771}, {\"ngram\": \"her 400 IM gold-medal performance\", \"from\": 6775, \"to\": 6808}]}, {\"sentence\": \"At the 2016 Olympics in Rio, her time of 4:45.86 was more than 17 seconds slower than four years earlier, placing her 27th overall.\", \"from\": 6810, \"to\": 6941, \"entities\": [{\"begin\": 6834, \"end\": 6837, \"title\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.6545877526561655e-29, \"text\": \"Rio\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2016_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"the 2016 Olympics\", \"from\": 6813, \"to\": 6830}, {\"ngram\": \"her time\", \"from\": 6839, \"to\": 6847}, {\"ngram\": \"4:45.86\", \"from\": 6851, \"to\": 6858}]}, {\"sentence\": \"She did not come close to making finals in the event, and she did not compete in Tokyo.\", \"from\": 6942, \"to\": 7029, \"entities\": [{\"begin\": 7023, \"end\": 7028, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.8203654976662282, \"rank\": 0.21896886551776235, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}], \"noun_phrases\": [{\"ngram\": \"finals\", \"from\": 6975, \"to\": 6981}, {\"ngram\": \"the event\", \"from\": 6985, \"to\": 6994}]}, {\"sentence\": \"\\u00e2\\u0080\\u009cNo comment,\\u00e2\\u0080\\u009d was the immediate reaction of American 400-IMer Elizabeth Beisel to Ye\\u00e2\\u0080\\u0099s plummeting performance in Rio.\", \"from\": 7031, \"to\": 7154, \"entities\": [{\"begin\": 7079, \"end\": 7087, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 1.0, \"rank\": 3.518235522349139e-17, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 7097, \"end\": 7113, \"title\": \"http://dbpedia.org/resource/Elizabeth_Beisel\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Elizabeth Beisel\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Elizabeth_Beisel\", \"dbpedia\": \"http://dbpedia.org/resource/Elizabeth_Beisel\"}, {\"begin\": 7150, \"end\": 7153, \"title\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.6545877526561655e-29, \"text\": \"Rio\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2016_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"\\u00e2\\u0080\\u009cNo comment\", \"from\": 7031, \"to\": 7044}, {\"ngram\": \"\\u00e2\\u0080\\u009d\", \"from\": 7045, \"to\": 7048}, {\"ngram\": \"the immediate reaction\", \"from\": 7053, \"to\": 7075}, {\"ngram\": \"Ye\\u00e2\\u0080\\u0099s plummeting performance\", \"from\": 7117, \"to\": 7146}]}, {\"sentence\": \"Four years earlier, Beisel had won silver to Ye\\u00e2\\u0080\\u0099s stunning gold.\", \"from\": 7155, \"to\": 7221, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Beisel\", \"from\": 7175, \"to\": 7181}, {\"ngram\": \"silver\", \"from\": 7190, \"to\": 7196}, {\"ngram\": \"Ye\\u00e2\\u0080\\u0099s\", \"from\": 7200, \"to\": 7206}, {\"ngram\": \"stunning gold\", \"from\": 7207, \"to\": 7220}]}, {\"sentence\": \"Immediately after the race in London, Beisel wondered if she had faltered badly in her final 100 meters as Ye pulled away.\", \"from\": 7223, \"to\": 7345, \"entiti