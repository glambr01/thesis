90, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"signs\", \"from\": 336, \"to\": 341}, {\"ngram\": \"banners\", \"from\": 346, \"to\": 353}, {\"ngram\": \"Justice\", \"from\": 371, \"to\": 378}, {\"ngram\": \"Amara\", \"from\": 383, \"to\": 388}]}, {\"sentence\": \"Others read: \\\"Amara, a victim of serious employer onsite safety breaches.\\\"\", \"from\": 391, \"to\": 465, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Others\", \"from\": 391, \"to\": 397}, {\"ngram\": \"Amara\", \"from\": 405, \"to\": 410}, {\"ngram\": \"a victim\", \"from\": 412, \"to\": 420}, {\"ngram\": \"serious employer onsite safety breaches\", \"from\": 424, \"to\": 463}]}, {\"sentence\": \"The rally in Paris, organised by one of France's largest labour unions, the Confederation Generale du Travail (CGT), was in honour of Amara Dioumassy, who was killed on June 16, 2023 while working on a construction project as a supervisor at the Bassin d'Austerlitz to improve the quality of the Seine.\", \"from\": 467, \"to\": 769, \"entities\": [{\"begin\": 480, \"end\": 485, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 4.821764988839331e-19, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 507, \"end\": 513, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9265406018676873, \"rank\": 0.07917470912123707, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 578, \"end\": 581, \"title\": \"http://dbpedia.org/resource/General_Confederation_of_Labour_of_the_Argentines\", \"score\": 1.0, \"rank\": 4.4307140981914605e-27, \"text\": \"CGT\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/General_Confederation_of_Labour_of_the_Argentines\", \"dbpedia\": \"http://dbpedia.org/resource/General_Confederation_of_Labour_of_the_Argen