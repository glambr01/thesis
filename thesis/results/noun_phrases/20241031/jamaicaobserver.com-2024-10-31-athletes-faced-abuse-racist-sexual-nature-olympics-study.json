"{\"uid\": \"jamaicaobserver.com-2024-10-31-athletes-faced-abuse-racist-sexual-nature-olympics-study\", \"noun_phrases\": [{\"sentence\": \"PARIS, France (AFP) - Track and field athletes at the Paris Olympics were targeted by racism or sexualised abuse, according to a World Athletics study of the social media accounts of over 1,900 competitors released on Thursday.\", \"from\": 0, \"to\": 227, \"entities\": [{\"begin\": 129, \"end\": 144, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 0.9999999999661213, \"rank\": 3.387949416288226e-11, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}], \"noun_phrases\": [{\"ngram\": \"AFP\", \"from\": 15, \"to\": 18}, {\"ngram\": \"the Paris Olympics\", \"from\": 50, \"to\": 68}, {\"ngram\": \"racism\", \"from\": 86, \"to\": 92}, {\"ngram\": \"sexualised abuse\", \"from\": 96, \"to\": 112}, {\"ngram\": \"the social media accounts\", \"from\": 154, \"to\": 179}, {\"ngram\": \"over 1,900 competitors\", \"from\": 183, \"to\": 205}, {\"ngram\": \"Thursday\", \"from\": 218, \"to\": 226}]}, {\"sentence\": \"Abuse of that nature made up more than 48% of the total while \\\"general abuse\\\" accounted for 32 per cent.\", \"from\": 229, \"to\": 333, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Abuse\", \"from\": 229, \"to\": 234}, {\"ngram\": \"that nature\", \"from\": 238, \"to\": 249}, {\"ngram\": \"more than 48%\", \"from\": 258, \"to\": 271}, {\"ngram\": \"the total\", \"from\": 275, \"to\": 284}, {\"ngram\": \"\\\"general abuse\", \"from\": 291, \"to\": 305}, {\"ngram\": \"32 per cent\", \"from\": 321, \"to\": 332}]}, {\"sentence\": \"The study monitored the social media accounts of 1,917 athletes and officials for the duration of the Olympics and for 24 hours before and after the Games started and ended.\", \"from\": 335, \"to\": 508, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The study\", \"from\": 335, \"to\": 344}, {\"ngram\": \"the social media accounts\", \"from\": 355, \"to\": 380}, {\"ngram\": \"1,917 athletes\", \"from\": 384, \"to\": 398}, {\"ngram\": \"officials\", \"from\": 403, \"to\": 412}, {\"ngram\": \"the duration\", \"from\": 417, \"to\": 429}, {\"ngram\": \"the Olympics\", \"from\": 433, \"to\": 445}, {\"ngram\": \"the Games\", \"from\": 480, \"to\": 489}]}, {\"sentence\": \"The sample size was 12 times bigger than the research conducted at the pandemic-delayed Tokyo Games in 2021.\", \"from\": 510, \"to\": 618, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The sample size\", \"from\": 510, \"to\": 525}, {\"ngram\": \"the research\", \"from\": 551, \"to\": 563}, {\"ngram\": \"the pandemic-delayed Tokyo Games\", \"from\": 577, \"to\": 609}]}, {\"sentence\": \"In all, 128 posts and comments were escalated to the relevant platform for additional action.\", \"from\": 620, \"to\": 713, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"128 posts\", \"from\": 628, \"to\": 637}, {\"ngram\": \"comments\", \"from\": 642, \"to\": 650}, {\"ngram\": \"the relevant platform\", \"from\": 669, \"to\": 690}, {\"ngram\": \"additional action\", \"from\": 695, \"to\": 712}]}, {\"sentence\": \"Racism was the largest category of detected abuse targeting male athletes, making up 26% of total abuse.\", \"from\": 715, \"to\": 819, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Racism\", \"from\": 715, \"to\": 721}, {\"ngram\": \"the largest category\", \"from\": 726, \"to\": 746}, {\"ngram\": \"detected abuse\", \"from\": 750, \"to\": 764}, {\"ngram\": \"male athletes\", \"from\": 775, \"to\": 788}, {\"ngram\": \"26%\", \"from\": 800, \"to\": 803}, {\"ngram\": \"total abuse\", \"from\": 807, \"to\": 818}]}, {\"sentence\": \"Female athletes were targeted with a mixture of sexual and sexist abuse and almost half of the detected content falling under the general abuse category (49%).\", \"from\": 821, \"to\": 980, \"