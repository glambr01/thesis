"{\"uid\": \"jamaicaobserver.com-2024-08-07-organisers-scrap-olympic-open-water-training-polluted-seine\", \"noun_phrases\": [{\"sentence\": \"PARIS, France (AFP) - Paris Olympics organisers said Tuesday that training for open water swimming in the River Seine had been cancelled due to pollution, raising questions over why triathletes were allowed to use the waterway the day before.\", \"from\": 0, \"to\": 242, \"entities\": [{\"begin\": 106, \"end\": 117, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"River Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"AFP\", \"from\": 15, \"to\": 18}, {\"ngram\": \"training\", \"from\": 66, \"to\": 74}, {\"ngram\": \"open water swimming\", \"from\": 79, \"to\": 98}, {\"ngram\": \"pollution\", \"from\": 144, \"to\": 153}, {\"ngram\": \"questions\", \"from\": 163, \"to\": 172}, {\"ngram\": \"triathletes\", \"from\": 182, \"to\": 193}, {\"ngram\": \"the waterway\", \"from\": 214, \"to\": 226}]}, {\"sentence\": \"The decision - the fifth time organisers have scrapped training in the river since the start of the Games on July 28 - is likely to frustrate competitors who must get used to the Seine's strong currents.\", \"from\": 244, \"to\": 447, \"entities\": [{\"begin\": 423, \"end\": 428, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999999998626663, \"rank\": 1.2341778250130125e-10, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"The decision\", \"from\": 244, \"to\": 256}, {\"ngram\": \"the fifth time\", \"from\": 259, \"to\": 273}, {\"ngram\": \"organisers\", \"from\": 274, \"to\": 284}, {\"ngram\": \"training\", \"from\": 299, \"to\": 307}, {\"ngram\": \"the river\", \"from\": 311, \"to\": 3