 {\"sentence\": \"Her exit also meant the end of the Philippines' quest in Paris for an Olympic boxing gold that has eluded the country in 100 years of participation in the Summer Games.\", \"from\": 1648, \"to\": 1816, \"entities\": [{\"begin\": 1683, \"end\": 1694, \"title\": \"http://dbpedia.org/resource/Philippines\", \"score\": 0.9999999999399733, \"rank\": 5.960167412217888e-11, \"text\": \"Philippines\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Philippines\", \"dbpedia\": \"http://dbpedia.org/resource/Philippines\"}, {\"begin\": 1705, \"end\": 1710, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999999999943384, \"rank\": 5.656487478362897e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Her exit\", \"from\": 1648, \"to\": 1656}, {\"ngram\": \"the end\", \"from\": 1668, \"to\": 1675}, {\"ngram\": \"an Olympic boxing gold\", \"from\": 1715, \"to\": 1737}, {\"ngram\": \"the country\", \"from\": 1754, \"to\": 1765}, {\"ngram\": \"100 years\", \"from\": 1769, \"to\": 1778}, {\"ngram\": \"participation\", \"from\": 1782, \"to\": 1795}, {\"ngram\": \"the Summer Games\", \"from\": 1799, \"to\": 1815}]}, {\"sentence\": \"Eumir Marcial(men's 80kg) andHergie Bacyadan(women's 75kg) both dropped their opening bouts,Carlo Paalam(mens 57kg) crashed out of the quarterfinals, whileAira Villegas(women's 50kg) also snagged bronze.\", \"from\": 1818, \"to\": 2021, \"entities\": [{\"begin\": 1818, \"end\": 1831, \"title\": \"http://dbpedia.org/resource/Eumir_Marcial\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Eumir Marcial\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Eumir_Marcial\", \"dbpedia\": \"http://dbpedia.org/resource/Eumir_Marcial\"}], \"noun_phrases\": [{\"ngram\": \"80kg\", \"from\": 1838, \"to\": 1842}, {\"ngram\": \"andHergie Bacyada