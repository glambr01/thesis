\": 4356, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Original Recipe Preheat\", \"from\": 4313, \"to\": 4336}, {\"ngram\": \"the oven\", \"from\": 4337, \"to\": 4345}, {\"ngram\": \"F\", \"from\": 4353, \"to\": 4354}]}, {\"sentence\": \"In a saucepan on medium heat, heat up the milk, water, and instant coffee.\", \"from\": 4358, \"to\": 4432, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a saucepan\", \"from\": 4361, \"to\": 4371}, {\"ngram\": \"medium heat\", \"from\": 4375, \"to\": 4386}, {\"ngram\": \"the milk\", \"from\": 4396, \"to\": 4404}, {\"ngram\": \"water\", \"from\": 4406, \"to\": 4411}, {\"ngram\": \"instant coffee\", \"from\": 4417, \"to\": 4431}]}, {\"sentence\": \"Add cocoa powder, butter, and \\u00bd cup of chocolate chunks.\", \"from\": 4433, \"to\": 4489, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"cocoa powder\", \"from\": 4437, \"to\": 4449}, {\"ngram\": \"butter\", \"from\": 4451, \"to\": 4457}, {\"ngram\": \"\\u00bd cup\", \"from\": 4463, \"to\": 4468}, {\"ngram\": \"chocolate chunks\", \"from\": 4472, \"to\": 4488}]}, {\"sentence\": \"Remove from heat and set aside to cool.\", \"from\": 4490, \"to\": 4529, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"heat\", \"from\": 4502, \"to\": 4506}]}, {\"sentence\": \"In a separate bowl, combine flour, baking powder, and salt.\", \"from\": 4531, \"to\": 4590, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a separate bowl\", \"from\": 4534, \"to\": 4549}, {\"ngram\": \"flour\", \"from\": 4559, \"to\": 4564}, {\"ngram\": \"powder\", \"from\": 4573, \"to\": 4579}, {\"ngram\": \"salt\", \"from\": 4585, \"to\": 4589}]}, {\"sentence\": \"In another bowl, add the heated chocolate mixture, both sugars, oil, eggs, and vanilla.\", \"from\": 4592, \"to\": 4679, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"another bowl\", \"from\": 4595, \"to\": 4607}, {\"ngram\": \"the heated chocolate mixture\", \"from\": 4613, \"to\": 4641}, {\"ngram\": \"both sugars\", \"from\": 4643, \"to\": 4654}, {\"ngram\": \"oil\", \"from\": 4656, \"to\": 4659}, {\"ngram\": \"eggs\", \"from\": 4661, \"to\": 4665}, {\"ngram\": \"vanilla\", \"from\": 4671, \"to\": 4678}]}, {\"sentence\": \"Slowly fold the dry flour mixture into the second bowl.\", \"from\": 4681, \"to\": 4736, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the dry flour mixture\", \"from\": 4693, \"to\": 4714}, {\"ngram\": \"the second bowl\", \"from\": 4720, \"to\": 4735}]}, {\"sentence\": \"Then, stir in \\u00bd cup of chocolate chunks.\", \"from\": 4737, \"to\": 4777, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"\\u00bd cup\", \"from\": 4751, \"to\": 4756}, {\"ngram\": \"chocolate chunks\", \"from\": 4760, \"to\": 4776}]}, {\"sentence\": \"Separately, to create the ganache filling: in a saucepan, combine the condensed milk and chocolate chunks and place on low to medium heat.\", \"from\": 4779, \"to\": 4917, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the ganache filling\", \"from\": 4801, \"to\": 4820}, {\"ngram\": \"a saucepan\", \"from\": 4825, \"to\": 4835}, {\"ngram\": \"the condensed milk\", \"from\": 4845, \"to\": 4863}, {\"ngram\": \"chocolate chunks\", \"from\": 4868, \"to\": 4884}, {\"ngram\": \"place\", \"from\": 4889, \"to\": 4894}, {\"ngram\": \"low to medium heat\", \"from\": 4898, \"to\": 4916}]}, {\"sentence\": \"Stir regularly.\", \"from\": 4918, \"to\": 4933, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Once the mixture reaches a smooth consistency, remove from heat and cool before piping into the muffin.\", \"from\": 4934, \"to\": 5037, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the mixture\", \"from\": 4939, \"to\": 4950}, {\"ngram\": \"a smooth consistency\", \"from\": 4959, \"to\": 4979}, {\"ngram\": \"heat\", \"from\": 4993, \"to\": 4997}, {\"ngram\": \"the muffin\", \"from\": 5026, \"to\": 5036}]}, {\"sentence\": \"Pour the batter into a greased muffin tray and bake for 17-24 minutes, or until a toothpick comes out clean.\", \"from\": 5