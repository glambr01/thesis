357}]}, {\"sentence\": \"Australiahad been the clear favourites for gold after qualifying 1.5seconds quicker for the final.\", \"from\": 361, \"to\": 459, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Australiahad\", \"from\": 361, \"to\": 373}, {\"ngram\": \"the clear favourites\", \"from\": 379, \"to\": 399}, {\"ngram\": \"gold\", \"from\": 404, \"to\": 408}, {\"ngram\": \"1.5seconds\", \"from\": 426, \"to\": 436}]}, {\"sentence\": \"But the British line-up, with a change from the previous rounds as Dan Bigham came in for Ollie Wood, pushed the Australian's mightily close.\", \"from\": 461, \"to\": 602, \"entities\": [{\"begin\": 469, \"end\": 476, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.6562739792549305, \"rank\": 0.5175874146300123, \"text\": \"British\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"a change\", \"from\": 491, \"to\": 499}, {\"ngram\": \"the previous rounds\", \"from\": 505, \"to\": 524}, {\"ngram\": \"Dan Bigham\", \"from\": 528, \"to\": 538}, {\"ngram\": \"Ollie Wood\", \"from\": 551, \"to\": 561}]}, {\"sentence\": \"They had a 0.160s deficit to make up in the final few hundred metres when Ethan Hayter's legs seemed to give way from a final effort, he slipped off his saddle and did well to stay upright.\", \"from\": 604, \"to\": 793, \"entities\": [{\"begin\": 678, \"end\": 690, \"title\": \"http://dbpedia.org/resource/Ethan_Hayter\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Ethan Hayter\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Ethan_Hayter\", \"dbpedia\": \"http://dbpedia.org/resource/Ethan_Hayter\"}], \"noun_phrases\": [{\"ngram\": \"a 0.160s deficit\", \"from\": 613, \"to\": 629}, {\"ngram\": \"the final few hundred metres\", \"from\": 644, \"to\": 672}, {\"ngram\": \"way\", \"from\": 713, \"to\": 716}, {\"ngram\": \"a final effort\", \"from\": 722, \"to\": 736}, {\"ngram\": \"his saddle\", \"from\": 753, \"to\": 763}]}, {\"sentence\": \"With that, the British challenge was ended.\", \"from\": 794, \"to\": 837, \"entities\": [{\"begin\": 809, \"end\": 816, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.6562739792549305, \"rank\": 0.5175874146300123, \"text\": \"British\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": []}, {\"sentence\": \"Afterwards, Hayter said: \\\"We were so close and I could see it.\", \"from\": 839, \"to\": 901, \"entities\": [{\"begin\": 851, \"end\": 857, \"title\": \"http://dbpedia.org/resource/Stanley_William_Hayter\", \"score\": 0.972577348634725, \"rank\": 0.028195856228740872, \"text\": \"Hayter\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Stanley_William_Hayter\", \"dbpedia\": \"http://dbpedia.org/resource/Stanley_William_Hayter\"}], \"noun_phrases\": []}, {\"sentence\": \"It was nearly five laps at the end and I just really gave too much, and my whole body went weak and I really struggled to hold myself on the bike in the end.\", \"from\": 902, \"to\": 1059, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"nearly five laps\", \"from\": 909, \"to\": 925}, {\"ngram\": \"the end\", \"from\": 929, \"to\": 936}, {\"ngram\": \"my whole body\", \"from\": 974, \"to\": 987}, {\"ngram\": \"the bike\", \"from\": 1039, \"to\": 1047}, {\"ngram\": \"the end\", \"from\": 1051, \"to\": 1058}]}, {\"sentence\": \"\\\"Sorry to the guys but I think we gave everything and we can be proud of that silver medal.\", \"from\": 1061, \"to\": 1152, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the guys\", \"from\": 1071, \"to\": 1079}, {\"ngram\": \"everything\", \"from\": 1100, \"to\": 1110}, {\"ngram\": \"that silver medal\", \"from\": 1134, \"to\": 1151}]}, {\"sentenc