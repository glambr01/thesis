oun_phrases\": [{\"ngram\": \"The event\", \"from\": 2195, \"to\": 2204}, {\"ngram\": \"the Bay\", \"from\": 2208, \"to\": 2215}, {\"ngram\": \"Marseilles\", \"from\": 2219, \"to\": 2229}, {\"ngram\": \"delays\", \"from\": 2241, \"to\": 2247}, {\"ngram\": \"Wednesday\", \"from\": 2265, \"to\": 2274}, {\"ngram\": \"a wind shift\", \"from\": 2282, \"to\": 2294}, {\"ngram\": \"Wearn\", \"from\": 2328, \"to\": 2333}, {\"ngram\": \"the winner\", \"from\": 2343, \"to\": 2353}]}, {\"sentence\": \"\\\"It has not really sunk in.\", \"from\": 2356, \"to\": 2383, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I thought I'd break down pretty quickly but it's just pure excitement.\", \"from\": 2384, \"to\": 2454, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"just pure excitement\", \"from\": 2433, \"to\": 2453}]}, {\"sentence\": \"It's something no one's done before, going back to back in the ILCA (dinghy) - or the laser as it was before,\\\" the 28-year-old said after the race.\", \"from\": 2455, \"to\": 2602, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"something\", \"from\": 2460, \"to\": 2469}, {\"ngram\": \"no one\", \"from\": 2470, \"to\": 2476}, {\"ngram\": \"the ILCA (dinghy\", \"from\": 2514, \"to\": 2530}, {\"ngram\": \"the race\", \"from\": 2593, \"to\": 2601}]}, {\"sentence\": \"\\\"That was a massive goal and I have made it happen so it's pretty special.\\\"\", \"from\": 2604, \"to\": 2679, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a massive goal\", \"from\": 2614, \"to\": 2628}]}, {\"sentence\": \"The gold was replicated a couple of hours later by Keegan Palmer, who defended his title from the Tokyo Games, triumphing in the men's skateboarding.\", \"from\": 2681, \"to\": 2830, \"entities\": [{\"begin\": 2732, \"end\": 2745, \"title\": \"http://dbpedia.org/resource/Keegan_Palmer\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Keegan Palmer\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Keegan_Palmer\", \"dbpedia\": \"http://dbpedia.org/resource/Keegan_Palmer\"}], \"noun_phrases\": [{\"ngram\": \"The gold\", \"from\": 2681, \"to\": 2689}, {\"ngram\": \"hours\", \"from\": 2717, \"to\": 2722}, {\"ngram\": \"his title\", \"from\": 2760, \"to\": 2769}, {\"ngram\": \"the Tokyo Games\", \"from\": 2775, \"to\": 2790}, {\"ngram\": \"the men's skateboarding\", \"from\": 2806, \"to\": 2829}]}, {\"sentence\": \"The 21-year-old set the challenge on his first run with a blistering score of 93.11, which was enough for him to secure back-to-back golds.\", \"from\": 2832, \"to\": 2971, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The 21-year-old set\", \"from\": 2832, \"to\": 2851}, {\"ngram\": \"the challenge\", \"from\": 2852, \"to\": 2865}, {\"ngram\": \"his first run\", \"from\": 2869, \"to\": 2882}, {\"ngram\": \"a blistering score\", \"from\": 2888, \"to\": 2906}, {\"ngram\": \"back\", \"from\": 2960, \"to\": 2964}]}, {\"sentence\": \"\\\"I got really lucky though by everyone kind of falling off on their last two runs, but I had something prepared if need be,\\\" American-born Palmer said.\", \"from\": 2973, \"to\": 3124, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"everyone\", \"from\": 3003, \"to\": 3011}, {\"ngram\": \"their last two runs\", \"from\": 3035, \"to\": 3054}, {\"ngram\": \"something\", \"from\": 3066, \"to\": 3075}, {\"ngram\": \"need\", \"from\": 3088, \"to\": 3092}, {\"ngram\": \"American-born Palmer\", \"from\": 3098, \"to\": 3118}]}, {\"sentence\": \"\\\"I am speechless though.\", \"from\": 3126, \"to\": 3150, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I just can not believe it bro.\", \"from\": 3151, \"to\": 3181, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Everyone's yelling at me.\", \"from\": 3182, \"to\": 3207, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I am just happy.\", \"from\": 3208, \"to\": 3224, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Come on Australia,