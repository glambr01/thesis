 [], \"noun_phrases\": [{\"ngram\": \"a position\", \"from\": 2207, \"to\": 2217}]}, {\"sentence\": \"I just want to say thank you, it means the world to me.'\", \"from\": 2229, \"to\": 2285, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the world\", \"from\": 2268, \"to\": 2277}]}, {\"sentence\": \"A near-speechless Jarman said he 'could not be happier' after getting his hands on a bronze medal with an impressive routine on the floor, which scored 14.933.\", \"from\": 2287, \"to\": 2446, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A near-speechless Jarman\", \"from\": 2287, \"to\": 2311}, {\"ngram\": \"his hands\", \"from\": 2357, \"to\": 2366}, {\"ngram\": \"a bronze medal\", \"from\": 2370, \"to\": 2384}, {\"ngram\": \"an impressive routine\", \"from\": 2390, \"to\": 2411}, {\"ngram\": \"the floor\", \"from\": 2415, \"to\": 2424}]}, {\"sentence\": \"'I am lost for words to be honest.\", \"from\": 2448, \"to\": 2482, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"words\", \"from\": 2463, \"to\": 2468}]}, {\"sentence\": \"This medal means everything to me,' he said.\", \"from\": 2483, \"to\": 2527, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"This medal\", \"from\": 2483, \"to\": 2493}, {\"ngram\": \"everything\", \"from\": 2500, \"to\": 2510}]}, {\"sentence\": \"'I have had a lot of people in my life that helped me to get where I am today.\", \"from\": 2529, \"to\": 2607, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a lot\", \"from\": 2541, \"to\": 2546}, {\"ngram\": \"people\", \"from\": 2550, \"to\": 2556}, {\"ngram\": \"my life\", \"from\": 2560, \"to\": 2567}]}, {\"sentence\": \"'I could not do it without the support they gave to me.\", \"from\": 2609, \"to\": 2664, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the support\", \"from\": 2636, \"to\": 2647}]}, {\"sentence\": \"I hope I made a lot of people proud.\", \"from\": 2665, \"to\": 2701, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a lot\", \"from\": 2679, \"to\": 2684}, {\"ngram\": \"people\", \"from\": 2688, \"to\": 2694}]}, {\"sentence\": \"Honestly, I could not be happier.'\", \"from\": 2702, \"to\": 2736, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"For more stories like this,check our sport page.\", \"from\": 2738, \"to\": 2786, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"more stories\", \"from\": 2742, \"to\": 2754}, {\"ngram\": \"our sport page\", \"from\": 2771, \"to\": 2785}]}, {\"sentence\": \"Follow Metro Sport for the latest news onFacebook,TwitterandInstagram.\", \"from\": 2788, \"to\": 2858, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Metro Sport\", \"from\": 2795, \"to\": 2806}, {\"ngram\": \"the latest news onFacebook\", \"from\": 2811, \"to\": 2837}, {\"ngram\": \"TwitterandInstagram\", \"from\": 2838, \"to\": 2857}]}, {\"sentence\": \"ArrowMORE:Matthew Hudson-Smith's mum breaks hearts everywhere as she wipes away Team GB star's tears after 400m final ArrowMORE:French pole vaulter reacts to the buzz around penis that ended his Olympic dream ArrowMORE:14-year-old Olympian reveals unusual gift from parents after winning gold in Paris Punchy analysis, transfer talk and more from Metro's football experts, sent straight to your inbox every week.\", \"from\": 2860, \"to\": 3275, \"entities\": [{\"begin\": 2940, \"end\": 2947, \"title\": \"http://dbpedia.org/resource/Great_Britain_at_the_Olympics\", \"score\": 0.8876532648824914, \"rank\": 0.07347525962140282, \"text\": \"Team GB\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Great_Britain_at_the_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Great_Britain_at_the_Olympics\"}, {\"begin\": 2989, \"end\": 2995, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.5945544637121728, \"rank\": 0.6410908579296288, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 3093, \"end\": 3