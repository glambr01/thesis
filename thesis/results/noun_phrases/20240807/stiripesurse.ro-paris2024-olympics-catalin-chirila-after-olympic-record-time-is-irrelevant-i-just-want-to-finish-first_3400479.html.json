ntities\": [], \"noun_phrases\": [{\"ngram\": \"a new race\", \"from\": 557, \"to\": 567}]}, {\"sentence\": \"But from experience, I know that they did not row at maximum capacity,\\\" said Chirila.\", \"from\": 580, \"to\": 665, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"experience\", \"from\": 589, \"to\": 599}, {\"ngram\": \"maximum capacity\", \"from\": 633, \"to\": 649}, {\"ngram\": \"Chirila\", \"from\": 657, \"to\": 664}]}, {\"sentence\": \"The Semifinals and Final of Men's Canoe Single 1000m are scheduled two hours apart, which is something new for Chirila, who voices his hope that he will be more resilient than his opponents.\", \"from\": 667, \"to\": 857, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The Semifinals\", \"from\": 667, \"to\": 681}, {\"ngram\": \"Final\", \"from\": 686, \"to\": 691}, {\"ngram\": \"Men's Canoe Single 1000m\", \"from\": 695, \"to\": 719}, {\"ngram\": \"something\", \"from\": 760, \"to\": 769}, {\"ngram\": \"Chirila\", \"from\": 778, \"to\": 785}, {\"ngram\": \"his hope\", \"from\": 798, \"to\": 806}, {\"ngram\": \"his opponents\", \"from\": 843, \"to\": 856}]}, {\"sentence\": \"\\\"It will be different for me, I have never rowed two races two hours apart.\", \"from\": 859, \"to\": 934, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"two races\", \"from\": 908, \"to\": 917}]}, {\"sentence\": \"The last one was in Tokyo in the Canoes Double.\", \"from\": 935, \"to\": 982, \"entities\": [{\"begin\": 955, \"end\": 960, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.9947399826551135, \"rank\": 0.0027935439859137334, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}], \"noun_phrases\": [{\"ngram\": \"The last one\", \"from\": 935, \"to\": 947}]}, {\"sentence\": \"I think it's the same for all my opponents.\", \"from\": 983, \"to\": 1026, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"all my 