"{\"uid\": \"jamaicaobserver.com-2024-03-19-extended-outdoor-bar-hours-paris-olympics-anger-residents\", \"noun_phrases\": [{\"sentence\": \"PARIS, France (AFP)- Several associations representing residents in Paris on Tuesday denounced plans to allow bars and restaurants to keep their outdoor summer terraces open later than usual during the Olympics, saying the change would impact the health of locals.\", \"from\": 0, \"to\": 264, \"entities\": [{\"begin\": 7, \"end\": 13, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9986063466832057, \"rank\": 0.0011776598554615585, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 68, \"end\": 73, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999999999252168, \"rank\": 7.478407856071863e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"PARIS\", \"from\": 0, \"to\": 5}, {\"ngram\": \"Several associations\", \"from\": 21, \"to\": 41}, {\"ngram\": \"residents\", \"from\": 55, \"to\": 64}, {\"ngram\": \"Tuesday\", \"from\": 77, \"to\": 84}, {\"ngram\": \"plans\", \"from\": 95, \"to\": 100}, {\"ngram\": \"bars\", \"from\": 110, \"to\": 114}, {\"ngram\": \"restaurants\", \"from\": 119, \"to\": 130}, {\"ngram\": \"their outdoor summer terraces\", \"from\": 139, \"to\": 168}, {\"ngram\": \"the Olympics\", \"from\": 198, \"to\": 210}, {\"ngram\": \"the change\", \"from\": 219, \"to\": 229}, {\"ngram\": \"the health\", \"from\": 243, \"to\": 253}, {\"ngram\": \"locals\", \"from\": 257, \"to\": 263}]}, {\"sentence\": \"Paris Mayor Anne Hidalgo announced last Friday that temporary summer terraces could be used for food and drinks until midnight, instead of 10pm, from July 1 until the end of the Olympics and Paralympics on September 8.\", \"from\": 266, \"to\": 484, \"entities\": [{\"begin\": 266, \"end\": 277, \"title\": \"http://dbpedia.org/resource/List_of_mayors_of_Paris\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Paris Mayor\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/List_of_mayors_of_Paris\", \"dbpedia\": \"http://dbpedia.org/resource/List_of_mayors_of_Paris\"}, {\"begin\": 278, \"end\": 290, \"title\": \"http://dbpedia.org/resource/Anne_Hidalgo\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Anne Hidalgo\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Anne_Hidalgo\", \"dbpedia\": \"http://dbpedia.org/resource/Anne_Hidalgo\"}], \"noun_phrases\": [{\"ngram\": \"temporary summer terraces\", \"from\": 318, \"to\": 343}, {\"ngram\": \"food\", \"from\": 362, \"to\": 366}, {\"ngram\": \"drinks\", \"from\": 371, \"to\": 377}, {\"ngram\": \"midnight\", \"from\": 384, \"to\": 392}, {\"ngram\": \"10pm\", \"from\": 405, \"to\": 409}, {\"ngram\": \"July\", \"from\": 416, \"to\": 420}, {\"ngram\": \"the end\", \"from\": 429, \"to\": 436}, {\"ngram\": \"the Olympics\", \"from\": 440, \"to\": 452}, {\"ngram\": \"Paralympics\", \"from\": 457, \"to\": 468}, {\"ngram\": \"September\", \"from\": 472, \"to\": 481}]}, {\"sentence\": \"Around one in five venues in Paris - 3,000 out of 15,000 - has a licence for a summer terrace, according to city hall figures.\", \"from\": 486, \"to\": 612, \"entities\": [{\"begin\": 515, \"end\": 520, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999999999252168, \"rank\": 7.478407856071863e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"five venues\", \"from\": 500, \"to\": 511}, {\"ngram\": \"a licence\", \"from\": 549, \"to\": 558}, {\"ngram\": \"a summer terrace\", \"from\": 563, \"to\": 579}, {\"ngram\": \"city hall figures\", \"from\": 594, \"to\": 611}]}, {\"sentence\": \"A joint statement from two residents' associations, Droit au Sommeil and Vivre Paris, said that they were \\\"alarmed\\\" that the mayor's office was \\\"supporting in an over-the-top way the revenues of restaurant owners to the detriment of the health and sleep of the people it administers.\\\"\", \"from\": 614, \"to\": 898, \"entities\": [{\"begin\": 687, \"end\": 692, \"title\": \"http://dbpedia.org/resource/Vivre_(Noa_song)\", \"score\": 0.8921307731570552, \"rank\": 0.0, \"text\": \"Vivre\", \"types\": [\"Q386724\", \"Q2188189\"], \"wikid\": \"http://dbpedia.org/resource/Vivre_(Noa_song)\", \"dbpedia\": \"http://dbpedia.org/resource/Vivre_(Noa_song)\"}, {\"begin\": 693, \"end\": 698, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999999999252168, \"rank\": 7.478407856071863e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"A joint statement\", \"from\": 614, \"to\": 631}, {\"ngram\": \"two residents' associations\", \"from\": 637, \"to\": 664}, {\"ngram\": \"Droit\", \"from\": 666, \"to\": 671}, {\"ngram\": \"Sommeil\", \"from\": 675, \"to\": 682}, {\"ngram\": \"the mayor's office\", \"from\": 735, \"to\": 753}, {\"ngram\": \"the-top\", \"from\": 781, \"to\": 788}, {\"ngram\": \"the revenues\", \"from\": 793, \"to\": 805}, {\"ngram\": \"restaurant owners\", \"from\": 809, \"to\": 826}, {\"ngram\": \"the detriment\", \"from\": 830, \"to\": 843}, {\"ngram\": \"the health\", \"from\": 847, \"to\": 857}, {\"ngram\": \"sleep\", \"from\": 862, \"to\": 867}, {\"ngram\": \"the people\", \"from\": 871, \"to\": 881}]}, {\"sentence\": \"Complaints about noise are a common feature of life in densely populated Paris, with the temporary summer terraces introduced by Hidalgo during the Covid-19 pandemic becoming a new source of friction.\", \"from\": 900, \"to\": 1100, \"entities\": [{\"begin\": 973, \"end\": 978,