\"begin\": 365, \"end\": 370, \"title\": \"http://dbpedia.org/resource/University_of_Akron\", \"score\": 0.999994276273365, \"rank\": 5.5157054084008834e-06, \"text\": \"Akron\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/University_of_Akron\", \"dbpedia\": \"http://dbpedia.org/resource/University_of_Akron\"}, {\"begin\": 411, \"end\": 428, \"title\": \"http://dbpedia.org/resource/Civil_engineering\", \"score\": 1.0, \"rank\": 6.1440842512796014e-21, \"text\": \"Civil Engineering\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Civil_engineering\", \"dbpedia\": \"http://dbpedia.org/resource/Civil_engineering\"}], \"noun_phrases\": [{\"ngram\": \"various indoor and outdoor locations\", \"from\": 316, \"to\": 352}, {\"ngram\": \"the competition\", \"from\": 379, \"to\": 394}, {\"ngram\": \"a fun\", \"from\": 455, \"to\": 460}, {\"ngram\": \"students\", \"from\": 486, \"to\": 494}, {\"ngram\": \"hands-on experience\", \"from\": 495, \"to\": 514}, {\"ngram\": \"their engineering education\", \"from\": 529, \"to\": 556}]}, {\"sentence\": \"Both Highschool and College students will be able to compete at this event.\", \"from\": 559, \"to\": 634, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Both Highschool and College students\", \"from\": 559, \"to\": 595}, {\"ngram\": \"this event\", \"from\": 623, \"to\": 633}]}, {\"sentence\": \"The sign-up sheet for those willing to participate will be inside the Auburn Science and Engineering building room 120.\", \"from\": 635, \"to\": 754, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The sign-up sheet\", \"from\": 635, \"to\": 652}, {\"ngram\": \"the Auburn Science and Engineering building room\", \"from\": 701, \"to\": 749}]}, {\"sentence\": \"The Construction Olympiad contains eight events where students compete for medals and prizes.\", \"from\": 755, \"to\": 848, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The Construction Olympiad\", \"from\": 755, \"to\": 780}, {\"ngram\": \"eight events\", \"from\": 790, \"to\": 802}, {\"ngram\": \"students\", \"from\": 809, \"to\": 817}, {\"ngram\": \"medals\", \"from\": 830, \"to\": 836}, {\"ngram\": \"prizes\", \"from\": 841, \"to\": 847}]}, {\"sentence\": \"This competition was designed as a recruitment event where high school faculty bring student groups interested in learning about civil engineering, construction, construction engineering technology, and surveying and mapping to campus.\", \"from\": 850, \"to\": 1085, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"This competition\", \"from\": 850, \"to\": 866}, {\"ngram\": \"a recruitment event\", \"from\": 883, \"to\": 902}, {\"ngram\": \"high school faculty\", \"from\": 909, \"to\": 928}, {\"ngram\": \"student groups\", \"from\": 935, \"to\": 949}, {\"ngram\": \"civil engineering\", \"from\": 979, \"to\": 996}, {\"ngram\": \"construction\", \"from\": 998, \"to\": 1010}, {\"ngram\": \"construction engineering technology\", \"from\": 1012, \"to\": 1047}, {\"ngram\": \"surveying\", \"from\": 1053, \"to\": 1062}, {\"ngram\": \"mapping\", \"from\": 1067, \"to\": 1074}, {\"ngram\": \"campus\", \"from\": 1078, \"to\": 1084}]}, {\"sentence\": \"Still hosting the event, now in its third year, Ballou loves seeing each student's face light up with a passion for engineering when competing in the competition.\", \"from\": 1087, \"to\": 1249, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the event\", \"from\": 1101, \"to\": 1110}, {\"ngram\": \"its third year\", \"from\": 1119, \"to\": 1133}, {\"ngram\": \"Ballou\", \"from\": 1135, \"to\": 1141}, {\"ngram\": \"each student's face\", \"from\": 1155, \"to\": 1174}, {\"ngram\": \"a passion\", \"from\": 1189, \"to\": 1198}, {\"ngram\": \"engineering\", \"from\": 1203, \"to\": 1214}, {\"ngram\": \"the competition\", \"from\": 1233, \"to\": 1248}]}, {\"sentence\": \"\\\"It stokes the competitive juices that are in each one of us and produces a memorable experience,\\\" Ballou said.\", \"from\": 1251, \"to\": 1362, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the competitive juices\", \"from\": 1262, \"to\": 1284}, {\"ngram\": \"us\", \"from\": 1309, \"to\": 1311}, {\"ngram\": \"a memorable experience\", \"from\": 1325, \"to\": 1347}, {\"ngram\": \"Ballou\", \"from\": 1350, \"to\": 1356}]}, {\"sentence\": \"From The Amazing Pace to Drilling for Dollars, the competition contains multiple events showcasing what students are learning in the classroom.\", \"from\": 1364, \"to\": 1507, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The Amazing Pace\", \"from\": 1369, \"to\": 1385}, {\"ngram\": \"Dollars\", \"from\": 1402, \"to\": 1409}, {\"ngram\": \"the competition\", \"from\": 1411, \"to\": 1426}, {\"ngram\": \"multiple events\", \"from\": 1436, \"to\": 1451}, {\"ngram\": \"students\", \"from\": 1468, \"to\": 1476}, {\"ngram\": \"the classroom\", \"from\": 1493, \"to\": 1506}]}, {\"sentence\": \"Ballou's favorite competition is the Bobcat Obstacle course, where students drive skid steers through a maze in a university parking lot.\", \"from\": 1508, \"to\": 1645, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Ballou's favorite competition\", \"from\": 1508, \"to\": 1537}, {\"ngram\": \"the Bobcat Obstacle course\", \"from\": 1541, \"to\": 1567}, {\"ngram\": \"students\", \"from\": 1575, \"to\": 1583}, {\"ngram\": \"skid steers\", \"from\": 1590, \"to\": 1601}, {\"ngram\": \"a maze\", \"from\": 1610, \"to\": 1616}, {\"ngram\": \"a university parking lot\", \"from\": 1620, \"to\": 1644}]}, {\"sentence\": \"\\\"It's a great sight to see students put into practice what they have been taught in the classroom,\\\" Ballou said.\", \"from\": 1647, \"to\": 1759, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a great sight\", \"from\": 1653, \"to\": 1666}, {\"ngram\": \"students\", \"from\": 1674, \"to\": 1682}, {\"ngram\": \"practice\", \"from\": 1692, \"to\": 1700}, {\"ngram\": \"the classroom\", \"from\": 1731, \"to\": 1744}, {\"ngram\": \"Ballou\", \"from\": 1747, \"to\": 1753}]}, {\"sentence\": \"For him, it's the moment they apply what they have learned into real world skills that is most exciting.\", \"from\": 1761, \"to\": 1865, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the moment\", \"from\": 1775, \"to\": 1785}, {\"ngram\": \"real world skills\", \"from\": 1825, \"to\": 1842}]}, {\"sentence\": \"Ballou joined UA in 1999.\", \"from\": 1867, \"to\": 1892, \"entities\": [{\"begin\": 1881, \"end\": 1883, \"title\": \"http://dbpedia.org/resource/University_of_Arizona\", \"score\": 0.9999998295457008, \"rank\": 1.3721202358144722e-07, \"text\": \"UA\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/University_of_Arizona\", \"dbpedia\": \"http://dbpedia.org/resource/University_of_Arizona\"}], \"noun_phrases\": [{\"ngram\": \"Ballou\", \"from\": 1867, \"to\": 1873}]}, {\"sentence\": \"Prior to this, he was an adjunct Professor of Architecture at Tri-C in Cleveland.\", \"from\": 1893, \"to\": 1974, \"entities\": [{\"begin\": 1964, \"end\": 1973, \"title\": \"http://dbpedia.org/resource/Cleveland\", \"score\": 0.9999999790002223, \"rank\": 2.0999737030664758e-08, \"text\": \"Cleveland\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Cleveland\", \"dbpedia\": \"http://dbpedia.org/resource/Cleveland\"}], \"noun_phrases\": [{\"ngram\": \"an adjunct Professor\", \"from\": 1915, \"to\": 1935}, {\"ngram\": \"Architecture\", \"from\": 1939, \"to\": 1951}, {\"ngram\": \"Tri-C\", \"from\": 1955, \"to\": 1960}]}, {\"sentence\": \"He has been recognized with outstanding teaching awards at the unit, college and university level.\", \"from\": 1975, \"to\": 2073, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"outstanding teaching awards\", \"from\": 2003, \"to\": 2030}, {\"ngram\": \"the unit\", \"from\": 2034, \"to\": 2042}, {\"ngram\": \"college and university level\", \"from\": 2044, \"to\":