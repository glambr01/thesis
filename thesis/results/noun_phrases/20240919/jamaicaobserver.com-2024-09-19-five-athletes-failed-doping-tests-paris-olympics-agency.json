"{\"uid\": \"jamaicaobserver.com-2024-09-19-five-athletes-failed-doping-tests-paris-olympics-agency\", \"noun_phrases\": [{\"sentence\": \"PARIS, Olympics (AFP) - Around a third of Olympic athletes were drug-tested during the Paris Games this year, with only five positive results, the International Testing Agency (ITA) said Thursday.\", \"from\": 0, \"to\": 196, \"entities\": [{\"begin\": 147, \"end\": 175, \"title\": \"http://dbpedia.org/resource/International_Testing_Agency\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Testing Agency\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Testing_Agency\", \"dbpedia\": \"http://dbpedia.org/resource/International_Testing_Agency\"}, {\"begin\": 177, \"end\": 180, \"title\": \"http://dbpedia.org/resource/Italy\", \"score\": 0.6753628588916272, \"rank\": 0.34729881056501416, \"text\": \"ITA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Italy\", \"dbpedia\": \"http://dbpedia.org/resource/Italy\"}], \"noun_phrases\": [{\"ngram\": \"PARIS\", \"from\": 0, \"to\": 5}, {\"ngram\": \"Olympics\", \"from\": 7, \"to\": 15}, {\"ngram\": \"AFP\", \"from\": 17, \"to\": 20}, {\"ngram\": \"a third\", \"from\": 31, \"to\": 38}, {\"ngram\": \"Olympic athletes\", \"from\": 42, \"to\": 58}, {\"ngram\": \"the Paris Games\", \"from\": 83, \"to\": 98}, {\"ngram\": \"only five positive results\", \"from\": 115, \"to\": 141}]}, {\"sentence\": \"That is one fewer than the Tokyo Games in 2021, although those tested represented a 4% increase on the previous Games and 10 per cent higher than Rio in 2016.\", \"from\": 198, \"to\": 356, \"entities\": [{\"begin\": 344, \"end\": 347, \"title\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"score\": 0.9999999912633939, \"rank\": 8.736505970224288e-09, \"text\": \"Rio\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2016_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"the Tokyo Games\", \"from\": 221, \"to\": 236}, {\"ngram\": \"a 4% increase\", \"from\": 280, \"to\": 293}, {\"ngram\": \"the previous Games\", \"from\": 297, \"to\": 315}]}, {\"sentence\": \"The ITA, which was in charge of testing during the Games, said 4,770 athletes - 39 percent of the total - had samples of their urine, blood and dried blood analysed during the July 26-August 11 event.\", \"from\": 358, \"to\": 558, \"entities\": [{\"begin\": 362, \"end\": 365, \"title\": \"http://dbpedia.org/resource/Italy\", \"score\": 0.6753628588916272, \"rank\": 0.34729881056501416, \"text\": \"ITA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Italy\", \"dbpedia\": \"http://dbpedia.org/resource/Italy\"}], \"noun_phrases\": [{\"ngram\": \"charge\", \"from\": 380, \"to\": 386}, {\"ngram\": \"testing\", \"from\": 390, \"to\": 397}, {\"ngram\": \"the Games\", \"from\": 405, \"to\": 414}, {\"ngram\": \"4,770 athletes\", \"from\": 421, \"to\": 435}, {\"ngram\": \"39 percent\", \"from\": 438, \"to\": 448}, {\"ngram\": \"the total - had samples\", \"from\": 452, \"to\": 475}, {\"ngram\": \"their urine\", \"from\": 479, \"to\": 490}, {\"ngram\": \"blood\", \"from\": 492, \"to\": 497}, {\"ngram\": \"dried blood\", \"from\": 502, \"to\": 513}, {\"ngram\": \"-August\", \"from\": 541, \"to\": 548}]}, {\"sentence\": \"ITA said it was the highest proportion of athletes ever tested, which followed intensive screening during 2024 which meant 90 percent of competitors were analysed at least once before the Games.\", \"from\": 560, \"to\": 754, \"entities\": [{\"begin\": 560, \"end\": 563, \"title\": \"http://dbpedia.org/resource/Italy\", \"score\": 0.6753628588916272, \"rank\": 0.34729881056501416, \"text\": \"ITA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Italy\", \"dbpedia\": \"http://dbpedia.org/resource/Italy\"}], \"noun_phrases\": [{\"ngram\": \"the highest proportion\", \"from\": 576, \"to\": 598}, {\"ngram\": \"athletes\", \"from\": 602, \"to\": 610}, {\"ngram\": \"intensive screening\", \"from\": 639, \"to\": 658}, {\"ngram\": \"90 percent\", \"from\": 683, \"to\": 693}, {\"ngram\": \"competitors\", \"from\": 697, \"to\": 708}, {\"ngram\": \"the Games\", \"from\": 744, \"to\": 753}]}, {\"sentence\": \"The agency added the greatest number of tests were implemented on athletes from the largest participating delegations: the United States, France, China and Australia.\", \"from\": 756, \"to\": 922, \"entities\": [{\"begin\": 879, \"end\": 892, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9997828712400263, \"rank\": 0.00020864767928037079, \"text\": \"United States\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 894, \"end\": 900, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9920695015549532, \"rank\": 0.006073742054440747, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 902, \"end\": 907, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.8232423599476714, \"rank\": 0.2140430525928517, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}, {\"begin\": 912, \"end\": 921, \"title\": \"http://dbpedia.org/resource/Australia\", \"score\": 0.9956132356463063, \"rank\": 0.003163809572549228, \"text\": \"Australia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Australia\", \"dbpedia\": \"http://dbpedia.org/resource/Australia\"}], \"noun_phrases\": [{\"ngram\": \"The agency\", \"from\": 756, \"to\": 766}, {\"ngram\": \"the greatest number\", \"from\": 773, \"to\": 792}, {\"ngram\": \"tests\", \"from\": 796, \"to\": 801}, {\"ngram\": \"athletes\", \"from\": 822, \"to\": 830}, {\"ngram\": \"the largest participating delegations\", \"from\": 836, \"to\": 873}]}, {\"sentence\": \"\\\"Sports such as athletics, aquatics, cycling, rowing, and wrestling saw the highest number of doping controls,\\\" read their statement.\", \"from\": 924, \"to\": 1057, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Sports\", \"from\": 925, \"to\": 931}, {\"ngram\": \"athletics\", \"from\": 940, \"to\": 949}, {\"ngram\": \"aquatics\", \"from\": 951, \"to\": 959}, {\"ngram\": \"cycling\", \"from\": 961, \"to\": 968}, {\"ngram\": \"rowing\", \"from\": 970, \"to\": 976}, {\"ngram\": \"wrestling\", \"from\": 982, \"to\": 991}, {\"ngram\": \"the highest number\", \"from\": 996, \"to\": 1014}, {\"ngram\": \"doping controls\", \"from\": 1018, \"to\": 1033}, {\"ngram\": \"their statement\", \"from\": 1041, \"to\": 1056}]}, {\"sentence\": \"The five athletes who tested positive in Paris were judokas Sajjad Ghanim Sehen Sehen from Iraq and Mohammad Samim Faizad from Afghanistan, as well as Nigerian boxer Cynthia Temitayo Ogunsemilore, Congolese sprinter Dominique Lasconi Mulamba, and Bolivian swimmer Maria Jose Ribera Pinto.\", \"from\": 1059, \"to\": 1347, \"entities\": [{\"begin\": 1100, \"end\": 1105, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999995184067553, \"rank\": 4.815934645357853e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 1150, \"end\": 1154, \"title\": \"http://dbpedia.org/resource/Iraq\", \"score\": 0.7216171395579299, \"rank\": 0.28809622266756385, \"text\": \"Iraq\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Iraq\", \"dbpedia\": \"http://dbpedia.org/resource/Iraq\"}, {\"begin\": 1168, \"end\": 1173, \"title\": \"http://dbpedia.org/resource/Samim\", \"score\": 0.9999997767593207, \"rank\": 0.0, \"text\": \"Samim\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Samim\", \"dbpedia