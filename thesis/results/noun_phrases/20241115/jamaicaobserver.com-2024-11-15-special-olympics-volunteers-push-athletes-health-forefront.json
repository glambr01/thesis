"{\"uid\": \"jamaicaobserver.com-2024-11-15-special-olympics-volunteers-push-athletes-health-forefront\", \"noun_phrases\": [{\"sentence\": \"Even as good-spirited competition bubbled across different venues in Trinidad and Tobago during the Special Olympics Caribbean Beach Games, there were volunteers behind the scenes helping to ensure athletes were in tip-top shape.\", \"from\": 0, \"to\": 229, \"entities\": [{\"begin\": 69, \"end\": 77, \"title\": \"http://dbpedia.org/resource/Trinidad_and_Tobago\", \"score\": 0.9969659374914228, \"rank\": 0.0030345990752169982, \"text\": \"Trinidad\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Trinidad_and_Tobago\", \"dbpedia\": \"http://dbpedia.org/resource/Trinidad_and_Tobago\"}], \"noun_phrases\": [{\"ngram\": \"good-spirited competition\", \"from\": 8, \"to\": 33}, {\"ngram\": \"different venues\", \"from\": 49, \"to\": 65}, {\"ngram\": \"Tobago\", \"from\": 82, \"to\": 88}, {\"ngram\": \"the Special Olympics Caribbean Beach Games\", \"from\": 96, \"to\": 138}, {\"ngram\": \"volunteers\", \"from\": 151, \"to\": 161}, {\"ngram\": \"the scenes\", \"from\": 169, \"to\": 179}, {\"ngram\": \"athletes\", \"from\": 198, \"to\": 206}, {\"ngram\": \"tip-top shape\", \"from\": 215, \"to\": 228}]}, {\"sentence\": \"The inaugural beach games, staged from November 8-10, provided the chance for athletes with intellectual disabilities to showcase their skills, compete against their peers, and build relationships with people across the region.\", \"from\": 231, \"to\": 458, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The inaugural beach games\", \"from\": 231, \"to\": 256}, {\"ngram\": \"November\", \"from\": 270, \"to\": 278}, {\"ngram\": \"the chance\", \"from\": 294, \"to\": 304}, {\"ngram\": \"athletes\", \"from\": 309, \"to\": 317}, {\"ngram\": \"intellectual disabilities\", \"from\": 323, \"to\": 348}, {\"ngram\": \"their skills\", \"from\": 361, \"to\": 373}, {\"ngram\": \"their peers\", \"from\": 391, \"to\": 402}, {\"ngram\": \"relationships\", \"from\": 414, \"to\": 427}, {\"ngram\": \"people\", \"from\": 433, \"to\": 439}, {\"ngram\": \"the region\", \"from\": 447, \"to\": 457}]}, {\"sentence\": \"Away from the sporting activities, organisers hosted healthy athletes screening, a family health forum and a Caribbean Initiative Family Engagement Workshop.\", \"from\": 460, \"to\": 617, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the sporting activities\", \"from\": 470, \"to\": 493}, {\"ngram\": \"organisers\", \"from\": 495, \"to\": 505}, {\"ngram\": \"healthy athletes screening\", \"from\": 513, \"to\": 539}, {\"ngram\": \"a family health forum\", \"from\": 541, \"to\": 562}, {\"ngram\": \"a Caribbean Initiative Family Engagement Workshop\", \"from\": 567, \"to\": 616}]}, {\"sentence\": \"The athletes screening, a key facet of the Special Olympics movement, allows access to free health services with emphasis on the eyes, ears, teeth and feet.\", \"from\": 619, \"to\": 775, \"entities\": [{\"begin\": 662, \"end\": 678, \"title\": \"http://dbpedia.org/resource/Special_Olympics\", \"score\": 1.0, \"rank\": 2.861951383071703e-17, \"text\": \"Special Olympics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Special_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Special_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"The athletes\", \"from\": 619, \"to\": 631}, {\"ngram\": \"a key facet\", \"from\": 643, \"to\": 654}, {\"ngram\": \"access\", \"from\": 696, \"to\": 702}, {\"ngram\": \"free health services\", \"from\": 706, \"to\": 726}, {\"ngram\": \"emphasis\", \"from\": 732, \"to\": 740}, {\"ngram\": \"the eyes\", \"from\": 744, \"to\": 752}, {\"ngram\": \"ears\", \"from\": 754, \"to\": 758}, {\"ngram\": \"teeth\", \"from\": 760, \"to\": 765}, {\"ngram\": \"feet\", \"from\": 770, \"to\": 774}]}, {\"sentence\": \"Athletes are also exposed to physiotherapy and general health awareness.\", \"from\": 776, \"to\": 848, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Athletes\", \"from\": 776, \"to\": 784}, {\"ngram\": \"physiotherapy\", \"from\": 805, \"to\": 818}, {\"ngram\": \"general health awareness\", \"from\": 823, \"to\": 847}]}, {\"sentence\": \"Dr Jewel Baird, medical chairperson for Special Olympics Trinidad and Tobago (SOTT), was integral in the planning and execution of the athletes screening and the family health forum during the games.\", \"from\": 850, \"to\": 1049, \"entities\": [{\"begin\": 853, \"end\": 858, \"title\": \"http://dbpedia.org/resource/Jewel_(supermarket)\", \"score\": 0.9884391541849433, \"rank\": 0.011421066227982953, \"text\": \"Jewel\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Jewel_(supermarket)\", \"dbpedia\": \"http://dbpedia.org/resource/Jewel_(supermarket)\"}, {\"begin\": 859, \"end\": 864, \"title\": \"http://dbpedia.org/resource/Mike_Baird\", \"score\": 0.9560163559934678, \"rank\": 0.043718765091209165, \"text\": \"Baird\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Mike_Baird\", \"dbpedia\": \"http://dbpedia.org/resource/Mike_Baird\"}], \"noun_phrases\": [{\"ngram\": \"medical chairperson\", \"from\": 866, \"to\": 885}, {\"ngram\": \"Special Olympics\", \"from\": 890, \"to\": 906}, {\"ngram\": \"Trinidad\", \"from\": 907, \"to\": 915}, {\"ngram\": \"Tobago\", \"from\": 920, \"to\": 926}, {\"ngram\": \"SOTT\", \"from\": 928, \"to\": 932}, {\"ngram\": \"the planning\", \"from\": 951, \"to\": 963}, {\"ngram\": \"execution\", \"from\": 968, \"to\": 977}, {\"ngram\": \"the family health forum\", \"from\": 1008, \"to\": 1031}, {\"ngram\": \"the games\", \"from\": 1039, \"to\": 1048}]}, {\"sentence\": \"For her, it was a \\\"hectic\\\", but \\\"productive\\\" experience.\", \"from\": 1051, \"to\": 1107, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"\\\"productive\\\" experience\", \"from\": 1083, \"to\": 1106}]}, {\"sentence\": \"\\\"I am glad\\u2026 that the athletes were screened, they got referrals for when they get back home for whether they need to see a doctor, or start medication,\\\" Baird told theJamaica Observer.\", \"from\": 1109, \"to\": 1293, \"entities\": [{\"begin\": 1262, \"end\": 1267, \"title\": \"http://dbpedia.org/resource/Mike_Baird\", \"score\": 0.9560163559934678, \"rank\": 0.043718765091209165, \"text\": \"Baird\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Mike_Baird\", \"dbpedia\": \"http://dbpedia.org/resource/Mike_Baird\"}], \"noun_phrases\": [{\"ngram\": \"the athletes\", \"from\": 1126, \"to\": 1138}, {\"ngram\": \"referrals\", \"from\": 1163, \"to\": 1172}, {\"ngram\": \"a doctor\", \"from\": 1230, \"to\": 1238}, {\"ngram\": \"medication\", \"from\": 1249, \"to\": 1259}, {\"ngram\": \"theJamaica Observer\", \"from\": 1273, \"to\": 1292}]}, {\"sentence\": \"\\\"When they come here they get to do their fitness, eye checks, blood pressure, check their vitals and all of that plays into their performances for their countries.\\\"\", \"from\": 1295, \"to\": 1460, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"their fitness\", \"from\": 1331, \"to\": 1344}, {\"ngram\": \"eye checks\", \"from\": 1346, \"to\": 1356}, {\"ngram\": \"blood pressure\", \"from\": 1358, \"to\": 1372}, {\"ngram\": \"their vitals\", \"from\": 1380, \"to\": 1392}, {\"ngram\": \"their performances\", \"from\": 1420, \"to\": 1438}, {\"ngram\": \"their countries\", \"from\": 1443, \"to\": 1458}]}, {\"sentence\": \"She underlined the significance of screening the athletes and spreading health awareness to their family members and coaches and to volunteers in the varying Caribbean programmes.\", \"from\": 1462, \"to\": 1641, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the significance\", \"from\": 1477, \"to\": 1493}, {\"ngram\": \"the athletes\", \"from\": 1507, \"to\": 1519}, {\"ngram\": \"health awareness\", \"from\": 1534, \"to\": 1550}, {\"ngram\": \"their family members\", \"from\": 1554, \"to\": 1574}, {\"ngram\": \"coaches\", \"from\": 1579, \"to\": 1586}, {\"ngram\": \"volunteers\", \"from\": 1594, \"to\": 1604}, {\"ngram\": \"the varying Caribbean programmes\", \"from\": 1608, \"to\": 1640}]}, {\"sentence\": \"\\\"There are some cases where athletes may not have proper access to health care and sometimes the only access they have is when they go to the different games, internationally, that kind of thing.\", \"from\": 1643, \"to\": 1838, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"some cases\", \"from\": 1654, \"to\": 1664}, {\"ngram\": \"athletes\", \"from\": 1671, \"to\": 1679}, {\"ngram\": \"proper access\", \"from\": 1693, \"to\": 1706}, {\"ngram\": \"health care\", \"from\": 1710, \"to\": 1721}, {\"ngram\": \"the only access\", \"from\": 1736, \"to\": 1751}, {\"ngram\": \"the different games\", \"from\": 1781, \"to\": 1800}, {\"ngram\": \"thing\", \"from\": 1832, \"to\": 1837}]}, {\"sentence\": \"\\\"So, it's very important because sometimes even in our clinics in the public service where we have eye clinics, cardiology clinics, etc, these athletes can sometimes be overlooked and a lot of things are missed,\\\" said the 29-year-old doctor who has been SOTT's medical chairperson since the 2023 World Summer Games in Berlin, Germany.\", \"from\": 1840, \"to\": 2174, \"entities\": [{\"begin\": 1952, \"end\": 1962, \"title\": \"http://dbpedia.org/resource/Cardiology\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"cardiology\", \"types\": [\"Q930752\"], \"wikid\": \"http://dbpedia.org/resource/Cardiology\", \"dbpedia\": \"http://dbpedia.org/resource/Cardiology\"}, {\"begin\": 2158, \"end\": 2173, \"title\": \"http://dbpedia.org/resource/Berlin\", \"score\": 1.0, \"rank\": 1.0945126881913765e-15, \"text\": \"Berlin, Germany\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Berlin\", \"dbpedia\": \"http://dbpedia.org/resource/Berlin\"}, {\"begin\": 2158, \"end\": 2173, \"title\": \"http://dbpedia.org/resource/Berlin\", \"score\": 1.0, \"rank\": 1.0945126881913765e-15, \"text\": \"Berlin, Germany\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Berlin\", \"dbpedia\": \"http://dbpedia.org/resource/Berlin\"}], \"noun_phrases\": [{\"ngram\": \"our clinics\", \"from\": 1891, \"to\": 1902}, {\"ngram\": \"the public service\", \"from\": 1906, \"to\": 1924}, {\"ngram\": \"eye clinics\", \"from\": 1939, \"to\": 1950}, {\"ngram\": \"these athletes\", \"from\": 1977, \"to\": 1991}, {\"ngram\": \"a lot\", \"from\": 2024, \"to\": 2029}, {\"ngram\": \"things\", \"from\": 2033, \"to\": 2039}, {\"ngram\": \"the 29-year-old doctor\", \"from\": 2058, \"to\": 2080}, {\"ngram\": \"SOTT's medical chairperson\", \"from\": 2094, \"to\": 2120}, {\"ngram\": \"the 2023 World Summer Games\", \"from\": 2127, \"to\": 2154}]}, {\"sentence\": \"\\\"Sometimes it's not about the access to health care but it's the quality of health care that they receive, which could be suboptimal compared to other people, which is really not fair.\", \"from\": 2176, \"to\": 2360, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the access\", \"from\": 2202, \"to\": 2212}, {\"ngram\": \"health care\", \"from\": 2216, \"to\": 2227}, {\"ngram\": \"the quality\", \"from\": 2237, \"to\": 2248}, {\"ngram\": \"health care\", \"from\": 2252, \"to\": 2263}, {\"ngram\": \"other people\", \"from\": 2321, \"to\": 2333}]}, {\"sentence\": \"So, it's really important that they come, we can pick up some things and we can give treatment, we give advice, they can ask any questions they might have.\", \"from\": 2361, \"to\": 2516, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"some things\", \"from\": 2418, \"to\": 2429}, {\"ngram\": \"treatment\", \"from\": 2446, \"to\": 2455}, {\"ngram\": \"advice\", \"from\": 2465, \"to\": 2471}, {\"ngram\": \"any questions\", \"from\": 2486, \"to\": 2499}]}, {\"sentence\": \"\\\"It kind of facilitates a conversation where they can continue to take care of themselves and their health.\", \"from\": 2518, \"to\": 2625, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a conversation\", \"from\": 2542, \"to\": 2556}, {\"ngram\": \"care\", \"from\": 2589, \"to\": 2593}, {\"ngram\": \"their health\", \"from\": 2612, \"to\": 2624}]}, {\"sentence\": \"I tell people that they are not just special needs, they are athletes, so they need to train like athletes, eat like athletes and their entire mindset needs to be like an athlete,\\\" she explained.\", \"from\": 2626, \"to\": 2821, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"people\", \"from\": 2633, \"to\": 2639}, {\"ngram\": \"special needs\", \"from\": 2663, \"to\": 2676}, {\"ngram\": \"athletes\", \"from\": 2687, \"to\": 2695}, {\"ngram\": \"athletes\", \"from\": 2724, \"to\": 2732}, {\"ngram\": \"athletes\", \"from\": 2743, \"to\": 2751}, {\"ngram\": \"their entire mindset\", \"from\": 2756, \"to\": 2776}, {\"ngram\": \"an athlete\", \"from\": 2794, \"to\": 2804}]}, {\"sentence\": \"Baird, who attended medical school at The University of the West Indies (UWI), Mona Campus in Jamaica, said volunteerism within Special Olympics is second nature in her family.\", \"from\": 2823, \"to\": 2999, \"entities\": [{\"begin\": 2823, \"end\": 2828, \"title\": \"http://dbpedia.org/resource/Mike_Baird\", \"score\": 0.9560163559934678, \"rank\": 0.043718765091209165, \"text\": \"Baird\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Mike_Baird\", \"dbpedia\": \"http://dbpedia.org/resource/Mike_Baird\"}, {\"begin\": 2896, \"end\": 2899, \"title\": \"http://dbpedia.org/resource/University_of_the_West_Indies\", \"score\": 1.0, \"rank\": 3.0298752975003413e-14, \"text\": \"UWI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/University_of_the_West_Indies\", \"dbpedia\": \"http://dbpedia.org/resource/University_of_the_West_Indies\"}, {\"begin\": 2902, \"end\": 2913, \"title\": \"http://dbpedia.org/resource/University_of_the_West_Indies\", \"score\": 1.0, \"rank\": 1.2350494466877821e-37, \"text\": \"Mona Campus\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/University_of_the_West_Indies\", \"dbpedia\": \"http://dbpedia.org/resource/University_of_the_West_Indies\"}, {\"begin\": 2917, \"end\": 2924, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.998868376258201, \"rank\": 0.001132859494666255, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}, {\"begin\": 2951, \"end\": 2967, \"title\": \"http://dbpedia.org/resource/Special_Olympics\", \"score\": 1.0, \"rank\": 2.861951383071703e-17, \"text\": \"Special Olympics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Special_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Special_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"medical school\", \"from\": 2843, \"to\": 2857}, {\"ngram\": \"The University\", \"from\": 2861, \"to\": 2875}, {\"ngram\": \"the West Indies\", \"from\": 2879, \"to\": 2894}, {\"ngram\": \"volunteerism\", \"from\": 2931, \"to\": 2943}, {\"ngram\": \"second nature\", \"from\": 2971, \"to\": 2984}, {\"ngram\": \"her family\", \"from\": 2988, \"to\": 2998}]}, {\"sentence\": \"\\\"I have been volunteering all my life.\", \"from\": 3001, \"to\": 3039, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"all my life\", \"from\": 3027, \"to\": 3038}]}, {\"sentence\": \"My mother is a coach of bocce, and since I was small she brought me to volunteer.\", \"from\": 3040, \"to\": 3121, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My mother\", \"from\": 3040, \"to\": 3049}, {\"ngram\": \"a coach\", \"from\": 3053, \"to\": 3060}, {\"ngram\": \"bocce\", \"from\": 3064, \"to\": 3069}]}, {\"sentence\": \"I have been volunteering since I was six or seven years old.\", \"from\": 3122, \"to\": 3182, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"When I did med school in Jamaica - big up, UWI, Mona - and when I came back home that's when they started utilising me in the medical setting.\", \"from\": 3183, \"to\": 3325, \"entities\": [{\"begin\": 3208, \"end\": 3215, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.998868376258201, \"rank\": 0.001132859494666255, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}, {\"begin\": 3226, \"end\": 3229, \"title\": \"http://dbpedia.org/resource/University_of_the_West_Indies\", \"score\": 1.0, \"rank\": 3.0298752975003413e-14, \"text\": \"UWI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/University_of_the_West_Indies\", \"dbpedia\": \"http://dbpedia.org/resource/University_of_the_West_Indies\"}], \"noun_phrases\": [{\"ngram\": \"med school\", \"from\": 3194, \"to\": 3204}, {\"ngram\": \"the medical setting\", \"from\": 3305, \"to\": 3324}]}, {\"sentence\": \"\\\"It's amazing, getting to be a part of this and seeing how the athletes respond.\", \"from\": 3327, \"to\": 3407, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a part\", \"from\": 3356, \"to\": 3362}, {\"ngram\": \"the athletes\", \"from\": 3386, \"to\": 3398}]}, {\"sentence\": \"And seeing how excited they are every time is really, really rewarding.\", \"from\": 3408, \"to\": 3479, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I love to see it.\", \"from\": 3480, \"to\": 3497, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I did it [volunteering] and it kind of stuck and it has stuck with my entire family.\", \"from\": 3498, \"to\": 3582, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my entire family\", \"from\": 3565, \"to\": 3581}]}, {\"sentence\": \"My dad is also involved and my brother is involved, in different aspects, but we all do our part,\\\" she said.\", \"from\": 3583, \"to\": 3691, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My dad\", \"from\": 3583, \"to\": 3589}, {\"ngram\": \"my brother\", \"from\": 3611, \"to\": 3621}, {\"ngram\": \"different aspects\", \"from\": 3638, \"to\": 3655}, {\"ngram\": \"our part\", \"from\": 3671, \"to\": 3679}]}, {\"sentence\": \"Over the three days of the Special Olympics Beach Games, athletes participated in aquathlon, beach bocce, beach football, beach cricket, beach volleyball, and open water swimming.\", \"from\": 3693, \"to\": 3872, \"entities\": [{\"begin\": 3720, \"end\": 3736, \"title\": \"http://dbpedia.org/resource/Special_Olympics\", \"score\": 1.0, \"rank\": 2.861951383071703e-17, \"text\": \"Special Olympics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Special_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Special_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"the three days\", \"from\": 3698, \"to\": 3712}, {\"ngram\": \"athletes\", \"from\": 3750, \"to\": 3758}, {\"ngram\": \"aquathlon\", \"from\": 3775, \"to\": 3784}, {\"ngram\": \"beach bocce\", \"from\": 3786, \"to\": 3797}, {\"ngram\": \"beach football\", \"from\": 3799, \"to\": 3813}, {\"ngram\": \"beach cricket\", \"from\": 3815, \"to\": 3828}, {\"ngram\": \"beach volleyball\", \"from\": 3830, \"to\": 3846}, {\"ngram\": \"open water swimming\", \"from\": 3852, \"to\": 3871}]}, {\"sentence\": \"The beach games and related activities were hosted across venues in both the islands of Trinidad and Tobago, and attracted approximately 130 athletes, 70 coaches, and scores of volunteers.\", \"from\": 3874, \"to\": 4062, \"entities\": [{\"begin\": 3962, \"end\": 3970, \"title\": \"http://dbpedia.org/resource/Trinidad_and_Tobago\", \"score\": 0.9969659374914228, \"rank\": 0.0030345990752169982, \"text\": \"Trinidad\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Trinidad_and_Tobago\", \"dbpedia\": \"http://dbpedia.org/resource/Trinidad_and_Tobago\"}], \"noun_phrases\": [{\"ngram\": \"The beach games\", \"from\": 3874, \"to\": 3889}, {\"ngram\": \"related activities\", \"from\": 3894, \"to\": 3912}, {\"ngram\": \"venues\", \"from\": 3932, \"to\": 3938}, {\"ngram\": \"both the islands\", \"from\": 3942, \"to\": 3958}, {\"ngram\": \"Tobago\", \"from\": 3975, \"to\": 3981}, {\"ngram\": \"approximately 130 athletes\", \"from\": 3997, \"to\": 4023}, {\"ngram\": \"70 coaches\", \"from\": 4025, \"to\": 4035}, {\"ngram\": \"scores\", \"from\": 4041, \"to\": 4047}, {\"ngram\": \"volunteers\", \"from\": 4051, \"to\": 4061}]}, {\"sentence\": \"HOUSE RULES\", \"from\": 4066, \"to\": 4077, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"HOUSE RULES\", \"from\": 4066, \"to\": 4077}]}]}"