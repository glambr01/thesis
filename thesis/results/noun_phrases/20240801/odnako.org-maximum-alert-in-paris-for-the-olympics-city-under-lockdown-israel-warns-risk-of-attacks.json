, \"from\": 1240, \"to\": 1252}, {\"ngram\": \"the capital\", \"from\": 1256, \"to\": 1267}, {\"ngram\": \"traffic\", \"from\": 1286, \"to\": 1293}, {\"ngram\": \"Parisians\", \"from\": 1346, \"to\": 1355}]}, {\"sentence\": \"Transport Minister Patrice Vergriete confirmed that the Paris ring road, known as the 'p\\u00e9riph\\u00e9rique', will be partially if not completely closed, to be \\\"reserved for athletes' traffic\\\", in addition to the presence in the capital of dozens of heads of state, invited to dinner at the Louvre by President Emmanuel Macron and who will attend the opening ceremony.\", \"from\": 1405, \"to\": 1765, \"entities\": [{\"begin\": 1461, \"end\": 1476, \"title\": \"http://dbpedia.org/resource/Boulevard_P\\u00e9riph\\u00e9rique\", \"score\": 0.9999999996771294, \"rank\": 0.0, \"text\": \"Paris ring road\", \"types\": [\"Q34442\"], \"wikid\": \"http://dbpedia.org/resource/Boulevard_P\\u00e9riph\\u00e9rique\", \"dbpedia\": \"http://dbpedia.org/resource/Boulevard_P\\u00e9riph\\u00e9rique\"}, {\"begin\": 1708, \"end\": 1723, \"title\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Emmanuel Macron\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"dbpedia\": \"http://dbpedia.org/resource/Emmanuel_Macron\"}], \"noun_phrases\": [{\"ngram\": \"Transport Minister Patrice Vergriete\", \"from\": 1405, \"to\": 1441}, {\"ngram\": \"the 'p\\u00e9riph\\u00e9rique\", \"from\": 1487, \"to\": 1504}, {\"ngram\": \"athletes' traffic\", \"from\": 1571, \"to\": 1588}, {\"ngram\": \"addition\", \"from\": 1594, \"to\": 1602}, {\"ngram\": \"the presence\", \"from\": 1606, \"to\": 1618}, {\"ngram\": \"the capital\", \"from\": 1622, \"to\": 1633}, {\"ngram\": \"dozens\", \"from\": 1637, \"to\": 1643}, {\"ngram\": \"heads\", \"from\": 1647, \"to\": 1652}, {\"ngram\": \"state\", \"from\": 1656, \"to\": 1661}, {\"ngram\": \"dinner\", \"from\": 16