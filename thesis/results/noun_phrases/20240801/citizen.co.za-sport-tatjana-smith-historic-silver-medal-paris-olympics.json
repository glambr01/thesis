tes\", \"score\": 0.9999332806508675, \"rank\": 6.475082869070246e-05, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 516, \"end\": 529, \"title\": \"http://dbpedia.org/resource/Kate_Douglass\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Kate Douglass\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Kate_Douglass\", \"dbpedia\": \"http://dbpedia.org/resource/Kate_Douglass\"}], \"noun_phrases\": [{\"ngram\": \"Smith\", \"from\": 393, \"to\": 398}, {\"ngram\": \"her intentions\", \"from\": 404, \"to\": 418}, {\"ngram\": \"the start\", \"from\": 446, \"to\": 455}, {\"ngram\": \"some ground\", \"from\": 470, \"to\": 481}, {\"ngram\": \"the first turn\", \"from\": 488, \"to\": 502}, {\"ngram\": \"a gap\", \"from\": 546, \"to\": 551}]}, {\"sentence\": \"While the 27-year-old South African worked hard to close her down over the final length, she fell narrowly shy, touching the wall in 2:19.60.\", \"from\": 554, \"to\": 695, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the 27-year-old South African\", \"from\": 560, \"to\": 589}, {\"ngram\": \"the final length\", \"from\": 625, \"to\": 641}, {\"ngram\": \"the wall\", \"from\": 675, \"to\": 683}, {\"ngram\": \"2:19.60\", \"from\": 687, \"to\": 694}]}, {\"sentence\": \"Douglass won gold in 2:19.24.\", \"from\": 696, \"to\": 725, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Douglass\", \"from\": 696, \"to\": 704}, {\"ngram\": \"gold\", \"from\": 709, \"to\": 713}]}, {\"sentence\": \"Another stunning race by Tatjana Smith.Congratulations on winning \\ud83e\\udd48 for \\ud83c\\uddff\\ud83c\\udde6pic.twitter.com/Dt1iaHLDyg Further back, Kaylene Corbett ended seventh in 2:24.46 and was unable to challenge for the podium in what would have been a historic double for Team SA.\", \"from\": 727, \"to\": 981, \"entities\": [{\"be