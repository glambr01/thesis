"{\"uid\": \"rte.ie-sport-paris-2024-2024-0801-1463123-paris-2024-gymnastics-queen-biles-goat-with-the-gold\", \"noun_phrases\": [{\"sentence\": \"If anyone had any questions aboutSimone Biles'standing in gymnastics, the sparkling GOAT necklace she slipped on and ecstatically showed off to the camera after sealing the all-around title at the Paris Olympics confirmed her status as the greatest of all-time.\", \"from\": 0, \"to\": 261, \"entities\": [{\"begin\": 58, \"end\": 68, \"title\": \"http://dbpedia.org/resource/Gymnastics_at_the_2016_Summer_Olympics\", \"score\": 0.9999215780359714, \"rank\": 6.553685931541142e-05, \"text\": \"gymnastics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/Gymnastics_at_the_2016_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Gymnastics_at_the_2016_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"anyone\", \"from\": 3, \"to\": 9}, {\"ngram\": \"any questions aboutSimone\", \"from\": 14, \"to\": 39}, {\"ngram\": \"the sparkling GOAT necklace\", \"from\": 70, \"to\": 97}, {\"ngram\": \"the camera\", \"from\": 144, \"to\": 154}, {\"ngram\": \"the all-around title\", \"from\": 169, \"to\": 189}, {\"ngram\": \"the Paris Olympics\", \"from\": 193, \"to\": 211}, {\"ngram\": \"her status\", \"from\": 222, \"to\": 232}, {\"ngram\": \"all-time\", \"from\": 252, \"to\": 260}]}, {\"sentence\": \"The world's most decorated gymnast clinched her sixth Olympic gold medal in front of a delirious crowd at Bercy Arena after she left all her challengers in her shade, completing a triumphant comeback three years after withdrawing from the same final at the Tokyo Games.\", \"from\": 263, \"to\": 532, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The world's most decorated gymnast\", \"from\": 263, \"to\": 297}, {\"ngram\": \"her sixth Olympic gold medal\", \"from\": 307, \"to\": 335}, {\"ngram\": \"front\", \"from\": 339, \"to\": 344}, {\"ngram\": \"a delirious crowd\", \"from\": 348, \"to\": 365}, {\"ngram\": \"Bercy Arena\", \"from\": 369, \"to\": 380}, {\"ngram\": \"all her challengers\", \"from\": 396, \"to\": 415}, {\"ngram\": \"her shade\", \"from\": 419, \"to\": 428}, {\"ngram\": \"a triumphant comeback\", \"from\": 441, \"to\": 462}, {\"ngram\": \"the same final\", \"from\": 498, \"to\": 512}, {\"ngram\": \"the Tokyo Games\", \"from\": 516, \"to\": 531}]}, {\"sentence\": \"Aged 27, Biles edged past Brazil'sRebeca Andradeby 1.199 points to become the oldest athlete since 1952 to win the most coveted individual title in women's gymnastics.\", \"from\": 534, \"to\": 701, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Biles\", \"from\": 543, \"to\": 548}, {\"ngram\": \"Brazil'sRebeca Andradeby\", \"from\": 560, \"to\": 584}, {\"ngram\": \"the oldest athlete\", \"from\": 608, \"to\": 626}, {\"ngram\": \"the most coveted individual title\", \"from\": 645, \"to\": 678}, {\"ngram\": \"women's gymnastics\", \"from\": 682, \"to\": 700}]}, {\"sentence\": \"\\\"My GOAT necklace is kind of an ode ... it is crazy that I am in the conversation of greatest of all athletes because I still just think that I am Simone Biles from Spring, Texas who loves to flip,\\\" said the American who now owns a jaw-dropping 39 world and Olympic medals.\", \"from\": 703, \"to\": 976, \"entities\": [{\"begin\": 850, \"end\": 862, \"title\": \"http://dbpedia.org/resource/Simone_Biles\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Simone Biles\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Simone_Biles\", \"dbpedia\": \"http://dbpedia.org/resource/Simone_Biles\"}, {\"begin\": 876, \"end\": 881, \"title\": \"http://dbpedia.org/resource/Texas_Longhorns\", \"score\": 0.6659881903561307, \"rank\": 0.4473965959495586, \"text\": \"Texas\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/Texas_Longhorns\", \"dbpedia\": \"http://dbpedia.org/resource/Texas_Longhorns\"}, {\"begin\": 911, \"end\": 919, \"