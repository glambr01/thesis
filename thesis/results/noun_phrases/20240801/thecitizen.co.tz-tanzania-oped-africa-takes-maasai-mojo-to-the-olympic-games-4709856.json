"{\"uid\": \"thecitizen.co.tz-tanzania-oped-africa-takes-maasai-mojo-to-the-olympic-games-4709856\", \"noun_phrases\": [{\"sentence\": \"Prime Team Kenya athletes pose for a selfie during the opening ceremony of 2024 Olympic Games in Paris on Friday night.\", \"from\": 0, \"to\": 120, \"entities\": [{\"begin\": 12, \"end\": 17, \"title\": \"http://dbpedia.org/resource/Kenya\", \"score\": 1.0, \"rank\": 3.513475844985777e-23, \"text\": \"Kenya\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Kenya\", \"dbpedia\": \"http://dbpedia.org/resource/Kenya\"}, {\"begin\": 98, \"end\": 103, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 4.298762020713265e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"a selfie\", \"from\": 35, \"to\": 43}, {\"ngram\": \"the opening ceremony\", \"from\": 51, \"to\": 71}, {\"ngram\": \"2024 Olympic Games\", \"from\": 75, \"to\": 93}, {\"ngram\": \"Friday night\", \"from\": 106, \"to\": 118}]}, {\"sentence\": \"ByCharles Onyango-Obbo An article in the wonderfully quirky Lithuanian art and pop culture magazine Bored Panda, just gave a thumbs up to the uniforms that Kenya's and South Sudan's 2024 Olympics teams wore at the weekend opening ceremony in Paris.\", \"from\": 122, \"to\": 373, \"entities\": [{\"begin\": 225, \"end\": 236, \"title\": \"http://dbpedia.org/resource/Bored_Panda\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Bored Panda\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Bored_Panda\", \"dbpedia\": \"http://dbpedia.org/resource/Bored_Panda\"}, {\"begin\": 281, \"end\": 286, \"title\": \"http://dbpedia.org/resource/Kenya\", \"score\": 1.0, \"rank\": 3.513475844985777e-23, \"text\": \"Kenya\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Kenya\", \"dbpedia\": \"http://dbpedia.org/resource/Kenya\"}, {\"begin\": 367, \"end\": 372, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 4.298762020713265e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"ByCharles Onyango\", \"from\": 122, \"to\": 139}, {\"ngram\": \"-Obbo An article\", \"from\": 139, \"to\": 155}, {\"ngram\": \"the wonderfully quirky Lithuanian art and pop culture magazine\", \"from\": 159, \"to\": 221}, {\"ngram\": \"a thumbs\", \"from\": 245, \"to\": 253}, {\"ngram\": \"the uniforms\", \"from\": 260, \"to\": 272}, {\"ngram\": \"the weekend opening ceremony\", \"from\": 332, \"to\": 360}]}, {\"sentence\": \"The entertaining Bored Panda, which has 100 million unique visitors a month, rated Kenya's uniform as the second best, and South Sudan's as the third best.\", \"from\": 375, \"to\": 530, \"entities\": [{\"begin\": 392, \"end\": 403, \"title\": \"http://dbpedia.org/resource/Bored_Panda\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Bored Panda\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Bored_Panda\", \"dbpedia\": \"http://dbpedia.org/resource/Bored_Panda\"}, {\"begin\": 458, \"end\": 463, \"title\": \"http://dbpedia.org/resource/Kenya\", \"score\": 1.0, \"rank\": 3.513475844985777e-23, \"text\": \"Kenya\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Kenya\", \"dbpedia\": \"http://dbpedia.org/resource/Kenya\"}], \"noun_phrases\": [{\"ngram\": \"100 million unique visitors\", \"from\": 415, \"to\": 442}, {\"ngram\": \"South Sudan\", \"from\": 498, \"to\": 509}]}, {\"sentence\": \"The Sierra Leoneans also got a look in for their uniform, with the authors placing them fifth.\", \"from\": 531, \"to\": 625, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The Sierra Leoneans\", \"from\": 531, \"to\": 550}, {\"ngram\": \"a look\", \"from\": 560, \"to\": 566}, {\"ngram\": \"their uniform\", \"from\": 574, \"to\": 587}, {\"ngram\": \"the authors\", \"from\": 594, \"to\": 605}]}, {\"sentence\": \"Further down, the Egyptians came in 20th.\", \"from\": 626, \"to\": 667, \"entities\": [{\"begin\": 644, \"end\": 653, \"title\": \"http://dbpedia.org/resource/Romani_people\", \"score\": 0.9999999315141418, \"rank\": 4.5366940829279976e-08, \"text\": \"Egyptians\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Romani_people\", \"dbpedia\": \"http://dbpedia.org/resource/Romani_people\"}], \"noun_phrases\": [{\"ngram\": \"20th\", \"from\": 662, \"to\": 666}]}, {\"sentence\": \"In common, all the uniforms were created by African designers.\", \"from\": 669, \"to\": 731, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"all the uniforms\", \"from\": 680, \"to\": 696}, {\"ngram\": \"African designers\", \"from\": 713, \"to\": 730}]}, {\"sentence\": \"Team Kenya's attire, stunning Maasai-inspired kits, was designed by Nairobi fashion brand Kovu Couture.\", \"from\": 732, \"to\": 835, \"entities\": [{\"begin\": 737, \"end\": 742, \"title\": \"http://dbpedia.org/resource/Kenya\", \"score\": 1.0, \"rank\": 3.513475844985777e-23, \"text\": \"Kenya\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Kenya\", \"dbpedia\": \"http://dbpedia.org/resource/Kenya\"}, {\"begin\": 800, \"end\": 807, \"title\": \"http://dbpedia.org/resource/Nairobi\", \"score\": 1.0, \"rank\": 2.7439680051356476e-26, \"text\": \"Nairobi\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Nairobi\", \"dbpedia\": \"http://dbpedia.org/resource/Nairobi\"}], \"noun_phrases\": [{\"ngram\": \"stunning Maasai-inspired kits\", \"from\": 753, \"to\": 782}]}, {\"sentence\": \"South Sudan's uniform was designed by Rwandan fashion house Moshions.\", \"from\": 836, \"to\": 905, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"South Sudan's uniform\", \"from\": 836, \"to\": 857}, {\"ngram\": \"Rwandan fashion house Moshions\", \"from\": 874, \"to\": 904}]}, {\"sentence\": \"British African heritage brand Labrum, founded by Sierra Leonean Foday Dumbuya, designed Team Sierra Leone's uniforms; and Concrete, a menswear fashion brand based in Egypt, designed Team Egypt's uniforms.\", \"from\": 906, \"to\": 1111, \"entities\": [{\"begin\": 906, \"end\": 913, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9948467633168409, \"rank\": 0.003061340499889772, \"text\": \"British\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}, {\"begin\": 937, \"end\": 943, \"title\": \"http://dbpedia.org/resource/Labrum_(arthropod_mouthpart)\", \"score\": 0.9801230330464664, \"rank\": 0.010204081632649378, \"text\": \"Labrum\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Labrum_(arthropod_mouthpart)\", \"dbpedia\": \"http://dbpedia.org/resource/Labrum_(arthropod_mouthpart)\"}, {\"begin\": 956, \"end\": 970, \"title\": \"http://dbpedia.org/resource/Sierra_Leone\", \"score\": 1.0, \"rank\": 7.081187979623386e-18, \"text\": \"Sierra Leonean\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Sierra_Leone\", \"dbpedia\": \"http://dbpedia.org/resource/Sierra_Leone\"}, {\"begin\": 1000, \"end\": 1012, \"title\": \"http://dbpedia.org/resource/Sierra_Leone\", \"score\": 0.9999997990094218, \"rank\": 2.009905406080336e-07, \"text\": \"Sierra Leone\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Sierra_Leone\", \"dbpedia\": \"http://dbpedia.org/resource/Sierra_Leone\"}, {\"begin\": 1029, \"end\": 1037, \"title\": \"http://dbpedia.org/resource/Concrete_art\", \"score\": 0.9274084416591303, \"rank\": 0.05149272002238314, \"text\": \"Concrete\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Concrete_art\", \"dbpedia\": \"http://dbpedia.org/resource/Concrete_art\"}, {\"begin\": 1073, \"end\": 1078, \"title\": \"http://dbpedia.org/resource/Egypt\", \"score\": 0.9572303214998952, \"rank\": 0.04468065565895496, \"text\": \"Egypt\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Egypt\", \"dbpedia\": \"http://dbpedia.org/resource/Egypt\"}, {\"begin\": 1094, \"end\": 1099, \"title\": \"http://dbpedia.org/resource/Egypt\", \"score\": 0.9572303214998952, \"rank\": 0.04468065565895496, \"text\": \"Egypt\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Egypt\", \"dbpedia\": \"http://dbpedia.org/resource/Egypt\"}], \"noun_phrases\": [{\"ngram\": \"a menswear fashion brand\", \"from\": 1039, \"to\": 1063}]}, {\"sentence\": \"In the varied world of East African aesthetics, Kovu Couture and Moshions moved in both opposite and the same directions with their designs.\", \"from\": 1113, \"to\": 1253, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the varied world\", \"from\": 1116, \"to\": 1132}, {\"ngram\": \"East African aesthetics\", \"from\": 1136, \"to\": 1159}, {\"ngram\": \"Kovu Couture\", \"from\": 1161, \"to\": 1173}, {\"ngram\": \"Moshions\", \"from\": 1178, \"to\": 1186}, {\"ngram\": \"the same directions\", \"from\": 1214, \"to\": 1233}, {\"ngram\": \"their designs\", \"from\": 1239, \"to\": 1252}]}, {\"sentence\": \"Kovu Couture started today and moved back into tradition.\", \"from\": 1254, \"to\": 1311, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Kovu Couture\", \"from\": 1254, \"to\": 1266}, {\"ngram\": \"tradition\", \"from\": 1301, \"to\": 1310}]}, {\"sentence\": \"It said its design was, \\\"celebrating the vibrant colours, traditions, and stories that make our country unique\\\".\", \"from\": 1312, \"to\": 1424, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"its design\", \"from\": 1320, \"to\": 1330}, {\"ngram\": \"the vibrant colours\", \"from\": 1349, \"to\": 1368}, {\"ngram\": \"traditions\", \"from\": 1370, \"to\": 1380}, {\"ngram\": \"stories\", \"from\": 1386, \"to\": 1393}, {\"ngram\": \"our country\", \"from\": 1404, \"to\": 1415}]}, {\"sentence\": \"Moshions, known for its avant-garde and experimental approach to fashion, harnessed traditional themes and took a look into the future.\", \"from\": 1425, \"to\": 1560, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Moshions\", \"from\": 1425, \"to\": 1433}, {\"ngram\": \"its avant-garde and experimental approach\", \"from\": 1445, \"to\": 1486}, {\"ngram\": \"fashion\", \"from\": 1490, \"to\": 1497}, {\"ngram\": \"traditional themes\", \"from\": 1509, \"to\": 1527}, {\"ngram\": \"a look\", \"from\": 1537, \"to\": 1543}, {\"ngram\": \"the future\", \"from\": 1549, \"to\": 1559}]}, {\"sentence\": \"In the end, both paid homage to African tradition.\", \"from\": 1562, \"to\": 1612, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the end\", \"from\": 1565, \"to\": 1572}, {\"ngram\": \"homage\", \"from\": 1584, \"to\": 1590}, {\"ngram\": \"African tradition\", \"from\": 1594, \"to\": 1611}]}, {\"sentence\": \"There was a time when African designers did not get such pride of place.\", \"from\": 1613, \"to\": 1685, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a time\", \"from\": 1623, \"to\": 1629}, {\"ngram\": \"African designers\", \"from\": 1635, \"to\": 1652}, {\"ngram\": \"such pride\", \"from\": 1665, \"to\": 1675}, {\"ngram\": \"place\", \"from\": 1679, \"to\": 1684}]}, {\"sentence\": \"African teams at the Olympics - and Commonwealth Games - looked largely the same; in western suits, ties, and sun hats for men.\", \"from\": 1686, \"to\": 1813, \"entities\": [{\"begin\": 1722, \"end\": 1740, \"title\": \"http://dbpedia.org/resource/Commonwealth_Games\", \"score\": 0.9967845896379733, \"rank\": 0.003102917398507767, \"text\": \"Commonwealth Games\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Commonwealth_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Commonwealth_Games\"}], \"noun_phrases\": [{\"ngram\": \"African teams\", \"from\": 1686, \"to\": 1699}, {\"ngram\": \"the Olympics\", \"from\": 1703, \"to\": 1715}, {\"ngram\": \"western suits\", \"from\": 1771, \"to\": 1784}, {\"ngram\": \"ties\", \"from\": 1786, \"to\": 1790}, {\"ngram\": \"sun hats\", \"from\": 1796, \"to\": 1804}, {\"ngram\": \"men\", \"from\": 1809, \"to\": 1812}]}, {\"sentence\": \"Maasai beads would not only have been considered heathen, but no one would have thought of them.\", \"from\": 1815, \"to\": 1911, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Maasai beads\", \"from\": 1815, \"to\": 1827}, {\"ngram\": \"no one\", \"from\": 1877, \"to\": 1883}]}, {\"sentence\": \"Rwanda's Imigongo traditional art which Moshion channels employed, was nearly wiped out in the 1994 genocide against the Tutsi and has only bounced back in the last two decades thanks to a women's cooperative in the eastern part of the country which revived it.\", \"from\": 1912, \"to\": 2173, \"entities\": [{\"begin\": 1912, \"end\": 1918, \"title\": \"http://dbpedia.org/resource/Rwanda\", \"score\": 1.0, \"rank\": 1.0441351007352651e-16, \"text\": \"Rwanda\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Rwanda\", \"dbpedia\": \"http://dbpedia.org/resource/Rwanda\"}, {\"begin\": 1921, \"end\": 1929, \"title\": \"http://dbpedia.org/resource/Imigongo\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Imigongo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Imigongo\", \"dbpedia\": \"http://dbpedia.org/resource/Imigongo\"}, {\"begin\": 2033, \"end\": 2038, \"title\": \"http://dbpedia.org/resource/Tutsi\", \"score\": 0.9969662777198505, \"rank\": 0.0030429537565376794, \"text\": \"Tutsi\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Tutsi\", \"dbpedia\": \"http://dbpedia.org/resource/Tutsi\"}], \"noun_phrases\": [{\"ngram\": \"Moshion channels\", \"from\": 1952, \"to\": 1968}, {\"ngram\": \"the 1994 genocide\", \"from\": 2003, \"to\": 2020}, {\"ngram\": \"the last two decades\", \"from\": 2068, \"to\": 2088}, {\"ngram\": \"a women's cooperative\", \"from\": 2099, \"to\": 2120}, {\"ngram\": \"the eastern part\", \"from\": 2124, \"to\": 2140}, {\"ngram\": \"the country\", \"from\": 2144, \"to\": 2155}]}, {\"sentence\": \"These creative movements, therefore, speak volumes about how Africans see themselves - more vividly as more connected to our history - and at a visceral level, a determination not to disappear.\", \"from\": 2175, \"to\": 2368, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"These creative movements\", \"from\": 2175, \"to\": 2199}, {\"ngram\": \"volumes\", \"from\": 2218, \"to\": 2225}, {\"ngram\": \"Africans\", \"from\": 2236, \"to\": 2244}, {\"ngram\": \"our history\", \"from\": 2296, \"to\": 2307}, {\"ngram\": \"a visceral level\", \"from\": 2317, \"to\": 2333}]}, {\"sentence\": \"It has, therefore, been interesting to watch the regionalisation of Maasai art, together with its commercialisation, which has been a longer-running global phenomenon.\", \"from\": 2370, \"to\": 2537, \"entities\": [{\"begin\": 2438, \"end\": 2444, \"title\": \"http://dbpedia.org/resource/Maasai_people\", \"score\": 1.0, \"rank\": 7.576672191879865e-29, \"text\": \"Maasai\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Maasai_people\", \"dbpedia\": \"http://dbpedia.org/resource/Maasai_people\"}], \"noun_phrases\": [{\"ngram\": \"the regionalisation\", \"from\": 2415, \"to\": 2434}, {\"ngram\": \"its commercialisation\", \"from\": 2464, \"to\": 2485}, {\"ngram\": \"a longer-running global phenomenon\", \"from\": 2502, \"to\": 2536}]}, {\"sentence\": \"The Maasai blanket, beads, bracelets and earrings have been at the centre of this diffusion.\", \"from\": 2539, \"to\": 2631, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The Maasai blanket\", \"from\": 2539, \"to\": 2557}, {\"ngram\": \"beads\", \"from\": 2559, \"to\": 2564}, {\"ngram\": \"bracelets\", \"from\": 2566, \"to\": 2575}, {\"ngram\": \"earrings\", \"from\": 2580, \"to\": 2588}, {\"ngram\": \"the centre\", \"from\": 2602, \"to\": 2612}, {\"ngram\": \"this diffusion\", \"from\": 2616, \"to\": 2630}]}, {\"sentence\": \"Not too long ago while travelling in the northern Uganda towns of Lira, and further northwest in Arua near the border with the Democratic Republic of Congo, I encountered itinerant hawkers of Masaai wares and art.\", \"from\": 2632, \"to\": 2845, \"entities\": [{\"begin\": 2682, \"end\": 2688, \"title\": \"http://dbpedia.org/resource/Uganda\", \"score\": 1.0, \"rank\": 6.801884402032571e-29, \"text\": \"Uganda\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Uganda\", \"dbpedia\": \"http://dbpedia.org/resource/Uganda\"}, {\"begin\": 2698, \"end\": 2702, \"title\": \"http://dbpedia.org/resource/Lira\", \"score\": 0.9843463327655485, \"rank\": 0.013091775437817225, \"text\": \"Lira\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Lira\", \"dbpedia\": \"http://dbpedia.org/resource/Lira\"}, {\"begin\": 2729, \"end\": 2733, \"title\": \"http://dbpedia.org/resource/Arua\", \"score\": 0.9999999998221938, \"rank\": 1.7790919172954136e-10, \"text\": \"Arua\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Arua\", \"dbpedia\": \"http://dbpedia.org/resource/Arua\"}, {\"begin\": 2824, \"end\": 2830, \"title\": \"http://dbpedia.org/resource/Maasai_people\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Masaai\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Maasai_people\", \"dbpedia\": \"http://dbpedia.org/resource/Maasai_people\"}], \"noun_phrases\": [{\"ngram\": \"the border\", \"from\": 2739, \"to\": 2749}, {\"ngram\": \"the Democratic Republic\", \"from\": 2755, \"to\": 2778}, {\"ngram\": \"Congo\", \"from\": 2782, \"to\": 2787}, {\"ngram\": \"itinerant hawkers\", \"from\": 2803, \"to\": 2820}, {\"ngram\": \"art\", \"from\": 2841, \"to\": 2844}]}, {\"sentence\": \"It was impressive how far they had travelled from home.\", \"from\": 2846, \"to\": 2901, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"home\", \"from\": 2896, \"to\": 2900}]}, {\"sentence\": \"Today many African women - including those in the Diaspora - especially those who consider themselves pan-Africanist and progressive, have to pay homage to Maasai culture to look complete.\", \"from\": 2903, \"to\": 3091, \"entities\": [{\"begin\": 2914, \"end\": 2927, \"title\": \"http://dbpedia.org/resource/Women_in_Africa\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"African women\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Women_in_Africa\", \"dbpedia\": \"http://dbpedia.org/resource/Women_in_Africa\"}, {\"begin\": 2953, \"end\": 2961, \"title\": \"http://dbpedia.org/resource/African_diaspora\", \"score\": 0.9999663076947227, \"rank\": 3.369344030569328e-05, \"text\": \"Diaspora\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/African_diaspora\", \"dbpedia\": \"http://dbpedia.org/resource/African_diaspora\"}, {\"begin\": 3059, \"end\": 3065, \"title\": \"http://dbpedia.org/resource/Maasai_people\", \"score\": 1.0, \"rank\": 7.576672191879865e-29, \"text\": \"Maasai\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Maasai_people\", \"dbpedia\": \"http://dbpedia.org/resource/Maasai_people\"}], \"noun_phrases\": [{\"ngram\": \"especially those\", \"from\": 2964, \"to\": 2980}, {\"ngram\": \"homage\", \"from\": 3049, \"to\": 3055}]}, {\"sentence\": \"Look at their photographs on Instagram, Facebook, and X (Twitter) and there it will be - the photograph with the Maasai headband, or necklace.\", \"from\": 3092, \"to\": 3234, \"entities\": [{\"begin\": 3121, \"end\": 3130, \"title\": \"http://dbpedia.org/resource/Instagram\", \"score\": 1.0, \"rank\": 3.384886859393691e-24, \"text\": \"Instagram\", \"types\": [\"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Instagram\", \"dbpedia\": \"http://dbpedia.org/resource/Instagram\"}], \"noun_phrases\": [{\"ngram\": \"their photographs\", \"from\": 3100, \"to\": 3117}, {\"ngram\": \"Facebook\", \"from\": 3132, \"to\": 3140}, {\"ngram\": \"X (Twitter\", \"from\": 3146, \"to\": 3156}, {\"ngram\": \"the photograph\", \"from\": 3181, \"to\": 3195}, {\"ngram\": \"the Maasai headband\", \"from\": 3201, \"to\": 3220}, {\"ngram\": \"necklace\", \"from\": 3225, \"to\": 3233}]}, {\"sentence\": \"You are a courageous woman receiving an international award for saving a forest, rescuing young girls from human traffickers, or returning wayward boys to society?\", \"from\": 3235, \"to\": 3398, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a courageous woman\", \"from\": 3243, \"to\": 3261}, {\"ngram\": \"an international award\", \"from\": 3272, \"to\": 3294}, {\"ngram\": \"a forest\", \"from\": 3306, \"to\": 3314}, {\"ngram\": \"young girls\", \"from\": 3325, \"to\": 3336}, {\"ngram\": \"human traffickers\", \"from\": 3342, \"to\": 3359}, {\"ngram\": \"wayward boys\", \"from\": 3374, \"to\": 3386}, {\"ngram\": \"society\", \"from\": 3390, \"to\": 3397}]}, {\"sentence\": \"Then you show up in London or New York to receive it in a kitenge dress, and Maasai beads around the neck or forehead, otherwise you are \\\"naked\\\".\", \"from\": 3399, \"to\": 3544, \"entities\": [{\"begin\": 3419, \"end\": 3425, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9999999999558895, \"rank\": 4.371805360768415e-11, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}, {\"begin\": 3429, \"end\": 3437, \"title\": \"http://dbpedia.org/resource/New_York_City\", \"score\": 0.9999999994083737, \"rank\": 5.913182598369929e-10, \"text\": \"New York\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/New_York_City\", \"dbpedia\": \"http://dbpedia.org/resource/New_York_City\"}, {\"begin\": 3476, \"end\": 3482, \"title\": \"http://dbpedia.org/resource/Maasai_people\", \"score\": 1.0, \"rank\": 7.576672191879865e-29, \"text\": \"Maasai\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Maasai_people\", \"dbpedia\": \"http://dbpedia.org/resource/Maasai_people\"