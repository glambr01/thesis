6461344e-05, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"a photograph\", \"from\": 4358, \"to\": 4370}]}, {\"sentence\": \"Many agreed and praised the ceremony for its creativity, style and showmanship.\", \"from\": 4392, \"to\": 4471, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the ceremony\", \"from\": 4416, \"to\": 4428}, {\"ngram\": \"its creativity\", \"from\": 4433, \"to\": 4447}, {\"ngram\": \"style\", \"from\": 4449, \"to\": 4454}, {\"ngram\": \"showmanship\", \"from\": 4459, \"to\": 4470}]}, {\"sentence\": \"But French Catholic bishops and others were among those who said Christians had been offended, though Paris Olympics organizers have said there was \\\"never an intention to show disrespect to any religious group\\\" but rather to \\\"celebrate community tolerance.\\\"\", \"from\": 4473, \"to\": 4730, \"entities\": [{\"begin\": 4477, \"end\": 4483, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9997669803286691, \"rank\": 0.00023184569323200145, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 4484, \"end\": 4492, \"title\": \"http://dbpedia.org/resource/Catholic_Church\", \"score\": 0.9999998932135042, \"rank\": 1.0423837890831911e-07, \"text\": \"Catholic\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Catholic_Church\", \"dbpedia\": \"http://dbpedia.org/resource/Catholic_Church\"}, {\"begin\": 4538, \"end\": 4548, \"title\": \"http://dbpedia.org/resource/Christianity\", \"score\": 0.9966717687142057, \"rank\": 0.003338990157117712, \"text\": \"Christians\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Christianity\", \"dbpedia\": \"http://dbpedia.org/resource/Christianity\"}, {\"begin\": 4575, \"end\": 4589, \"title\": \"http://d