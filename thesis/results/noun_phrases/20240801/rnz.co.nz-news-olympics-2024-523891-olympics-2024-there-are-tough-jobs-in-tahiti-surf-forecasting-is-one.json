 [{\"ngram\": \"two and a half days\", \"from\": 1250, \"to\": 1269}, {\"ngram\": \"unbelievably all-time good\", \"from\": 1295, \"to\": 1321}, {\"ngram\": \"the case\", \"from\": 1325, \"to\": 1333}, {\"ngram\": \"Monday morning\", \"from\": 1337, \"to\": 1351}]}, {\"sentence\": \"\\\"So I would just look whether we get anything more like that the rest of the waiting period - probably not - but we have got a day and a half to finish.\", \"from\": 1354, \"to\": 1506, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"anything\", \"from\": 1391, \"to\": 1399}, {\"ngram\": \"the rest\", \"from\": 1415, \"to\": 1423}, {\"ngram\": \"the waiting period\", \"from\": 1427, \"to\": 1445}, {\"ngram\": \"a day\", \"from\": 1479, \"to\": 1484}, {\"ngram\": \"a half\", \"from\": 1489, \"to\": 1495}]}, {\"sentence\": \"We have got to try and find the best day and a half left in the waiting period.\\\"\", \"from\": 1507, \"to\": 1587, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the best day\", \"from\": 1535, \"to\": 1547}, {\"ngram\": \"a half\", \"from\": 1552, \"to\": 1558}, {\"ngram\": \"the waiting period\", \"from\": 1567, \"to\": 1585}]}, {\"sentence\": \"Portugal's Yolanda Hopkins turns off the lip of a wave at Teahupo'o.Photo:AFP / Ben Thouard Monday's waves were somewhat atypical, with a westerly swell that created thick slabs of water when they hit Teahupo'o's unique reef, providing spectacular viewing and challenging conditions even for the world's best surfers.\", \"from\": 1589, \"to\": 1907, \"entities\": [{\"begin\": 1589, \"end\": 1597, \"title\": \"http://dbpedia.org/resource/Portugal\", \"score\": 0.9163366797526461, \"rank\": 0.07562939795551665, \"text\": \"Portugal\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Portugal\", \"dbpedia\": \"http://dbpedia.org/resource/Portugal\"}, {\"begin\": 1600, \"end\": 1607, \"title\": \"http://dbpedia.org/resource/Typhoon_Haiyan\", \"score\": 1.0, \"rank\": 1.6151663316042436e-14, \"text\": \"