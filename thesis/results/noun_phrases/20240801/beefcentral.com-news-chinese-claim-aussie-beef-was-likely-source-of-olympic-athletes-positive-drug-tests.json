"{\"uid\": \"beefcentral.com-news-chinese-claim-aussie-beef-was-likely-source-of-olympic-athletes-positive-drug-tests\", \"noun_phrases\": [{\"sentence\": \"CHINESE authorities have pointed the finger at Australian imported beef as the potential source of two positive drug tests recorded against Chinese swimmers two years ago - one of which is competing in Paris this week.\", \"from\": 0, \"to\": 218, \"entities\": [{\"begin\": 47, \"end\": 57, \"title\": \"http://dbpedia.org/resource/Australian_Government\", \"score\": 0.9994284916307933, \"rank\": 0.0005701829480013055, \"text\": \"Australian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Australian_Government\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_Government\"}, {\"begin\": 140, \"end\": 147, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.5788909149498058, \"rank\": 0.6007963795315263, \"text\": \"Chinese\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}, {\"begin\": 202, \"end\": 207, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999998444309434, \"rank\": 1.5556922249642393e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"CHINESE authorities\", \"from\": 0, \"to\": 19}, {\"ngram\": \"the finger\", \"from\": 33, \"to\": 43}, {\"ngram\": \"the potential source\", \"from\": 75, \"to\": 95}, {\"ngram\": \"two positive drug tests\", \"from\": 99, \"to\": 122}]}, {\"sentence\": \"While providing zero evidence, Chinese authorities suggested Australian beef consumed at a food service outlet near the swimmers' training facility in Beijing was the likely cause.\", \"from\": 220, \"to\": 400, \"entities\": [{\"begin\": 251, \"end\": 258, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.5788909149498058, \"rank\": 0.600796379531526