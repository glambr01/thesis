 457, \"end\": 470, \"title\": \"http://dbpedia.org/resource/Wilma_Rudolph\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Wilma Rudolph\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Wilma_Rudolph\", \"dbpedia\": \"http://dbpedia.org/resource/Wilma_Rudolph\"}], \"noun_phrases\": [{\"ngram\": \"The book\", \"from\": 295, \"to\": 303}, {\"ngram\": \"about a little girl\", \"from\": 339, \"to\": 358}, {\"ngram\": \"the fastest girl\", \"from\": 412, \"to\": 428}, {\"ngram\": \"her hero\", \"from\": 447, \"to\": 455}, {\"ngram\": \"history\", \"from\": 481, \"to\": 488}, {\"ngram\": \"the first women\", \"from\": 492, \"to\": 507}, {\"ngram\": \"the U.S\", \"from\": 513, \"to\": 520}, {\"ngram\": \"three gold medals\", \"from\": 528, \"to\": 545}, {\"ngram\": \"one Olympics\", \"from\": 549, \"to\": 561}]}, {\"sentence\": \"The girl is trying to attend Wilma's welcome back party after she won her medals with another local girl, and along they way they find they may have more in common then they think Zietlow said the book focusses on perseverance, just like Wilma had when she was told she may never walk again after a childhood polio diagnosis, but also reminds readers of that well-known feeling of being a young kid inspired by an athlete.\", \"from\": 564, \"to\": 987, \"entities\": [{\"begin\": 593, \"end\": 598, \"title\": \"http://dbpedia.org/resource/Wilma_Flintstone\", \"score\": 0.9836573811614422, \"rank\": 0.016614130540998816, \"text\": \"Wilma\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Wilma_Flintstone\", \"dbpedia\": \"http://dbpedia.org/resource/Wilma_Flintstone\"}, {\"begin\": 803, \"end\": 808, \"title\": \"http://dbpedia.org/resource/Wilma_Flintstone\", \"score\": 0.9836573811614422, \"rank\": 0.016614130540998816, \"text\": \"Wilma\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Wilma_Flintstone\", \"dbpedia\": \"http://dbpedia