"{\"uid\": \"nbcsports.com-olympics-news-world-athletics-out-of-stadium-athlete-of-the-year-nominees-2024\", \"noun_phrases\": [{\"sentence\": \"The 10 nominees for World Athletics Out of Stadium Female and Male Athletes of the Year include the first woman to break 2:10 in a marathon and both Olympic marathon record holders.\", \"from\": 0, \"to\": 181, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The 10 nominees\", \"from\": 0, \"to\": 15}, {\"ngram\": \"World Athletics\", \"from\": 20, \"to\": 35}, {\"ngram\": \"Stadium Female\", \"from\": 43, \"to\": 57}, {\"ngram\": \"Male Athletes\", \"from\": 62, \"to\": 75}, {\"ngram\": \"the Year\", \"from\": 79, \"to\": 87}, {\"ngram\": \"the first woman\", \"from\": 96, \"to\": 111}, {\"ngram\": \"a marathon\", \"from\": 129, \"to\": 139}, {\"ngram\": \"both Olympic marathon record holders\", \"from\": 144, \"to\": 180}]}, {\"sentence\": \"The women's award nominees are Kenyans Ruth Chepngetich (who ran a marathon world record 2:09:56 in Chicago on Oct. 13) and Agnes Jebet Ngetich (who broke the road 5km and 10km records); Ethiopians Sutume Kebede (Tokyo Marathon winner) and Tigist Ketema (Berlin and Dubai Marathon winner) and Dutchwoman Sifan Hassan (who ran the fastest women's marathon in Olympic history).\", \"from\": 183, \"to\": 558, \"entities\": [{\"begin\": 283, \"end\": 290, \"title\": \"http://dbpedia.org/resource/Chicago\", \"score\": 0.9995396509820598, \"rank\": 0.0004594433313093863, \"text\": \"Chicago\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Chicago\", \"dbpedia\": \"http://dbpedia.org/resource/Chicago\"}, {\"begin\": 438, \"end\": 444, \"title\": \"http://dbpedia.org/resource/Berlin\", \"score\": 0.9960780881727029, \"rank\": 0.0031757647607217037, \"text\": \"Berlin\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Berlin\", \"dbpedia\": \"http://dbpedia.org/resource/Berlin\"}, {\"begin\": 449, \"end\": 463, \"title\": \"http://dbp