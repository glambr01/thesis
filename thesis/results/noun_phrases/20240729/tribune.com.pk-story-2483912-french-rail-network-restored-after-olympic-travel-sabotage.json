"{\"uid\": \"tribune.com.pk-story-2483912-french-rail-network-restored-after-olympic-travel-sabotage\", \"noun_phrases\": [{\"sentence\": \"US France's high-speed train network resumed normal operations after coordinated arson attacks disrupted travel.\", \"from\": 0, \"to\": 113, \"entities\": [{\"begin\": 4, \"end\": 10, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9972717928795787, \"rank\": 0.0015611061665479755, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"normal operations\", \"from\": 45, \"to\": 62}, {\"ngram\": \"coordinated arson attacks\", \"from\": 69, \"to\": 94}, {\"ngram\": \"travel\", \"from\": 105, \"to\": 111}]}, {\"sentence\": \"France's high-speed train network resumed normal operations on Monday, three days after sabotage acts significantly disrupted travel ahead of the Olympics opening ceremony, according to the transport minister, the press reports said on Monday.\", \"from\": 115, \"to\": 358, \"entities\": [{\"begin\": 115, \"end\": 121, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9972717928795787, \"rank\": 0.0015611061665479755, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"normal operations\", \"from\": 157, \"to\": 174}, {\"ngram\": \"Monday\", \"from\": 178, \"to\": 184}, {\"ngram\": \"sabotage\", \"from\": 203, \"to\": 211}, {\"ngram\": \"travel\", \"from\": 241, \"to\": 247}, {\"ngram\": \"the Olympics opening ceremony\", \"from\": 257, \"to\": 286}, {\"ngram\": \"the transport minister\", \"from\": 301, \"to\": 323}, {\"ngram\": \"the press reports\", \"from\": 325, \"to\": 342}, {\"ngram\": \"Monday\", \"from\": 351, \"to\": 357}]}, {\"sentence\": \"Patrice Vergriete confirmed that the coordinated arson attacks on Friday morning targeted key points of the rail infrastructure, according to local media outlets.\", \"from\": 360, \"to\": 522, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Patrice Vergriete\", \"from\": 360, \"to\": 377}, {\"ngram\": \"the coordinated arson attacks\", \"from\": 393, \"to\": 422}, {\"ngram\": \"Friday morning\", \"from\": 426, \"to\": 440}, {\"ngram\": \"key points\", \"from\": 450, \"to\": 460}, {\"ngram\": \"the rail infrastructure\", \"from\": 464, \"to\": 487}, {\"ngram\": \"local media outlets\", \"from\": 502, \"to\": 521}]}, {\"sentence\": \"The incidents raised concerns as they occurred just before the grand opening.\", \"from\": 524, \"to\": 601, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The incidents\", \"from\": 524, \"to\": 537}, {\"ngram\": \"concerns\", \"from\": 545, \"to\": 553}, {\"ngram\": \"the grand opening\", \"from\": 583, \"to\": 600}]}, {\"sentence\": \"However, authorities have yet to determine the perpetrators or whether the timing was intended to disrupt the event.\", \"from\": 603, \"to\": 719, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"authorities\", \"from\": 612, \"to\": 623}, {\"ngram\": \"the perpetrators\", \"from\": 646, \"to\": 662}, {\"ngram\": \"the timing\", \"from\": 674, \"to\": 684}, {\"ngram\": \"the event\", \"from\": 709, \"to\": 718}]}, {\"sentence\": \"Metro disruptions in Paris In Paris, where the number of tourists is expected to reach 16 million during the Olympic Games, there were also disruptions to metro services.\", \"from\": 721, \"to\": 892, \"entities\": [{\"begin\": 742, \"end\": 747, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999086328486, \"rank\": 9.136724755954422e-08, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 752, \"end\": 757, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999086328486, \"rank\": 9.1367247559