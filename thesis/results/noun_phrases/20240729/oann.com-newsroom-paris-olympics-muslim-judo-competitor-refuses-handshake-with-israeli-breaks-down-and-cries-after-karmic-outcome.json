to\": 195}]}, {\"sentence\": \"However, this resulted in instant karma, as the Muslim competitor was defeated soon after and left in tears during the next match.\", \"from\": 198, \"to\": 328, \"entities\": [{\"begin\": 246, \"end\": 252, \"title\": \"http://dbpedia.org/resource/Islam\", \"score\": 0.8045924541630117, \"rank\": 0.24286074220487042, \"text\": \"Muslim\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Islam\", \"dbpedia\": \"http://dbpedia.org/resource/Islam\"}], \"noun_phrases\": [{\"ngram\": \"instant karma\", \"from\": 224, \"to\": 237}, {\"ngram\": \"tears\", \"from\": 300, \"to\": 305}, {\"ngram\": \"the next match\", \"from\": 313, \"to\": 327}]}, {\"sentence\": \"Additionally, in the men's under-145-pound weight class, the same Israeli judoka, Baruch Shmailov, defeated Abderrahmane Boushita of Morocco in his debut fight, and Boushita refused to shake hands with him as well.\", \"from\": 330, \"to\": 544, \"entities\": [{\"begin\": 396, \"end\": 403, \"title\": \"http://dbpedia.org/resource/Israel\", \"score\": 0.6861965905191971, \"rank\": 0.41201163496491494, \"text\": \"Israeli\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Israel\", \"dbpedia\": \"http://dbpedia.org/resource/Israel\"}, {\"begin\": 412, \"end\": 418, \"title\": \"http://dbpedia.org/resource/Book_of_Baruch\", \"score\": 0.9238096633309559, \"rank\": 0.06776079509625778, \"text\": \"Baruch\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Book_of_Baruch\", \"dbpedia\": \"http://dbpedia.org/resource/Book_of_Baruch\"}, {\"begin\": 463, \"end\": 470, \"title\": \"http://dbpedia.org/resource/Morocco_national_football_team\", \"score\": 0.9374361590364853, \"rank\": 0.0667289151361806, \"text\": \"Morocco\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Morocco_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Morocco_national_football_team\"}], \"noun_phrases\": [{\"ngram\": \"