, \"noun_phrases\": [{\"ngram\": \"my faith\", \"from\": 6382, \"to\": 6390}, {\"ngram\": \"someone\", \"from\": 6438, \"to\": 6445}]}, {\"sentence\": \"Forever and always.\", \"from\": 6488, \"to\": 6507, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"And will always be there.\", \"from\": 6508, \"to\": 6533, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I want them to have that promise and that security.\", \"from\": 6534, \"to\": 6585, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"that promise\", \"from\": 6554, \"to\": 6566}, {\"ngram\": \"that security\", \"from\": 6571, \"to\": 6584}]}, {\"sentence\": \"So, I started making changes.\", \"from\": 6587, \"to\": 6616, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"changes\", \"from\": 6608, \"to\": 6615}]}, {\"sentence\": \"We started going to@parkridgechurchfl.\", \"from\": 6617, \"to\": 6655, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"to@parkridgechurchfl\", \"from\": 6634, \"to\": 6654}]}, {\"sentence\": \"We started saying grace with every meal.\", \"from\": 6656, \"to\": 6696, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"grace\", \"from\": 6674, \"to\": 6679}, {\"ngram\": \"every meal\", \"from\": 6685, \"to\": 6695}]}, {\"sentence\": \"I started watching my words and my actions.\", \"from\": 6697, \"to\": 6740, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my words\", \"from\": 6716, \"to\": 6724}, {\"ngram\": \"my actions\", \"from\": 6729, \"to\": 6739}]}, {\"sentence\": \"We started having a prayer list and a gratitude list.\", \"from\": 6741, \"to\": 6794, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a prayer list\", \"from\": 6759, \"to\": 6772}, {\"ngram\": \"a gratitude list\", \"from\": 6777, \"to\": 6793}]}, {\"sentence\": \"And I started watching God bless our lives and touch their hearts.\", \"from\": 6795, \"to\": 6861, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"God\", \"from\": 6818, \"to\": 6821}, {\"ngram\": \"our lives\", \"fro