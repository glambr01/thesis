435, \"entities\": [{\"begin\": 5217, \"end\": 5222, \"title\": \"http://dbpedia.org/resource/Kayla_Brady\", \"score\": 1.0, \"rank\": 1.5383012633043245e-37, \"text\": \"Kayla\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Kayla_Brady\", \"dbpedia\": \"http://dbpedia.org/resource/Kayla_Brady\"}], \"noun_phrases\": [{\"ngram\": \"her \\\"Fearless Foundation\", \"from\": 5253, \"to\": 5277}, {\"ngram\": \"her book\", \"from\": 5283, \"to\": 5291}, {\"ngram\": \"an Olympic Champion's Story\", \"from\": 5314, \"to\": 5341}, {\"ngram\": \"Us\", \"from\": 5352, \"to\": 5354}, {\"ngram\": \"Child Sexual Abuse\", \"from\": 5388, \"to\": 5406}, {\"ngram\": \"Helping Kids\", \"from\": 5413, \"to\": 5425}, {\"ngram\": \"Recover\", \"from\": 5426, \"to\": 5433}]}, {\"sentence\": \"6) Persevere and never give up!\", \"from\": 5437, \"to\": 5468, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"6) Persevere\", \"from\": 5437, \"to\": 5449}]}, {\"sentence\": \"Kayla's message to others is this: \\\"Never give up on your dreams.\", \"from\": 5470, \"to\": 5535, \"entities\": [{\"begin\": 5470, \"end\": 5475, \"title\": \"http://dbpedia.org/resource/Kayla_Brady\", \"score\": 1.0, \"rank\": 1.5383012633043245e-37, \"text\": \"Kayla\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Kayla_Brady\", \"dbpedia\": \"http://dbpedia.org/resource/Kayla_Brady\"}], \"noun_phrases\": [{\"ngram\": \"others\", \"from\": 5489, \"to\": 5495}, {\"ngram\": \"your dreams\", \"from\": 5523, \"to\": 5534}]}, {\"sentence\": \"I mean, if I can do it, anybody can do it.\", \"from\": 5536, \"to\": 5578, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"anybody\", \"from\": 5560, \"to\": 5567}]}, {\"sentence\": \"Things have happened, but now, my life is a dream.\", \"from\": 5579, \"to\": 5629, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Things\", \"from\": 5579, \"to\": 5585}, {\"ngram\": \"my life\", \"from\": 5610, \"to\": 5