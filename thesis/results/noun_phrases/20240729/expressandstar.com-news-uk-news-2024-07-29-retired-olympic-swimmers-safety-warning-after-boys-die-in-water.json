: [], \"noun_phrases\": [{\"ngram\": \"Perdiswell Leisure Centre\", \"from\": 1226, \"to\": 1251}, {\"ngram\": \"Monday\", \"from\": 1255, \"to\": 1261}, {\"ngram\": \"sad cases\", \"from\": 1291, \"to\": 1300}]}, {\"sentence\": \"\\\"There is quite a few statistics around this where about half of drownings happen in June, July and August when the weather gets warm.\", \"from\": 1303, \"to\": 1437, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"quite a few statistics\", \"from\": 1313, \"to\": 1335}, {\"ngram\": \"about half\", \"from\": 1354, \"to\": 1364}, {\"ngram\": \"drownings\", \"from\": 1368, \"to\": 1377}, {\"ngram\": \"June\", \"from\": 1388, \"to\": 1392}, {\"ngram\": \"July\", \"from\": 1394, \"to\": 1398}, {\"ngram\": \"August\", \"from\": 1403, \"to\": 1409}, {\"ngram\": \"the weather\", \"from\": 1415, \"to\": 1426}]}, {\"sentence\": \"Cold water shock is a serious issue.\", \"from\": 1438, \"to\": 1474, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Cold water shock\", \"from\": 1438, \"to\": 1454}, {\"ngram\": \"a serious issue\", \"from\": 1458, \"to\": 1473}]}, {\"sentence\": \"\\\"We always advise the people please please, please, do not ever jump into water.\", \"from\": 1476, \"to\": 1556, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the people\", \"from\": 1494, \"to\": 1504}, {\"ngram\": \"water\", \"from\": 1550, \"to\": 1555}]}, {\"sentence\": \"Only swim where it's lifeguarded, only somewhere it's safe.\", \"from\": 1557, \"to\": 1616, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"\\\"There is a reason these places are not lifeguard and if there is no one there, we just do not want to see cases like this, but sadly they still happen far too often.\\\"\", \"from\": 1618, \"to\": 1785, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a reason\", \"from\": 1628, \"to\": 1636}, {\"ngram\": \"these places\", \"from\": 1637, \"to\": 1649}, {\"ngram\": \"no one\", \"from\": 1684, \"to\": 1690}, {\"ngram\": \"cases\", \"from\": 1725, \"to\": 1730}]}, {\"sentence\": \"Alice, 27, said the BSA was created to promote the welfare and inclusion of Black and Asian people in swimming.\", \"from\": 1787, \"to\": 1898, \"entities\": [{\"begin\": 1787, \"end\": 1792, \"title\": \"http://dbpedia.org/resource/Alice_and_Bob\", \"score\": 0.9994732711894496, \"rank\": 0.0005270064000707739, \"text\": \"Alice\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Alice_and_Bob\", \"dbpedia\": \"http://dbpedia.org/resource/Alice_and_Bob\"}, {\"begin\": 1807, \"end\": 1810, \"title\": \"http://dbpedia.org/resource/Boy_Scouts_of_America\", \"score\": 0.9999433853216996, \"rank\": 5.661788289064429e-05, \"text\": \"BSA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Boy_Scouts_of_America\", \"dbpedia\": \"http://dbpedia.org/resource/Boy_Scouts_of_America\"}, {\"begin\": 1863, \"end\": 1868, \"title\": \"http://dbpedia.org/resource/Black_people\", \"score\": 0.8845801224272419, \"rank\": 0.13019425435179807, \"text\": \"Black\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Black_people\", \"dbpedia\": \"http://dbpedia.org/resource/Black_people\"}, {\"begin\": 1873, \"end\": 1885, \"title\": \"http://dbpedia.org/resource/Asian_people\", \"score\": 0.9999991274682257, \"rank\": 8.725326455757901e-07, \"text\": \"Asian people\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Asian_people\", \"dbpedia\": \"http://dbpedia.org/resource/Asian_people\"}], \"noun_phrases\": [{\"ngram\": \"the welfare\", \"from\": 1834, \"to\": 1845}, {\"ngram\": \"inclusion\", \"from\": 1850, \"to\": 1859}, {\"ngram\": \"swimming\", \"from\": 1889, \"to\": 1897}]}, {\"sentence\": \"She said: \\\"We are mainly looking at water safety, making sure that our communities are safe in and around water and getting that valuable knowledge and experience out to our communities that have been left behind a little bit.\", \"from\": 1900, \"to\": 2126, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"water safety\", \"from\": 1936, \"to\": 1948}, {\"ngram\": \"our communities\", \"from\": 1967, \"to\": 1982}, {\"ngram\": \"water\", \"from\": 2006, \"to\": 2011}, {\"ngram\": \"that valuable knowledge\", \"from\": 2024, \"to\": 2047}, {\"ngram\": \"our communities\", \"from\": 2070, \"to\": 2085}]}, {\"sentence\": \"\\\"Basically, we do not want anyone to drown, so this is looking to help every single person that we come across, but we are specifically equipped to help Black and Asian communities.\\\"\", \"from\": 2128, \"to\": 2310, \"entities\": [{\"begin\": 2291, \"end\": 2296, \"title\": \"http://dbpedia.org/resource/British_Asian\", \"score\": 0.9573117474439113, \"rank\": 0.04214140845541692, \"text\": \"Asian\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/British_Asian\", \"dbpedia\": \"http://dbpedia.org/resource/British_Asian\"}], \"noun_phrases\": [{\"ngram\": \"anyone\", \"from\": 2155, \"to\": 2161}, {\"ngram\": \"every single person\", \"from\": 2199, \"to\": 2218}]}, {\"sentence\": \"Speaking last week, Matt Croxall, charity director of the Royal Life Saving Society UK, said: \\\"We tend to see an increase in drownings as the weather gets warmer and in light of the two recent tragic drownings we have seen, it's more important than ever that everybody has the tools to enjoy water safely this summer and beyond.\", \"from\": 2312, \"to\": 2640, \"entities\": [{\"begin\": 2337, \"end\": 2344, \"title\": \"http://dbpedia.org/resource/Croxall\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Croxall\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Croxall\", \"dbpedia\": \"http://dbpedia.org/resource/Croxall\"}], \"noun_phrases\": [{\"ngram\": \"charity director\", \"from\": 2346, \"to\": 2362}, {\"ngram\": \"Saving Society\", \"from\": 2381, \"to\": 2395}, {\"ngram\": \"an increase\", \"from\": 2422, \"to\": 2433}, {\"ngram\": \"drownings\", \"from\": 2437, \"to\": 2446}, {\"ngram\": \"the weather\", \"from\": 2450, \"to\": 2461}, {\"ngram\": \"light\", \"from\": 2481, \"to\": 2486}, {\"ngram\": \"the two recent tragic drownings\", \"from\": 2490, \"to\": 2521}, {\"ngram\": \"everybody\", \"from\": 2571, \"to\": 2580}, {\"ngram\": \"the tools\", \"from\": 2585, \"to\": 2594}, {\"ngram\": \"water\", \"from\": 2604, \"to\": 2609}]}, {\"sentence\": \"\\\"More than half of accidental drownings have occurred at inland open water sites - and many of these drownings occur due to a lack of knowledge and understanding of open water safety.\", \"from\": 2642, \"to\": 2825, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"More than half\", \"from\": 2643, \"to\": 2657}, {\"ngram\": \"accidental drownings\", \"from\": 2661, \"to\": 2681}, {\"ngram\": \"inland open water sites\", \"from\": 2699, \"to\": 2722}, {\"ngram\": \"these drownings\", \"from\": 2737, \"to\": 2752}, {\"ngram\": \"a lack\", \"from\": 2766, \"to\": 2772}, {\"ngram\": \"knowledge\", \"from\": 2776, \"to\": 2785}, {\"ngram\": \"understanding\", \"from\": 2790, \"to\": 2803}, {\"ngram\": \"open water safety\", \"from\": 2807, \"to\": 2824}]}, {\"sentence\": \"\\\"By taking simple steps and following the Water Safety Code and making people aware of what they need to take into account before they get in, and when they are in the water will save lives - knowing the risks associated and your limits could make all the difference.\\\"\", \"from\": 2827, \"to\": 3095, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"simple steps\", \"from\": 2838, \"to\": 2850}, {\"ngram\": \"the Water Safety Code\", \"from\": 2865, \"to\": 2886}, {\"ngram\": \"people\", \"from\": 2898, \"to\": 2904}, {\"ngram\": \"account\", \"from\": 2942, \"to\": 2949}, {\"ngram\": \"the water\", \"from\": 2991, \"to\": 3000}, {\"ngram\": \"lives\", \"from\": 3011, \"to\": 3016}, {\"ngram\": \"the risks\", \"from\": 3027, \"to\": 3036}, {\"ngram\": \"your limits\", \"from\": 3052, \"to\": 3063}, {\"ngram\": \"all the difference\", \"from\": 3075, \"to\": 30