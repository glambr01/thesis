ence\": \"\\\"I wanted to be here and compete at the Olympics because, well just because how much I enjoy it, how much I love it.\", \"from\": 3800, \"to\": 3916, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the Olympics\", \"from\": 3836, \"to\": 3848}]}, {\"sentence\": \"\\\"I think it's an amazing, amazing event for many more reasons than just the tennis.\\\"\", \"from\": 3918, \"to\": 4002, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an amazing, amazing event\", \"from\": 3932, \"to\": 3957}, {\"ngram\": \"many more reasons\", \"from\": 3962, \"to\": 3979}, {\"ngram\": \"just the tennis\", \"from\": 3985, \"to\": 4000}]}, {\"sentence\": \"As a sport for which the Games is not the pinnacle, how and whether tennis ought to wear the Olympic rings remains the subject of debate for some.\", \"from\": 4004, \"to\": 4150, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a sport\", \"from\": 4007, \"to\": 4014}, {\"ngram\": \"the Games\", \"from\": 4025, \"to\": 4034}, {\"ngram\": \"the pinnacle\", \"from\": 4042, \"to\": 4054}, {\"ngram\": \"whether tennis\", \"from\": 4064, \"to\": 4078}, {\"ngram\": \"the Olympic rings\", \"from\": 4093, \"to\": 4110}, {\"ngram\": \"the subject\", \"from\": 4119, \"to\": 4130}, {\"ngram\": \"debate\", \"from\": 4134, \"to\": 4140}]}, {\"sentence\": \"Really, though, it is on the participants to define importance and no tennis player has worn them with more pride than Murray.\", \"from\": 4151, \"to\": 4277, \"entities\": [{\"begin\": 4270, \"end\": 4276, \"title\": \"http://dbpedia.org/resource/Andy_Murray\", \"score\": 1.0, \"rank\": 1.0181530905567686e-37, \"text\": \"Murray\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Andy_Murray\", \"dbpedia\": \"http://dbpedia.org/resource/Andy_Murray\"}], \"noun_phrases\": [{\"ngram\": \"the participants\", \"from\": 4176, \"to\": 4192}, {\"ngram\": \"importance\", \"from\": 4203, \"to\": 4213}, {\"ngram\": \"n