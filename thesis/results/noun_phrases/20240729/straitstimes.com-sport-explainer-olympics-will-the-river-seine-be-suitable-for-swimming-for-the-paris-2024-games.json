\": [\"Q729\", \"Q5\", \"Q4964182\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Walter_Benjamin\", \"dbpedia\": \"http://dbpedia.org/resource/Walter_Benjamin\"}, {\"begin\": 2107, \"end\": 2122, \"title\": \"http://dbpedia.org/resource/H\\u00f4tel_de_Ville,_Paris\", \"score\": 0.9999999991164259, \"rank\": 0.0, \"text\": \"Paris city hall\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/H\\u00f4tel_de_Ville,_Paris\", \"dbpedia\": \"http://dbpedia.org/resource/H\\u00f4tel_de_Ville,_Paris\"}], \"noun_phrases\": [{\"ngram\": \"director\", \"from\": 2074, \"to\": 2082}, {\"ngram\": \"water quality\", \"from\": 2086, \"to\": 2099}, {\"ngram\": \"four main factors\", \"from\": 2124, \"to\": 2141}, {\"ngram\": \"an impact\", \"from\": 2147, \"to\": 2156}, {\"ngram\": \"water pollution\", \"from\": 2160, \"to\": 2175}]}, {\"sentence\": \"- Rainfall.\", \"from\": 2178, \"to\": 2189, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"- Rainfall\", \"from\": 2178, \"to\": 2188}]}, {\"sentence\": \"More rain more pollution runoff.\", \"from\": 2190, \"to\": 2222, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"More rain more pollution runoff\", \"from\": 2190, \"to\": 2221}]}, {\"sentence\": \"- UV index.\", \"from\": 2224, \"to\": 2235, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"- UV index\", \"from\": 2224, \"to\": 2234}]}, {\"sentence\": \"\\\"The higher the UV index, the faster the bacteria die,\\\" Raigneau said.\", \"from\": 2236, \"to\": 2306, \"entities\": [{\"begin\": 2252, \"end\": 2254, \"title\": \"http://dbpedia.org/resource/Ultraviolet\", \"score\": 0.9999995376225502, \"rank\": 4.6020816038992353e-07, \"text\": \"UV\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ultraviolet\", \"dbpedia\": \"http://dbpedia.org/resource/Ultraviolet\"}], \"noun_phrases\": [{\"ngram\": \"the bacteria\", \"from\": 2273, \"to\": 2285}, {\"ngram\": \"Raigneau\", \"from\": 2292, \"to\": 2300}]}, {\"sentence\": \"- Temper