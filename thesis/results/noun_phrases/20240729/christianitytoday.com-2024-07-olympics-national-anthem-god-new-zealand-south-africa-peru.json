: 8823, \"to\": 8942, \"entities\": [{\"begin\": 8864, \"end\": 8887, \"title\": \"http://dbpedia.org/resource/Languages_of_South_Africa\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"South African languages\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Languages_of_South_Africa\", \"dbpedia\": \"http://dbpedia.org/resource/Languages_of_South_Africa\"}], \"noun_phrases\": [{\"ngram\": \"The anthem\", \"from\": 8823, \"to\": 8833}, {\"ngram\": \"a call\", \"from\": 8899, \"to\": 8905}, {\"ngram\": \"unity\", \"from\": 8909, \"to\": 8914}, {\"ngram\": \"the end\", \"from\": 8921, \"to\": 8928}, {\"ngram\": \"apartheid\", \"from\": 8932, \"to\": 8941}]}, {\"sentence\": \"Enoch Mankayi Sontonga, a Xhosa teacher and choirmater at a Methodist mission school, composed \\\"Nkosi Sikelel' iAfrika\\\" in 1897 as a school anthem.\", \"from\": 8944, \"to\": 9091, \"entities\": [{\"begin\": 8944, \"end\": 8949, \"title\": \"http://dbpedia.org/resource/Enoch\", \"score\": 0.9940260874194764, \"rank\": 0.006009814687913165, \"text\": \"Enoch\", \"types\": [\"Q729\", \"Q5\", \"Q43115\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Enoch\", \"dbpedia\": \"http://dbpedia.org/resource/Enoch\"}, {\"begin\": 8970, \"end\": 8975, \"title\": \"http://dbpedia.org/resource/Xhosa_language\", \"score\": 1.0, \"rank\": 2.549518903672262e-15, \"text\": \"Xhosa\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Xhosa_language\", \"dbpedia\": \"http://dbpedia.org/resource/Xhosa_language\"}, {\"begin\": 9004, \"end\": 9013, \"title\": \"http://dbpedia.org/resource/Methodism\", \"score\": 1.0, \"rank\": 3.512352496343749e-17, \"text\": \"Methodist\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Methodism\", \"dbpedia\": \"http://dbpedia.org/resource/Methodism\"}, {\"begin\": 9040, \"end\": 9062, \"title\": \"http://dbpedia.org/resource/Nkosi_Sikelel'_iAfrika\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Nkosi Sikelel' iAfrika\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Nkosi_Sikelel'_iAfrika\", \"dbpedia\": \"http://dbpedia.org/resource/Nkosi_Sikelel'_iAfrika\"}], \"noun_phrases\": [{\"ngram\": \"choirmater\", \"from\": 8988, \"to\": 8998}, {\"ngram\": \"a school anthem\", \"from\": 9075, \"to\": 9090}]}, {\"sentence\": \"The song, whichreflectsboth Methodist hymnody and African praise singing, was first performed publicly in 1899 at the ordination of John Hlengani Mboweni, the first Tsonga Methodist pastor.\", \"from\": 9092, \"to\": 9281, \"entities\": [{\"begin\": 9120, \"end\": 9129, \"title\": \"http://dbpedia.org/resource/Methodism\", \"score\": 1.0, \"rank\": 3.512352496343749e-17, \"text\": \"Methodist\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Methodism\", \"dbpedia\": \"http://dbpedia.org/resource/Methodism\"}, {\"begin\": 9264, \"end\": 9273, \"title\": \"http://dbpedia.org/resource/Methodism\", \"score\": 1.0, \"rank\": 3.512352496343749e-17, \"text\": \"Methodist\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Methodism\", \"dbpedia\": \"http://dbpedia.org/resource/Methodism\"}], \"noun_phrases\": [{\"ngram\": \"The song\", \"from\": 9092, \"to\": 9100}, {\"ngram\": \"African praise singing\", \"from\": 9142, \"to\": 9164}, {\"ngram\": \"the ordination\", \"from\": 9206, \"to\": 9220}, {\"ngram\": \"John Hlengani Mboweni\", \"from\": 9224, \"to\": 9245}]}, {\"sentence\": \"The song gained popularity as it was sung to close the 1912 meeting of the South African Native National Congress (now the African National Congress), the liberation movement seeking to advance the rights of black South Africans.\", \"from\": 9283, \"to\": 9512, \"entities\": [{\"begin\": 9358, \"end\": 9396, \"title\": \"http://dbpedia.org/resource/African_National_Congress\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"South African Native National Congress\", \"types\": [\"Q7278\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/African_National_Congress\", \"dbpedia\": \"http://dbpedia.org/resource/African_National_Congress\"}, {\"begin\": 9406, \"end\": 9431, \"title\": \"http://dbpedia.org/resource/African_National_Congress\", \"score\": 1.0, \"rank\": 6.220141748252796e-39, \"text\": \"African National Congress\", \"types\": [\"Q7278\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/African_National_Congress\", \"dbpedia\": \"http://dbpedia.org/resource/African_National_Congress\"}], \"noun_phrases\": [{\"ngram\": \"The song\", \"from\": 9283, \"to\": 9291}, {\"ngram\": \"popularity\", \"from\": 9299, \"to\": 9309}, {\"ngram\": \"the 1912 meeting\", \"from\": 9334, \"to\": 9350}, {\"ngram\": \"the liberation movement\", \"from\": 9434, \"to\": 9457}, {\"ngram\": \"the rights\", \"from\": 9477, \"to\": 9487}, {\"ngram\": \"black South Africans\", \"from\": 9491, \"to\": 9511}]}, {\"sentence\": \"The congress adopted the song as its official anthem in 1925, causing it to be banned during apartheid.\", \"from\": 9513, \"to\": 9616, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The congress\", \"from\": 9513, \"to\": 9525}, {\"ngram\": \"the song\", \"from\": 9534, \"to\": 9542}, {\"ngram\": \"its official anthem\", \"from\": 9546, \"to\": 9565}, {\"ngram\": \"apartheid\", \"from\": 9606, \"to\": 9615}]}, {\"sentence\": \"Meanwhile, poet C. J. Langenhoven wrote \\\"Die Stem van Suid-Afrika\\\" in 1918, and three years later, Dutch Reformed pastor Marthinus Lourens de Villiers composed its melody.\", \"from\": 9618, \"to\": 9789, \"entities\": [{\"begin\": 9640, \"end\": 9651, \"title\": \"http://dbpedia.org/resource/Cornelis_Jacobus_Langenhoven\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Langenhoven\", \"types\": [\"Q729\", \"Q5\", \"Q36180\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Cornelis_Jacobus_Langenhoven\", \"dbpedia\": \"http://dbpedia.org/resource/Cornelis_Jacobus_Langenhoven\"}, {\"begin\": 9717, \"end\": 9731, \"title\": \"http://dbpedia.org/resource/Dutch_Reformed_Church\", \"score\": 1.0, \"rank\": 1.3358528546527104e-18, \"text\": \"Dutch Reformed\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Dutch_Reformed_Church\", \"dbpedia\": \"http://dbpedia.org/resource/Dutch_Reformed_Church\"}, {\"begin\": 9757, \"end\": 9768, \"title\": \"http://dbpedia.org/resource/De_Villiers_Graaff\", \"score\": 0.9999999773535821, \"rank\": 2.2646220435450262e-08, \"text\": \"de Villiers\", \"types\": [\"Q729\", \"Q5\", \"Q36180\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/De_Villiers_Graaff\", \"dbpedia\": \"http://dbpedia.org/resource/De_Villiers_Graaff\"}], \"noun_phrases\": [{\"ngram\": \"\\\"Die Stem van Suid-Afrika\", \"from\": 9658, \"to\": 9683}, {\"ngram\": \"its melody\", \"from\": 9778, \"to\": 9788}]}, {\"sentence\": \"It became the national anthem in 1938, alongside \\\"God Save the King.\\\"\", \"from\": 9790, \"to\": 9859, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the national anthem\", \"from\": 9800, \"to\": 9819}, {\"ngram\": \"God\", \"from\": 9840, \"to\": 9843}, {\"ngram\": \"the King\", \"from\": 9849, \"to\": 9857}]}, {\"sentence\": \"In 1994, before Nelson Mandela's inauguration as president, State President F. W. de Klerk declared that both songs would be the country's national anthems.\", \"from\": 9861, \"to\": 10017, \"entities\": [{\"begin\": 9877, \"end\": 9891, \"title\": \"http://dbpedia.org/resource/Nelson_Mandela\", \"score\": 1.0, \"rank\": 9.371265316470025e-58, \"text\": \"Nelson Mandela\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Nelson_Mandela\", \"dbpedia\": \"http://dbpedia.org/resource/Nelson_Mandela\"}, {\"begin\": 9937, \"end\": 9939, \"title\": \"http://dbpedia.org/resource/Federal_Reporter\", \"score\": 1.0, \"rank\": 1.4423429167014447e-34, \"text\": \"F.\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Federal_Reporter\", \"dbpedia\": \"http://dbpedia.org/resource/Federal_Reporter\"}, {\"begin\": 9943, \"end\": 9951, \"title\": \"http://dbpedia.org/resource/F._W._de_Klerk\", \"score\": 1.0, \"rank\": 1.2924969003693202e-56, \"text\": \"de Klerk\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/F._W._de_Klerk\", \"dbpedia\": \"http://dbpedia.org/resource/F._W._de_Klerk\"}], \"noun_phrases\": [{\"ngram\": \"president\", \"from\": 9910, \"to\": 9919}, {\"ngram\": \"both songs\", \"from\": 9966, \"to\": 9976}, {\"ngram\": \"the country's national anthems\", \"from\": 9986, \"to\": 10016}]}, {\"sentence\": \"Three years into his administration, Mandela declared a new official national anthem that combined shortened versions of both songs.\", \"from\": 10018, \"to\": 10150, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"his administration\", \"from\": 10035, \"to\": 10053}, {\"ngram\": \"Mandela\", \"from\": 10055, \"to\": 10062}, {\"ngram\": \"a new official national anthem\", \"from\": 10072, \"to\": 10102}, {\"ngram\": \"both songs\", \"from\": 10139, \"to\": 10149}]}, {\"sentence\": \"\\\"The declaration of trust [in God] is the first and most important component of the South African National Anthem,\\\"wroteMorakeng E. K. Lebaka, an African musical arts researcher at the University of South Africa.\", \"from\": 10152, \"to\": 10364, \"entities\": [{\"begin\": 10250, \"end\": 10265, \"title\": \"http://dbpedia.org/resource/National_anthem\", \"score\": 1.0, \"rank\": 3.22125846653949e-24, \"text\": \"National Anthem\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/National_anthem\", \"dbpedia\": \"http://dbpedia.org/resource/National_anthem\"}, {\"begin\": 10284, \"end\": 10286, \"title\": \"http://dbpedia.org/resource/Ralph_Kirkpatrick\", \"score\": 0.9999998758876322, \"rank\": 1.24112311162551e-07, \"text\": \"K.\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Ralph_Kirkpatrick\", \"dbpedia\":