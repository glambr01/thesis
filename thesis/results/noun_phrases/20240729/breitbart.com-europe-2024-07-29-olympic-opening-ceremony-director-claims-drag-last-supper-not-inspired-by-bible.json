: 2222, \"title\": \"http://dbpedia.org/resource/Kingdom_of_France\", \"score\": 0.5402339711336795, \"rank\": 0.48454753390444105, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Kingdom_of_France\", \"dbpedia\": \"http://dbpedia.org/resource/Kingdom_of_France\"}], \"noun_phrases\": [{\"ngram\": \"Backlash\", \"from\": 2189, \"to\": 2197}, {\"ngram\": \"former Culture Secretary Philippe de Villiersdeclaring\", \"from\": 2229, \"to\": 2283}, {\"ngram\": \"the suicide\", \"from\": 2304, \"to\": 2315}, {\"ngram\": \"our country\", \"from\": 2319, \"to\": 2330}, {\"ngram\": \"front\", \"from\": 2334, \"to\": 2339}, {\"ngram\": \"the whole world\", \"from\": 2343, \"to\": 2358}]}, {\"sentence\": \"Right-wing populist Member of the European Parliament, Marion Mar\\u00e9chal,said: \\\"To all the Christians of the world who are watching the Paris 2024 ceremony and felt insulted by this drag queen parody of the Last Supper, know that it is not France that is speaking but a left-wing minority ready for any provocation.\", \"from\": 2362, \"to\": 2675, \"entities\": [{\"begin\": 2396, \"end\": 2415, \"title\": \"http://dbpedia.org/resource/European_Parliament\", \"score\": 0.9999877325424075, \"rank\": 8.08421013530451e-06, \"text\": \"European Parliament\", \"types\": [\"Q43229\", \"Q24229398\", \"Q11204\"], \"wikid\": \"http://dbpedia.org/resource/European_Parliament\", \"dbpedia\": \"http://dbpedia.org/resource/European_Parliament\"}, {\"begin\": 2417, \"end\": 2432, \"title\": \"http://dbpedia.org/resource/Marion_Mar\\u00e9chal\", \"score\": 0.9999998162447978, \"rank\": 0.0, \"text\": \"Marion Mar\\u00e9chal\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Marion_Mar\\u00e9chal\", \"dbpedia\": \"http://dbpedia.org/resource/Marion_Mar\\u00e9chal\"}, {\"begin\": 2451, \"end\": 2461, \"title\": \"http://dbpedia.org/resource/History_of_Christianity\", \"score\": 0.5687140680