, \"from\": 2560, \"to\": 2568}, {\"ngram\": \"300 athletes\", \"from\": 2599, \"to\": 2611}]}, {\"sentence\": \"\\\"We are going to take money from our department.\", \"from\": 2629, \"to\": 2677, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"money\", \"from\": 2651, \"to\": 2656}, {\"ngram\": \"our department\", \"from\": 2662, \"to\": 2676}]}, {\"sentence\": \"We spoke to Lotto, we spoke to SuperSport, we are speaking to different companies that are willing to put money into Project 300 where we are going to search for talent in South Africa.\", \"from\": 2678, \"to\": 2863, \"entities\": [{\"begin\": 2690, \"end\": 2695, \"title\": \"http://dbpedia.org/resource/Lottery\", \"score\": 1.0, \"rank\": 5.342128991616894e-16, \"text\": \"Lotto\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Lottery\", \"dbpedia\": \"http://dbpedia.org/resource/Lottery\"}, {\"begin\": 2850, \"end\": 2862, \"title\": \"http://dbpedia.org/resource/South_Africa\", \"score\": 1.0, \"rank\": 6.4676092905031595e-15, \"text\": \"South Africa\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/South_Africa\", \"dbpedia\": \"http://dbpedia.org/resource/South_Africa\"}], \"noun_phrases\": [{\"ngram\": \"SuperSport\", \"from\": 2709, \"to\": 2719}, {\"ngram\": \"different companies\", \"from\": 2740, \"to\": 2759}, {\"ngram\": \"money\", \"from\": 2784, \"to\": 2789}, {\"ngram\": \"Project\", \"from\": 2795, \"to\": 2802}, {\"ngram\": \"talent\", \"from\": 2840, \"to\": 2846}]}, {\"sentence\": \"\\\"We are starting Project 300 because it's a disgrace that you have a country with five million people taking 150 athletes to the Olympics while we have 60 million and we are taking the same amount of athletes to the Olympics,\\\" McKenzie said.\", \"from\": 2865, \"to\": 3106, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Project\", \"from\": 2882, \"to\": 2889}, {\"ngram\": \"a disgrace\", \"from\": 2907, \"to\": 2917}, {\"ngram\": \"a country\", \"from\": 2932, \"