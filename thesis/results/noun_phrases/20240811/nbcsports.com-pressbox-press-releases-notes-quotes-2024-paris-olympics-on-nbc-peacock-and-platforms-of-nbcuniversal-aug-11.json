130332, \"rank\": 9.647349174785564e-07, \"text\": \"Wasserman\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Wasserman_Media_Group\", \"dbpedia\": \"http://dbpedia.org/resource/Wasserman_Media_Group\"}, {\"begin\": 7155, \"end\": 7160, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 4.2452028348054446e-19, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Tirico\", \"from\": 7122, \"to\": 7128}, {\"ngram\": \"LA28\", \"from\": 7137, \"to\": 7141}, {\"ngram\": \"\\\"The willingness\", \"from\": 7162, \"to\": 7178}, {\"ngram\": \"the box\", \"from\": 7203, \"to\": 7210}, {\"ngram\": \"the things\", \"from\": 7211, \"to\": 7221}, {\"ngram\": \"the traditional mold\", \"from\": 7240, \"to\": 7260}, {\"ngram\": \"Games presentation\", \"from\": 7264, \"to\": 7282}]}, {\"sentence\": \"Those things are risky, which is why a lot of Games do not take them, but we give [Paris] a ton of credit for doing them.\", \"from\": 7284, \"to\": 7405, \"entities\": [{\"begin\": 7367, \"end\": 7372, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 4.2452028348054446e-19, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Those things\", \"from\": 7284, \"to\": 7296}, {\"ngram\": \"a lot\", \"from\": 7321, \"to\": 7326}, {\"ngram\": \"Games\", \"from\": 7330, \"to\": 7335}, {\"ngram\": \"a ton\", \"from\": 7374, \"to\": 7379}, {\"ngram\": \"credit\", \"from\": 7383, \"to\": 7389}]}, {\"sentence\": \"We will not copy those, but it will force us to think about how we can do those things differently and take advantage of our city and our landscape to present the Games in our unique way.\\\"\", \"from\": 7406, \"to\": 7594, \