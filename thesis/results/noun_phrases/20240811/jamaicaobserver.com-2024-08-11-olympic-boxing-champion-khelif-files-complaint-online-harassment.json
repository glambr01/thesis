ram\": \"campaign\", \"from\": 525, \"to\": 533}, {\"ngram\": \"the online lynching\", \"from\": 591, \"to\": 610}, {\"ngram\": \"Boudi\", \"from\": 613, \"to\": 618}]}, {\"sentence\": \"The \\\"iniquitous harassment\\\" the boxing champion had been subjected to will remain \\\"the biggest stain on these Olympic Games\\\", said Boudi.\", \"from\": 626, \"to\": 763, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The \\\"iniquitous harassment\", \"from\": 626, \"to\": 652}, {\"ngram\": \"the boxing champion\", \"from\": 654, \"to\": 673}, {\"ngram\": \"the biggest stain\", \"from\": 709, \"to\": 726}, {\"ngram\": \"these Olympic Games\", \"from\": 730, \"to\": 749}, {\"ngram\": \"Boudi\", \"from\": 757, \"to\": 762}]}, {\"sentence\": \"On Friday, Khelif won the women's 66kg final against China's Yang Liu in a unanimous points decision, having been the focus of intense scrutiny in the French capital in the past fortnight.\", \"from\": 765, \"to\": 953, \"entities\": [{\"begin\": 818, \"end\": 823, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9758305273732888, \"rank\": 0.02146182104654947, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}, {\"begin\": 826, \"end\": 834, \"title\": \"http://dbpedia.org/resource/Liu_Yang_(violinist)\", \"score\": 0.9999966834678135, \"rank\": 0.0, \"text\": \"Yang Liu\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Liu_Yang_(violinist)\", \"dbpedia\": \"http://dbpedia.org/resource/Liu_Yang_(violinist)\"}, {\"begin\": 916, \"end\": 922, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.6843931252452984, \"rank\": 0.44341557779874746, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"Fri