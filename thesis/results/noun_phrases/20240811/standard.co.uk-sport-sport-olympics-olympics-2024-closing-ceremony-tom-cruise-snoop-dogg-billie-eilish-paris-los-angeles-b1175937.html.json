7}, {\"ngram\": \"the outskirts\", \"from\": 911, \"to\": 924}, {\"ngram\": \"the Covid-enforced anonymity\", \"from\": 937, \"to\": 965}, {\"ngram\": \"its iconic landmarks\", \"from\": 990, \"to\": 1010}, {\"ngram\": \"front\", \"from\": 1016, \"to\": 1021}, {\"ngram\": \"centre\", \"from\": 1026, \"to\": 1032}, {\"ngram\": \"a Games\", \"from\": 1036, \"to\": 1043}, {\"ngram\": \"the fans\", \"from\": 1053, \"to\": 1061}, {\"ngram\": \"tram\", \"from\": 1073, \"to\": 1077}, {\"ngram\": \"Metro\", \"from\": 1082, \"to\": 1087}, {\"ngram\": \"electric bike\", \"from\": 1095, \"to\": 1108}]}, {\"sentence\": \"If Paris underscored one particular legacy for the at times turbulent 12-year reign of outgoing International Olympic Committee (IOC) president Thomas Bach, it may well have been his overseeing of the expansion of the urban programme that once again provided some of the Games' most indelible memories.\", \"from\": 1111, \"to\": 1413, \"entities\": [{\"begin\": 1114, \"end\": 1119, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 4.586801599565944e-27, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 1207, \"end\": 1244, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee (IOC)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 1207, \"end\": 1244, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee (IOC)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/Internatio