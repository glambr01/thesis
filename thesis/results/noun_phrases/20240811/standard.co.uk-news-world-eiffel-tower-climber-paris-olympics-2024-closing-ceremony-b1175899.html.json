ities\": [{\"begin\": 1198, \"end\": 1203, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999893134, \"rank\": 1.0630392021738311e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"More than 30,000 police officers\", \"from\": 1139, \"to\": 1171}, {\"ngram\": \"the last Olympic events\", \"from\": 1229, \"to\": 1252}, {\"ngram\": \"Sunday's closing ceremony\", \"from\": 1257, \"to\": 1282}]}, {\"sentence\": \"France's interior minister, Gerald Darmanin, said about 3,000 police officers will be mobilised around the Stade de France, and 20,000 police troops and other security personnel in Paris and the Saint-Denis area will be mobilised late into Sunday night to ensure safety on the last day of the Games.\", \"from\": 1285, \"to\": 1584, \"entities\": [{\"begin\": 1285, \"end\": 1291, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9731594451681242, \"rank\": 0.02363925901537563, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 1313, \"end\": 1319, \"title\": \"http://dbpedia.org/resource/Gerald_Ford\", \"score\": 0.9998096415019307, \"rank\": 9.523622276487657e-05, \"text\": \"Gerald\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Gerald_Ford\", \"dbpedia\": \"http://dbpedia.org/resource/Gerald_Ford\"}, {\"begin\": 1466, \"end\": 1471, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999893134, \"rank\": 1.0630392021738311e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"about 3,000 police officers\", \"from\": 1335, \"to\": 1362}, {\"ngram\": \"the Stade de Fr