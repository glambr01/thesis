, {\"ngram\": \"top spot\", \"from\": 2252, \"to\": 2260}]}, {\"sentence\": \"Diving brought five medals and canoeing four but no golds, while Lewis Richardson's bronze salvaged an otherwise dismal boxing effort.\", \"from\": 2263, \"to\": 2397, \"entities\": [{\"begin\": 2328, \"end\": 2344, \"title\": \"http://dbpedia.org/resource/Lewis_Richardson_(Hollyoaks)\", \"score\": 0.9965136461602875, \"rank\": 0.0034965034965027397, \"text\": \"Lewis Richardson\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Lewis_Richardson_(Hollyoaks)\", \"dbpedia\": \"http://dbpedia.org/resource/Lewis_Richardson_(Hollyoaks)\"}], \"noun_phrases\": [{\"ngram\": \"Diving\", \"from\": 2263, \"to\": 2269}, {\"ngram\": \"five medals\", \"from\": 2278, \"to\": 2289}, {\"ngram\": \"four but no golds\", \"from\": 2303, \"to\": 2320}, {\"ngram\": \"an otherwise dismal boxing effort\", \"from\": 2363, \"to\": 2396}]}, {\"sentence\": \"Britain's lone weightlifter, Emily Campbell, won the team's final medal of the Games on the last day of competition.\", \"from\": 2398, \"to\": 2514, \"entities\": [{\"begin\": 2398, \"end\": 2405, \"title\": \"http://dbpedia.org/resource/Great_Britain\", \"score\": 0.9999991990715468, \"rank\": 8.00928996293264e-07, \"text\": \"Britain\", \"types\": [\"Q23442\"], \"wikid\": \"http://dbpedia.org/resource/Great_Britain\", \"dbpedia\": \"http://dbpedia.org/resource/Great_Britain\"}, {\"begin\": 2427, \"end\": 2441, \"title\": \"http://dbpedia.org/resource/Emily_Campbell\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Emily Campbell\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emily_Campbell\", \"dbpedia\": \"http://dbpedia.org/resource/Emily_Campbell\"}], \"noun_phrases\": [{\"ngram\": \"the team's final medal\", \"from\": 2447, \"to\": 2469}, {\"ngram\": \"the Games\", \"from\": 2473, \"to\": 2482}, {\"ngram\": \"the last day\", \"from\": 2486, \"to\": 2498}, {\"ngram\": \"competition\", \"from\": 2502, \"to\": 2513}]}, {\"sentence\": \"Archery, badminton, hockey, judo, modern pentathlon, rugby sevens, table tennis and tennis were the only sports not to bring home at least one medal.\", \"from\": 2516, \"to\": 2665, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Archery\", \"from\": 2516, \"to\": 2523}, {\"ngram\": \"badminton\", \"from\": 2525, \"to\": 2534}, {\"ngram\": \"hockey\", \"from\": 2536, \"to\": 2542}, {\"ngram\": \"judo\", \"from\": 2544, \"to\": 2548}, {\"ngram\": \"modern pentathlon\", \"from\": 2550, \"to\": 2567}, {\"ngram\": \"rugby\", \"from\": 2569, \"to\": 2574}, {\"ngram\": \"the only sports\", \"from\": 2612, \"to\": 2627}, {\"ngram\": \"at least one medal\", \"from\": 2646, \"to\": 2664}]}, {\"sentence\": \"Of Team GB's 14 gold medals, six each came in men's and women's events and two in mixed equestrian events, where male and female riders compete together - though the team jumping was won by an all-male trio of Scott Brash, Harry Charles and Ben Maher.\", \"from\": 2667, \"to\": 2918, \"entities\": [{\"begin\": 2755, \"end\": 2765, \"title\": \"http://dbpedia.org/resource/Equestrian_at_the_Summer_Olympics\", \"score\": 0.9989858976349588, \"rank\": 0.001013175104703545, \"text\": \"equestrian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Equestrian_at_the_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Equestrian_at_the_Summer_Olympics\"}, {\"begin\": 2877, \"end\": 2888, \"title\": \"http://dbpedia.org/resource/Scott_Brash\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Scott Brash\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Scott_Brash\", \"dbpedia\": \"http://dbpedia.org/resource/Scott_Brash\"}, {\"begin\": 2908, \"end\": 2917, \"title\": \"http://dbpedia.org/resource/Ben_Maher\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Ben Maher\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ben_Maher\", \"dbpedia\": \"http://dbp