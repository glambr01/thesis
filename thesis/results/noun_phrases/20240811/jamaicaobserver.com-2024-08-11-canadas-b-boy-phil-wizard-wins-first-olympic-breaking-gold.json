_phrases\": [{\"ngram\": \"today\", \"from\": 678, \"to\": 683}, {\"ngram\": \"a perfect example\", \"from\": 688, \"to\": 705}, {\"ngram\": \"the world\", \"from\": 717, \"to\": 726}, {\"ngram\": \"how incredible breaking\", \"from\": 727, \"to\": 750}, {\"ngram\": \"my only goal\", \"from\": 771, \"to\": 783}, {\"ngram\": \"a former world champion\", \"from\": 813, \"to\": 836}]}, {\"sentence\": \"\\\"I am so grateful and so happy to come out with the win, but more than anything I just wanted to show the world what breaking is.\\\"\", \"from\": 839, \"to\": 969, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the win\", \"from\": 887, \"to\": 894}, {\"ngram\": \"anything\", \"from\": 910, \"to\": 918}, {\"ngram\": \"the world\", \"from\": 941, \"to\": 950}, {\"ngram\": \"what breaking\", \"from\": 951, \"to\": 964}]}, {\"sentence\": \"The competition saw 16 dancers, known as B-Boys, going head-to-head in a series of battles, starting with a pool stage before moving to a knockout round.\", \"from\": 971, \"to\": 1124, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The competition\", \"from\": 971, \"to\": 986}, {\"ngram\": \"16 dancers\", \"from\": 991, \"to\": 1001}, {\"ngram\": \"B-Boys\", \"from\": 1012, \"to\": 1018}, {\"ngram\": \"head\", \"from\": 1034, \"to\": 1038}, {\"ngram\": \"a series\", \"from\": 1042, \"to\": 1050}, {\"ngram\": \"battles\", \"from\": 1054, \"to\": 1061}, {\"ngram\": \"a pool stage\", \"from\": 1077, \"to\": 1089}, {\"ngram\": \"a knockout round\", \"from\": 1107, \"to\": 1123}]}, {\"sentence\": \"Phil Wizard had the crowd against him in the final against local hero Dany Dann, a 36-year-old with blue hair whose real name is Danis Civil.\", \"from\": 1126, \"to\": 1267, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Phil Wizard\", \"from\": 1126, \"to\": 1137}, {\"ngram\": \"the crowd\", \"from\": 1142, \"to\": 1151}, {\"ngram\": \"local hero Dany Dann\", \"from\": 1185, \"to\": 1205}, {\"ngram\": \"blue hair\", \"from\": 122