m\": 390, \"to\": 550, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"CGTN\", \"from\": 390, \"to\": 394}, {\"ngram\": \"a series\", \"from\": 405, \"to\": 413}, {\"ngram\": \"reports\", \"from\": 417, \"to\": 424}, {\"ngram\": \"the U.S.'s role\", \"from\": 433, \"to\": 448}, {\"ngram\": \"the controversy\", \"from\": 452, \"to\": 467}, {\"ngram\": \"its dominance\", \"from\": 476, \"to\": 489}, {\"ngram\": \"international sports\", \"from\": 493, \"to\": 513}, {\"ngram\": \"global anti-doping rules\", \"from\": 525, \"to\": 549}]}, {\"sentence\": \"As Chinese athletes amaze the world again with their record-shattering performances at the ongoing Paris Olympic Games, some athletes and media outlets have cast doubts about how they got there.\", \"from\": 552, \"to\": 746, \"entities\": [{\"begin\": 555, \"end\": 562, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9978577301190765, \"rank\": 0.0019387730099619817, \"text\": \"Chinese\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}], \"noun_phrases\": [{\"ngram\": \"the world\", \"from\": 578, \"to\": 587}, {\"ngram\": \"their record-shattering performances\", \"from\": 599, \"to\": 635}, {\"ngram\": \"the ongoing Paris Olympic Games\", \"from\": 639, \"to\": 670}, {\"ngram\": \"some athletes\", \"from\": 672, \"to\": 685}, {\"ngram\": \"media outlets\", \"from\": 690, \"to\": 703}, {\"ngram\": \"doubts\", \"from\": 714, \"to\": 720}]}, {\"sentence\": \"In April, a New York Times story claimed that 23 top Chinese swimmers had tested positive for the banned drug trimetazidine, known as TMZ, but escaped punishment as some went on to compete in the subsequent Tokyo Olympics in 2021.\", \"from\": 748, \"to\": 978, \"entities\": [{\"begin\": 760, \"end\": 768, \"title\": \"http://dbpedia.org/resource/New_York_City\", \"score\": 0.999999651035584, \"rank\": 3.2883757577077755e-07, \"text\": \"New York\", \"types\": [\"Q515\"