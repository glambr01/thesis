 1465, \"to\": 1473}, {\"ngram\": \"relevant authorities\", \"from\": 1490, \"to\": 1510}, {\"ngram\": \"the power\", \"from\": 1511, \"to\": 1520}, {\"ngram\": \"membership fees\", \"from\": 1533, \"to\": 1548}]}, {\"sentence\": \"The law is \\\"a tool for USADA to put itself above the rest of the world, perhaps even to replace WADA as the global regulator for anti-doping,\\\" said WADA President Witold Banka at a session of the International Olympic Committee (IOC) in Paris on July 24, two days before the opening of the 2024 Olympic Games.\", \"from\": 1573, \"to\": 1882, \"entities\": [{\"begin\": 1596, \"end\": 1601, \"title\": \"http://dbpedia.org/resource/United_States_Anti-Doping_Agency\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"USADA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_States_Anti-Doping_Agency\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_Anti-Doping_Agency\"}, {\"begin\": 1736, \"end\": 1742, \"title\": \"http://dbpedia.org/resource/Vytautas\", \"score\": 1.0, \"rank\": 3.413757979388084e-14, \"text\": \"Witold\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Vytautas\", \"dbpedia\": \"http://dbpedia.org/resource/Vytautas\"}, {\"begin\": 1743, \"end\": 1748, \"title\": \"http://dbpedia.org/resource/Bangka_Island\", \"score\": 0.9892109421042896, \"rank\": 0.01081186859179785, \"text\": \"Banka\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Bangka_Island\", \"dbpedia\": \"http://dbpedia.org/resource/Bangka_Island\"}, {\"begin\": 1769, \"end\": 1806, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee (IOC)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 1810, \"end\": 