oun_phrases\": [{\"ngram\": \"The goal\", \"from\": 795, \"to\": 803}, {\"ngram\": \"the Olympics\", \"from\": 832, \"to\": 844}]}, {\"sentence\": \"We can not look ahead of ourselves and say this is what we want to achieve at the Olympics, \\\"Waldrum told the Super Falcons media team.\", \"from\": 846, \"to\": 981, \"entities\": [{\"begin\": 956, \"end\": 969, \"title\": \"http://dbpedia.org/resource/Nigeria_women's_national_football_team\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Super Falcons\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Nigeria_women's_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Nigeria_women's_national_football_team\"}], \"noun_phrases\": [{\"ngram\": \"the Olympics\", \"from\": 924, \"to\": 936}, {\"ngram\": \"Waldrum\", \"from\": 939, \"to\": 946}]}, {\"sentence\": \"\\\"Qualification is going to be the primary goal.\", \"from\": 983, \"to\": 1030, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Qualification\", \"from\": 984, \"to\": 997}, {\"ngram\": \"the primary goal\", \"from\": 1013, \"to\": 1029}]}, {\"sentence\": \"Everyone knows we have a difficult set of matches coming up against Cameroon.\", \"from\": 1031, \"to\": 1108, \"entities\": [{\"begin\": 1099, \"end\": 1107, \"title\": \"http://dbpedia.org/resource/Cameroon_national_football_team\", \"score\": 0.9996222096785512, \"rank\": 0.0003779330569822798, \"text\": \"Cameroon\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Cameroon_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Cameroon_national_football_team\"}], \"noun_phrases\": [{\"ngram\": \"Everyone\", \"from\": 1031, \"to\": 1039}, {\"ngram\": \"a difficult set\", \"from\": 1054, \"to\": 1069}, {\"ngram\": \"matches\", \"from\": 1073, \"to\": 1080}]}, {\"sentence\": \"\\\"The focus is now on the two matches.\", \"from\": 1110, \"to\": 1147, \"entities\": [], \"noun_phrases\