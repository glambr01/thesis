/resource/National_Fascist_Party\"}, {\"begin\": 865, \"end\": 875, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.4750169983701667e-19, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"a number\", \"from\": 790, \"to\": 798}, {\"ngram\": \"locations\", \"from\": 802, \"to\": 811}, {\"ngram\": \"June\", \"from\": 815, \"to\": 819}, {\"ngram\": \"the headquarters\", \"from\": 841, \"to\": 857}, {\"ngram\": \"the offices\", \"from\": 898, \"to\": 909}, {\"ngram\": \"contractors\", \"from\": 913, \"to\": 924}, {\"ngram\": \"the committee\", \"from\": 934, \"to\": 947}, {\"ngram\": \"the homes\", \"from\": 953, \"to\": 962}, {\"ngram\": \"ofParis 2024 CEO\", \"from\": 963, \"to\": 979}, {\"ngram\": \"Etienne Thoboisand\", \"from\": 980, \"to\": 998}, {\"ngram\": \"his executive director\", \"from\": 999, \"to\": 1021}, {\"ngram\": \"operations\", \"from\": 1025, \"to\": 1035}, {\"ngram\": \"Edouard Donnelly\", \"from\": 1037, \"to\": 1053}]}, {\"sentence\": \"No charges have been brought against any individuals or organisations and those implicated have denied wrongdoing.\", \"from\": 1056, \"to\": 1170, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"No charges\", \"from\": 1056, \"to\": 1066}, {\"ngram\": \"any individuals\", \"from\": 1093, \"to\": 1108}, {\"ngram\": \"organisations\", \"from\": 1112, \"to\": 1125}, {\"ngram\": \"wrongdoing\", \"from\": 1159, \"to\": 1169}]}, {\"sentence\": \"The Independentunderstands that the investigation into \\\"illegal conflict of interest, misuse of public funds and favouritism\\\" is very unlikely to be wrapped up before the opening ceremony on Friday 26 July.\", \"from\": 1172, \"to\": 1378, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The Independentunderstands\", \"from\": 1172, \"to\": 1198}, {\"ngram\": \"the investigation\", \"from\": 1204, \"to\": 1221}, {\"ngram\": \"illegal conflict\", \"from\": 1228, \"to\": 1244}, {\"ngram\": \"interest\", \"from\": 1248, \"to\": 1256}, {\"ngram\": \"misuse\", \"from\": 1258, \"to\": 1264}, {\"ngram\": \"public funds\", \"from\": 1268, \"to\": 1280}, {\"ngram\": \"favouritism\", \"from\": 1285, \"to\": 1296}, {\"ngram\": \"the opening ceremony\", \"from\": 1339, \"to\": 1359}, {\"ngram\": \"Friday\", \"from\": 1363, \"to\": 1369}, {\"ngram\": \"July\", \"from\": 1373, \"to\": 1377}]}, {\"sentence\": \"A spokesperson for the PNF toldThe Independentthat the inquiry was still continuing \\\"with analysis by investigators of the numerous documents seized\\\".\", \"from\": 1379, \"to\": 1529, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A spokesperson\", \"from\": 1379, \"to\": 1393}, {\"ngram\": \"the PNF\", \"from\": 1398, \"to\": 1405}, {\"ngram\": \"Independentthat\", \"from\": 1414, \"to\": 1429}, {\"ngram\": \"the inquiry\", \"from\": 1430, \"to\": 1441}, {\"ngram\": \"analysis\", \"from\": 1469, \"to\": 1477}, {\"ngram\": \"investigators\", \"from\": 1481, \"to\": 1494}, {\"ngram\": \"the numerous documents\", \"from\": 1498, \"to\": 1520}]}, {\"sentence\": \"The lack of any imminent resolution before the Games is a blow to both the organising committee and the French government, both of whom have sought to downplay the significance of the investigation as they prepare for the Olympics to begin.\", \"from\": 1531, \"to\": 1771, \"entities\": [{\"begin\": 1635, \"end\": 1641, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.6053998092538795, \"rank\": 0.6280218203202854, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"The lack\", \"from\": 1531, \"to\": 1539}, {\"ngram\": \"any imminent resolution\", \"from\": 1543, \"to\": 1566}, {\"ngram\": \"the Games\", \"from\": 1574, \"to\": 1583}, {\"ngram\": \"a blow\", \"from\": 1587, \"to\": 1593}, {\"ngram\": \"both the organising committee\", \"from\": 1597, \"to\": 1626}, {\"ngram\": \"the significance\", \"from\": 1691, \"to\": 1707}, {\"ngram\": \"the investigation\", \"from\": 1711, \"to\": 1728}, {\"ngram\": \"the Olympics\", \"from\": 1749, \"to\": 1761}]}, {\"sentence\": \"The French minister for sport and the Olympic and Paralympic Games, Amelie Oudea-Castera, said she had \\\"no specific concerns\\\" after being questioned about the case, while Paris 2024 president Tony Estanguet dismissed comparisons with major corruption scandals atthe RioandTokyo Olympicsas unfair.\", \"from\": 1773, \"to\": 2069, \"entities\": [{\"begin\": 1773, \"end\": 1792, \"title\": \"http://dbpedia.org/resource/The_French_Minister\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"The French minister\", \"types\": [\"Q386724\", \"Q11424\"], \"wikid\": \"http://dbpedia.org/resource/The_French_Minister\", \"dbpedia\": \"http://dbpedia.org/resource/The_French_Minister\"}, {\"begin\": 1944, \"end\": 1954, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.4750169983701667e-19, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 1965, \"end\": 1979, \"title\": \"http://dbpedia.org/resource/Tony_Estanguet\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Tony Estanguet\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Tony_Estanguet\", \"dbpedia\": \"http://dbpedia.org/resource/Tony_Estanguet\"}], \"noun_phrases\": [{\"ngram\": \"sport\", \"from\": 1797, \"to\": 1802}, {\"ngram\": \"the Olympic and Paralympic Games\", \"from\": 1807, \"to\": 1839}, {\"ngram\": \"Amelie Oudea-Castera\", \"from\": 1841, \"to\": 1861}, {\"ngram\": \"no specific concerns\", \"from\": 1877, \"to\": 1897}, {\"ngram\": \"the case\", \"from\": 1928, \"to\": 1936}, {\"ngram\": \"comparisons\", \"from\": 1990, \"to\": 2001}, {\"ngram\": \"major corruption scandals\", \"from\": 2007, \"to\": 2032}, {\"ngram\": \"atthe RioandTokyo Olympicsas unfair\", \"from\": 2033, \"to\": 2068}]}, {\"sentence\": \"The PNF has also sought to play down the seriousness of the matter, suggesting it will not uncover \\\"the most serious cases of corruption\\\" and stressing that investigators do not want to disrupt the Olympic Games.\", \"from\": 2071, \"to\": 2283, \"entities\": [{\"begin\": 2075, \"end\": 2078, \"title\": \"http://dbpedia.org/resource/National_Fascist_Party\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"PNF\", \"types\": [\"Q7278\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/National_Fascist_Party\", \"dbpedia\": \"http://dbpedia.org/resource/National_Fascist_Party\"}], \"noun_phrases\": [{\"ngram\": \"the seriousness\", \"from\": 2108, \"to\": 2123}, {\"ngram\": \"the matter\", \"from\": 2127, \"to\": 2137}, {\"ngram\": \"the most serious cases\", \"from\": 2171, \"to\": 2193}, {\"ngram\": \"corruption\", \"from\": 2197, \"to\": 2207}, {\"ngram\": \"investigators\", \"from\": 2228, \"to\": 2241}, {\"ngram\": \"the Olympic Games\", \"from\": 2265, \"to\": 2282}]}, {\"sentence\": \"\\\"It's about favouritism, of illegal interest-taking,\\\" said the head of the PNF, Jean-Francois Bohnert.\", \"from\": 2285, \"to\": 2387, \"entities\": [{\"begin\": 2360, \"end\": 2363, \"title\": \"http://dbpedia.org/resource/National_Fascist_Party\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"PNF\", \"types\": [\"Q7278\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/National_Fascist_Party\", \"dbpedia\": \"http://dbpedia.org/resource/National_Fascist_Party\"}], \"noun_phrases\": [{\"ngram\": \"favouritism\", \"from\": 2297, \"to\": 2308}, {\"ngram\": \"illegal interest-taking\", \"from\": 2313, \"to\": 2336}, {\"ngram\": \"the head\", \"from\": 2344, \"to\": 2352}]}, {\"sentence\": \"\\\"It's about the way certain contracts have been distributed, the arrangements\\u2026 But I do not see any elements, at least not at this stage, that would lead the investigation towards the most serious cases of corruption or influence peddling.\\\"\", \"from\": 2388, \"to\": 2628, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the way\", \"from\": 2400, \"to\": 2407}, {\"ngram\": \"certain contracts\", \"from\": 2408, \"to\": 2425}, {\"ngram\": \"the arrangements\", \"from\": 2449, \"to\": 2465}, {\"ngram\": \"any elements\", \"from\": 2484, \"to\": 2496}, {\"ngram\": \"this stage\", \"from\": 2514, \"to\": 2524}, {\"ngram\": \"the investigation\", \"from\": 2542, \"to\": 2559}, {\"ngram\": \"the most serious cases\", \"from\": 2568, \"to\": 2590}, {\"ngram\": \"corruption\", \"from\": 2594, \"to\": 2604}, {\"ngram\": \"influence peddling\", \"from\": 2608, \"to\": 2626}]}, {\"sentence\": \"In a statement issued toThe Independent, Paris 2024 said: \\\"We are taking the situation very seriously and are actively collaborating with the investigators to facilitate their inquiries and provide all the answers to the questions raised as quickly as possible.\", \"from\": 2630, \"to\": 2891, \"entities\": [{\"begin\": 2658, \"end\": 2669, \"title\": \"http://dbpedia.org/resource/The_Independent\", \"score\": 0.999999999998181, \"rank\": 1.8135088932542413e-12, \"text\": \"Independent\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Independent\", \"dbpedia\": \"http://dbpedia.org/resource/The_Independent\"}, {\"begin\": 2671, \"end\": 2681, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.4750169983701667e-19, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"a statement\", \"from\": 2633, \"to\": 2644}, {\"ngram\": \"the situation\", \"from\": 2703, \"to\": 2716}, {\"ngram\": \"the investigators\", \"from\": 2768, \"to\": 2785}, {\"ngram\": \"their inquiries\", \"from\": 2800, \"to\": 2815}, {\"ngram\": \"all the answers\", \"from\": 2828, \"to\": 2843}, {\"ngram\": \"the questions\", \"from\": 2847, \"to\": 2860}]}, {\"sentence\": \"\\\"To ensure the transparency and regularity of several hundred contracts, Paris 2024 has adopted stringent procedures and set up an ethics committee and an audit committee to oversee its activities.\", \"from\": 2893, \"to\": 3090, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the transparency\", \"from\": 2904, \"to\": 2920}, {\"ngram\": \"regularity\", \"from\": 2925, \"to\": 2935}, {\"ngram\": \"several hundred contracts\", \"from\": 2939, \"to\": 2964}, {\"ngram\": \"Paris\", \"from\": 2966, \"to\": 2971}, {\"ngram\": \"stringent procedures\", \"from\": 2989, \"to\": 3009}, {\"ngram\": \"an ethics committee\", \"from\": 3021, \"to\": 3040}, {\"ngram\": \"an audit committee\", \"from\": 3045, \"to\": 3063}, {\"ngram\": \"its activities\", \"from\": 3075, \"to\": 3089}]}, {\"sentence\": \"Paris 2024 is also undoubtedly one of the most audited organisations in France (one audit by the French Anti-Corruption Agency, five audits by the Cour des Comptes), in addition to the ongoing monitoring of its governance, and has never been made aware of any wrongdoing.\", \"from\": 3091, \"to\": 3362, \"entities\": [{\"begin\": 3091, \"end\": 3101, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.4750169983701667e-19, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 3163, \"end\": 3169, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9957801148870044, \"rank\": 0.00214256499784364, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 3188, \"end\": 3194, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.6053998092538795, \"rank\": 0.6280218203202854, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 3238, \"end\": 3254, \"title\": \"http://dbpedia.org/resource/Cour_des_Comptes_(France)\", \"score\": 0.9999999999995453, \"rank\": 0.0, \"text\": \"Cour des Comptes\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Cour_des_Comptes_(France)\", \"dbpedia\": \"http://dbpedia.org/resource/Cour_des_Comptes_(France)\"}], \"noun_phrases\": [{\"ngram\": \"the most audited organisations\", \"from\": 3129, \"to\": 3159}, {\"ngram\": \"one audit\", \"from\": 3171, \"to\": 3180}, {\"ngram\": \"five audits\", \"from\": 3219, \"to\": 3230}, {\"ngram\": \"addition\", \"from\": 3260, \"to\": 3268}, {\"ngram\": \"the ongoing monitoring\", \"from\": 3272, \"to\": 3294}, {\"ngram\": \"its governance\", \"from\": 3298, \"to\": 3312}, {\"ngram\": \"any wrongdoing\", \"from\": 3347, \"to\": 3361}]}, {\"sentence\": \"Paris 2024 has been able to demonstrate in past audits the effectiveness of these demanding procedures, which it will continue to enforce in collaboration with the audit bodies.\", \"from\": 3363, \"to\": 3540, \"entities\": [{\"begin\": 3363, \"end\": 3373, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.4750169983701667e-19, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"past audits\", \"from\": 3406, \"to\": 3417}, {\"ngram\": \"the effectiveness\", \"from\": 3418, \"to\": 3435}, {\"ngram\": \"these demanding procedures\", \"from\": 3439, \"to\": 3465}, {\"ngram\": \"collaboration\", \"from\": 3504, \"to\": 3517}, {\"ngram\": \"the audit bodies\", \"from\": 3523, \"to\": 3539}]}, {\"sentence\": \"\\\"Paris 2024 naturally hopes that the information provided will quickly rule out any suspicion of the Organising Committee and its employees.\", \"from\": 3542, \"to\": 3682, \"entities\": [{\"begin\": 3543, \"end\": 3553, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.4750169983701667e-19, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"the information\", \"from\": 3575, \"to\": 3590}, {\"ngram\": \"any suspicion\", \"from\": 3622, \"to\": 3635}, {\"ngram\": \"the Organising Committee\", \"from\": 3639, \"to\": 3663}, {\"ngram\": \"its employees\", \"from\": 3668, \"to\": 3681}]}, {\"sentence\": \"If necessary, this procedure may give rise to subsequent hearings and/or requests for additional information.\", \"from\": 3683, \"to\": 3792, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this procedure\", \"from\": 3697, \"to\": 3711}, {\"ngram\": \"rise\", \"from\": 3721, \"to\": 3725}, {\"ngram\": \"subsequent hearings\", \"from\": 3729, \"to\": 3748}, {\"ngram\": \"requests\", \"from\": 3756, \"to\": 3764}, {\"ngram\": \"additional information\", \"from\": 3769, \"to\": 3791}]}, {\"sentence\": \"Should this situation arise, Paris 2024 hopes that it will intervene as soon as possible to clarify the matter.\", \"from\": 3793, \"to\": 3904, \"entities\": [{\"begin\": 3822, \"end\": 3832, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.4750169983701667e-19, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource