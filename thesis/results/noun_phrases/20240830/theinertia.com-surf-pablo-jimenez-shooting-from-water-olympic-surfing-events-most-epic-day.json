": [{\"ngram\": \"the water\", \"from\": 6335, \"to\": 6344}, {\"ngram\": \"over 30 years\", \"from\": 6349, \"to\": 6362}]}, {\"sentence\": \"This man knows what he's doing.\", \"from\": 6365, \"to\": 6396, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"This man\", \"from\": 6365, \"to\": 6373}]}, {\"sentence\": \"Photo:Ben Reed//ISA How would you tell a photographer they are ready?\", \"from\": 6397, \"to\": 6467, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Photo\", \"from\": 6397, \"to\": 6402}, {\"ngram\": \"a photographer\", \"from\": 6436, \"to\": 6450}]}, {\"sentence\": \"How do you gauge your comfort level?\", \"from\": 6468, \"to\": 6504, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"your comfort level\", \"from\": 6485, \"to\": 6503}]}, {\"sentence\": \"I get people asking me for tips all the time.\", \"from\": 6506, \"to\": 6551, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"people\", \"from\": 6512, \"to\": 6518}, {\"ngram\": \"tips\", \"from\": 6533, \"to\": 6537}]}, {\"sentence\": \"The first thing is, you have to feel comfortable in the water.\", \"from\": 6552, \"to\": 6614, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The first thing\", \"from\": 6552, \"to\": 6567}, {\"ngram\": \"the water\", \"from\": 6604, \"to\": 6613}]}, {\"sentence\": \"But what does that mean?\", \"from\": 6615, \"to\": 6639, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Because that (photographer who almost died), I guess he felt comfortable in the water too.\", \"from\": 6640, \"to\": 6730, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"photographer\", \"from\": 6654, \"to\": 6666}, {\"ngram\": \"the water\", \"from\": 6716, \"to\": 6725}]}, {\"sentence\": \"You have to respect (the ocean), of course.\", \"from\": 6731, \"to\": 6774, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the ocean\", \"from\": 6752, \"to\": 6761}, {\"ngram\": \"course\", \"from\": 6767, \"to\": 6773}]}, {\"sentence\": \"The years give you some of that.