 {\"begin\": 352, \"end\": 391, \"title\": \"http://dbpedia.org/resource/Hong_Kong\", \"score\": 0.9542935084858089, \"rank\": 0.047881114608236124, \"text\": \"Hong Kong Special Administrative Region\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Hong_Kong\", \"dbpedia\": \"http://dbpedia.org/resource/Hong_Kong\"}], \"noun_phrases\": [{\"ngram\": \"CGTN\", \"from\": 205, \"to\": 209}, {\"ngram\": \"A delegation\", \"from\": 217, \"to\": 229}, {\"ngram\": \"the Paris 2024 Olympic Games\", \"from\": 274, \"to\": 302}, {\"ngram\": \"August\", \"from\": 329, \"to\": 335}, {\"ngram\": \"Sunday\", \"from\": 422, \"to\": 428}]}, {\"sentence\": \"The delegation will attend a welcome reception and welcome banquet hosted by the HKSAR government, and visit the Hong Kong Sports Institute for exchange activities.\", \"from\": 433, \"to\": 597, \"entities\": [{\"begin\": 546, \"end\": 572, \"title\": \"http://dbpedia.org/resource/Hong_Kong_Sports_Institute\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Hong Kong Sports Institute\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/Hong_Kong_Sports_Institute\", \"dbpedia\": \"http://dbpedia.org/resource/Hong_Kong_Sports_Institute\"}], \"noun_phrases\": [{\"ngram\": \"The delegation\", \"from\": 433, \"to\": 447}, {\"ngram\": \"a welcome reception\", \"from\": 460, \"to\": 479}, {\"ngram\": \"welcome banquet\", \"from\": 484, \"to\": 499}, {\"ngram\": \"the HKSAR government\", \"from\": 510, \"to\": 530}, {\"ngram\": \"exchange activities\", \"from\": 577, \"to\": 596}]}, {\"sentence\": \"Members will also attend three public events, including a Gala Show at Queen Elizabeth Stadium on August 30, and give sports demonstrations at Queen Elizabeth Stadium and Victoria Park Swimming Pool on August 31.\", \"from\": 598, \"to\": 810, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Members\", \"from\": 598, \"to\": 605}, {\"ngram\": \"three public events\", \"from\": 623, \"to\": 642}, {\"ngram\": \"a Gala Show\", \"from\": 654, \"to\": 665}, {\"ngram\": \"Queen Elizabeth Stadium\", \"from\": 669, \"to\": 692}, {\"ngram\": \"August\", \"from\": 696, \"to\": 702}, {\"ngram\": \"sports demonstrations\", \"from\": 716, \"to\": 737}, {\"ngram\": \"Queen Elizabeth Stadium\", \"from\": 741, \"to\": 764}, {\"ngram\": \"Victoria Park Swimming Pool\", \"from\": 769, \"to\": 796}, {\"ngram\": \"August\", \"from\": 800, \"to\": 806}]}, {\"sentence\": \"John Lee, chief executive of the HKSAR, expressed his sincere gratitude to the central government for arranging another visit of the Chinese mainland Olympians delegation, which he said \\\"fully demonstrates its care for Hong Kong.\\\"\", \"from\": 812, \"to\": 1042, \"entities\": [{\"begin\": 812, \"end\": 820, \"title\": \"http://dbpedia.org/resource/John_Lee_(government_official)\", \"score\": 0.8026218482808528, \"rank\": 0.059701492537309275, \"text\": \"John Lee\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/John_Lee_(government_official)\", \"dbpedia\": \"http://dbpedia.org/resource/John_Lee_(government_official)\"}, {\"begin\": 945, \"end\": 961, \"title\": \"http://dbpedia.org/resource/Mainland_China\", \"score\": 0.9999691060724826, \"rank\": 3.089488193711214e-05, \"text\": \"Chinese mainland\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Mainland_China\", \"dbpedia\": \"http://dbpedia.org/resource/Mainland_China\"}, {\"begin\": 1031, \"end\": 1040, \"title\": \"http://dbpedia.org/resource/Hong_Kong\", \"score\": 0.9891543971653821, \"rank\": 0.01093020449451811, \"text\": \"Hong Kong\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Hong_Kong\", \"dbpedia\": \"http://dbpedia.org/resource/Hong_Kong\"}], \"noun_phrases\": [{\"ngram\": \"chief executive\", \"from\": 822, \"to\": 837}, {\"ngram\": \"the HKSAR\", \"from\": 841, \"to\": 850}, {\"ngram\": \"his sincere gratitude\", \"from\": 862, \"to\": 883}, {\"ngram\": \"the central government\", \"from\": 887, \"to\": 909}, {\"ngram\": \"another visit\", \"from\": 924, \"to\": 937}, {\"ngram\": \"its care\", \"from\": 1018, \"to\": 1026}]}, {\"sentence\": \"\\\"Athletes of the national team, with their spirit of perseverance and high level of skills, achieved breakthroughs in a number of sports in this year's Paris Olympic Games.\", \"from\": 1044, \"to\": 1216, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Athletes\", \"from\": 1045, \"to\": 1053}, {\"ngram\": \"the national team\", \"from\": 1057, \"to\": 1074}, {\"ngram\": \"their spirit\", \"from\": 1081, \"to\": 1093}, {\"ngram\": \"perseverance\", \"from\": 1097, \"to\": 1109}, {\"ngram\": \"high level\", \"from\": 1114, \"to\": 1124}, {\"ngram\": \"skills\", \"from\": 1128, \"to\": 1134}, {\"ngram\": \"breakthroughs\", \"from\": 1145, \"to\": 1158}, {\"ngram\": \"a number\", \"from\": 1162, \"to\": 1170}, {\"ngram\": \"sports\", \"from\": 1174, \"to\": 1180}, {\"ngram\": \"this year's Paris Olympic Games\", \"from\": 1184, \"to\": 1215}]}, {\"sentence\": \"The national team achieved its best performance abroad since it comprehensively participated in the 1984 Summer Olympics,\\\" said Lee.\", \"from\": 1217, \"to\": 1349, \"entities\": [{\"begin\": 1345, \"end\": 1348, \"title\": \"http://dbpedia.org/resource/Robert_E._Lee\", \"score\": 0.9971485372094462, \"rank\": 0.0016752339801719912, \"text\": \"Lee\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Robert_E._Lee\", \"dbpedia\": \"http://dbpedia.org/resource/Robert_E._Lee\"}], \"noun_phrases\": [{\"ngram\": \"The national team\", \"from\": 1217, \"to\": 1234}, {\"ngram\": \"its best performance\", \"from\": 1244, \"to\": 1264}, {\"ngram\": \"the 1984 Summer Olympics\", \"from\": 1313, \"to\": 1337}]}, {\"sentence\": \"\\\"We are extremely proud to have witnessed China's competitive sports continue to scale new heights.\\\"\", \"from\":