53, \"title\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\", \"score\": 0.9976343463548808, \"rank\": 0.0023534642078199813, \"text\": \"IBA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\", \"dbpedia\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\"}, {\"begin\": 2189, \"end\": 2192, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.973145684052609e-26, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"The two female athletes\", \"from\": 2113, \"to\": 2136}, {\"ngram\": \"transgender athletes\", \"from\": 2162, \"to\": 2182}, {\"ngram\": \"Monday\", \"from\": 2207, \"to\": 2213}]}, {\"sentence\": \"Khelif advanced through the Olympic Games amid international scrutiny anduninformed speculation about her sex.\", \"from\": 2216, \"to\": 2326, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Khelif\", \"from\": 2216, \"to\": 2222}, {\"ngram\": \"the Olympic Games\", \"from\": 2240, \"to\": 2257}, {\"ngram\": \"international scrutiny anduninformed speculation\", \"from\": 2263, \"to\": 2311}, {\"ngram\": \"her sex\", \"from\": 2318, \"to\": 2325}]}, {\"sentence\": \"Despite being born and raised as a woman, she found herself at the center of Western debates about gender, sex and sports after failing unspecified eligibility tests for women's competition from the IBA in 2023.\", \"from\": 2327, \"to\": 2538, \"entities\": [{\"begin\": 2526, \"end\": 2529, \"title\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\", \"score\": 0.9976343463548808, \"rank\": 0.0023534642078199813, \"text\": \"IBA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Independent_Broa