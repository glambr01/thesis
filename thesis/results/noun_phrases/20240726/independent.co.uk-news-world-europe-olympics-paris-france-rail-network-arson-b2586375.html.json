{\"ngram\": \"updates\", \"from\": 407, \"to\": 414}, {\"ngram\": \"The Independent\", \"from\": 420, \"to\": 435}]}, {\"sentence\": \"Read ourPrivacy notice Saboteurs have launched a \\\"malicious\\\" arson attackonFrance's rail networks in \\\"an effort to destabilise\\\" the country just hours before the start of theParisOlympic Games.\", \"from\": 441, \"to\": 635, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"ourPrivacy notice\", \"from\": 446, \"to\": 463}, {\"ngram\": \"Saboteurs\", \"from\": 464, \"to\": 473}, {\"ngram\": \"a \\\"malicious\\\" arson attackonFrance's rail networks\", \"from\": 488, \"to\": 538}, {\"ngram\": \"an effort\", \"from\": 543, \"to\": 552}, {\"ngram\": \"the country\", \"from\": 569, \"to\": 580}, {\"ngram\": \"the start\", \"from\": 599, \"to\": 608}, {\"ngram\": \"theParisOlympic Games\", \"from\": 612, \"to\": 633}]}, {\"sentence\": \"Up to 800,000 passengers are facingtravel chaosattempting to reach Paris this weekend after high-speedrail servicesto the French capital were hit by what officials described as \\\"criminal actions\\\" ahead of the opening ceremony on Friday.\", \"from\": 637, \"to\": 873, \"entities\": [{\"begin\": 704, \"end\": 709, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 9.991094651665143e-27, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 759, \"end\": 765, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9984628779761164, \"rank\": 0.0015392397462047234, \"text\": \"French\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"Up to 800,000 passengers\", \"from\": 637, \"to\": 661}, {\"ngram\": \"facingtravel chaosattempting\", \"from\": 666, \"to\": 694}, {\"ngram\": \"high-speedrail servicesto\", \"from\": 729, \"to\": 754}, {\"ngra