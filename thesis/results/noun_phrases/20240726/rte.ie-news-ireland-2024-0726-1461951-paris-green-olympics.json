"{\"uid\": \"rte.ie-news-ireland-2024-0726-1461951-paris-green-olympics\", \"noun_phrases\": [{\"sentence\": \"With medals made of iron salvaged from Eiffel Tower refurbishments and stadium seating of recycled plastic, Paris 2024 aims to be the greenest Olympics yet.\", \"from\": 0, \"to\": 156, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"medals\", \"from\": 5, \"to\": 11}, {\"ngram\": \"iron\", \"from\": 20, \"to\": 24}, {\"ngram\": \"Eiffel Tower refurbishments\", \"from\": 39, \"to\": 66}, {\"ngram\": \"stadium seating\", \"from\": 71, \"to\": 86}, {\"ngram\": \"recycled plastic\", \"from\": 90, \"to\": 106}, {\"ngram\": \"the greenest Olympics\", \"from\": 130, \"to\": 151}]}, {\"sentence\": \"The case for action is clear as scientists have said intense heat linked to man-made carbon emissions is a growing risk to competitors at the world's largest sporting event and beyond.\", \"from\": 158, \"to\": 342, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The case\", \"from\": 158, \"to\": 166}, {\"ngram\": \"action\", \"from\": 171, \"to\": 177}, {\"ngram\": \"scientists\", \"from\": 190, \"to\": 200}, {\"ngram\": \"intense heat\", \"from\": 211, \"to\": 223}, {\"ngram\": \"man-made carbon emissions\", \"from\": 234, \"to\": 259}, {\"ngram\": \"a growing risk\", \"from\": 263, \"to\": 277}, {\"ngram\": \"competitors\", \"from\": 281, \"to\": 292}, {\"ngram\": \"the world's largest sporting event\", \"from\": 296, \"to\": 330}]}, {\"sentence\": \"Paris 2024 has pledged to reduce its carbon emissions by half compared to the average emitted during the London and Rio Summer Games.\", \"from\": 344, \"to\": 477, \"entities\": [{\"begin\": 344, \"end\": 354, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 2.5204909683914832e-21, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"beg