ntities\": [{\"begin\": 648, \"end\": 654, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9946322152828864, \"rank\": 0.005367514749428728, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 692, \"end\": 702, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 3.3867963251569196e-18, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 802, \"end\": 814, \"title\": \"http://dbpedia.org/resource/Buenos_Aires\", \"score\": 0.9997999089461669, \"rank\": 0.00019917416152022727, \"text\": \"Buenos Aires\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Buenos_Aires\", \"dbpedia\": \"http://dbpedia.org/resource/Buenos_Aires\"}], \"noun_phrases\": [{\"ngram\": \"Estanguet\", \"from\": 594, \"to\": 603}, {\"ngram\": \"a three-time Olympic canoeing champion\", \"from\": 605, \"to\": 643}, {\"ngram\": \"a unique event\", \"from\": 673, \"to\": 687}, {\"ngram\": \"the opening ceremony\", \"from\": 720, \"to\": 740}, {\"ngram\": \"the 2018 Youth Olympics\", \"from\": 744, \"to\": 767}, {\"ngram\": \"the streets\", \"from\": 787, \"to\": 798}]}, {\"sentence\": \"Paris 2024 executive director Thierry Reboul is said to have been inspired by a walk along the Seine five years ago and came up with the idea for the ceremony to be held on the river.\", \"from\": 817, \"to\": 1000, \"entities\": [{\"begin\": 817, \"end\": 827, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 3.3867963251569196e-18, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 847, \"end\": 854, \"title\": \"http://dbpedia.org/resource/Augustin_Thierry\", \"score\": 1.0, \"rank\": 4.103597491419538e-18, \"text\": \"Thierry\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Augustin_Thierry\", \"dbpedia\": \"http://dbpedia.org/resource/Augustin_Thierry\"}, {\"begin\": 912, \"end\": 917, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 1.0, \"rank\": 1.4898853749338618e-15, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"a walk\", \"from\": 895, \"to\": 901}, {\"ngram\": \"the idea\", \"from\": 950, \"to\": 958}, {\"ngram\": \"the ceremony\", \"from\": 963, \"to\": 975}, {\"ngram\": \"the river\", \"from\": 990, \"to\": 999}]}, {\"sentence\": \"'I can tell you that at the very beginning, it seemed to be a crazy and not very serious idea,' Macron said at the Elysee palace on Monday.\", \"from\": 1002, \"to\": 1141, \"entities\": [{\"begin\": 1098, \"end\": 1104, \"title\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"score\": 0.9999999999915872, \"rank\": 8.455889102643407e-12, \"text\": \"Macron\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"dbpedia\": \"http://dbpedia.org/resource/Emmanuel_Macron\"}, {\"begin\": 1117, \"end\": 1130, \"title\": \"http://dbpedia.org/resource/\\u00c9lys\\u00e9e_Palace\", \"score\": 0.9999999998246949, \"rank\": 0.0, \"text\": \"Elysee palace\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/\\u00c9lys\\u00e9e_Palace\", \"dbpedia\": \"http://dbpedia.org/resource/\\u00c9lys\\u00e9e_Palace\"}], \"noun_phrases\": [{\"ngram\": \"the very beginning\", \"from\": 1026, \"to\": 1044}, {\"ngram\": \"a crazy and not very serious idea\", \"from\": 1062, \"to\": 1095}, {\"ngram\": \"Monday\", \"from\": 1134, \"to\": 1140}]}, {\"sentence\": \"'But we decided it was the right moment to deliver this crazy idea and make it real.'\", \"from\": 1143, \"to\": 1228, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the right moment\", \"from\": 1166, \"to\": 1182}, {\"ngram\": \"this crazy idea\", \"from\": 1194, \"to\": 1209}]}, {\"sentence\": \"Security for the unique opening ceremony was one of the major concerns for Paris 2024 officials but 45,000 police officers and 18,000 soldiers, the biggest deployment in the country since World War II, have been deployed.\", \"from\": 1230, \"to\": 1451, \"entities\": [{\"begin\": 1305, \"end\": 1315, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 3.3867963251569196e-18, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"Security\", \"from\": 1230, \"to\": 1238}, {\"ngram\": \"the unique opening ceremony\", \"from\": 1243, \"to\": 1270}, {\"ngram\": \"the major concerns\", \"from\": 1282, \"to\": 1300}, {\"ngram\": \"officials\", \"from\": 1316, \"to\": 1325}, {\"ngram\": \"45,000 police officers\", \"from\": 1330, \"to\": 1352}, {\"ngram\": \"18,000 soldiers\", \"from\": 1357, \"to\": 1372}, {\"ngram\": \"the biggest deployment\", \"from\": 1374, \"to\": 1396}, {\"ngram\": \"the country\", \"from\": 1400, \"to\": 1411}, {\"ngram\": \"World War II\", \"from\": 1418, \"to\": 1430}]}, {\"sentence\": \"Earlier this year, Macron had suggested that the opening ceremony could be moved to the Stade de France if security issues 'But if we think there are risks, depending on our analysis of the context, we have fallback scenarios,' Macron said in April.\", \"from\": 1453, \"to\": 1703, \"entities\": [{\"begin\": 1472, \"end\": 1478, \"title\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"score\": 0.9999999999915872, \"rank\": 8.455889102643407e