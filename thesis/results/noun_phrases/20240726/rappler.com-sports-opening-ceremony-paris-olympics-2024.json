\"ngram\": \"the river\", \"from\": 868, \"to\": 877}, {\"ngram\": \"performers\", \"from\": 943, \"to\": 953}, {\"ngram\": \"the sports\", \"from\": 972, \"to\": 982}, {\"ngram\": \"the Games\", \"from\": 1002, \"to\": 1011}, {\"ngram\": \"floating platforms\", \"from\": 1015, \"to\": 1033}]}, {\"sentence\": \"More than 10,500 athletes will compete at the Olympics, 100 years since Paris last staged the Games.\", \"from\": 1036, \"to\": 1136, \"entities\": [{\"begin\": 1108, \"end\": 1113, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 2.5860334755717507e-32, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"More than 10,500 athletes\", \"from\": 1036, \"to\": 1061}, {\"ngram\": \"the Olympics\", \"from\": 1078, \"to\": 1090}, {\"ngram\": \"the Games\", \"from\": 1126, \"to\": 1135}]}, {\"sentence\": \"Competition started on Wednesday and the first of the 329 gold medals will be awarded on Saturday, July 27.\", \"from\": 1137, \"to\": 1244, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Competition\", \"from\": 1137, \"to\": 1148}, {\"ngram\": \"Wednesday\", \"from\": 1160, \"to\": 1169}, {\"ngram\": \"the 329 gold medals\", \"from\": 1187, \"to\": 1206}, {\"ngram\": \"Saturday\", \"from\": 1226, \"to\": 1234}, {\"ngram\": \"July\", \"from\": 1236, \"to\": 1240}]}, {\"sentence\": \"It was the first time that an opening ceremony has taken place outside a stadium, adding to the headaches for a vast security operation, just hours after a sabotage attack on the high-speed TGV rail network caused travel chaos across France.\", \"from\": 1246, \"to\": 1487, \"entities\": [{\"begin\": 1436, \"end\": 1439, \"title\": \"http://dbpedia.org/resource/TGV\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"TGV\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/TGV\", \"dbped