"{\"uid\": \"si.com-olympics-swimming-medal-predictions-team-usa-tough-test-paris-olympics\", \"noun_phrases\": [{\"sentence\": \"Alarm bells have been ringing around USA Swimming for a year now, since Australia won 13 gold medals to America\\u00e2\\u0080\\u0099s seven at the 2023 World Championships.\", \"from\": 0, \"to\": 154, \"entities\": [{\"begin\": 37, \"end\": 49, \"title\": \"http://dbpedia.org/resource/USA_Swimming\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"USA Swimming\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/USA_Swimming\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Swimming\"}, {\"begin\": 72, \"end\": 81, \"title\": \"http://dbpedia.org/resource/Australia\", \"score\": 0.9999999787455638, \"rank\": 1.3472714855933592e-08, \"text\": \"Australia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Australia\", \"dbpedia\": \"http://dbpedia.org/resource/Australia\"}], \"noun_phrases\": [{\"ngram\": \"Alarm bells\", \"from\": 0, \"to\": 11}, {\"ngram\": \"a year\", \"from\": 54, \"to\": 60}, {\"ngram\": \"13 gold medals\", \"from\": 86, \"to\": 100}, {\"ngram\": \"the 2023 World Championships\", \"from\": 125, \"to\": 153}]}, {\"sentence\": \"Was this a sign of star-spangled decline, a sign ofan international surge, or a correctable blip?\", \"from\": 155, \"to\": 252, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a sign\", \"from\": 164, \"to\": 170}, {\"ngram\": \"star-spangled decline\", \"from\": 174, \"to\": 195}, {\"ngram\": \"a sign ofan international surge\", \"from\": 197, \"to\": 228}, {\"ngram\": \"a correctable blip\", \"from\": 233, \"to\": 251}]}, {\"sentence\": \"Perhaps all of the above.\", \"from\": 254, \"to\": 279, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Perhaps all\", \"from\": 254, \"to\": 265}]}, {\"sentence\": \"For the first time since 1945, no U.S. swimmer set a world record in 2023 in either long-course or short-course meters.\", \"from\": 280, \"to\": 399, \"entities\": [],