09, \"to\": 1548, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My parents\", \"from\": 1509, \"to\": 1519}, {\"ngram\": \"Sanchez\", \"from\": 1540, \"to\": 1547}]}, {\"sentence\": \"\\\"They were also a big part of the decision for me moving to the Philippines.\", \"from\": 1550, \"to\": 1626, \"entities\": [{\"begin\": 1614, \"end\": 1625, \"title\": \"http://dbpedia.org/resource/Philippines\", \"score\": 0.9989247039362465, \"rank\": 0.0010762974304967976, \"text\": \"Philippines\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Philippines\", \"dbpedia\": \"http://dbpedia.org/resource/Philippines\"}], \"noun_phrases\": [{\"ngram\": \"a big part\", \"from\": 1566, \"to\": 1576}, {\"ngram\": \"the decision\", \"from\": 1580, \"to\": 1592}]}, {\"sentence\": \"I want to represent their country and make them proud.\\\"\", \"from\": 1627, \"to\": 1682, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"their country\", \"from\": 1647, \"to\": 1660}]}, {\"sentence\": \"Opting to make thenationality switchin 2022, Sanchez completed a one-year residency before she debuted for the Philippines in the Asian Games in Hangzhou, China, last year.\", \"from\": 1684, \"to\": 1856, \"entities\": [{\"begin\": 1795, \"end\": 1806, \"title\": \"http://dbpedia.org/resource/Philippines\", \"score\": 0.9989247039362465, \"rank\": 0.0010762974304967976, \"text\": \"Philippines\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Philippines\", \"dbpedia\": \"http://dbpedia.org/resource/Philippines\"}, {\"begin\": 1829, \"end\": 1837, \"title\": \"http://dbpedia.org/resource/Hangzhou\", \"score\": 1.0, \"rank\": 1.981834452065286e-15, \"text\": \"Hangzhou\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Hangzhou\", \"dbpedia\": \"http://dbpedia.org/resource/Hangzhou\"}, {\"begin\": 1839, \"end\": 1844, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.9600261004210701, \"rank\": 0.03491172027639444, \"text