"{\"uid\": \"fortune.com-europe-2024-07-26-frances-train-networks-hit-by-sabotage-as-nation-gears-up-to-play-host-for-2024-olympics\", \"noun_phrases\": [{\"sentence\": \"Trains to and from Paris, including the international Eurostar service, were hit by what authorities called a \\\"massive attack aimed at paralyzing the network\\\" of France's super-fast trains just hours ahead of the inauguration ceremony of the 2024 Olympic Games.\", \"from\": 0, \"to\": 261, \"entities\": [{\"begin\": 19, \"end\": 24, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 6.1378165348475905e-21, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 54, \"end\": 62, \"title\": \"http://dbpedia.org/resource/Eurostar\", \"score\": 0.9999994116430483, \"rank\": 5.883573500333993e-07, \"text\": \"Eurostar\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Eurostar\", \"dbpedia\": \"http://dbpedia.org/resource/Eurostar\"}, {\"begin\": 162, \"end\": 168, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9999999818046491, \"rank\": 1.8138989104350116e-08, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"Trains\", \"from\": 0, \"to\": 6}, {\"ngram\": \"authorities\", \"from\": 89, \"to\": 100}, {\"ngram\": \"a \\\"massive attack\", \"from\": 108, \"to\": 125}, {\"ngram\": \"the network\", \"from\": 146, \"to\": 157}, {\"ngram\": \"the inauguration ceremony\", \"from\": 209, \"to\": 234}, {\"ngram\": \"the 2024 Olympic Games\", \"from\": 238, \"to\": 260}]}, {\"sentence\": \"\\\"Coordinated malicious acts targeted several TGV lines last night and will seriously disrupt traffic until this weekend,\\\" French Transport Minister Patrice Vergriete wrote in a post on the X social network.\", \"from\": 263, \"to\": 469, \"entities\": [{\"begin\": 308, \"end\": 311, \"title\": \"http://dbpedia.org/resource/TGV\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"TGV\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/TGV\", \"dbpedia\": \"http://dbpedia.org/resource/TGV\"}, {\"begin\": 385, \"end\": 391, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.8020032324869008, \"rank\": 0.24687673193787904, \"text\": \"French\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"Coordinated malicious acts\", \"from\": 264, \"to\": 290}, {\"ngram\": \"traffic\", \"from\": 356, \"to\": 363}, {\"ngram\": \"this weekend\", \"from\": 370, \"to\": 382}, {\"ngram\": \"a post\", \"from\": 438, \"to\": 444}, {\"ngram\": \"the X social network\", \"from\": 448, \"to\": 468}]}, {\"sentence\": \"Fires were set off at three critical rail-line nodes, with people seen fleeing the sites in vans, Jean-Pierre Farandou, the head of the national rail company SNCF, said on BFM TV.\", \"from\": 471, \"to\": 650, \"entities\": [{\"begin\": 569, \"end\": 580, \"title\": \"http://dbpedia.org/resource/Dardenne_brothers\", \"score\": 1.0, \"rank\": 2.6836016830725013e-17, \"text\": \"Jean-Pierre\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Dardenne_brothers\", \"dbpedia\": \"http://dbpedia.org/resource/Dardenne_brothers\"}, {\"begin\": 629, \"end\": 633, \"title\": \"http://dbpedia.org/resource/SNCF\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"SNCF\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/SNCF\", \"dbpedia\": \"http://dbpedia.org/resource/SNCF\"}, {\"begin\": 643, \"end\": 649, \"title\": \"http://dbpedia.org/resource/BFM_TV\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"BFM TV\", \"types\": [\"Q