\"}], \"noun_phrases\": [{\"ngram\": \"The action\", \"from\": 610, \"to\": 620}, {\"ngram\": \"several reporters\", \"from\": 630, \"to\": 647}, {\"ngram\": \"the much-anticipated event\", \"from\": 681, \"to\": 707}]}, {\"sentence\": \"The strike will not affect the network's television coverage of the Games.\", \"from\": 765, \"to\": 839, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The strike\", \"from\": 765, \"to\": 775}, {\"ngram\": \"the network's television coverage\", \"from\": 792, \"to\": 825}, {\"ngram\": \"the Games\", \"from\": 829, \"to\": 838}]}, {\"sentence\": \"Sky News Senior Reporter Kenny Heatley was at a demonstration in Sydney on Friday where some attendees could be seen holding signs with the slogan \\\"do not torch journalism\\\".\", \"from\": 841, \"to\": 1014, \"entities\": [{\"begin\": 841, \"end\": 849, \"title\": \"http://dbpedia.org/resource/Sky_News\", \"score\": 0.9996661994486852, \"rank\": 0.0003339120114364644, \"text\": \"Sky News\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Sky_News\", \"dbpedia\": \"http://dbpedia.org/resource/Sky_News\"}, {\"begin\": 872, \"end\": 879, \"title\": \"http://dbpedia.org/resource/Heatley,_Queensland\", \"score\": 0.7667766132905607, \"rank\": 0.19444444444441875, \"text\": \"Heatley\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Heatley,_Queensland\", \"dbpedia\": \"http://dbpedia.org/resource/Heatley,_Queensland\"}, {\"begin\": 906, \"end\": 912, \"title\": \"http://dbpedia.org/resource/Sydney\", \"score\": 0.9999999825886335, \"rank\": 1.72149864993832e-08, \"text\": \"Sydney\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Sydney\", \"dbpedia\": \"http://dbpedia.org/resource/Sydney\"}], \"noun_phrases\": [{\"ngram\": \"a demonstration\", \"from\": 887, \"to\": 902}, {\"ngram\": \"Friday\", \"from\": 916, \"to\": 922}, {\"ngram\": \"some attendees\", \"from\": 929, \"to\": 943}, {\"ngram\": \"signs\", \"from\": 966, \"to\": 971}, {\"ngram\": \"the slogan\", \"from\": 977, \"to\": 987}, {\"ngram\": \"\\\"do not torch journalism\", \"from\": 988, \"to\": 1012}]}, {\"sentence\": \"Others were spotted wearing white t-shirts emblazoned with the same message alongside a caricature of Nine CEO Mike Sneesby holding the Olympic torch in Paris.\", \"from\": 1016, \"to\": 1175, \"entities\": [{\"begin\": 1169, \"end\": 1174, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999995366124, \"rank\": 4.632817532268212e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Others\", \"from\": 1016, \"to\": 1022}, {\"ngram\": \"white t-shirts\", \"from\": 1044, \"to\": 1058}, {\"ngram\": \"the same message\", \"from\": 1075, \"to\": 1091}, {\"ngram\": \"a caricature\", \"from\": 1102, \"to\": 1114}, {\"ngram\": \"Nine CEO Mike Sneesby\", \"from\": 1118, \"to\": 1139}, {\"ngram\": \"the Olympic torch\", \"from\": 1148, \"to\": 1165}]}, {\"sentence\": \"Images of the chief executive carrying the torch in the relay before the Games this week were widely circulated and are said to have only increased frustration of the company's employees.\", \"from\": 1177, \"to\": 1364, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Images\", \"from\": 1177, \"to\": 1183}, {\"ngram\": \"the chief executive\", \"from\": 1187, \"to\": 1206}, {\"ngram\": \"the torch\", \"from\": 1216, \"to\": 1225}, {\"ngram\": \"the relay\", \"from\": 1229, \"to\": 1238}, {\"ngram\": \"the Games\", \"from\": 1246, \"to\": 1255}, {\"ngram\": \"to have only increased frustration\", \"from\": 1302, \"to\": 1336}, {\"ngram\": \"the company's employees\", \"from\": 1340, \"to\": 1363}]}, {\"sentence\": \"When pressed on what sort of impact the industrial action would have on the print coverage of the Olympics, chief Cricket writer at the Sydney Morning Herald Malcolm Conn dropped a bombshell.\", \"from\": 1366, \"to\": 1557, \"entities\": [{\"begin\": 1524, \"end\": 1536, \"title\": \"http://dbpedia.org/resource/Malcolm_Conn\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Malcolm Conn\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Malcolm_Conn\", \"dbpedia\": \"http://dbpedia.org/resource/Malcolm_Conn\"}], \"noun_phrases\": [{\"ngram\": \"what sort\", \"from\": 1382, \"to\": 1391}, {\"ngram\": \"impact\", \"from\": 1395, \"to\": 1401}, {\"ngram\": \"the industrial action\", \"from\": 1402, \"to\": 1423}, {\"ngram\": \"the print coverage\", \"from\": 1438, \"to\": 1456}, {\"ngram\": \"the Olympics\", \"from\": 1460, \"to\": 1472}, {\"ngram\": \"chief Cricket writer\", \"from\": 1474, \"to\": 1494}]}, {\"sentence\": \"\\\"Well, we have got very talented journalists in Paris, and none of them are going to be filing over the next five days,\\\" he said.\", \"from\": 1559, \"to\": 1688, \"entities\": [{\"begin\": 1607, \"end\": 1612, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999995366124, \"rank\": 4.632817532268212e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"very talented journalists\", \"from\": 1578, \"to\": 1603}, {\"ngram\": \"none\", \"from\": 1618, \"to\": 1622}, {\"ngram\": \"the next five days\", \"from\": 1659, \"to\": 1677}]}, {\"sentence\": \"\\\"So all the colour and excitement that they would have brought to us is not going to be there.\", \"from\": 1690, \"to\": 1784, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"all the colour\", \"from\": 1694, \"to\": 1708}, {\"ngram\": \"excitement\", \"from\": 1713, \"to\": 1723}, {\"ngram\": \"us\", \"from\": 1756, \"to\": 1758}]}, {\"sentence\": \"\\\"It's going to be a very bland, straightforward coverage, from various wire services.\", \"from\": 1786, \"to\": 1871, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a very bland, straightforward coverage\", \"from\": 1804, \"to\": 1842}, {\"ngram\": \"various wire services\", \"from\": 1849, \"to\": 1870}]}, {\"sentence\": \"So disappointing for them and disappointing for our readers.\\\"\", \"from\": 1872, \"to\": 1933, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"our readers\", \"from\": 1920, \"to\": 1931}]}, {\"sentence\": \"Mr Conn described the negotiation process as \\\"long and drawn out\\\".\", \"from\": 1935, \"to\": 2001, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Mr Conn\", \"from\": 1935, \"to\": 1942}, {\"ngram\": \"the negotiation process\", \"from\": 1953, \"to\": 1976}]}, {\"sentence\": \"\\\"The negotiations have been going on for some time, not only on pay, but also on issues like how AI is going to influence journalists' jobs and also about diversity across the newsroom, about how freelancers are being treated,\\\" he told Sky News Australia.\", \"from\": 2003, \"to\": 2258, \"entities\": [{\"begin\": 2100, \"end\": 2102, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 0.9999990611718063, \"rank\": 9.388257761274612e-07, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}, {\"begin\": 2239, \"end\": 2257, \"title\": \"http://dbpedia.org/resource/Sky_News_Australia\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Sky News Australia\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/Sky_News_Australia\", \"dbpedia\": \"http://dbpedia.org/resource/Sky_News_Australia\"}], \"noun_phrases\": [{\"ngram\": \"The negotiations\", \"from\": 2004, \"to\": 2020}, {\"ngram\": \"some time\", \"from\": 2044, \"to\": 2053}, {\"ngram\": \"pay\", \"from\": 2067, \"to\": 2070}, {\"ngram\": \"issues\", \"from\": 2084, \"to\": 2090}, {\"ngram\": \"journalists' jobs\", \"from\": 2125, \"to\": 2142}, {\"ngram\": \"diversity\", \"from\": 2158, \"to\": 2167}, {\"ngram\": \"the newsroom\", \"from\": 2175, \"to\": 2187}, {\"ngram\": \"freelancers\", \"from\": 2199, \"to\": 2210}]}, {\"sentence\": \"\\\"But I think one of the things that we are most disappointed about is that during COVID, when everyone was doing it tough, we decided not to take a pay rise.\", \"from\": 2260, \"to\": 2417, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the things\", \"from\": 2280, \"to\": 2290}, {\"ngram\": \"COVID\", \"from\": 2342, \"to\": 2347}, {\"ngram\": \"everyone\", \"from\": 2354, \"to\": 2362}, {\"ngram\": \"a pay rise\", \"from\": 2406, \"to\": 2416}]}, {\"sentence\": \"And the company sort of made it fairly clear that that would be remembered.\", \"from\": 2418, \"to\": 2493, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the company\", \"from\": 2422, \"to\": 2433}]}, {\"sentence\": \"\\\"Well, we have now had a spike in inflation, and the offer we have been given is little more than half inflation after taking nothing of the previous deal.\\\"\", \"from\": 2495, \"to\": 2651, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a spike\", \"from\": 2518, \"to\": 2525}, {\"ngram\": \"inflation\", \"from\": 2529, \"to\": 2538}, {\"ngram\": \"the offer\", \"from\": 2544, \"to\": 2553}, {\"ngram\": \"little more than half inflation\", \"from\": 2576, \"to\": 2607}, {\"ngram\": \"nothing\", \"from\": 2621, \"to\": 2628}, {\"ngram\": \"the previous deal\", \"from\": 2632, \"to\": 2649}]}, {\"sentence\": \"It\\u00e2\\u20ac\\u2122s a walk out#DontTorchJournalismpic.twitter.com/cRAIrA2x8m According to news.com.au, staff were offered a 3.5 per cent annual pay rise in an email sent on Wednesday, compared to the two per cent which was already in place.\", \"from\": 2653, \"to\": 2881, \"entities\": [{\"begin\": 2731, \"end\": 2742, \"title\": \"http://dbpedia.org/resource/News_Corp_Australia\", \"score\": 0.9999767232505894, \"rank\": 2.3277291406204472e-05, \"text\": \"news.com.au\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/News_Corp_Australia\", \"dbpedia\": \"http://dbpedia.org/resource/News_Corp_Australia\"}], \"noun_phrases\": [{\"ngram\": \"\\u2122\", \"from\": 2657, \"to\": 2658}, {\"ngram\": \"staff\", \"from\": 2743, \"to\": 2748}, {\"ngram\": \"a 3.5 per cent annual pay rise\", \"from\": 2762, \"to\": 2792}, {\"ngram\": \"an email\", \"from\": 2796, \"to\": 2804}, {\"ngram\": \"Wednesday\", \"from\": 2813, \"to\": 2822}, {\"ngram\": \"the two per cent\", \"from\": 2836, \"to\": 2852}, {\"ngram\": \"place\", \"from\": 2874, \"to\": 2879}]}, {\"sentence\": \"Mr Sneesby, who is currently in Paris for the Olympics,addressed Nine staff in an email in response to the industrial action, saying he was \\\"profoundly disappointed\\\".\", \"from\": 2883, \"to\": 3049, \"entities\": [{\"begin\": 2915, \"end\": 2920, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999995366124, \"rank\": 4.632817532268212e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Mr Sneesby\", \"from\": 2883, \"to\": 2893}, {\"ngram\": \"the Olympics\", \"from\": 2925, \"to\": 2937}, {\"ngram\": \"Nine staff\", \"from\": 2948, \"to\": 2958}, {\"ngram\": \"an email\", \"from\": 2962, \"to\": 2970}, {\"ngram\": \"response\", \"from\": 2974, \"to\": 2982}, {\"ngram\": \"the industrial action\", \"from\": 2986, \"to\": 3007}]}, {\"sentence\": \"\\\"It goes without saying we are profoundly disappointed by this decision as we have offered a new and improved agreement yesterday and were negotiating in good faith to a constructive outcome,\\\" Mr Sneesby wrote.\", \"from\": 3051, \"to\": 3261, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this decision\", \"from\": 3109, \"to\": 3122}, {\"ngram\": \"a new and improved agreement\", \"from\": 3142, \"to\": 3170}, {\"ngram\": \"good faith\", \"from\": 3205, \"to\": 3215}, {\"ngram\": \"a constructive outcome\", \"from\": 3219, \"to\": 3241}, {\"ngram\": \"Mr Sneesby\", \"from\": 3244, \"to\": 3254}]}, {\"sentence\": \"He acknowledged the right of unions to take industrial action but reiterated he felt a return to the negotiating table was the best way forward.\", \"from\": 3263, \"to\": 3407, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the right\", \"from\": 3279, \"to\": 3288}, {\"ngram\": \"unions\", \"from\": 3292, \"to\": 3298}, {\"ngram\": \"industrial action\", \"from\": 3307, \"to\": 3324}, {\"ngram\": \"a return\", \"from\": 3348, \"to\": 3356}, {\"ngram\": \"the negotiating table\", \"from\": 3360, \"to\": 3381}, {\"ngram\": \"the best way\", \"from\": 3386, \"to\": 3398}]}, {\"sentence\": \"\\\"While we have endeavoured to avert the industrial action, we have been preparing for the prospect of prolonged industrial action,\\\" he said.\", \"from\": 3409, \"to\": 3549, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the industrial action\", \"from\": 3445, \"to\": 3466}, {\"ngram\": \"the prospect\", \"from\": 3495, \"to\": 3507}, {\"ngram\": \"prolonged industrial action\", \"from\": 3511, \"to\": 3538}]}, {\"sentence\": \"\\\"We are well positioned to ensure our mastheads are produced and distributed for our loyal readers.\\\"\", \"from\": 3551, \"to\": 3651, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"our mastheads\", \"from\": 3585, \"to\": 3598}, {\"ngram\": \"our loyal readers\", \"from\": 3632, \"to\": 3649}]}, {\"sentence\": \"When asked if the email alleviated any of the reported anger and frustration being felt by the company's journalists, Mr Conn provided a blunt response.\", \"from\": 3653, \"to\": 3805, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the email\", \"from\": 3667, \"to\": 3676}, {\"ngram\": \"the reported anger\", \"from\": 3695, \"to\": 3713}, {\"ngram\": \"frustration\", \"from\": 3718, \"to\": 3729}, {\"ngram\": \"the company's journalists\", \"from\": 3744, \"to\": 3769}, {\"ngram\": \"Mr Conn\", \"from\": 3771, \"to\": 3778}, {\"ngram\": \"a blunt response\", \"from\": 3788, \"to\": 3804}]}, {\"sentence\": \"\\\"No, it does not, and I do not know what they have done to try and avert industrial action because, from the point of view of a journalist, they have not taken this seriously at all,\\\" he said.\", \"from\": 3807, \"to\": 3999, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"industrial action\", \"from\": 3880, \"to\": 3897}, {\"ngram\": \"the point\", \"from\": 3912, \"to\": 3921}, {\"ngram\": \"view\", \"from\": 3925, \"to\": 3929}, {\"ngram\": \"a journalist\", \"from\": 3933, \"to\": 3945}]}, {\"sentence\": \"\\\"There is been no suggestion from management about anyone not taking bonuses, about cutting back on basically junkets to Paris.\", \"from\": 4001, \"to\": 4128, \"entities\": [{\"begin\": 4122, \"end\": 4127, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999995366124, \"rank\": 4.632817532268212e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"no suggestion\", \"from\": 4016, \"to\": 4029}, {\"ngram\": \"management\", \"from\": 4035, \"to\": 4045}, {\"ngram\": \"anyone\", \"from\": 4052, \"to\": 4058}, {\"ngram\": \"bonuses\", \"from\": 4070, \"to\": 4077}, {\"ngram\": \"basically junkets\", \"from\": 4101, \"to\": 4118}]}, {\"sentence\": \"There is a lot of people over there in Paris at the moment who do not have any real direct association with Nine and the Nine newspapers.\", \"from\": 4129, \"to\": 4266, \"entities\": [{\"begin\": 4168, \"end\": 4173, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999995366124, \"rank\": 4.632817532268212e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"a lot\", \"from\": 4138, \"to\": 4143}, {\"ngram\": \"people\", \"from\": 4147, \"to\": 4153}, {\"ngram\": \"the moment\", \"from\": 4177, \"to\": 4187}, {\"ngram\": \"any real direct association\", \"from\": 4204, \"to\": 4231}, {\"ngram\": \"Nine\", \"from\": 4237, \"to\": 4241}, {\"ngram\": \"the Nine newspapers\", \"from\": 4246, \"to\": 4265}]}, {\"sentence\": \"\\\"So, we think it's been very disappointing that they have really have not done anything concrete.\\\"\", \"from\": 4268, \"to\": 4366, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"anything\", \"from\": 4347, \"to\": 4355}]}, {\"sentence\": \"It comes afterMr Sneesby announced more than 200 job cuts, mostly from the newspaper and broadcast divisions, amid plunging advertising revenue.\", \"from\": 4368, \"to\": 4512, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"afterMr Sneesby\", \"from\": 4377, \"to\": 4392}, {\"ngram\": \"more than 200 job cuts\", \"from\": 4403, \"to\": 4425}, {\"ngram\": \"the newspaper and broadcast divisions\", \"from\": 4439, \"to\": 4476}, {\"ngram\": \"plunging advertising revenue\", \"from\": 4483, \"to\": 4511}]}, {\"sentence\": \"To join the conversation, pleaselog in.Do not have an account?Register Join the conversation, you are commenting asLogout Our Apps\", \"from\": 4514, \"to\": 4646, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the conversation\", \"from\": 4522, \"to\": 4538}, {\"ngram\": \"pleaselog\", \"from\": 4540, \"to\": 4549}, {\"ngram\": \"an account?Register\", \"from\": 4565, \"to\": 4584}, {\"ngram\": \"the conversation\", \"from\": 4590, \"to\": 4606}, {\"ngram\": \"Our Apps\", \"from\": 4636, \"to\": 4644}]}]}"