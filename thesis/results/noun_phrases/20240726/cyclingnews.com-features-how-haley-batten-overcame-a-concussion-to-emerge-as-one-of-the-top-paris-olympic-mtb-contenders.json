\"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"\\\"The thing that I am happy I got out of the way is just how much energy and craziness it takes,\\\" Batten says.\", \"from\": 7090, \"to\": 7199, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The thing\", \"from\": 7091, \"to\": 7100}, {\"ngram\": \"the way\", \"from\": 7130, \"to\": 7137}, {\"ngram\": \"just how much energy\", \"from\": 7141, \"to\": 7161}, {\"ngram\": \"craziness\", \"from\": 7166, \"to\": 7175}, {\"ngram\": \"Batten\", \"from\": 7187, \"to\": 7193}]}, {\"sentence\": \"\\\"When you land at the Olympics, all the processing you go through just to get to your venue and on race day, there is all the security you have to go through just to get from the outside of the venue into the venue.\", \"from\": 7200, \"to\": 7415, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the Olympics\", \"from\": 7218, \"to\": 7230}, {\"ngram\": \"your venue\", \"from\": 7281, \"to\": 7291}, {\"ngram\": \"race day\", \"from\": 7299, \"to\": 7307}, {\"ngram\": \"all the security\", \"from\": 7318, \"to\": 7334}, {\"ngram\": \"the outside\", \"from\": 7375, \"to\": 7386}, {\"ngram\": \"the venue\", \"from\": 7390, \"to\": 7399}, {\"ngram\": \"the venue\", \"from\": 7405, \"to\": 7414}]}, {\"sentence\": \"We do not have to do that at most Worlds; you just show up and walk into your race.\\\"\", \"from\": 7416, \"to\": 7500, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"most Worlds\", \"from\": 7445, \"to\": 7456}, {\"ngram\": \"your race\", \"from\": 7489, \"to\": 7498}]}, {\"sentence\": \"Batten's Tokyo experience has left her feeling more prepared for the unique challenges of the Olympics.\", \"from\": 7504, \"to\": 7607, \"entities\": [{\"begin\": 7513, \"end\": 7518, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.9750763656456365, \"rank\": 0.02551559852659889, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"her feeling\", \"from\": 7539, \"to\": 7550}, {\"ngram\": \"the unique challenges\", \"from\": 7569, \"to\": 7590}, {\"ngram\": \"the Olympics\", \"from\": 7594, \"to\": 7606}]}, {\"sentence\": \"\\\"I am glad I had that experience.\", \"from\": 7608, \"to\": 7641, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"that experience\", \"from\": 7625, \"to\": 7640}]}, {\"sentence\": \"I loved it.\", \"from\": 7642, \"to\": 7653, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I loved racing there, but I am really excited to focus on the race itself now and feel like I am more prepared for all the hectic energy around it.\", \"from\": 7654, \"to\": 7801, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the race\", \"from\": 7712, \"to\": 7720}, {\"ngram\": \"all the hectic energy\", \"from\": 7769, \"to\": 7790}]}, {\"sentence\": \"I love it when you have to be adaptable like that, but I am also glad I had that experience.\\\"\", \"from\": 7802, \"to\": 7895, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"that experience\", \"from\": 7878, \"to\": 7893}]}, {\"sentence\": \"In Tokyo, Batten was an outside hopeful and her top-10 a surprise.\", \"from\": 7897, \"to\": 7963, \"entities\": [{\"begin\": 7900, \"end\": 7905, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.9750763656456365, \"rank\": 0.02551559852659889, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"Batten\", \"from\": 7907, \"to\": 7913}, {\"ngram\": \"an outside hopeful\", \"from\": 7918, \"to\": 7936}, {\"ngram\": \"her top-10\", \"from\": 7941, \"to\": 7951}, {\"ngram\": \"a surprise\", \"from\": 7952, \"to\": 7962}]}, {\"sentence\": \"However, after the season she's had, lying third in the World Series and 11th in the 12-month UCI rankings even with her layoff last year, she's going into Paris as a favourite for the medals.\", \"from\": 7964, \"to\": 8156, \"entities\": [{\"begin\": 8058, \"end\": 8061, \"title\": \"http://dbpedia.org/resource/Union_Cycliste_Internationale\", \"score\": 0.9999999957244654, \"rank\": 4.275555510566192e-09, \"text\": \"UCI\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Union_Cycliste_Internationale\", \"dbpedia\": \"http://dbpedia.org/resource/Union_Cycliste_Internationale\"}, {\"begin\": 8120, \"end\": 8125, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 3.7095459258796206e-19, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"the season\", \"from\": 7979, \"to\": 7989}, {\"ngram\": \"the World Series\", \"from\": 8016, \"to\": 8032}, {\"ngram\": \"11th\", \"from\": 8037, \"to\": 8041}, {\"ngram\": \"her layoff\", \"from\": 8081, \"to\": 8091}, {\"ngram\": \"a favourite\", \"from\": 8129, \"to\": 8140}, {\"ngram\": \"the medals\", \"from\": 8145, \"to\": 8155}]}, {\"sentence\": \"Batten will race alongside Savilla Blunk, the US national champion who has also scored several World Series podiums and is ranked fourth in the world, giving the USA a very good chance at a top result.\", \"from\": 8157, \"to\": 8358, \"entities\": [{\"begin\": 8203, \"end\": 8205, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999996555835107, \"rank\": 3.3612373164224717e-07, \"text\": \"US\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 8319, \"end\": 8322, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9