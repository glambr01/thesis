int.\", \"from\": 438, \"to\": 486, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A plane\", \"from\": 438, \"to\": 445}, {\"ngram\": \"a line\", \"from\": 454, \"to\": 460}, {\"ngram\": \"a point\", \"from\": 478, \"to\": 485}]}, {\"sentence\": \"Any room for error gets folded away, out of reach, tucked inside that dimensional collapse.\\u00c2 This is the problem at the heart of the long jump.\", \"from\": 487, \"to\": 631, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Any room\", \"from\": 487, \"to\": 495}, {\"ngram\": \"error\", \"from\": 500, \"to\": 505}, {\"ngram\": \"reach\", \"from\": 531, \"to\": 536}, {\"ngram\": \"that dimensional collapse\", \"from\": 552, \"to\": 577}, {\"ngram\": \"\\u00c2\", \"from\": 578, \"to\": 579}, {\"ngram\": \"the problem\", \"from\": 588, \"to\": 599}, {\"ngram\": \"the heart\", \"from\": 603, \"to\": 612}, {\"ngram\": \"the long jump\", \"from\": 616, \"to\": 629}]}, {\"sentence\": \"How can you arrange for a perfect hit on that 20-centimeter take-off board?\", \"from\": 632, \"to\": 707, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a perfect hit\", \"from\": 656, \"to\": 669}, {\"ngram\": \"that 20-centimeter take-off board\", \"from\": 673, \"to\": 706}]}, {\"sentence\": \"That question lies underneath a tangle of others.\", \"from\": 708, \"to\": 757, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"That question\", \"from\": 708, \"to\": 721}, {\"ngram\": \"a tangle\", \"from\": 738, \"to\": 746}, {\"ngram\": \"others\", \"from\": 750, \"to\": 756}]}, {\"sentence\": \"How do you adjust your mechanics for that last step?\", \"from\": 758, \"to\": 810, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"your mechanics\", \"from\": 776, \"to\": 790}, {\"ngram\": \"that last step\", \"from\": 795, \"to\": 809}]}, {\"sentence\": \"For the step before that?\", \"from\": 811, \"to\": 836, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the step\", \"from\": 815, \"to\": 823}]}, {\"sentence\": \"How do you tr