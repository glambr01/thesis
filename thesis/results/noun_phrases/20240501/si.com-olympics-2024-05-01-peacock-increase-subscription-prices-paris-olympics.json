om\": 821, \"to\": 832}, {\"ngram\": \"live and on-demand\", \"from\": 853, \"to\": 871}, {\"ngram\": \"fans\", \"from\": 876, \"to\": 880}, {\"ngram\": \"the ability\", \"from\": 891, \"to\": 902}, {\"ngram\": \"up to four events\", \"from\": 912, \"to\": 929}]}, {\"sentence\": \"NBC has the broadcast rights for the Olympics through 2032.\", \"from\": 939, \"to\": 998, \"entities\": [{\"begin\": 939, \"end\": 942, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.9989807326071695, \"rank\": 0.0006742858373711718, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}], \"noun_phrases\": [{\"ngram\": \"the broadcast rights\", \"from\": 947, \"to\": 967}, {\"ngram\": \"the Olympics\", \"from\": 972, \"to\": 984}]}, {\"sentence\": \"Peacock is clearly using sports as the main selling point of their streaming service with NFL, Olympics and even WWE, but it's also their excuse to raise prices.\", \"from\": 1000, \"to\": 1161, \"entities\": [{\"begin\": 1090, \"end\": 1093, \"title\": \"http://dbpedia.org/resource/NFL_on_Fox\", \"score\": 0.998410480619413, \"rank\": 0.001527091352554151, \"text\": \"NFL\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/NFL_on_Fox\", \"dbpedia\": \"http://dbpedia.org/resource/NFL_on_Fox\"}, {\"begin\": 1113, \"end\": 1116, \"title\": \"http://dbpedia.org/resource/WWE\", \"score\": 0.9999999699989535, \"rank\": 2.5570400242713948e-08, \"text\": \"WWE\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/WWE\", \"dbpedia\": \"http://dbpedia.org/resource/WWE\"}], \"noun_phrases\": [{\"ngram\": \"Peacock\", \"from\": 1000, \"to\": 1007}, {\"ngram\": \"sports\", \"from\": 1025, \"to\": 1031}, {\"ngram\": \"the main selling point\", \"from\": 1035, \"to\": 1057}, {\"ngram\": \"their streaming service\", \"from\": 1061, \"to\": 1084}, {\"ngram\": \"Olympics\", \"