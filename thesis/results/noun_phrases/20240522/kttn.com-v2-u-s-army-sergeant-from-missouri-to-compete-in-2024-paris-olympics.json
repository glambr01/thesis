"{\"uid\": \"kttn.com-v2-u-s-army-sergeant-from-missouri-to-compete-in-2024-paris-olympics\", \"noun_phrases\": [{\"sentence\": \"A U.S. Army sergeant from Pattonsburg, Missouri, has been selected to compete in the 2024 Paris Olympics, representing the nation on Team USA for the Women's Trap event.\", \"from\": 0, \"to\": 169, \"entities\": [{\"begin\": 7, \"end\": 11, \"title\": \"http://dbpedia.org/resource/United_States_Army\", \"score\": 0.9999923965556562, \"rank\": 2.439782800795128e-06, \"text\": \"Army\", \"types\": [\"Q43229\", \"Q24229398\", \"Q176799\"], \"wikid\": \"http://dbpedia.org/resource/United_States_Army\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_Army\"}, {\"begin\": 26, \"end\": 47, \"title\": \"http://dbpedia.org/resource/Pattonsburg,_Missouri\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Pattonsburg, Missouri\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Pattonsburg,_Missouri\", \"dbpedia\": \"http://dbpedia.org/resource/Pattonsburg,_Missouri\"}, {\"begin\": 26, \"end\": 47, \"title\": \"http://dbpedia.org/resource/Pattonsburg,_Missouri\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Pattonsburg, Missouri\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Pattonsburg,_Missouri\", \"dbpedia\": \"http://dbpedia.org/resource/Pattonsburg,_Missouri\"}, {\"begin\": 133, \"end\": 141, \"title\": \"http://dbpedia.org/resource/United_States_national_team\", \"score\": 0.999441178527851, \"rank\": 0.0005451803810055468, \"text\": \"Team USA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_national_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_national_team\"}], \"noun_phrases\": [{\"ngram\": \"the 2024 Paris Olympics\", \"from\": 81, \"to\": 104}, {\"ngram\": \"the nation\", \"from\": 119, \"to\": 129}, {\"ngram\": \"the Women's Trap event\", \"from\": 146, \"to\": 168}]}, {\"sentence\": \"Sergeant Rachel Tozier states that she has wanted to go to the Olympics since high school and specifically joined the army to shoot for the Marksmanship Unit, where she has been for the past seven and a half years.\", \"from\": 171, \"to\": 385, \"entities\": [{\"begin\": 180, \"end\": 193, \"title\": \"http://dbpedia.org/resource/Rachel_Tozier\", \"score\": 0.9999945585807635, \"rank\": 0.0, \"text\": \"Rachel Tozier\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Rachel_Tozier\", \"dbpedia\": \"http://dbpedia.org/resource/Rachel_Tozier\"}], \"noun_phrases\": [{\"ngram\": \"the Olympics\", \"from\": 230, \"to\": 242}, {\"ngram\": \"high school\", \"from\": 249, \"to\": 260}, {\"ngram\": \"the army\", \"from\": 285, \"to\": 293}, {\"ngram\": \"the Marksmanship Unit\", \"from\": 307, \"to\": 328}, {\"ngram\": \"the past seven and a half years\", \"from\": 353, \"to\": 384}]}, {\"sentence\": \"\\\"I started shooting when I was 12 years old.\", \"from\": 387, \"to\": 431, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"My stepdad got me started.\", \"from\": 432, \"to\": 458, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My stepdad\", \"from\": 432, \"to\": 442}]}, {\"sentence\": \"He put an American trap in our front yard and told me that I needed to learn how to shoot,\\\" said Tozier.\", \"from\": 459, \"to\": 563, \"entities\": [{\"begin\": 469, \"end\": 477, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999934307722694, \"rank\": 4.950465161216419e-06, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"our front yard\", \"from\": 486, \"to\": 500}, {\"ngram\": \"Tozier\", \"from\": 556, \"to\": 562}]}, {\"sentence\": \"\\\"I was reluctant at first, but after I got started, I was addicted.\\\"\", \"from\": 564, \"to\": 632, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"The hard work paid off, and while she was chosen as an alternate for the Tokyo Games in 2020, she recently qualified to participate in the 2024 Paris Olympics.\", \"from\": 634, \"to\": 793, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The hard work\", \"from\": 634, \"to\": 647}, {\"ngram\": \"an alternate\", \"from\": 686, \"to\": 698}, {\"ngram\": \"the Tokyo Games\", \"from\": 703, \"to\": 718}, {\"ngram\": \"the 2024 Paris Olympics\", \"from\": 769, \"to\": 792}]}, {\"sentence\": \"\\\"It's been a long, hard journey, but to finally make it is absolutely amazing.\", \"from\": 795, \"to\": 873, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a long, hard journey\", \"from\": 806, \"to\": 826}]}, {\"sentence\": \"There are not even words to describe what an awesome feeling it is to make the team.\\\"\", \"from\": 874, \"to\": 959, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"words\", \"from\": 893, \"to\": 898}, {\"ngram\": \"what an awesome feeling\", \"from\": 911, \"to\": 934}, {\"ngram\": \"the team\", \"from\": 949, \"to\": 957}]}, {\"sentence\": \"Tozier will be participating in an international trap, where competitors use a shotgun to shoot targets 30-35 meters away.\", \"from\": 961, \"to\": 1083, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Tozier\", \"from\": 961, \"to\": 967}, {\"ngram\": \"an international trap\", \"from\": 993, \"to\": 1014}, {\"ngram\": \"competitors\", \"from\": 1022, \"to\": 1033}, {\"ngram\": \"a shotgun\", \"from\": 1038, \"to\": 1047}, {\"ngram\": \"targets\", \"from\": 1057, \"to\": 1064}]}, {\"sentence\": \"Her personal best is shooting 122 targets out of 125.\", \"from\": 1084, \"to\": 1137, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"122 targets\", \"from\": 1114, \"to\": 1125}]}, {\"sentence\": \"A score of 120 is considered really good, but Tozier still trains daily for the big day.\", \"from\": 1138, \"to\": 1226, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A score\", \"from\": 1138, \"to\": 1145}, {\"ngram\": \"Tozier\", \"from\": 1184, \"to\": 1190}, {\"ngram\": \"the big day\", \"from\": 1214, \"to\": 1225}]}, {\"sentence\": \"\\\"Training every day, just go out, shoot a couple of rounds, take a little break.\", \"from\": 1228, \"to\": 1308, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a couple\", \"from\": 1268, \"to\": 1276}, {\"ngram\": \"rounds\", \"from\": 1280, \"to\": 1286}, {\"ngram\": \"a little break\", \"from\": 1293, \"to\": 1307}]}, {\"sentence\": \"I am probably shooting six to eight rounds a day, so between 150 and 200 targets a day, just getting ready for this.\", \"from\": 1309, \"to\": 1425, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"six to eight rounds\", \"from\": 1332, \"to\": 1351}, {\"ngram\": \"so between 150 and 200 targets\", \"from\": 1359, \"to\": 1389}]}, {\"sentence\": \"I shoot five days a week, so it's a heavy load, but it's great to get the training and be able to go out and train whenever I want, however much I want.\\\"\", \"from\": 1426, \"to\": 1579, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a heavy load\", \"from\": 1460, \"to\": 1472}, {\"ngram\": \"the training\", \"from\": 1496, \"to\": 1508}]}, {\"sentence\": \"To any aspiring marksmen looking to go big like her, Tozier says to keep pushing yourself.\", \"from\": 1581, \"to\": 1671, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"any aspiring marksmen\", \"from\": 1584, \"to\": 1605}, {\"ngram\": \"Tozier\", \"from\": 1634, \"to\": 1640}]}, {\"sentence\": \"\\\"It took me 14 years from the time I wrote that on my board, and I had never shot an international target before at that point.\", \"from\": 1673, \"to\": 1800, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the time\", \"from\": 1699, \"to\": 1707}, {\"ngram\": \"my board\", \"from\": 1724, \"to\": 1732}, {\"ngram\": \"an international target\", \"from\": 1755, \"to\": 1778}, {\"ngram\": \"that point\", \"from\": 1789, \"to\": 1799}]}, {\"sentence\": \"So just keep pushing.\", \"from\": 1801, \"to\": 1822, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"You may not make it the first time, but keep trying.\\\"\", \"from\": 1823, \"to\": 1876, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Tozier will compete late this summer in Paris and states that her family has been her biggest support system during this accomplishment.\", \"from\": 1878, \"to\": 2014, \"entities\": [{\"begin\": 1918, \"end\": 1923, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999975717873817, \"rank\": 2.428218564947878e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Tozier\", \"from\": 1878, \"to\": 1884}, {\"ngram\": \"her family\", \"from\": 1940, \"to\": 1950}, {\"ngram\": \"her biggest support system\", \"from\": 1960, \"to\": 1986}, {\"ngram\": \"this accomplishment\", \"from\": 1994, \"to\": 2013}]}, {\"sentence\": \"http://www.kttn.com\", \"from\": 2016, \"to\": 2035, \"entities\": [], \"noun_phrases\": []}]}"