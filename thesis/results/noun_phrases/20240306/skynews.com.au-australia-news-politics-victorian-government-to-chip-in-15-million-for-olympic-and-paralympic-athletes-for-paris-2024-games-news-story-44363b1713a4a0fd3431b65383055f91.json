bpedia.org/resource/Jacinta_Allan\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Jacinta Allan\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jacinta_Allan\", \"dbpedia\": \"http://dbpedia.org/resource/Jacinta_Allan\"}, {\"begin\": 224, \"end\": 244, \"title\": \"http://dbpedia.org/resource/Victoria_State_Government\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Victorian government\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Victoria_State_Government\", \"dbpedia\": \"http://dbpedia.org/resource/Victoria_State_Government\"}, {\"begin\": 336, \"end\": 341, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999997496161399, \"rank\": 2.503839306752259e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"a financial contribution\", \"from\": 258, \"to\": 282}, {\"ngram\": \"Australians\", \"from\": 294, \"to\": 305}]}, {\"sentence\": \"Ms Allan revealed to reporters on Thursday the government would chip in $1.5 million to be shared equally between Olympic and Paralympic athletes at this year's games.\", \"from\": 350, \"to\": 517, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Ms Allan\", \"from\": 350, \"to\": 358}, {\"ngram\": \"reporters\", \"from\": 371, \"to\": 380}, {\"ngram\": \"Thursday\", \"from\": 384, \"to\": 392}, {\"ngram\": \"the government\", \"from\": 393, \"to\": 407}, {\"ngram\": \"Olympic and Paralympic athletes\", \"from\": 464, \"to\": 495}, {\"ngram\": \"this year's games\", \"from\": 499, \"to\": 516}]}, {\"sentence\": \"The news came amid concerns being raised about the government giving athletes the \\\"run-around\\\" after being asked for funding in October and again in December.\", \"from\": 519, \"to\": 677, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The news\", \"from\": 519, \"to\": 527}, {\"ngram\": \"concerns\", \"from\": 538, \"to\": 546}, {\"ngram\": \"the government\", \"from\": 566, \"to\": 580}, {\"ngram\": \"athletes\", \"from\": 588, \"to\": 596}, {\"ngram\": \"the \\\"run-around\", \"from\": 597, \"to\": 612}, {\"ngram\": \"funding\", \"from\": 636, \"to\": 643}, {\"ngram\": \"October\", \"from\": 647, \"to\": 654}, {\"ngram\": \"December\", \"from\": 668, \"to\": 676}]}, {\"sentence\": \"Ms Allan said the financial support was only confirmed on Wednesday night at a budget committee meeting.\", \"from\": 679, \"to\": 783, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Ms Allan\", \"from\": 679, \"to\": 687}, {\"ngram\": \"the financial support\", \"from\": 693, \"to\": 714}, {\"ngram\": \"Wednesday night\", \"from\": 737, \"to\": 752}, {\"ngram\": \"a budget committee meeting\", \"from\": 756, \"to\": 782}]}, {\"sentence\": \"\\\"I am really pleased this morning to be able to confirm that the Victorian government will make a $1.5 million contribution split equally between our Olympic and Paralympic teams who are heading off to Paris,\\\" she said.\", \"from\": 785, \"to\": 1004, \"entities\": [{\"begin\": 850, \"end\": 870, \"title\": \"http://dbpedia.org/resource/Victoria_State_Government\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Victorian government\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Victoria_State_Government\", \"dbpedia\": \"http://dbpedia.org/resource/Victoria_State_Government\"}, {\"begin\": 987, \"end\": 992, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999997496161399, \"rank\": 2.503839306752259e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"a $1.5 million contribution\", \"from\": 881, \"to\": 908}, {\"ngram\": \"our Olympic and Paralympic teams\", \"from\": 931, \"to\": 963}]}, {\"sentence\": \"\\\"We wish our athletes all the very best as they go and represent not just Victoria but indeed the nation\\u2026 and we are really proud to be able to provide this support.\\\"\", \"from\": 1006, \"to\": 1172, \"entities\": [{\"begin\": 1080, \"end\": 1088, \"title\": \"http://dbpedia.org/resource/Victoria_Australian_rules_football_team\", \"score\": 0.8439349875850912, \"rank\": 0.17526948773408643, \"text\": \"Victoria\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Victoria_Australian_rules_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Victoria_Australian_rules_football_team\"}], \"noun_phrases\": [{\"ngram\": \"our athletes\", \"from\": 1015, \"to\": 1027}, {\"ngram\": \"indeed the nation\", \"from\": 1093, \"to\": 1110}, {\"ngram\": \"this support\", \"from\": 1158, \"to\": 1170}]}, {\"sentence\": \"But shadow tourism, sport and events minister Sam Groth blasted the government for taking so long to confirm the funding, after previously axing the 2026 Commonwealth Games planned for regional Victoria.\", \"from\": 1174, \"to\": 1377, \"entities\": [{\"begin\": 1220, \"end\": 1229, \"title\": \"http://dbpedia.org/resource/Sam_Groth\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Sam Groth\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10833314\"], \"wikid\": \"http://dbpedia.org/resource/Sam_Groth\", \"dbpedia\": \"http://dbpedia.org/resource/Sam_Groth\"}, {\"begin\": 1368, \"end\": 1376, \"title\": \"http://dbpedia.org/resource/Victoria_Australian_rules_football_team\", \"score\": 0.8439349875850912, \"rank\": 0.17526948773408643, \"text\": \"Victoria\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Victoria_Australian_rules_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Victoria_Australian_rules_football_team\"}], \"noun_phrases\": [{\"ngram\": \"shadow tourism\", \"from\": 1178, \"to\": 1192}, {\"ngram\": \"the government\", \"from\": 1238, \"to\": 1252}, {\"ngram\": \"the funding\", \"from\": 1283, \"to\": 1294}, {\"ngram\": \"the 2026 Commonwealth Games\", \"from\": 1319, \"to\": 1346}]}, {\"sentence\": \"\\\"It's a disgrace that Labor could find $600 million to cancel the Commonwealth games, but gave Olympic and Paralympic athletes the run-around for months over just $1.5 million,\\\" Mr Groth said.\", \"from\": 1379, \"to\": 1571, \"entities\": [{\"begin\": 1401, \"end\": 1406, \"title\": \"http://dbpedia.org/resource/Australian_Labor_Party\", \"score\": 1.0, \"rank\": 1.7440617013240325e-15, \"text\": \"Labor\", \"types\": [\"Q7278\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Australian_Labor_Party\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_Labor_Party\"}, {\"begin\": 1445, \"end\": 1463, \"title\": \"http://dbpedia.org/resource/Commonwealth_Games\", \"score\": 0.9956146141760182, \"rank\": 0.0032957482899993533, \"text\": \"Commonwealth games\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Commonwealth_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Commonwealth_Games\"}], \"noun_phrases\": [{\"ngram\": \"a disgrace\", \"from\": 1385, \"to\": 1395}, {\"ngram\": \"the run-around\", \"from\": 1506, \"to\": 1520}, {\"ngram\": \"months\", \"from\": 1525, \"to\": 1531}, {\"ngram\": \"Mr Groth\", \"from\": 1557, \"to\": 1565}]}, {\"sentence\": \"\\\"The Liberals and Nationals support this funding commitment, but it never should have been this difficult.\\\"\", \"from\": 1573, \"to\": 1680, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The Liberals\", \"from\": 1574, \"to\": 1586}, {\"ngram\": \"Nationals\", \"from\": 1591, \"to\": 1600}, {\"ngram\": \"this funding commitment\", \"from\": 1609, \"to\": 1632}]}, {\"sentence\": \"New South Wales, Queensland, Western Australia and the Australian Capital Territory have reportedly already made contributions to the athletes.\", \"from\": 1682, \"to\": 1825, \"entities\": [{\"begin\": 1699, \"end\": 1709, \"title\": \"http://dbpedia.org/resource/Queensland\", \"score\":