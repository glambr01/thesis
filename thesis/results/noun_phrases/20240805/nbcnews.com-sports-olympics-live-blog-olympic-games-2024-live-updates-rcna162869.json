es\": [{\"ngram\": \"the pommel horse\", \"from\": 53850, \"to\": 53866}, {\"ngram\": \"\\u00c2 fencing\", \"from\": 53867, \"to\": 53876}, {\"ngram\": \"its origins\", \"from\": 53886, \"to\": 53897}, {\"ngram\": \"military training\", \"from\": 53901, \"to\": 53918}, {\"ngram\": \"a sport\", \"from\": 53947, \"to\": 53954}]}, {\"sentence\": \"The earliest depiction of swordplay is a relief in the temple of Med\\u00c4\\u00abnat Habu, built by Egyptian pharaoh Ramses III in about 1190 BCE, near to the Egyptian city of Luxor.\", \"from\": 53957, \"to\": 54128, \"entities\": [{\"begin\": 54046, \"end\": 54054, \"title\": \"http://dbpedia.org/resource/Ancient_Egypt\", \"score\": 0.907730903871674, \"rank\": 0.1009878865848257, \"text\": \"Egyptian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ancient_Egypt\", \"dbpedia\": \"http://dbpedia.org/resource/Ancient_Egypt\"}, {\"begin\": 54063, \"end\": 54073, \"title\": \"http://dbpedia.org/resource/Ramesses_III\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Ramses III\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Ramesses_III\", \"dbpedia\": \"http://dbpedia.org/resource/Ramesses_III\"}, {\"begin\": 54105, \"end\": 54113, \"title\": \"http://dbpedia.org/resource/Ancient_Egypt\", \"score\": 0.907730903871674, \"rank\": 0.1009878865848257, \"text\": \"Egyptian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ancient_Egypt\", \"dbpedia\": \"http://dbpedia.org/resource/Ancient_Egypt\"}, {\"begin\": 54122, \"end\": 54127, \"title\": \"http://dbpedia.org/resource/Luxor\", \"score\": 0.999892840187541, \"rank\": 0.00010717129685719823, \"text\": \"Luxor\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Luxor\", \"dbpedia\": \"http://dbpedia.org/resource/Luxor\"}], \"noun_phrases\": [{\"ngram\": \"The earliest depiction\", \"from\": 53957, \"to\": 53979}, {\"ngram\": \"swordplay\", \"from\": 53983, \"to\": 53992}, {\"ngram\": \"a relief\", \"from\": 53996, \"to\": 54004}, {\"ngram\": \"the temple\", \"from\": 54008, \"to\": 54018}, {\"ngram\": \"Med\\u00c4\\u00abnat Habu\", \"from\": 54022, \"to\": 54035}, {\"ngram\": \"about 1190 BCE\", \"from\": 54077, \"to\": 54091}]}, {\"sentence\": \"But it wasn\\u00e2\\u0080\\u0099t until two-and-a-half thousand years later that it became a sport.\", \"from\": 54130, \"to\": 54211, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a sport\", \"from\": 54203, \"to\": 54210}]}, {\"sentence\": \"Inspired by the Italian, German and French fencing masters of the early 15th century, it made the transition from a form of military training to sport.\", \"from\": 54213, \"to\": 54364, \"entities\": [{\"begin\": 54229, \"end\": 54236, \"title\": \"http://dbpedia.org/resource/Italian_language\", \"score\": 0.9978716770851347, \"rank\": 0.0010378780928794787, \"text\": \"Italian\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Italian_language\", \"dbpedia\": \"http://dbpedia.org/resource/Italian_language\"}, {\"begin\": 54238, \"end\": 54244, \"title\": \"http://dbpedia.org/resource/German_language\", \"score\": 0.9940564966629641, \"rank\": 0.005375119964403956, \"text\": \"German\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/German_language\", \"dbpedia\": \"http://dbpedia.org/resource/German_language\"}, {\"begin\": 54249, \"end\": 54255, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9614258421730311, \"rank\": 0.0368665561826591, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"the early 15th century\", \"from\": 54275, \"to\": 54297}, {\"ngram\": \"the transition\", \"from\": 54307, \"to\": 54321}, {\"ngram\": \"a form\", \"from\": 54327, \"to\": 54333}, {\"ngram\": \"military training\", \"from\": 54337, \"to\": 54354}, {\"ngram\": \"sport\", \"from\": 54358, \"to\": 54363}]}, {\"sentence\": \"German fencing masters then began organizing the first guilds, including the famous Marxbrueder of Frankfurt in 1478.\", \"from\": 54365, \"to\": 54482, \"entities\": [{\"begin\": 54365, \"end\": 54371, \"title\": \"http://dbpedia.org/resource/German_language\", \"score\": 0.9674015709994388, \"rank\": 0.031334489831172894, \"text\": \"German\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/German_language\", \"dbpedia\": \"http://dbpedia.org/resource/German_language\"}], \"noun_phrases\": [{\"ngram\": \"the first guilds\", \"from\": 54410, \"to\": 54426}, {\"ngram\": \"the famous Marxbrueder\", \"from\": 54438, \"to\": 54460}, {\"ngram\": \"Frankfurt\", \"from\": 54464, \"to\": 54473}]}, {\"sentence\": \"By the 17th and 18th centuries, the sport of fencing had already begun to resemble what is seen at the Olympics today, with the invention of the flat-tipped foil weapon and wire-mesh masks, as well as rules governing procedure and target area.\", \"from\": 54484, \"to\": 54727, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the 17th and 18th centuries\", \"from\": 54487, \"to\": 54514}, {\"ngram\": \"the sport\", \"from\": 54516, \"to\": 54525}, {\"ngram\": \"fencing\", \"from\": 54529, \"to\": 54536}, {\"ngram\": \"the Olympics\", \"from\": 54583, \"to\": 54595}, {\"ngram\": \"the invention\", \"from\": 54608, \"to\": 54621}, {\"ngram\": \"the flat-tipped foil weapon and wire-mesh masks\", \"from\": 54625, \"to\": 54672}, {\"ngram\": \"rules\", \"from\": 54685, \"to\": 54690}, {\"ngram\": \"procedure and target area\", \"from\": 54701, \"to\": 54726}]}, {\"sentence\": \"The stage is set for an epic finale in the men's golf competition with Team USA's Xander Schauffele tied with Jon Rahm at the top of the leaderboard heading into today's finely-poised final round at Le Golf National.\", \"from\": 54729, \"to\": 54945, \"entities\": [{\"begin\": 54800, \"end\": 54808, \"title\": \"http://dbpedia.org/reso