"{\"uid\": \"cbsnews.com-news-suni-lee-2024-paris-olympics-gymnast-i-gave-it-my-all\", \"noun_phrases\": [{\"sentence\": \"Watch CBS News August 5, 2024 / 2:54 PM EDT/ CBS News Two-time OlympianSuni Leeis proud of her performance at theParis Olympics, saying \\\"I gave it my all, and that's all that matters.\", \"from\": 0, \"to\": 185, \"entities\": [{\"begin\": 6, \"end\": 14, \"title\": \"http://dbpedia.org/resource/CBS_News\", \"score\": 0.9986044484070979, \"rank\": 0.0013974958552248125, \"text\": \"CBS News\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/CBS_News\", \"dbpedia\": \"http://dbpedia.org/resource/CBS_News\"}, {\"begin\": 46, \"end\": 54, \"title\": \"http://dbpedia.org/resource/CBS_News\", \"score\": 0.9986044484070979, \"rank\": 0.0013974958552248125, \"text\": \"CBS News\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/CBS_News\", \"dbpedia\": \"http://dbpedia.org/resource/CBS_News\"}], \"noun_phrases\": [{\"ngram\": \"Two-time OlympianSuni Leeis\", \"from\": 54, \"to\": 81}, {\"ngram\": \"her performance\", \"from\": 91, \"to\": 106}, {\"ngram\": \"theParis Olympics\", \"from\": 110, \"to\": 127}]}, {\"sentence\": \"The 21-year-old Team USA gymnast won bronze in the uneven bars final on Sunday - her third medal of the 2024 Paris Games.\", \"from\": 186, \"to\": 307, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The 21-year-old Team USA gymnast\", \"from\": 186, \"to\": 218}, {\"ngram\": \"bronze\", \"from\": 223, \"to\": 229}, {\"ngram\": \"the uneven bars\", \"from\": 233, \"to\": 248}, {\"ngram\": \"Sunday - her third medal\", \"from\": 258, \"to\": 282}, {\"ngram\": \"the 2024 Paris Games\", \"from\": 286, \"to\": 306}]}, {\"sentence\": \"On Monday, she fell during the balance beam final.\", \"from\": 308, \"to\": 358, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Monday\", \"from\": 311, \"to\": 317}, {\"ngram\": \"the balance beam final\", \"from\": 335, \"to\": 357}]}, {\"sentence\": \"\\\"I did not even think that I would make it this far,\\\" Lee told CBS News on Monday.\", \"from\": 360, \"to\": 442, \"entities\": [{\"begin\": 414, \"end\": 417, \"title\": \"http://dbpedia.org/resource/Cliff_Lee\", \"score\": 0.9958990581452102, \"rank\": 0.0039025955331304265, \"text\": \"Lee\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Cliff_Lee\", \"dbpedia\": \"http://dbpedia.org/resource/Cliff_Lee\"}, {\"begin\": 423, \"end\": 431, \"title\": \"http://dbpedia.org/resource/CBS_News\", \"score\": 0.9986044484070979, \"rank\": 0.0013974958552248125, \"text\": \"CBS News\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/CBS_News\", \"dbpedia\": \"http://dbpedia.org/resource/CBS_News\"}], \"noun_phrases\": [{\"ngram\": \"Monday\", \"from\": 435, \"to\": 441}]}, {\"sentence\": \"\\\"So I am trying to give myself a little bit of grace and be like, OK, we did not even think that we would be at the Olympics.\", \"from\": 443, \"to\": 568, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a little bit\", \"from\": 474, \"to\": 486}, {\"ngram\": \"grace\", \"from\": 490, \"to\": 495}, {\"ngram\": \"the Olympics\", \"from\": 555, \"to\": 567}]}, {\"sentence\": \"So making it to the final was just kind of a bonus.\\\"\", \"from\": 569, \"to\": 621, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"kind of a bonus\", \"from\": 604, \"to\": 619}]}, {\"sentence\": \"In 2023, Lee was diagnosed with two kidney diseases that put her training schedule on hold and her Olympic dreams into question.\", \"from\": 623, \"to\": 751, \"entities\": [{\"begin\": 632, \"end\": 635, \"title\": \"http://dbpedia.org/resource/Cliff_Lee\", \"score\": 0.9958990581452102, \"rank\": 0.0039025955331304265, \"text\": \"Lee\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Cliff_Lee\", \"dbpedia\": \"http://dbpedia.org/resource/Cliff_Lee\"}], \"noun_phrases\": [{\"ngram\": \