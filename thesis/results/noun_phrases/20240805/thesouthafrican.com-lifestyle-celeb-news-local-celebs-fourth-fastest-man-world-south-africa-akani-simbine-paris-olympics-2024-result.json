\": []}, {\"sentence\": \"He has been dubbed the most consistent sprinter in the world since the Rio Games in 2016, where he finished fifth in 9.94.\", \"from\": 1372, \"to\": 1494, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the most consistent sprinter\", \"from\": 1391, \"to\": 1419}, {\"ngram\": \"the world\", \"from\": 1423, \"to\": 1432}, {\"ngram\": \"the Rio Games\", \"from\": 1439, \"to\": 1452}]}, {\"sentence\": \"In 2021, at the Tokyo Olympics, he finished in fourth place with 9.94.\", \"from\": 1495, \"to\": 1565, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the Tokyo Olympics\", \"from\": 1507, \"to\": 1525}, {\"ngram\": \"fourth place\", \"from\": 1542, \"to\": 1554}]}, {\"sentence\": \"This year in Paris he finished fourth again, this time in 9.82.\", \"from\": 1566, \"to\": 1629, \"entities\": [{\"begin\": 1579, \"end\": 1584, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999872671, \"rank\": 1.255354703455033e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": []}, {\"sentence\": \"Simbine said that he was happy to have set a South African record and he is not yet done with the sport.\", \"from\": 1631, \"to\": 1735, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Simbine\", \"from\": 1631, \"to\": 1638}, {\"ngram\": \"a South African record\", \"from\": 1674, \"to\": 1696}, {\"ngram\": \"the sport\", \"from\": 1725, \"to\": 1734}]}, {\"sentence\": \"He explained that he started sprinting late in life and he still wants to get more out of it.\", \"from\": 1736, \"to\": 1829, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"life\", \"from\": 1783, \"to\": 1787}]}, {\"sentence\": \"\\\"I am happy to have got a national record, I am happy to have been in the final.\", \"from\": 1831, \"to\": 1911, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a national record\", \"from\": 1855, \"to\":