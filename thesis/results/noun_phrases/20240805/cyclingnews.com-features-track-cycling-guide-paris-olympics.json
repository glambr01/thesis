\": [], \"noun_phrases\": [{\"ngram\": \"the answers\", \"from\": 1170, \"to\": 1181}, {\"ngram\": \"almost every question\", \"from\": 1185, \"to\": 1206}, {\"ngram\": \"track cycling\", \"from\": 1228, \"to\": 1241}, {\"ngram\": \"our Frequently Asked Questions section\", \"from\": 1245, \"to\": 1283}]}, {\"sentence\": \"Considered an endurance event (as opposed to a sprint), despite taking only around four minutes, the team pursuit consists of four riders riding 4,000m, or 16 laps of the track, with two teams starting at opposite sides of the track in all but the first round.\", \"from\": 1288, \"to\": 1548, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an endurance event\", \"from\": 1299, \"to\": 1317}, {\"ngram\": \"a sprint\", \"from\": 1333, \"to\": 1341}, {\"ngram\": \"only around four minutes\", \"from\": 1359, \"to\": 1383}, {\"ngram\": \"the team pursuit\", \"from\": 1385, \"to\": 1401}, {\"ngram\": \"four riders\", \"from\": 1414, \"to\": 1425}, {\"ngram\": \"4,000m\", \"from\": 1433, \"to\": 1439}, {\"ngram\": \"16 laps\", \"from\": 1444, \"to\": 1451}, {\"ngram\": \"the track\", \"from\": 1455, \"to\": 1464}, {\"ngram\": \"two teams\", \"from\": 1471, \"to\": 1480}, {\"ngram\": \"opposite sides\", \"from\": 1493, \"to\": 1507}, {\"ngram\": \"the track\", \"from\": 1511, \"to\": 1520}, {\"ngram\": \"the first round\", \"from\": 1532, \"to\": 1547}]}, {\"sentence\": \"The team pursuit requires precision for the riders to keep close to each other to slipstream the lead rider, who will peel off up the banking and take their place at the rear of the train.\", \"from\": 1550, \"to\": 1738, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The team pursuit\", \"from\": 1550, \"to\": 1566}, {\"ngram\": \"precision\", \"from\": 1576, \"to\": 1585}, {\"ngram\": \"the riders\", \"from\": 1590, \"to\": 1600}, {\"ngram\": \"the lead rider\", \"from\": 1643, \"to\": 1657}, {\"ngram\": \"the banking\", \"from\": 1680, \"to\": 1691}, {\"ngram\": \"their place\", \"from\": 1701, \"to\": 1712}, {\"ngram\": \"the rear\", \"from\": 1716, \"to\": 1724}, {\"ngram\": \"the train\", \"from\": 1728, \"to\": 1737}]}, {\"sentence\": \"Riders take in turns on the front to maximise the speed of the team as a whole.\", \"from\": 1739, \"to\": 1818, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Riders\", \"from\": 1739, \"to\": 1745}, {\"ngram\": \"turns\", \"from\": 1754, \"to\": 1759}, {\"ngram\": \"the front\", \"from\": 1763, \"to\": 1772}, {\"ngram\": \"the speed\", \"from\": 1785, \"to\": 1794}, {\"ngram\": \"the team\", \"from\": 1798, \"to\": 1806}, {\"ngram\": \"a whole\", \"from\": 1810, \"to\": 1817}]}, {\"sentence\": \"The latest race content, interviews, features, reviews and expert buying guides, direct to your inbox!\", \"from\": 1820, \"to\": 1922, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The latest race content\", \"from\": 1820, \"to\": 1843}, {\"ngram\": \"interviews\", \"from\": 1845, \"to\": 1855}, {\"ngram\": \"features\", \"from\": 1857, \"to\": 1865}, {\"ngram\": \"reviews\", \"from\": 1867, \"to\": 1874}, {\"ngram\": \"expert buying guides\", \"from\": 1879, \"to\": 1899}, {\"ngram\": \"your inbox\", \"from\": 1911, \"to\": 1921}]}, {\"sentence\": \"There are three rounds to the competition.\", \"from\": 1924, \"to\": 1966, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"three rounds\", \"from\": 1934, \"to\": 1946}, {\"ngram\": \"the competition\", \"from\": 1950, \"to\": 1965}]}, {\"sentence\": \"Early rounds are against the clock, and in the knockout rounds, two teams race on opposite sides of the track.\", \"from\": 1967, \"to\": 2077, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Early rounds\", \"from\": 1967, \"to\": 1979}, {\"ngram\": \"the clock\", \"from\": 1992, \"to\": 2001}, {\"ngram\": \"the knockout\", \"from\": 2010, \"to\": 2022}, {\"ngram\": \"rounds\", \"from\": 2023, \"to\": 2029}, {\"ngram\": \"two teams\", \"from\": 2031, \"to\": 2040}, {\"ngram\": \"opposite sides\", \"from\": 2049, \"to\": 2063}, {\"ngram\": \"the track\", \"from\": 2067, \"to\": 2076}]}, {\"sentence\": \"The time is taken for the third rider in the team, so teams will often have one rider spend more time on the front in the opening section before peeling off.\", \"from\": 2078, \"to\": 2235, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The time\", \"from\": 2078, \"to\": 2086}, {\"ngram\": \"the third rider\", \"from\": 2100, \"to\": 2115}, {\"ngram\": \"the team\", \"from\": 2119, \"to\": 2127}, {\"ngram\": \"teams\", \"from\": 2132, \"to\": 2137}, {\"ngram\": \"one rider\", \"from\": 2154, \"to\": 2163}, {\"ngram\": \"more time\", \"from\": 2170, \"to\": 2179}, {\"ngram\": \"the front\", \"from\": 2183, \"to\": 2192}, {\"ngram\": \"the opening section\", \"from\": 2196, \"to\": 2215}]}, {\"sentence\": \"Readwhat is the team pursuitfor more details.\", \"from\": 2237, \"to\": 2282, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Readwhat\", \"from\": 2237, \"to\": 2245}, {\"ngram\": \"the team\", \"from\": 2249, \"to\": 2257}, {\"ngram\": \"more details\", \"from\": 2269, \"to\": 2281}]}, {\"sentence\": \"The team sprint is a timed race over a set number of laps of the velodrome.\", \"from\": 2286, \"to\": 2361, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The team sprint\", \"from\": 2286, \"to\": 2301}, {\"ngram\": \"a timed race\", \"from\": 2305, \"to\": 2317}, {\"ngram\": \"a set number\", \"from\": 2323, \"to\": 2335}, {\"ngram\": \"laps\", \"from\": 2339, \"to\": 2343}, {\"ngram\": \"the velodrome\", \"from\": 2347, \"to\": 2360}]}, {\"sentence\": \"Women would previously race as a team of two over 2km, while men would race as threes over 3km.\", \"from\": 2362, \"to\": 2457, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Women\", \"from\": 2362, \"to\": 2367}, {\"ngram\": \"a team\", \"from\": 2393, \"to\": 2399}, {\"ngram\": \"two over 2km\", \"from\": 2403, \"to\": 2415}, {\"ngram\": \"men\", \"from\": 2423, \"to\": 2426}, {\"ngr