"{\"uid\": \"jamaicaobserver.com-2024-08-05-parisolympics-pryce-williams-bromfield-400m-semis\", \"noun_phrases\": [{\"sentence\": \"Nickisha Pryce got her quest for a medal in the women's 400m at the Paris Olympics off to a smooth start on Monday, winning her first round heat in 50.02 seconds at Stade de France to lead all three Jamaicans through to the semi-finals.\", \"from\": 0, \"to\": 236, \"entities\": [{\"begin\": 165, \"end\": 180, \"title\": \"http://dbpedia.org/resource/Stade_de_France\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Stade de France\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Stade_de_France\", \"dbpedia\": \"http://dbpedia.org/resource/Stade_de_France\"}, {\"begin\": 199, \"end\": 208, \"title\": \"http://dbpedia.org/resource/Jamaicans\", \"score\": 0.9999999979015683, \"rank\": 1.1900589849366744e-09, \"text\": \"Jamaicans\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Jamaicans\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaicans\"}], \"noun_phrases\": [{\"ngram\": \"Nickisha Pryce\", \"from\": 0, \"to\": 14}, {\"ngram\": \"her quest\", \"from\": 19, \"to\": 28}, {\"ngram\": \"a medal\", \"from\": 33, \"to\": 40}, {\"ngram\": \"the women's 400m\", \"from\": 44, \"to\": 60}, {\"ngram\": \"the Paris Olympics\", \"from\": 64, \"to\": 82}, {\"ngram\": \"a smooth start\", \"from\": 90, \"to\": 104}, {\"ngram\": \"Monday\", \"from\": 108, \"to\": 114}, {\"ngram\": \"her first round heat\", \"from\": 124, \"to\": 144}, {\"ngram\": \"50.02 seconds\", \"from\": 148, \"to\": 161}, {\"ngram\": \"the semi\", \"from\": 220, \"to\": 228}, {\"ngram\": \"finals\", \"from\": 229, \"to\": 235}]}, {\"sentence\": \"Stacey-Ann Williams was second in her heat in a season's best 50.16 seconds while Junelle Bromfield was third in her heat in 51.36 seconds.\", \"from\": 238, \"to\": 377, \"entities\": [{\"begin\": 320, \"end\": 337, \"title\": \"http://dbpedia.org/resource/Junelle_Bromfield\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Junelle Bromfield\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Junelle_Bromfield\", \"dbpedia\": \"http://dbpedia.org/resource/Junelle_Bromfield\"}], \"noun_phrases\": [{\"ngram\": \"Stacey-Ann Williams\", \"from\": 238, \"to\": 257}, {\"ngram\": \"her heat\", \"from\": 272, \"to\": 280}, {\"ngram\": \"a season's best 50.16 seconds\", \"from\": 284, \"to\": 313}, {\"ngram\": \"her heat\", \"from\": 351, \"to\": 359}, {\"ngram\": \"51.36 seconds\", \"from\": 363, \"to\": 376}]}, {\"sentence\": \"Pryce, the world leader with 48.57 seconds set two weeks ago at the London Diamond League, was not pushed in her heat, beating Great Britain's Laviai Nielsen who was second in 50.36 seconds and Norway's Henriette Jaeger who was third in 50.39 seconds.\", \"from\": 379, \"to\": 630, \"entities\": [{\"begin\": 447, \"end\": 453, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.7921951867991505, \"rank\": 0.26231056043512535, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}, {\"begin\": 454, \"end\": 468, \"title\": \"http://dbpedia.org/resource/Diamond_League\", \"score\": 0.9885907583650331, \"rank\": 0.006220430866353647, \"text\": \"Diamond League\", \"types\": [\"Q623109\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Diamond_League\", \"dbpedia\": \"http://dbpedia.org/resource/Diamond_League\"}, {\"begin\": 506, \"end\": 519, \"title\": \"http://dbpedia.org/resource/Great_Britain_at_the_Olympics\", \"score\": 0.999992212384169, \"rank\": 7.591088449457039e-06, \"text\": \"Great Britain\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Great_Britain_at_the_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Great_Britain_at_the_Olympics\"}, {\"begin\": 522, \"end\": 536, \"title\": \"http://dbpedia.org/resource/Laviai_Nielsen\", \"score