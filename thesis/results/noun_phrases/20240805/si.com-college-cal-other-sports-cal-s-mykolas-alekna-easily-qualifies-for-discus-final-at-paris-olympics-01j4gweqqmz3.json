"{\"uid\": \"si.com-college-cal-other-sports-cal-s-mykolas-alekna-easily-qualifies-for-discus-final-at-paris-olympics-01j4gweqqmz3\", \"noun_phrases\": [{\"sentence\": \"In this story: Updated World-recordholder Mykolas Alekna needed just two throws in the men's discus qualifying on Monday to lock up a spot in the Paris Olympics final.\", \"from\": 0, \"to\": 169, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this story\", \"from\": 3, \"to\": 13}, {\"ngram\": \"Updated World-recordholder Mykolas Alekna\", \"from\": 15, \"to\": 56}, {\"ngram\": \"just two throws\", \"from\": 64, \"to\": 79}, {\"ngram\": \"the men's discus qualifying\", \"from\": 83, \"to\": 110}, {\"ngram\": \"Monday\", \"from\": 114, \"to\": 120}, {\"ngram\": \"a spot\", \"from\": 132, \"to\": 138}]}, {\"sentence\": \"After fouling on his first attempt, the Cal junior from Lithuania uncorked a throw of 221 feet, 4 inches (67.47 meters) to achieve the automatic qualifying standard of 66 meters.\", \"from\": 171, \"to\": 349, \"entities\": [{\"begin\": 211, \"end\": 214, \"title\": \"http://dbpedia.org/resource/California_Golden_Bears\", \"score\": 0.9989744358516081, \"rank\": 0.0010266107189045855, \"text\": \"Cal\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/California_Golden_Bears\", \"dbpedia\": \"http://dbpedia.org/resource/California_Golden_Bears\"}, {\"begin\": 227, \"end\": 236, \"title\": \"http://dbpedia.org/resource/Lithuania_men's_national_basketball_team\", \"score\": 0.9999993041904109, \"rank\": 6.958101089444827e-07, \"text\": \"Lithuania\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Lithuania_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/Lithuania_men's_national_basketball_team\"}], \"noun_phrases\": [{\"ngram\": \"his first attempt\", \"from\": 188, \"to\": 205}, {\"ngram\": \"a throw\", \"from\": 246, \"to\": 253}, {\"ngram\": \"221 feet\", \"from\": 257, \"to\": 265}, {\"ngram\":