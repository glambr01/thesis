"{\"uid\": \"horseandhound.co.uk-news-ben-maher-olympic-showjumping-individual-qualifier-2-867622\", \"noun_phrases\": [{\"sentence\": \"Great Britain'sBen Maherand Dallas Vegas Batilly did an impressive job of regaining their composure after collecting four faults at a tricky optical illusion fence to earn their place in theParis 2024Olympic showjumpingindividual final.\", \"from\": 0, \"to\": 236, \"entities\": [{\"begin\": 0, \"end\": 13, \"title\": \"http://dbpedia.org/resource/Great_Britain\", \"score\": 0.7225654596394447, \"rank\": 0.22312412240655224, \"text\": \"Great Britain\", \"types\": [\"Q23442\"], \"wikid\": \"http://dbpedia.org/resource/Great_Britain\", \"dbpedia\": \"http://dbpedia.org/resource/Great_Britain\"}, {\"begin\": 28, \"end\": 34, \"title\": \"http://dbpedia.org/resource/Dallas\", \"score\": 0.9873434878293195, \"rank\": 0.010907234018479987, \"text\": \"Dallas\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Dallas\", \"dbpedia\": \"http://dbpedia.org/resource/Dallas\"}], \"noun_phrases\": [{\"ngram\": \"an impressive job\", \"from\": 53, \"to\": 70}, {\"ngram\": \"their composure\", \"from\": 84, \"to\": 99}, {\"ngram\": \"four faults\", \"from\": 117, \"to\": 128}, {\"ngram\": \"a tricky optical illusion fence\", \"from\": 132, \"to\": 163}, {\"ngram\": \"their place\", \"from\": 172, \"to\": 183}, {\"ngram\": \"theParis 2024Olympic showjumpingindividual final\", \"from\": 187, \"to\": 235}]}, {\"sentence\": \"The 11-year-old mare, who Ben owns with Charlotte Rossetter and Pamela Wright, looked on super form as she navigated the track, until the pair fell foul of the wall at fence 12, with Dallas Vegas Batilly's back legs taking it down.\", \"from\": 238, \"to\": 469, \"entities\": [{\"begin\": 278, \"end\": 287, \"title\": \"http://dbpedia.org/resource/Charlotte_Motor_Speedway\", \"score\": 0.9999986015646528, \"rank\": 8.236147870557631e-07, \"text\": \"Charlotte\", \"types\": [], \"wikid\": \"http://dbp