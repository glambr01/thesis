, \"from\": 1192, \"to\": 1204}, {\"ngram\": \"every point\", \"from\": 1228, \"to\": 1239}]}, {\"sentence\": \"Some waved Taiwan flags and chanted \\\"Support Taiwan!\\\"\", \"from\": 1246, \"to\": 1299, \"entities\": [{\"begin\": 1257, \"end\": 1263, \"title\": \"http://dbpedia.org/resource/Taiwan\", \"score\": 0.9999999766064323, \"rank\": 2.3004973949475396e-08, \"text\": \"Taiwan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Taiwan\", \"dbpedia\": \"http://dbpedia.org/resource/Taiwan\"}], \"noun_phrases\": [{\"ngram\": \"Support Taiwan\", \"from\": 1283, \"to\": 1297}]}, {\"sentence\": \"As with previous Olympics, Taiwan's international status has been thrust into the spotlight given its longstanding sovereignty disputes with China.\", \"from\": 1301, \"to\": 1448, \"entities\": [{\"begin\": 1328, \"end\": 1334, \"title\": \"http://dbpedia.org/resource/Taiwan\", \"score\": 0.9999999766064323, \"rank\": 2.3004973949475396e-08, \"text\": \"Taiwan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Taiwan\", \"dbpedia\": \"http://dbpedia.org/resource/Taiwan\"}, {\"begin\": 1442, \"end\": 1447, \"title\": \"http://dbpedia.org/resource/Taiwan\", \"score\": 0.9999999687770473, \"rank\": 2.7005057031953922e-08, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Taiwan\", \"dbpedia\": \"http://dbpedia.org/resource/Taiwan\"}], \"noun_phrases\": [{\"ngram\": \"previous Olympics\", \"from\": 1309, \"to\": 1326}, {\"ngram\": \"the spotlight\", \"from\": 1379, \"to\": 1392}, {\"ngram\": \"its longstanding sovereignty disputes\", \"from\": 1399, \"to\": 1436}]}, {\"sentence\": \"The island competes as 'Chinese Taipei' rather than as Taiwan, to avoid objections from China, which claims the island as its own territory.\", \"from\": 1450, \"to\": 1590, \"entities\": [{\"begin\": 1482, \"end\": 1488, \"title\": \"http://dbpedia.org/resource/Taiwan\", \"score\": 0.9988178882179244, \"rank\": 0.00079599137838