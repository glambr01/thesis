om\": 2238, \"to\": 2246}]}, {\"sentence\": \"The two men stood together as they anxiously watched the screen immediately after the end of the race.\", \"from\": 2250, \"to\": 2352, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The two men\", \"from\": 2250, \"to\": 2261}, {\"ngram\": \"the screen\", \"from\": 2303, \"to\": 2313}, {\"ngram\": \"the end\", \"from\": 2332, \"to\": 2339}, {\"ngram\": \"the race\", \"from\": 2343, \"to\": 2351}]}, {\"sentence\": \"\\\"Come on man!\\\"\", \"from\": 2353, \"to\": 2367, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"man\", \"from\": 2362, \"to\": 2365}]}, {\"sentence\": \"Thompson roared with impatience as he waited for the big screen to display the official results.\", \"from\": 2368, \"to\": 2464, \"entities\": [{\"begin\": 2368, \"end\": 2376, \"title\": \"http://dbpedia.org/resource/Tina_Thompson\", \"score\": 0.8478324608534589, \"rank\": 0.1794783120252571, \"text\": \"Thompson\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Tina_Thompson\", \"dbpedia\": \"http://dbpedia.org/resource/Tina_Thompson\"}], \"noun_phrases\": [{\"ngram\": \"impatience\", \"from\": 2389, \"to\": 2399}, {\"ngram\": \"the big screen\", \"from\": 2417, \"to\": 2431}, {\"ngram\": \"the official results\", \"from\": 2443, \"to\": 2463}]}, {\"sentence\": \"Lyles told Thompson at one point: \\\"I think you have got the Olympics, big dog.\\\"\", \"from\": 2465, \"to\": 2544, \"entities\": [{\"begin\": 2476, \"end\": 2484, \"title\": \"http://dbpedia.org/resource/Tina_Thompson\", \"score\": 0.8478324608534589, \"rank\": 0.1794783120252571, \"text\": \"Thompson\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Tina_Thompson\", \"dbpedia\": \"http://dbpedia.org/resource/Tina_Thompson\"}], \"noun_phrases\": [{\"ngram\": \"Lyles\", \"from\": 2465, \"to\": 2470}, {\"ngram\": \"one point\", \"from\": 2488, \"to\": 2497