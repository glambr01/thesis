02, \"entities\": [{\"begin\": 1234, \"end\": 1239, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999999970673343, \"rank\": 2.9327123244258347e-09, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"the issue\", \"from\": 1217, \"to\": 1226}, {\"ngram\": \"the same depth\", \"from\": 1253, \"to\": 1267}, {\"ngram\": \"one place\", \"from\": 1271, \"to\": 1280}, {\"ngram\": \"another\", \"from\": 1284, \"to\": 1291}]}, {\"sentence\": \"\\\"The bridges do not have the same strength, nor do the banks of the river.\", \"from\": 1303, \"to\": 1377, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The bridges\", \"from\": 1304, \"to\": 1315}, {\"ngram\": \"the same strength\", \"from\": 1328, \"to\": 1345}, {\"ngram\": \"the banks\", \"from\": 1354, \"to\": 1363}, {\"ngram\": \"the river\", \"from\": 1367, \"to\": 1376}]}, {\"sentence\": \"\\\"The wind does not blow in the same way depending on where you are.\", \"from\": 1379, \"to\": 1446, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The wind\", \"from\": 1380, \"to\": 1388}, {\"ngram\": \"the same way\", \"from\": 1406, \"to\": 1418}]}, {\"sentence\": \"There are places where fish spawn too, because we are trying not to disturb the natural environment.\\\"\", \"from\": 1447, \"to\": 1548, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"places\", \"from\": 1457, \"to\": 1463}, {\"ngram\": \"fish\", \"from\": 1470, \"to\": 1474}, {\"ngram\": \"the natural environment\", \"from\": 1523, \"to\": 1546}]}, {\"sentence\": \"Once the vertigo subsided, he set about assembling a team of creatives to develop plans which were submitted for review in July 2023 to a range of stakeholders from the police to the Olympic organising committee.\", \"from\": 1550, \"to\": 1762, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the vertigo\", \"from\": 1555, \"to\": 1566}, {\"ngram\": \"a team\", \"from\": 1601, \"to\": 1607}, {\"ngram\": \"creatives\", \"from\": 1611, \"to\": 1620}, {\"ngram\": \"plans\", \"from\": 1632, \"to\": 1637}, {\"ngram\": \"review\", \"from\": 1663, \"to\": 1669}, {\"ngram\": \"July\", \"from\": 1673, \"to\": 1677}, {\"ngram\": \"a range\", \"from\": 1686, \"to\": 1693}, {\"ngram\": \"stakeholders\", \"from\": 1697, \"to\": 1709}, {\"ngram\": \"the police\", \"from\": 1715, \"to\": 1725}, {\"ngram\": \"the Olympic organising committee\", \"from\": 1729, \"to\": 1761}]}, {\"sentence\": \"\\\"All of these reviews were done to see if we could turn our dream into reality,\\\" he said.\", \"from\": 1764, \"to\": 1853, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"these reviews\", \"from\": 1772, \"to\": 1785}, {\"ngram\": \"our dream\", \"from\": 1820, \"to\": 1829}, {\"ngram\": \"reality\", \"from\": 1835, \"to\": 1842}]}, {\"sentence\": \"\\\"They all agreed pretty unanimously on around 90 per cent, so I have around 10 per cent left of the project that I need to re-adapt.\\\"\", \"from\": 1854, \"to\": 1987, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"cent\", \"from\": 1907, \"to\": 1911}, {\"ngram\": \"around 10 per cent\", \"from\": 1923, \"to\": 1941}, {\"ngram\": \"the project\", \"from\": 1950, \"to\": 1961}]}, {\"sentence\": \"There is another major constraint that would keep most theatre directors awake at night, even for a small production.\", \"from\": 1989, \"to\": 2106, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"another major constraint\", \"from\": 1998, \"to\": 2022}, {\"ngram\": \"most theatre directors\", \"from\": 2039, \"to\": 2061}, {\"ngram\": \"night\", \"from\": 2071, \"to\": 2076}, {\"ngram\": \"a small production\", \"from\": 2087, \"to\": 2105}]}, {\"sentence\": \"\\\"What's unique about this show is that you can not rehearse it on location.\", \"from\": 2108, \"to\": 2183, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this show\", \"from\": 2129, \"to\": 2138}, {\"ngram\": \"location\", \"from\": 2174, \"to\": 2182}]}, {\"sentence\": \"Actually you can not rehearse it even once in advance,\\\" explained Jolly.\", \"from\": 2184, \"to\": 2256, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"advance\", \"from\": 2230, \"to\": 2237}, {\"ngram\": \"Jolly\", \"from\": 2250, \"to\": 2255}]}, {\"sentence\": \"Parts of his show will be rehearsed individually inside giant hangars, and boat captains will practise at a sailing centre.\", \"from\": 2258, \"to\": 2381, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Parts\", \"from\": 2258, \"to\": 2263}, {\"ngram\": \"his show\", \"from\": 2267, \"to\": 2275}, {\"ngram\": \"giant hangars\", \"from\": 2314, \"to\": 2327}, {\"ngram\": \"boat captains\", \"from\": 2333, \"to\": 2346}, {\"ngram\": \"a sailing centre\", \"from\": 2364, \"to\": 2380}]}, {\"sentence\": \"The idea of the open-air ceremony fits with the overall grandiose vision for the July 26-Aug 11 Paris Olympics, which organisers have promised will be \\\"iconic\\\" and \\\"revolutionary\\\".\", \"from\": 2383, \"to\": 2563, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The idea\", \"from\": 2383, \"to\": 2391}, {\"ngram\": \"the open-air ceremony\", \"from\": 2395, \"to\": 2416}, {\"ngram\": \"the overall grandiose vision\", \"from\": 2427, \"to\": 2455}, {\"ngram\": \"-Aug\", \"from\": 2471, \"to\": 2475}, {\"ngram\": \"organisers\", \"from\": 2501, \"to\": 2511}]}, {\"sentence\": \"As expected, Jolly was tightlipped about what he is planning when the eyes of the world - and those of up to 600,000 live spectators - will be on his work.\", \"from\": 2565, \"to\": 2720, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Jolly\", \"from\": 2578, \"to\": 2583}, {\"ngram\": \"the eyes\", \"from\": 2631, \"to\": 2639}, {\"ngram\": \"the world\", \"from\": 2643, \"to\": 2652}, {\"ngram\": \"up to 600,000 live spectators\", \"from\": 2668, \"to\": 2697}, {\"ngram\": \"his work\", \"from\": 2711, \"to\": 2719}]}, {