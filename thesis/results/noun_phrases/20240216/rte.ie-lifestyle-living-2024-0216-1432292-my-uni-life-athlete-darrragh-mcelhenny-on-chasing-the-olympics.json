 503}, {\"ngram\": \"athletics\", \"from\": 512, \"to\": 521}, {\"ngram\": \"those four years\", \"from\": 533, \"to\": 549}, {\"ngram\": \"college\", \"from\": 553, \"to\": 560}]}, {\"sentence\": \"McElhinney went on to become one of UCD's 60 Ad Astra scholars, and over the course of his four years of university life, he has risen to become one of the most promising young athletes in Ireland.\", \"from\": 564, \"to\": 761, \"entities\": [{\"begin\": 564, \"end\": 574, \"title\": \"http://dbpedia.org/resource/Curtis_McElhinney\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"McElhinney\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q11774891\"], \"wikid\": \"http://dbpedia.org/resource/Curtis_McElhinney\", \"dbpedia\": \"http://dbpedia.org/resource/Curtis_McElhinney\"}, {\"begin\": 600, \"end\": 603, \"title\": \"http://dbpedia.org/resource/University_College_Dublin\", \"score\": 0.9999996155007296, \"rank\": 3.844989505447956e-07, \"text\": \"UCD\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/University_College_Dublin\", \"dbpedia\": \"http://dbpedia.org/resource/University_College_Dublin\"}, {\"begin\": 753, \"end\": 760, \"title\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"score\": 0.9999998411813193, \"rank\": 1.588164824408803e-07, \"text\": \"Ireland\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"dbpedia\": \"http://dbpedia.org/resource/Republic_of_Ireland\"}], \"noun_phrases\": [{\"ngram\": \"the course\", \"from\": 637, \"to\": 647}, {\"ngram\": \"his four years\", \"from\": 651, \"to\": 665}, {\"ngram\": \"university life\", \"from\": 669, \"to\": 684}, {\"ngram\": \"the most promising young athletes\", \"from\": 716, \"to\": 749}]}, {\"sentence\": \"Now graduated, the West Cork native has his sights firmly set on this year's Olympic Games in Paris.\", \"from\": 762, \"to\": 862, \"entities\": [{\"begin\": 856, \"end\": 861, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9998748890974652, \"rank\": 0.00012512655740368629, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"his sights\", \"from\": 802, \"to\": 812}, {\"ngram\": \"this year's Olympic Games\", \"from\": 827, \"to\": 852}]}, {\"sentence\": \"He's one of a number of students who feature in the new season ofMy Uni Life, which charts a year in the life of Ireland's universities.\", \"from\": 864, \"to\": 1000, \"entities\": [{\"begin\": 932, \"end\": 935, \"title\": \"http://dbpedia.org/resource/Uni_Records\", \"score\": 0.9983791935659356, \"rank\": 0.0016234377125802588, \"text\": \"Uni\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\", \"Q18127\"], \"wikid\": \"http://dbpedia.org/resource/Uni_Records\", \"dbpedia\": \"http://dbpedia.org/resource/Uni_Records\"}, {\"begin\": 977, \"end\": 984, \"title\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"score\": 0.9999998411813193, \"rank\": 1.588164824408803e-07, \"text\": \"Ireland\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"dbpedia\": \"http://dbpedia.org/resource/Republic_of_Ireland\"}], \"noun_phrases\": [{\"ngram\": \"a number\", \"from\": 876, \"to\": 884}, {\"ngram\": \"students\", \"from\": 888, \"to\": 896}, {\"ngram\": \"the new season\", \"from\": 912, \"to\": 926}, {\"ngram\": \"the life\", \"from\": 965, \"to\": 973}]}, {\"sentence\": \"McElhinney got involved to show the reality of balancing studies with a demanding and disciplined sporting career.\", \"from\": 1001, \"to\": 1115, \"entities\": [{\"begin\": 1001, \"end\": 1011, \"title\": \"http://dbpedia.org/resource/Curtis_McElhinney\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"McElhinney\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q11774891\"], \"wikid\": \"http://dbpedia.org/resource/Curtis_McElhinney\", \"dbpedia\": \"http://dbpedia.org/resource/Curtis_McElhinney\"}], \"noun_phrases\": [{\"ngram\": \"the reality\", \"from\": 1033, \"to\": 1044}, {\"ngram\": \"studies\", \"from\": 1058, \"to\": 1065}, {\"ngram\": \"a demanding and disciplined sporting career\", \"from\": 1071, \"to\": 1114}]}, {\"sentence\": \"\\\"There is no one to tell you what your balance should really be like.\", \"from\": 1117, \"to\": 1186, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"no one\", \"from\": 1127, \"to\": 1133}, {\"ngram\": \"your balance\", \"from\": 1151, \"to\": 1163}]}, {\"sentence\": \"You kind of just have to figure it out for yourself\\\", he says.\", \"from\": 1187, \"to\": 1249, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"McElhinney's college career has been unlike most: \\\"By the time that the show rolled around, I was in my final year and I just had a better understanding overall of how to balance everything and how to prioritise my athletics while still not failing college or whatever\\\", he says, but finding his feet at the beginning took a while.\", \"from\": 1251, \"to\": 1582, \"entities\": [{\"begin\": 1251, \"end\": 1261, \"title\": \"http://dbpedia.org/resource/Curtis_McElhinney\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"McElhinney\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q11774891\"], \"wikid\": \"http://dbpedia.org/resource/Curtis_McElhinney\", \"dbpedia\": \"http://dbpedia.org/resource/Curtis_McElhinney\"}], \"noun_phrases\": [{\"ngram\": \"the time\", \"from\": 1305, \"to\": 1313}, {\"ngram\": \"the show\", \"from\": 1319, \"to\": 1327}, {\"ngram\": \"my final year\", \"from\": 1352, \"to\": 1365}, {\"ngram\": \"a better understanding\", \"from\": 1381, \"to\": 1403}, {\"ngram\": \"everything\", \"from\": 1430, \"to\": 1440}, {\"ngram\": \"my athletics\", \"from\": 1463, \"to\": 1475}, {\"ngram\": \"college\", \"from\": 1500, \"to\": 1507}, {\"ngram\": \"his feet\", \"from\": 1543, \"to\": 1551}, {\"ngram\": \"the beginning\", \"from\": 1555, \"to\": 1568}]}, {\"sentence\": \"\\\"I would have allocated my time to training and then tried to fit in my study around that, as opposed to the other way around.\\\"\", \"from\": 1584, \"to\": 1711, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my time\", \"from\": 1608, \"to\": 1615}, {\"ngram\": \"training\", \"from\": 1619, \"to\": 1627}, {\"ngram\": \"my study\", \"from\": 1653, \"to\": 1661}, {\"ngram\": \"the other way\", \"from\": 1689, \"to\": 1702}]}, {\"sentence\": \"A typical day in the life then included two training sessions, one in the morning and one in the evening, with a block of hours in between during which McElhinney would try and fit in as much study as possible.\", \"from\": 1715, \"to\": 1925, \"entities\": [{\"begin\": 1867, \"end\": 1877, \"title\": \"http://dbpedia.org/resource/Curtis_McElhinney\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"McElhinney\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q11774891\"], \"wikid\": \"http://dbpedia.org/resource/Curtis_McElhinney\", \"dbpedia\": \"http://dbpedia.org/resource/Curtis_McElhinney\"}], \"noun_phrases\": [{\"ngram\": \"A typical day\", \"from\": 1715, \"to\": 1728}, {\"ngram\": \"the life\", \"from\": 1732, \"to\": 1740}, {\"ngram\": \"two training sessions\", \"from\": 1755, \"to\": 1776}, {\"ngram\": \"the morning\", \"from\": 1785, \"to\": 1796}, {\"ngram\": \"the evening\", \"from\": 1808, \"to\": 1819}, {\"ngram\": \"a block\", \"from\": 1826, \"to\": 1833}, {\"ngram\": \"hours\", \"from\": 1837, \"to\": 1842}, {\"ngram\": \"as much study\", \"from\": 1899, \"to\": 1912}]}, {\"sentence\": \"All of this, with the swirl of college life and its parties, social clubs and more going on around him.\", \"from\": 1926, \"to\": 2029, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the swirl\", \"from\": 1944, \"to\": 1953}, {\"ngram\": \"college life\", \"from\": 1957, \"to\": 1969}, {\"ngram\": \"its parties\", \"from\": 1974, \"to\": 1985}, {\"ngram\": \"social clubs\", \"from\": 1987, \"to\": 1999}]}, {\"sentence\": \"\\\"Because I am from West Cork, there was kind of nobody\\\", he says.\", \"from\": 2031, \"to\": 2096, \"entities\": [{\"begin\": 2055, \"end\": 2059, \"title\": \"http://dbpedia.org/resource/University_College_Cork\", \"score\": 0.9710649579491925, \"rank\": 0.029797182698397012, \"text\": \"Cork\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/University_College_Cork\", \"dbpedia\": \"http://dbpedia.org/resource/University_College_Cork\"}], \"noun_phrases\": [{\"ngram\": \"kind of nobody\", \"from\": 2071, \"to\": 2085}]}, {\"sentence\": \"\\\"I did not really know many people in Dublin when I came.\", \"from\": 2097, \"to\": 2154, \"entities\": [{\"begin\": 2135, \"end\": 2141, \"title\": \"http://dbpedia.org/resource/Dublin\", \"score\": 0.9998598192215187, \"rank\": 0.00014018670571991926, \"text\": \"Dublin\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Dublin\", \"dbpedia\": \"http://dbpedia.org/resource/Dublin\"}], \"noun_phrases\": [{\"ngram\": \"many people\", \"from\": 2120, \"to\": 2131}]}, {\"sentence\": \"So I was obviously trying to meet new people.\", \"from\": 2155, \"to\": 2200, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"new people\", \"from\": 2189, \"to\": 2199}]}, {\"sentence\": \"That was kind of a bit of a barrier.\", \"from\": 2201, \"to\": 2237, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"kind of a bit\", \"from\": 2210, \"to\": 2223}, {\"ngram\": \"a barrier\", \"from\": 2227, \"to\": 2236}]}, {\"sentence\": \"\\\"There was just a lot of that type of stuff going on and you are trying to avoid it, but I suppose by the time you got to third or fourth year, you have made a few friends and you are content enough with your kind of circle, and you are just trying to focus on the athletics.\\\"\", \"from\": 2239, \"to\": 2515, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"just a lot\", \"from\": 2250, \"to\": 2260}, {\"ngram\": \"that type\", \"from\": 2264, \"to\": 2273}, {\"ngram\": \"stuff\", \"from\": 2277, \"to\": 2282}, {\"ngram\": \"the time\", \"from\": 2341, \"to\": 2349}, {\"ngram\": \"third or fourth year\", \"from\": 2361, \"to\": 2381}, {\"ngram\": \"a few friends\", \"from\": 2397, \"to\": 2410}, {\"ngram\": \"your kind\", \"from\": 2443, \"to\": 2452}, {\"ngram\": \"circle\", \"from\": 2456, \"to\": 2462}, {\"ngram\": \"the athletics\", \"from\": 2500, \"to\": 2513}]}, {\"sentence\": \"The stakes got higher when McElhinney signed his first professional contract at the end of 2020: \\\"Then it kind of turns into your job and you are like, all right, I need to up the focus even more.\\\"\", \"from\": 2517, \"to\": 2714, \"entities\": [{\"begin\": 2544, \"end\": 2554, \"title\": \"http://dbpedia.org/resource/Curtis_McElhinney\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"McElhinney\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q11774891\"], \"wikid\": \"http://dbpedia.org/resource/Curtis_McElhinney\", \"dbpedia\": \"http://dbpedia.org/resource/Curtis_McElhinney\"}], \"noun_phrases\": [{\"ngram\": \"The stakes\", \"from\": 2517, \"to\": 2527}, {\"ngram\": \"his first professional contract\", \"from\": 2562, \"to\": 2593}, {\"ngram\": \"the end\", \"from\": 2597, \"to\": 2604}, {\"ngram\": \"your job\", \"from\": 2642, \"to\": 2650}, {\"ngram\": \"the focus\", \"from\": 2693, \"to\": 2702}]}, {\"sentence\": \"He recalls that by then he was \\\"a bit incognito in college\\\".\", \"from\": 2716, \"to\": 2776, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a bit incognito\", \"from\": 2748, \"to\": 2763}, {\"ngram\": \"college\", \"from\": 2767, \"to\": 2774}]}, {\"sentence\": \"\\\"There were people in my year in college that probably would not know what I looked like because I was away so often\\\", he says.\", \"from\": 2778, \"to\": 2905, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"people\", \"from\": 2790, \"to\": 2796}, {\"ngram\": \"my year\", \"from\": 2800, \"to\": 2807}, {\"ngram\": \"college\", \"from\": 2811, \"to\": 2818}]}, {\"sentence\": \"\\\"If there was a lecture that I knew that maybe I did not have to go in, my time would be better spent using that hour to do an assignment or something like that.\\\"\", \"from\": 2906, \"to\": 3068, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a lecture\", \"from\": 2920, \"to\": 2929}, {\"ngram\": \"my time\", \"from\": 2978, \"to\": 2985}, {\"ngram\": \"that hour\", \"from\": 3014, \"to\": 3023}, {\"ngram\": \"an assignment\", \"from\": 3030, \"to\": 3043}, {\"ngram\": \"something\", \"from\": 3047, \"to\": 3056}]}, {\"sentence\": \"Exam season is hellish for the majority of students, but add in a grueling training routine, the need to get as much sleep as possible and preparing for European Championships or target races, and it becomes something else entirely.\", \"from\": 3072, \"to\": 3304, \"entities\": [{\"begin\": 3225, \"end\": 3247, \"title\": \"http://dbpedia.org/resource/UEFA_European_Championship\", \"score\": 0.9997324785393131, \"rank\": 0.0002658435035110383, \"text\": \"European Championships\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/UEFA_European_Championship\", \"dbpedia\": \"http://dbpedia.org/resource/UEFA_European_Championship\"}], \"noun_phrases\": [{\"ngram\": \"Exam season\", \"from\": 3072, \"to\": 3083}, {\"ngram\": \"the majority\", \"from\": 3099, \"to\": 3111}, {\"ngram\": \"students\", \"from\": 3115, \"to\": 3123}, {\"ngram\": \"a grueling training routine\", \"from\": 3136, \"to\": 3163}, {\"ngram\": \"the need\", \"from\": 3165, \"to\": 3173}, {\"ngram\": \"as much sleep\", \"from\": 3181, \"to\": 3194}, {\"ngram\": \"target races\", \"from\": 3251, \"to\": 3263}, {\"ngram\": \"something\", \"from\": 3280, \"to\": 3289}]}, {\"sentence\": \"McElhinney remembers the weeks around exams being particularly stressful.\", \"from\": 3305, \"to\": 3378, \"entities\": [{\"begin\": 3305, \"end\": 3315, \"title\": \"http://dbpedia.org/resource/Curtis_McElhinney\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"McElhinney\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q11774891\"], \"wikid\": \"http://dbpedia.org/resource/Curtis_McElhinney\", \"dbpedia\": \"http://dbpedia.org/resource/Curtis_McElhinney\"}], \"noun_phrases\": [{\"ngram\": \"the weeks\", \"from\": 3326, \"to\": 3335}, {\"ngram\": \"exams\", \"from\": 3343, \"to\": 3348}]}, {\"sentence\": \"What helped, however, was having \\\"the foresight as well to be honest with yourself and say, I am not going to be able to reach my potential as a runner and then also try and get like a law degree\\\", he says.\", \"from\": 3380, \"to\": 3586, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the foresight\", \"from\": 3414, \"to\": 3427}, {\"ngram\": \"my potential\", \"from\": 3507, \"to\": 3519}, {\"ngram\": \"a runner\", \"from\": 3523, \"to\": 3531}, {\"ngram\": \"a law degree\", \"from\": 3563, \"to\": 3575}]}, {\"sentence\": \"Now with the Olympic track firmly in his sights, McElhinney says there is a lot more room to focus on just athletics.\", \"from\": 3588, \"to\": 3705, \"entities\": [{\"begin\": 3637, \"end\": 3647, \"title\": \"http://dbpedia.org/resource/Curtis_McElhinney\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"McElhinney\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q11774891\"], \"wikid\": \"http://dbpedia.org/resource/Curtis_McElhinney\", \"dbpedia\": \"http://dbpedia.org/resource/Curtis_McElhinney\"}], \"noun_phrases\": [{\"ngram\": \"the Olympic track\", \"from\": 3597, \"to\": 3614}, {\"ngram\": \"his sights\", \"from\": 3625, \"to\": 3635}, {\"ngram\": \"a lot more room\", \"from\": 3662, \"to\": 3677}, {\"ngram\": \"just athletics\", \"from\": 3690, \"to\": 3704}]}, {\"sentence\": \"Sharing an apartment with other athletes has been a major help, something he says is \\\"key\\\".\", \"from\": 3706, \"to\": 3797, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an apartment\", \"from\": 3714, \"to\": 3726}, {\"ngram\": \"other athletes\", \"from\": 3732, \"to\": 3746}, {\"ngram\": \"a major help\", \"from\": 3756, \"to\": 3768}, {\"ngram\": \"something\", \"from\": 3770, \"to\": 3779}]}, {\"sentence\": \"\\\"The most effective thing that an athlete can do between training is nothing, you know what I mean?\", \"from\": 3799, \"to\": 3898, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The most effective thing\", \"from\": 3800, \"to\": 3824}, {\"ngram\": \"an athlete\", \"from\": 3830, \"to\": 3840}, {\"ngram\": \"training\", \"from\": 3856, \"to\": 3864}, {\"ngram\": \"nothing\", \"from\": 3868, \"to\": 3875}]}, {\"sentence\": \"The less you do, the better.\", \"from\": 3899, \"to\": 3927, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"But that obviously raises few eyebrows from people who do not understand.\", \"from\": 3928, \"to\": 4001, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"few eyebrows\", \"from\": 3954, \"to\": 3966}, {\"ngram\": \"people\", \"from\": 3972, \"to\": 3978}]}, {\"sentence\": \"It just looks like you are being lazy or whatever.\\\"\", \"from\": 4002, \"to\": 4053, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"With the window for qualifications opening a year before the event itself, the athlete is \\\"playing a little bit of catch up\\\" after a period of bad performance on the track.\", \"from\": 4055, \"to\": 4227, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the window\", \"from\": 4060, \"to\": 4070}, {\"ngram\": \"qualifications\", \"from\": 4075, \"to\": 4089}, {\"ngram\": \"the event\", \"from\": 4112, \"to\": 4121}, {\"ngram\": \"the athlete\", \"from\": 4130, \"to\": 4141}, {\"ngram\": \"a little bit\", \"from\": 4154, \"to\": 4166}, {\"ngram\": \"catch\", \"from\": 4170, \"to\": 4175}, {\"ngram\": \"a period\", \"from\": 4186, \"to\": 4194}, {\"ngram\": \"bad performance\", \"from\": 4198, \"to\": 4213}, {\"ngram\": \"the track\", \"from\": 4217, \"to\": 4226}]}, {\"sentence\": \"\\\"I do not really have a lot of good performances within the winter so far.\", \"from\": 4229, \"to\": 4303, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a lot\", \"from\": 4251, \"to\": 4256}, {\"ngram\": \"good performances\", \"from\": 4260, \"to\": 4277}, {\"ngram\": \"the winter\", \"from\": 4285, \"to\": 4295}]}, {\"sentence\": \"But thankfully, my first and only race this year went really well.\", \"from\": 4304, \"to\": 4370, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my first and only race\", \"from\": 4320, \"to\": 4342}]}, {\"sentence\": \"So it's good to have some points on the board now in terms of qualification.\", \"from\": 4371, \"to\": 4447, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"some points\", \"from\": 4392, \"to\": 4403}, {\"ngram\": \"the board\", \"from\": 4407, \"to\": 4416}, {\"ngram\": \"terms\", \"from\": 4424, \"to\": 4429}, {\"ngram\": \"qualification\", \"from\": 4433, \"to\": 4446}]}, {\"sentence\": \"Once I am fully healthy and I am in good form, it's definitely very doable.\\\"\", \"from\": 4448, \"to\": 4524, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"good form\", \"from\": 4484, \"to\": 4493}]}, {\"sentence\": \"\\\"It's a crazy kind of situation to even be in thinking about qualifying\\\", he says about the Olympics.\", \"from\": 4526, \"to\": 4627, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a crazy kind\", \"from\": 4532, \"to\": 4544}, {\"ngram\": \"situation\", \"from\": 4548, \"to\": 4557}, {\"ngram\": \"qualifying\", \"from\": 4587, \"to\": 4597}, {\"ngram\": \"the Olympics\", \"from\": 4614, \"to\": 4626}]}, {\"sentence\": \"\\\"It's what you are always striving for.\", \"from\": 4628, \"to\": 4667, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"And it's always in the back of your head.\", \"from\": 4668, \"to\": 4709, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the back\", \"from\": 4687, \"to\": 4695}, {\"ngra