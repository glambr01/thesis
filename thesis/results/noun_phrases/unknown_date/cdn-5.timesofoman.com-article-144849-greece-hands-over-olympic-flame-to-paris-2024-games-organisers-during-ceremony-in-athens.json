\"text\": \"Panathenaic\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Panathenaic_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Panathenaic_Games\"}, {\"begin\": 12717, \"end\": 12723, \"title\": \"http://dbpedia.org/resource/Greece\", \"score\": 0.9999999802043933, \"rank\": 1.0611729943837551e-08, \"text\": \"Greece\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Greece\", \"dbpedia\": \"http://dbpedia.org/resource/Greece\"}], \"noun_phrases\": [{\"ngram\": \"a unique journey\", \"from\": 12648, \"to\": 12664}, {\"ngram\": \"hope\", \"from\": 12668, \"to\": 12672}, {\"ngram\": \"pride\", \"from\": 12677, \"to\": 12682}, {\"ngram\": \"the whole\", \"from\": 12704, \"to\": 12713}, {\"ngram\": \"one end\", \"from\": 12729, \"to\": 12736}, {\"ngram\": \"its end\", \"from\": 12759, \"to\": 12766}]}, {\"sentence\": \"And yet these 11 days that have captivated our country and captured the attention of the whole world are just the beginning of a great journey.\", \"from\": 12768, \"to\": 12911, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"these 11 days\", \"from\": 12776, \"to\": 12789}, {\"ngram\": \"our country\", \"from\": 12811, \"to\": 12822}, {\"ngram\": \"the attention\", \"from\": 12836, \"to\": 12849}, {\"ngram\": \"the whole world\", \"from\": 12853, \"to\": 12868}, {\"ngram\": \"just the beginning\", \"from\": 12873, \"to\": 12891}, {\"ngram\": \"a great journey\", \"from\": 12895, \"to\": 12910}]}, {\"sentence\": \"That of the next Olympic Games in Paris 2024,\\\" the Olympic's official website quoted Capralos as saying.\", \"from\": 12912, \"to\": 13016, \"entities\": [{\"begin\": 12946, \"end\": 12956, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 0.9999999999918145, \"rank\": 8.15929760679469e-12, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}], \"