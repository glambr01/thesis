, \"score\": 0.9999999568408393, \"rank\": 3.9629404640167504e-08, \"text\": \"Isshiki\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Isshiki_clan\", \"dbpedia\": \"http://dbpedia.org/resource/Isshiki_clan\"}, {\"begin\": 2361, \"end\": 2367, \"title\": \"http://dbpedia.org/resource/Matcha\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Matcha\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Matcha\", \"dbpedia\": \"http://dbpedia.org/resource/Matcha\"}], \"noun_phrases\": [{\"ngram\": \"the owner\", \"from\": 2340, \"to\": 2349}]}, {\"sentence\": \"Zheng said she casually answered: \\\"Yeah, I will do it.\", \"from\": 2370, \"to\": 2424, \"entities\": [{\"begin\": 2370, \"end\": 2375, \"title\": \"http://dbpedia.org/resource/Qin_Shi_Huang\", \"score\": 0.7862168799614816, \"rank\": 0.25921418621922104, \"text\": \"Zheng\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Qin_Shi_Huang\", \"dbpedia\": \"http://dbpedia.org/resource/Qin_Shi_Huang\"}], \"noun_phrases\": []}, {\"sentence\": \"...\", \"from\": 2425, \"to\": 2428, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"This sounds like a fun project.\\\"\", \"from\": 2429, \"to\": 2461, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a fun project\", \"from\": 2446, \"to\": 2459}]}, {\"sentence\": \"\\\"I really also for selfish reasons want to try these Olympic muffins,\\\" she said.\", \"from\": 2463, \"to\": 2543, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"selfish reasons\", \"from\": 2482, \"to\": 2497}, {\"ngram\": \"these Olympic muffins\", \"from\": 2510, \"to\": 2531}]}, {\"sentence\": \"Zhang and Zheng said they quickly got to work together.\", \"from\": 2545, \"to\": 2600, \"entities\": [{\"begin\": 2555, \"end\": 2560, \"title\": \"http://dbpedia.org/resource/Qin_Shi_Huang\", \"score\": 0.7862168799614816, \"rank\": 0.25921418621922104, \"text\": \"Zheng\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"