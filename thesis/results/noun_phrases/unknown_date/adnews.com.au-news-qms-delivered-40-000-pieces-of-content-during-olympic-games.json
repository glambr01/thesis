8}, {\"ngram\": \"the preeminent display\", \"from\": 1399, \"to\": 1421}, {\"ngram\": \"brands\", \"from\": 1429, \"to\": 1435}, {\"ngram\": \"the immediacy\", \"from\": 1448, \"to\": 1461}, {\"ngram\": \"home\", \"from\": 1480, \"to\": 1484}, {\"ngram\": \"its geographical impact\", \"from\": 1496, \"to\": 1519}, {\"ngram\": \"broadcast scale audience\", \"from\": 1531, \"to\": 1555}, {\"ngram\": \"relevant and contextualised creative content\", \"from\": 1567, \"to\": 1611}, {\"ngram\": \"community cultures\", \"from\": 1632, \"to\": 1650}]}, {\"sentence\": \"This is a momentous step change for DOOH and the role it can play in major events and campaigns.\\\"\", \"from\": 1670, \"to\": 1767, \"entities\": [{\"begin\": 1706, \"end\": 1710, \"title\": \"http://dbpedia.org/resource/Out-of-home_advertising\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"DOOH\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Out-of-home_advertising\", \"dbpedia\": \"http://dbpedia.org/resource/Out-of-home_advertising\"}], \"noun_phrases\": [{\"ngram\": \"a momentous step change\", \"from\": 1678, \"to\": 1701}, {\"ngram\": \"the role\", \"from\": 1715, \"to\": 1723}, {\"ngram\": \"major events\", \"from\": 1739, \"to\": 1751}, {\"ngram\": \"campaigns\", \"from\": 1756, \"to\": 1765}]}, {\"sentence\": \"Murphy said that by tapping into the immediacy and scale of digital, QMS have showcased how advanced its digital capabilities now are, and in doing so, delivered the gold standard for partners.\", \"from\": 1769, \"to\": 1962, \"entities\": [{\"begin\": 1838, \"end\": 1841, \"title\": \"http://dbpedia.org/resource/Konica_Minolta\", \"score\": 0.6987114528906249, \"rank\": 0.4312059146796484, \"text\": \"QMS\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Konica_Minolta\", \"dbpedia\": \"http://dbpedia.org/resource/Konica_Minolta\"}], \"noun_phrases\": [{\"ngram\": \"Murphy\", \"from\": 1769, \"to\": 1775}, {\"ngram\": \"the immedia