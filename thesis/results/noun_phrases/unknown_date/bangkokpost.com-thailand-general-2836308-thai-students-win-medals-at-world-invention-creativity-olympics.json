"{\"uid\": \"bangkokpost.com-thailand-general-2836308-thai-students-win-medals-at-world-invention-creativity-olympics\", \"noun_phrases\": [{\"sentence\": \"PUBLISHED : 26 Jul 2024 at 13:30 NEWSPAPER SECTION:News WRITER:Online Reporters A group of four Thai students won two gold medals, one silver medal and a special award at the \\\"13th World Invention Creativity Olympics 2024\\\" (WICO 2024) held in South Korea.\", \"from\": 0, \"to\": 258, \"entities\": [{\"begin\": 99, \"end\": 103, \"title\": \"http://dbpedia.org/resource/Thailand\", \"score\": 0.9457272976804387, \"rank\": 0.05566125518537735, \"text\": \"Thai\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Thailand\", \"dbpedia\": \"http://dbpedia.org/resource/Thailand\"}, {\"begin\": 246, \"end\": 257, \"title\": \"http://dbpedia.org/resource/South_Korea\", \"score\": 0.9992915905590843, \"rank\": 0.0006983969535381194, \"text\": \"South Korea\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/South_Korea\", \"dbpedia\": \"http://dbpedia.org/resource/South_Korea\"}], \"noun_phrases\": [{\"ngram\": \"13:30 NEWSPAPER SECTION\", \"from\": 27, \"to\": 50}, {\"ngram\": \"News WRITER\", \"from\": 51, \"to\": 62}, {\"ngram\": \"Online Reporters\", \"from\": 63, \"to\": 79}, {\"ngram\": \"A group\", \"from\": 80, \"to\": 87}, {\"ngram\": \"two gold medals\", \"from\": 114, \"to\": 129}, {\"ngram\": \"one silver medal\", \"from\": 131, \"to\": 147}, {\"ngram\": \"a special award\", \"from\": 152, \"to\": 167}, {\"ngram\": \"the \\\"13th World Invention Creativity Olympics\", \"from\": 171, \"to\": 216}, {\"ngram\": \"WICO\", \"from\": 224, \"to\": 228}]}, {\"sentence\": \"The international competition took place on Tuesday and Wednesday at the Seoul University of Education Convention Hall and was organised by the Korea University Invention Association (KUIA) and theWorld Invention Intellectual Property Associations(WIIPA).\", \"from\": 260, \"to\": 515, \"entities\": [{\"begin\": 404, \"end\": 420, \"title\": \"http://dbpedia.org/resource/Korea_University\", \"score\": 1.0, \"rank\": 1.8356670160083003e-16, \"text\": \"Korea University\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/Korea_University\", \"dbpedia\": \"http://dbpedia.org/resource/Korea_University\"}], \"noun_phrases\": [{\"ngram\": \"The international competition\", \"from\": 260, \"to\": 289}, {\"ngram\": \"place\", \"from\": 295, \"to\": 300}, {\"ngram\": \"Tuesday\", \"from\": 304, \"to\": 311}, {\"ngram\": \"Wednesday\", \"from\": 316, \"to\": 325}, {\"ngram\": \"Education\", \"from\": 353, \"to\": 362}, {\"ngram\": \"KUIA\", \"from\": 444, \"to\": 448}, {\"ngram\": \"theWorld Invention Intellectual Property Associations(WIIPA\", \"from\": 454, \"to\": 513}]}, {\"sentence\": \"A total of 206 inventions were showcased by contestants from 27 countries around the world.\", \"from\": 517, \"to\": 608, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A total\", \"from\": 517, \"to\": 524}, {\"ngram\": \"206 inventions\", \"from\": 528, \"to\": 542}, {\"ngram\": \"contestants\", \"from\": 561, \"to\": 572}, {\"ngram\": \"27 countries\", \"from\": 578, \"to\": 590}, {\"ngram\": \"the world\", \"from\": 598, \"to\": 607}]}, {\"sentence\": \"The Thai students showcased three inventions: Senior-Safety-Strider, an AI-powered walking aid with fall detection for seniors; Smart Finger Fruit, an AI-powered glove to help measure the ripeness of fruit; and Blip, a natural lip balm designed to reduce black pigmentation on the lips.\", \"from\": 610, \"to\": 896, \"entities\": [{\"begin\": 614, \"end\": 618, \"title\": \"http://dbpedia.org/resource/Thailand\", \"score\": 0.9457272976804387, \"rank\": 0.05566125518537735, \"text\": \"Thai\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Thailand\", \"dbpedia\": \"http://dbpedia.org/resource/Thailand\"}, {\"begin\": 738, \"end\": 743, \"title\": \"http://dbpedia.org/resource/Smart_Communications\", \"score\": 0.9999974397809215, \"rank\": 2.5208979486025064e-06, \"text\": \"Smart\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Smart_Communications\", \"dbpedia\": \"http://dbpedia.org/resource/Smart_Communications\"}, {\"begin\": 821, \"end\": 825, \"title\": \"http://dbpedia.org/resource/The_Blip\", \"score\": 1.0, \"rank\": 7.182198541897215e-15, \"text\": \"Blip\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/The_Blip\", \"dbpedia\": \"http://dbpedia.org/resource/The_Blip\"}], \"noun_phrases\": [{\"ngram\": \"three inventions\", \"from\": 638, \"to\": 654}, {\"ngram\": \"Senior-Safety-Strider\", \"from\": 656, \"to\": 677}, {\"ngram\": \"an AI-powered walking aid\", \"from\": 679, \"to\": 704}, {\"ngram\": \"fall detection\", \"from\": 710, \"to\": 724}, {\"ngram\": \"seniors\", \"from\": 729, \"to\": 736}, {\"ngram\": \"an AI-powered glove\", \"from\": 758, \"to\": 777}, {\"ngram\": \"the ripeness\", \"from\": 794, \"to\": 806}, {\"ngram\": \"fruit\", \"from\": 810, \"to\": 815}, {\"ngram\": \"a natural lip balm\", \"from\": 827, \"to\": 845}, {\"ngram\": \"black pigmentation\", \"from\": 865, \"to\": 883}, {\"ngram\": \"the lips\", \"from\": 887, \"to\": 895}]}, {\"sentence\": \"Their inventions earned them three medals and a special prize from the Research Institution of Creativity Education (RICE).\", \"from\": 898, \"to\": 1021, \"entities\": [{\"begin\": 1015, \"end\": 1019, \"title\": \"http://dbpedia.org/resource/RICE_(medicine)\", \"score\": 0.9652390584946159, \"rank\": 0.0, \"text\": \"RICE\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/RICE_(medicine)\", \"dbpedia\": \"http://dbpedia.org/resource/RICE_(medicine)\"}], \"noun_phrases\": [{\"ngram\": \"Their inventions\", \"from\": 898, \"to\": 914}, {\"ngram\": \"three medals\", \"from\": 927, \"to\": 939}, {\"ngram\": \"a special prize\", \"from\": 944, \"to\": 959}, {\"ngram\": \"the Research Institution\", \"from\": 965, \"to\": 989}, {\"ngram\": \"Creativity Education\", \"from\": 993, \"to\": 1013}]}, {\"sentence\": \"The four students were Pimphaporn Chonviriyabun, Kanjanick Chonviriyabun and Nadham Wongkularb from Ruamrudee International School (RIS), and Piraya Makararpong from Youth Exchange School (YES).\", \"from\": 1023, \"to\": 1217, \"entities\": [{\"begin\": 1123, \"end\": 1153, \"title\": \"http://dbpedia.org/resource/Ruamrudee_International_School\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Ruamrudee International School\", \"types\": [\"Q43229\", \"Q3914\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/Ruamrudee_International_School\", \"dbpedia\": \"http://dbpedia.org/resource/Ruamrudee_International_School\"}, {\"begin\": 1155, \"end\": 1158, \"title\": \"http://dbpedia.org/resource/United_States_of_Indonesia\", \"score\": 0.7333638289129478, \"rank\": 0.3635793099614993, \"text\": \"RIS\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States_of_Indonesia\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_of_Indonesia\"}], \"noun_phrases\": [{\"ngram\": \"The four students\", \"from\": 1023, \"to\": 1040}, {\"ngram\": \"Pimphaporn Chonviriyabun\", \"from\": 1046, \"to\": 1070}, {\"ngram\": \"Kanjanick Chonviriyabun\", \"from\": 1072, \"to\": 1095}, {\"ngram\": \"Nadham Wongkularb\", \"from\": 1100, \"to\": 1117}, {\"ngram\": \"Piraya Makararpong\", \"from\": 1165, \"to\": 1183}, {\"ngram\": \"Youth Exchange School\", \"from\": 1189, \"to\": 1210}]}, {\"sentence\": \"Thai students and visitors at the 13th World Invention Creativity Olympics in South Korea.\", \"from\": 1219, \"to\": 1309, \"entities\": [{\"begin\": 1219, \"end\": 1223, \"title\": \"http://dbpedia.org/resource/Thailand\", \"score\": 0.9457272976804387, \"rank\": 0.05566125518537735, \"text\": \"Thai\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Thailand\", \"dbpedia\": \"http://dbped