 3300, \"to\": 3426, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"IDG\", \"from\": 3327, \"to\": 3330}, {\"ngram\": \"other publications\", \"from\": 3335, \"to\": 3353}, {\"ngram\": \"developments\", \"from\": 3368, \"to\": 3380}, {\"ngram\": \"technology\", \"from\": 3384, \"to\": 3394}, {\"ngram\": \"minority rights\", \"from\": 3396, \"to\": 3411}, {\"ngram\": \"education\", \"from\": 3416, \"to\": 3425}]}, {\"sentence\": \"Covering topics in risk management, compliance, fraud, and information security.\", \"from\": 3430, \"to\": 3510, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"topics\", \"from\": 3439, \"to\": 3445}, {\"ngram\": \"risk management\", \"from\": 3449, \"to\": 3464}, {\"ngram\": \"compliance\", \"from\": 3466, \"to\": 3476}, {\"ngram\": \"fraud\", \"from\": 3478, \"to\": 3483}, {\"ngram\": \"information security\", \"from\": 3489, \"to\": 3509}]}, {\"sentence\": \"By submitting this form you agree to ourPrivacy & GDPR Statement whitepaper whitepaper Cybercrime Government Cyber Insurance Artificial Intelligence & Machine Learning AI-Based Attacks Continue \\u00bb 90 minutes \\u00b7 Premium OnDemand Overview From heightened risks to increased regulations, senior leaders at all levels are pressured to improve their organizations' risk management capabilities.\", \"from\": 3512, \"to\": 3946, \"entities\": [{\"begin\": 3562, \"end\": 3566, \"title\": \"http://dbpedia.org/resource/General_Data_Protection_Regulation\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"GDPR\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/General_Data_Protection_Regulation\", \"dbpedia\": \"http://dbpedia.org/resource/General_Data_Protection_Regulation\"}, {\"begin\": 3738, \"end\": 3746, \"title\": \"http://dbpedia.org/resource/Software_as_a_service\", \"score\": 1.0, \"rank\": 1.9459020108432856e-24, \"text\": \"OnDemand\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Software_as_a_service\", \"dbpedia\": \"http://dbpedia.org/resource/Softwar