[{\"ngram\": \"pretty dang smokey\", \"from\": 1842, \"to\": 1860}, {\"ngram\": \"Kyle-Milward\", \"from\": 1873, \"to\": 1885}]}, {\"sentence\": \"\\\"Given the wind direction, there is an assumption that Seattle might get a little smoke.\", \"from\": 1892, \"to\": 1980, \"entities\": [{\"begin\": 1947, \"end\": 1954, \"title\": \"http://dbpedia.org/resource/Seattle\", \"score\": 1.0, \"rank\": 5.1126425907979655e-17, \"text\": \"Seattle\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Seattle\", \"dbpedia\": \"http://dbpedia.org/resource/Seattle\"}], \"noun_phrases\": [{\"ngram\": \"the wind direction\", \"from\": 1899, \"to\": 1917}, {\"ngram\": \"an assumption\", \"from\": 1928, \"to\": 1941}, {\"ngram\": \"a little smoke\", \"from\": 1965, \"to\": 1979}]}, {\"sentence\": \"We are not sure how much, but they are going to at least be able to smell it.\\\"\", \"from\": 1981, \"to\": 2059, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"The fire is burning in a recently logged area with steep terrain and heavy fuels, according to an Incident Management Team news release.\", \"from\": 2061, \"to\": 2197, \"entities\": [{\"begin\": 2159, \"end\": 2183, \"title\": \"http://dbpedia.org/resource/Incident_management_team\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Incident Management Team\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Incident_management_team\", \"dbpedia\": \"http://dbpedia.org/resource/Incident_management_team\"}], \"noun_phrases\": [{\"ngram\": \"The fire\", \"from\": 2061, \"to\": 2069}, {\"ngram\": \"a recently logged area\", \"from\": 2084, \"to\": 2106}, {\"ngram\": \"steep terrain\", \"from\": 2112, \"to\": 2125}, {\"ngram\": \"heavy fuels\", \"from\": 2130, \"to\": 2141}]}, {\"sentence\": \"Crews on the ground are working to place lines around homes for protection.\", \"from\": 2198, \"to\": 2273, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Crews\", \"from\": 2198, \"to\": 2203}, {\"ngram\": \"the ground\", \"from\": 2207, \"to\": 2217}, {\"ngram\": \"lines\", \"from\": 2239, \"to\": 2244}, {\"ngram\": \"homes\", \"from\": 2252, \"to\": 2257}, {\"ngram\": \"protection\", \"from\": 2262, \"to\": 2272}]}, {\"sentence\": \"Shelters have not been opened.\", \"from\": 2275, \"to\": 2305, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Shelters\", \"from\": 2275, \"to\": 2283}]}, {\"sentence\": \"Residents evacuating and needing to shelter animals because of the fire should contact the Center Valley Animal Rescue in Quilcene.\", \"from\": 2306, \"to\": 2437, \"entities\": [{\"begin\": 2397, \"end\": 2410, \"title\": \"http://dbpedia.org/resource/Center_Valley,_Pennsylvania\", \"score\": 0.9976247030865579, \"rank\": 0.0009523809523812096, \"text\": \"Center Valley\", \"types\": [\"Q532\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Center_Valley,_Pennsylvania\", \"dbpedia\": \"http://dbpedia.org/resource/Center_Valley,_Pennsylvania\"}, {\"begin\": 2428, \"end\": 2436, \"title\": \"http://dbpedia.org/resource/Quilcene,_Washington\", \"score\": 0.9843231115469712, \"rank\": 0.0, \"text\": \"Quilcene\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Quilcene,_Washington\", \"dbpedia\": \"http://dbpedia.org/resource/Quilcene,_Washington\"}], \"noun_phrases\": [{\"ngram\": \"Residents\", \"from\": 2306, \"to\": 2315}, {\"ngram\": \"animals\", \"from\": 2350, \"to\": 2357}, {\"ngram\": \"the fire\", \"from\": 2369, \"to\": 2377}]}, {\"sentence\": \"Tips when smoke worsens air quality * Stay indoors when air quality levels are considered \\\"unhealthy,\\\" or when AQI levels exceed 150.\", \"from\": 2439, \"to\": 2573, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"air quality\", \"from\": 2463, \"to\": 2474}, {\"ngram\": \"indoors\", \"from\": 2482, \"to\": 2489}, {\"ngram\": \"air quality levels\", \"from\": 2495, \"to\": 2513}, {\"ngram\": \"AQI levels\", \"from\": 2550, \"to\": 2560}]}, {\"sentence\": \"People at higher risk from smoke - including children, those over 65, those with asthma or respiratory and heart conditions, and pregnant people - should stay indoors when AQI hits 100.\", \"from\": 2574, \"to\": 2759, \"entities\": [{\"begin\": 2746, \"end\": 2749, \"title\": \"http://dbpedia.org/resource/Air_quality_index\", \"score\": 1.0, \"rank\": 1.745043262895762e-32, \"text\": \"AQI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Air_quality_index\", \"dbpedia\": \"http://dbpedia.org/resource/Air_quality_index\"}], \"noun_phrases\": [{\"ngram\": \"People\", \"from\": 2574, \"to\": 2580}, {\"ngram\": \"higher risk\", \"from\": 2584, \"to\": 2595}, {\"ngram\": \"smoke\", \"from\": 2601, \"to\": 2606}, {\"ngram\": \"children\", \"from\": 2619, \"to\": 2627}, {\"ngram\": \"asthma\", \"from\": 2655, \"to\": 2661}, {\"ngram\": \"heart\", \"from\": 2681, \"to\": 2686}, {\"ngram\": \"conditions\", \"from\": 2687, \"to\": 2697}, {\"ngram\": \"pregnant people\", \"from\": 2703, \"to\": 2718}, {\"ngram\": \"indoors\", \"from\": 2733, \"to\": 2740}]}, {\"sentence\": \"* Limit physical activity outdoors, including physical labor, running, biking and sports, when smoke levels are \\\"unhealthy for sensitive groups,\\\" or measure over 100 AQI.\", \"from\": 2761, \"to\": 2931, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"* Limit physical activity\", \"from\": 2761, \"to\": 2786}, {\"ngram\": \"physical labor\", \"from\": 2807, \"to\": 2821}, {\"ngram\": \"running\", \"from\": 2823, \"to\": 2830}, {\"ngram\": \"biking\", \"from\": 2832, \"to\": 2838}, {\"ngram\": \"sports\", \"from\": 2843, \"to\": 2849}, {\"ngram\": \"smoke levels\", \"from\": 2856, \"to\": 2868}, {\"ngram\": \"sensitive groups\", \"from\": 2888, \"to\": 2904}, {\"ngram\": \"100 AQI\", \"from\": 2923, \"to\": 2930}]}, {\"sentence\": \"* Watch for symptoms of smoke exposure.\", \"from\": 2933, \"to\": 2972, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"symptoms\", \"from\": 2945, \"to\": 2953}, {\"ngram\": \"smoke exposure\", \"from\": 2957, \"to\": 2971}]}, {\"sentence\": \"Move people inside if they have a headache, sore throat or nose, cough, burning eyes, dizziness or wheezing.\", \"from\": 2973, \"to\": 3081, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"people\", \"from\": 2978, \"to\": 2984}, {\"ngram\": \"a headache\", \"from\": 3005, \"to\": 3015}, {\"ngram\": \"sore throat\", \"from\": 3017, \"to\": 3028}, {\"ngram\": \"nose\", \"from\": 3032, \"to\": 3036}, {\"ngram\": \"cough\", \"from\": 3038, \"to\": 3043}, {\"ngram\": \"burning eyes\", \"from\": 3045, \"to\": 3057}, {\"ngram\": \"dizziness\", \"from\": 3059, \"to\": 3068}, {\"ngram\": \"wheezing\", \"from\": 3072, \"to\": 3080}]}, {\"sentence\": \"* Improve indoor air quality by closing windows and doors, unless it gets too hot, and setting up a HEPA or box fan filter.\", \"from\": 3083, \"to\": 3206, \"entities\": [{\"begin\": 3183, \"end\": 3187, \"title\": \"http://dbpedia.org/resource/HEPA\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"HEPA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/HEPA\", \"dbpedia\": \"http://dbpedia.org/resource/HEPA\"}, {\"begin\": 3191, \"end\": 3198, \"title\": \"http://dbpedia.org/resource/Fan_(machine)\", \"score\": 0.999999839168153, \"rank\": 0.0, \"text\": \"box fan\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Fan_(machine)\", \"dbpedia\": \"http://dbpedia.org/resource/Fan_(machine)\"}, {\"begin\": 3199, \"end\": 3205, \"title\": \"http://dbpedia.org/resource/Air_filter\", \"score\": 0.9999999982373993, \"rank\": 1.5120182417542895e-09, \"text\": \"filter\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Air_filter\", \"dbpedia\": \"http://dbpedia.org/resource/Air_filter\"}], \"noun_phrases\": [{\"ngram\": \"indoor air quality\", \"from\": 3093, \"to\": 3111}, {\"ngram\": \"windows\", \"from\": 3123, \"to\": 3130}, {\"ngram\": \"doors\", \"from\": 3135, \"to\": 3140}]}, {\"sentence\": \"* Visit libraries, community centers, malls or other indoor spaces with air conditioning to stay cool.\", \"from\": 3208, \"to\": 3310, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Visit libraries\", \"from\": 3210, \"to\": 3225}, {\"ngram\": \"community centers\", \"from\": 3227, \"to\": 3244}, {\"ngram\": \"malls\", \"from\": 3246, \"to\": 3251}, {\"ngram\": \"other indoor spaces\", \"from\": 3255, \"to\": 3274}, {\"ngram\": \"air conditioning\", \"from\": 3280, \"to\": 3296}]}, {\"sentence\": \"* Wear N95 or KN95 masks when outside.\", \"from\": 3312, \"to\": 3350, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"N95\", \"from\": 3319, \"to\": 3322}, {\"ngram\": \"KN95 masks\", \"from\": 3326, \"to\": 3336}]}, {\"sentence\": \"They offer good protection from smoke for most people.\", \"from\": 3351, \"to\": 3405, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"good protection\", \"from\": 3362, \"to\": 3377}, {\"ngram\": \"smoke\", \"from\": 3383, \"to\": 3388}, {\"ngram\": \"most people\", \"from\": 3393, \"to\": 3404}]}, {\"sentence\": \"Visit st.news/WAtracker for interactive maps to track Washington wildfires and air quality.\", \"from\": 3407, \"to\": 3498, \"entities\": [{\"begin\": 3461, \"end\": 3471, \"title\": \"http://dbpedia.org/resource/University_of_Washington\", \"score\": 0.7215018119439207, \"rank\": 0.3859978249012268, \"text\": \"Washington\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/University_of_Washington\", \"dbpedia\": \"http://dbpedia.org/resource/University_of_Washington\"}], \"noun_phrases\": [{\"ngram\": \"st.news/WAtracker\", \"from\": 3413, \"to\": 3430}, {\"ngram\": \"interactive maps\", \"from\": 3435, \"to\": 3451}, {\"ngram\": \"air quality\", \"from\": 3486, \"to\": 3497}]}, {\"sentence\": \"For additional information on air quality and smoke impacts near you, visit the website AirNow.gov or the Washington Smoke Blog, which is run by local, state and federal agencies.\", \"from\": 3500, \"to\": 3679, \"entities\": [{\"begin\": 3606, \"