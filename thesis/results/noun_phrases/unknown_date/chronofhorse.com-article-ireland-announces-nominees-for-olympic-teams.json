\"to\": 507}]}, {\"sentence\": \"The following combination has been selected to serve as traveling alternate: -Aoife ClarkwithSportsfield Freelance, owned by the Freelance Syndicate.\", \"from\": 556, \"to\": 706, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The following combination\", \"from\": 556, \"to\": 581}, {\"ngram\": \"-Aoife ClarkwithSportsfield Freelance\", \"from\": 633, \"to\": 670}, {\"ngram\": \"the Freelance Syndicate\", \"from\": 681, \"to\": 704}]}, {\"sentence\": \"Seethe full list of eventing team alternates here.\", \"from\": 708, \"to\": 758, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Seethe full list\", \"from\": 708, \"to\": 724}, {\"ngram\": \"team alternates\", \"from\": 737, \"to\": 752}]}, {\"sentence\": \"\\\"It is an honor and privilege to be leading the Irish team into the Paris Olympic Games this summer, and I am absolutely delighted with the athletes and their horses, who have been raising their performances week-on-week as we have gotten to this point in the selection process,\\\" said eventing high performance director Dag Albert.\", \"from\": 760, \"to\": 1091, \"entities\": [{\"begin\": 808, \"end\": 813, \"title\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"score\": 0.820458340433543, \"rank\": 0.21710914902132894, \"text\": \"Irish\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"dbpedia\": \"http://dbpedia.org/resource/Republic_of_Ireland\"}, {\"begin\": 1084, \"end\": 1090, \"title\": \"http://dbpedia.org/resource/Matt_Bloom\", \"score\": 0.9986526688262488, \"rank\": 0.0011887386781916124, \"text\": \"Albert\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Matt_Bloom\", \"dbpedia\": \"http://dbpedia.org/resource/Matt_Bloom\"}], \"noun_phrases\": [{\"ngram\": \"an honor\", \"from\": 767, \"to\": 775}, {\"ngram\": \"privilege\", \"from\": 780, \"to\": 789}, {\"ngram\": \"the Paris Olympic Games\", \"from\":