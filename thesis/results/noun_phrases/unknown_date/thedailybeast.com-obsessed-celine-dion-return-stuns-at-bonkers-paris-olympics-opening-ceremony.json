rom\": 4801, \"to\": 4817}]}, {\"sentence\": \"I laughed along to Gaga's cheekiness.\", \"from\": 4820, \"to\": 4857, \"entities\": [{\"begin\": 4839, \"end\": 4843, \"title\": \"http://dbpedia.org/resource/Lady_Gaga\", \"score\": 1.0, \"rank\": 2.6945276710678682e-52, \"text\": \"Gaga\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Lady_Gaga\", \"dbpedia\": \"http://dbpedia.org/resource/Lady_Gaga\"}], \"noun_phrases\": []}, {\"sentence\": \"I stared bewildered at 90 percent of the dance routines.\", \"from\": 4858, \"to\": 4914, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"90 percent\", \"from\": 4881, \"to\": 4891}, {\"ngram\": \"the dance routines\", \"from\": 4895, \"to\": 4913}]}, {\"sentence\": \"I cried as C\\u00e9line sang.\", \"from\": 4915, \"to\": 4938, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"C\\u00e9line\", \"from\": 4926, \"to\": 4932}]}, {\"sentence\": \"I feared for the competitors' safety: One thing every athlete should do on the eve of the biggest physical contest of their lives is take a three-hour evening boat ride in the pouring rain.\", \"from\": 4939, \"to\": 5128, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the competitors' safety\", \"from\": 4952, \"to\": 4975}, {\"ngram\": \"One thing\", \"from\": 4977, \"to\": 4986}, {\"ngram\": \"every athlete\", \"from\": 4987, \"to\": 5000}, {\"ngram\": \"the eve\", \"from\": 5014, \"to\": 5021}, {\"ngram\": \"the biggest physical contest\", \"from\": 5025, \"to\": 5053}, {\"ngram\": \"their lives\", \"from\": 5057, \"to\": 5068}, {\"ngram\": \"a three-hour evening boat\", \"from\": 5077, \"to\": 5102}, {\"ngram\": \"the pouring rain\", \"from\": 5111, \"to\": 5127}]}, {\"sentence\": \"I learned that you can, apparently, get seasick from watching boats bob up and down on TV.\", \"from\": 5129, \"to\": 5219, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"boats\", \"from\": 5191, \"to\": 5196}, {\"ngram\": \"TV\", \"from\": 52