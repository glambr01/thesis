38, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Pat\", \"from\": 5245, \"to\": 5248}, {\"ngram\": \"everything\", \"from\": 5253, \"to\": 5263}, {\"ngram\": \"the ability\", \"from\": 5308, \"to\": 5319}]}, {\"sentence\": \"To play for him was super fun.\", \"from\": 5339, \"to\": 5369, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"super fun\", \"from\": 5359, \"to\": 5368}]}, {\"sentence\": \"No regrets there.\\\"\", \"from\": 5370, \"to\": 5388, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"No regrets\", \"from\": 5370, \"to\": 5380}]}, {\"sentence\": \"\\\"They worked their butts off tonight.\", \"from\": 5390, \"to\": 5427, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"their butts\", \"from\": 5403, \"to\": 5414}]}, {\"sentence\": \"They did everything they could,\\\" Krikorian said.\", \"from\": 5428, \"to\": 5476, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"everything\", \"from\": 5437, \"to\": 5447}, {\"ngram\": \"Krikorian\", \"from\": 5461, \"to\": 5470}]}, {\"sentence\": \"\\\"I wish we could have gotten the result.\", \"from\": 5477, \"to\": 5517, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the result\", \"from\": 5506, \"to\": 5516}]}, {\"sentence\": \"That's all you can say.\", \"from\": 5518, \"to\": 5541, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Honestly, you try to put yourself in the best position you can and you do your best and you live with the result.\", \"from\": 5542, \"to\": 5655, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the best position\", \"from\": 5579, \"to\": 5596}, {\"ngram\": \"the result\", \"from\": 5644, \"to\": 5654}]}, {\"sentence\": \"It's sadness, but you have got to also put this thing in perspective to real life and where this fits.\", \"from\": 5656, \"to\": 5758, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"sadness\", \"from\": 5661, \"to\": 5668}, {\"ngram\": \"this thing\", \"from\": 5699, \"to\": 5709}, {\"ngram\": \"perspective\", \"from\": 5713, \"to\