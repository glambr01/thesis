}]}, {\"sentence\": \"This annual event raises millions of dollars for Special Olympics every year.\", \"from\": 259, \"to\": 336, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"This annual event\", \"from\": 259, \"to\": 276}, {\"ngram\": \"millions\", \"from\": 284, \"to\": 292}, {\"ngram\": \"dollars\", \"from\": 296, \"to\": 303}, {\"ngram\": \"Special Olympics\", \"from\": 308, \"to\": 324}]}, {\"sentence\": \"Unfortunately, the traffic delays the torch run causes are expected to be made worse by this week's Route 15 bridge closure.\", \"from\": 337, \"to\": 461, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the torch run causes\", \"from\": 371, \"to\": 391}, {\"ngram\": \"this week's Route 15 bridge closure\", \"from\": 425, \"to\": 460}]}, {\"sentence\": \"All we can do is give you the times the torch run will be traveling along Sussex County Roads.\", \"from\": 462, \"to\": 556, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the times\", \"from\": 488, \"to\": 497}, {\"ngram\": \"the torch run\", \"from\": 498, \"to\": 511}, {\"ngram\": \"Sussex County Roads\", \"from\": 536, \"to\": 555}]}, {\"sentence\": \"So you can plan ahead.\", \"from\": 557, \"to\": 579, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"At 6 o'clock tomorrow morning the first leg of the run will begin at the Wantage Municipal Building and proceed south along Route 23 reaching Hamburg around 7:10.\", \"from\": 581, \"to\": 743, \"entities\": [{\"begin\": 654, \"end\": 661, \"title\": \"http://dbpedia.org/resource/Wantage\", \"score\": 0.9999999999986358, \"rank\": 7.124432365229138e-13, \"text\": \"Wantage\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Wantage\", \"dbpedia\": \"http://dbpedia.org/resource/Wantage\"}, {\"begin\": 662, \"end\": 680, \"title\": \"http://dbpedia.org/resource/Manhattan_Municipal_Building\", \"score\": 0.7644233454119899, \"rank\": 0.3070467839227031, \"text\": \"Municipal Building\", \"types\": [\"Q41176\"], \"wi