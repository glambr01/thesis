{\"ngram\": \"competition\", \"from\": 1719, \"to\": 1730}, {\"ngram\": \"that pregnancy\", \"from\": 1757, \"to\": 1771}, {\"ngram\": \"high-level athletic performance\", \"from\": 1776, \"to\": 1807}]}, {\"sentence\": \"The Paris Olympics have highlighted the achievements of not only women, but also mothers, with 16 American mother-athletes alone competing in various events.\", \"from\": 1823, \"to\": 1980, \"entities\": [{\"begin\": 1827, \"end\": 1841, \"title\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Paris Olympics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/1924_Summer_Olympics\"}, {\"begin\": 1921, \"end\": 1929, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999999998708518, \"rank\": 1.1820237198200661e-10, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"the achievements\", \"from\": 1859, \"to\": 1875}, {\"ngram\": \"not only women\", \"from\": 1879, \"to\": 1893}, {\"ngram\": \"mothers\", \"from\": 1904, \"to\": 1911}, {\"ngram\": \"various events\", \"from\": 1965, \"to\": 1979}]}, {\"sentence\": \"Thesuccess of many mother-athletes, such as New Zealanders Lucy Spoors and Brooke Francis who rowed together to win gold in double sculls, have shown it's feasible to train safely during, and return to sport successfully after pregnancy.\", \"from\": 1982, \"to\": 2219, \"entities\": [{\"begin\": 2026, \"end\": 2040, \"title\": \"http://dbpedia.org/resource/New_Zealanders\", \"score\": 0.9935840522582151, \"rank\": 0.006356007923018408, \"text\": \"New Zealanders\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/New_Zealanders\", \"dbpedia\": \"http://dbpedia.org/resource/New_Zealanders\"}, {\"begin\": 2041, \"end\": 