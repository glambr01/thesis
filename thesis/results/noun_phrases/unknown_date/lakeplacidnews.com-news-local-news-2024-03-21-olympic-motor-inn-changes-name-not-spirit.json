om\": 429, \"to\": 434}]}, {\"sentence\": \"Milne said he does not technically own the Devlin.\", \"from\": 465, \"to\": 515, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Milne\", \"from\": 465, \"to\": 470}, {\"ngram\": \"the Devlin\", \"from\": 504, \"to\": 514}]}, {\"sentence\": \"Formerly Art Devlin's Olympic Motor Inn, the hotel is now run by BNB-Buddy, a local hotel management company.\", \"from\": 516, \"to\": 625, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Formerly Art Devlin's Olympic Motor Inn\", \"from\": 516, \"to\": 555}, {\"ngram\": \"the hotel\", \"from\": 557, \"to\": 566}, {\"ngram\": \"BNB-Buddy\", \"from\": 581, \"to\": 590}, {\"ngram\": \"a local hotel management company\", \"from\": 592, \"to\": 624}]}, {\"sentence\": \"The company owns and operates Sara Placid Inn & Suites and The Ashley in Saranac Lake, the latter named for Andrew's wife Ashley, who owns BNB-Buddy.\", \"from\": 626, \"to\": 775, \"entities\": [{\"begin\": 748, \"end\": 754, \"title\": \"http://dbpedia.org/resource/Ashley_Abbott\", \"score\": 0.9566613205072132, \"rank\": 0.03481225279151521, \"text\": \"Ashley\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Ashley_Abbott\", \"dbpedia\": \"http://dbpedia.org/resource/Ashley_Abbott\"}], \"noun_phrases\": [{\"ngram\": \"The company\", \"from\": 626, \"to\": 637}, {\"ngram\": \"Sara Placid Inn\", \"from\": 656, \"to\": 671}, {\"ngram\": \"Suites\", \"from\": 674, \"to\": 680}, {\"ngram\": \"The Ashley\", \"from\": 685, \"to\": 695}, {\"ngram\": \"Saranac Lake\", \"from\": 699, \"to\": 711}, {\"ngram\": \"BNB-Buddy\", \"from\": 765, \"to\": 774}]}, {\"sentence\": \"Art Devlin, Lake Placid's current mayor, sold the hotel for $4.4 million in 2022.\", \"from\": 777, \"to\": 858, \"entities\": [{\"begin\": 777, \"end\": 787, \"title\": \"http://dbpedia.org/resource/Art_Devlin_(baseball)\", \"score\": 0.8717465996187553, \"rank\": 0.14705882352940106, \"text\": \"Art Devlin\", \"types\":