, {\"ngram\": \"the best support\", \"from\": 2739, \"to\": 2755}]}, {\"sentence\": \"\\\"I do have direct conversations with him, his parents, and there is a two-way feedback between his family and us.\", \"from\": 2758, \"to\": 2871, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"direct conversations\", \"from\": 2769, \"to\": 2789}, {\"ngram\": \"his parents\", \"from\": 2800, \"to\": 2811}, {\"ngram\": \"a two-way feedback\", \"from\": 2826, \"to\": 2844}, {\"ngram\": \"his family\", \"from\": 2853, \"to\": 2863}, {\"ngram\": \"us\", \"from\": 2868, \"to\": 2870}]}, {\"sentence\": \"The key is to keep him focused on Paris 2024.\", \"from\": 2872, \"to\": 2917, \"entities\": [{\"begin\": 2906, \"end\": 2916, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 3.97828942158753e-20, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"The key\", \"from\": 2872, \"to\": 2879}]}, {\"sentence\": \"\\\"We have fingers crossed.\", \"from\": 2919, \"to\": 2944, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"fingers\", \"from\": 2928, \"to\": 2935}]}, {\"sentence\": \"He is the world champion but at same time, we do not put undue pressure on him.\", \"from\": 2945, \"to\": 3024, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the world champion\", \"from\": 2951, \"to\": 2969}, {\"ngram\": \"same time\", \"from\": 2977, \"to\": 2986}, {\"ngram\": \"undue pressure\", \"from\": 3002, \"to\": 3016}]}, {\"sentence\": \"But we are quietly confident that he will stay focused and fly our flag high in Paris.\\\"\", \"from\": 3025, \"to\": 3112, \"entities\": [{\"begin\": 3105, \"end\": 3110, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999995793587, \"rank\": 4.2063130597309434e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"htt