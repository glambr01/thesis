ies\": [], \"noun_phrases\": [{\"ngram\": \"the opportunity\", \"from\": 8090, \"to\": 8105}, {\"ngram\": \"the Paris Olympics\", \"from\": 8120, \"to\": 8138}]}, {\"sentence\": \"It's a dream come true and a chance to showcase my hard work and dedication.\", \"from\": 8140, \"to\": 8216, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a dream\", \"from\": 8145, \"to\": 8152}, {\"ngram\": \"a chance\", \"from\": 8167, \"to\": 8175}, {\"ngram\": \"my hard work\", \"from\": 8188, \"to\": 8200}, {\"ngram\": \"dedication\", \"from\": 8205, \"to\": 8215}]}, {\"sentence\": \"I am looking forward to representing my country and experiencing the incredible atmosphere of the Games.\", \"from\": 8217, \"to\": 8321, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my country\", \"from\": 8254, \"to\": 8264}, {\"ngram\": \"the incredible atmosphere\", \"from\": 8282, \"to\": 8307}, {\"ngram\": \"the Games\", \"from\": 8311, \"to\": 8320}]}, {\"sentence\": \"It's both an honour and a motivation to push myself even further.\\\"\", \"from\": 8322, \"to\": 8388, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an honour\", \"from\": 8332, \"to\": 8341}, {\"ngram\": \"a motivation\", \"from\": 8346, \"to\": 8358}]}, {\"sentence\": \"Diane talks about her cycling journey: \\\"I decided to become a racing cyclist in 2018 because I was drawn to the thrill of competition and the freedom cycling offers.\", \"from\": 8390, \"to\": 8556, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her cycling journey\", \"from\": 8408, \"to\": 8427}, {\"ngram\": \"a racing cyclist\", \"from\": 8450, \"to\": 8466}, {\"ngram\": \"the thrill\", \"from\": 8498, \"to\": 8508}, {\"ngram\": \"competition\", \"from\": 8512, \"to\": 8523}]}, {\"sentence\": \"It's a challenging sport that pushes me to improve my physical limits and develop resilience.\", \"from\": 8557, \"to\": 8650, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a challenging sport\", \"from\": 8562, \"to\": 8581}, {\"ngram\": \"my physical limits\", \"from\": 8608, \"to\": 8626}, {\"ngram\": \"resilience\", \"from\": 8639, \"to\": 8649}]}, {\"sentence\": \"Plus, being part of a community and sharing this passion with others is incredibly rewarding.\", \"from\": 8651, \"to\": 8744, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"part\", \"from\": 8663, \"to\": 8667}, {\"ngram\": \"a community\", \"from\": 8671, \"to\": 8682}, {\"ngram\": \"this passion\", \"from\": 8695, \"to\": 8707}, {\"ngram\": \"others\", \"from\": 8713, \"to\": 8719}]}, {\"sentence\": \"\\\"I received significant support from my family, friends, and the local cycling community.\", \"from\": 8746, \"to\": 8835, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"significant support\", \"from\": 8758, \"to\": 8777}, {\"ngram\": \"my family\", \"from\": 8783, \"to\": 8792}, {\"ngram\": \"friends\", \"from\": 8794, \"to\": 8801}, {\"ngram\": \"the local cycling community\", \"from\": 8807, \"to\": 8834}]}, {\"sentence\": \"They encouraged me to pursue my passion, helped me with training, and provided resources to get started.\", \"from\": 8836, \"to\": 8940, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my passion\", \"from\": 8865, \"to\": 8875}, {\"ngram\": \"training\", \"from\": 8892, \"to\": 8900}, {\"ngram\": \"resources\", \"from\": 8915, \"to\": 8924}]}, {\"sentence\": \"This was crucial in building my confidence and skills as a racer.\", \"from\": 8941, \"to\": 9006, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my confidence\", \"from\": 8970, \"to\": 8983}, {\"ngram\": \"skills\", \"from\": 8988, \"to\": 8994}, {\"ngram\": \"a racer\", \"from\": 8998, \"to\": 9005}]}, {\"sentence\": \"\\\"To other women who would like to get into cycling racing, I would tell her to follow her passion and believe in herself.\", \"from\": 9008, \"to\": 9129, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"other women\", \"from\": 9012, \"to\": 9023}, {\"ngram\": \"cycling racing\", \"from\": 9051, \"to\": 9065}, {\"ngram\": \"her passion\", \"from\": 9094, \"to\": 9105}]}, {\"sentence\": \"Start by getting involved in local cycling clubs, do not be afraid of challenges, and surround yourself with supportive people.\", \"from\": 9130, \"to\": 9257, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"local cycling clubs\", \"from\": 9159, \"to\": 9178}, {\"ngram\": \"challenges\", \"from\": 9200, \"to\": 9210}, {\"ngram\": \"supportive people\", \"from\": 9239, \"to\": 9256}]}, {\"sentence\": \"Remember, every small step counts towards achieving your dreams.\\\"\", \"from\": 9258, \"to\": 9323, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"every small step counts\", \"from\": 9268, \"to\": 9291}, {\"ngram\": \"your dreams\", \"from\": 9310, \"to\": 9321}]}, {\"sentence\": \"In 2021, as a racer for the UCI World Cycling Centre team, she was due to represent Ethiopia at the World Championships in Ghent.\", \"from\": 9327, \"to\": 9456, \"entities\": [{\"begin\": 9355, \"end\": 9358, \"title\": \"http://dbpedia.org/resource/Union_Cycliste_Internationale\", \"score\": 1.0, \"rank\": 8.291929932347568e-17, \"text\": \"UCI\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Union_Cycliste_Internationale\", \"dbpedia\": \"http://dbpedia.org/resource/Union_Cycliste_Internationale\"}, {\"begin\": 9359, \"end\": 9379, \"title\": \"http://dbpedia.org/resource/World_Cycling_Centre\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"World Cycling Centre\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/World_Cycling_Centre\", \"dbpedia\": \"http://dbpedia.org/resource/World_Cycling_Centre\"}, {\"begin\": 9411, \"end\": 9419, \"title\": \"http://dbpedia.org/resource/Ethiopia\", \"score\": 0.9999989924377206, \"rank\": 1.0069132403764204e-06, \"text\": \"Ethiopia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ethiopia\", \"dbpedia\": \"http://dbpedia.org/resource/Ethiopia\"}, {\"begin\": 9450, \"end\": 9455, \"title\": \"http: