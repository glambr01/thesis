\": 7173, \"to\": 7180}, {\"ngram\": \"all the cars\", \"from\": 7199, \"to\": 7211}, {\"ngram\": \"cyclists\", \"from\": 7222, \"to\": 7230}]}, {\"sentence\": \"I think that if a child would really like to do cycling, their parents should give them support.\\\"\", \"from\": 7246, \"to\": 7343, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a child\", \"from\": 7262, \"to\": 7269}, {\"ngram\": \"cycling\", \"from\": 7294, \"to\": 7301}, {\"ngram\": \"their parents\", \"from\": 7303, \"to\": 7316}, {\"ngram\": \"support\", \"from\": 7334, \"to\": 7341}]}, {\"sentence\": \"Ese's focus is now fully focused on the 158km race on August 4.\", \"from\": 7345, \"to\": 7408, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Ese's focus\", \"from\": 7345, \"to\": 7356}, {\"ngram\": \"the 158km race\", \"from\": 7381, \"to\": 7395}, {\"ngram\": \"August\", \"from\": 7399, \"to\": 7405}]}, {\"sentence\": \"\\\"I have learned so much since joining Canyon-SRAM Generation.\", \"from\": 7410, \"to\": 7471, \"entities\": [{\"begin\": 7448, \"end\": 7459, \"title\": \"http://dbpedia.org/resource/Canyon\\u2013SRAM\", \"score\": 0.9999999999499778, \"rank\": 0.0, \"text\": \"Canyon-SRAM\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/Canyon\\u2013SRAM\", \"dbpedia\": \"http://dbpedia.org/resource/Canyon\\u2013SRAM\"}], \"noun_phrases\": []}, {\"sentence\": \"If it wasn't for the team and being in Girona, I would not have had this improvement.\", \"from\": 7472, \"to\": 7557, \"entities\": [{\"begin\": 7511, \"end\": 7517, \"title\": \"http://dbpedia.org/resource/Girona\", \"score\": 0.9987977625393829, \"rank\": 0.0012036845661052883, \"text\": \"Girona\", \"types\": [\"Q486972\", \"Q3957\"], \"wikid\": \"http://dbpedia.org/resource/Girona\", \"dbpedia\": \"http://dbpedia.org/resource/Girona\"}], \"noun_phrases\": [{\"ngram\": \"the team\", \"from\": 7489, \"to\": 7497}, {\"ngram\": \"this improvement\", \"from\": 7540, \"to\": 7556}]}, {\"sentence\": \"It's not going to be easy for me as it will be my first Olympics.\", \"from\": 7558, \"to\": 7623, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my first Olympics\", \"from\": 7605, \"to\": 7622}]}, {\"sentence\": \"But I want to make my team proud and to make my sisters happy.\\\"\", \"from\": 7624, \"to\": 7687, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my team\", \"from\": 7643, \"to\": 7650}, {\"ngram\": \"my sisters\", \"from\": 7669, \"to\": 7679}]}, {\"sentence\": \"Also taking the start line at Trocadero, close to the Eiffel Tower will be one of Ese's teammates, Diane Ingabire, representing Rwanda.\", \"from\": 7691, \"to\": 7826, \"entities\": [{\"begin\": 7721, \"end\": 7730, \"title\": \"http://dbpedia.org/resource/London_Trocadero\", \"score\": 0.9999999764304451, \"rank\": 2.3569028537601435e-08, \"text\": \"Trocadero\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/London_Trocadero\", \"dbpedia\": \"http://dbpedia.org/resource/London_Trocadero\"}, {\"begin\": 7790, \"end\": 7795, \"title\": \"http://dbpedia.org/resource/Diane_Chambers\", \"score\": 0.9993187663414757, \"rank\": 0.0006816956221179244, \"text\": \"Diane\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Diane_Chambers\", \"dbpedia\": \"http://dbpedia.org/resource/Diane_Chambers\"}, {\"begin\": 7819, \"end\": 7825, \"title\": \"http://dbpedia.org/resource/Rwanda\", \"score\": 0.9999999998381099, \"rank\": 1.345362064610363e-10, \"text\": \"Rwanda\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Rwanda\", \"dbpedia\": \"http://dbpedia.org/resource/Rwanda\"}], \"noun_phrases\": [{\"ngram\": \"the start line\", \"from\": 7703, \"to\": 7717}, {\"ngram\": \"the Eiffel Tower\", \"from\": 7741, \"to\": 7757}, {\"ngram\": \"Ese's teammates\", \"from\": 7773, \"to\": 7788}]}, {\"sentence\": \"Diane qualified for the Olympics when she won the Rwandan National Road Race and Time Trial Championships.\"