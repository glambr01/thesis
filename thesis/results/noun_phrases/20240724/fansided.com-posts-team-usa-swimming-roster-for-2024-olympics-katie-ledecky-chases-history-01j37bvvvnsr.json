"{\"uid\": \"fansided.com-posts-team-usa-swimming-roster-for-2024-olympics-katie-ledecky-chases-history-01j37bvvvnsr\", \"noun_phrases\": [{\"sentence\": \"Katie Ledecky is arguably the greatest female swimmer in history with unmatched dominance across the years.\", \"from\": 0, \"to\": 107, \"entities\": [{\"begin\": 0, \"end\": 13, \"title\": \"http://dbpedia.org/resource/Katie_Ledecky\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Katie Ledecky\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Katie_Ledecky\", \"dbpedia\": \"http://dbpedia.org/resource/Katie_Ledecky\"}], \"noun_phrases\": [{\"ngram\": \"the greatest female swimmer\", \"from\": 26, \"to\": 53}, {\"ngram\": \"history\", \"from\": 57, \"to\": 64}, {\"ngram\": \"unmatched dominance\", \"from\": 70, \"to\": 89}, {\"ngram\": \"the years\", \"from\": 97, \"to\": 106}]}, {\"sentence\": \"After herOlympicdebut in 2012 which saw her win the 800m freestyle gold as an underdog, she has never entered a competition anything less than a favorite, and the same would be the case when she lines up for her fourth consecutive gold at the2024 Paris Olympics.\", \"from\": 108, \"to\": 370, \"entities\": [{\"begin\": 355, \"end\": 369, \"title\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Paris Olympics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/1924_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"herOlympicdebut\", \"from\": 114, \"to\": 129}, {\"ngram\": \"the 800m freestyle gold\", \"from\": 156, \"to\": 179}, {\"ngram\": \"an underdog\", \"from\": 183, \"to\": 194}, {\"ngram\": \"a competition\", \"from\": 218, \"to\": 231}, {\"ngram\": \"anything\", \"from\": 232, \"to\": 240}, {\"ngram\": \"the case\", \"from\": 285, \"to\": 293}, {\"ngram\": \"her fourth consecutive gold\", \"from\": 316, \"to\": 343}]}, {\"sentence\": \"If Ledecky wins the 800m freestyle gold again, she will become the first female swimmer to win any event four consecutive times at Olympic Games.\", \"from\": 372, \"to\": 517, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Ledecky\", \"from\": 375, \"to\": 382}, {\"ngram\": \"the 800m freestyle gold\", \"from\": 388, \"to\": 411}, {\"ngram\": \"the first female swimmer\", \"from\": 435, \"to\": 459}, {\"ngram\": \"any event\", \"from\": 467, \"to\": 476}, {\"ngram\": \"Olympic Games\", \"from\": 503, \"to\": 516}]}, {\"sentence\": \"If her dominance in 800m freestyle was anything less, the 10-time Olympic medalist owns the 19 fastest times in the 1500m freestyle history.\", \"from\": 518, \"to\": 658, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her dominance\", \"from\": 521, \"to\": 534}, {\"ngram\": \"800m freestyle\", \"from\": 538, \"to\": 552}, {\"ngram\": \"anything\", \"from\": 557, \"to\": 565}, {\"ngram\": \"the 10-time Olympic medalist\", \"from\": 572, \"to\": 600}, {\"ngram\": \"the 19 fastest times\", \"from\": 606, \"to\": 626}, {\"ngram\": \"the 1500m freestyle history\", \"from\": 630, \"to\": 657}]}, {\"sentence\": \"Ledecky is the defending champion in the event as well.\", \"from\": 659, \"to\": 714, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Ledecky\", \"from\": 659, \"to\": 666}, {\"ngram\": \"the defending champion\", \"from\": 670, \"to\": 692}, {\"ngram\": \"the event\", \"from\": 696, \"to\": 705}]}, {\"sentence\": \"She has the 400m freestyle up her arsenal as well and is the American record holder in the event.\", \"from\": 716, \"to\": 813, \"entities\": [{\"begin\": 777, \"end\": 785, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9998255803463825, \"rank\": 0.0001507651209610903, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"the 400m freestyle\", \"from\": 724, \"to\": 742}, {\"ngram\": \"her arsenal\", \"from\": 746, \"to\": 757}, {\"ngram\": \"the event\", \"from\": 803, \"to\": 812}]}, {\"sentence\": \"Ledecky is an overwhelming favorite in all three events at the Paris Olympics 2024, and though she has qualified for 200m freestyle as well, the 27-year-old is likely to drop that.\", \"from\": 814, \"to\": 994, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Ledecky\", \"from\": 814, \"to\": 821}, {\"ngram\": \"an overwhelming favorite\", \"from\": 825, \"to\": 849}, {\"ngram\": \"all three events\", \"from\": 853, \"to\": 869}, {\"ngram\": \"the Paris Olympics\", \"from\": 873, \"to\": 891}, {\"ngram\": \"200m freestyle\", \"from\": 931, \"to\": 945}]}, {\"sentence\": \"She will instead focus on her fourth gold medal in 4x200m freestyle.\", \"from\": 995, \"to\": 1063, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her fourth gold medal\", \"from\": 1021, \"to\": 1042}, {\"ngram\": \"4x200m freestyle\", \"from\": 1046, \"to\": 1062}]}, {\"sentence\": \"However, Ledecky will only need two gold medals to become the most decorated female swimmer of all time.\", \"from\": 1064, \"to\": 1168, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Ledecky\", \"from\": 1073, \"to\": 1080}, {\"ngram\": \"two gold medals\", \"from\": 1096, \"to\": 1111}, {\"ngram\": \"the most decorated female swimmer\", \"from\": 1122, \"to\": 1155}, {\"ngram\": \"all time\", \"from\": 1159, \"to\": 1167}]}, {\"sentence\": \"Athletes Hometown Events qualified in Jack Alexy Morristown, NJ 100m freestyle 4x100m freestyle relay Hunter Armstrong Dover, OH 100m backstroke 4x100m freestyle relay Shaine Casas McAllen, TX 200m IM Brooks Curry Dunwoody, GA 4x200m freestyle relay Caeleb Dressel Orange Park, FL 50m freestyle 100m butterfly 4x100m freestyle relay Matt Fallon Warren, N.J. 200m breaststroke Nic Fink Morristown, NJ 100m breastroke Bobby Finke Clearwater, FL 800m freestyle 1500m freestyle Carson