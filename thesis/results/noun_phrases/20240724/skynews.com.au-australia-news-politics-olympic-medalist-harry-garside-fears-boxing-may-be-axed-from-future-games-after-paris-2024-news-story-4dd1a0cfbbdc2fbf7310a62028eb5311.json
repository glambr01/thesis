"{\"uid\": \"skynews.com.au-australia-news-politics-olympic-medalist-harry-garside-fears-boxing-may-be-axed-from-future-games-after-paris-2024-news-story-4dd1a0cfbbdc2fbf7310a62028eb5311\", \"noun_phrases\": [{\"sentence\": \"The inclusion of new Olympic sports is a long-standing tradition, but one Australian star athlete has raised concerns a staple event could be axed after Paris 2024.\", \"from\": 0, \"to\": 164, \"entities\": [{\"begin\": 74, \"end\": 89, \"title\": \"http://dbpedia.org/resource/The_Australian_Star\", \"score\": 0.9999999999988631, \"rank\": 0.0, \"text\": \"Australian star\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/The_Australian_Star\", \"dbpedia\": \"http://dbpedia.org/resource/The_Australian_Star\"}, {\"begin\": 153, \"end\": 163, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.042186194490027e-21, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"The inclusion\", \"from\": 0, \"to\": 13}, {\"ngram\": \"new Olympic sports\", \"from\": 17, \"to\": 35}, {\"ngram\": \"a long-standing tradition\", \"from\": 39, \"to\": 64}, {\"ngram\": \"concerns\", \"from\": 109, \"to\": 117}, {\"ngram\": \"a staple event\", \"from\": 118, \"to\": 132}]}, {\"sentence\": \"Breakdancing, men's artistic swimming and skateboarding will all be on the agenda at the 2024 Paris Olympics.\", \"from\": 166, \"to\": 275, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the agenda\", \"from\": 237, \"to\": 247}, {\"ngram\": \"the 2024 Paris Olympics\", \"from\": 251, \"to\": 274}]}, {\"sentence\": \"But there are fears for the future of a sport that has been part of the Games for 120 years.\", \"from\": 277, \"to\": 369, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"fears\", \"from\": 291, \"to\": 296}, {\"ngram\": \"the future\", \"from\": 301, \"to\": 311}, {\"ngram\": \"a sport\", \"from\": 315, \"to\": 322}, {\"ngram\": \"part\", \"from\": 337, \"to\": 341}, {\"ngram\": \"the Games\", \"from\": 345, \"to\": 354}, {\"ngram\": \"120 years\", \"from\": 359, \"to\": 368}]}, {\"sentence\": \"Tokyo bronze medallist Harry Garside said it would be a \\\"crime\\\" if boxing was scrapped from the Olympic line-up after the 2024 Games.\", \"from\": 371, \"to\": 504, \"entities\": [{\"begin\": 371, \"end\": 376, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.7271274633441934, \"rank\": 0.3752742531899587, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}], \"noun_phrases\": [{\"ngram\": \"a \\\"crime\", \"from\": 425, \"to\": 433}, {\"ngram\": \"boxing\", \"from\": 438, \"to\": 444}, {\"ngram\": \"the Olympic line-up\", \"from\": 463, \"to\": 482}, {\"ngram\": \"the 2024 Games\", \"from\": 489, \"to\": 503}]}, {\"sentence\": \"\\\"It's more about the young up-and-coming people who dream of this,\\\" he said.\", \"from\": 506, \"to\": 582, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the young up-and-coming people\", \"from\": 523, \"to\": 553}]}, {\"sentence\": \"\\\"All of our dreams started somewhere and whether you are a boxer or you are from another sport we all love the Olympic movement, that's why we are here, we love wearing the green and gold, we love fighting for our country and I think to take that away from some young people around the world would be a crime.\\\"\", \"from\": 584, \"to\": 894, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"our dreams\", \"from\": 592, \"to\": 602}, {\"ngram\": \"a boxer\", \"from\": 641, \"to\": 648}, {\"ngram\": \"another sport\", \"from\": 665, \"to\": 678}, {\"ngram\": \"the Olympic movement\", \"from\": 691, \"to\": 711}, {\"ngram\": \"the green\", \"from\": 753, \"to\": 762}, {\"ngram\": \"gold\", \"from\": 767, \"to\": 771}, {