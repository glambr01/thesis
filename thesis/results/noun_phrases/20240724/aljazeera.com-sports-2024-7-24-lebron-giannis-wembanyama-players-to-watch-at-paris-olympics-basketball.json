ities\": [{\"begin\": 5006, \"end\": 5009, \"title\": \"http://dbpedia.org/resource/National_Basketball_Association\", \"score\": 1.0, \"rank\": 6.838183487230192e-79, \"text\": \"NBA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/National_Basketball_Association\", \"dbpedia\": \"http://dbpedia.org/resource/National_Basketball_Association\"}], \"noun_phrases\": [{\"ngram\": \"Antetokounmpo\", \"from\": 4858, \"to\": 4871}, {\"ngram\": \"the \\\"Greek Freak\", \"from\": 4888, \"to\": 4904}, {\"ngram\": \"recognition\", \"from\": 4909, \"to\": 4920}, {\"ngram\": \"his outrageously athletic drives\", \"from\": 4924, \"to\": 4956}, {\"ngram\": \"the basketball court\", \"from\": 4960, \"to\": 4980}, {\"ngram\": \"30.4 points\", \"from\": 5046, \"to\": 5057}, {\"ngram\": \"game\", \"from\": 5062, \"to\": 5066}, {\"ngram\": \"11.5 rebounds\", \"from\": 5085, \"to\": 5098}, {\"ngram\": \"6.5 assists\", \"from\": 5103, \"to\": 5114}]}, {\"sentence\": \"While he has added the three-point shot to his arsenal over the last few years, his real value comes from his rampaging - and often, unstoppable - drives into the paint, which he usually finishes with a thunderous dunk.\", \"from\": 5117, \"to\": 5336, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the three-point shot\", \"from\": 5136, \"to\": 5156}, {\"ngram\": \"his arsenal\", \"from\": 5160, \"to\": 5171}, {\"ngram\": \"the last few years\", \"from\": 5177, \"to\": 5195}, {\"ngram\": \"his real value\", \"from\": 5197, \"to\": 5211}, {\"ngram\": \"his rampaging\", \"from\": 5223, \"to\": 5236}, {\"ngram\": \"the paint\", \"from\": 5276, \"to\": 5285}, {\"ngram\": \"a thunderous dunk\", \"from\": 5318, \"to\": 5335}]}, {\"sentence\": \"Greece are hoping to make a deep run in the tournament but they are drawn in the \\\"Group of Death\\\" alongside Spain, Australia and Canada.\", \"from\": 5338, \"to\": 5474, \"entities\": [{\"begin\": 5338, \"end\": 5344, \"title\": \"http://dbpedia.org/resource/Greece_nat