ities\": [], \"noun_phrases\": [{\"ngram\": \"anything\", \"from\": 2724, \"to\": 2732}, {\"ngram\": \"my lips\", \"from\": 2738, \"to\": 2745}]}, {\"sentence\": \"With the commencement of the 2024 Paris Olympics this Friday, fans will be able to watch Simone Biles' beauty looks in action.\", \"from\": 2792, \"to\": 2918, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the commencement\", \"from\": 2797, \"to\": 2813}, {\"ngram\": \"the 2024 Paris Olympics\", \"from\": 2817, \"to\": 2840}, {\"ngram\": \"fans\", \"from\": 2854, \"to\": 2858}, {\"ngram\": \"action\", \"from\": 2911, \"to\": 2917}]}, {\"sentence\": \"The beauty of Black athletes is on the tri-level podium at the upcoming Games (we can not wait to see Sha'Carri Richardson have her moment)--and they are taking home the gold every time.\", \"from\": 2919, \"to\": 3105, \"entities\": [{\"begin\": 3027, \"end\": 3047, \"title\": \"http://dbpedia.org/resource/Sha'Carri_Richardson\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Sha'Carri Richardson\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Sha'Carri_Richardson\", \"dbpedia\": \"http://dbpedia.org/resource/Sha'Carri_Richardson\"}], \"noun_phrases\": [{\"ngram\": \"The beauty\", \"from\": 2919, \"to\": 2929}, {\"ngram\": \"Black athletes\", \"from\": 2933, \"to\": 2947}, {\"ngram\": \"the tri-level podium\", \"from\": 2954, \"to\": 2974}, {\"ngram\": \"the upcoming Games\", \"from\": 2978, \"to\": 2996}, {\"ngram\": \"the gold\", \"from\": 3085, \"to\": 3093}]}]}"