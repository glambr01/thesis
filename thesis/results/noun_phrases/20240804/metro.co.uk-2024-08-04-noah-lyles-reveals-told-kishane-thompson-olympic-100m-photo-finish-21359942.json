"{\"uid\": \"metro.co.uk-2024-08-04-noah-lyles-reveals-told-kishane-thompson-olympic-100m-photo-finish-21359942\", \"noun_phrases\": [{\"sentence\": \"Noah Lyles has revealed that he thought Kishane Thompson had won theirOlympic100m final.\", \"from\": 0, \"to\": 88, \"entities\": [{\"begin\": 0, \"end\": 10, \"title\": \"http://dbpedia.org/resource/Noah_Lyles\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Noah Lyles\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Noah_Lyles\", \"dbpedia\": \"http://dbpedia.org/resource/Noah_Lyles\"}, {\"begin\": 48, \"end\": 56, \"title\": \"http://dbpedia.org/resource/Klay_Thompson\", \"score\": 0.9756963561816728, \"rank\": 0.02490901940137801, \"text\": \"Thompson\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Klay_Thompson\", \"dbpedia\": \"http://dbpedia.org/resource/Klay_Thompson\"}], \"noun_phrases\": [{\"ngram\": \"theirOlympic100\", \"from\": 65, \"to\": 80}]}, {\"sentence\": \"TheUnited Statessprinter is the new Olympic champion following a dramatic end to the men's 100m final inParison Sunday evening.\", \"from\": 90, \"to\": 217, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"TheUnited Statessprinter\", \"from\": 90, \"to\": 114}, {\"ngram\": \"the new Olympic champion\", \"from\": 118, \"to\": 142}, {\"ngram\": \"a dramatic end\", \"from\": 153, \"to\": 167}, {\"ngram\": \"the men's 100m final inParison\", \"from\": 171, \"to\": 201}]}, {\"sentence\": \"A photo finish was required to split Lyles and Thompson, who was the favourite heading into the race after his impressive time of 9.80 seconds earlier in the semi final.\", \"from\": 219, \"to\": 388, \"entities\": [{\"begin\": 266, \"end\": 274, \"title\": \"http://dbpedia.org/resource/Klay_Thompson\", \"score\": 0.9756963561816728, \"rank\": 0.02490901940137801, \"text\": \"Thompson\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Klay_Thompson\", \"dbpedia\": \"http://dbpedia.org/resource/Klay_Thompson\"}], \"noun_phrases\": [{\"ngram\": \"A photo finish\", \"from\": 219, \"to\": 233}, {\"ngram\": \"Lyles\", \"from\": 256, \"to\": 261}, {\"ngram\": \"the favourite heading\", \"from\": 284, \"to\": 305}, {\"ngram\": \"the race\", \"from\": 311, \"to\": 319}, {\"ngram\": \"his impressive time\", \"from\": 326, \"to\": 345}, {\"ngram\": \"the semi final\", \"from\": 373, \"to\": 387}]}, {\"sentence\": \"But Lyles finished 0.005 seconds ahead of Thompson and the 27-year-old has now won the first Olympic gold medal of his career.\", \"from\": 390, \"to\": 516, \"entities\": [{\"begin\": 394, \"end\": 399, \"title\": \"http://dbpedia.org/resource/Jordan_Lyles\", \"score\": 0.9608120430182666, \"rank\": 0.04034189530538471, \"text\": \"Lyles\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Jordan_Lyles\", \"dbpedia\": \"http://dbpedia.org/resource/Jordan_Lyles\"}, {\"begin\": 432, \"end\": 440, \"title\": \"http://dbpedia.org/resource/Klay_Thompson\", \"score\": 0.9756963561816728, \"rank\": 0.02490901940137801, \"text\": \"Thompson\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Klay_Thompson\", \"dbpedia\": \"http://dbpedia.org/resource/Klay_Thompson\"}], \"noun_phrases\": [{\"ngram\": \"the first Olympic gold medal\", \"from\": 473, \"to\": 501}, {\"ngram\": \"his career\", \"from\": 505, \"to\": 515}]}, {\"sentence\": \"'It was a very close race,' Lyles told Jamaican broadcaster SportsMax TV after his victory.\", \"from\": 518, \"to\": 609, \"entities\": [{\"begin\": 546, \"end\": 551, \"title\": \"http://dbpedia.org/resource/Jordan_Lyles\", \"score\": 0.9608120430182666, \"rank\": 0.04034189530538471, \"text\": \"Lyles\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Jordan_Lyles\", \"dbpedia\": \"http://dbpedia.org/resource/Jordan_Lyles\"}, {\"begin\": 557, \"end\": 565, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.9735049492441984, \"rank\": 0.027215996753668818, \"text\": \"Jamaican\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}, {\"begin\": 588, \"end\": 590, \"title\": \"http://dbpedia.org/resource/Television\", \"score\": 0.9203177220338431, \"rank\": 0.05892826843399924, \"text\": \"TV\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Television\", \"dbpedia\": \"http://dbpedia.org/resource/Television\"}], \"noun_phrases\": [{\"ngram\": \"a very close race\", \"from\": 526, \"to\": 543}, {\"ngram\": \"his victory\", \"from\": 597, \"to\": 608}]}, {\"sentence\": \"'I am glad I had Oblique Seville next to me because I was like, 'yo, I need someone to put that pressure on me early'.\", \"from\": 611, \"to\": 729, \"entities\": [{\"begin\": 636, \"end\": 643, \"title\": \"http://dbpedia.org/resource/Seville\", \"score\": 0.9999999763599593, \"rank\": 2.340345752935315e-08, \"text\": \"Seville\", \"types\": [\"Q486972\", \"Q3957\"], \"wikid\": \"http://dbpedia.org/resource/Seville\", \"dbpedia\": \"http://dbpedia.org/resource/Seville\"}], \"noun_phrases\": [{\"ngram\": \"someone\", \"from\": 687, \"to\": 694}, {\"ngram\": \"that pressure\", \"from\": 702, \"to\": 715}]}, {\"sentence\": \"I know that in a lot of races he's been one or two lanes away from me and he's been able to be get out just in that acceleration phase and I have just been missing it.\", \"from\": 730, \"to\": 897, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a lot\", \"from\": 745, \"to\": 750}, {\"ngram\": \"races\", \"from\": 754, \"to\": 759}, {\"ngram\": \"that acceleration phase\", \"from\": 841, \"to\": 864}]}, {\"sentence\": \"I was like, 'nah, now that you are right next to me I will make sure I cover that'.\", \"from\": 898, \"to\": 981, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"'And then after I passed him I saw Kishane out there I was like just do what I do, hit my top-end speed, let it work.\", \"from\": 983, \"to\": 1100, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Kishane\", \"from\": 1018, \"to\": 1025}, {\"ngram\": \"my top-end speed\", \"from\": 1070, \"to\": 1086}]}, {\"sentence\": \"'To be honest, I did not know if I had it.\", \"from\": 1102, \"to\": 1144, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I leaned but I did not know I had it.\", \"from\": 1145, \"to\": 1182, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"'Me and Kishane were at the end waiting for our names to come up and I came back and I said, 'I will be honest, man, I think you got that one'.\", \"from\": 1184, \"to\": 1327, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Kishane\", \"from\": 1192, \"to\": 1199}, {\"ngram\": \"the end\", \"from\": 1208, \"to\": 1215}, {\"ngram\": \"our names\", \"from\": 1228, \"to\": 1237}, {\"ngram\": \"that one\", \"from\": 1317, \"to\": 1325}]}, {\"sentence\": \"'But my name came up and I was like, 'oh my gosh, I am amazing'.\", \"from\": 1329, \"to\": 1393, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my name\", \"from\": 1334, \"to\": 1341}]}, {\"sentence\": \"'I have waited a long time, I have seen Jamaican's dominate the 100m and 200m for so long and I remember growing up saying, 'when it's my turn I am going to make sure that the US is on top'.\", \"from\": 1395, \"to\": 1585, \"entities\": [{\"begin\": 1435, \"end\": 1443, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.9735049492441984, \"rank\": 0.027215996753668818, \"text\": \"Jamaican\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}, {\"begin\": 1571, \"end\": 1573, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 0.538057529282402, \"rank\": 0.8383593634512255, \"text\": \"US\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\"}], \"noun_phrases\": [{\"ngram\": \"the 100m\", \"from\": 1455, \"to\": 1463}, {\"ngram\": \"my turn\", \"from\": 1530, \"to\": 1537}, {\"ngram\": \"top\", \"from\": 1580, \"to\": 1583}]}, {\"sentence\": \"And here it is, here's my time, my journey, my moment, it's such a beautiful thing to see.'\", \"from\": 1586, \"to\": 1677, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my time\", \"from\": 1609, \"to\": 1616}, {\"ngram\": \"my moment\", \"from\": 1630, \"to\": 1639}, {\"ngram\": \"such a beautiful thing\", \"from\": 1646, \"to\": 1668}]}, {\"sentence\": \"In a separate interview with the BBC, Lyles admitted he was frustrated with his performance in the semi final earlier on Sunday evening after he finished second behind Jamaica's Oblique Seville.\", \"from\": 1679, \"to\": 1873, \"entities\": [{\"begin\": 1712, \"end\": 1715, \"title\": \"http://dbpedia.org/resource/BBC_Sport\", \"score\": 0.9875104108785916, \"rank\": 0.01138051650168465, \"text\": \"BBC\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/BBC_Sport\", \"dbpedia\": \"http://dbpedia.org/resource/BBC_Sport\"}, {\"begin\": 1717, \"end\": 1722, \"title\": \"http://dbpedia.org/resource/Jordan_Lyles\", \"score\": 0.9608120430182666, \"rank\": 0.04034189530538471, \"text\": \"Lyles\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Jordan_Lyles\", \"dbpedia\": \"http://dbpedia.org/resource/Jordan_Lyles\"}, {\"begin\": 1847, \"end\": 1854, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.9999999540868895, \"rank\": 4.583563016846421e-08, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}, {\"begin\": 1865, \"end\": 1872, \"title\": \"http://dbpedia.org/resource/Seville\", \"score\": 0.9999999763599593, \"rank\": 2.340345752935315e-08, \"text\": \"Seville\", \"types\": [\"Q486972\", \"Q3957\"], \"wikid\": \"http://dbpedia.org/resource/Seville\", \"dbpedia\": \"http://dbpedia.org/resource/Seville\"}], \"noun_phrases\": [{\"ngram\": \"a separate interview\", \"from\": 1682, \"to\": 1702}, {\"ngram\": \"his performance\", \"from\": 1755, \"to\": 1770}, {\"ngram\": \"Sunday evening\", \"from\": 1800, \"to\": 1814}]}, {\"sentence\": \"'A guy in biomechanics comes down and before I came out here, he said it was going to be this much, that's how close it is going to be and gosh was he right,' Lyles said.\", \"from\": 1875, \"to\": 2045, \"entities\": [{\"begin\": 2034, \"end\": 2039, \"title\": \"http://dbpedia.org/resource/Jordan_Lyles\", \"score\": 0.9608120430182666, \"rank\": 0.04034189530538471, \"text\": \"Lyles\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Jordan_Lyles\", \"dbpedia\": \"http://dbpedia.org/resource/Jordan_Lyles\"}], \"noun_phrases\": [{\"ngram\": \"A guy\", \"from\": 1876, \"to\": 1881}, {\"ngram\": \"biomechanics\", \"from\": 1885, \"to\": 1897}]}, {\"sentence\": \"'I had to take every round as it was and I was a little upset after the first round so I came with the aggression and after I ran that 83 and I was done with the aggression.\", \"from\": 2047, \"to\": 2220, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"every round\", \"from\": 2062, \"to\": 2073}, {\"ngram\": \"the first round\", \"from\": 2115, \"to\": 2130}, {\"ngram\": \"the aggression\", \"from\": 2146, \"to\": 2160}, {\"ngram\": \"the aggression\", \"from\": 2205, \"to\": 2219}]}, {\"sentence\": \"'My sports therapist told me you need to let go, you are holding on.\", \"from\": 2222, \"to\": 2290, \"entities