s\": [{\"ngram\": \"the call room\", \"from\": 2300, \"to\": 2313}, {\"ngram\": \"the championships\", \"from\": 2331, \"to\": 2348}, {\"ngram\": \"anything\", \"from\": 2353, \"to\": 2361}, {\"ngram\": \"the last moment\", \"from\": 2376, \"to\": 2391}, {\"ngram\": \"Neita\", \"from\": 2394, \"to\": 2399}]}, {\"sentence\": \"\\\"I really need to stay focused on myself, I can not really be looking at the field too much but I just wish her the best with whatever's happening.\\\"\", \"from\": 2407, \"to\": 2555, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the field\", \"from\": 2480, \"to\": 2489}, {\"ngram\": \"whatever\", \"from\": 2533, \"to\": 2541}]}, {\"sentence\": \"Fraser-Pryce revealed her disappointment at her Games ending on Saturday night, stating: \\\"It is difficult for me to find the words to describe the depth of my disappointment.\", \"from\": 2557, \"to\": 2731, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Fraser-Pryce\", \"from\": 2557, \"to\": 2569}, {\"ngram\": \"her disappointment\", \"from\": 2579, \"to\": 2597}, {\"ngram\": \"her Games\", \"from\": 2601, \"to\": 2610}, {\"ngram\": \"Saturday night\", \"from\": 2621, \"to\": 2635}, {\"ngram\": \"the words\", \"from\": 2678, \"to\": 2687}, {\"ngram\": \"the depth\", \"from\": 2700, \"to\": 2709}, {\"ngram\": \"my disappointment\", \"from\": 2713, \"to\": 2730}]}, {\"sentence\": \"\\\"I know that my supporters share and shoulder this disappointment with me.\", \"from\": 2733, \"to\": 2807, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my supporters\", \"from\": 2746, \"to\": 2759}, {\"ngram\": \"this disappointment\", \"from\": 2779, \"to\": 2798}]}, {\"sentence\": \"I am truly blessed to have had the steadfast support of my fans since my Olympic debut in 2008.\", \"from\": 2808, \"to\": 2903, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the steadfast support\", \"from\": 2839, \"to\": 2860}, {\"ngram\": \"my fans\", \"from\": 2864, \"to\": 2871}, {\"ngram\": \"my Olympic debut\", \"from\": 2878, \"to\": 2894}]}, {\"sentence\": \"\\\"The support of my fans, my country, and the larger community has rooted me in immense gratitude that has sustained me throughout my career.\", \"from\": 2905, \"to\": 3045, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The support\", \"from\": 2906, \"to\": 2917}, {\"ngram\": \"my fans\", \"from\": 2921, \"to\": 2928}, {\"ngram\": \"my country\", \"from\": 2930, \"to\": 2940}, {\"ngram\": \"the larger community\", \"from\": 2946, \"to\": 2966}, {\"ngram\": \"immense gratitude\", \"from\": 2984, \"to\": 3001}, {\"ngram\": \"my career\", \"from\": 3035, \"to\": 3044}]}, {\"sentence\": \"\\\"With every step and win, you all have been there for me.\", \"from\": 3047, \"to\": 3104, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"every step\", \"from\": 3053, \"to\": 3063}, {\"ngram\": \"win\", \"from\": 3068, \"to\": 3071}]}, {\"sentence\": \"My faith has always affirmed my trust in my journey.\", \"from\": 3105, \"to\": 3157, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My faith\", \"from\": 3105, \"to\": 3113}, {\"ngram\": \"my trust\", \"from\": 3134, \"to\": 3142}, {\"ngram\": \"my journey\", \"from\": 3146, \"to\": 3156}]}, {\"sentence\": \"Thank you for continuing to be with me today and every day.\\\"\", \"from\": 3158, \"to\": 3218, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Join thought-provoking conversations, follow other Independent readers and see their replies Please refresh the page or navigate to another page on the site to be automatically logged inPlease refresh your browser to be logged in\", \"from\": 3220, \"to\": 3450, \"entities\": [{\"begin\": 3271, \"end\": 3282, \"title\": \"http://dbpedia.org/resource/The_Independent\", \"score\": 0.9999999999986358, \"rank\": 1.1952525090353667e-12, \"text\": \"Independent\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Independent\", \"dbpedia\": \"http://