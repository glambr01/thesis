3}, {\"ngram\": \"a male gymnast\", \"from\": 2420, \"to\": 2434}, {\"ngram\": \"the apparatus\", \"from\": 2438, \"to\": 2451}, {\"ngram\": \"this Olympics\", \"from\": 2455, \"to\": 2468}]}, {\"sentence\": \"Yulo then landed a Kasamatsu double twist that gave him 14.800 points and an average of 15.116 points on the way to becoming the first Filipino to win multiple medals in a single Olympics.\", \"from\": 2471, \"to\": 2659, \"entities\": [{\"begin\": 2490, \"end\": 2499, \"title\": \"http://dbpedia.org/resource/Kasamatsu,_Gifu\", \"score\": 0.9670713156274444, \"rank\": 0.0, \"text\": \"Kasamatsu\", \"types\": [\"Q486972\", \"Q3957\"], \"wikid\": \"http://dbpedia.org/resource/Kasamatsu,_Gifu\", \"dbpedia\": \"http://dbpedia.org/resource/Kasamatsu,_Gifu\"}], \"noun_phrases\": [{\"ngram\": \"Yulo\", \"from\": 2471, \"to\": 2475}, {\"ngram\": \"14.800 points\", \"from\": 2527, \"to\": 2540}, {\"ngram\": \"an average\", \"from\": 2545, \"to\": 2555}, {\"ngram\": \"15.116 points\", \"from\": 2559, \"to\": 2572}, {\"ngram\": \"the way\", \"from\": 2576, \"to\": 2583}, {\"ngram\": \"the first Filipino\", \"from\": 2596, \"to\": 2614}, {\"ngram\": \"multiple medals\", \"from\": 2622, \"to\": 2637}, {\"ngram\": \"a single Olympics\", \"from\": 2641, \"to\": 2658}]}, {\"sentence\": \"Agem from the grassrootswho got discovered in the Palarong Pambansa, Yulo joined an exclusive club of multiple Olympic medalists from the Philippines that includes swimmer Teofilo Yldefonso and weightlifter Hidilyn Diaz.\", \"from\": 2661, \"to\": 2881, \"entities\": [{\"begin\": 2730, \"end\": 2734, \"title\": \"http://dbpedia.org/resource/Carlos_Yulo\", \"score\": 1.0, \"rank\": 5.939827401669641e-42, \"text\": \"Yulo\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Carlos_Yulo\", \"dbpedia\": \"http://dbpedia.org/resource/Carlos_Yulo\"}, {\"begin\": 2799, \"end\": 2810, \"title\": \"http://dbpedia.org/resource/Philippines\", \"score\": 0.9