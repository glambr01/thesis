ngram\": \"nearly a month\", \"from\": 986, \"to\": 1000}, {\"ngram\": \"the competition\", \"from\": 1028, \"to\": 1043}]}, {\"sentence\": \"\\\"To come away with a medal I do not even have the words for it right now,\\\" he said.\", \"from\": 1046, \"to\": 1129, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a medal\", \"from\": 1065, \"to\": 1072}, {\"ngram\": \"the words\", \"from\": 1092, \"to\": 1101}]}, {\"sentence\": \"\\\"But it's just the start.\\\"\", \"from\": 1130, \"to\": 1156, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"just the start\", \"from\": 1140, \"to\": 1154}]}, {\"sentence\": \"At a time whereMax Whitlock, the elder statesman of the team is bowing out of the sport, Hepworth is one of a number of rising stars in the set-up.\", \"from\": 1158, \"to\": 1305, \"entities\": [{\"begin\": 1247, \"end\": 1255, \"title\": \"http://dbpedia.org/resource/Barbara_Hepworth\", \"score\": 0.9999999999959073, \"rank\": 4.287743220676898e-12, \"text\": \"Hepworth\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Barbara_Hepworth\", \"dbpedia\": \"http://dbpedia.org/resource/Barbara_Hepworth\"}], \"noun_phrases\": [{\"ngram\": \"a time\", \"from\": 1161, \"to\": 1167}, {\"ngram\": \"the elder statesman\", \"from\": 1187, \"to\": 1206}, {\"ngram\": \"the team\", \"from\": 1210, \"to\": 1218}, {\"ngram\": \"the sport\", \"from\": 1236, \"to\": 1245}, {\"ngram\": \"a number\", \"from\": 1266, \"to\": 1274}, {\"ngram\": \"rising stars\", \"from\": 1278, \"to\": 1290}, {\"ngram\": \"the set-up\", \"from\": 1294, \"to\": 1304}]}, {\"sentence\": \"His father was in the stands to watch him and he admitted he could hear him shouting but could not make out the words.\", \"from\": 1307, \"to\": 1425, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"His father\", \"from\": 1307, \"to\": 1317}, {\"ngram\": \"the stands\", \"from\": 1325, \"to\": 1335}, {\"ngram\": \"the words\", \"from\": 1415, \"to