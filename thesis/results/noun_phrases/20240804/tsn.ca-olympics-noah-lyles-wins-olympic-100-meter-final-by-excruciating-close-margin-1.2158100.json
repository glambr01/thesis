\"from\": 257, \"to\": 281}]}, {\"sentence\": \"Was all that toil since the last Olympics - all the work on the practice track and in the weight room in the name of finding a centimeter here or a millisecond there - really going to be worth all the trouble?\", \"from\": 285, \"to\": 494, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"all that toil\", \"from\": 289, \"to\": 302}, {\"ngram\": \"the last Olympics\", \"from\": 309, \"to\": 326}, {\"ngram\": \"all the work\", \"from\": 329, \"to\": 341}, {\"ngram\": \"the practice track\", \"from\": 345, \"to\": 363}, {\"ngram\": \"the weight room\", \"from\": 371, \"to\": 386}, {\"ngram\": \"the name\", \"from\": 390, \"to\": 398}, {\"ngram\": \"a centimeter\", \"from\": 410, \"to\": 422}, {\"ngram\": \"a millisecond\", \"from\": 431, \"to\": 444}]}, {\"sentence\": \"Ten seconds passed, then 20.\", \"from\": 496, \"to\": 524, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Ten seconds\", \"from\": 496, \"to\": 507}]}, {\"sentence\": \"Then, nearly 30.\", \"from\": 525, \"to\": 541, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"And then, the answer popped up.\", \"from\": 542, \"to\": 573, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the answer\", \"from\": 552, \"to\": 562}]}, {\"sentence\": \"Yes, Lyles is the 100-meter champion at the Paris Olympics.\", \"from\": 575, \"to\": 634, \"entities\": [{\"begin\": 580, \"end\": 585, \"title\": \"http://dbpedia.org/resource/Jordan_Lyles\", \"score\": 0.9962146911447616, \"rank\": 0.003799540493677415, \"text\": \"Lyles\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Jordan_Lyles\", \"dbpedia\": \"http://dbpedia.org/resource/Jordan_Lyles\"}], \"noun_phrases\": [{\"ngram\": \"the 100-meter champion\", \"from\": 589, \"to\": 611}, {\"ngram\": \"the Paris Olympics\", \"from\": 615, \"to\": 633}]}, {\"sentence\": \"The World's Fastest Man.\", \"from\": 635, \"to\": 659, \"entities\": [], \"