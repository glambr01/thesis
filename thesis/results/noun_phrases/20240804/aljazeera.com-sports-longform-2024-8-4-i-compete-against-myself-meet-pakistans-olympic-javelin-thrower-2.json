.org/resource/Al_Jazeera\", \"score\": 1.0, \"rank\": 7.334130817485203e-14, \"text\": \"Al Jazeera\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/Al_Jazeera\", \"dbpedia\": \"http://dbpedia.org/resource/Al_Jazeera\"}], \"noun_phrases\": [{\"ngram\": \"My main objective\", \"from\": 16247, \"to\": 16264}, {\"ngram\": \"my country's flag\", \"from\": 16275, \"to\": 16292}, {\"ngram\": \"the anthem\", \"from\": 16310, \"to\": 16320}, {\"ngram\": \"the gold\", \"from\": 16343, \"to\": 16351}, {\"ngram\": \"Nadeem\", \"from\": 16354, \"to\": 16360}, {\"ngram\": \"the Olympics\", \"from\": 16397, \"to\": 16409}]}, {\"sentence\": \"Among his competitors will be India's Chopra, a now 27-year-old who has won seven gold medals.\", \"from\": 16418, \"to\": 16512, \"entities\": [{\"begin\": 16448, \"end\": 16453, \"title\": \"http://dbpedia.org/resource/India_national_cricket_team\", \"score\": 0.9999999447545649, \"rank\": 5.5245196101758745e-08, \"text\": \"India\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/India_national_cricket_team\", \"dbpedia\": \"http://dbpedia.org/resource/India_national_cricket_team\"}], \"noun_phrases\": [{\"ngram\": \"his competitors\", \"from\": 16424, \"to\": 16439}, {\"ngram\": \"seven gold medals\", \"from\": 16494, \"to\": 16511}]}, {\"sentence\": \"When they competed against one another at the 2020 Tokyo Olympics, people on social media fanned the flames of the traditional rivalry between the South Asian countries and criticised Nadeem for being distracted and not winning a medal whileChopra won gold.\", \"from\": 16513, \"to\": 16770, \"entities\": [{\"begin\": 16660, \"end\": 16671, \"title\": \"http://dbpedia.org/resource/South_Asian_Games\", \"score\": 0.9998415489108435, \"rank\": 0.00015847619999613842, \"text\": \"South Asian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/South_Asian_Games\", \"dbpedia\": \"http://dbped