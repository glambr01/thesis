oun_phrases\": [{\"ngram\": \"any recovery period\", \"from\": 9043, \"to\": 9062}]}, {\"sentence\": \"You cannot force or flog a player and say working for long hours is part of training,\\\" Saqi explained.\", \"from\": 9064, \"to\": 9166, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a player\", \"from\": 9089, \"to\": 9097}, {\"ngram\": \"long hours\", \"from\": 9118, \"to\": 9128}, {\"ngram\": \"part\", \"from\": 9132, \"to\": 9136}, {\"ngram\": \"training\", \"from\": 9140, \"to\": 9148}, {\"ngram\": \"Saqi\", \"from\": 9151, \"to\": 9155}]}, {\"sentence\": \"Saqi, who trained Nadeem until 2015, still maintains close ties with the athlete.\", \"from\": 9168, \"to\": 9249, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Saqi\", \"from\": 9168, \"to\": 9172}, {\"ngram\": \"Nadeem\", \"from\": 9186, \"to\": 9192}, {\"ngram\": \"close ties\", \"from\": 9221, \"to\": 9231}, {\"ngram\": \"the athlete\", \"from\": 9237, \"to\": 9248}]}, {\"sentence\": \"Saqi believes the most important factor behind Nadeem's success is his humility and said he has not been \\\"tainted\\\" by fame or money.\", \"from\": 9251, \"to\": 9383, \"entities\": [{\"begin\": 9298, \"end\": 9304, \"title\": \"http://dbpedia.org/resource/Nadeem_Baig_(actor)\", \"score\": 0.9934085430122968, \"rank\": 0.0, \"text\": \"Nadeem\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Nadeem_Baig_(actor)\", \"dbpedia\": \"http://dbpedia.org/resource/Nadeem_Baig_(actor)\"}], \"noun_phrases\": [{\"ngram\": \"Saqi\", \"from\": 9251, \"to\": 9255}, {\"ngram\": \"the most important factor\", \"from\": 9265, \"to\": 9290}, {\"ngram\": \"his humility\", \"from\": 9318, \"to\": 9330}, {\"ngram\": \"fame\", \"from\": 9369, \"to\": 9373}, {\"ngram\": \"money\", \"from\": 9377, \"to\": 9382}]}, {\"sentence\": \"\\\"He displays no arrogance or pride.\", \"from\": 9385, \"to\": 9420, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"no arrogance\", \"from\": 9398, \"to\": 9410}, {\"ngram\": \"pride\", \"from\": 9414, \"to\": 9419}]}, {\"sentence\": \"When he comes to Mian Channu to see me, he makes sure he walks behind me.\", \"from\": 9421, \"to\": 9494, \"entities\": [{\"begin\": 9438, \"end\": 9449, \"title\": \"http://dbpedia.org/resource/Mian_Channu\", \"score\": 1.0, \"rank\": 1.8238061390691224e-29, \"text\": \"Mian Channu\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Mian_Channu\", \"dbpedia\": \"http://dbpedia.org/resource/Mian_Channu\"}], \"noun_phrases\": []}, {\"sentence\": \"He ensures he opens the doors for me and waits till I sit,\\\" Saqi said.\", \"from\": 9495, \"to\": 9565, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the doors\", \"from\": 9515, \"to\": 9524}, {\"ngram\": \"Saqi\", \"from\": 9555, \"to\": 9559}]}, {\"sentence\": \"Recalling an incident from a few years ago, the hotel owner said Nadeem was at a training camp in Islamabad when Saqi was taken to the hospital for a heart complication.\", \"from\": 9567, \"to\": 9736, \"entities\": [{\"begin\": 9632, \"end\": 9638, \"title\": \"http://dbpedia.org/resource/Nadeem_Baig_(actor)\", \"score\": 0.9934085430122968, \"rank\": 0.0, \"text\": \"Nadeem\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Nadeem_Baig_(actor)\", \"dbpedia\": \"http://dbpedia.org/resource/Nadeem_Baig_(actor)\"}, {\"begin\": 9665, \"end\": 9674, \"title\": \"http://dbpedia.org/resource/Islamabad\", \"score\": 1.0, \"rank\": 3.658793823100115e-35, \"text\": \"Islamabad\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Islamabad\", \"dbpedia\": \"http://dbpedia.org/resource/Islamabad\"}], \"noun_phrases\": [{\"ngram\": \"an incident\", \"from\": 9577, \"to\": 9588}, {\"ngram\": \"the hotel owner\", \"from\": 9611, \"to\": 9626}, {\"ngram\": \"a training camp\", \"from\": 9646, \"to\": 9661}, {\"ngram\": \"Saqi\", \"from\": 9680, \"to\": 9684}, {\"ngram\": \"the hospital\", \"from\": 9698, \"to\": 9710}, {\"ngram\": \"a heart complication\", \"from\": 9715, \"to\": 9735}]}, {\"sentence\": \"\\\"Somehow, he found out, and he left the camp to come and see me within a day's notice.\", \"from\": 9738, \"to\": 9824, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the camp\", \"from\": 9774, \"to\": 9782}, {\"ngram\": \"a day's notice\", \"from\": 9809, \"to\": 9823}]}, {\"sentence\": \"I had to scold him, despite my health, telling him to go back to training,\\\" Saqi recalled with a chuckle.\", \"from\": 9825, \"to\": 9930, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my health\", \"from\": 9853, \"to\": 9862}, {\"ngram\": \"training\", \"from\": 9890, \"to\": 9898}, {\"ngram\": \"Saqi\", \"from\": 9901, \"to\": 9905}, {\"ngram\": \"a chuckle\", \"from\": 9920, \"to\": 9929}]}, {\"sentence\": \"Nadeem refers to Saqi as his \\\"spiritual father\\\".\", \"from\": 9932, \"to\": 9980, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Saqi\", \"from\": 9949, \"to\": 9953}, {\"ngram\": \"his \\\"spiritual father\", \"from\": 9957, \"to\": 9978}]}, {\"sentence\": \"A decade ago, when he did not even know specific spikes for javelin throwers existed, let alone owned them, it was Saqi who bought him his first pair.\", \"from\": 9981, \"to\": 10131, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"specific spikes\", \"from\": 10021, \"to\": 10036}, {\"ngram\": \"javelin throwers\", \"from\": 10041, \"to\": 10057}, {\"ngram\": \"his first pair\", \"from\": 10116, \"to\": 10130}]}, {\"sentence\": \"The athlete also said it was thanks to Saqi that he secured employment at the sports department of the Water and Power Development Authority (WAPDA), a government-owned public utility that pays him a monthly retainer.\", \"from\": 10133, \"to\": 10350, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The athlete\", \"from\": 10133, \"to\": 10144}, {\"ngram\": \"thanks\", \"from\": 10162, \"to\": 10168}, {\"ngram\": \"Saqi\", \"fr