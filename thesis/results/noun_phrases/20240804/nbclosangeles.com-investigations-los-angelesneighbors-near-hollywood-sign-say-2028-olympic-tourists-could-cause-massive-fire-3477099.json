"{\"uid\": \"nbclosangeles.com-investigations-los-angelesneighbors-near-hollywood-sign-say-2028-olympic-tourists-could-cause-massive-fire-3477099\", \"noun_phrases\": [{\"sentence\": \"Clogged streets, gridlock, neighbors near the Hollywood sign say this is problem that's been going on for years and only getting worse.\", \"from\": 0, \"to\": 135, \"entities\": [{\"begin\": 46, \"end\": 60, \"title\": \"http://dbpedia.org/resource/Hollywood_Sign\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Hollywood sign\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Hollywood_Sign\", \"dbpedia\": \"http://dbpedia.org/resource/Hollywood_Sign\"}], \"noun_phrases\": [{\"ngram\": \"Clogged streets\", \"from\": 0, \"to\": 15}, {\"ngram\": \"gridlock\", \"from\": 17, \"to\": 25}, {\"ngram\": \"neighbors\", \"from\": 27, \"to\": 36}, {\"ngram\": \"problem\", \"from\": 73, \"to\": 80}, {\"ngram\": \"years\", \"from\": 106, \"to\": 111}]}, {\"sentence\": \"With LA hosting the 2028 Olympics, residents say that the popular tourist spot can be a recipe for disaster.\", \"from\": 136, \"to\": 244, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"LA\", \"from\": 141, \"to\": 143}, {\"ngram\": \"the 2028 Olympics\", \"from\": 152, \"to\": 169}, {\"ngram\": \"residents\", \"from\": 171, \"to\": 180}, {\"ngram\": \"the popular tourist spot\", \"from\": 190, \"to\": 214}, {\"ngram\": \"a recipe\", \"from\": 222, \"to\": 230}, {\"ngram\": \"disaster\", \"from\": 235, \"to\": 243}]}, {\"sentence\": \"Joel Grover reports for the NBC4 News at 6 p.m. on Aug. 4, 2024.\", \"from\": 245, \"to\": 309, \"entities\": [{\"begin\": 245, \"end\": 256, \"title\": \"http://dbpedia.org/resource/Joel_Grover\", \"score\": 0.9999956859544287, \"rank\": 0.0, \"text\": \"Joel Grover\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Joel_Grover\", \"dbpedia\": \"http://dbpedia.org/resource/Joel_Grover\"}, {\"begin\": 273, \"end\": 277, \"title\": \"http://dbpedia.org/resource/KNBC\", \"score\": 0.9999630973322198, \"rank\": 3.690402963727899e-05, \"text\": \"NBC4\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/KNBC\", \"dbpedia\": \"http://dbpedia.org/resource/KNBC\"}], \"noun_phrases\": [{\"ngram\": \"6 p.m.\", \"from\": 286, \"to\": 292}, {\"ngram\": \"Aug.\", \"from\": 296, \"to\": 300}]}, {\"sentence\": \"On a typical summer weekend, the traffic is bumper to bumper on the streets leading to the world-famous Hollywood sign, and residents worry that tourists coming to the 2028 Olympics will overwhelm the area and potentially cause a massive fire.\", \"from\": 311, \"to\": 554, \"entities\": [{\"begin\": 415, \"end\": 429, \"title\": \"http://dbpedia.org/resource/Hollywood_Sign\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Hollywood sign\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Hollywood_Sign\", \"dbpedia\": \"http://dbpedia.org/resource/Hollywood_Sign\"}], \"noun_phrases\": [{\"ngram\": \"a typical summer weekend\", \"from\": 314, \"to\": 338}, {\"ngram\": \"the traffic\", \"from\": 340, \"to\": 351}, {\"ngram\": \"the streets\", \"from\": 375, \"to\": 386}, {\"ngram\": \"residents\", \"from\": 435, \"to\": 444}, {\"ngram\": \"tourists\", \"from\": 456, \"to\": 464}, {\"ngram\": \"the 2028 Olympics\", \"from\": 475, \"to\": 492}, {\"ngram\": \"the area\", \"from\": 508, \"to\": 516}, {\"ngram\": \"a massive fire\", \"from\": 539, \"to\": 553}]}, {\"sentence\": \"\\\"The way things are right now, we would not survive during the Olympics at all,\\\" says Kim Kevorkian, a longtime resident of the nearby Lake Hollywood neighborhood.\", \"from\": 556, \"to\": 719, \"entities\": [{\"begin\": 642, \"end\": 645, \"title\": \"http://dbpedia.org/resource/Kim_Kardashian\", \"score\": 0.9999999921715244, \"rank\": 7.815662635277544e-09, \"text\": \"Kim\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kim_Kardashian\", \"dbpedia\": \"http://dbpedia.org/resource/Kim_Kardashian\"}], \"noun_phrases\": [{\"ngram\": \"things\", \"from\": 565, \"to\": 571}, {\"ngram\": \"the Olympics\", \"from\": 615, \"to\": 627}, {\"ngram\": \"a longtime resident\", \"from\": 657, \"to\": 676}, {\"ngram\": \"the nearby Lake Hollywood neighborhood\", \"from\": 680, \"to\": 718}]}, {\"sentence\": \"Stream Los Angeles News for free, 24/7, wherever you are.\", \"from\": 721, \"to\": 778, \"entities\": [{\"begin\": 728, \"end\": 739, \"title\": \"http://dbpedia.org/resource/Los_Angeles\", \"score\": 0.9999999902988748, \"rank\": 9.700379528441728e-09, \"text\": \"Los Angeles\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Los_Angeles\", \"dbpedia\": \"http://dbpedia.org/resource/Los_Angeles\"}], \"noun_phrases\": []}, {\"sentence\": \"\\\"My worst fear is that there is going to be a fire up here, and we are not going to all be able to get out,\\\" Kevorkian told the I-Team.\", \"from\": 780, \"to\": 915, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My worst fear\", \"from\": 781, \"to\": 794}, {\"ngram\": \"a fire\", \"from\": 824, \"to\": 830}, {\"ngram\": \"Kevorkian\", \"from\": 889, \"to\": 898}, {\"ngram\": \"the I-Team\", \"from\": 904, \"to\": 914}]}, {\"sentence\": \"The Hollywood sign wasn't built as a tourist attraction.\", \"from\": 917, \"to\": 973, \"entities\": [{\"begin\": 917, \"end\": 935, \"title\": \"http://dbpedia.org/resource/The_Hollywood_Sign_(film)\", \"score\": 0.9999999997526174, \"rank\": 0.0, \"text\": \"The Hollywood sign\", \"types\": [\"Q386724\", \"Q11424\"], \"wikid\": \"http://dbpedia.org/resource/The_Hollywood_Sign_(film)\", \"dbpedia\": \"http://dbpedia.org/resource/The_Hollywood_Sign_(film)\"}], \"noun_phrases\": [{\"ngram\": \"a tourist attraction\", \"from\": 952, \"to\": 972}]}, {\"sentence\": \"It was built in 1923 to advertise \\\"Hollywoodland,\\\" a new housing development.\", \"from\": 974, \"to\": 1051, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"\\\"Hollywoodland\", \"from\": 1008, \"to\": 1022}, {\"ngram\": \"a new housing development\", \"from\": 1025, \"to\": 1050}]}, {\"sentence\": \"But in recent years, the sign is heavily promoted as a tourist attraction on social media and by the city of LA.\", \"from\": 1053, \"to\": 1165, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"recent years\", \"from\": 1060, \"to\": 1072}, {\"ngram\": \"the sign\", \"from\": 1074, \"to\": 1082}, {\"ngram\": \"a tourist attraction\", \"from\": 1106, \"to\": 1126}, {\"ngram\": \"social media\", \"from\": 1130, \"to\": 1142}, {\"ngram\": \"the city\", \"from\": 1150, \"to\": 1158}, {\"ngram\": \"LA\", \"from\": 1162, \"to\": 1164}]}, {\"sentence\": \"Every summer weekend, out-of-towners and locals cause gridlock in the area, even blocking intersections to get selfies with the Hollywood sign behind them.\", \"from\": 1167, \"to\": 1322, \"entities\": [{\"begin\": 1295, \"end\": 1309, \"title\": \"http://dbpedia.org/resource/Hollywood_Sign\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Hollywood sign\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Hollywood_Sign\", \"dbpedia\": \"http://dbpedia.org/resource/Hollywood_Sign\"}], \"noun_phrases\": [{\"ngram\": \"out-of-towners\", \"from\": 1189, \"to\": 1203}, {\"ngram\": \"locals\", \"from\": 1208, \"to\": 1214}, {\"ngram\": \"gridlock\", \"from\": 1221, \"to\": 1229}, {\"ngram\": \"the area\", \"from\": 1233, \"to\": 1241}, {\"ngram\": \"intersections\", \"from\": 1257, \"to\": 1270}, {\"ngram\": \"selfies\", \"from\": 1278, \"to\": 1285}]}, {\"sentence\": \"During a two-week period in June, city cameras documented over 52,000 cars jamming into the area, compare that to a two-week period in March when around 16,000 cars were counted by those cameras.\", \"from\": 1324, \"to\": 1519, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a two-week period\", \"from\": 1331, \"to\": 1348}, {\"ngram\": \"June\", \"from\": 1352, \"to\": 1356}, {\"ngram\": \"city cameras\", \"from\": 1358, \"to\": 1370}, {\"ngram\": \"over 52,000 cars\", \"from\": 1382, \"to\": 1398}, {\"ngram\": \"the area\", \"from\": 1412, \"to\": 1420}, {\"ngram\": \"a two-week period\", \"from\": 1438, \"to\": 1455}, {\"ngram\": \"March\", \"from\": 1459, \"to\": 1464}, {\"ngram\": \"around 16,000 cars\", \"from\": 1470, \"to\": 1488}, {\"ngram\": \"those cameras\", \"from\": 1505, \"to\": 1518}]}, {\"sentence\": \"\\\"When you are building tourist attractions, you are building infrastructure to accommodate so many different numbers of people,,\\\" said Jeff Zarrinam, the head of the Hollywood Sign Trust, which maintains the sign.\", \"from\": 1521, \"to\": 1734, \"entities\": [{\"begin\": 1687, \"end\": 1701, \"title\": \"http://dbpedia.org/resource/Hollywood_Sign\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Hollywood Sign\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Hollywood_Sign\", \"dbpedia\": \"http://dbpedia.org/resource/Hollywood_Sign\"}], \"noun_phrases\": [{\"ngram\": \"tourist attractions\", \"from\": 1544, \"to\": 1563}, {\"ngram\": \"infrastructure\", \"from\": 1582, \"to\": 1596}, {\"ngram\": \"so many different numbers\", \"from\": 1612, \"to\": 1637}, {\"ngram\": \"people\", \"from\": 1641, \"to\": 1647}, {\"ngram\": \"Jeff Zarrinam\", \"from\": 1656, \"to\": 1669}, {\"ngram\": \"the head\", \"from\": 1671, \"to\": 1679}, {\"ngram\": \"the sign\", \"from\": 1725, \"to\": 1733}]}, {\"sentence\": \"\\\"That was never taken into consideration here.\\\"\", \"from\": 1735, \"to\": 1782, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"consideration\", \"from\": 1762, \"to\": 1775}]}, {\"sentence\": \"Kim Kevorkian and her neighbor Lisa Hope contacted the NBC4 I-Team last year in the wake of the tragic fire that killed more than 100 people and ravaged Lahaina, Maui, a traffic clogged area with few ways in and out, similar to the neighborhoods surrounding the Hollywood sign.\", \"from\": 1784, \"to\": 2061, \"entities\": [{\"begin\": 1784, \"end\": 1787, \"title\": \"http://dbpedia.org/resource/Kim_Kardashian\", \"score\": 0.9999999921715244, \"rank\": 7.815662635277544e-09, \"text\": \"Kim\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kim_Kardashian\", \"dbpedia\": \"http://dbpedia.org/resource/Kim_Kardashian\"}, {\"begin\": 1815, \"end\": 1819, \"title\": \"http://dbpedia.org/resource/Lisa_Simpson\", \"score\": 1.0, \"rank\": 8.547075499291124e-14, \"text\": \"Lisa\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Lisa_Simpson\", \"dbpedia\": \"http://dbpedia.org/resource/Lisa_Simpson\"}, {\"begin\": 1820, \"end\": 1824, \"title\": \"http://dbpedia.org/resource/Hope\", \"score\": 0.9999889609493895, \"rank\": 1.1039172521840344e-05, \"text\": \"Hope\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Hope\", \"dbpedia\": \"http://dbpedia.org/resource/Hope\"}, {\"begin\": 2046, \"end\": 2060, \"title\": \"http://dbpedia.org/resource/Hollywood_Sign\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Hollywood sign\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Hollywood_Sign\", \"dbpedia\": \"http://dbpedia.org/resource/Hollywood_Sign\"}], \"noun_phrases\": [{\"ngram\": \"her neighbor\", \"from\": 1802, \"to\": 1814}, {\"ngram\": \"the NBC4 I-Team\", \"from\": 1835, \"to\": 1850}, {\"ngram\": \"the wake\", \"from\": 1864, \"to\": 1872}, {\"ngram\": \"the tragic fire\", \"from\": 1876, \"to\": 1891}, {\"ngram\": \"more than 100 people\", \"from\": 1904, \"to\": 1924}, {\"ngram\": \"Lahaina\", \"from\": 1937, \"to\": 1944}, {\"ngram\": \"Maui\", \"from\": 1946, \"to\": 1950}, {\"ngram\": \"a traffic clogged area\", \"from\": 1952, \"to\": 1974}, {\"ngram\": \"few ways\", \"from\": 1980, \"to\": 1988}, {\"ngram\": \"the neighborhoods\", \"from\": 2012, \"to\": 2029}]}, {\"sentence\": \"\\\"A wind driven fire up here with only two ways in and out -- (it's) just a recipe for disaster,\\\" Hope told the I-Team.\", \"from\": 2063, \"to\": 2181, \"entities\": [{\"begin\": 2160, \"end\": 2164, \"title\": \"http://dbpedia.org/resource/Hope\", \"score\": 0.9999889609493895, \"rank\": 1.1039172521840344e-05, \"text\": \"Hope\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Hope\", \"dbpedia\": \"http://dbpedia.org/resource/Hope\"}], \"noun_phrases\": [{\"ngram\": \"fire\", \"from\": 2078, \"to\": 2082}, {\"ngram\": \"only two ways\", \"from\": 2096, \"to\": 2109}, {\"ngram\": \"just a recipe\", \"from\": 2131, \"to\": 2144}, {\"ngram\": \"disaster\", \"from\": 2149, \"to\": 2157}, {\"ngram\": \"the I-Team\", \"from\": 2170, \"to\": 2180}]}, {\"sentence\": \"The women provided NBC4 with videos and photos of outrageous and sometimes dangerous behavior by tourists, trying to get an up-close look at the sign.\", \"from\": 2185, \"to\": 2335, \"entities\": [{\"begin\": 2204, \"end\": 2208, \"title\": \"http://dbpedia.org/resource/KNBC\", \"score\": 0.9999630973322198, \"rank\": 3.690402963727899e-05, \"text\": \"NBC4\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/KNBC\", \"dbpedia\": \"http://dbpedia.org/resource/KNBC\"}], \"noun_phrases\": [{\"ngram\": \"The women\", \"from\": 2185, \"to\": 2194}, {\"ngram\": \"videos\", \"from\": 2214, \"to\": 2220}, {\"ngram\": \"photos\", \"from\": 2225, \"to\": 2231}, {\"ngram\": \"outrageous and sometimes dangerous behavior\", \"from\": 2235, \"to\": 2278}, {\"ngram\": \"tourists\", \"from\": 2282, \"to\": 2290}, {\"ngram\": \"-close\", \"from\": 2311, \"to\": 2317}, {\"ngram\": \"the sign\", \"from\": 2326, \"to\": 2334}]}, {\"sentence\": \"One set of photos documents a tourist who hauled in a piano and blocked the street to to film a TikTok video of himself playing the piano with the Hollywood sign in the background.\", \"from\": 2337, \"to\": 2517, \"entities\": [{\"begin\": 2433, \"end\": 2439, \"title\": \"http://dbpedia.org/resource/TikTok\", \"score\": 1.0, \"rank\": 2.076466932808174e-31, \"text\": \"TikTok\", \"types\": [\"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/TikTok\", \"dbpedia\": \"http://dbpedia.org/resource/TikTok\"}, {\"begin\": 2484, \"end\": 2498, \"title\": \"http://dbpedia.org/resource/Hollywood_Sign\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Hollywood sign\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Hollywood_Sign\", \"dbpedia\": \"http://dbpedia.org/resource/Hollywood_Sign\"}], \"noun_phrases\": [{\"ngram\": \"One set\", \"from\": 2337, \"to\": 2344}, {\"ngram\": \"photos\", \"from\": 2348, \"to\": 2354}, {\"ngram\": \"a tourist\", \"from\": 2365, \"to\": 2374}, {\"ngram\": \"a piano\", \"from\": 2389, \"to\": 2396}, {\"ngram\": \"the street\", \"from\": 2409, \"to\": 2419}, {\"ngram\": \"the piano\", \"from\": 2465, \"to\": 2474}, {\"ngram\": \"the background\", \"from\": 2502, \"to\": 2516}]}, {\"sentence\": \"Other photos show tourists who got out of their cars to urinate.\", \"from\": 2519, \"to\": 2583, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Other photos\", \"from\": 2519, \"to\": 2531}, {\"ngram\": \"tourists\", \"from\": 2537, \"to\": 2545}, {\"ngram\": \"their cars\", \"from\": 2561, \"to\": 2571}]}, {\"sentence\": \"The biggest concern is the large number tourists who smoke in this area where the hills are covered by dry brush; the area is ranked by the LA Fire Department as one of the highest fire risk zones in LA.\", \"from\": 2585, \"to\": 2788, \"entities\": [{\"begin\": 2725, \"end\": 2743, \"title\": \"http://dbpedia.org/resource/Los_Angeles_Fire_Department\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"LA Fire Department\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Los_Angeles_Fire_Department\", \"dbpedia\": \"http://dbpedia.org/resource/Los_Angeles_Fire_Department\"}], \"noun_phrases\": [{\"ngram\": \"The biggest concern\", \"from\": 2585, \"to\": 2604}, {\"ngram\": \"the large number tourists\", \"from\": 2608, \"