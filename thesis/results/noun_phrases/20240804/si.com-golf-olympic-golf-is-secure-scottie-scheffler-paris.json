, \"from\": 266, \"to\": 605, \"entities\": [{\"begin\": 276, \"end\": 293, \"title\": \"http://dbpedia.org/resource/Scottie_Scheffler\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Scottie Scheffler\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q13156709\"], \"wikid\": \"http://dbpedia.org/resource/Scottie_Scheffler\", \"dbpedia\": \"http://dbpedia.org/resource/Scottie_Scheffler\"}, {\"begin\": 554, \"end\": 569, \"title\": \"http://dbpedia.org/resource/Tommy_Fleetwood\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Tommy Fleetwood\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q13156709\"], \"wikid\": \"http://dbpedia.org/resource/Tommy_Fleetwood\", \"dbpedia\": \"http://dbpedia.org/resource/Tommy_Fleetwood\"}], \"noun_phrases\": [{\"ngram\": \"his way\", \"from\": 298, \"to\": 305}, {\"ngram\": \"another victory\", \"from\": 309, \"to\": 324}, {\"ngram\": \"joy\", \"from\": 344, \"to\": 347}, {\"ngram\": \"a crucial birdie putt\", \"from\": 354, \"to\": 375}, {\"ngram\": \"the 17th\\u00c2 hole\", \"from\": 379, \"to\": 393}, {\"ngram\": \"the medal stand\", \"from\": 410, \"to\": 425}, {\"ngram\": \"the gold\", \"from\": 495, \"to\": 503}, {\"ngram\": \"medal\\u00e2\\u0080\\u0094as\", \"from\": 504, \"to\": 514}, {\"ngram\": \"bronze winner\", \"from\": 574, \"to\": 587}]}, {\"sentence\": \"A spirited run by Jon Rahm up the leaderboard ended without even a spot on the podium and saying he felt he let the country of Spain down while France\\u00e2\\u0080\\u0099s Victor Perez sent thrills through the home crowd with a push for a medal that came up just short, his country\\u00e2\\u0080\\u0099s national anthem sung to him on every hole.\", \"from\": 607, \"to\": 918, \"entities\": [{\"begin\": 625, \"end\": 633, \"title\": \"http://dbpedia.org/resource/Jon_Rahm\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Jon Rahm\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q13156709\"], \"wikid\": \"http://dbpedia.org/resource/Jon_Rahm\", \"db