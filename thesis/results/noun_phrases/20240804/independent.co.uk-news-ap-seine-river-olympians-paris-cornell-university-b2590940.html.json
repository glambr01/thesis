 344}, {\"ngram\": \"theParisOlympics\", \"from\": 348, \"to\": 364}, {\"ngram\": \"the water quality\", \"from\": 374, \"to\": 391}, {\"ngram\": \"some swimming events\", \"from\": 432, \"to\": 452}, {\"ngram\": \"a major question\", \"from\": 462, \"to\": 478}]}, {\"sentence\": \"Bacteria levels in the river fluctuate constantly, and daily water samples are tested so organizers can assess the risk and determine whether swims in the long-polluted Paris waterway should go forward.\", \"from\": 482, \"to\": 684, \"entities\": [{\"begin\": 651, \"end\": 656, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.8350356355766536e-13, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Bacteria levels\", \"from\": 482, \"to\": 497}, {\"ngram\": \"the river fluctuate\", \"from\": 501, \"to\": 520}, {\"ngram\": \"daily water samples\", \"from\": 537, \"to\": 556}, {\"ngram\": \"organizers\", \"from\": 571, \"to\": 581}, {\"ngram\": \"the risk\", \"from\": 593, \"to\": 601}, {\"ngram\": \"swims\", \"from\": 624, \"to\": 629}]}, {\"sentence\": \"Triathletes raced in the river Wednesday, and testing will determine whether upcoming competitions will happen as planned, including the triathlon mixed relay Monday and the marathon swimming races scheduled for Thursday and Friday.\", \"from\": 686, \"to\": 918, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Triathletes\", \"from\": 686, \"to\": 697}, {\"ngram\": \"the river\", \"from\": 707, \"to\": 716}, {\"ngram\": \"testing\", \"from\": 732, \"to\": 739}, {\"ngram\": \"upcoming competitions\", \"from\": 763, \"to\": 784}, {\"ngram\": \"the triathlon mixed relay\", \"from\": 819, \"to\": 844}, {\"ngram\": \"the marathon swimming races\", \"from\": 856, \"to\": 883}, {\"ngram\": \"Thursday\", \"from\": 898, \"to\": 906}, {\"ngram\": \"Friday\", \"from\": 911, \"to\": 917}]}, {\"sentence\": \"Here are some things to know about water quality testing in the Seine: Why do bacteria levels matter?\", \"from\": 920, \"to\": 1022, \"entities\": [{\"begin\": 984, \"end\": 989, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999999989067874, \"rank\": 1.0933904016993636e-09, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"some things\", \"from\": 929, \"to\": 940}, {\"ngram\": \"water quality testing\", \"from\": 955, \"to\": 976}, {\"ngram\": \"bacteria levels\", \"from\": 998, \"to\": 1013}]}, {\"sentence\": \"High levels of E. coli and enterococci indicate sewage or fecal pollution in the water.\", \"from\": 1024, \"to\": 1111, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"High levels\", \"from\": 1024, \"to\": 1035}, {\"ngram\": \"E. coli\", \"from\": 1039, \"to\": 1046}, {\"ngram\": \"enterococci\", \"from\": 1051, \"to\": 1062}, {\"ngram\": \"sewage\", \"from\": 1072, \"to\": 1078}, {\"ngram\": \"fecal pollution\", \"from\": 1082, \"to\": 1097}, {\"ngram\": \"the water\", \"from\": 1101, \"to\": 1110}]}, {\"sentence\": \"Most strains are harmless and some live in the intestines of healthy people and animals.\", \"from\": 1112, \"to\": 1200, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Most strains\", \"from\": 1112, \"to\": 1124}, {\"ngram\": \"the intestines\", \"from\": 1155, \"to\": 1169}, {\"ngram\": \"healthy people\", \"from\": 1173, \"to\": 1187}, {\"ngram\": \"animals\", \"from\": 1192, \"to\": 1199}]}, {\"sentence\": \"But others can be dangerous.\", \"from\": 1201, \"to\": 1229, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"others\", \"from\": 1205, \"to\": 1211}]}, {\"sentence\": \"Even a mouthful of contaminated water can lead to diarrhea, and illnesses such as infections in the urinary tract or intestines can result.\", \"from\": 1231, \"to\": 1370, 