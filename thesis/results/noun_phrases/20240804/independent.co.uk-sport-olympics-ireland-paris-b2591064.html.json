1, \"to\": 1487}]}, {\"sentence\": \"\\\"The way I was looking, Greg was kind of blocking Bobby, so I could not see him and then when I saw him way up ahead I said 'we are going to be in for a very painful race here',\\\" Wiffen added.\", \"from\": 1490, \"to\": 1682, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Greg\", \"from\": 1514, \"to\": 1518}, {\"ngram\": \"Bobby\", \"from\": 1540, \"to\": 1545}, {\"ngram\": \"a very painful race\", \"from\": 1641, \"to\": 1660}, {\"ngram\": \"Wiffen\", \"from\": 1669, \"to\": 1675}]}, {\"sentence\": \"\\\"I did dig deep to try and push it but I just did not have enough.\", \"from\": 1684, \"to\": 1750, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"\\\"I am just thinking in my head - a gold and a bronze, I can not be more happy and today's race did not go my way but who cares, I am Olympic champion.\", \"from\": 1752, \"to\": 1902, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my head\", \"from\": 1775, \"to\": 1782}, {\"ngram\": \"a gold\", \"from\": 1785, \"to\": 1791}, {\"ngram\": \"a bronze\", \"from\": 1796, \"to\": 1804}, {\"ngram\": \"today's race\", \"from\": 1834, \"to\": 1846}, {\"ngram\": \"Olympic champion\", \"from\": 1885, \"to\": 1901}]}, {\"sentence\": \"To be honest, it's quite emotional.\\\"\", \"from\": 1903, \"to\": 1939, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Please refresh the page or navigate to another page on the site to be automatically logged inPlease refresh your browser to be logged in\", \"from\": 1941, \"to\": 2077, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the page\", \"from\": 1956, \"to\": 1964}, {\"ngram\": \"another page\", \"from\": 1980, \"to\": 1992}, {\"ngram\": \"the site\", \"from\": 1996, \"to\": 2004}, {\"ngram\": \"inPlease\", \"from\": 2032, \"to\": 2040}, {\"ngram\": \"your browser\", \"from\": 2049, \"to\": 2061}]}]}"