es\": [{\"ngram\": \"my costume\", \"from\": 888, \"to\": 898}, {\"ngram\": \"anyone\", \"from\": 910, \"to\": 916}, {\"ngram\": \"my intention\", \"from\": 952, \"to\": 964}]}, {\"sentence\": \"I would like to apologise to anyone that I offended.\\\"\", \"from\": 966, \"to\": 1019, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"anyone\", \"from\": 995, \"to\": 1001}]}, {\"sentence\": \"\\\"I do not feel like I have done anything particularly bad.\\\"\", \"from\": 1021, \"to\": 1080, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"anything\", \"from\": 1053, \"to\": 1061}]}, {\"sentence\": \"Rose won team eventing silver at the 2008 and 2020 Olympics and bronze in 2016.\", \"from\": 1082, \"to\": 1161, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Rose\", \"from\": 1082, \"to\": 1086}, {\"ngram\": \"team\", \"from\": 1091, \"to\": 1095}, {\"ngram\": \"silver\", \"from\": 1105, \"to\": 1111}, {\"ngram\": \"the 2008 and 2020 Olympics\", \"from\": 1115, \"to\": 1141}, {\"ngram\": \"bronze\", \"from\": 1146, \"to\": 1152}]}, {\"sentence\": \"He said he hoped the incident would not affect his Olympic preparation, while expressing a desire for the situation to be resolved quickly.\", \"from\": 1163, \"to\": 1302, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the incident\", \"from\": 1180, \"to\": 1192}, {\"ngram\": \"his Olympic preparation\", \"from\": 1210, \"to\": 1233}, {\"ngram\": \"a desire\", \"from\": 1252, \"to\": 1260}, {\"ngram\": \"the situation\", \"from\": 1265, \"to\": 1278}]}, {\"sentence\": \"\\\"With a bit of luck this will all be a bit of a laugh in a few days and we can all move on,\\\" he told the Sydney Morning Herald.\", \"from\": 1304, \"to\": 1431, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a bit\", \"from\": 1310, \"to\": 1315}, {\"ngram\": \"luck\", \"from\": 1319, \"to\": 1323}, {\"ngram\": \"a bit\", \"from\": 1341, \"to\": 1346}, {\"ngram\": \"a laugh\", \"from\": 1350, \"to\": 1357}, {\"ngram\": \"a few days\", \"fr