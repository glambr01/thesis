noun_phrases\": [{\"ngram\": \"U.S. Soccer\", \"from\": 314, \"to\": 325}, {\"ngram\": \"a rebound\", \"from\": 336, \"to\": 345}]}, {\"sentence\": \"All they did was hire a serial winner from one of the biggest club teams in the world, the kind of coach we all want the USMNT to put into place prior to the 2026 World Cup on home soil.\", \"from\": 347, \"to\": 533, \"entities\": [{\"begin\": 468, \"end\": 473, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_soccer_team\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"USMNT\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_soccer_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_soccer_team\"}], \"noun_phrases\": [{\"ngram\": \"a serial winner\", \"from\": 369, \"to\": 384}, {\"ngram\": \"the biggest club teams\", \"from\": 397, \"to\": 419}, {\"ngram\": \"the world\", \"from\": 423, \"to\": 432}, {\"ngram\": \"the kind\", \"from\": 434, \"to\": 442}, {\"ngram\": \"coach\", \"from\": 446, \"to\": 451}, {\"ngram\": \"place\", \"from\": 486, \"to\": 491}, {\"ngram\": \"the 2026 World Cup\", \"from\": 501, \"to\": 519}, {\"ngram\": \"home soil\", \"from\": 523, \"to\": 532}]}, {\"sentence\": \"After watching from across the pond and being in charge for just two matches, Emma Hayes made the decision on the 18 she will be taking to Western Europe on June 26.\", \"from\": 535, \"to\": 700, \"entities\": [{\"begin\": 613, \"end\": 623, \"title\": \"http://dbpedia.org/resource/Emma_Hayes\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Emma Hayes\", \"types\": [\"Q729\", \"Q628099\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emma_Hayes\", \"dbpedia\": \"http://dbpedia.org/resource/Emma_Hayes\"}], \"noun_phrases\": [{\"ngram\": \"the pond\", \"from\": 562, \"to\": 570}, {\"ngram\": \"charge\", \"from\": 584, \"to\": 590}, {\"ngram\": \"just two matches\", \"from\": 595, \"to\": 611}, {\"ngram\": \"the decision\", \"from\": 629, \"to\": 641}, {\"ngram\": \"Western Europe\", \"from\": 674, \"to\": 688}, {\"ngram\": \"June\", \"from\": 692, \"to\": 696}]}, {\"sentence\": \"No Alex Morgan.\", \"from\": 701, \"to\": 716, \"entities\": [{\"begin\": 704, \"end\": 715, \"title\": \"http://dbpedia.org/resource/Alex_Morgan\", \"score\": 1.0, \"rank\": 7.580484924792968e-54, \"text\": \"Alex Morgan\", \"types\": [\"Q937857\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Alex_Morgan\", \"dbpedia\": \"http://dbpedia.org/resource/Alex_Morgan\"}], \"noun_phrases\": []}, {\"sentence\": \"Why?\", \"from\": 717, \"to\": 721, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Because there are hungry youngsters who can provide much more than a forward who has struggled in front of the net all year at the club level.\", \"from\": 722, \"to\": 864, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"hungry youngsters\", \"from\": 740, \"to\": 757}, {\"ngram\": \"front\", \"from\": 820, \"to\": 825}, {\"ngram\": \"the net\", \"from\": 829, \"to\": 836}, {\"ngram\": \"the club level\", \"from\": 849, \"to\": 863}]}, {\"sentence\": \"Only six players are 30 or older.\", \"from\": 865, \"to\": 898, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Only six players\", \"from\": 865, \"to\": 881}]}, {\"sentence\": \"It is the fourth-youngest roster the USA has ever sent to the Olympics and the youngest since 2008, a team that included a 20-year-old Tobin Heath.\", \"from\": 899, \"to\": 1046, \"entities\": [{\"begin\": 936, \"end\": 939, \"title\": \"http://dbpedia.org/resource/United_States_women's_national_soccer_team\", \"score\": 1.0, \"rank\": 3.2348932590230426e-20, \"text\": \"USA\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_States_women's_national_soccer_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_women's_national_soccer_team\"}