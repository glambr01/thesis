.org/resource/Kenenisa_Bekele\"}, {\"begin\": 4309, \"end\": 4323, \"title\": \"http://dbpedia.org/resource/Eliud_Kipchoge\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Eliud Kipchoge\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Eliud_Kipchoge\", \"dbpedia\": \"http://dbpedia.org/resource/Eliud_Kipchoge\"}, {\"begin\": 4378, \"end\": 4383, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999995453, \"rank\": 5.443730819617003e-13, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"The longstanding rivalry\", \"from\": 4205, \"to\": 4229}, {\"ngram\": \"the men's marathon\", \"from\": 4356, \"to\": 4374}]}, {\"sentence\": \"The 41-year-old Bekele last competed at the 2012 London Olympics when he finished fourth in the men's 10,000-metre before being overlooked for the 2016 and 2020 Olympics.\", \"from\": 4386, \"to\": 4556, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The 41-year-old Bekele\", \"from\": 4386, \"to\": 4408}, {\"ngram\": \"the 2012 London Olympics\", \"from\": 4426, \"to\": 4450}, {\"ngram\": \"the men's 10,000-metre\", \"from\": 4478, \"to\": 4500}, {\"ngram\": \"the 2016 and 2020 Olympics\", \"from\": 4529, \"to\": 4555}]}, {\"sentence\": \"However, a remarkable second-place finish at the London marathon in April earned him a place in the Paris Olympics, where he will line up against 39-year-old Kipchoge, the former marathon world record holder.\", \"from\": 4557, \"to\": 4765, \"entities\": [{\"begin\": 4606, \"end\": 4621, \"title\": \"http://dbpedia.org/resource/London_Marathon\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"London marathon\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/London_Marathon\", \"dbpedia\": \"http://dbpedia.org/resource/London_Marathon\"}], \"noun_phrases\": [{\"ngram\": \"a remarkable second-place finish\", \"from\": 4566, \"to\": 4598}, {\"ngram\": \"April\", \"from\": 4625, \"to\": 4630}, {\"ngram\": \"a place\", \"from\": 4642, \"to\": 4649}, {\"ngram\": \"the Paris Olympics\", \"from\": 4653, \"to\": 4671}, {\"ngram\": \"39-year-old Kipchoge\", \"from\": 4703, \"to\": 4723}, {\"ngram\": \"the former marathon world record holder\", \"from\": 4725, \"to\": 4764}]}, {\"sentence\": \"While Bekele has won three Olympic golds in the 5,000-metre and 10,000-metre, Kipchoge has won two Olympic marathon golds and is aiming for an unprecedented third.\", \"from\": 4767, \"to\": 4930, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Bekele\", \"from\": 4773, \"to\": 4779}, {\"ngram\": \"three Olympic golds\", \"from\": 4788, \"to\": 4807}, {\"ngram\": \"the 5,000-metre\", \"from\": 4811, \"to\": 4826}, {\"ngram\": \"10,000-metre\", \"from\": 4831, \"to\": 4843}, {\"ngram\": \"Kipchoge\", \"from\": 4845, \"to\": 4853}, {\"ngram\": \"two Olympic marathon golds\", \"from\": 4862, \"to\": 4888}, {\"ngram\": \"an unprecedented third\", \"from\": 4907, \"to\": 4929}]}, {\"sentence\": \"Bekele and Kipchoge's rivalry dates back to their first meeting at the 2003 World Championships final and the last time they raced together was at the London Marathon in 2018 when Kipchoge won.\", \"from\": 4932, \"to\": 5125, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Bekele\", \"from\": 4932, \"to\": 4938}, {\"ngram\": \"Kipchoge's rivalry\", \"from\": 4943, \"to\": 4961}, {\"ngram\": \"their first meeting\", \"from\": 4976, \"to\": 4995}, {\"ngram\": \"the last time\", \"from\": 5038, \"to\": 5051}, {\"ngram\": \"the London Marathon\", \"from\": 5079, \"to\": 5098}, {\"ngram\": \"Kipchoge\", \"from\": 5112, \"to\": 5120}]}, {\"sentence\": \"Rarely have two athletes been so inseparable in world sport as Italy's Gianmarco Tamberi and Mutaz Essa Barsham of Qatar.\", \"from\": 5127, \"to\": 5248, \"entities\": [{\"begin\": 5190, \"end\": 5195, \"title\": \"http://dbpedia.org/resourc