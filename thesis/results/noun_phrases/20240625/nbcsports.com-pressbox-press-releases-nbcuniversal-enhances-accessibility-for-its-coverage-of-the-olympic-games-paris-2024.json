 {\"sentence\": \"Livestreams and replays which offer audio description will have English audio description as a language choice within the players on these digital platforms.\", \"from\": 1751, \"to\": 1908, \"entities\": [{\"begin\": 1815, \"end\": 1822, \"title\": \"http://dbpedia.org/resource/English_language\", \"score\": 0.9999999999931788, \"rank\": 2.8501157103151255e-12, \"text\": \"English\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/English_language\", \"dbpedia\": \"http://dbpedia.org/resource/English_language\"}], \"noun_phrases\": [{\"ngram\": \"Livestreams\", \"from\": 1751, \"to\": 1762}, {\"ngram\": \"replays\", \"from\": 1767, \"to\": 1774}, {\"ngram\": \"audio description\", \"from\": 1787, \"to\": 1804}, {\"ngram\": \"a language choice\", \"from\": 1844, \"to\": 1861}, {\"ngram\": \"the players\", \"from\": 1869, \"to\": 1880}, {\"ngram\": \"these digital platforms\", \"from\": 1884, \"to\": 1907}]}, {\"sentence\": \"To easily find all events with audio description, clickhere.\", \"from\": 1909, \"to\": 1969, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"all events\", \"from\": 1924, \"to\": 1934}, {\"ngram\": \"audio description\", \"from\": 1940, \"to\": 1957}, {\"ngram\": \"clickhere\", \"from\": 1959, \"to\": 1968}]}, {\"sentence\": \"To contact NBCUniversal about issues related to closed captions, please send an email to CCFeedback@nbcuni.com.\", \"from\": 1971, \"to\": 2082, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"NBCUniversal\", \"from\": 1982, \"to\": 1994}, {\"ngram\": \"issues\", \"from\": 2001, \"to\": 2007}, {\"ngram\": \"closed captions\", \"from\": 2019, \"to\": 2034}, {\"ngram\": \"an email\", \"from\": 2048, \"to\": 2056}, {\"ngram\": \"CCFeedback@nbcuni.com\", \"from\": 2060, \"to\": 2081}]}, {\"sentence\": \"For audio description issues, email ADFeedback@nbcuni.com \\\"We are excited to provide all viewers with more accessibility to our Olympics coverage than ever before,\\\" saidGary Zenkel, President, NBC Olympics.\", \"from\": 2083, \"to\": 2290, \"entities\": [{\"begin\": 2277, \"end\": 2289, \"title\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"NBC Olympics\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\"}], \"noun_phrases\": [{\"ngram\": \"audio description issues\", \"from\": 2087, \"to\": 2111}, {\"ngram\": \"all viewers\", \"from\": 2168, \"to\": 2179}, {\"ngram\": \"more accessibility\", \"from\": 2185, \"to\": 2203}, {\"ngram\": \"our Olympics coverage\", \"from\": 2207, \"to\": 2228}, {\"ngram\": \"President\", \"from\": 2265, \"to\": 2274}]}, {\"sentence\": \"\\\"With the goal of enabling all viewers to enjoy the unprecedented excitement of the Olympic Games in Paris, we are proud to provide closed captioning on all live coverage and the most audio description ever.\\\"\", \"from\": 2291, \"to\": 2499, \"entities\": [{\"begin\": 2392, \"end\": 2397, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.462873003403436e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"the goal\", \"from\": 2297, \"to\": 2305}, {\"ngram\": \"all viewers\", \"from\": 2318, \"to\": 2329}, {\"ngram\": \"the unprecedented excitement\", \"from\": 2339, \"to\": 2367}, {\"ngram\": \"the Olympic Games\", \"from\": 2371, \"to\": 2388}, {\"ngram\": \"closed captioning\", \"from\": 2423, \"to\": 2440}, {\"ngram\": \"all live coverage\", \"from\": 2444, \"to\": 2461}, {\"ngram\": \"the most audio description\", \"from\": 2466, \"to\": 2492}]}, {\"sentence\": \"All of this audio description and closed captioning will be available to Comcast Xfinity customers who experience the Games on the Xfinity X1 platform, including on the live Olympic Games coverage delivered in 4K, on Xfinity Stream, and on Xfinity Flex.\", \"from\": 2501, \"to\": 2754, \"entities\": [{\"begin\": 2574, \"end\": 2589, \"title\": \"http://dbpedia.org/resource/Comcast\", \"score\": 0.9999999999872671, \"rank\": 1.285090974996118e-11, \"text\": \"Comcast Xfinity\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Comcast\", \"dbpedia\": \"http://dbpedia.org/resource/Comcast\"}, {\"begin\": 2718, \"end\": 2725, \"title\": \"http://dbpedia.org/resource/Comcast\", \"score\": 0.9999999999345164, \"rank\": 6.546120694229028e-11, \"text\": \"Xfinity\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Comcast\", \"dbpedia\": \"http://dbpedia.org/resource/Comcast\"}, {\"begin\": 2741, \"end\": 2753, \"title\": \"http://dbpedia.org/resource/Xfinity_Flex\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Xfinity Flex\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Xfinity_Flex\", \"dbpedia\": \"http://dbpedia.org/resource/Xfinity_Flex\"}], \"noun_phrases\": [{\"ngram\": \"this audio description\", \"from\": 2508, \"to\": 2530}, {\"ngram\": \"closed captioning\", \"from\": 2535, \"to\": 2552}, {\"ngram\": \"the Games\", \"from\": 2615, \"to\": 2624}, {\"ngram\": \"the Xfinity X1 platform\", \"from\": 2628, \"to\": 2651}, {\"ngram\": \"the live Olympic Games coverage\", \"from\": 2666, \"to\": 2697}, {\"ngram\": \"4K\", \"from\": 2711, \"to\": 2713}]}, {\"sentence\": \"\\\"For over a decade, Comcast NBCUniversal has been committed to connecting people to moments that matter,\\\" saidTom Wlodkowski, Vice President of Accessibility at Comcast.\", \"from\": 2756, \"to\": 2925, \"entities\": [{\"begin\": 2784, \"end\": 2796, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 1.0, \"rank\": 1.4954560922230907e-17, \"text\": \"NBCUniversal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q2422939