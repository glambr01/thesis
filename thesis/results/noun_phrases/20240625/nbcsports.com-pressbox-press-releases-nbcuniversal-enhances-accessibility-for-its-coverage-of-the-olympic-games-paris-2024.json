\", \"from\": 975, \"to\": 1211, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"More audio description services - interspersing broadcast audio\", \"from\": 975, \"to\": 1038}, {\"ngram\": \"skilled voices\", \"from\": 1044, \"to\": 1058}, {\"ngram\": \"Olympic scenes\", \"from\": 1070, \"to\": 1084}, {\"ngram\": \"context\", \"from\": 1089, \"to\": 1096}, {\"ngram\": \"viewers\", \"from\": 1121, \"to\": 1128}, {\"ngram\": \"the Paris Olympics\", \"from\": 1168, \"to\": 1186}, {\"ngram\": \"any previous Games\", \"from\": 1192, \"to\": 1210}]}, {\"sentence\": \"All coverage on NBC, including daytime, primetime, and late night, and theGold Zonewhip-around showon Peacock, will feature audio description provided by Descriptive Video Works.\", \"from\": 1212, \"to\": 1390, \"entities\": [{\"begin\": 1228, \"end\": 1231, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.683950296634214, \"rank\": 0.46209454807483813, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Sports\"}], \"noun_phrases\": [{\"ngram\": \"All coverage\", \"from\": 1212, \"to\": 1224}, {\"ngram\": \"daytime\", \"from\": 1243, \"to\": 1250}, {\"ngram\": \"late night\", \"from\": 1267, \"to\": 1277}, {\"ngram\": \"theGold Zonewhip-around showon Peacock\", \"from\": 1283, \"to\": 1321}, {\"ngram\": \"audio description\", \"from\": 1336, \"to\": 1353}, {\"ngram\": \"Descriptive Video Works\", \"from\": 1366, \"to\": 1389}]}, {\"sentence\": \"In a first for a U.S. broadcaster, audio description services for NBC coverage will be provided in stereo, enhancing the quality of sound for viewers.\", \"from\": 1391, \"to\": 1541, \"entities\": [{\"begin\": 1457, \"end\": 1460, \"title\": \"http://dbpedia.org/resource/NBC_Sports\", \"score\": 0.683950296634214, \"rank\": 0.46209454807483813, \"text\": \"NBC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/NBC_Sports\", \"dbpedia\": \"http://dbpedi