ral_Republic_of_Yugoslavia\", \"score\": 0.9999149583701208, \"rank\": 8.504886145957844e-05, \"text\": \"Yugoslav\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Socialist_Federal_Republic_of_Yugoslavia\", \"dbpedia\": \"http://dbpedia.org/resource/Socialist_Federal_Republic_of_Yugoslavia\"}], \"noun_phrases\": [{\"ngram\": \"every citizen\", \"from\": 4495, \"to\": 4508}, {\"ngram\": \"infrastructure projects\", \"from\": 4530, \"to\": 4553}, {\"ngram\": \"the common good\", \"from\": 4558, \"to\": 4573}]}, {\"sentence\": \"There were 1,200,000 individual donations and more than 4,000 group donations from companies.\", \"from\": 4575, \"to\": 4668, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"1,200,000 individual donations\", \"from\": 4586, \"to\": 4616}, {\"ngram\": \"more than 4,000 group donations\", \"from\": 4621, \"to\": 4652}, {\"ngram\": \"companies\", \"from\": 4658, \"to\": 4667}]}, {\"sentence\": \"\\\"I remember kids coming from all around the country for rehearsal days before the opening.\", \"from\": 4670, \"to\": 4760, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"kids\", \"from\": 4682, \"to\": 4686}, {\"ngram\": \"the country\", \"from\": 4710, \"to\": 4721}, {\"ngram\": \"rehearsal days\", \"from\": 4726, \"to\": 4740}, {\"ngram\": \"the opening\", \"from\": 4748, \"to\": 4759}]}, {\"sentence\": \"They all lived together at the time, and my late daughter was one of them,\\\" Begic remembered.\", \"from\": 4761, \"to\": 4854, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the time\", \"from\": 4788, \"to\": 4796}, {\"ngram\": \"my late daughter\", \"from\": 4802, \"to\": 4818}, {\"ngram\": \"Begic\", \"from\": 4837, \"to\": 4842}]}, {\"sentence\": \"Young participants from all over Yugoslavia were billeted in student dormitories in the Bosnian capital while they worked on the routines for the opening ceremony.\", \"from\": 4855, \"to\": 5018, \"entities\": [{\"begin\": 4888, \"end\": 4898, \"title\": \"http://db