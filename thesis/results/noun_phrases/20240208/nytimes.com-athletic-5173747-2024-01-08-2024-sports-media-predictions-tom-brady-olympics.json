"noun_phrases\": [{\"ngram\": \"an effective group\", \"from\": 2624, \"to\": 2642}]}, {\"sentence\": \"He will also be the beneficiary of players and coaches being candid with him.\", \"from\": 2663, \"to\": 2740, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the beneficiary\", \"from\": 2679, \"to\": 2694}, {\"ngram\": \"players\", \"from\": 2698, \"to\": 2705}, {\"ngram\": \"coaches\", \"from\": 2710, \"to\": 2717}]}, {\"sentence\": \"The first couple of games will likely be mixed for him - everyone is going to have an opinion on him as a broadcaster - but I bet by Week 9-10, he's a decent listen.\", \"from\": 2741, \"to\": 2906, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The first couple\", \"from\": 2741, \"to\": 2757}, {\"ngram\": \"games\", \"from\": 2761, \"to\": 2766}, {\"ngram\": \"everyone\", \"from\": 2798, \"to\": 2806}, {\"ngram\": \"an opinion\", \"from\": 2824, \"to\": 2834}, {\"ngram\": \"a broadcaster\", \"from\": 2845, \"to\": 2858}, {\"ngram\": \"Week\", \"from\": 2874, \"to\": 2878}, {\"ngram\": \"a decent listen\", \"from\": 2890, \"to\": 2905}]}, {\"sentence\": \"Advertisement The last two Olympic Games were a viewership disaster.\", \"from\": 2908, \"to\": 2977, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The last two Olympic Games\", \"from\": 2922, \"to\": 2948}, {\"ngram\": \"a viewership disaster\", \"from\": 2954, \"to\": 2975}]}, {\"sentence\": \"The Beijing Olympics in February 2022 were the least-watched Games in prime time on NBC ever, averaging 10.7 million viewers per night on television, with that number rising slightly to 11.4 million including all other viewing platforms.\", \"from\": 2978, \"to\": 3215, \"entities\": [{\"begin\": 2982, \"end\": 2998, \"title\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.1929955737893619e-15, \"text\": \"Beijing Olympics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"dbpedia\": \"http://d