om\": 949, \"to\": 958}, {\"ngram\": \"his mother\", \"from\": 970, \"to\": 980}, {\"ngram\": \"three brothers\", \"from\": 985, \"to\": 999}]}, {\"sentence\": \"Hughes represents Team GB because the International Olympic Committee does not recognise Anguilla, which is a British overseas territory.\", \"from\": 1040, \"to\": 1177, \"entities\": [{\"begin\": 1058, \"end\": 1065, \"title\": \"http://dbpedia.org/resource/Team_GB\", \"score\": 1.0, \"rank\": 1.4599067313016302e-13, \"text\": \"Team GB\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Team_GB\", \"dbpedia\": \"http://dbpedia.org/resource/Team_GB\"}, {\"begin\": 1078, \"end\": 1109, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 1150, \"end\": 1176, \"title\": \"http://dbpedia.org/resource/British_Overseas_Territories\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"British overseas territory\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/British_Overseas_Territories\", \"dbpedia\": \"http://dbpedia.org/resource/British_Overseas_Territories\"}], \"noun_phrases\": [{\"ngram\": \"Hughes\", \"from\": 1040, \"to\": 1046}, {\"ngram\": \"Anguilla\", \"from\": 1129, \"to\": 1137}]}, {\"sentence\": \"Instead, Hughes became driven by the buzz from rubbing shoulders with track royalty such as Bolt and an opportunity to achieve greatness.\", \"from\": 1178, \"to\": 1315, \"entities\": [{\"begin\": 1187, \"end\": 1193, \"title\": \"http://dbpedia.org/resource/Howard_Hughes\", \"score\": 0.999999987830961, \"rank\": 7.904753992924234e-09, \"text\": \"Hughes\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Howard_Hughes\", \"dbpedia\": \"http: