"{\"uid\": \"citizen.co.za-sport-team-sa-kit-paris-olympic-games\", \"noun_phrases\": [{\"sentence\": \"Home\\u00bbSport ByWesley Botton Chief sports journalist 2 minute read 21 May 2024 07:04 pm Track athletes Marione Fourie and Luxolo Adams at the SA team kit reveal on Tuesday night.\", \"from\": 0, \"to\": 182, \"entities\": [{\"begin\": 21, \"end\": 27, \"title\": \"http://dbpedia.org/resource/Botton,_North_Yorkshire\", \"score\": 0.901131173431149, \"rank\": 0.0, \"text\": \"Botton\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Botton,_North_Yorkshire\", \"dbpedia\": \"http://dbpedia.org/resource/Botton,_North_Yorkshire\"}, {\"begin\": 126, \"end\": 138, \"title\": \"http://dbpedia.org/resource/Luxolo_Adams\", \"score\": 0.9999999998044586, \"rank\": 0.0, \"text\": \"Luxolo Adams\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Luxolo_Adams\", \"dbpedia\": \"http://dbpedia.org/resource/Luxolo_Adams\"}, {\"begin\": 146, \"end\": 148, \"title\": \"http://dbpedia.org/resource/South_Africa\", \"score\": 0.9999998853188637, \"rank\": 1.0511004301026768e-07, \"text\": \"SA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/South_Africa\", \"dbpedia\": \"http://dbpedia.org/resource/South_Africa\"}], \"noun_phrases\": [{\"ngram\": \"2 minute\", \"from\": 51, \"to\": 59}, {\"ngram\": \"Track\", \"from\": 86, \"to\": 91}, {\"ngram\": \"Marione Fourie\", \"from\": 101, \"to\": 115}, {\"ngram\": \"Tuesday night\", \"from\": 162, \"to\": 175}]}, {\"sentence\": \"Picture Anton Geyser/Gallo Images South African athletes will 'look good and feel good' at this year's Olympic Games, according to the national Olympic committee (Sascoc), after the SA team kit was revealed on Tuesday night.\", \"from\": 183, \"to\": 408, \"entities\": [{\"begin\": 197, \"end\": 203, \"title\": \"http://dbpedia.org/resource/Geyser\", \"score\": 0.9999999999854481, \"rank\": 1.4636973673989857e-11, \"text\": \"