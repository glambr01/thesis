, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the leader\", \"from\": 25296, \"to\": 25306}, {\"ngram\": \"the race\", \"from\": 25310, \"to\": 25318}, {\"ngram\": \"the context\", \"from\": 25340, \"to\": 25351}, {\"ngram\": \"this crowd\", \"from\": 25360, \"to\": 25370}, {\"ngram\": \"his history\", \"from\": 25396, \"to\": 25407}, {\"ngram\": \"the event\", \"from\": 25421, \"to\": 25430}, {\"ngram\": \"my approach\", \"from\": 25452, \"to\": 25463}, {\"ngram\": \"his reaction\", \"from\": 25481, \"to\": 25493}]}, {\"sentence\": \"After the opening ceremony, the Olympic Cauldron was placed next to the Louvre.\", \"from\": 25496, \"to\": 25575, \"entities\": [{\"begin\": 25528, \"end\": 25544, \"title\": \"http://dbpedia.org/resource/Olympic_flame\", \"score\": 0.9999997646104071, \"rank\": 2.3538959781879045e-07, \"text\": \"Olympic Cauldron\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_flame\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_flame\"}], \"noun_phrases\": [{\"ngram\": \"the opening ceremony\", \"from\": 25502, \"to\": 25522}, {\"ngram\": \"the Louvre\", \"from\": 25564, \"to\": 25574}]}, {\"sentence\": \"I heard about it being lifted at night, so I went there since the weather got better after terrible rains on Friday and Saturday.\", \"from\": 25576, \"to\": 25705, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"night\", \"from\": 25609, \"to\": 25614}, {\"ngram\": \"the weather\", \"from\": 25638, \"to\": 25649}, {\"ngram\": \"terrible rains\", \"from\": 25667, \"to\": 25681}, {\"ngram\": \"Friday\", \"from\": 25685, \"to\": 25691}, {\"ngram\": \"Saturday\", \"from\": 25696, \"to\": 25704}]}, {\"sentence\": \"The crowd around was huge on Sunday so I expected this beautiful moment to happen after sunset.\", \"from\": 25706, \"to\": 25801, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The crowd\", \"from\": 25706, \"to\": 25715}, {\"ngram\": \"Sunday\", \"from\": 25735, \"to\": 25741}, {\"ngram\": \"this beautiful moment\", \"from\": 25756, \"to\": 25777}, {\"ngram\": \"sunset\", \"from\": 25794, \"to\": 25800}]}, {\"sentence\": \"I wanted to be a bit behind to show all the people around and to catch some of the phones in front of me of people taking in the moment.\", \"from\": 25802, \"to\": 25938, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"all the people\", \"from\": 25838, \"to\": 25852}, {\"ngram\": \"the phones\", \"from\": 25881, \"to\": 25891}, {\"ngram\": \"front\", \"from\": 25895, \"to\": 25900}, {\"ngram\": \"people\", \"from\": 25910, \"to\": 25916}, {\"ngram\": \"the moment\", \"from\": 25927, \"to\": 25937}]}, {\"sentence\": \"At 10 p.m. when the Eiffel Tower started sprinkling, they lifted the cauldron, and everyone started cheering.\", \"from\": 25939, \"to\": 26048, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"10 p.m.\", \"from\": 25942, \"to\": 25949}, {\"ngram\": \"the Eiffel Tower\", \"from\": 25955, \"to\": 25971}, {\"ngram\": \"the cauldron\", \"from\": 26004, \"to\": 26016}, {\"ngram\": \"everyone\", \"from\": 26022, \"to\": 26030}]}, {\"sentence\": \"It was a special moment to be part of and I like the lighting just as the sun lowers and twilight begins as the cauldron lifts.\", \"from\": 26049, \"to\": 26176, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a special moment\", \"from\": 26056, \"to\": 26072}, {\"ngram\": \"part\", \"from\": 26079, \"to\": 26083}, {\"ngram\": \"the lighting\", \"from\": 26098, \"to\": 26110}, {\"ngram\": \"the sun lowers\", \"from\": 26119, \"to\": 26133}, {\"ngram\": \"twilight\", \"from\": 26138, \"to\": 26146}, {\"ngram\": \"the cauldron lifts\", \"from\": 26157, \"to\": 26175}]}, {\"sentence\": \"This Image taken from the Rugby Sevens at Stade de France using a Canon Robotic head with a 100-300mm lens.\", \"from\": 26178, \"to\": 26285, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"This Image\", \"from\": 26178, \"to\": 26188}, {\"ngram\": \"the Rugby Sevens\", \"from\": 26200, \"to\": 2