s\": [], \"wikid\": \"http://dbpedia.org/resource/Commonwealth_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Commonwealth_Games\"}, {\"begin\": 4463, \"end\": 4468, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 4.350907823073971e-16, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"The King's message\", \"from\": 4229, \"to\": 4247}, {\"ngram\": \"My wife\", \"from\": 4255, \"to\": 4262}, {\"ngram\": \"our warmest congratulations\", \"from\": 4283, \"to\": 4310}, {\"ngram\": \"the competitors\", \"from\": 4314, \"to\": 4329}, {\"ngram\": \"their support teams\", \"from\": 4334, \"to\": 4353}, {\"ngram\": \"their many outstanding successes\", \"from\": 4406, \"to\": 4438}, {\"ngram\": \"the Olympic Games\", \"from\": 4442, \"to\": 4459}]}, {\"sentence\": \"\\\"Your achievements, across so many disciplines, were forged from that invaluable combination of raw talent, true grit and hard toil over many years, burnished these past weeks by sportsmanship and team spirit in the finest tradition of the Games.\", \"from\": 4471, \"to\": 4717, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Your achievements\", \"from\": 4472, \"to\": 4489}, {\"ngram\": \"so many disciplines\", \"from\": 4498, \"to\": 4517}, {\"ngram\": \"that invaluable combination\", \"from\": 4536, \"to\": 4563}, {\"ngram\": \"raw talent\", \"from\": 4567, \"to\": 4577}, {\"ngram\": \"true grit\", \"from\": 4579, \"to\": 4588}, {\"ngram\": \"hard toil\", \"from\": 4593, \"to\": 4602}, {\"ngram\": \"many years\", \"from\": 4608, \"to\": 4618}, {\"ngram\": \"sportsmanship and team spirit\", \"from\": 4650, \"to\": 4679}, {\"ngram\": \"the finest tradition\", \"from\": 4683, \"to\": 4703}, {\"ngram\": \"the Games\", \"from\": 4707, \"to\": 4716}]}, {\"sentence\": \"\\\"To those who missed out on the greatest prizes, you have most certainly