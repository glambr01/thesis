zerbaijan\"}], \"noun_phrases\": [{\"ngram\": \"The campaign\", \"from\": 518, \"to\": 530}, {\"ngram\": \"response\", \"from\": 538, \"to\": 546}, {\"ngram\": \"the ethnic cleansing\", \"from\": 550, \"to\": 570}, {\"ngram\": \"a military campaign\", \"from\": 650, \"to\": 669}, {\"ngram\": \"the president\", \"from\": 681, \"to\": 694}, {\"ngram\": \"the dictator\", \"from\": 751, \"to\": 763}, {\"ngram\": \"Azerbaijan\", \"from\": 767, \"to\": 777}, {\"ngram\": \"Ilham Aliyev\", \"from\": 780, \"to\": 792}]}, {\"sentence\": \"Despite the IOC's public commitment to \\\"promoting human rights through sport,\\\" and its decision to ban the Russian and Belarusian national teams from participating in the Paris Games over Russia's invasion of Ukraine, the IOC did not take any action against Azerbaijan after its ethnic cleansing campaign in Nagorno Karabakh.\", \"from\": 795, \"to\": 1120, \"entities\": [{\"begin\": 807, \"end\": 810, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 4.958312594268069e-17, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 902, \"end\": 909, \"title\": \"http://dbpedia.org/resource/Russian_language\", \"score\": 0.9657081832477094, \"rank\": 0.022093532030828752, \"text\": \"Russian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Russian_language\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_language\"}, {\"begin\": 914, \"end\": 924, \"title\": \"http://dbpedia.org/resource/Belarus\", \"score\": 0.9401321489672436, \"rank\": 0.040591374189799745, \"text\": \"Belarusian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Belarus\", \"dbpedia\": \"http://dbpedia.org/resource/Belarus\"}, {\"begin\": 983, \"end\": 989, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.