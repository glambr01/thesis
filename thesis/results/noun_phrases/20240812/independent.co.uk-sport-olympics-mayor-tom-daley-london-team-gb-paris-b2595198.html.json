: 704}, {\"ngram\": \"hands\", \"from\": 756, \"to\": 761}, {\"ngram\": \"the athletes\", \"from\": 767, \"to\": 779}, {\"ngram\": \"the platform\", \"from\": 783, \"to\": 795}, {\"ngram\": \"the country\", \"from\": 827, \"to\": 838}]}, {\"sentence\": \"He said: \\\"These athletes are going to inspire another generation to get involved.\", \"from\": 851, \"to\": 932, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"These athletes\", \"from\": 861, \"to\": 875}, {\"ngram\": \"another generation\", \"from\": 897, \"to\": 915}]}, {\"sentence\": \"Our Olympians have brought the country together and that's what's needed.\\\"\", \"from\": 933, \"to\": 1007, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Our Olympians\", \"from\": 933, \"to\": 946}, {\"ngram\": \"the country\", \"from\": 960, \"to\": 971}]}, {\"sentence\": \"Tom Daley, who revealed on his arrival in the capital that he was retiring from diving, won silver with partner Noah Williams in the synchronised 10 metre platform in Paris, his fifth Games.\", \"from\": 1009, \"to\": 1199, \"entities\": [{\"begin\": 1009, \"end\": 1018, \"title\": \"http://dbpedia.org/resource/Tom_Daley\", \"score\": 1.0, \"rank\": 3.918500881360081e-43, \"text\": \"Tom Daley\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tom_Daley\", \"dbpedia\": \"http://dbpedia.org/resource/Tom_Daley\"}, {\"begin\": 1121, \"end\": 1134, \"title\": \"http://dbpedia.org/resource/Noah_Williams_(diver)\", \"score\": 0.999998273608197, \"rank\": 0.0, \"text\": \"Noah Williams\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Noah_Williams_(diver)\", \"dbpedia\": \"http://dbpedia.org/resource/Noah_Williams_(diver)\"}, {\"begin\": 1176, \"end\": 1181, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999996091447, \"rank\": 3.908791178725234e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"his arrival\", \"from\": 1036, \"to\": 1047}, {\"ngram\": \"the capital\", \"from\": 1051, \"to\": 1062}, {\"ngram\": \"diving\", \"from\": 1089, \"to\": 1095}, {\"ngram\": \"silver\", \"from\": 1101, \"to\": 1107}, {\"ngram\": \"the synchronised 10 metre platform\", \"from\": 1138, \"to\": 1172}, {\"ngram\": \"his fifth Games\", \"from\": 1183, \"to\": 1198}]}, {\"sentence\": \"Khan added: \\\"Noah Williams was inspired by Tom Daley in 2012, our canoeists say they took advantage of the facilities we built off the back of (London) 2012.\", \"from\": 1201, \"to\": 1358, \"entities\": [{\"begin\": 1201, \"end\": 1205, \"title\": \"http://dbpedia.org/resource/Shah_Rukh_Khan\", \"score\": 0.9999245325609087, \"rank\": 4.692002793700304e-05, \"text\": \"Khan\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q33999\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Shah_Rukh_Khan\", \"dbpedia\": \"http://dbpedia.org/resource/Shah_Rukh_Khan\"}, {\"begin\": 1214, \"end\": 1227, \"title\": \"http://dbpedia.org/resource/Noah_Williams_(diver)\", \"score\": 0.999998273608197, \"rank\": 0.0, \"text\": \"Noah Williams\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Noah_Williams_(diver)\", \"dbpedia\": \"http://dbpedia.org/resource/Noah_Williams_(diver)\"}, {\"begin\": 1244, \"end\": 1253, \"title\": \"http://dbpedia.org/resource/Tom_Daley\", \"score\": 1.0, \"rank\": 3.918500881360081e-43, \"text\": \"Tom Daley\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tom_Daley\", \"dbpedia\": \"http://dbpedia.org/resource/Tom_Daley\"}, {\"begin\": 1345, \"end\": 1351, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9999999898629994, \"rank\": 5.448982184165479e-09, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}], \"noun_phrases\": [{\"ngram\": \"our canoeists\", \"from\": 1263, \"to\": 1276}, {\"ngram\": \"advantage\", \"from\": 1291, \"to\": 1300}, {\"ngram\": \"the facilities\", \"from\": 1304, \"to\": 1318}, {\"ngram\": \"the back\", \"from\": 1332, \"to\": 1340}]}, {\"sentence\": \"\\\"It's important to recognise that not only are the Olympics important to win the medals, but to inspire fans of a new generation.\\\"\", \"from\": 1360, \"to\": 1490, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the Olympics\", \"from\": 1407, \"to\": 1419}, {\"ngram\": \"the medals\", \"from\": 1437, \"to\": 1447}, {\"ngram\": \"fans\", \"from\": 1464, \"to\": 1468}, {\"ngram\": \"a new generation\", \"from\": 1472, \"to\": 1488}]}, {\"sentence\": \"The 65-medal haul, which included 14 golds, was the same amount won byTeam GBat the 2012 Games.\", \"from\": 1492, \"to\": 1587, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The 65-medal haul\", \"from\": 1492, \"to\": 1509}, {\"ngram\": \"14 golds\", \"from\": 1526, \"to\": 1534}, {\"ngram\": \"the same amount\", \"from\": 1540, \"to\": 1555}, {\"ngram\": \"byTeam\", \"from\": 1560, \"to\": 1566}, {\"ngram\": \"the 2012 Games\", \"from\": 1572, \"to\": 1586}]}, {\"sentence\": \"The athletes, many of whom wore their medals round their necks, posed for pictures with adoring fans on the platform.\", \"from\": 1589, \"to\": 1706, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The athletes\", \"from\": 1589, \"to\": 1601}, {\"ngram\": \"their medals\", \"from\": 1621, \"to\": 1633}, {\"ngram\": \"their necks\", \"from\": 1640, \"to\": 1651}, {\"ngram\": \"pictures\", \"from\": 1663, \"to\": 1671}, {\"ngram\": \"adoring fans\", \"from\": 1677, \"to\": 1689}, {\"ngram\": \"the platform\", \"from\": 1693, \"to\": 1705}]}, {\"sentence\": \"An emotional Daley, who made his Olympic debut as a 14-year-old in Beijing in 2008, said: \\\"It felt like a massive bonus because I took two years out of the sport after Tokyo and I did not know if I would get back into the team or qualify for a spot with Team GB.\", \"from\": 1708, \"to\": 1970, \"entities\": [{\"begin\": 1775, \"end\": 1782, \"title\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"score\": 0.9999999994061, \"rank\": 5.937955409281119e-10, \"text\": \"Beijing\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2008_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2008_Summer_Olympics\"}, {\"begin\": 1876, \"end\": 1881, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.9998368666456037, \"rank\": 0.00016293551980905562, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}, {\"begin\": 1962, \"end\": 1969, \"title\": \"http://dbpedia.org/resource/Team_GB\", \"score\": 0.9999996475219799, \"rank\": 3.520259432995039e-07, \"text\": \"Team GB\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Team_GB\", \"dbpedia\": \"http://dbpedia.org/resource/Team_GB\"}], \"noun_phrases\": [{\"ngram\": \"An emotional Daley\", \"from\": 1708, \"to\": 1726}, {\"ngram\": \"his Olympic debut\", \"from\": 1737, \"to\": 1754}, {\"ngram\": \"a massive bonus\", \"from\": 1812, \"to\": 1827}, {\"ngram\": \"two years\", \"from\": 1843, \"to\": 1852}, {\"ngram\": \"the sport\", \"from\": 1860, \"to\": 1869}, {\"ngram\": \"the team\", \"from\": 1926, \"to\": 1934}, {\"ngram\": \"a spot\", \"from\": 1950, \"to\": 1956}]}, {\"sentence\": \"\\\"To come away with a medal in front of my family, it meant a lot to me.\\\"\", \"from\": 1972, \"to\": 2044, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a medal\", \"from\": 1991, \"to\": 1998}, {\"ngram\": \"front\", \"from\": 2002, \"to\": 2007}, {\"ngram\": \"my family\", \"from\": 2011, \"to\": 2020}, {\"ngram\": \"a lot\", \"from\": 2031, \"to\": 2036}]}, {\"sentence\": \"Also among the medallists was boxer Lewis Richardson, who won bronze in the 71kg category.\", \"from\": 2046, \"to\": 2136, \"entities\": [{\"begin\": 2082, \"end\": 2098, \"title\": \"http://dbpedia.org/resource/Lewis_Richardson_(Hollyoaks)\", \"score\": 0.9965136461602875, \"rank\": 0.0034965034965035347, \"text\": \"Lewis Richardson\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Lewis_Richardson_(Hollyoaks)\", \"dbpedia\": \"http://dbpedia.org/resource/Lewis_Richardson_(Hollyoaks)\"}], \"noun_phrases\": [{\"ngram\": \"the medallists\", \"from\": 2057, \"to\": 2071}, {\"ngram\": \"bronze\", \"from\": 2108, \"to\": 2114}, {\"ngram\": \"the 71kg category\", \"from\": 2118, \"to\": 2135}]}, {\"sentence\": \"\\\"It was a special Games because it was the first one in Europe since London,\\\" the 27-year-old told the PA news agency.\", \"from\": 2138, \"to\": 2256, \"entities\": [{\"begin\": 2207, \"end\": 2213, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9999999898629994, \"rank\": 5.448982184165479e-09, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}], \"noun_phrases\": [{\"ngram\": \"a special Games\", \"from\": 2146, \"to\": 2161}, {\"ngram\": \"Europe\", \"from\": 2194, \"to\": 2200}, {\"ngram\": \"the PA news agency\", \"from\": 2237, \"to\": 2255}]}, {\"sentence\": \"\\\"We had a lot of support out here and to be honest it felt like a home games.\", \"from\": 2258, \"to\": 2335, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a lot\", \"from\": 2266, \"to\": 2271}, {\"ngram\": \"support\", \"from\": 2275, \"to\": 2282}, {\"ngram\": \"a home games\", \"from\": 2322, \"to\": 2334}]}, {\"sentence\": \"It has been special for mine, my family's life and everyone who has been connected to my journey.\", \"from\": 2336, \"to\": 2433, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"mine\", \"from\": 2360, \"to\": 2364}, {\"ngram\": \"my family's life\", \"from\": 2366, \"to\": 2382}, {\"ngram\": \"everyone\", \"from\": 2387, \"to\": 2395}, {\"ngram\": \"my journey\", \"from\": 2422, \"to\": 2432}]}, {\"sentence\": \"It's been up there with the best times of my life.\", \"from\": 2434, \"to\": 2484, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the best times\", \"from\": 2458, \"to\": 2472}, {\"ngram\": \"my life\", \"from\": 2476, \"to\": 2483}]}, {\"sentence\": \"\\\"I have always felt like I can dream, but that this would only be a dream.\", \"from\": 2486, \"to\": 2560, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a dream\", \"from\": 2552, \"to\": 2559}]}, {\"sentence\": \"To be able to turn this into a reality has been special and the highlight of my boxing career so far.\", \"from\": 2561, \"to\": 2662, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a reality\", \"from\": 2590, \"to\": 2599}, {\"ngram\": \"the highlight\", \"from\": 2621, \"to\": 2634}, {\"ngram\": \"my boxing career\", \"from\": 2638, \"to\": 2654}]}, {\"sentence\": \"\\\"I want to celebrate this moment because there is been a lot of hard work going into this.\\\"\", \"from\": 2664, \"to\": 2755, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this moment\", \"from\": 2685, \"to\": 2696}, {\"ngram\": \"a lot\", \"from\": 2719, \"to\": 2724}, {\"ngram\": \"hard work\", \"from\": 2728, \"to\": 2737}]}, {\"sentence\": \"Richardson battled past Serbia's Vahid Abasov and Jordan's Zeyad Eashash before a split-decision defeat to Mexican Marco Verde.\", \"from\": 2757, \"to\": 2884, \"entities\": [{\"begin\": 2781, \"end\": 2787, \"title\": \"http://dbpedia.org/resource/Serbia\", \"score\": 0.9777608797002321, \"rank\": 0.022710481203992574, \"text\": \"Serbia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Serbia\", \"dbpedia\": \"http://dbpedia.org/resource/Serbia\"}, {\"begin\": 2807, \"end\": 2813, \"title\": \"http://dbpedia.org/resource/Jordan\", \"score\": 0.7414702782901715, \"rank\": 0.32553486560954237, \"text\": \"Jordan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jordan\", \"dbpedia\": \"http://dbpedia.org/resource/Jordan\"}, {\"begin\": 2864, \"end\": 2871, \"title\": \"http://dbpedia.org/resource/Mexico\", \"score\": 0.6382681849032533, \"rank\": 0.5654995134381084, \"text\": \"Mexican\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Mexico\", \"dbpedia\": \"http://dbpedia.org/resource/Mexico\"}], \"noun_phrases\": [{\"ngram\": \"Richardson\", \"from\": 2757, \"to\": 2767}, {\"ngram\": \"a split-decision defeat\", \"from\": 2837, \"to\": 2860}]}, {\"sentence\": \"He added: \\\"I am a natural middleweight and I have dropped down to light-middleweight to make these Olympics which has been a struggle in itself, but I would not change it for the world and every struggle has been worth it.\", \"from\": 2886, \"to\": 3108, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a natural middleweight\", \"from\": 2902, \"to\": 2924}, {\"ngram\": \"light-middleweight\", \"from\": 2952, \"to\": 2970}, {\"ngram\": \"these Olympics\", \"from\": 2979, \"to\": 2993}, {\"ngram\": \"a struggle\", \"from\": 3009, \"to\": 3019}, {\"ngram\": \"the world\", \"from\": 3061, \"to\": 3070}, {\"ngram\": \"every struggle\", \"from\": 3075, \"to\": 3089}]}, {\"sentence\": \"\\\"The squeeze has been worth the juice because I have made memories for life.\", \"from\": 3110, \"to\": 3186, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The squeeze\", \"from\": 3111, \"to\": 3122}, {\"ngram\": \"memories\", \"from\": 3168, \"to\": 3176}, {\"ngram\": \"life\", \"from\": 3181, \"to\": 3185}]}, {\"sentence\": \"\\\"Light-middleweight it the most stacked division at the Games in terms of talent, the standard was extremely high.\", \"from\": 3188, \"to\": 3302, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the most stacked division\", \"from\": 3211, \"to\": 3236}, {\"ngram\": \"the Games\", \"from\": 3240, \"to\": 3249}, {\"ngram\": \"terms\", \"from\": 3253, \"to\": 3258}, {\"ngram\"