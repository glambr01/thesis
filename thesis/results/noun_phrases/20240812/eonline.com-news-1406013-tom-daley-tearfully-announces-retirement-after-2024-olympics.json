"{\"uid\": \"eonline.com-news-1406013-tom-daley-tearfully-announces-retirement-after-2024-olympics\", \"noun_phrases\": [{\"sentence\": \"Great Britain's Tom Daley confirmed the 2024 Paris Olympic Games were his last, as the diver announced his retirement from the sport August 12.\", \"from\": 0, \"to\": 143, \"entities\": [{\"begin\": 0, \"end\": 13, \"title\": \"http://dbpedia.org/resource/Great_Britain_at_the_Olympics\", \"score\": 0.8991978054689388, \"rank\": 0.11153362881964105, \"text\": \"Great Britain\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Great_Britain_at_the_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Great_Britain_at_the_Olympics\"}, {\"begin\": 16, \"end\": 25, \"title\": \"http://dbpedia.org/resource/Tom_Daley\", \"score\": 1.0, \"rank\": 5.109458824148962e-37, \"text\": \"Tom Daley\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tom_Daley\", \"dbpedia\": \"http://dbpedia.org/resource/Tom_Daley\"}], \"noun_phrases\": [{\"ngram\": \"the 2024 Paris Olympic Games\", \"from\": 36, \"to\": 64}, {\"ngram\": \"the diver\", \"from\": 83, \"to\": 92}, {\"ngram\": \"his retirement\", \"from\": 103, \"to\": 117}, {\"ngram\": \"the sport\", \"from\": 123, \"to\": 132}]}, {\"sentence\": \"Tom Daleyis diving into a new chapter after the2024 Paris Olympics.\", \"from\": 145, \"to\": 212, \"entities\": [{\"begin\": 197, \"end\": 211, \"title\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Paris Olympics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/1924_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"Tom Daleyis diving\", \"from\": 145, \"to\": 163}, {\"ngram\": \"a new chapter\", \"from\": 169, \"to\": 182}]}, {\"sentence\": \"The beloved athlete from Team Great Britain-who has become a fan-favorite across an impressive five Olympic Games between his medal-earning performancesand knitting projects-announced he is officially retiring from the sport in an emotionalinterview with the BBC August 12while leaving Paris.\", \"from\": 214, \"to\": 506, \"entities\": [{\"begin\": 473, \"end\": 476, \"title\": \"http://dbpedia.org/resource/BBC\", \"score\": 0.9904605018421272, \"rank\": 0.009428337847431321, \"text\": \"BBC\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/BBC\", \"dbpedia\": \"http://dbpedia.org/resource/BBC\"}, {\"begin\": 500, \"end\": 505, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999996125553, \"rank\": 3.874489678372332e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"The beloved athlete\", \"from\": 214, \"to\": 233}, {\"ngram\": \"Team Great Britain\", \"from\": 239, \"to\": 257}, {\"ngram\": \"an impressive five Olympic Games\", \"from\": 295, \"to\": 327}, {\"ngram\": \"his medal-earning performancesand knitting projects\", \"from\": 336, \"to\": 387}, {\"ngram\": \"the sport\", \"from\": 429, \"to\": 438}, {\"ngram\": \"an emotionalinterview\", \"from\": 442, \"to\": 463}]}, {\"sentence\": \"\\\"It's hard to talk about, it's emotional,\\\" Tom told the camera through tears, while the BBC announcer gave him a moment to collect himself, telling him, \\\"The whole of the U.K. are so proud of you, and it's so amazing to have you back with your silver medal.\", \"from\": 508, \"to\": 765, \"entities\": [{\"begin\": 596, \"end\": 599, \"title\": \"http://dbpedia.org/resource/BBC\", \"score\": 0.9904605018421272, \"rank\": 0.009428337847431321, \"text\": \"BBC\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/BBC\", \"dbpedia\": \"http://dbpedia.org/resource/BBC\"}, {\"begin\": 679, \"end\": 683, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.999802957456035, \"rank\": 0.00015134561904527803, \"text\": \"U.K.\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"Tom\", \"from\": 551, \"to\": 554}, {\"ngram\": \"the camera\", \"from\": 560, \"to\": 570}, {\"ngram\": \"tears\", \"from\": 579, \"to\": 584}, {\"ngram\": \"a moment\", \"from\": 619, \"to\": 627}, {\"ngram\": \"The whole\", \"from\": 662, \"to\": 671}, {\"ngram\": \"your silver medal\", \"from\": 747, \"to\": 764}]}, {\"sentence\": \"And you must just feel so proud of yourself.\\\"\", \"from\": 766, \"to\": 811, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"And on what the 30-year-old is most looking forward to upon his return from this year's Games, Tom-who shares kidsRobert \\\"Robbie\\\" Ray, 6, andPhoenix Rose, 16 months, withhusbandDustin Lance Black-had the perfect answer.\", \"from\": 813, \"to\": 1032, \"entities\": [{\"begin\": 962, \"end\": 966, \"title\": \"http://dbpedia.org/resource/Rose_Tyler\", \"score\": 0.9999902683153462, \"rank\": 9.308468873295048e-06, \"text\": \"Rose\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Rose_Tyler\", \"dbpedia\": \"http://dbpedia.org/resource/Rose_Tyler\"}], \"noun_phrases\": [{\"ngram\": \"his return\", \"from\": 873, \"to\": 883}, {\"ngram\": \"this year's Games\", \"from\": 889, \"to\": 906}, {\"ngram\": \"Tom\", \"from\": 908, \"to\": 911}, {\"ngram\": \"kidsRobert \\\"Robbie\\\" Ray\", \"from\": 923, \"to\": 946}, {\"ngram\": \"16 months\", \"from\": 968, \"to\": 977}, {\"ngram\": \"the perfect answer\", \"from\": 1013, \"to\": 1031}]}, {\"sentence\": \"\\\"I want to be with my family,\\\" he explained.\", \"from\": 1034, \"to\": 1078, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my family\", \"from\": 1053, \"to\": 1062}]}, {\"sentence\": \"\\\"I am really excited to be able to spend some time with them and just be able to feel a bit normal for a couple of days.\", \"from\": 1079, \"to\": 1199, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"some time\", \"from\": 1120, \"to\": 1129}, {\"ngram\": \"a couple\", \"from\": 1182, \"to\": 1190}, {\"ngram\": \"days\", \"from\": 1194, \"to\": 1198}]}, {\"sentence\": \"But, yeah, it's just very overwhelming.\", \"from\": 1200, \"to\": 1239, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I did not mean for it to time out exactly like this, but I just feel very proud of my career.\\\"\", \"from\": 1240, \"to\": 1334, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my career\", \"from\": 1323, \"to\": 1332}]}, {\"sentence\": \"As he should: Across his five Olympic Games-the first of which he qualified for at the age of 14-Tom has earned an impressive five medals, including one gold, three bronze, and a newly-earned silver from his time in Paris.\", \"from\": 1336, \"to\": 1558, \"entities\": [{\"begin\": 1552, \"end\": 1557, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999996125553, \"rank\": 3.874489678372332e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"his five Olympic Games\", \"from\": 1357, \"to\": 1379}, {\"ngram\": \"the age\", \"from\": 1419, \"to\": 1426}, {\"ngram\": \"14-Tom\", \"from\": 1430, \"to\": 1436}, {\"ngram\": \"an impressive five medals\", \"from\": 1448, \"to\": 1473}, {\"ngram\": \"one gold\", \"from\": 1485, \"to\": 1493}, {\"ngram\": \"three bronze\", \"from\": 1495, \"to\": 1507}, {\"ngram\": \"a newly-earned silver\", \"from\": 1513, \"to\": 1534}, {\"ngram\": \"his time\", \"from\": 1540, \"to\": 1548}]}, {\"sentence\": \"\\\"It's a lot, but I am really happy with how everything's gone,\\\" Tom added.\", \"from\": 1560, \"to\": 1634, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a lot\", \"from\": 1566, \"to\": 1571}, {\"ngram\": \"everything\", \"from\": 1604, \"to\": 1614}, {\"ngram\": \"Tom\", \"from\": 1624, \"to\": 1627}]}, {\"sentence\": \"\\\"I just think it's always hard when you say goodbye to your sport.\", \"from\": 1635, \"to\": 1701, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"goodbye\", \"from\": 1679, \"to\": 1686}, {\"ngram\": \"your sport\", \"from\": 1690, \"to\": 1700}]}, {\"sentence\": \"Lots of things to process, but I think it's the right time.\", \"from\": 1702, \"to\": 1761, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Lots\", \"from\": 1702, \"to\": 1706}, {\"ngram\": \"things\", \"from\": 1710, \"to\": 1716}, {\"ngram\": \"the right time\", \"from\": 1746, \"to\": 1760}]}, {\"sentence\": \"Like, this year felt like such a bonus.\\\"\", \"from\": 1762, \"to\": 1802, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"such a bonus\", \"from\": 1788, \"to\": 1800}]}, {\"sentence\": \"As he explained, he checked off many bucket list items in Paris.\", \"from\": 1804, \"to\": 1868, \"entities\": [{\"begin\": 1862, \"end\": 1867, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999996125553, \"rank\": 3.874489678372332e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"many bucket list items\", \"from\": 1836, \"to\": 1858}]}, {\"sentence\": \"\\\"I got to compete in front of my family, my kids,\\\" Tom continued, \\\"and Igot to be flagbearer.\\\"\", \"from\": 1869, \"to\": 1963, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"front\", \"from\": 1890, \"to\": 1895}, {\"ngram\": \"my family\", \"from\": 1899, \"to\": 1908}, {\"ngram\": \"Tom\", \"from\": 1920, \"to\": 1923}, {\"ngram\": \"Igot\", \"from\": 1940, \"to\": 1944}, {\"ngram\": \"flagbearer\", \"from\": 1951, \"to\": 1961}]}, {\"sentence\": \"Tom-who noted his tearful demeanor is not like him-also reflected on the legacy he's left for his children and shared a message to the fans who have been supporting him from near and far.\", \"from\": 1965, \"to\": 2152, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Tom\", \"from\": 1965, \"to\": 1968}, {\"ngram\": \"his tearful demeanor\", \"from\": 1979, \"to\": 1999}, {\"ngram\": \"the legacy\", \"from\": 2034, \"to\": 2044}, {\"ngram\": \"his children\", \"from\": 2059, \"to\": 2071}, {\"ngram\": \"a message\", \"from\": 2083, \"to\": 2092}, {\"ngram\": \"the fans\", \"from\": 2096, \"to\": 2104}]}, {\"sentence\": \"\\\"I like to think they are very proud of me,\\\" he said of Robbie and Phoenix, adding of his team back home, \\\"The support that I had from Great Britain has been so incredible.\", \"from\": 2154, \"to\": 2326, \"entities\": [{\"begin\": 2210, \"end\": 2216, \"title\": \"http://dbpedia.org/resource/Robbie_Jackson\", \"score\": 0.9960443357498453, \"rank\": 0.003971371842610508, \"text\": \"Robbie\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Robbie_Jackson\", \"dbpedia\": \"http://dbpedia.org/resource/Robbie_Jackson\"}, {\"begin\": 2289, \"end\": 2302, \"title\": \"http://dbpedia.org/resource/Great_Britain_at_the_Olympics\", \"score\": 0.8991978054689388, \"rank\": 0.11153362881964105, \"text\": \"Great Britain\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Great_Britain_at_the_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Great_Britain_at_the_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"Phoenix\", \"from\": 2221, \"to\": 2228}, {\"ngram\": \"his team\", \"from\": 2240, \"to\": 2248}, {\"ngram\": \"The support\", \"from\": 2261, \"to\": 2272}]}, {\"sentence\": \"Thank you to everyone that's just been there for me throughout the whole of this.\", \"from\": 2327, \"to\": 2408, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"everyone\", \"from\": 2340, \"to\": 2348}, {\"ngram\": \"the whole\", \"from\": 2390, \"to\": 2399}]}, {\"sentence\": \"I guess it's the end of an era, but I can look back on my 23 years and be very proud.\\\"\", \"from\": 2409, \"to\": 2495, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the end\", \"from\": 2422, \"to\": 2429}, {\"ngram\": \"an era\", \"from\": 2433, \"to\": 2439}, {\"ngram\": \"my 23 years\", \"from\": 2464, \"to\": 2475}]}, {\"sentence\": \"In a separateinterview he did withVoguein anticipation for his retirement announcement, which was published in congruence with his public confirmation, Tom shared a sneak peek about what his next chapter might include.\", \"from\": 2497, \"to\": 2715, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a separateinterview\", \"from\": 2500, \"to\": 2519}, {\"ngram\": \"withVoguein anticipation\", \"from\": 2527, \"to\": 2551}, {\"ngram\": \"his retirement announcement\", \"from\": 2556, \"to\": 2583}, {\"ngram\": \"congruence\", \"from\": 2608, \"to\": 2618}, {\"ngram\": \"his public confirmation\", \"from\": 2624, \"to\": 2647}, {\"ngram\": \"Tom\", \"from\": 2649, \"to\": 2652}, {\"ngram\": \"a sneak peek\", \"from\": 2660, \"to\": 2672}, {\"ngram\": \"his next chapter\", \"from\": 2684, \"to\": 2700}]}, {\"sentence\": \"\\\"I have enrolled in a class, a course at the Fashion Institute of Design and Merchandising (FIDM) in Los Angeles, to be able to learn how to sew,\\\" he explained to the outlet.\", \"from\": 2717, \"to\": 2891, \"entities\": [{\"begin\": 2818, \"end\": 2829, \"title\": \"http://dbpedia.org/resource/Los_Angeles\", \"score\": 1.0, \"rank\": 1.901991973356327e-14, \"text\": \"Los Angeles\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Los_Angeles\", \"dbpedia\": \"http://dbpedia.org/resource/Los_Angeles\"}], \"noun_phrases\": [{\"ngram\": \"a class\", \"from\": 2737, \"to\": 2744}, {\"ngram\": \"the Fashion Institute\", \"from\": 2758, \"to\": 2779}, {\"ngram\": \"Design\", \"from\": 2783, \"to\": 2789}, {\"ngram\": \"Merchandising (FIDM\", \"from\": 2794, \"to\": 2813}, {\"ngram\": \"the outlet\", \"from\": 2880, \"to\": 2890}]}, {\"sentence\": \"\\\"I knit and I crochet, but sewing will just add a whole different level of knowledge as to how to construct things.\", \"from\": 2892, \"to\": 3007, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"I crochet\", \"from\": 2904, \"to\": 2913}, {\"ngram\": \"sewing\", \"from\": 2919, \"to\": 2925}, {\"ngram\": \"a whole different level\", \"from\": 2940, \"to\": 2963}, {\"ngram\": \"knowledge\", \"from\": 2967, \"to\": 2976}, {\"ngram\": \"things\", \"from\": 3000, \"to\": 3006}]}, {\"sentence\": \"I have actually designed a couple of pieces of underwear that I am going to be launching, and then I am also hoping to launch a swimwear project next year.\\\"\", \"from\": 3008, \"to\": 3164, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a couple\", \"from\": 3033, \"to\": 3041}, {\"ngram\": \"pieces\", \"from\": 3045, \"to\": 3051}, {\"ngram\": \"underwear\", \"from\": 3055, \"to\": 3064}, {\"ngram\": \"a swimwear project\", \"from\": 3134, \"to\": 3152}]}, {\"sentence\": \"Though he admitted, \\\"I have spent my whole life doing this.\", \"from\": 3166, \"to\": 3225, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my whole life\", \"from\": 3200, \"to\": 3213}]}, {\"sentence\": \"Actually being able to let go of it-it's going to be hard.\", \"from\": 3226, \"to\": 3284, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"And it's going to be a major adjustment to figure out how my days are structured.\\\"\", \"from\": 3285, \"to\": 3367, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a major adjustment\", \"from\": 3306, \"to\": 3324}, {\"ngram\": \"my days\", \"from\": 3343, \"to\": 3350}]}, {\"sentence\": \"Yet stepping away from the sport as Britain's most decorated diver-and as someone who has paved the way for future LGBTQ athletes-he leaves behind quit the legacy.\", \"from\": 3369, \"to\": 3532, \"entities\": [{\"begin\": 3405, \"end\": 3412, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.999854512555965, \"rank\": 0.00014541174050620995, \"text\": \"Britain\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"the sport\", \"from\": 3392, \"to\": 3401}, {\"ngram\": \"someone\", \"from\": 3443, \"to\": 3450}, {\"ngram\": \"the way\", \"from\": 3465, \"to\": 3472}, {\"ngram\": \"future LGBTQ athletes\", \"from\": 3477, \"to\": 3498}, {\"ngram\": \"the legacy\", \"from\": 3521, \"to\": 3531}]}, {\"sentence\": \"\\\"I would love,\\\" he reflected, \\\"for people to remember me for being a person that persevered, who persisted and did not give up on his dream until he was able to achieve it.\\\"\", \"from\": 3534, \"to\": 3707, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"people\", \"from\": 3569, \"to\": 3575}, {\"ngram\": \"a person\", \"from\": 3601, \"to\": 3609}, {\"ngram\": \"his dream\", \"from\": 3664, \"to\": 3673}]}, {\"sentence\": \"Your source for entertainment news, celebrities, celeb news, and \\u200bcelebrity gossip.\", \"from\": 3709, \"to\": 3792, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Your source\", \"from\": 3709, \"to\": 3720}, {\"ngram\": \"entertainment news\", \"from\": 3725, \"to\": 3743}, {\"ngram\": \"celebrities\", \"from\": 3745, \"to\": 3756}, {\"ngram\": \"celeb news\", \"from\": 3758, \"to\": 3768}, {\"ngram\": \"\\u200bcelebrity gossip\", \"from\": 3774, \"to\": 3791}]}, {\"sentence\": \"Check out the hottest fashion, photos, movies and TV shows!\", \"from\": 3793, \"to\": 3852, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the hottest fashion\", \"from\": 3803, \"to\": 3822}, {\"ngram\": \"photos\", \"from\": 3824, \"to\": 3830}, {\"ngram\": \"movies\", \"from\": 3832, \"to\": 3838}, {\"ngram\": \"TV shows\", \"from\": 3843, \"to\": 3851}]}, {\"sentence\": \"\\u00a92025E!\", \"from\": 3854, \"to\": 3861, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"\\u0