"{\"uid\": \"eonline.com-news-1405382-paris-olympics-why-fries-and-avocados-are-banned-in-the-olympic-village\", \"noun_phrases\": [{\"sentence\": \"Organizers for the 2024 Olympics in Paris are focusing on sustainability this year, so some foods are off-limits at the Olympic Village.\", \"from\": 0, \"to\": 136, \"entities\": [{\"begin\": 36, \"end\": 41, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.1597006792611649e-18, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Organizers\", \"from\": 0, \"to\": 10}, {\"ngram\": \"the 2024 Olympics\", \"from\": 15, \"to\": 32}, {\"ngram\": \"sustainability\", \"from\": 58, \"to\": 72}, {\"ngram\": \"some foods\", \"from\": 87, \"to\": 97}, {\"ngram\": \"off-limits\", \"from\": 102, \"to\": 112}, {\"ngram\": \"the Olympic Village\", \"from\": 116, \"to\": 135}]}, {\"sentence\": \"Athletes will have to say au revoir to a few foods during their visit to France.\", \"from\": 138, \"to\": 218, \"entities\": [{\"begin\": 211, \"end\": 217, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9999999962046786, \"rank\": 3.3289149661567926e-09, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"Athletes\", \"from\": 138, \"to\": 146}, {\"ngram\": \"au revoir\", \"from\": 164, \"to\": 173}, {\"ngram\": \"a few foods\", \"from\": 177, \"to\": 188}, {\"ngram\": \"their visit\", \"from\": 196, \"to\": 207}]}, {\"sentence\": \"With the2024 Olympicsin full swing, competitors staying inthe Olympic Villagewon't be finding some specific foods, including french fries and avocados.\", \"from\": 220, \"to\": 371, \"entities\": [{\"begin\": 345, \"end\": 357, \"title\": \"http://dbpedia.org/resource/French_fries\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"french fries\", \"types\": [\"Q2095\"], \"wikid\": \"http://dbpedia.org/resource/French_fries\", \"dbpedia\": \"http://dbpedia.org/resource/French_fries\"}], \"noun_phrases\": [{\"ngram\": \"the2024 Olympicsin full swing\", \"from\": 225, \"to\": 254}, {\"ngram\": \"competitors\", \"from\": 256, \"to\": 267}, {\"ngram\": \"inthe Olympic\", \"from\": 276, \"to\": 289}, {\"ngram\": \"some specific foods\", \"from\": 314, \"to\": 333}, {\"ngram\": \"avocados\", \"from\": 362, \"to\": 370}]}, {\"sentence\": \"But the ban is not just a random policy to deprive competitors of guacamol\\u00e9 or their side of fries.\", \"from\": 372, \"to\": 471, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the ban\", \"from\": 376, \"to\": 383}, {\"ngram\": \"just a random policy\", \"from\": 391, \"to\": 411}, {\"ngram\": \"deprive competitors\", \"from\": 415, \"to\": 434}, {\"ngram\": \"guacamol\\u00e9\", \"from\": 438, \"to\": 447}, {\"ngram\": \"their side\", \"from\": 451, \"to\": 461}, {\"ngram\": \"fries\", \"from\": 465, \"to\": 470}]}, {\"sentence\": \"\\\"French fries are too risky because of fire-hazard concerns over deep-fat fryers,\\\"Charles Guilloy, one of the village's chefs in charge, toldThe New York Timesin March.\", \"from\": 473, \"to\": 641, \"entities\": [{\"begin\": 474, \"end\": 486, \"title\": \"http://dbpedia.org/resource/French_fries\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"French fries\", \"types\": [\"Q2095\"], \"wikid\": \"http://dbpedia.org/resource/French_fries\", \"dbpedia\": \"http://dbpedia.org/resource/French_fries\"}], \"noun_phrases\": [{\"ngram\": \"fire-hazard concerns\", \"from\": 512, \"to\": 532}, {\"ngram\": \"deep-fat fryers,\\\"Charles\", \"from\": 538, \"to\": 562}, {\"ngram\": \"the village's chefs\", \"from\": 579, \"to\": 598}, {\"ngram\": \"charge\", \"from\": 602, \"to\": 608}]}, {\"sentence\": \"\\\"No to foie gras because animal well-being is on everyone's mind, and no to avocados because they are imported from a great distance and consume a lot of water.\\\"\", \"from\": 642, \"to\": 803, \"entities\": [{\"begin\": 649, \"end\": 658, \"title\": \"http://dbpedia.org/resource/Foie_gras\", \"score\": 1.0, \"rank\": 1.444218307445223e-45, \"text\": \"foie gras\", \"types\": [\"Q2095\"], \"wikid\": \"http://dbpedia.org/resource/Foie_gras\", \"dbpedia\": \"http://dbpedia.org/resource/Foie_gras\"}], \"noun_phrases\": [{\"ngram\": \"animal well-being\", \"from\": 667, \"to\": 684}, {\"ngram\": \"everyone's mind\", \"from\": 691, \"to\": 706}, {\"ngram\": \"a great distance\", \"from\": 758, \"to\": 774}, {\"ngram\": \"a lot\", \"from\": 787, \"to\": 792}, {\"ngram\": \"water\", \"from\": 796, \"to\": 801}]}, {\"sentence\": \"For Charles and fellow chefSt\\u00e9phane Chicheri, the Olympic Games' carbon footprint played a major role in the menu.\", \"from\": 805, \"to\": 919, \"entities\": [{\"begin\": 809, \"end\": 816, \"title\": \"http://dbpedia.org/resource/Charles_II_of_England\", \"score\": 0.9949448894353041, \"rank\": 0.00502505523670255, \"text\": \"Charles\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Charles_II_of_England\", \"dbpedia\": \"http://dbpedia.org/resource/Charles_II_of_England\"}], \"noun_phrases\": [{\"ngram\": \"fellow chefSt\\u00e9phane Chicheri\", \"from\": 821, \"to\": 849}, {\"ngram\": \"the Olympic Games' carbon footprint\", \"from\": 851, \"to\": 886}, {\"ngram\": \"a major role\", \"from\": 894, \"to\": 906}, {\"ngram\": \"the menu\", \"from\": 910, \"to\": 918}]}, {\"sentence\": \"But it does not mean the athletes will not have endless options to choose from.\", \"from\": 920, \"to\": 999, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the athletes\", \"from\": 941, \"to\": 953}, {\"ngram\": \"endless options\", \"from\": 968, \"to\": 983}]}, {\"sentence\": \"In fact, the dining hall in Saint-Denis, just north of Paris, will serve about 500 different dishes, according to the outlet.\", \"from\": 1001, \"to\": 1126, \"entities\": [{\"begin\": 1029, \"end\": 1040, \"title\": \"http://dbpedia.org/resource/Stade_de_France\", \"score\": 0.9935137943246931, \"rank\": 0.006528549746791745, \"text\": \"Saint-Denis\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Stade_de_France\", \"dbpedia\": \"http://dbpedia.org/resource/Stade_de_France\"}, {\"begin\": 1056, \"end\": 1061, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.1597006792611649e-18, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"fact\", \"from\": 1004, \"to\": 1008}, {\"ngram\": \"the dining hall\", \"from\": 1010, \"to\": 1025}, {\"ngram\": \"about 500 different dishes\", \"from\": 1074, \"to\": 1100}, {\"ngram\": \"the outlet\", \"from\": 1115, \"to\": 1125}]}, {\"sentence\": \"Not to mention, six quick-meal establishments specializing in Asian, Middle Eastern and Afro-Caribbean cuisine will also be ready to go.\", \"from\": 1127, \"to\": 1263, \"entities\": [{\"begin\": 1189, \"end\": 1194, \"title\": \"http://dbpedia.org/resource/Asian_cuisine\", \"score\": 0.9999999822885003, \"rank\": 1.3033069795741743e-08, \"text\": \"Asian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Asian_cuisine\", \"dbpedia\": \"http://dbpedia.org/resource/Asian_cuisine\"}, {\"begin\": 1196, \"end\": 1210, \"title\": \"http://dbpedia.org/resource/Middle_East\", \"score\": 0.9997040420150692, \"rank\": 0.0002959939990309061, \"text\": \"Middle Eastern\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Middle_East\", \"dbpedia\": \"http://dbpedia.org/resource/Middle_East\"}, {\"begin\": 1215, \"end\": 1229, \"title\": \"http://dbpedia.org/resource/Black_people\", \"score\": 0.6093065306120827, \"rank\": 0.6399589161690913, \"text\": \"Afro-Caribbean\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Black_people\", \"dbpedia\": \"http://dbpedia.org/resource/Black_people\"}], \"noun_phrases\": [{\"ngram\": \"six quick-meal establishments\", \"from\": 1143, \"to\": 1172}]}, {\"sentence\": \"\\\"At the Village, catering has an important role,\\\" Operations Director of catering company Soxedo Live!,Laurent Pasteurexplainedin a statement, \\\"to contribute modestly to the performance of the athletes with menus that have been adapted to suit elite sport but also satisfy the expectations of athletes from every continent, with more than 200 nationalities, so that everyone feels at home.\\\"\", \"from\": 1265, \"to\": 1655, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the Village\", \"from\": 1269, \"to\": 1280}, {\"ngram\": \"catering\", \"from\": 1282, \"to\": 1290}, {\"ngram\": \"an important role\", \"from\": 1295, \"to\": 1312}, {\"ngram\": \"catering company\", \"from\": 1338, \"to\": 1354}, {\"ngram\": \"Soxedo Live!,Laurent Pasteurexplainedin\", \"from\": 1355, \"to\": 1394}, {\"ngram\": \"a statement\", \"from\": 1395, \"to\": 1406}, {\"ngram\": \"the performance\", \"from\": 1435, \"to\": 1450}, {\"ngram\": \"the athletes\", \"from\": 1454, \"to\": 1466}, {\"ngram\": \"menus\", \"from\": 1472, \"to\": 1477}, {\"ngram\": \"elite sport\", \"from\": 1509, \"to\": 1520}, {\"ngram\": \"the expectations\", \"from\": 1538, \"to\": 1554}, {\"ngram\": \"athletes\", \"from\": 1558, \"to\": 1566}, {\"ngram\": \"every continent\", \"from\": 1572, \"to\": 1587}, {\"ngram\": \"more than 200 nationalities\", \"from\": 1594, \"to\": 1621}, {\"ngram\": \"everyone\", \"from\": 1631, \"to\": 1639}, {\"ngram\": \"home\", \"from\": 1649, \"to\": 1653}]}, {\"sentence\": \"The menu items, or lack thereof, are part of Paris' conscious effort to lower carbon emissions during the event.\", \"from\": 1657, \"to\": 1769, \"entities\": [{\"begin\": 1702, \"end\": 1707, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.1597006792611649e-18, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"The menu items\", \"from\": 1657, \"to\": 1671}, {\"ngram\": \"lack\", \"from\": 1676, \"to\": 1680}, {\"ngram\": \"part\", \"from\": 1694, \"to\": 1698}, {\"ngram\": \"carbon emissions\", \"from\": 1735, \"to\": 1751}, {\"ngram\": \"the event\", \"from\": 1759, \"to\": 1768}]}, {\"sentence\": \"Allathletes in the village are sleepingoneasily recyclable cardboard beds, and the organizerschose not to install air conditioning at the complex.\", \"from\": 1770, \"to\": 1916, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Allathletes\", \"from\": 1770, \"to\": 1781}, {\"ngram\": \"the village\", \"from\": 1785, \"to\": 1796}, {\"ngram\": \"sleepingoneasily recyclable cardboard beds\", \"from\": 1801, \"to\": 1843}, {\"ngram\": \"the organizerschose\", \"from\": 1849, \"to\": 1868}, {\"ngram\": \"air conditioning\", \"from\": 1884, \"to\": 1900}, {\"ngram\": \"the complex\", \"from\": 1904, \"to\": 1915}]}, {\"sentence\": \"Instead, it's cooled by water pipes that run under the floorboards.\", \"from\": 1917, \"to\": 1984, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"water pipes\", \"from\": 1941, \"to\": 1952}, {\"ngram\": \"the floorboards\", \"from\": 1968, \"to\": 1983}]}, {\"sentence\": \"But the reaction from athletes visiting has not been all that chill.\", \"from\": 1986, \"to\": 2054, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the reaction\", \"from\": 1990, \"to\": 2002}, {\"ngram\": \"athletes\", \"from\": 2008, \"to\": 2016}, {\"ngram\": \"all that chill\", \"from\": 2039, \"to\": 2053}]}, {\"sentence\": \"Along with other countries, including Great Britain and Australia, Team USA will also be hauling in their own AC units, according to theWashington Post.\", \"from\": 2055, \"to\": 2207, \"entities\": [{\"begin\": 2093, \"end\": 2106, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9960579156649103, \"rank\": 0.002453538725267279, \"text\": \"Great Britain\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}, {\"begin\": 2111, \"end\": 2120, \"title\": \"http://dbpedia.org/resource/Australia\", \"score\": 0.999999999990905, \"rank\": 9.348384444439899e-12, \"text\": \"Australia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Australia\", \"dbpedia\": \"http://dbpedia.org/resource/Australia\"}, {\"begin\": 2122, \"end\": 2130, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999999992824087, \"rank\": 7.066249024934321e-10, \"text\": \"Team USA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 2165, \"end\": 2167, \"title\": \"http://dbpedia.org/resource/Alternating_current\", \"score\": 0.9999695525054098, \"rank\": 2.5932197929838774e-05, \"text\": \"AC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Alternating_current\", \"dbpedia\": \"http://dbpedia.org/resource/Alternating_current\"}], \"noun_phrases\": [{\"ngram\": \"other countries\", \"from\": 2066, \"to\": 2081}, {\"ngram\": \"theWashington Post\", \"from\": 2188, \"to\": 2206}]}, {\"sentence\": \"\\\"As you can imagine, this is a period of time in which consistency and predictability is critical for Team USA's performance,\\\" CEO of the U.S. Olympic & Paralympic CommitteeSarah Hylandsaid ina briefing last month.\", \"from\": 2209, \"to\": 2423, \"entities\": [{\"begin\": 2311, \"end\": 2319, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999999992824087, \"rank\": 7.066249024934321e-10, \"text\": \"Team USA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ng