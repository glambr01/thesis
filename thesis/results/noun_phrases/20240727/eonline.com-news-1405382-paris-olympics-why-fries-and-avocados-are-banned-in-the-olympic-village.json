\"entities\": [{\"begin\": 3016, \"end\": 3025, \"title\": \"http://dbpedia.org/resource/Foie_gras\", \"score\": 1.0, \"rank\": 1.444218307445223e-45, \"text\": \"foie gras\", \"types\": [\"Q2095\"], \"wikid\": \"http://dbpedia.org/resource/Foie_gras\", \"dbpedia\": \"http://dbpedia.org/resource/Foie_gras\"}], \"noun_phrases\": [{\"ngram\": \"Au Revoir Avocados Athletes\", \"from\": 2962, \"to\": 2989}, {\"ngram\": \"their day\", \"from\": 3034, \"to\": 3043}, {\"ngram\": \"some avocado toast\", \"from\": 3049, \"to\": 3067}, {\"ngram\": \"the village\", \"from\": 3071, \"to\": 3082}]}, {\"sentence\": \"\\\"No to foie gras because animal well-being is on everyone's mind,\\\" Guilloy continued, \\\"and no to avocados because they are imported from a great distance and consume a lot of water.\\\"\", \"from\": 3091, \"to\": 3273, \"entities\": [{\"begin\": 3098, \"end\": 3107, \"title\": \"http://dbpedia.org/resource/Foie_gras\", \"score\": 1.0, \"rank\": 1.444218307445223e-45, \"text\": \"foie gras\", \"types\": [\"Q2095\"], \"wikid\": \"http://dbpedia.org/resource/Foie_gras\", \"dbpedia\": \"http://dbpedia.org/resource/Foie_gras\"}], \"noun_phrases\": [{\"ngram\": \"animal well-being\", \"from\": 3116, \"to\": 3133}, {\"ngram\": \"everyone's mind\", \"from\": 3140, \"to\": 3155}, {\"ngram\": \"Guilloy\", \"from\": 3158, \"to\": 3165}, {\"ngram\": \"a great distance\", \"from\": 3228, \"to\": 3244}, {\"ngram\": \"a lot\", \"from\": 3257, \"to\": 3262}, {\"ngram\": \"water\", \"from\": 3266, \"to\": 3271}]}, {\"sentence\": \"Champagne Problems While some Olympians may want to toast to their success with a glass of bubbly, they will not be able to at the Olympic Village.\", \"from\": 3275, \"to\": 3423, \"entities\": [{\"begin\": 3275, \"end\": 3293, \"title\": \"http://dbpedia.org/resource/Champagne_Problems_(Taylor_Swift_song)\", \"score\": 0.8122743681281602, \"rank\": 0.23111111111108376, \"text\": \"Champagne Problems\", \"types\": [\"Q386724\", \"Q2188189\"], \"wikid\": \"http://dbpedia.org/resource/Champagne_Problems_(Taylor_Swift_song)\", \"dbpedia\": \"http://dbpedia.org/resource/Champagne_Problems_(Taylor_Swift_song)\"}], \"noun_phrases\": [{\"ngram\": \"some Olympians\", \"from\": 3300, \"to\": 3314}, {\"ngram\": \"their success\", \"from\": 3336, \"to\": 3349}, {\"ngram\": \"a glass\", \"from\": 3355, \"to\": 3362}, {\"ngram\": \"bubbly\", \"from\": 3366, \"to\": 3372}, {\"ngram\": \"the Olympic Village\", \"from\": 3402, \"to\": 3421}]}, {\"sentence\": \"\\\"No champagne in the village, of course,\\\" Director of the Olympic and Paralympic VillagesLaurent MichaudtoldSky Newsin March, \\\"but they can have all the champagne they want also in Paris.\", \"from\": 3423, \"to\": 3610, \"entities\": [{\"begin\": 3604, \"end\": 3609, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.1597006792611649e-18, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"\\\"No champagne\", \"from\": 3423, \"to\": 3436}, {\"ngram\": \"the village\", \"from\": 3440, \"to\": 3451}, {\"ngram\": \"course\", \"from\": 3456, \"to\": 3462}, {\"ngram\": \"the Olympic\", \"from\": 3477, \"to\": 3488}, {\"ngram\": \"Paralympic\", \"from\": 3493, \"to\": 3503}, {\"ngram\": \"all the champagne\", \"from\": 3568, \"to\": 3585}]}, {\"sentence\": \"\\\"And even though there is a sports bar in the village, it will not be serving any alcohol.\", \"from\": 3610, \"to\": 3700, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a sports bar\", \"from\": 3636, \"to\": 3648}, {\"ngram\": \"the village\", \"from\": 3652, \"to\": 3663}, {\"ngram\": \"any alcohol\", \"from\": 3688, \"to\": 3699}]}, {\"sentence\": \"\\\"We wanted to create some places where the athletes will feel very enthusiastic and comfortable, so they can have some conversations, discussions and to share their core values about sports,\\\" Michaud shared with the outlet.\", \"from\": 3700, \"to\": 3923, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"some places\", \"from\": 3721, \"to\": 3732}, {\"ngram\": \"the athletes\", \"from\": 3739, \"to\": 3751}, {\"ngram\": \"some conversations\", \"from\": 3814, \"to\": 3832}, {\"ngram\": \"discussions\", \"from\": 3834, \"to\": 3845}, {\"ngram\": \"their core values\", \"from\": 3859, \"to\": 3876}, {\"ngram\": \"sports\", \"from\": 3883, \"to\": 3889}, {\"ngram\": \"Michaud\", \"from\": 3892, \"to\": 3899}, {\"ngram\": \"the outlet\", \"from\": 3912, \"to\": 3922}]}, {\"sentence\": \"\\\"So we have made a village club, also, with a lounge, with a sports bar, with Coca-Cola-I mean, no alcohol, of course, over there.\", \"from\": 3924, \"to\": 4054, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a village club\", \"from\": 3941, \"to\": 3955}, {\"ngram\": \"a lounge\", \"from\": 3968, \"to\": 3976}, {\"ngram\": \"a sports bar\", \"from\": 3983, \"to\": 3995}, {\"ngram\": \"no alcohol\", \"from\": 4020, \"to\": 4030}, {\"ngram\": \"course\", \"from\": 4035, \"to\": 4041}]}, {\"sentence\": \"But it's going to be a great place so they can actually share their moment and the environment here.\\\"\", \"from\": 4055, \"to\": 4156, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a great place\", \"from\": 4076, \"to\": 4089}, {\"ngram\": \"their moment\", \"from\": 4117, \"to\": 4129}, {\"ngram\": \"the environment\", \"from\": 4134, \"to\": 4149}]}, {\"sentence\": \"Freezing Out the A.C. Talking about a lack of air conditioning during the Summer Games is one way athletes can break the ice.Olympic organizers have opted to forgo a.c. in the Olympians' rooms and instead rely on another way to stay cool.\", \"from\": 4158, \"to\": 4397, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the A.C.\", \"from\": 4171, \"to\": 4179}, {\"ngram\": \"a lack\", \"from\": 4194, \"to\": 4200}, {\"ngram\": \"air conditioning\", \"from\": 4204, \"to\": 4220}, {\"ngram\": \"the Summer Games\", \"from\": 4228, \"to\": 4244}, {\"ngram\": \"one way\", \"from\": 4248, \"to\": 4255}, {\"ngram\": \"athletes\", \"from\": 4256, \"to\": 4264}, {\"ngram\": \"the ice\", \"from\": 4275, \"to\": 4282}, {\"ngram\": \"Olympic organizers\", \"from\": 4283, \"to\": 4301}, {\"ngram\": \"a.c\", \"from\": 4322, \"to\": 4325}, {\"ngram\": \"the Olympians' rooms\", \"from\": 4330, \"to\": 4350}, {\"ngram\": \"another way\", \"from\": 4371, \"to\": 4382}]}, {\"sentence\": \"\\\"We designed these buildings so that they would be comfortable places to live in in the summer, in 2024 and later on,\\\"Yann Krysinski, SVP of SOLIDEO (the entity in charge of the major infrastructures for the Olympics), toldReutersin February, \\\"and we do not need air conditioning in these buildings because we oriented the facades so that they would not get too much sun during the summer, and the facades, the insulation is really efficient.\", \"from\": 4397, \"to\": 4839, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"these buildings\", \"from\": 4410, \"to\": 4425}, {\"ngram\": \"comfortable places\", \"from\": 4448, \"to\": 4466}, {\"ngram\": \"the summer\", \"from\": 4481, \"to\": 4491}, {\"ngram\": \"later on,\\\"Yann Krysinski\", \"from\": 4505, \"to\": 4529}, {\"ngram\": \"SVP\", \"from\": 4531, \"to\": 4534}, {\"ngram\": \"SOLIDEO\", \"from\": 4538, \"to\": 4545}, {\"ngram\": \"the entity\", \"from\": 4547, \"to\": 4557}, {\"ngram\": \"charge\", \"from\": 4561, \"to\": 4567}, {\"ngram\": \"the major infrastructures\", \"from\": 4571, \"to\": 4596}, {\"ngram\": \"the Olympics\", \"from\": 4601, \"to\": 4613}, {\"ngram\": \"air conditioning\", \"from\": 4660, \"to\": 4676}, {\"ngram\": \"these buildings\", \"from\": 4680, \"to\": 4695}, {\"ngram\": \"the facades\", \"from\": 4716, \"to\": 4727}, {\"ngram\": \"too much sun\", \"from\": 4755, \"to\": 4767}, {\"ngram\": \"the summer\", \"from\": 4775, \"to\": 4785}, {\"ngram\": \"the insulation\", \"from\": 4804, \"to\": 4818}]}, {\"sentence\": \"\\\"He added, \\\"We also are providing naturally cool water that we are getting from underground to cool the air of these apartments.\", \"from\": 4839, \"to\": 4967, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"naturally cool water\", \"from\": 4873, \"to\": 4893}, {\"ngram\": \"the air\", \"from\": 4939, \"to\": 4946}, {\"ngram\": \"these apartments\", \"from\": 4950, \"to\": 4966}]}, {\"sentence\": \"So you will not need air conditioning in the summer here.\", \"from\": 4968, \"to\": 5025, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"air conditioning\", \"from\": 4989, \"to\": 5005}, {\"ngram\": \"the summer\", \"from\": 5009, \"to\": 5019}]}, {\"sentence\": \"\\\"Still, not all competitors were chill with this decision, and the United States Olympic Committee's CEOSarah HirshlandpreviouslyconfirmedTeam USA will have air conditioning in their rooms.\", \"from\": 5025, \"to\": 5214, \"entities\": [{\"begin\": 5092, \"end\": 5123, \"title\": \"http://dbpedia.org/resource/United_States_Olympic_&_Paralympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"United States Olympic Committee\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_Olympic_&_Paralympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_Olympic_&_Paralympic_Committee\"}, {\"begin\": 5168, \"end\": 5171, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 1.0, \"rank\": 6.175019904905812e-14, \"text\": \"USA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"not all competitors\", \"from\": 5033, \"to\": 5052}, {\"ngram\": \"this decision\", \"from\": 5069, \"to\": 5082}, {\"ngram\": \"air conditioning\", \"from\": 5182, \"to\": 5198}, {\"ngram\": \"their rooms\", \"from\": 5202, \"to\": 5213}]}, {\"sentence\": \"According toThe Washington Post, Britain, Canada, and