ation\", \"from\": 1937, \"to\": 1951}, {\"ngram\": \"the team\", \"from\": 2015, \"to\": 2023}, {\"ngram\": \"third position\", \"from\": 2033, \"to\": 2047}, {\"ngram\": \"a good chance\", \"from\": 2084, \"to\": 2097}, {\"ngram\": \"their first team medal\", \"from\": 2109, \"to\": 2131}, {\"ngram\": \"bronze\", \"from\": 2138, \"to\": 2144}]}, {\"sentence\": \"Fraser, the former world parallel bars final whose all-around score of 84.666 was only eclipsed by team-mate Jarman in the first rotation, paid tribute to his team's ability to deliver under pressure.\", \"from\": 2162, \"to\": 2362, \"entities\": [{\"begin\": 2162, \"end\": 2168, \"title\": \"http://dbpedia.org/resource/Malcolm_Fraser\", \"score\": 0.9714431788986756, \"rank\": 0.026515080433522874, \"text\": \"Fraser\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Malcolm_Fraser\", \"dbpedia\": \"http://dbpedia.org/resource/Malcolm_Fraser\"}], \"noun_phrases\": [{\"ngram\": \"the former world parallel bars\", \"from\": 2170, \"to\": 2200}, {\"ngram\": \"whose all-around score\", \"from\": 2207, \"to\": 2229}, {\"ngram\": \"team-mate Jarman\", \"from\": 2261, \"to\": 2277}, {\"ngram\": \"the first rotation\", \"from\": 2281, \"to\": 2299}, {\"ngram\": \"tribute\", \"from\": 2306, \"to\": 2313}, {\"ngram\": \"his team's ability\", \"from\": 2317, \"to\": 2335}, {\"ngram\": \"pressure\", \"from\": 2353, \"to\": 2361}]}, {\"sentence\": \"\\\"Me and the team really just gave it our all out there,\\\" said Fraser.\", \"from\": 2364, \"to\": 2433, \"entities\": [{\"begin\": 2426, \"end\": 2432, \"title\": \"http://dbpedia.org/resource/Malcolm_Fraser\", \"score\": 0.9714431788986756, \"rank\": 0.026515080433522874, \"text\": \"Fraser\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Malcolm_Fraser\", \"dbpedia\": \"http://dbpedia.org/resource/Malcolm_Fraser\"}], \"noun_phrases\": [{\"ngra