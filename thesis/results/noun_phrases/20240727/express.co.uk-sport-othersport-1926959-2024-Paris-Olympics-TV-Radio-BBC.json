ies\": [{\"begin\": 1956, \"end\": 1966, \"title\": \"http://dbpedia.org/resource/BBC_Sounds\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"BBC Sounds\", \"types\": [\"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/BBC_Sounds\", \"dbpedia\": \"http://dbpedia.org/resource/BBC_Sounds\"}], \"noun_phrases\": [{\"ngram\": \"A daily podcast\", \"from\": 1914, \"to\": 1929}]}, {\"sentence\": \"And even if you are bound to an office for the majority of the Games, you can still follow the action - just so long as you are discreet with the angle of your computer screen.\", \"from\": 1969, \"to\": 2145, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an office\", \"from\": 1998, \"to\": 2007}, {\"ngram\": \"the majority\", \"from\": 2012, \"to\": 2024}, {\"ngram\": \"the Games\", \"from\": 2028, \"to\": 2037}, {\"ngram\": \"the action\", \"from\": 2060, \"to\": 2070}, {\"ngram\": \"the angle\", \"from\": 2111, \"to\": 2120}, {\"ngram\": \"your computer screen\", \"from\": 2124, \"to\": 2144}]}, {\"sentence\": \"In a word, no.\", \"from\": 2147, \"to\": 2161, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a word\", \"from\": 2150, \"to\": 2156}]}, {\"sentence\": \"But if you want blanket coverage and the option to watch any sport you want, you will have to sign up for Discovery+.\", \"from\": 2162, \"to\": 2279, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"blanket coverage\", \"from\": 2178, \"to\": 2194}, {\"ngram\": \"the option\", \"from\": 2199, \"to\": 2209}, {\"ngram\": \"any sport\", \"from\": 2219, \"to\": 2228}, {\"ngram\": \"Discovery+\", \"from\": 2268, \"to\": 2278}]}, {\"sentence\": \"The station will show 3,800 hours of live coverage via a network of 55+ live channel feeds, and is currently giving fans the chance to sign up for \\u00a33.99 a month as part of a special Olympics offer.\", \"from\": 2280, \"to\": 2477, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The station\", \"from\": 2280, \"to\": 2291}, {\"ngram\": \"3,800 hours\", \"from\": 2302, \"to\": 2313}, {\"ngram\": \"live coverage\", \"from\": 2317, \"to\": 2330}, {\"ngram\": \"a network\", \"from\": 2335, \"to\": 2344}, {\"ngram\": \"55+ live channel feeds\", \"from\": 2348, \"to\": 2370}, {\"ngram\": \"fans\", \"from\": 2396, \"to\": 2400}, {\"ngram\": \"the chance\", \"from\": 2401, \"to\": 2411}, {\"ngram\": \"part\", \"from\": 2444, \"to\": 2448}, {\"ngram\": \"a special Olympics offer\", \"from\": 2452, \"to\": 2476}]}, {\"sentence\": \"We use your sign-up to provide content in ways you have consented to and to improve our understanding of you.\", \"from\": 2479, \"to\": 2588, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"your sign-up\", \"from\": 2486, \"to\": 2498}, {\"ngram\": \"content\", \"from\": 2510, \"to\": 2517}, {\"ngram\": \"ways\", \"from\": 2521, \"to\": 2525}, {\"ngram\": \"our understanding\", \"from\": 2563, \"to\": 2580}]}, {\"sentence\": \"This may include adverts from us and 3rd parties based on our understanding.\", \"from\": 2589, \"to\": 2665, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"adverts\", \"from\": 2606, \"to\": 2613}, {\"ngram\": \"us\", \"from\": 2619, \"to\": 2621}, {\"ngram\": \"3rd parties\", \"from\": 2626, \"to\": 2637}, {\"ngram\": \"our understanding\", \"from\": 2647, \"to\": 2664}]}, {\"sentence\": \"You can unsubscribe at any time.\", \"from\": 2666, \"to\": 2698, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"any time\", \"from\": 2689, \"to\": 2697}]}, {\"sentence\": \"Read ourPrivacy Policy Sky TV customers, though, can follow on Eurosport 1 and 2 and can activate a Discovery+ Standard Plan at no extra cost.\", \"from\": 2699, \"to\": 2842, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"ourPrivacy Policy Sky TV customers\", \"from\": 2704, \"to\": 2738}, {\"ngram\": \"Eurosport\", \"from\": 2762, \"to\": 2771}, {\"ngram\": \"a Discovery+ Standard Plan\", \"from\": 2797, \"to\": 2823}, {\"ngram\": \"no extra cost\", \"from\": 2827, \"to\": 2840}]}, {\"sentenc