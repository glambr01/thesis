"{\"uid\": \"express.co.uk-sport-othersport-1928654-Adam-Peaty-Paris-Olympic-Michael-Phelps\", \"noun_phrases\": [{\"sentence\": \"There have been many versions of Adam Peaty during a decade lived in a very public gaze.\", \"from\": 0, \"to\": 90, \"entities\": [{\"begin\": 35, \"end\": 45, \"title\": \"http://dbpedia.org/resource/Adam_Peaty\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Adam Peaty\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Adam_Peaty\", \"dbpedia\": \"http://dbpedia.org/resource/Adam_Peaty\"}], \"noun_phrases\": [{\"ngram\": \"many versions\", \"from\": 16, \"to\": 29}, {\"ngram\": \"a decade\", \"from\": 51, \"to\": 59}, {\"ngram\": \"a very public gaze\", \"from\": 69, \"to\": 87}]}, {\"sentence\": \"Whether this is Peaty 3.0 or 4.0 is up for debate, but there is no doubt he's a very different man from 2021.\", \"from\": 92, \"to\": 201, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Peaty\", \"from\": 108, \"to\": 113}, {\"ngram\": \"debate\", \"from\": 135, \"to\": 141}, {\"ngram\": \"no doubt\", \"from\": 156, \"to\": 164}, {\"ngram\": \"a very different man\", \"from\": 170, \"to\": 190}]}, {\"sentence\": \"The big question \\u2026 is he a very different swimmer?\", \"from\": 202, \"to\": 252, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The big question\", \"from\": 202, \"to\": 218}, {\"ngram\": \"a very different swimmer\", \"from\": 227, \"to\": 251}]}, {\"sentence\": \"In the days before Tokyo, where he defended his 100m breaststroke title, Peaty was wound up like a prize fighter.\", \"from\": 254, \"to\": 367, \"entities\": [{\"begin\": 273, \"end\": 278, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.9999493853842374, \"rank\": 5.036389233498626e-05, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resourc