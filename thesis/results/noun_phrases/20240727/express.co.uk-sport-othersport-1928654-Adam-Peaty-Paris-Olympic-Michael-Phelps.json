668, \"to\": 1779, \"entities\": [{\"begin\": 1715, \"end\": 1720, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.9999493853842374, \"rank\": 5.036389233498626e-05, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}, {\"begin\": 1775, \"end\": 1778, \"title\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"score\": 0.9874319990578583, \"rank\": 0.012727965984294489, \"text\": \"Rio\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2016_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"even what\", \"from\": 1743, \"to\": 1752}]}, {\"sentence\": \"I know I have nothing to prove here.\\\"\", \"from\": 1780, \"to\": 1817, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"nothing\", \"from\": 1794, \"to\": 1801}]}, {\"sentence\": \"Peaty is one of over 1,000 elite athletes on UK Sport's National Lottery-funded World Class Programme, allowing them to train full time, have access to the world's best coaches and benefit from pioneering medical support - which has been vital on their pathway to the Paris 2024 Games.\", \"from\": 1819, \"to\": 2104, \"entities\": [{\"begin\": 1864, \"end\": 1872, \"title\": \"http://dbpedia.org/resource/UK_Sport\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"UK Sport\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/UK_Sport\", \"dbpedia\": \"http://dbpedia.org/resource/UK_Sport\"}, {\"begin\": 1864, \"end\": 1872, \"title\": \"http://dbpedia.org/resource/UK_Sport\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"UK Sport\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/UK_Sport\", \"dbpedia\": \"http://dbpedia.org/resource/UK_Sport\"}], \"noun_phrases\": [{\"ngram\": \"Peaty\", \