 feeling\", \"from\": 1499, \"to\": 1510}]}, {\"sentence\": \"For instance, when Italian sprinter Marcell Jacobs stunned the world by winning gold in the men's 100 metres in Tokyo, Italian commentators screamed their reactions, showing the genuine moment of \\\"experts sitting side-by-side, really living out that story,\\\" Young said.\", \"from\": 1523, \"to\": 1792, \"entities\": [{\"begin\": 1542, \"end\": 1549, \"title\": \"http://dbpedia.org/resource/Italian_language\", \"score\": 0.9947029307004431, \"rank\": 0.005051252048213331, \"text\": \"Italian\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Italian_language\", \"dbpedia\": \"http://dbpedia.org/resource/Italian_language\"}, {\"begin\": 1559, \"end\": 1573, \"title\": \"http://dbpedia.org/resource/Marcell_Jacobs\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Marcell Jacobs\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Marcell_Jacobs\", \"dbpedia\": \"http://dbpedia.org/resource/Marcell_Jacobs\"}, {\"begin\": 1635, \"end\": 1640, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.999995008549101, \"rank\": 4.988739214328246e-06, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}, {\"begin\": 1642, \"end\": 1649, \"title\": \"http://dbpedia.org/resource/Italian_language\", \"score\": 0.9947029307004431, \"rank\": 0.005051252048213331, \"text\": \"Italian\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Italian_language\", \"dbpedia\": \"http://dbpedia.org/resource/Italian_language\"}], \"noun_phrases\": [{\"ngram\": \"instance\", \"from\": 1527, \"to\": 1535}, {\"ngram\": \"the world\", \"from\": 1582, \"to\": 1591}, {\"ngram\": \"gold\", \"from\": 1603, \"to\": 1607}, {\"ngram\": \"the men's 100 metres\", \"from\": 1611, \"