30453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Google\", \"dbpedia\": \"http://dbpedia.org/resource/Google\"}, {\"begin\": 3721, \"end\": 3729, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999999981182555, \"rank\": 1.6371355960157448e-09, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 3750, \"end\": 3757, \"title\": \"http://dbpedia.org/resource/Comcast\", \"score\": 0.9999999972778824, \"rank\": 2.7223235515123625e-09, \"text\": \"Comcast\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Comcast\", \"dbpedia\": \"http://dbpedia.org/resource/Comcast\"}, {\"begin\": 3811, \"end\": 3817, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9988095802803378, \"rank\": 0.0011887877534325609, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"the original Minions characters\", \"from\": 3673, \"to\": 3704}, {\"ngram\": \"properties\", \"from\": 3707, \"to\": 3717}, {\"ngram\": \"their purchase\", \"from\": 3762, \"to\": 3776}, {\"ngram\": \"NBCUniversal\", \"from\": 3780, \"to\": 3792}]}, {\"sentence\": \"Around this point, events made a decided turn towards the bizarre.\", \"from\": 3833, \"to\": 3899, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this point\", \"from\": 3840, \"to\": 3850}, {\"ngram\": \"events\", \"from\": 3852, \"to\": 3858}, {\"ngram\": \"a decided turn\", \"from\": 3864, \"to\": 3878}]}, {\"sentence\": \"The story of the runner, and effectively the Olympic torch itself, was abandoned, and attention focused on the gantry-like structure of the Debilly Footbridge, not far from the Eiffel Tower.\", \"from\": 3900, \"to\": 4090, \"entities\": [{\"begin\": 4040, \"end\": 4058, \"title\": \"http://dbpedia.org/resource/Passerelle_Debilly\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Debilly Footbridge\", \"types\": [\"Q12280\"], \"wikid\": \"http://dbpedia.org/resource/Passerelle_Debilly\", \"dbpedia\": \"http://dbpedia.org/resource/Passerelle_Debilly\"}], \"noun_phrases\": [{\"ngram\": \"The story\", \"from\": 3900, \"to\": 3909}, {\"ngram\": \"the runner\", \"from\": 3913, \"to\": 3923}, {\"ngram\": \"effectively the Olympic torch\", \"from\": 3929, \"to\": 3958}, {\"ngram\": \"attention\", \"from\": 3986, \"to\": 3995}, {\"ngram\": \"the gantry-like structure\", \"from\": 4007, \"to\": 4032}, {\"ngram\": \"the Eiffel Tower\", \"from\": 4073, \"to\": 4089}]}, {\"sentence\": \"On top, what began as a Parisian fashion tribute soon became a general parade of camp and drag, culminating in the moment that a giant cloche was removed from a platter of flowers to reveal a mostly naked Smurf-man (Dionysus, apparently) who delivered a song to camera.\", \"from\": 4091, \"to\": 4360, \"entities\": [{\"begin\": 4307, \"end\": 4315, \"title\": \"http://dbpedia.org/resource/Dionysius_of_Halicarnassus\", \"score\": 1.0, \"rank\": 8.993790373488112e-28, \"text\": \"Dionysus\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Dionysius_of_Halicarnassus\", \"dbpedia\": \"http://dbpedia.org/resource/Dionysius_of_Halicarnassus\"}], \"noun_phrases\": [{\"ngram\": \"top\", \"from\": 4094, \"to\": 4097}, {\"ngram\": \"a Parisian fashion tribute\", \"from\": 4113, \"to\": 4139}, {\"ngram\": \"a general parade\", \"from\": 4152, \"to\": 4168}, {\"ngram\": \"camp\", \"from\": 4172, \"to\": 4176}, {\"ngram\": \"the moment\", \"from\": 4202, \"to\": 4212}, {\"ngram\": \"a giant cloche\", \"from\": 4218, \"to\": 4232}, {\"ngram\": \"a platter\", \"from\": 4250, \"to\": 4259}, {\"ngram\": \"flowers\", \"from\": 4263, \"to\": 4270}, {\"ngram\": \"a mostly naked Smurf-man\", \"from\": 4281, \"to\": 4305}, {\"ngram\": \"a song\", \"from\": 4343, \"to\": 4349}, {\"ngram\": \"camera\", \"from\": 4353, \"to\": 4359}]}, {\"sentence\": \"By this point the athletes' boats had all passed through.\", \"from\": 4361, \"to\": 4418, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this point\", \"from\": 4364, \"to\": 4374}, {\"ngram\": \"the athletes' boats\", \"from\": 4375, \"to\": 4394}]}, {\"sentence\": \"But a Eurodancing barge had drifted beneath the footbridge, and the ceremony essentially devolved into the most lavish and well-coordinated boat party Paris had ever seen.\", \"from\": 4419, \"to\": 4590, \"entities\": [{\"begin\": 4570, \"end\": 4575, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.9654379747492232e-30, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"a Eurodancing barge\", \"from\": 4423, \"to\": 4442}, {\"ngram\": \"the footbridge\", \"from\": 4463, \"to\": 4477}, {\"ngram\": \"the ceremony\", \"from\": 4483, \"to\": 4495}, {\"ngram\": \"the most lavish and well-coordinated boat party\", \"from\": 4522, \"to\": 4569}]}, {\"sentence\": \"From here, it was a wayward clamber back towards being an opening ceremony.\", \"from\": 4592, \"to\": 4667, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a wayward clamber\", \"from\": 4610, \"to\": 4627}, {\"ngram\": \"an opening ceremony\", \"from\": 4647, \"to\": 4666}]}, {\"sentence\": \"Emmanuel Macron and several Olympic grandees made speeches in the (still pouring) rain.\", \"from\": 4668, \"to\": 4755, \"entities\": [{\"begin\": 4668, \"end\": 4683, \"title\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Emmanuel Macron\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"dbpedia\": \"http://dbpedia.org/resource/Emmanuel_Macron\"}], \"noun_phrases\": [{\"ngram\": \"several Olympic grandees\", \"from\": 4688, \"to\": 4712}, {\"ngram\": \"speeches\", \"from\": 4718, \"to\": 4726}, {\"ngram\": \"rain\", \"from\": 4750, \"to\": 4754}]}, {\"sentence\": \"And as athletes and Parisians gathered beneath the Eiffel Tower in disciplined formation, it seemed a moment of coherence was upon us.\", \"from\": 4756, \"to\": 4890, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"athletes\", \"from\": 4763, \"to\": 4771}, {\"ngram\": \"Parisians\", \"from\": 4776, \"to\": 4785}, {\"ngram\": \"the Eiffel Tower\", \"from\": 4803, \"to\": 4819}, {\"ngram\": \"disciplined formation\", \"from\": 4823, \"to\": 4844}, {\"ngram\": \"a moment\", \"from\": 4856, \"to\": 4864}, {\"ngram\": \"coherence\", \"from\": 4868, \"to\": 4877}, {\"ngram\": \"us\", \"from\": 4887, \"to\": 4889}]}, {\"sentence\": \"The masked runner was even found; the flame brought before the crowd.\", \"from\": 4891, \"to\": 4960, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The masked runner\", \"from\": 4891, \"to\": 4908}, {\"ngram\": \"the flame\", \"from\": 4925, \"to\": 4934}, {\"ngram\": \"the crowd\", \"from\": 4950, \"to\": 4959}]}, {\"sentence\": \"But then a further series of very French narrative contrivances: the mysterious identity of the runner became suddenly redundant as he vanished from the story; and the flame was dispatched not towards the Tower, but on another boat back upriver.\", \"from\": 4961, \"to\": 5206, \"entities\": [{\"begin\": 4995, \"end\": 5001, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9988095802803378, \"rank\": 0.0011887877534325609, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"then a further series\", \"from\": 4965, \"to\": 4986}, {\"ngram\": \"the mysterious identity\", \"from\": 5026, \"to\": 5049}, {\"ngram\": \"the runner\", \"from\": 5053, \"to\": 5063}, {\"ngram\": \"the story\", \"from\": 5110, \"to\": 5119}, {\"ngram\": \"the flame\", \"from\": 5125, \"to\": 5134}, {\"ngram\": \"the Tower\", \"from\": 5162, \"to\": 5171}, {\"ngram\": \"another boat\", \"from\": 5180, \"to\": 5192}]}, {\"sentence\": \"Drizzly transit again!\", \"from\": 5207, \"to\": 5229, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Drizzly transit\", \"from\": 5207, \"to\": 5222}]}, {\"sentence\": \"The Parisians did have some final flourishes in store.\", \"from\": 5231, \"to\": 5285, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The Parisians\", \"from\": 5231, \"to\": 5244}, {\"ngram\": \"some final flourishes\", \"from\": 5254, \"to\": 5275}, {\"ngram\": \"store\", \"from\": 5279, \"to\": 5284}]}, {\"sentence\": \"C\\u00e9line Dion delivered a stunning rendition of \\u00c9dith Piaf's \\\"Hymne \\u00e0 l'Amour\\\" from atop the Eiffel Tower.\", \"from\": 5286, \"to\": 5390, \"entities\": [{\"begin\": 5332, \"end\": 5342, \"title\": \"http://dbpedia.org/resource/\\u00c9dith_Piaf\", \"score\": 0.9999999997962732, \"rank\": 0.0, \"text\": \"\\u00c9dith Piaf\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/\\u00c9dith_Piaf\", \"dbpedia\": \"http://dbpedia.org/resource/\\u00c9dith_Piaf\"}], \"noun_phrases\": [{\"ngram\": \"C\\u00e9line Dion\", \"from\": 5286, \"to\": 5297}, {\"ngram\": \"a stunning rendition\", \"from\": 5308, \"to\": 5328}, {\"ngram\": \"the Eiffel Tower\", \"from\": 5373, \"to\": 5389}]}, {\"sentence\": \"And, after it had retraced the steps of practically the entire ceremony so far, the torch was taken by a group of French athletes through the Louvre, and from there to theJardin des Tuileries.\", \"from\": 5391, \"to\": 5583, \"entities\": [{\"begin\": 5505, \"end\": 5511, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9988095802803378, \"rank\": 0.0011887877534325609, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 5533, \"end\": 5539, \"title\": \"http://dbpedia.org/resource/Louvre\", \"score\": 0.9999999992196535, \"rank\": 7.801429225104056e-10, \"text\": \"Louvre\", \"types\": [\"Q41176\", \"Q33506\"], \"wikid\": \"http://dbpedia.org/resource/Louvre\", \"dbpedia\": \"http://dbpedia.org/resource/Louvre\"}], \"noun_phrases\": [{\"ngram\": \"the steps\", \"from\": 5418, \"to\": 5427}, {\"ngram\": \"practically the entire ceremony\", \"from\": 5431, \"to\": 5462}, {\"ngram\": \"the torch\", \"from\": 5471, \"to\": 5480}, {\"ngram\": \"a group\", \"from\": 5494, \"to\": 5501}, {\"ngram\": \"des Tuileries\", \"from\": 5569, \"to\": 5582}]}, {\"sentence\": \"There, they found a cauldron that was affixed to a gorgeous spherical hot air balloon (a genuine French invention), which when lit rose some 30 metres in the air.\", \"from\": 5584, \"to\": 5746, \"entities\": [{\"begin\": 5681, \"end\": 5687, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9988095802803378, \"rank\": 0.0011887877534325609, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"a cauldron\", \"from\": 5602, \"to\": 5612}, {\"ngram\": \"a gorgeous spherical hot air balloon\", \"from\": 5633, \"to\": 5669}, {\"ngram\": \"the air\", \"from\": 5738, \"to\": 5745}]}, {\"sentence\": \"It will hang above the city for the duration of the Games, casting its glow across the skyline.\", \"from\": 5747, \"to\": 5842, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the city\", \"from\": 5766, \"to\": 5774}, {\"ngram\": \"the duration\", \"from\": 5779, \"to\": 5791}, {\"ngram\": \"the Games\", \"from\": 5795, \"to\": 5804}, {\"ngram\": \"its glow\", \"from\": 5814, \"to\": 5822}, {\"ngram\": \"the skyline\", \"from\": 5830, \"to\": 5841}]}, {\"sentence\": \"It was a moment of rare poignancy in an evening that was otherwise half English bank holiday and half rogue club night.\", \"from\": 5844, \"to\": 5963, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a moment\", \"from\": 5851, \"to\": 5859}, {\"ngram\": \"rare poignancy\", \"from\": 5863, \"to\": 5877}, {\"ngram\": \"an evening\", \"from\": 5881, \"to\": 5891}, {\"ngram\": \"English bank holiday\", \"from\": 5916, \"to\": 5936}, {\"ngram\": \"half rogue club night\", \"from\": 5941, \"to\": 5962}]}, {\"sentence\": \"Back in the studio with a boosterish Clare Balding, Rebecca Adlington said that it wasn't her favourite Olympic opening ceremony, even if she admitted it was tarnished by the weather.\", \"from\": 5964, \"to\": 6147, \"entities\": [{\"begin\": 6001, \"end\": 6014, \"title\": \"http://dbpedia.org/resource/Clare_Balding\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Clare Balding\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Clare_Balding\", \"dbpedia\": \"http://dbpedia.org/resource/Clare_Balding\"}, {\"begin\": 6016, \"end\": 6033, \"title\": \"http://dbpedia.org/resource/Rebecca_Adlington\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Rebecca Adlington\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Rebecca_Adlington\", \"dbpedia\": \"http://dbpedia.org/resource/Rebecca_Adlington\"}], \"noun_phrases\": [{\"ngram\": \"the studio\", \"from\": 5972, \"to\": 5982}, {\"ngram\": \"her favourite Olympic opening ceremony\", \"from\": 6054, \"to\": 6092}, {\"ngram\": \"the weather\", \"from\": 6135, \"to\": 6146}]}, {\"sentence\": \"The event this carnival truly resembled - in its colours, its chaos, and its unyielding but questionable self-confidence - was the Eurovision Song Contest.\", \"from\": 6148, \"to\": 6303, \"entities\": [{\"begin\": 6279, \"end\": 6302, \"title\": \"http://dbpedia.org/resource/Eurovision_Song_Contest\", \"score\": 0.999999999920874, \"rank\": 7.867637412644329e-11, \"text\": \"Eurovision Song Contest\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/Eurovision_Song_Contest\", \"dbpedia\": \"http://dbpedia.org/resource/Eurovision_Song_Contest\"}], \"noun_phrases\": [{\"ngram\": \"The event\", \"from\": 6148, \"to\": 6157}, {\"ngram\": \"this carnival\", \"from\": 6158, \"to\": 6171}, {\"ngram\": \"its colours\", \"from\": 6193, \"to\": 6204}, {\"ngram\": \"its chaos\", \"from\": 6206, \"to\": 6215}, {\"ngram\": \"its unyielding\", \"from\": 6221, \"to\": 6235}, {\"ngram\": \"questionable self-confidence\", \"from\": 6240, \"to\": 6268}]}, {\"sentence\": \"What was really needed therefore was not a different show, but a different commentator - a Norton or a Wogan, someone who could make sense of it all, or at least dryly mock that which they could not.\", \"from\": 6304, \"to\": 6503, \"entities\": [{\"begin\": 6395, \"end\": 6401, \"title\": \"http://dbpedia.org/resource/Norton_Motorcycle_Company\", \"score\": 1.0, \"rank\": 9.850009124294981e-29, \"text\": \"Norton\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Norton_Motorcycle_Company\", \"dbpedia\": \"http://dbpedia.org/resource/Norton_Motorcycle_Company\"}, {\"begin\": 6407, \"end\": 6412, \"title\": \"http://dbpedia.org/resource/Wogan\", \"score\": 1.0, \"rank\": 4.31675418650268e-21, \"text\": \"Wogan\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/Wogan\", \"dbpedia\": \"http://dbpedia.org/resource/Wogan\"}], \"noun_phrases\": [{\"ngram\": \"a different show\", \"from\": 6345, \"to\": 6361}, {\"ngram\": \"a different commentator\", \"from\": 6367, \"to\": 6390}, {\"ngram\": \"someone\", \"from\": 6414, \"to\": 6421}, {\"ngram\": \"sense\", \"from\": 6437, \"to\": 6442}]}, {\"sentence\": \"The temptation, perhaps unfairly, is to compare this to Britain's triumph of 12 years ago.\", \"from\": 6505, \"to\": 6595, \"entities\": [{\"begin\": 6561, \"end\": 6568, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9999999871806723, \"rank\": 1.2544732054292375e-08, \"text\": \"Britain\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"The temptation\", \"from\": 6505, \"to\": 6519}]}, {\"sentence\": \"Danny Boyle's \\\"Isles of Wonder\\\" has become easy to mock in the years since, too readily deployed as a shorthand for a kind of populist-centrist Whiggery.\", \"from\": 6596, \"to\": 6749, \"entities\": [{\"begin\": 6596, \"end\": 6607, \"title\": \"http://dbpedia.org/resource/Danny_Boyle\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Danny Boyle\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Danny_Boyle\", \"dbpedia\": \"http://dbpedia.org/resource/Danny_Boyle\"}, {\"begin\": 6740, \"end\": 6748, \"title\": \"http://dbpedia.org/resource/Whiggism\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Whiggery\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Whiggism\", \"dbpedia\": \"http://dbpedia.org/resource/Whiggism\"}], \"noun_phrases\": [{\"ngram\": \"Wonder\", \"from\": 6620, \"to\": 6626}, {\"ngram\": \"the years\", \"from\": 6655, \"to\": 6664}, {\"ngram\": \"a shorthand\", \"from\": 6696, \"to\": 6707}, {\"ngram\": \"a kind\", \"from\": 6712, \"to\": 6718}]}, {\"sentence\": \"But perhaps we needed reminding what these international events can too often be like.\", \"from\": 6750, \"to\": 6836, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"these international events\", \"from\": 6787, \"to\": 6813}]}, {\"sentence\": \"In its narrative, pulse and humour, London 2012 is still the opening ceremony to beat.\", \"from\": 6837, \"to\": 6923, \"entities\": [{\"begin\": 6873, \"end\": 6884, \"title\": \"http://dbpedia.org/resource/2012_Summer_Olympics\", \"score\": 1.0, \"rank\": 8.358176198460303e-14, \"text\": \"London 2012\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2012_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2012_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"its narrative\", \"from\": 6840, \"to\": 6853}, {\"ngram\": \"pulse\", \"from\": 6855, \"to\": 6860}, {\"ngram\": \"humour\", \"from\": 6865, \"to\": 6871}, {\"ngram\": \"the opening ceremony\", \"from\": 6894, \"to\": 6914}]}, {\"sentence\": \"Related\", \"from\": 6925, \"to\": 6932, \"entities\": [], \"noun_phrases\": []}]}"