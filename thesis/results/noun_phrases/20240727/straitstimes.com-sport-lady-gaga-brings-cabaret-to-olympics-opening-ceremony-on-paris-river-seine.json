"rank\": 0.0, \"text\": \"Aya Nakamura\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Aya_Nakamura\", \"dbpedia\": \"http://dbpedia.org/resource/Aya_Nakamura\"}, {\"begin\": 2236, \"end\": 2242, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9973145484235338, \"rank\": 0.0025206461430411103, \"text\": \"French\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 2321, \"end\": 2338, \"title\": \"http://dbpedia.org/resource/French_First_Republic\", \"score\": 0.9999999105234605, \"rank\": 8.884250333312895e-08, \"text\": \"French Republican\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/French_First_Republic\", \"dbpedia\": \"http://dbpedia.org/resource/French_First_Republic\"}], \"noun_phrases\": [{\"ngram\": \"A more modern image\", \"from\": 2123, \"to\": 2142}, {\"ngram\": \"the country\", \"from\": 2146, \"to\": 2157}, {\"ngram\": \"display\", \"from\": 2165, \"to\": 2172}, {\"ngram\": \"the world\", \"from\": 2260, \"to\": 2269}, {\"ngram\": \"her biggest hits\", \"from\": 2284, \"to\": 2300}]}, {\"sentence\": \"Nakamura\\u00e2\\u0080\\u0099s performance drew some of the ceremony\\u00e2\\u0080\\u0099s biggest cheers.\", \"from\": 2362, \"to\": 2432, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Nakamura\\u00e2\\u0080\\u0099s performance\", \"from\": 2362, \"to\": 2386}, {\"ngram\": \"the ceremony\\u00e2\\u0080\\u0099s biggest cheers\", \"from\": 2400, \"to\": 2431}]}, {\"sentence\": \"Rumours of her inclusion had sparked a row over French identity, with supporters saying said she represented the vibrancy of modern-day France while her detractors saying her music owes more to foreign influences than French.\", \"from\": 2434, \"to\": 2659, \"entities\": [{\"begin\": 2482, \"end\": 2488, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9973145484235338