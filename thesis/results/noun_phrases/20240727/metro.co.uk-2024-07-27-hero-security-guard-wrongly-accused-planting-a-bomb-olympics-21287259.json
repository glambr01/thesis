"{\"uid\": \"metro.co.uk-2024-07-27-hero-security-guard-wrongly-accused-planting-a-bomb-olympics-21287259\", \"noun_phrases\": [{\"sentence\": \"On a hot July evening inAtlanta, Georgia, crowds of people were gathered in Centennial Olympic Park on the eighth day of the 1996 SummerOlympics.\", \"from\": 0, \"to\": 145, \"entities\": [{\"begin\": 33, \"end\": 40, \"title\": \"http://dbpedia.org/resource/University_of_Georgia\", \"score\": 0.9999999859887795, \"rank\": 1.0952459720751624e-08, \"text\": \"Georgia\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/University_of_Georgia\", \"dbpedia\": \"http://dbpedia.org/resource/University_of_Georgia\"}], \"noun_phrases\": [{\"ngram\": \"a hot July evening inAtlanta\", \"from\": 3, \"to\": 31}, {\"ngram\": \"crowds\", \"from\": 42, \"to\": 48}, {\"ngram\": \"people\", \"from\": 52, \"to\": 58}, {\"ngram\": \"Centennial Olympic Park\", \"from\": 76, \"to\": 99}, {\"ngram\": \"the eighth day\", \"from\": 103, \"to\": 117}, {\"ngram\": \"the 1996 SummerOlympics\", \"from\": 121, \"to\": 144}]}, {\"sentence\": \"Thirty-three-year-old Richard Jewell had been more than seven hours into his shift as a security guard in the area when he noticed something odd.\", \"from\": 147, \"to\": 292, \"entities\": [{\"begin\": 169, \"end\": 183, \"title\": \"http://dbpedia.org/resource/Richard_Jewell\", \"score\": 1.0, \"rank\": 1.3549600624030532e-65, \"text\": \"Richard Jewell\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Richard_Jewell\", \"dbpedia\": \"http://dbpedia.org/resource/Richard_Jewell\"}], \"noun_phrases\": [{\"ngram\": \"more than seven hours\", \"from\": 193, \"to\": 214}, {\"ngram\": \"his shift\", \"from\": 220, \"to\": 229}, {\"ngram\": \"a security guard\", \"from\": 233, \"to\": 249}, {\"ngram\": \"the area\", \"from\": 253, \"to\": 261}, {\"ngram\": \"something\", \"from\": 278, \"to\": 287}]}, {\"sentence\": \"A green military-style bag had been left unattended and nobody was claiming it.\", \"from\": 294, \"to\": 373, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A green military-style bag\", \"from\": 294, \"to\": 320}, {\"ngram\": \"nobody\", \"from\": 350, \"to\": 356}]}, {\"sentence\": \"Jewell raised the alarm, and minutes later, 911 received a call from aphonebooth near the park.\", \"from\": 374, \"to\": 469, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Jewell\", \"from\": 374, \"to\": 380}, {\"ngram\": \"the alarm\", \"from\": 388, \"to\": 397}, {\"ngram\": \"a call\", \"from\": 431, \"to\": 437}, {\"ngram\": \"aphonebooth\", \"from\": 443, \"to\": 454}, {\"ngram\": \"the park\", \"from\": 460, \"to\": 468}]}, {\"sentence\": \"'There is a bomb in Centennial Park.\", \"from\": 471, \"to\": 507, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a bomb\", \"from\": 481, \"to\": 487}, {\"ngram\": \"Centennial Park\", \"from\": 491, \"to\": 506}]}, {\"sentence\": \"You have 30 minutes.'\", \"from\": 508, \"to\": 529, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"30 minutes\", \"from\": 517, \"to\": 527}]}, {\"sentence\": \"Jewell began moving people away and out of the park, but at 1.20am, the 40-pound pipe bomb exploded - killing one woman and injuring more than 100 others.\", \"from\": 531, \"to\": 685, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Jewell\", \"from\": 531, \"to\": 537}, {\"ngram\": \"people\", \"from\": 551, \"to\": 557}, {\"ngram\": \"the park\", \"from\": 574, \"to\": 582}, {\"ngram\": \"the 40-pound pipe bomb\", \"from\": 599, \"to\": 621}, {\"ngram\": \"one woman\", \"from\": 641, \"to\": 650}, {\"ngram\": \"more than 100 others\", \"from\": 664, \"to\": 684}]}, {\"sentence\": \"The unsuspecting security guard saved many lives that day by spotting the bag and beginning evacuations.\", \"from\": 687, \"to\": 791, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The unsuspecting security guard\", \"from\": 687, \"to\": 718}, {\"ngram\": \"many lives\", \"from\": 725, \"to\": 735}, {\"ngram\": \"the bag\", \"from\": 757, \"to\": 764}, {\"ngram\": \"beginning evacuations\", \"from\": 769, \"to\": 790}]}, {\"sentence\": \"But even though Jewell was praised as a hero following the bombing, the narrative slowly shifted.\", \"from\": 792, \"to\": 889, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Jewell\", \"from\": 808, \"to\": 814}, {\"ngram\": \"a hero\", \"from\": 830, \"to\": 836}, {\"ngram\": \"the bombing\", \"from\": 847, \"to\": 858}, {\"ngram\": \"the narrative\", \"from\": 860, \"to\": 873}]}, {\"sentence\": \"Within days, Jewell - a quiet security guard who lived with his mother - became a suspect in the 1996 Atlanta Olympic bombings.\", \"from\": 891, \"to\": 1018, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"days\", \"from\": 898, \"to\": 902}, {\"ngram\": \"Jewell\", \"from\": 904, \"to\": 910}, {\"ngram\": \"a quiet security guard\", \"from\": 913, \"to\": 935}, {\"ngram\": \"his mother\", \"from\": 951, \"to\": 961}, {\"ngram\": \"a suspect\", \"from\": 971, \"to\": 980}, {\"ngram\": \"the 1996 Atlanta Olympic bombings\", \"from\": 984, \"to\": 1017}]}, {\"sentence\": \"Jewell was born in Danville, Virginia, to a father who worked for Chevrolet and a mother who worked in insurance.\", \"from\": 1020, \"to\": 1133, \"entities\": [{\"begin\": 1049, \"end\": 1057, \"title\": \"http://dbpedia.org/resource/Virginia\", \"score\": 0.9999967296165595, \"rank\": 3.0214206742636477e-06, \"text\": \"Virginia\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Virginia\", \"dbpedia\": \"http://dbpedia.org/resource/Virginia\"}, {\"begin\": 1086, \"end\": 1095, \"title\": \"http://dbpedia.org/resource/Chevrolet_Indy_V6\", \"score\": 0.6712214246782418, \"rank\": 0.48981467068688855, \"text\": \"Chevrolet\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Chevrolet_Indy_V6\", \"dbpedia\": \"http://dbpedia.org/resource/Chevrolet_Indy_V6\"}], \"noun_phrases\": [{\"ngram\": \"Jewell\", \"from\": 1020, \"to\": 1026}, {\"ngram\": \"Danville\", \"from\": 1039, \"to\": 1047}, {\"ngram\": \"a father\", \"from\": 1062, \"to\": 1070}, {\"ngram\": \"a mother\", \"from\": 1100, \"to\": 1108}, {\"ngram\": \"insurance\", \"from\": 1123, \"to\": 1132}]}, {\"sentence\": \"He moved to Atlanta with his mum and stepfather when he was young.\", \"from\": 1134, \"to\": 1200, \"entities\": [{\"begin\": 1146, \"end\": 1153, \"title\": \"http://dbpedia.org/resource/Atlanta\", \"score\": 1.0, \"rank\": 3.2411114665928466e-26, \"text\": \"Atlanta\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Atlanta\", \"dbpedia\": \"http://dbpedia.org/resource/Atlanta\"}], \"noun_phrases\": [{\"ngram\": \"his mum\", \"from\": 1159, \"to\": 1166}, {\"ngram\": \"stepfather\", \"from\": 1171, \"to\": 1181}]}, {\"sentence\": \"He worked in a variety of jobs before joining the Habersham County Sheriff's Office in Georgia as a jailer in 1990.\", \"from\": 1202, \"to\": 1317, \"entities\": [{\"begin\": 1289, \"end\": 1296, \"title\": \"http://dbpedia.org/resource/University_of_Georgia\", \"score\": 0.9999999859887795, \"rank\": 1.0952459720751624e-08, \"text\": \"Georgia\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/University_of_Georgia\", \"dbpedia\": \"http://dbpedia.org/resource/University_of_Georgia\"}], \"noun_phrases\": [{\"ngram\": \"a variety\", \"from\": 1215, \"to\": 1224}, {\"ngram\": \"jobs\", \"from\": 1228, \"to\": 1232}, {\"ngram\": \"the Habersham County Sheriff's Office\", \"from\": 1248, \"to\": 1285}, {\"ngram\": \"a jailer\", \"from\": 1300, \"to\": 1308}]}, {\"sentence\": \"He was charged with impersonating a police officer after arresting a couple when he was working as a security officer.\", \"from\": 1318, \"to\": 1436, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a police officer\", \"from\": 1352, \"to\": 1368}, {\"ngram\": \"a couple\", \"from\": 1385, \"to\": 1393}, {\"ngram\": \"a security officer\", \"from\": 1417, \"to\": 1435}]}, {\"sentence\": \"Jewell, described as an 'overzealous' employee, eventually resigned and worked a brief stint as a campus police officer, before returning to Atlanta and getting a job as a security officer ahead of the 1996 Olympic Games.\", \"from\": 1438, \"to\": 1659, \"entities\": [{\"begin\": 1579, \"end\": 1586, \"title\": \"http://dbpedia.org/resource/Atlanta\", \"score\": 1.0, \"rank\": 3.2411114665928466e-26, \"text\": \"Atlanta\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Atlanta\", \"dbpedia\": \"http://dbpedia.org/resource/Atlanta\"}], \"noun_phrases\": [{\"ngram\": \"Jewell\", \"from\": 1438, \"to\": 1444}, {\"ngram\": \"an 'overzealous' employee\", \"from\": 1459, \"to\": 1484}, {\"ngram\": \"a brief stint\", \"from\": 1517, \"to\": 1530}, {\"ngram\": \"a campus police officer\", \"from\": 1534, \"to\": 1557}, {\"ngram\": \"a job\", \"from\": 1599, \"to\": 1604}, {\"ngram\": \"a security officer\", \"from\": 1608, \"to\": 1626}, {\"ngram\": \"the 1996 Olympic Games\", \"from\": 1636, \"to\": 1658}]}, {\"sentence\": \"While working in that job, he spotted the backpack which turned out to be a massive pipebomb, which exploded in the park, killing one woman and injuring more than 100.\", \"from\": 1661, \"to\": 1828, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"that job\", \"from\": 1678, \"to\": 1686}, {\"ngram\": \"the backpack\", \"from\": 1699, \"to\": 1711}, {\"ngram\": \"a massive pipebomb\", \"from\": 1735, \"to\": 1753}, {\"ngram\": \"the park\", \"from\": 1773, \"to\": 1781}, {\"ngram\": \"one woman\", \"from\": 1791, \"to\": 1800}]}, {\"sentence\": \"Jewell's attempts to move crowds away from the area saved countless lives on July 27, 1996, and he was praised for his efforts.\", \"from\": 1830, \"to\": 1957, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Jewell's attempts\", \"from\": 1830, \"to\": 1847}, {\"ngram\": \"crowds\", \"from\": 1856, \"to\": 1862}, {\"ngram\": \"the area\", \"from\": 1873, \"to\": 1881}, {\"ngram\": \"countless lives\", \"from\": 1888, \"to\": 1903}, {\"ngram\": \"July\", \"from\": 1907, \"to\": 1911}, {\"ngram\": \"his efforts\", \"from\": 1945, \"to\": 1956}]}, {\"sentence\": \"But all of that changed with one headline from The Atlanta Journal three days later.\", \"from\": 1958, \"to\": 2042, \"entities\": [{\"begin\": 2005, \"end\": 2024, \"title\": \"http://dbpedia.org/resource/The_Atlanta_Journal-Constitution\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"The Atlanta Journal\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Atlanta_Journal-Constitution\", \"dbpedia\": \"http://dbpedia.org/resource/The_Atlanta_Journal-Constitution\"}], \"noun_phrases\": [{\"ngram\": \"one headline\", \"from\": 1987, \"to\": 1999}]}, {\"sentence\": \"In the days following the bombing, Jewell had not been considered a suspect by the FBI.\", \"from\": 2044, \"to\": 2131, \"entities\": [{\"begin\": 2127, \"end\": 2130, \"title\": \"http://dbpedia.org/resource/Federal_Bureau_of_Investigation\", \"score\": 1.0, \"rank\": 1.2523786338705633e-47, \"text\": \"FBI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Federal_Bureau_of_Investigation\", \"dbpedia\": \"http://dbpedia.org/resource/Federal_Bureau_of_Investigation\"}], \"noun_phrases\": [{\"ngram\": \"the days\", \"from\": 2047, \"to\": 2055}, {\"ngram\": \"the bombing\", \"from\": 2066, \"to\": 2077}, {\"ngram\": \"Jewell\", \"from\": 2079, \"to\": 2085}, {\"ngram\": \"a suspect\", \"from\": 2110, \"to\": 2119}]}, {\"sentence\": \"On July 28, they received a call from the president of Piedmont College, where Jewell had worked briefly as a campus security guard.\", \"from\": 2132, \"to\": 2264, \"entities\": [{\"begin\": 2187, \"end\": 2203, \"title\": \"http://dbpedia.org/resource/Piedmont_University\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Piedmont College\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/Piedmont_University\", \"dbpedia\": \"http://dbpedia.org/resource/Piedmont_University\"}], \"noun_phrases\": [{\"ngram\": \"July\", \"from\": 2135, \"to\": 2139}, {\"ngram\": \"a call\", \"from\": 2158, \"to\": 2164}, {\"ngram\": \"the president\", \"from\": 2170, \"to\": 2183}, {\"ngram\": \"Jewell\", \"from\": 2211, \"to\": 2217}, {\"ngram\": \"a campus security guard\", \"from\": 2240, \"to\": 2263}]}, {\"sentence\": \"He told the FBI that Jewell could have been involved in planting the bomb.\", \"from\": 2265, \"to\": 2339, \"entities\": [{\"begin\": 2277, \"end\": 2280, \"title\": \"http://dbpedia.org/resource/Federal_Bureau_of_Investigation\", \"score\": 1.0, \"rank\": 1.2523786338705633e-47, \"text\": \"FBI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Federal_Bureau_of_Investigation\", \"dbpedia\": \"http://dbpedia.org/resource/Federal_Bureau_of_Investigation\"}], \"noun_phrases\": [{\"ngram\": \"Jewell\", \"from\": 2286, \"to\": 2292}, {\"ngram\": \"the bomb\", \"from\": 2330, \"to\": 2338}]}, {\"sentence\": \"On July 30, three days after the bomb detonated, The Atlanta Journal published an article titled 'F.B.I.\", \"from\": 2341, \"to\": 2445, \"entities\": [{\"begin\": 2390, \"end\": 2409, \"title\": \"http://dbpedia.org/resource/The_Atlanta_Journal-Constitution\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"The Atlanta Journal\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Atlanta_Journal-Constitution\", \"dbpedia\": \"http://dbpedia.org/resource/The_Atlanta_Journal-Constitution\"}, {\"begin\": 2439, \"end\": 2445, \"title\": \"http://dbpedia.org/resource/Federal_Bureau_of_Investigation\", \"score\": 1.0, \"rank\": 1.0660066664884243e-44, \"text\": \"F.B.I.\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Federal_Bureau_of_Investigation\", \"dbpedia\": \"http://dbpedia.org/resource/Federal_Bureau_of_Investigation\"}], \"noun_phrases\": [{\"ngram\": \"July\", \"from\": 2344, \"to\": 2348}, {\"ngram\": \"the bomb\", \"from\": 2370, \"to\": 2378}, {\"ngram\": \"an article\", \"from\": 2420, \"to\": 2430}]}, {\"sentence\": \"Suspects 'Hero' Guard May Have Planted Bomb.'\", \"from\": 2446, \"to\": 2491, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Suspects 'Hero' Guard\", \"from\": 2446, \"to\": 2467}, {\"ngram\": \"Bomb\", \"from\": 2485, \"to\": 2489}]}, {\"sentence\": \"The newspaper did not cite its sources for the article, but it sparked a media firestorm - camera crews and reporters camped outside of Jewell's home in the days following the allegation.\", \"from\": 2493, \"to\": 2680, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The newspaper\", \"from\": 2493, \"to\": 2506}, {\"ngram\": \"its sources\", \"from\": 2520, \"to\": 2531}, {\"ngram\": \"the article\", \"from\": 2536, \"to\": 2547}, {\"ngram\": \"a media firestorm - camera crews\", \"from\": 2564, \"to\": 2596}, {\"ngram\": \"reporters\", \"from\": 2601, \"to\": 2610}, {\"ngram\": \"Jewell's home\", \"from\": 2629, \"to\": 2642}, {\"ngram\": \"the days\", \"from\": 2646, \"to\": 2654}, {\"ngram\": \"the allegation\", \"from\": 2665, \"to\": 2679}]}, {\"sentence\": \"Why did they latch onto the idea that a security guard planted the bomb to become a hero?\", \"from\": 2682, \"to\": 2771, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the idea\", \"from\": 2706, \"to\": 2714}, {\"ngram\": \"a security guard\", \"from\": 2720, \"to\": 2736}, {\"ngram\": \"the bomb\", \"from\": 2745, \"to\": 2753}, {\"ngram\": \"a hero\", \"from\": 2764, \"to\": 2770}]}, {\"sentence\": \"A case less than ten years earlier saw a volunteer firefighter in California set intentional fires to put them out, in order to be a 'hero'.\", \"from\": 2772, \"to\": 2912, \"entities\": [{\"begin\": 2838, \"end\": 2848, \"title\": \"http://dbpedia.org/resource/California\", \"score\": 0.9999999988740456, \"rank\": 1.126021295816889e-09, \"text\": \"California\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/California\", \"dbpedia\": \"http://dbpedia.org/resource/California\"}], \"noun_phrases\": [{\"ngram\": \"A case\", \"from\": 2772, \"to\": 2778}, {\"ngram\": \"a volunteer firefighter\", \"from\": 2811, \"to\": 2834}, {\"ngram\": \"intentional fires\", \"from\": 2853, \"to\": 2870}, {\"ngram\": \"order\", \"from\": 2891, \"to\": 2896}, {\"ngram\": \"a 'hero\", \"from\": 2903, \"to\": 2910}]}, {\"sentence\": \"On July 29, the FBI was advised that 'Jewell fit the profile of a person who might create an incident so he could emerge as a hero.'\", \"from\": 2914, \"to\": 3046, \"entities\": [{\"begin\": 2930, \"end\": 2933, \"title\": \"http://dbpedia.org/resource/Federal_Bureau_of_Investigation\", \"score\": 1.0, \"rank\": 1.2523786338705633e-47, \"text\": \"FBI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Federal_Bureau_of_Investigation\", \"dbpedia\": \"http://dbpedia.org/resource/Federal_Bureau_of_Investigation\"}], \"noun_phrases\": [{\"ngram\": \"July\", \"from\": 2917, \"to\": 2921}, {\"ngram\": \"Jewell\", \"from\": 2952, \"to\": 2958}, {\"ngram\": \"the profile\", \"from\": 2963, \"to\": 2974}, {\"ngram\": \"a person\", \"from\": 2978, \"to\": 2986}, {\"ngram\": \"an incident\", \"from\": 3004, \"to\": 3015}, {\"ngram\": \"a hero\", \"from\": 3038, \"to\": 3044}]}, {\"sentence\": \"Now, he was considered a suspect - but not the only one.\", \"from\": 3047, \"to\": 3103, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a suspect\", \"from\": 3070, \"to\": 3079}]}, {\"sentence\": \"But the idea of a man who helped save lives in the bombing being the man who actually planted it was a juicy news story - and most news organisations ran with it.\", \"from\": 3105, \"to\": 3267, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the idea\", \"from\": 3109, \"to\": 3117}, {\"ngram\": \"a man\", \"from\": 3121, \"to\": 3126}, {\"ngram\": \"lives\", \"from\": 3143, \"to\": 3148}, {\"ngram\": \"the bombing\", \"from\": 3152, \"to\": 3163}, {\"ngram\": \"the man\", \"from\": 3170, \"to\": 3177}, {\"ngram\": \"a juicy news story\", \"from\": 3206, \"to\": 3224}, {\"ngram\": \"most news organisations\", \"from\": 3231, \"to\": 3254}]}, {\"sentence\": \"For Jewell, he had begun his '88 days of hell'.\", \"from\": 3269, \"to\": 3316, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Jewell\", \"from\": 3273, \"to\": 3279}, {\"ngram\": \"his '88 days\", \"from\": 3294, \"to\": 3306}, {\"ngram\": \"hell\", \"from\": 3310, \"to\": 3314}]}, {\"sentence\": \"He was unable to leave his apartment without being swarmed by reporters and cameras.\", \"from\": 3317, \"to\": 3401, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"his apartment\", \"from\": 3340, \"to\": 3353}, {\"ngram\": \"reporters\", \"from\": 3379, \"to\": 3388}, {\"ngram\": \"cameras\", \"from\": 3393, \"to\": 3400}]}, {\"sentence\": \"Three months after the damning headline claiming Jewell may have planted the bomb in Atlanta, his name was cleared.\", \"from\": 3403, \"to\": 3518, \"entities\": [{\"begin\": 3488, \"end\": 3495, \"title\": \"http://dbpedia.org/resource/Atlanta\", \"score\": 1.0, \"rank\": 3.2411114665928466e-26, \"text\": \"Atlanta\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Atlanta\", \"dbpedia\": \"http://dbpedia.org/resource/Atlanta\"}], \"noun_phrases\": [{\"ngram\": \"the damning headline\", \"from\": 3422, \"to\": 3442}, {\"ngram\": \"Jewell\", \"from\": 3452, \"to\": 3458}, {\"ngram\": \"the bomb\", \"from\": 3476, \"to\": 3484}, {\"ngram\": \"his name\", \"from\": 3497, \"to\": 3505}]}, {\"sentence\": \"The Justice Department wrote to Jewell's lawyer that he was not the man they believed to be behind the bombing.\", \"from\": 3520, \"to\": 3631, \"entities\": [{\"begin\": 3524, \"end\": 3542, \"title\": \"http://dbpedia.org/resource/United_States_Department_of_Justice\", \"score\": 1.0, \"rank\": 1.586260930487042e-13, \"text\": \"Justice Department\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_States_Department_of_Justice\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_Department_of_Justice\"}], \"noun_phrases\": [{\"ngram\": \"Jewell's lawyer\", \"from\": 3552, \"to\": 3567}, {\"ngram\": \"the man\", \"from\": 3584, \"to\": 3591}, {\"ngram\": \"the bombing\", \"from\": 3619, \"to\": 3630}]}, {\"sentence\": \"Jewell's name was cleared - but his reputation was never the same, despite being the actual hero of the Olympic bombings.\", \"from\": 3633, \"to\": 3754, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Jewell's name\", \"from\": 3633, \"to\": 3646}, {\"ngram\": \"his reputation\", \"from\": 3665, \"to\": 3679}, {\"ngram\": \"the actual hero\", \"from\": 3714, \"to\": 3729}, {\"ngram\": \"the Olympic bombings\", \"from\": 3733, \"to\": 3753}]}, {\"sentence\": \"He won multiple lawsuits against NBC, CNN and the New York Post.\", \"from\": 3756, \"to\": 3820, \"entities\": [{\"begin\": 3789, \"end\": 3792, \"title\": \"http://dbpedia.org/resource/NBC\", \"score\": 1.0, \"rank\": 4.0191724284968655e-15, \"text\": \"NBC\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/NBC\", \"dbpedia\": \"http://dbpedia.org/resource/NBC\"}], \"noun_phrases\": [{\"ngram\": \"multiple lawsuits\", \"from\": 3763, \"to\": 3780}]}, {\"sentence\": \"He went on to work small jobs in Georgia law enforcement.\", \"from\": 3821, \"to\": 3878, \"entities\": [{\"begin\": 3854, \"end\": 3861, \"title\": \"http://dbpedia.org/resource/University_of_Georgia\", \"score\": 0.9999999859887795, \"rank\": 1.0952459720751624e-08, \"text\": \"Georgia\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/University_of_Georgia\", \"dbpedia\": \"http://dbpedia.org/resource/University_of_Georgia\"}], \"noun_phrases\": [{\"ngram\": \"small jobs\", \"from\": 3840, \"to\": 3850}]}, {\"sentence\": \"Months after his name was cleared, Jewell told The New York Times: 'I am a lot more cynical than I used to be.\", \"from\": 3880, \"to\": 3990, \"entities\": [{\"begin\": 3927, \"end\": 3945, \"title\": \"http://dbpedia.org/resource/The_New_York_Times\", \"score\": 1.0, \"rank\": 2.7345478066912156e-18, \"text\": \"The New York Times\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_New_York_Times\", \"dbpedia\": \"http://dbpedia.org/resource/The_New_York_Times\"}], \"noun_phrases\": [{\"ngram\": \"his name\", \"from\": 3893, \"to\": 3901}, {\"ngram\": \"Jewell\", \"from\": 3915, \"to\": 3921}]}, {\"sentence\": \"I am not as trusting as I once was.\", \"from\": 3991, \"to\": 4026, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"And I do not think I am as outgoing as I used to be.'\", \"from\": 4027, \"to\": 4080, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Jewell went on to marry his wife Dana in 1998 and remained with her until he died of heart failure and side effects of diabetes.\", \"from\": 4082, \"to\": 4210, \"entities\": [{\"begin\": 4115, \"end\": 4119, \"title\": \"http://dbpedia.org/resource/Dana_Scully\", \"score\": 1.0, \"rank\": 7.268211762405475e-28, \"text\": \"Dana\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Dana_Scully\", \"dbpedia\": \"http://dbpedia.org/resource/Dana_Scully\"}], \"noun_phrases\": [{\"ngram\": \"Jewell\", \"from\": 4082, \"to\": 4088}, {\"ngram\": \"his wife\", \"from\": 4106, \"to\": 4114}, {\"ngram\": \"heart failure\", \"from\": 4167, \"to\": 4180}, {\"ngram\": \"side effects\", \"from\": 4185, \"to\": 4197}, {\"ngram\": \"diabetes\", \"from\": 4201, \"to\": 4209}]}, {\"sentence\": \"Though he was truly one of the heroes of the tragic 1996 Olympic Bombings, he wasn't the man who planted the bomb which killed a woman and injured hundreds.\", \"from\": 4212, \"to\": 4368, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the heroes\", \"from\": 4239, \"to\": 4249}, {\"ngram\": \"the tragic 1996 Olympic Bombings\", \"from\": 4253, \"to\": 4285}, {\"ngram\": \"the man\", \"from\": 4297, \"to\": 4304}, {\"ngram\": \"the bomb\", \"from\": 4317, \"to\": 4325}, {\"ngram\": \"a woman\", \"from\": 4339, \"to\": 4346}, {\"ngram\": \"hundreds\", \"from\": 4359, \"to\": 4367}]}, {\"sentence\": \"That man wasn't caught until 2003, after bombing two other locations.\", \"from\": 4370, \"to\": 4439, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"That man\", \"from\": 4370, \"to\": 4378}, {\"ngram\": \"two other locations\", \"from\": 4419, \"to\": 4438}]}, {\"sentence\": \"Eric Robert Rudolph was the lone wolf behind the deadly Atlanta bombing on July 27, 1996.\", \"from\": 4441, \"to\": 4530, \"entities\": [{\"begin\": 4441, \"end\": 4460, \"title\": \"http://dbpedia.org/resource/Eric_Rudolph\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Eric Robert Rudolph\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Eric_Rudolph\", \"dbpedia\": \"http://dbpedia.org/resource/Eric_Rudolph\"}, {\"begin\": 4497, \"end\": 4504, \"title\": \"http://dbpedia.org/resource/Atlanta\", \"score\": 1.0, \"rank\": 3.2411114665928466e-26, \"text\": \"Atlanta\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Atlanta\", \"dbpedia\": \"http://dbpedia.org/resource/Atlanta\"}], \"noun_phrases\": [{\"ngram\": \"July\", \"from\": 4516, \"to\": 4520}]}, {\"sentence\": \"He was first named as a suspect in February 1998.\", \"from\": 4532, \"to\": 4581, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a suspect\", \"from\": 4554, \"to\": 4563}, {\"ngram\": \"February\", \"from\": 4567, \"to\": 4575}]}, {\"sentence\": \"Eventually, the bombings of a north Atlanta abortion clinic and a gay nightclub were linked to Rudolph - as well as the Olympic bombing, and one in Alabama.\", \"from\": 4582, \"to\": 4738, \"entities\": [{\"begin\": 4618, \"end\": 4625, \"title\": \"http://dbpedia.org/resource/Atlanta\", \"score\": 1.0, \"rank\": 3.2411114665928466e-26, \"text\": \"Atlanta\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Atlanta\", \"dbpedia\": \"http://dbpedia.org/resource/Atlanta\"}, {\"begin\": 4677, \"end\": 4684, \"title\": \"http://dbpedia.org/resource/Rudolf_I_of_Germany\", \"score\": 0.9255711891193825, \"rank\": 0.080193925603598, \"text\": \"Rudolph\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Rudolf_I_of_Germany\", \"dbpedia\": \"http://dbpedia.org/resource/Rudolf_I_of_Germany\"}, {\"begin\": 4730, \"end\": 4737, \"title\": \"http://dbpedia.org/resource/Alabama\", \"score\": 0.9999999803349058, \"rank\": 1.963697709598066e-08, \"text\": \"Alabama\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Alabama\", \"dbpedia\": \"http://dbpedia.org/resource/Alabama\"}], \"noun_phrases\": [{\"ngram\": \"the bombings\", \"from\": 4594, \"to\": 4606}, {\"ngram\": \"a gay nightclub\", \"from\": 4646, \"to\": 4661}, {\"ngram\": \"the Olympic bombing\", \"from\": 4698, \"to\": 4717}]}, {\"sentence\": \"The bombing in Centennial Olympic Park was the first time Rudolph detonated one of his explosives and the largest.\", \"from\": 4740, \"to\": 4854, \"entities\": [{\"begin\": 4798, \"end\": 4805, \"title\": \"http://dbpedia.org/resource/Rudolf_I_of_Germany\", \"score\": 0.9255711891193825, \"rank\": 0.080193925603598, \"text\": \"Rudolph\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Rudolf_I_of_Germany\", \"dbpedia\": \"http://dbpedia.org/resource/Rudolf_I_of_Germany\"}], \"noun_phrases\": [{\"ngram\": \"The bombing\", \"from\": 4740, \"to\": 4751}, {\"ngram\": \"Centennial Olympic Park\", \"from\": 4755, \"to\": 4778}, {\"ngram\": \"the first time\", \"from\": 47