gin\": 8708, \"end\": 8714, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.5794617751176464, \"rank\": 0.7093985075956301, \"text\": \"French\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"the end\", \"from\": 8578, \"to\": 8585}, {\"ngram\": \"a beer bottle\", \"from\": 8617, \"to\": 8630}, {\"ngram\": \"yesterday's arson attacks\", \"from\": 8653, \"to\": 8678}, {\"ngram\": \"some faction\", \"from\": 8692, \"to\": 8704}, {\"ngram\": \"trouble\", \"from\": 8744, \"to\": 8751}]}, {\"sentence\": \"My sense is that this is a nation that's already had to put up with ultraviolent terror attacks, the rise of thegilet jaunes, and then the far right.\", \"from\": 8753, \"to\": 8902, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My sense\", \"from\": 8753, \"to\": 8761}, {\"ngram\": \"a nation\", \"from\": 8778, \"to\": 8786}, {\"ngram\": \"ultraviolent terror attacks\", \"from\": 8821, \"to\": 8848}, {\"ngram\": \"the rise\", \"from\": 8850, \"to\": 8858}, {\"ngram\": \"thegilet jaunes\", \"from\": 8862, \"to\": 8877}, {\"ngram\": \"then the far right\", \"from\": 8883, \"to\": 8901}]}, {\"sentence\": \"They probably do not really have the stomach for another \\\"Libert\\u00e9, \\u00c9galit\\u00e9, Fraternit\\u00e9\\\" firework show.\", \"from\": 8903, \"to\": 9005, \"entities\": [{\"begin\": 8961, \"end\": 8989, \"title\": \"http://dbpedia.org/resource/Libert\\u00e9,_\\u00e9galit\\u00e9,_fraternit\\u00e9\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Libert\\u00e9, \\u00c9galit\\u00e9, Fraternit\\u00e9\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Libert\\u00e9,_\\u00e9galit\\u00e9,_fraternit\\u00e9\", \"dbpedia\": \"http://dbpedia.org/resource/Libert\\u00e9,_\\u00e9galit\\u00e9,_fraternit\\u00e9\"}], \"noun_phrases\": [{\"ngram\": \"the stomach\", \"from\": 8936, \"to\": 8947}]}, {\"sentence\": \"But, clearly, Paris wants the Olympics to usher in some change.\", \"from\": 9007, \"to\": 9070, \"entities\": [{\"begin\": 9021, \"end\": 9026, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 8.531686910764791e-24, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"the Olympics\", \"from\": 9033, \"to\": 9045}, {\"ngram\": \"some change\", \"from\": 9058, \"to\": 9069}]}, {\"sentence\": \"Much like London back in 2012, the French capital has plenty of unfashionable space it would like to see reclaimed, and Saint Denis has its parallels with Stratford.\", \"from\": 9071, \"to\": 9236, \"entities\": [{\"begin\": 9081, \"end\": 9087, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9999999979099812, \"rank\": 2.0903602504530897e-09, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}, {\"begin\": 9106, \"end\": 9112, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.5794617751176464, \"rank\": 0.7093985075956301, \"text\": \"French\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 9197, \"end\": 9202, \"title\": \"http://dbpedia.org/resource/Saint_Denis_of_Paris\", \"score\": 0.9803658043053679, \"rank\": 0.010392175993607308, \"text\": \"Denis\", \"types\": [\"Q729\", \"Q5\", \"Q43115\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Saint_Denis_of_Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Saint_Denis_of_Paris\"}, {\"begin\": 9226, \"end\": 9235, \"title\": \"http://dbpedia.org/resource/Stratford_station\", \"score\": 0.8155737944478726, \"rank\": 0.22613061725140882, \"text\": \"Stratford\", \"types\": [\"Q719456\"], \"wikid\": \"http://dbpedia.org/resource/Stratford_stati