\"ngram\": \"13 per cent market share\", \"from\": 4462, \"to\": 4486}, {\"ngram\": \"the previous ratings period\", \"from\": 4496, \"to\": 4523}, {\"ngram\": \"B105\", \"from\": 4551, \"to\": 4555}, {\"ngram\": \"the biggest loss\", \"from\": 4572, \"to\": 4588}, {\"ngram\": \"cent\", \"from\": 4615, \"to\": 4619}]}, {\"sentence\": \"KIIS, 4JJJ and 4BH increased market share.\", \"from\": 4627, \"to\": 4669, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"KIIS\", \"from\": 4627, \"to\": 4631}, {\"ngram\": \"4JJJ\", \"from\": 4633, \"to\": 4637}, {\"ngram\": \"4BH\", \"from\": 4642, \"to\": 4645}, {\"ngram\": \"increased market share\", \"from\": 4646, \"to\": 4668}]}, {\"sentence\": \"B105 was still the most popular overall (11.9 per cent share), followed by Triple M (11.8 per cent) and Nova (10.3 per cent), while the leading AM station was 4BH (9.5 per cent) followed by 4BC (7.0 per cent), and with ABC Brisbane still languishing (4.2 per cent).\", \"from\": 4671, \"to\": 4936, \"entities\": [{\"begin\": 4746, \"end\": 4754, \"title\": \"http://dbpedia.org/resource/Triple_M\", \"score\": 0.9999999947094693, \"rank\": 5.290247793186722e-09, \"text\": \"Triple M\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Triple_M\", \"dbpedia\": \"http://dbpedia.org/resource/Triple_M\"}, {\"begin\": 4890, \"end\": 4893, \"title\": \"http://dbpedia.org/resource/Australian_Broadcasting_Corporation\", \"score\": 1.0, \"rank\": 5.836406761794125e-21, \"text\": \"ABC\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Australian_Broadcasting_Corporation\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_Broadcasting_Corporation\"}, {\"begin\": 4894, \"end\": 4902, \"title\": \"http://dbpedia.org/resource/Brisbane\", \"score\": 1.0, \"rank\": 5.55527441920157e-33, \"text\": \"Brisbane\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Brisbane\", \"dbpedia\": \"http://dbpedia.org/resource/B