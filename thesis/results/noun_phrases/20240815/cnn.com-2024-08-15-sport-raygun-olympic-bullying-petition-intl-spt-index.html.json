edia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"a 36-year-old university lecturer\", \"from\": 244, \"to\": 277}, {\"ngram\": \"a point\", \"from\": 310, \"to\": 317}, {\"ngram\": \"her battles\", \"from\": 321, \"to\": 332}, {\"ngram\": \"Lithuania'sNicka\", \"from\": 375, \"to\": 391}, {\"ngram\": \"each occasion\", \"from\": 408, \"to\": 421}]}, {\"sentence\": \"Meanwhile, her performance ignited widespread social media commentary and critique.\", \"from\": 423, \"to\": 506, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her performance\", \"from\": 434, \"to\": 449}, {\"ngram\": \"widespread social media commentary\", \"from\": 458, \"to\": 492}, {\"ngram\": \"critique\", \"from\": 497, \"to\": 505}]}, {\"sentence\": \"Related articleAustralian breaker Raygun earns mixed reviews, praised for 'courage' and 'character' after viral performances at Paris Games In a statement on Thursday, the AOC's Chief Executive Officer Matt Carroll criticized the \\\"vexatious, misleading and bullying\\\" petition that \\\"contains numerous falsehoods designed to engender hatred against an athlete who was selected in the Australian Olympic Team through a transparent and independent qualification event and nomination process.\\\"\", \"from\": 508, \"to\": 997, \"entities\": [{\"begin\": 542, \"end\": 548, \"title\": \"http://dbpedia.org/resource/Raygun\", \"score\": 1.0, \"rank\": 8.796407494927517e-24, \"text\": \"Raygun\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Raygun\", \"dbpedia\": \"http://dbpedia.org/resource/Raygun\"}, {\"begin\": 681, \"end\": 684, \"title\": \"http://dbpedia.org/resource/Australian_Olympic_Committee\", \"score\": 0.5824490752954454, \"rank\": 0.7168882953282617, \"text\": \"AOC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Australian_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_Olympic_Committee\"}, {\"begin\": 711, \"end\": 723, \"title\": \"http://dbpedia.org/resource/M