\\\"\", \"from\": 2691, \"to\": 2758, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"tenths\", \"from\": 2713, \"to\": 2719}, {\"ngram\": \"sometimes hundredths\", \"from\": 2724, \"to\": 2744}, {\"ngram\": \"a second\", \"from\": 2748, \"to\": 2756}]}, {\"sentence\": \"Zhao knows a thing or two about winning.\", \"from\": 2760, \"to\": 2800, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Zhao\", \"from\": 2760, \"to\": 2764}, {\"ngram\": \"a thing\", \"from\": 2771, \"to\": 2778}]}, {\"sentence\": \"In May, he told Bloomberg that the firm wasset to break revenue records this year, topping its $7.5 billion in revenue in 2022.\", \"from\": 2801, \"to\": 2928, \"entities\": [{\"begin\": 2817, \"end\": 2826, \"title\": \"http://dbpedia.org/resource/Bloomberg_News\", \"score\": 0.8772349636942496, \"rank\": 0.13985874884696903, \"text\": \"Bloomberg\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Bloomberg_News\", \"dbpedia\": \"http://dbpedia.org/resource/Bloomberg_News\"}], \"noun_phrases\": [{\"ngram\": \"May\", \"from\": 2804, \"to\": 2807}, {\"ngram\": \"revenue records\", \"from\": 2857, \"to\": 2872}, {\"ngram\": \"revenue\", \"from\": 2912, \"to\": 2919}]}, {\"sentence\": \"\\\"Like those swimmers, we often compete to be just a little bit better and faster, and we take home the gold,\\\" he told interns.\", \"from\": 2930, \"to\": 3056, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"those swimmers\", \"from\": 2936, \"to\": 2950}, {\"ngram\": \"the gold\", \"from\": 3029, \"to\": 3037}, {\"ngram\": \"interns\", \"from\": 3048, \"to\": 3055}]}, {\"sentence\": \"\\\"So remember that that's what brought you here into this room.\", \"from\": 3057, \"to\": 3119, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this room\", \"from\": 3109, \"to\": 3118}]}, {\"sentence\": \"That's what will bring you onto the top of the podium.\\\"\", \"from\": 3120, \"to\": 3175, \"entities\": [], \"noun_phrases\": [{\"ng