p://dbpedia.org/resource/Kellie_Harrington\"}], \"noun_phrases\": [{\"ngram\": \"lightweight\", \"from\": 2197, \"to\": 2208}, {\"ngram\": \"60kg\", \"from\": 2210, \"to\": 2214}, {\"ngram\": \"countries\", \"from\": 2220, \"to\": 2229}, {\"ngram\": \"only boxer\", \"from\": 2247, \"to\": 2257}, {\"ngram\": \"weight\", \"from\": 2262, \"to\": 2268}, {\"ngram\": \"reigning Olympic lightweight champion\", \"from\": 2283, \"to\": 2320}, {\"ngram\": \"has already secured qualification\", \"from\": 2339, \"to\": 2372}]}, {\"sentence\": \"The UK do not have a boxer qualified at 60kg though, meaning the pair could potentially meet in Paris, if Broadhurst's application is fast-tracked by the International Olympic Council and she secured a place at the final tournament in Thailand.\", \"from\": 2375, \"to\": 2619, \"entities\": [{\"begin\": 2379, \"end\": 2381, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9988127372364826, \"rank\": 0.0011886318100239005, \"text\": \"UK\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}, {\"begin\": 2471, \"end\": 2476, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999419669637, \"rank\": 5.803314139824949e-08, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 2481, \"end\": 2491, \"title\": \"http://dbpedia.org/resource/Broadhurst_Theatre\", \"score\": 0.9999999998731255, \"rank\": 1.269876360809952e-10, \"text\": \"Broadhurst\", \"types\": [\"Q41176\", \"Q24354\"], \"wikid\": \"http://dbpedia.org/resource/Broadhurst_Theatre\", \"dbpedia\": \"http://dbpedia.org/resource/Broadhurst_Theatre\"}, {\"begin\": 2610, \"end\": 2618, \"title\": \"http://dbpedia.org/resource/Thailand_national_football_team\", \"score\": 0.9812068063543832, \"rank\": 0.014203925912700407, \"text\": \"Thailand\", \"ty