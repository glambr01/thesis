\"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"a sensational switch\", \"from\": 94, \"to\": 114}, {\"ngram\": \"a bid\", \"from\": 153, \"to\": 158}, {\"ngram\": \"the Olympic Games\", \"from\": 174, \"to\": 191}]}, {\"sentence\": \"The Dundalk native previously represented Northern Ireland, qualifying through her English-born father Tony.\", \"from\": 205, \"to\": 313, \"entities\": [{\"begin\": 209, \"end\": 216, \"title\": \"http://dbpedia.org/resource/Dundalk_F.C.\", \"score\": 0.9672486214782099, \"rank\": 0.033860351717576606, \"text\": \"Dundalk\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Dundalk_F.C.\", \"dbpedia\": \"http://dbpedia.org/resource/Dundalk_F.C.\"}, {\"begin\": 247, \"end\": 263, \"title\": \"http://dbpedia.org/resource/Northern_Ireland\", \"score\": 0.9999996956956246, \"rank\": 3.0430451259728237e-07, \"text\": \"Northern Ireland\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Northern_Ireland\", \"dbpedia\": \"http://dbpedia.org/resource/Northern_Ireland\"}], \"noun_phrases\": [{\"ngram\": \"her English-born father\", \"from\": 284, \"to\": 307}, {\"ngram\": \"Tony\", \"from\": 308, \"to\": 312}]}, {\"sentence\": \"Broadhurst was told by the Irish Athletic Boxing Association last week that she would not be going forward to the final Olympic qualifying tournament in May.\", \"from\": 315, \"to\": 472, \"entities\": [{\"begin\": 342, \"end\": 375, \"title\": \"http://dbpedia.org/resource/Irish_Athletic_Boxing_Association\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Irish Athletic Boxing Association\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Irish_Athletic_Boxing_Association\", \"dbpedia\": \"http://dbpedia.org/resource/Irish_Athletic_Boxing_Association\"}], \"noun_phrases\": [{\"ngram\": \"Broadhurst\", \"from\": 315, \"to\": 325}, {\"ngram\": \"the final Olympic qualifying tournament\", \"from\": 425, \"to\": 464}, {\"ngram\": \"May\", \"from\": 468, \"to\": 471}]}, {\"sentence\": \"In a statement released on Twitter tonight, Broadhurst confirmed that she was \\\"exploring all options available to me keep that (Olympic) dream alive.\\\"\", \"from\": 474, \"to\": 624, \"entities\": [{\"begin\": 501, \"end\": 508, \"title\": \"http://dbpedia.org/resource/Twitter\", \"score\": 0.9999999997980922, \"rank\": 2.0193453685682372e-10, \"text\": \"Twitter\", \"types\": [\"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Twitter\", \"dbpedia\": \"http://dbpedia.org/resource/Twitter\"}, {\"begin\": 518, \"end\": 528, \"title\": \"http://dbpedia.org/resource/Broadhurst_Theatre\", \"score\": 0.9999999998731255, \"rank\": 1.269876360809952e-10, \"text\": \"Broadhurst\", \"types\": [\"Q41176\", \"Q24354\"], \"wikid\": \"http://dbpedia.org/resource/Broadhurst_Theatre\", \"dbpedia\": \"http://dbpedia.org/resource/Broadhurst_Theatre\"}], \"noun_phrases\": [{\"ngram\": \"a statement\", \"from\": 477, \"to\": 488}, {\"ngram\": \"all options\", \"from\": 563, \"to\": 574}, {\"ngram\": \"that (Olympic) dream\", \"from\": 596, \"to\": 616}]}, {\"sentence\": \"\\\"I was left broken-hearted and completely devastated when I was informed by the IABA that I would be assessed for selection ahead of the final Olympic qualifier in May and that my Olympic ambitions were effectively over,\\\" Broadhurst wrote.\", \"from\": 626, \"to\": 865, \"entities\": [{\"begin\": 706, \"end\": 710, \"title\": \"http://dbpedia.org/resource/Irish_Athletic_Boxing_Association\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"IABA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Irish_Athletic_Boxing_Association\", \"dbpedia\": \"http://dbpedia.org/resource/Irish_Athletic_Boxing_Association\"}], \"noun_phrases\": [{\"ngram\": \"selection\", \"from\": 740, \"to\": 749}, {\"ngram\": \"the final Olympic qualifier\", \"from\": 759, \"to\": 786}, {\"ngram\": \"May\", \"from\": 790, \"to\": 793}, {\"ngram\": \"my Olympic ambitions\", \"from\": 803, \"to\": 823}, {\"ngram\": \"Broadhurst\", \"from\": 848, \"to\": 858}]}, {\"sentence\": \"\\\"I have won World, European and Commonwealth gold medals and remain the IABA's highest rated boxer in the current world rankings but my lifelong dream has been to become an Olympian.\", \"from\": 867, \"to\": 1049, \"entities\": [{\"begin\": 899, \"end\": 911, \"title\": \"http://dbpedia.org/resource/Commonwealth_Boxing_Council\", \"score\": 0.9471960182560798, \"rank\": 0.05574746065494836, \"text\": \"Commonwealth\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Commonwealth_Boxing_Council\", \"dbpedia\": \"http://dbpedia.org/resource/Commonwealth_Boxing_Council\"}, {\"begin\": 939, \"end\": 943, \"title\": \"http://dbpedia.org/resource/Irish_Athletic_Boxing_Association\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"IABA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Irish_Athletic_Boxing_Association\", \"dbpedia\": \"http://dbpedia.org/resource/Irish_Athletic_Boxing_Association\"}, {\"begin\": 1040, \"end\": 1048, \"title\": \"http://dbpedia.org/resource/Olympic_Games\", \"score\": 0.9999975197992005, \"rank\": 2.480206855992841e-06, \"text\": \"Olympian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games\"}], \"noun_phrases\": [{\"ngram\": \"the current world\", \"from\": 969, \"to\": 986}, {\"ngram\": \"my lifelong dream\", \"from\": 1000, \"to\": 1017}]}, {\"sentence\": \"I have split blood, sweat and tears over 22 years in the boxing ring in pursuit of that childhood goal.\", \"from\": 1050, \"to\": 1153, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"blood\", \"from\": 1063, \"to\": 1068}, {\"ngram\": \"sweat\", \"from\": 1070, \"to\": 1075}, {\"ngram\": \"tears\", \"from\": 1080, \"to\": 1085}, {\"ngram\": \"22 years\", \"from\": 1091, \"to\": 1099}, {\"ngram\": \"the boxing ring\", \"from\": 1103, \"to\": 1118}, {\"ngram\": \"pursuit\", \"from\": 1122, \"to\": 1129}, {\"ngram\": \"that childhood goal\", \"from\": 1133, \"to\": 1152}]}, {\"sentence\": \"\\\"Since being informed of the IABA's decision, I have been exploring all options available to me to keep that dream alive.\", \"from\": 1155, \"to\": 1276, \"entities\": [{\"begin\": 1184, \"end\": 1188, \"title\": \"http://dbpedia.org/resource/Irish_Athletic_Boxing_Association\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"IABA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Irish_Athletic_Boxing_Association\", \"dbpedia\": \"http://dbpedia.org/resource/Irish_Athletic_Boxing_Association\"}], \"noun_phrases\": [{\"ngram\": \"all options\", \"from\": 1223, \"to\": 1234}, {\"ngram\": \"that dream\", \"from\": 1259, \"to\": 1269}]}, {\"sentence\": \"I will continue to do so because the Olympic flame continues to burn brightly in me and I am determined to do everything in my power to become an Olympian.\\\"\", \"from\": 1277, \"to\": 1433, \"entities\": [{\"begin\": 1423, \"end\": 1431, \"title\": \"http://dbpedia.org/resource/Olympic_Games\", \"score\": 0.9999975197992005, \"rank\": 2.480206855992841e-06, \"text\": \"Olympian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games\"}], \"noun_phrases\": [{\"ngram\": \"the Olympic flame\", \"from\": 1310, \"to\": 1327}, {\"ngram\": \"everything\", \"from\": 1387, \"to\": 1397}, {\"ngram\": \"my power\", \"from\": 1401, \"to\": 1409}]}, {\"sentence\": \"pic.twitter.com/xPZ2d6Pic1 Gr\\u00e1inne Walsh defeated Broadhurst in the Irish welterweight (66kg) national final in January 2023.\", \"from\": 1437, \"to\": 1565, \"entities\": [{\"begin\": 1508, \"end\": 1513, \"title\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"score\": 0.9999898089218704, \"rank\": 7.69208138172617e-06, \"text\": \"Irish\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"db