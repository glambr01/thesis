"{\"uid\": \"nypost.com-2024-08-23-us-news-no-cakewalk-east-village-cafe-tracks-down-viral-olympic-village-muffins-flies-them-in-from-france\", \"noun_phrases\": [{\"sentence\": \"Getting these muffins was no cakewalk.\", \"from\": 0, \"to\": 38, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"these muffins\", \"from\": 8, \"to\": 21}, {\"ngram\": \"no cakewalk\", \"from\": 26, \"to\": 37}]}, {\"sentence\": \"An East Village cafe owner and a local foodie got so obsessed with tasting the chocolate muffinsthat went viral duringthe 2024 Olympic games in Paris, they waged a gold medal winning effort to get them from France to the Big Apple.\", \"from\": 40, \"to\": 271, \"entities\": [{\"begin\": 43, \"end\": 55, \"title\": \"http://dbpedia.org/resource/East_Village,_Manhattan\", \"score\": 0.9968205661580373, \"rank\": 0.0010645904504647525, \"text\": \"East Village\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/East_Village,_Manhattan\", \"dbpedia\": \"http://dbpedia.org/resource/East_Village,_Manhattan\"}, {\"begin\": 184, \"end\": 189, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999999999998181, \"rank\": 1.6901033601071226e-12, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 247, \"end\": 253, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9999999311021407, \"rank\": 4.3163749897509756e-08, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 261, \"end\": 270, \"title\": \"http://dbpedia.org/resource/New_York_City\", \"score\": 0.9999999997453415, \"rank\": 2.545203093722153e-10, \"text\": \"Big Apple\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/New_York_City\", \"dbpedia\": \"http://dbpedia.org/resource/New_York_City\"}], \"noun_phrases\": [{\"ngra