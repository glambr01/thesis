rt, toldFortuneathletes have the option, per international regulations, to wear long leggings as part of their kit.\", \"from\": 2390, \"to\": 2559, \"entities\": [{\"begin\": 2390, \"end\": 2404, \"title\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"score\": 0.9999999999977263, \"rank\": 2.461038583932981e-12, \"text\": \"USA Gymnastics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/USA_Gymnastics\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Gymnastics\"}], \"noun_phrases\": [{\"ngram\": \"the national governing body\", \"from\": 2406, \"to\": 2433}, {\"ngram\": \"the sport\", \"from\": 2437, \"to\": 2446}, {\"ngram\": \"toldFortuneathletes\", \"from\": 2448, \"to\": 2467}, {\"ngram\": \"the option\", \"from\": 2473, \"to\": 2483}, {\"ngram\": \"international regulations\", \"from\": 2489, \"to\": 2514}, {\"ngram\": \"long leggings\", \"from\": 2524, \"to\": 2537}, {\"ngram\": \"part\", \"from\": 2541, \"to\": 2545}, {\"ngram\": \"their kit\", \"from\": 2549, \"to\": 2558}]}, {\"sentence\": \"Instead, gymnasts prefer to wear the traditional leotard.\", \"from\": 2560, \"to\": 2617, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"gymnasts\", \"from\": 2569, \"to\": 2577}, {\"ngram\": \"the traditional leotard\", \"from\": 2593, \"to\": 2616}]}, {\"sentence\": \"\\\"We are charged to create this beautiful intersection of fashion and sport and the Team USA leotard represents that at its pinnacle,\\\" GK Elite CEO Matt Cowantold theLos Angeles Times.\", \"from\": 2619, \"to\": 2802, \"entities\": [{\"begin\": 2702, \"end\": 2710, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999987681392979, \"rank\": 1.1520714831567694e-06, \"text\": \"Team USA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 2742, \"end\": 2750, \"title\": \"http://dbpedia.org/resource/Pinnacle\", \"score\": 1.0, \"r