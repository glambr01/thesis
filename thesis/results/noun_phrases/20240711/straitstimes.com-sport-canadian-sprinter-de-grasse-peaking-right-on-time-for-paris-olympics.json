tities\": [{\"begin\": 1137, \"end\": 1143, \"title\": \"http://dbpedia.org/resource/Grasse\", \"score\": 0.9999999999936335, \"rank\": 3.3172552378962127e-12, \"text\": \"Grasse\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Grasse\", \"dbpedia\": \"http://dbpedia.org/resource/Grasse\"}, {\"begin\": 1149, \"end\": 1156, \"title\": \"http://dbpedia.org/resource/Reuters\", \"score\": 0.999999999998181, \"rank\": 1.6048331298887462e-12, \"text\": \"Reuters\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Reuters\", \"dbpedia\": \"http://dbpedia.org/resource/Reuters\"}], \"noun_phrases\": [{\"ngram\": \"the highest stage\", \"from\": 921, \"to\": 938}, {\"ngram\": \"something\", \"from\": 954, \"to\": 963}, {\"ngram\": \"all the hard work\", \"from\": 1016, \"to\": 1033}, {\"ngram\": \"a lot\", \"from\": 1043, \"to\": 1048}, {\"ngram\": \"sacrifices\", \"from\": 1052, \"to\": 1062}, {\"ngram\": \"these moments\", \"from\": 1067, \"to\": 1080}, {\"ngram\": \"an interview\", \"from\": 1160, \"to\": 1172}]}, {\"sentence\": \"\\\"When I put on that bib and I put on that (Canada) uniform, knowing that I am not just representing myself, I am representing my country, my family, my friends, it inspires me and gives me that motivation to just go out there and give it my all.\\\"\", \"from\": 1175, \"to\": 1421, \"entities\": [{\"begin\": 1218, \"end\": 1224, \"title\": \"http://dbpedia.org/resource/Canada\", \"score\": 0.7374162308127941, \"rank\": 0.3541483713771258, \"text\": \"Canada\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Canada\", \"dbpedia\": \"http://dbpedia.org/resource/Canada\"}], \"noun_phrases\": [{\"ngram\": \"that bib\", \"from\": 1190, \"to\": 1198}, {\"ngram\": \"my country\", \"from\": 1301, \"to\": 1311}, {\"ngram\": \"my family\", \"from\": 1313, \"to\": 1322}, {\"ngram\": \"my friends\", \"from\": 1324, \"to\": 1334}, {\"ngram\": \"that motivation\", \"from\": 1364, \"to\": 1379}]}, {\"sentence\": \"De Grasse has taken a patient approach by racing in smaller meets, and on Tuesday the Olympic 200 metres champion finally dipped under the 20-second barrier in that event for the first time this season in winning the Gyulai Istvan Memorial in Hungary.\", \"from\": 1423, \"to\": 1674, \"entities\": [{\"begin\": 1426, \"end\": 1432, \"title\": \"http://dbpedia.org/resource/Grasse\", \"score\": 0.9999999999936335, \"rank\": 3.3172552378962127e-12, \"text\": \"Grasse\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Grasse\", \"dbpedia\": \"http://dbpedia.org/resource/Grasse\"}, {\"begin\": 1666, \"end\": 1673, \"title\": \"http://dbpedia.org/resource/Hungary\", \"score\": 0.999968688988684, \"rank\": 3.1166081315303144e-05, \"text\": \"Hungary\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Hungary\", \"dbpedia\": \"http://dbpedia.org/resource/Hungary\"}], \"noun_phrases\": [{\"ngram\": \"a patient approach\", \"from\": 1443, \"to\": 1461}, {\"ngram\": \"smaller meets\", \"from\": 1475, \"to\": 1488}, {\"ngram\": \"Tuesday\", \"from\": 1497, \"to\": 1504}, {\"ngram\": \"the Olympic 200 metres champion\", \"from\": 1505, \"to\": 1536}, {\"ngram\": \"the 20-second barrier\", \"from\": 1558, \"to\": 1579}, {\"ngram\": \"that event\", \"from\": 1583, \"to\": 1593}, {\"ngram\": \"the first time\", \"from\": 1598, \"to\": 1612}, {\"ngram\": \"the Gyulai Istvan Memorial\", \"from\": 1636, \"to\": 1662}]}, {\"sentence\": \"Patience can prove fleeting, however, when rivals such as Americans Noah Lyles and Kenny Bednarek -- who have the top two times this season of 19.53 and 19.59 respectively -- are laying down quick performances.\", \"from\": 1676, \"to\": 1886, \"entities\": [{\"begin\": 1744, \"end\": 1754, \"title\": \"http://dbpedia.org/resource/Noah_Lyles\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Noah Lyles\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Noah_Lyles\", \"dbpedia\": \"http://dbpedia.org/resource/Noah_Lyles\"}, {\"begin\": 1759, \"end\": 1773, \"title\": \"http://dbpedia.org/resource/Kenny_Bednarek\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Kenny Bednarek\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kenny_Bednarek\", \"dbpedia\": \"http://dbpedia.org/resource/Kenny_Bednarek\"}], \"noun_phrases\": [{\"ngram\": \"Patience\", \"from\": 1676, \"to\": 1684}, {\"ngram\": \"rivals\", \"from\": 1719, \"to\": 1725}, {\"ngram\": \"quick performances\", \"from\": 1867, \"to\": 1885}]}, {\"sentence\": \"\\\"It is hard to stay patient, but they are on a different plan than me,\\\" De Grasse said.\", \"from\": 1888, \"to\": 1975, \"entities\": [{\"begin\": 1963, \"end\": 1969, \"title\": \"http://dbpedia.org/resource/Grasse\", \"score\": 0.9999999999936335, \"rank\": 3.3172552378962127e-12, \"text\": \"Grasse\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Grasse\", \"dbpedia\": \"http://dbpedia.org/resource/Grasse\"}], \"noun_phrases\": [{\"ngram\": \"a different plan\", \"from\": 1933, \"to\": 1949}]}, {\"sentence\": \"\\\"But I have had time to be patient to say 'okay, I do not have to run as fast right now.\", \"from\": 1976, \"to\": 2064, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"time\", \"from\": 1992, \"to\": 1996}]}, {\"sentence\": \"I can work on some things and train through it so that when it matters I am more fresh and I am more ready.'\", \"from\": 2065, \"to\": 2173, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"some things\", \"from\": 2079, \"to\": 2090}]}, {\"sentence\": \"\\\"I do not want to start off my season too early, so chose to go to more low-key meets where there is not as much stiff competition, so I could work on some things and get better.\", \"from\": 2175, \"to\": 2353, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my season\", \"from\": 2203, \"to\": 2212}, {\"ngram\": \"more low-key meets\", \"from\": 2242, \"to\": 2260}, {\"ngram\": \"as much stiff competition\", \"from\": 2280, \"to\": 2305}, {\"ngram\": \"some things\", \"from\": 2326, \"to\": 2337}]}, {\"sentence\": \"\\\"I started off my season late, I knew it's not going to make sense if I am in only 10.1 (for the 100m) or 20.2 shape, and these guys are already running sub-10 and sub-20.\", \"from\": 2355, \"to\": 2526, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my season\", \"from\": 2370, \"to\": 2379}, {\"ngram\": \"sense\", \"from\": 2416, \"to\": 2421}, {\"ngram\": \"these guys\", \"from\": 2477, \"to\": 2487}, {\"ngram\": \"sub-20\", \"from\": 2519, \"to\": 2525}]}, {\"sentence\": \"My coach was like, let us just pull back, train and let us just compete locally and try to work on some things.\\\"\", \"from\": 2527, \"to\": 2639, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My coach\", \"from\": 2527, \"to\": 2535}, {\"ngram\": \"us\", \"from\": 2550, \"to\": 2552}, {\"ngram\": \"us\", \"from\": 2583, \"to\": 2585}, {\"ngram\": \"some things\", \"from\": 2626, \"to\": 2637}]}, {\"sentence\": \"LA OLYMPICS De Grasse's six Olympic medals make him Canada's most decorated male Summer Olympian.\", \"from\": 2641, \"to\": 2739, \"entities\": [{\"begin\": 2657, \"end\": 2663, \"title\": \"http://dbpedia.org/resource/Grasse\", \"score\": 0.9999999999936335, \"rank\": 3.3172552378962127e-12, \"text\": \"Grasse\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Grasse\", \"dbpedia\": \"http://dbpedia.org/resource/Grasse\"}], \"noun_phrases\": []}, {\"sentence\": \"He has no plans to stop after Paris either.\", \"from\": 2740, \"to\": 2783, \"entities\": [{\"begin\": 2770, \"end\": 2775, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999977263, \"rank\": 2.4408806322379054e-12, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"no plans\", \"from\": 2747, \"to\": 2755}]}, {\"sentence\": \"De Grasse, whose interview was part of a promotional campaign with sponsor Invisalign, is keen to race at next year's World Championships in Tokyo after winning 2020 Olympic gold in a virtually empty stadium there due to the COVID-19 pandemic.\", \"from\": 2785, \"to\": 3028, \"entities\": [{\"begin\": 2788, \"end\": 2794, \"title\": \"http://dbpedia.org/resource/Grasse\", \"score\": 0.9999999999936335, \"rank\": 3.3172552378962127e-12, \"text\": \"Grasse\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Grasse\", \"dbpedia\": \"http://dbpedia.org/resource/Grasse\"}, {\"begin\": 2860, \"end\": 2870, \"title\": \"http://dbpedia.org/resource/Align_Technology\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Invisalign\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Align_Technology\", \"dbpedia\": \"http://dbpedia.org/resource/Align_Technology\"}, {\"begin\": 2926, \"end\": 2931, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.9999285911189544, \"rank\": 7.141379180297272e-05, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}, {\"begin\": 3010, \"end\": 3027, \"title\": \"http://dbpedia.org/resource/COVID-19_pandemic\", \"score\": 0.9998627122697167, \"rank\": 0.0001372720039835435, \"text\": \"COVID-19 pandemic\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/COVID-19_pandemic\", \"dbpedia\": \"http://dbpedia.org/resource/COVID-19_pandemic\"}], \"noun_phrases\": [{\"ngram\": \"whose interview\", \"from\": 2796, \"to\": 2811}, {\"ngram\": \"part\", \"from\": 2816, \"to\": 2820}, {\"ngram\": \"a promotional campaign\", \"from\": 2824, \"to\": 2846}, {\"ngram\": \"next year's World Championships\", \"from\": 2891, \"to\": 2922}, {\"ngram\": \"2020 Olympic gold\", \"from\": 2946, \"to\": 2963}, {\"ngram\": \"a virtually empty stadium\", \"from\": 2967, \"to\": 2992}]}, {\"sentence\": \"He would like to carry on until at least the 2028 Los Angeles Olympics.\", \"from\": 3030, \"to\": 3101, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"at least the 2028 Los Angeles Olympics\", \"from\": 3062, \"to\": 3100}]}, {\"sentence\": \"\\\"People around me are always saying, 'Andre you can go longer than you think, you got into the sport so late, 16, 17, you do not have that mileage that other people have who have been running since they were kids (have),'\\\" De Grasse said.\", \"from\": 3103, \"to\": 3341, \"entities\": [{\"begin\": 3329, \"end\": 3335, \"title\": \"http://dbpedia.org/resource/Grasse\", \"score\": 0.9999999999936335, \"rank\": 3.3172552378962127e-12, \"text\": \"Grasse\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Grasse\", \"dbpedia\": \"http://dbpedia.org/resource/Grasse\"}], \"noun_phrases\": [{\"ngram\": \"People\", \"from\": 3104, \"to\": 3110}, {\"ngram\": \"the sport\", \"from\": 3194, \"to\": 3203}, {\"ngram\": \"that mileage\", \"from\": 3237, \"to\": 3249}, {\"ngram\": \"other people\", \"from\": 3255, \"to\": 3267}, {\"ngram\": \"kids\", \"from\": 3311, \"to\": 3315}]}, {\"sentence\": \"De Grasse was a top basketball player before he famously ran a high school 100m race from a standing start in basketball shorts and borrowed spikes.\", \"from\": 3343, \"to\": 3491, \"entities\": [{\"begin\": 3346, \"end\": 3352, \"title\": \"http://dbpedia.org/resource/Grasse\", \"score\": 0.9999999999936335, \"rank\": 3.3172552378962127e-12, \"text\": \"Grasse\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Grasse\", \"dbpedia\": \"http://dbpedia.org/resource/Grasse\"}], \"noun_phrases\": [{\"ngram\": \"a top basketball player\", \"from\": 3357, \"to\": 3380}, {\"ngram\": \"a high school\", \"from\": 3404, \"to\"