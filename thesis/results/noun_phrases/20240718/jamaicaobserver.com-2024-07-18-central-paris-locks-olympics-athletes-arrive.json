62}, {\"ngram\": \"50 per cent\", \"from\": 1675, \"to\": 1686}, {\"ngram\": \"a senior waiter\", \"from\": 1702, \"to\": 1717}, {\"ngram\": \"the famed Deux Magots cafe\", \"from\": 1721, \"to\": 1747}, {\"ngram\": \"Saint-German-des-Pres\", \"from\": 1751, \"to\": 1772}, {\"ngram\": \"the new security perimeter\", \"from\": 1790, \"to\": 1816}, {\"ngram\": \"Thursday\", \"from\": 1827, \"to\": 1835}]}, {\"sentence\": \"\\\"Normally we have people queuing out the door,\\\" he told AFP, gesturing towards the numerous empty seats on the outdoor terrace.\", \"from\": 1838, \"to\": 1965, \"entities\": [{\"begin\": 1894, \"end\": 1897, \"title\": \"http://dbpedia.org/resource/Agence_France-Presse\", \"score\": 0.9825196077636744, \"rank\": 0.017791391954319797, \"text\": \"AFP\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Agence_France-Presse\", \"dbpedia\": \"http://dbpedia.org/resource/Agence_France-Presse\"}], \"noun_phrases\": [{\"ngram\": \"people\", \"from\": 1856, \"to\": 1862}, {\"ngram\": \"the door\", \"from\": 1875, \"to\": 1883}, {\"ngram\": \"the numerous empty seats\", \"from\": 1917, \"to\": 1941}, {\"ngram\": \"the outdoor terrace\", \"from\": 1945, \"to\": 1964}]}, {\"sentence\": \"Elsewhere on Thursday, the first athletes arrived at the newly built Olympic Village in the Saint-Ouen northern suburb of the capital which urban planners are hoping to regenerate.\", \"from\": 1967, \"to\": 2147, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Thursday\", \"from\": 1980, \"to\": 1988}, {\"ngram\": \"the first athletes\", \"from\": 1990, \"to\": 2008}, {\"ngram\": \"the newly built Olympic Village\", \"from\": 2020, \"to\": 2051}, {\"ngram\": \"the Saint-Ouen northern suburb\", \"from\": 2055, \"to\": 2085}, {\"ngram\": \"the capital\", \"from\": 2089, \"to\": 2100}, {\"ngram\": \"urban planners\", \"from\": 2107, \"to\": 2121}]}, {\"sentence\": \"Comprising 40 different low-rise housing blocs, the complex has been built as a showcase of innovative construction techniques using low-carbon concrete, water recycling and reclaimed building materials.\", \"from\": 2149, \"to\": 2352, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"40 different low-rise housing blocs\", \"from\": 2160, \"to\": 2195}, {\"ngram\": \"the complex\", \"from\": 2197, \"to\": 2208}, {\"ngram\": \"a showcase\", \"from\": 2227, \"to\": 2237}, {\"ngram\": \"innovative construction techniques\", \"from\": 2241, \"to\": 2275}, {\"ngram\": \"low-carbon concrete\", \"from\": 2282, \"to\": 2301}, {\"ngram\": \"water recycling\", \"from\": 2303, \"to\": 2318}, {\"ngram\": \"reclaimed building materials\", \"from\": 2323, \"to\": 2351}]}, {\"sentence\": \"It was also intended to be free of air-conditioning, but Olympic delegations have ordered around 2,500 portable cooling units for their athletes out of fear of high temperatures.\", \"from\": 2354, \"to\": 2532, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"air-conditioning\", \"from\": 2389, \"to\": 2405}, {\"ngram\": \"Olympic delegations\", \"from\": 2411, \"to\": 2430}, {\"ngram\": \"around 2,500 portable cooling units\", \"from\": 2444, \"to\": 2479}, {\"ngram\": \"their athletes\", \"from\": 2484, \"to\": 2498}, {\"ngram\": \"fear\", \"from\": 2506, \"to\": 2510}, {\"ngram\": \"high temperatures\", \"from\": 2514, \"to\": 2531}]}, {\"sentence\": \"\\\"We are super excited to check how it's looking,\\\" Australian hockey player Stephanie Kershaw told AFP as she waited to enter the village.\", \"from\": 2534, \"to\": 2671, \"entities\": [{\"begin\": 2584, \"end\": 2608, \"title\": \"http://dbpedia.org/resource/Australia_men's_national_field_hockey_team\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Australian hockey player\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Australia_men's_national_field_hockey_team\", \"dbpedia\": \"http://dbpedia.org/resource/Australia_men's_national_field_hockey_team\"}, {\"begin\": 2609, \"end\": 2