m\": 1032, \"to\": 1231, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"July\", \"from\": 1042, \"to\": 1046}, {\"ngram\": \"the Olympics\", \"from\": 1067, \"to\": 1079}, {\"ngram\": \"a fun trip\", \"from\": 1096, \"to\": 1106}, {\"ngram\": \"the negative integers portion\", \"from\": 1115, \"to\": 1144}, {\"ngram\": \"your calendar\", \"from\": 1148, \"to\": 1161}, {\"ngram\": \"a handful\", \"from\": 1166, \"to\": 1175}, {\"ngram\": \"the opening ceremony\", \"from\": 1209, \"to\": 1229}]}, {\"sentence\": \"Men\\u00e2\\u0080\\u0099s soccer\\u00e2\\u0080\\u0094featuring under-23 squads with up to three overage players\\u00e2\\u0080\\u0094kicks off on Day \\u00e2\\u0080\\u00932, and the U.S. will face the hosts at the famed Marseille Stadium, aka Stade V\\u00c3\\u00a9lodrome.\\u00c2 Day \\u00e2\\u0080\\u00931, July 25 Since being introduced in 2016, rugby sevens has become a Games staple.\", \"from\": 1232, \"to\": 1512, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"under-23 squads\", \"from\": 1259, \"to\": 1274}, {\"ngram\": \"up to three overage players\\u00e2\\u0080\\u0094kicks\", \"from\": 1280, \"to\": 1315}, {\"ngram\": \"Day\", \"from\": 1323, \"to\": 1326}, {\"ngram\": \"the U.S.\", \"from\": 1337, \"to\": 1345}, {\"ngram\": \"the hosts\", \"from\": 1356, \"to\": 1365}, {\"ngram\": \"the famed Marseille Stadium\", \"from\": 1369, \"to\": 1396}, {\"ngram\": \"aka Stade V\\u00c3\\u00a9lodrome\", \"from\": 1398, \"to\": 1418}, {\"ngram\": \"rugby\", \"from\": 1471, \"to\": 1476}, {\"ngram\": \"a Games staple\", \"from\": 1495, \"to\": 1509}]}, {\"sentence\": \"It\\u00e2\\u0080\\u0099s fast-paced, with matches played in frantic seven-minute halves, and it happens over just six competition days, so catch some action while you can.\", \"from\": 1513, \"to\": 1666, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"It\\u00e2\\u0080\\u0099s\", \"from\": 1513, \"to\": 1519}, {\"ngram\": \"matches\", \"from\": 1537, \"to\": 1544}, {\"ngram\": \"frantic sev