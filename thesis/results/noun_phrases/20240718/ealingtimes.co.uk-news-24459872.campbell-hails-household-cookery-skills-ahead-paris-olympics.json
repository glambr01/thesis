"{\"uid\": \"ealingtimes.co.uk-news-24459872.campbell-hails-household-cookery-skills-ahead-paris-olympics\", \"noun_phrases\": [{\"sentence\": \"Sport If Emily Campbell wasn't an Olympic weightlifter there is a good chance she could have been a chef.\", \"from\": 0, \"to\": 106, \"entities\": [{\"begin\": 10, \"end\": 24, \"title\": \"http://dbpedia.org/resource/Emily_Campbell\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Emily Campbell\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emily_Campbell\", \"dbpedia\": \"http://dbpedia.org/resource/Emily_Campbell\"}], \"noun_phrases\": [{\"ngram\": \"Sport\", \"from\": 0, \"to\": 5}, {\"ngram\": \"an Olympic weightlifter\", \"from\": 31, \"to\": 54}, {\"ngram\": \"a good chance\", \"from\": 64, \"to\": 77}, {\"ngram\": \"a chef\", \"from\": 98, \"to\": 104}]}, {\"sentence\": \"The Tokyo 2020 silver medallist says food is a recurring theme in the Campbell household, with her mother a former chef and her father whipping up an array of Caribbean cuisine on a daily basis.\", \"from\": 108, \"to\": 302, \"entities\": [{\"begin\": 112, \"end\": 117, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.999979640136544, \"rank\": 1.790324009847412e-05, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}, {\"begin\": 178, \"end\": 186, \"title\": \"http://dbpedia.org/resource/Clan_Campbell\", \"score\": 0.9999999999108695, \"rank\": 8.915148524138804e-11, \"text\": \"Campbell\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Clan_Campbell\", \"dbpedia\": \"http://dbpedia.org/resource/Clan_Campbell\"}], \"noun_phrases\": [{\"ngram\": \"food\", \"from\": 145, \"to\": 149}, {\"ngram\": \"a recurring theme\", \"from\": 153, \"to\": 170}, {\"ngram\": \"her mother\", \"from\": 203, \"to\": 213}, {\"ngram\": \"a former chef\", \"from\": 214, \"to\": 227}, {\"ngram\": \"her father\", \"from\": 232, \"to\": 242}, {\"ngram\": \"an array\", \"from\": 255, \"to\": 263}, {\"ngram\": \"Caribbean cuisine\", \"from\": 267, \"to\": 284}, {\"ngram\": \"a daily basis\", \"from\": 288, \"to\": 301}]}, {\"sentence\": \"In fact, the entire family is blessed with skills in the kitchen - skills so strong it comes as a detriment to her sister Kelsie, who Campbell reluctantly ranked at the bottom of the pile when it comes to cooking.\", \"from\": 304, \"to\": 517, \"entities\": [{\"begin\": 438, \"end\": 446, \"title\": \"http://dbpedia.org/resource/Clan_Campbell\", \"score\": 0.9999999999108695, \"rank\": 8.915148524138804e-11, \"text\": \"Campbell\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Clan_Campbell\", \"dbpedia\": \"http://dbpedia.org/resource/Clan_Campbell\"}], \"noun_phrases\": [{\"ngram\": \"fact\", \"from\": 307, \"to\": 311}, {\"ngram\": \"the entire family\", \"from\": 313, \"to\": 330}, {\"ngram\": \"skills\", \"from\": 347, \"to\": 353}, {\"ngram\": \"the kitchen - skills\", \"from\": 357, \"to\": 377}, {\"ngram\": \"a detriment\", \"from\": 400, \"to\": 411}, {\"ngram\": \"her sister\", \"from\": 415, \"to\": 425}, {\"ngram\": \"Kelsie\", \"from\": 426, \"to\": 432}, {\"ngram\": \"the bottom\", \"from\": 469, \"to\": 479}, {\"ngram\": \"the pile\", \"from\": 483, \"to\": 491}, {\"ngram\": \"cooking\", \"from\": 509, \"to\": 516}]}, {\"sentence\": \"\\\"I have to give everybody credit, because everybody in our family can cook,\\\" said Campbell, speaking as a newly-appointed Home Team Hero for Old El Paso as anticipation builds for the Paris 2024 Olympics.\", \"from\": 519, \"to\": 723, \"entities\": [{\"begin\": 601, \"end\": 609, \"title\": \"http://dbpedia.org/resource/Clan_Campbell\", \"score\": 0.9999999999108695, \"rank\": 8.915148524138804e-11, \"text\": \"Campbell\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Clan_Campbell\", \"dbpedia\": \"http://dbpedia.org/resource/Clan_Campbell\"}, {\"b