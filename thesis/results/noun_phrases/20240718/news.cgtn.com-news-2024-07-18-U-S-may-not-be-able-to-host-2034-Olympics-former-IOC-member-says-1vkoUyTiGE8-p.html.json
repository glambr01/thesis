 \"from\": 275, \"to\": 549, \"entities\": [{\"begin\": 313, \"end\": 326, \"title\": \"http://dbpedia.org/resource/Federal_government_of_the_United_States\", \"score\": 0.7410470553967945, \"rank\": 0.3494419722807598, \"text\": \"United States\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Federal_government_of_the_United_States\", \"dbpedia\": \"http://dbpedia.org/resource/Federal_government_of_the_United_States\"}, {\"begin\": 448, \"end\": 455, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.8064339059571526, \"rank\": 0.23984162917781116, \"text\": \"Chinese\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}, {\"begin\": 493, \"end\": 530, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee (IOC)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"/CFP\", \"from\": 275, \"to\": 279}, {\"ngram\": \"a possibility\", \"from\": 289, \"to\": 302}, {\"ngram\": \"the 2024 Winter Olympics\", \"from\": 350, \"to\": 374}, {\"ngram\": \"its law enforcement authorities\", \"from\": 378, \"to\": 409}, {\"ngram\": \"their investigation\", \"from\": 424, \"to\": 443}]}, {\"sentence\": \"Pound, who is also the World Anti-Doping Agency's founding president, told Reuters that the Rodchenkov Act the U.S. is using to investigate the contamination case of 23 Chinese swimmers is non-compliant with the world anti-doping code.\", \"from\": 551, \"to\": 786, \"entities\": [{\"begin\": 626, \"end\": 633, \"title\": \"http://dbpedia.org/resource/Reuters\", \"score\": 0.9999999998024123, \"rank\": 1.9748274678093485e-10, \"text\": \"Reuters\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Reuters\", \"dbpedia\": \"http://dbpedia.org/resource/Reuters\"}, {\"begin\": 720, \"end\": 727, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.8064339059571526, \"rank\": 0.23984162917781116, \"text\": \"Chinese\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}], \"noun_phrases\": [{\"ngram\": \"Pound\", \"from\": 551, \"to\": 556}, {\"ngram\": \"the World Anti-Doping Agency's founding president\", \"from\": 570, \"to\": 619}, {\"ngram\": \"the Rodchenkov Act\", \"from\": 639, \"to\": 657}, {\"ngram\": \"the U.S.\", \"from\": 658, \"to\": 666}, {\"ngram\": \"the contamination case\", \"from\": 691, \"to\": 713}, {\"ngram\": \"the world anti-doping code\", \"from\": 759, \"to\": 785}]}, {\"sentence\": \"Countries that fall out of compliance with the code are not allowed to compete in or stage international sporting events.\", \"from\": 788, \"to\": 909, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Countries\", \"from\": 788, \"to\": 797}, {\"ngram\": \"compliance\", \"from\": 815, \"to\": 825}, {\"ngram\": \"the code\", \"from\": 831, \"to\": 839}, {\"ngram\": \"international sporting events\", \"from\": 879, \"to\": 908}]}, {\"sentence\": \"The Rodchenkov Act gives the United States broad extraterritorial jurisdiction over any international sporting competitions that include American athletes or have financial connections to the U.S.. \\\"My guess is that one of the steps that WADA is going to take at this point is to turn this particular issue over to the compliance review committee, which I suspect, if or when there is a hearing on it, they will declare the U.S. non-compliant.\", \"from\": 911, \"to\": 1355, \"entities\": [{\"begin\": 940, \"end\": 953, \"title\": \"http://dbpedia.org/resource/Federal_government_of_the_United_States\", \"score\": 0.7410470553967945, \"rank\": 0.3494419722807598, \"text\": \"United States\", \"types\": []