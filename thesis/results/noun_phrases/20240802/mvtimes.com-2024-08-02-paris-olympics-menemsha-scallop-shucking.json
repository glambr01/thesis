 \"entities\": [{\"begin\": 1353, \"end\": 1361, \"title\": \"http://dbpedia.org/resource/Menemsha,_Massachusetts\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Menemsha\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Menemsha,_Massachusetts\", \"dbpedia\": \"http://dbpedia.org/resource/Menemsha,_Massachusetts\"}], \"noun_phrases\": [{\"ngram\": \"The brothers\", \"from\": 1283, \"to\": 1295}, {\"ngram\": \"the Homeport Restaurant\", \"from\": 1321, \"to\": 1344}, {\"ngram\": \"a suggested $3 donation\", \"from\": 1380, \"to\": 1403}]}, {\"sentence\": \"Board president of the preservation trust, John Keene, said the event is an opportunity to show a full presentation of what the fishing industry is all about.\", \"from\": 1406, \"to\": 1564, \"entities\": [{\"begin\": 1449, \"end\": 1459, \"title\": \"http://dbpedia.org/resource/John_Keene_(writer)\", \"score\": 0.9999659344680225, \"rank\": 0.0, \"text\": \"John Keene\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/John_Keene_(writer)\", \"dbpedia\": \"http://dbpedia.org/resource/John_Keene_(writer)\"}], \"noun_phrases\": [{\"ngram\": \"Board president\", \"from\": 1406, \"to\": 1421}, {\"ngram\": \"the preservation trust\", \"from\": 1425, \"to\": 1447}, {\"ngram\": \"the event\", \"from\": 1466, \"to\": 1475}, {\"ngram\": \"an opportunity\", \"from\": 1479, \"to\": 1493}, {\"ngram\": \"a full presentation\", \"from\": 1502, \"to\": 1521}, {\"ngram\": \"the fishing industry\", \"from\": 1530, \"to\": 1550}]}, {\"sentence\": \"And it was obvious to onlookers through drinks, toasted on boat decks, and friendly jabs made between competition contestants, that the event was also a coming-together and a physical representation of the heart of the fishing village.\", \"from\": 1565, \"to\": 1800, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"onlookers\", \"from\": 1587, \"to\": 1596}, {\"ngram\": \"drinks\", \"from\": 1605, \"to\": 1611}, {\"ngram\": \"boat decks\", \"from\": 1624, \"to\": 1634}, {\"ngram\": \"competition contestants\", \"from\": 1667, \"to\": 1690}, {\"ngram\": \"the event\", \"from\": 1697, \"to\": 1706}, {\"ngram\": \"a coming-together\", \"from\": 1716, \"to\": 1733}, {\"ngram\": \"a physical representation\", \"from\": 1738, \"to\": 1763}, {\"ngram\": \"the heart\", \"from\": 1767, \"to\": 1776}, {\"ngram\": \"the fishing village\", \"from\": 1780, \"to\": 1799}]}, {\"sentence\": \"\\\"It's a rebirth of the fleet down here,\\\" Keene said.\", \"from\": 1802, \"to\": 1854, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a rebirth\", \"from\": 1808, \"to\": 1817}, {\"ngram\": \"the fleet\", \"from\": 1821, \"to\": 1830}, {\"ngram\": \"Keene\", \"from\": 1843, \"to\": 1848}]}, {\"sentence\": \"\\\"People are investing in it.\\\"\", \"from\": 1855, \"to\": 1884, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"People\", \"from\": 1856, \"to\": 1862}]}, {\"sentence\": \"Not only could community members and visitors talk to commercial fishermen right from their floating havens, they could hop onto the Coast Guard's 47-foot search-and-rescue boat, the Massachusetts State Police's 37-foot moose boat, and the state's Environmental Police 31-foot boat.\", \"from\": 1886, \"to\": 2168, \"entities\": [{\"begin\": 2019, \"end\": 2030, \"title\": \"http://dbpedia.org/resource/United_States_Coast_Guard\", \"score\": 0.999999999990905, \"rank\": 9.215493931132104e-12, \"text\": \"Coast Guard\", \"types\": [\"Q43229\", \"Q24229398\", \"Q176799\"], \"wikid\": \"http://dbpedia.org/resource/United_States_Coast_Guard\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_Coast_Guard\"}, {\"begin\": 2069, \"end\": 2082, \"title\": \"http://dbpedia.org/resource/Massachusetts\", \"score\": 1.0, \"rank\": 1.471152140221208e-14, \"text\": \"Massachusetts\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Massachusetts\", \"dbpedia\": \"http://dbpedia.org/resource/Massachusetts\"}, {\"begin\": 2134, \"end\": 2154, \"title\": \"http