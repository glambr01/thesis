]}, {\"sentence\": \"Mentally, I think she's coping with the pressure of the event really well as well.\", \"from\": 2773, \"to\": 2855, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the pressure\", \"from\": 2809, \"to\": 2821}, {\"ngram\": \"the event\", \"from\": 2825, \"to\": 2834}]}, {\"sentence\": \"She's got a good support network around her coaches out here as well as all my coaching team around her and I think her entire family - I am not kidding - is out here as well.\", \"from\": 2856, \"to\": 3031, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a good support network\", \"from\": 2866, \"to\": 2888}, {\"ngram\": \"her coaches\", \"from\": 2896, \"to\": 2907}, {\"ngram\": \"all my coaching team\", \"from\": 2928, \"to\": 2948}, {\"ngram\": \"her entire family\", \"from\": 2972, \"to\": 2989}]}, {\"sentence\": \"\\\"I think she feels well supported.\", \"from\": 3033, \"to\": 3067, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I think that's helping her case as well she has an extremely strong start.\", \"from\": 3068, \"to\": 3142, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her case\", \"from\": 3091, \"to\": 3099}, {\"ngram\": \"an extremely strong start\", \"from\": 3116, \"to\": 3141}]}, {\"sentence\": \"She just needs to kind of perfect the first jump a little bit and some of the other jumps.\", \"from\": 3143, \"to\": 3233, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the first jump\", \"from\": 3177, \"to\": 3191}, {\"ngram\": \"the other jumps\", \"from\": 3217, \"to\": 3232}]}, {\"sentence\": \"But I think she will definitely stick her nose in that first turn.\", \"from\": 3234, \"to\": 3300, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her nose\", \"from\": 3272, \"to\": 3280}, {\"ngram\": \"that first turn\", \"from\": 3284, \"to\": 3299}]}, {\"sentence\": \"Watch for her.\", \"from\": 3301, \"to\": 3315, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"It'd be amazing if she could make the final