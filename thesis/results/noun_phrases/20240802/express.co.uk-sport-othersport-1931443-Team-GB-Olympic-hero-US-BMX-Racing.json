iscipline\", \"from\": 951, \"to\": 965}, {\"ngram\": \"the line\", \"from\": 981, \"to\": 989}, {\"ngram\": \"a stacked roster\", \"from\": 1021, \"to\": 1037}, {\"ngram\": \"cautiously optimistic heading\", \"from\": 1051, \"to\": 1080}, {\"ngram\": \"Friday's semis\", \"from\": 1086, \"to\": 1100}, {\"ngram\": \"finals\", \"from\": 1105, \"to\": 1111}, {\"ngram\": \"the Saint Quentin-en-Yvelines track\", \"from\": 1115, \"to\": 1150}]}, {\"sentence\": \"UCI World Champion Alise Willoughby appears to be Team USA's best shot - but she faces a tough fight against on-fire Aussie Saya Sakakibara, and reigning Olympic champion Bethany Shriever of Team GB.\", \"from\": 1153, \"to\": 1352, \"entities\": [{\"begin\": 1153, \"end\": 1156, \"title\": \"http://dbpedia.org/resource/Union_Cycliste_Internationale\", \"score\": 0.9999999999777174, \"rank\": 2.2386722684333918e-11, \"text\": \"UCI\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Union_Cycliste_Internationale\", \"dbpedia\": \"http://dbpedia.org/resource/Union_Cycliste_Internationale\"}, {\"begin\": 1157, \"end\": 1171, \"title\": \"http://dbpedia.org/resource/World_championship\", \"score\": 0.9489152268680833, \"rank\": 0.053834910312541805, \"text\": \"World Champion\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/World_championship\", \"dbpedia\": \"http://dbpedia.org/resource/World_championship\"}, {\"begin\": 1172, \"end\": 1188, \"title\": \"http://dbpedia.org/resource/Alise_Willoughby\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Alise Willoughby\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Alise_Willoughby\", \"dbpedia\": \"http://dbpedia.org/resource/Alise_Willoughby\"}, {\"begin\": 1203, \"end\": 1211, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 0.859385255927532, \"rank\": 0.15201844544900614, \"text\": \"Team USA\", \"types\": [], \"wikid\": \"htt