\\"\", \"from\": 2114, \"to\": 2181, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"anything\", \"from\": 2142, \"to\": 2150}]}, {\"sentence\": \"He went on to declare, \\\"That such an event could take place shows us, in a most painful way, how what was once a Christian culture has become the theater of Satan and those who cooperate with his thoroughly evil plans, the plans of 'a murderer from the beginning' who 'has nothing to do with the truth,' the plans of 'a liar and the father of lies.'\\\"\", \"from\": 2183, \"to\": 2533, \"entities\": [{\"begin\": 2296, \"end\": 2313, \"title\": \"http://dbpedia.org/resource/Christian_culture\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Christian culture\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Christian_culture\", \"dbpedia\": \"http://dbpedia.org/resource/Christian_culture\"}, {\"begin\": 2340, \"end\": 2345, \"title\": \"http://dbpedia.org/resource/Satan\", \"score\": 0.9999999999968168, \"rank\": 3.110906109641057e-12, \"text\": \"Satan\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Satan\", \"dbpedia\": \"http://dbpedia.org/resource/Satan\"}], \"noun_phrases\": [{\"ngram\": \"such an event\", \"from\": 2212, \"to\": 2225}, {\"ngram\": \"place\", \"from\": 2237, \"to\": 2242}, {\"ngram\": \"us\", \"from\": 2249, \"to\": 2251}, {\"ngram\": \"a most painful way\", \"from\": 2256, \"to\": 2274}, {\"ngram\": \"the theater\", \"from\": 2325, \"to\": 2336}, {\"ngram\": \"his thoroughly evil plans\", \"from\": 2375, \"to\": 2400}, {\"ngram\": \"a murderer\", \"from\": 2416, \"to\": 2426}, {\"ngram\": \"the beginning\", \"from\": 2432, \"to\": 2445}, {\"ngram\": \"nothing\", \"from\": 2456, \"to\": 2463}, {\"ngram\": \"the truth\", \"from\": 2475, \"to\": 2484}, {\"ngram\": \"the plans\", \"from\": 2487, \"to\": 2496}, {\"ngram\": \"a liar\", \"from\": 2501, \"to\": 2507}, {\"ngram\": \"the father\", \"from\": 2512, \"to\": 2522}, {\"ngram\": \"lies\", \"from\": 2526, \"to\": 2530}]}, {\"sente