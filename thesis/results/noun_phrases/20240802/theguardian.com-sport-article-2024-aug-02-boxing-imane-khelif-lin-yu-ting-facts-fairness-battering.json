ce/J._K._Rowling\"}], \"noun_phrases\": [{\"ngram\": \"the process\", \"from\": 792, \"to\": 803}, {\"ngram\": \"an extraordinary development\", \"from\": 812, \"to\": 840}, {\"ngram\": \"her own previously regulation existence\", \"from\": 844, \"to\": 883}, {\"ngram\": \"Lin\", \"from\": 885, \"to\": 888}, {\"ngram\": \"the gaze\", \"from\": 902, \"to\": 910}, {\"ngram\": \"the entire massed global commentariat\", \"from\": 943, \"to\": 980}, {\"ngram\": \"a complex and acrimonious war\", \"from\": 984, \"to\": 1013}, {\"ngram\": \"ideas\", \"from\": 1017, \"to\": 1022}, {\"ngram\": \"identity\", \"from\": 1027, \"to\": 1035}]}, {\"sentence\": \"Can we just be really clear on this?\", \"from\": 1080, \"to\": 1116, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Lin is not, as far as anyone knows, a transgender woman.\", \"from\": 1117, \"to\": 1173, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Lin\", \"from\": 1117, \"to\": 1120}, {\"ngram\": \"anyone\", \"from\": 1139, \"to\": 1145}, {\"ngram\": \"a transgender woman\", \"from\": 1153, \"to\": 1172}]}, {\"sentence\": \"Lin is also not male, as far as anyone knows, and has never changed her gender identity.\", \"from\": 1174, \"to\": 1262, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Lin\", \"from\": 1174, \"to\": 1177}, {\"ngram\": \"anyone\", \"from\": 1206, \"to\": 1212}, {\"ngram\": \"her gender identity\", \"from\": 1242, \"to\": 1261}]}, {\"sentence\": \"Lin was born a girl 28 years ago.\", \"from\": 1264, \"to\": 1297, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Lin\", \"from\": 1264, \"to\": 1267}, {\"ngram\": \"a girl\", \"from\": 1277, \"to\": 1283}]}, {\"sentence\": \"She is an athlete competing under her birth passport as a woman, backed also, as has been reported in her home country, by a Taiwanese identity number assigned at birth that begins with a 2, meaning this person was born a baby girl.\", \"from\": 1298, \"to\": 1530, \"entities\": [{\"begin\": 1423, \"end\": 1441