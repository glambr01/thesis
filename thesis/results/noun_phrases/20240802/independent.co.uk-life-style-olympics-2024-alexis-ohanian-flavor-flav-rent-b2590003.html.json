ases\": [{\"ngram\": \"Flavor Flav -the sponsor\", \"from\": 1574, \"to\": 1598}, {\"ngram\": \"his assistance\", \"from\": 1659, \"to\": 1673}, {\"ngram\": \"C'm\", \"from\": 1686, \"to\": 1689}]}, {\"sentence\": \"I will split it with@flavorfav.\\\"\", \"from\": 1698, \"to\": 1730, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"with@flavorfav\", \"from\": 1714, \"to\": 1728}]}, {\"sentence\": \"However, the Reddit founder's post about Flavor Flav came after the singer made his own offer to help Fraley pay her rent.\", \"from\": 1732, \"to\": 1854, \"entities\": [{\"begin\": 1745, \"end\": 1751, \"title\": \"http://dbpedia.org/resource/Reddit\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Reddit\", \"types\": [\"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Reddit\", \"dbpedia\": \"http://dbpedia.org/resource/Reddit\"}, {\"begin\": 1773, \"end\": 1784, \"title\": \"http://dbpedia.org/resource/Flavor_Flav\", \"score\": 1.0, \"rank\": 3.3086708562464574e-33, \"text\": \"Flavor Flav\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Flavor_Flav\", \"dbpedia\": \"http://dbpedia.org/resource/Flavor_Flav\"}], \"noun_phrases\": [{\"ngram\": \"the singer\", \"from\": 1796, \"to\": 1806}, {\"ngram\": \"his own offer\", \"from\": 1812, \"to\": 1825}, {\"ngram\": \"Fraley\", \"from\": 1834, \"to\": 1840}, {\"ngram\": \"her rent\", \"from\": 1845, \"to\": 1853}]}, {\"sentence\": \"\\\"I gotchu, DM me and I will send payment TODAY so you do not have to worry bout it TOMORROW, and imma be rooting for ya tomorrow LETZ GO!!!\\\"\", \"from\": 1856, \"to\": 1996, \"entities\": [{\"begin\": 1867, \"end\": 1869, \"title\": \"http://dbpedia.org/resource/Deutsche_Mark\", \"score\": 0.9996861576070449, \"rank\": 0.00031374513953201754, \"text\": \"DM\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Deutsche_Mark\", \"dbpedia\": \"http://dbpedia.org/resource/Deutsche_Mark\"}], \"noun_phrases\": [{\"ngram\": 