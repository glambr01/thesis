rases\": [{\"ngram\": \"This disqualification\", \"from\": 2218, \"to\": 2239}, {\"ngram\": \"a result\", \"from\": 2244, \"to\": 2252}, {\"ngram\": \"their failure\", \"from\": 2256, \"to\": 2269}, {\"ngram\": \"the eligibility criteria\", \"from\": 2278, \"to\": 2302}, {\"ngram\": \"the women's competition\", \"from\": 2324, \"to\": 2347}, {\"ngram\": \"the IBA Regulations\", \"from\": 2372, \"to\": 2391}]}, {\"sentence\": \"This decision, made after a meticulous review, was extremely important and necessary to uphold the level of fairness and utmost integrity of the competition.\", \"from\": 2393, \"to\": 2550, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"This decision\", \"from\": 2393, \"to\": 2406}, {\"ngram\": \"a meticulous review\", \"from\": 2419, \"to\": 2438}, {\"ngram\": \"the level\", \"from\": 2488, \"to\": 2497}, {\"ngram\": \"fairness and utmost integrity\", \"from\": 2501, \"to\": 2530}, {\"ngram\": \"the competition\", \"from\": 2534, \"to\": 2549}]}, {\"sentence\": \"Point to note, the athletes did not undergo a testosterone examination but were subject to a separate and recognized test, whereby the specifics remain confidential.\", \"from\": 2552, \"to\": 2717, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the athletes\", \"from\": 2567, \"to\": 2579}, {\"ngram\": \"a testosterone examination\", \"from\": 2596, \"to\": 2622}, {\"ngram\": \"a separate and recognized test\", \"from\": 2643, \"to\": 2673}, {\"ngram\": \"the specifics\", \"from\": 2683, \"to\": 2696}]}, {\"sentence\": \"This test conclusively indicated that both athletes did not meet the required necessary eligibility criteria and were found to have competitive advantages over other female competitors.\", \"from\": 2718, \"to\": 2903, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"This test\", \"from\": 2718, \"to\": 2727}, {\"ngram\": \"both athletes\", \"from\": 2756, \"to\": 2769}, {\"ngram\": \"the required necessary eligibility criteria\", \"from\": 2783, \"to\": 2826}, {\"ngram\": \"competitive advantages\", \"from\": 2850, \"to\": 2872}, {\"ngram\": \"other female competitors\", \"from\": 2878, \"to\": 2902}]}, {\"sentence\": \"The decision made by IBA on 24 March 2023, was subsequently ratified by the IBA Board of Directors on 25 March 2023.\", \"from\": 2905, \"to\": 3021, \"entities\": [{\"begin\": 2926, \"end\": 2929, \"title\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\", \"score\": 0.9999968658588843, \"rank\": 3.134132356276684e-06, \"text\": \"IBA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\", \"dbpedia\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\"}], \"noun_phrases\": [{\"ngram\": \"The decision\", \"from\": 2905, \"to\": 2917}, {\"ngram\": \"24 March\", \"from\": 2933, \"to\": 2941}, {\"ngram\": \"the IBA Board\", \"from\": 2977, \"to\": 2990}, {\"ngram\": \"Directors\", \"from\": 2994, \"to\": 3003}, {\"ngram\": \"25 March\", \"from\": 3007, \"to\": 3015}]}, {\"sentence\": \"The official record of this decision can be accessed on the IBA website hereIBA Board of Directors Meeting Minutes.\", \"from\": 3022, \"to\": 3137, \"entities\": [{\"begin\": 3082, \"end\": 3085, \"title\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\", \"score\": 0.9999968658588843, \"rank\": 3.134132356276684e-06, \"text\": \"IBA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\", \"dbpedia\": \"http://dbpedia.org/resource/Independent_Broadcasting_Authority\"}], \"noun_phrases\": [{\"ngram\": \"The official record\", \"from\": 3022, \"to\": 3041}, {\"ngram\": \"this decision\", \"from\": 3045, \"to\": 3058}, {\"ngram\": \"hereIBA Board\", \"from\": 3094, \"to\": 3107}, {\"ngram\": \"Directors Meeting Minutes\", \"from\": 3111, \"to\": 3136}]}, {\"sentence\": \"The disqualification was based on two tests conducted on both athlete