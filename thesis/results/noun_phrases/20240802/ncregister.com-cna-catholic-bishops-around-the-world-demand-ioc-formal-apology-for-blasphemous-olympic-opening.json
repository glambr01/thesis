8, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9999990823339094, \"rank\": 8.607778992702725e-07, \"text\": \"United Kingdom\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"the24\", \"from\": 1246, \"to\": 1251}, {\"ngram\": \"the U.S.\", \"from\": 1272, \"to\": 1280}, {\"ngram\": \"Crookston\", \"from\": 1510, \"to\": 1519}, {\"ngram\": \"the letter\", \"from\": 1631, \"to\": 1641}]}, {\"sentence\": \"The prelates demand that the IOC \\\"repudiate this blasphemous action and apologize to all people of faith,\\\" warning that the display \\\"threatens people of all faiths and of none, as it opens the door to those with power doing whatever they wish to people they do not like.\\\"\", \"from\": 1644, \"to\": 1915, \"entities\": [{\"begin\": 1673, \"end\": 1676, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 3.064210165442968e-23, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"The prelates\", \"from\": 1644, \"to\": 1656}, {\"ngram\": \"this blasphemous action\", \"from\": 1688, \"to\": 1711}, {\"ngram\": \"all people\", \"from\": 1729, \"to\": 1739}, {\"ngram\": \"faith\", \"from\": 1743, \"to\": 1748}, {\"ngram\": \"the display\", \"from\": 1764, \"to\": 1775}, {\"ngram\": \"people\", \"from\": 1787, \"to\": 1793}, {\"ngram\": \"all faiths\", \"from\": 1797, \"to\": 1807}, {\"ngram\": \"none\", \"from\": 1815, \"to\": 1819}, {\"ngram\": \"the door\", \"from\": 1833, \"to\": 1841}, {\"ngram\": \"power\", \"from\": 1856, \"to\": 1861}, {\"ngram\": \"whatever\", \"from\": 1868, \"to\": 1876}, {\"ngram\": \"people\", \"from\": 1890, \"to\": 1896}]}, {\"sentenc