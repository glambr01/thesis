: 2265, \"to\": 2280}, {\"ngram\": \"such an extent\", \"from\": 2294, \"to\": 2308}, {\"ngram\": \"one U.S. mobile phone\", \"from\": 2314, \"to\": 2335}, {\"ngram\": \"internet companydecidedto\", \"from\": 2340, \"to\": 2365}, {\"ngram\": \"its advertising\", \"from\": 2371, \"to\": 2386}, {\"ngram\": \"the Olympics\", \"from\": 2392, \"to\": 2404}]}, {\"sentence\": \"In a first response to the scandal one day after the ceremony, the artistic director responsible for the ceremony, Thomas Jolly, told local broadcaster BFMTV the scene was inspired by a pagan feast, not the Last Supper.\", \"from\": 2407, \"to\": 2626, \"entities\": [{\"begin\": 2522, \"end\": 2528, \"title\": \"http://dbpedia.org/resource/Thomas_the_Apostle\", \"score\": 0.9999999999718057, \"rank\": 2.8232224940320073e-11, \"text\": \"Thomas\", \"types\": [\"Q729\", \"Q5\", \"Q43115\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Thomas_the_Apostle\", \"dbpedia\": \"http://dbpedia.org/resource/Thomas_the_Apostle\"}, {\"begin\": 2593, \"end\": 2598, \"title\": \"http://dbpedia.org/resource/Paganism\", \"score\": 0.9999999999995453, \"rank\": 2.551029002480592e-13, \"text\": \"pagan\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Paganism\", \"dbpedia\": \"http://dbpedia.org/resource/Paganism\"}], \"noun_phrases\": [{\"ngram\": \"a first response\", \"from\": 2410, \"to\": 2426}, {\"ngram\": \"the scandal\", \"from\": 2430, \"to\": 2441}, {\"ngram\": \"the ceremony\", \"from\": 2456, \"to\": 2468}, {\"ngram\": \"the artistic director\", \"from\": 2470, \"to\": 2491}, {\"ngram\": \"the ceremony\", \"from\": 2508, \"to\": 2520}, {\"ngram\": \"local broadcaster BFMTV\", \"from\": 2541, \"to\": 2564}, {\"ngram\": \"the scene\", \"from\": 2565, \"to\": 2574}, {\"ngram\": \"the Last Supper\", \"from\": 2610, \"to\": 2625}]}, {\"sentence\": \"\\\"You will never find in my work a desire to denigrate anyone or anything,\\\" Jolly said, according to Reuters.\", \"from\": 2628,