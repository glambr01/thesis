\", \"from\": 1524, \"to\": 1532}, {\"ngram\": \"one gold medal\", \"from\": 1567, \"to\": 1581}, {\"ngram\": \"Dressel\", \"from\": 1582, \"to\": 1589}, {\"ngram\": \"the winning 4x100-meter freestyle foursome\", \"from\": 1599, \"to\": 1641}, {\"ngram\": \"the Americans\", \"from\": 1645, \"to\": 1658}, {\"ngram\": \"the rival Australians\", \"from\": 1668, \"to\": 1689}, {\"ngram\": \"Saturday night\", \"from\": 1705, \"to\": 1719}, {\"ngram\": \"Day\", \"from\": 1723, \"to\": 1726}, {\"ngram\": \"Olympic swimming competition\", \"from\": 1732, \"to\": 1760}]}, {\"sentence\": \"That marked his eighth career gold.\", \"from\": 1764, \"to\": 1799, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"his eighth career gold\", \"from\": 1776, \"to\": 1798}]}, {\"sentence\": \"In Tokyo, he also won the 100 free and 4x100 medley relay after capturing golds in the two relays at the 2016 Rio de Janeiro Games, too.\", \"from\": 1800, \"to\": 1936, \"entities\": [{\"begin\": 1803, \"end\": 1808, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.9785168372553299, \"rank\": 0.021954817201296793, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"the 100 free and 4x100 medley relay\", \"from\": 1822, \"to\": 1857}, {\"ngram\": \"golds\", \"from\": 1874, \"to\": 1879}, {\"ngram\": \"the two relays\", \"from\": 1883, \"to\": 1897}, {\"ngram\": \"the 2016 Rio de Janeiro Games\", \"from\": 1901, \"to\": 1930}]}, {\"sentence\": \"The Associated Press contributed to this report.\", \"from\": 1938, \"to\": 1986, \"entities\": [{\"begin\": 1942, \"end\": 1958, \"title\": \"http://dbpedia.org/resource/Associated_Press\", \"score\": 0.9999994654650955, \"rank\": 4.4578335361801477e-07, \"text\": \"Associated Press\", \"types\": [\"Q4830453\", \"Q43229\", \"Q