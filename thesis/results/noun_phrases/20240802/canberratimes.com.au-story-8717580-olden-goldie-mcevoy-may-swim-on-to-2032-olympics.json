], \"noun_phrases\": [{\"ngram\": \"the Paris Games\", \"from\": 705, \"to\": 720}, {\"ngram\": \"most chapters\", \"from\": 732, \"to\": 745}, {\"ngram\": \"his rivals\", \"from\": 775, \"to\": 785}, {\"ngram\": \"insight\", \"from\": 786, \"to\": 793}, {\"ngram\": \"his revolutionary methods\", \"from\": 797, \"to\": 822}]}, {\"sentence\": \"Now, he's an open book.\", \"from\": 825, \"to\": 848, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an open book\", \"from\": 835, \"to\": 847}]}, {\"sentence\": \"\\\"We have been inundated with questions and interest,\\\" McEvoy said.\", \"from\": 850, \"to\": 916, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"questions\", \"from\": 879, \"to\": 888}, {\"ngram\": \"interest\", \"from\": 893, \"to\": 901}, {\"ngram\": \"McEvoy\", \"from\": 904, \"to\": 910}]}, {\"sentence\": \"\\\"And I think it will go a long way not only for athletes who are high performance but for the amount of ex-swimmers who quit when they are 16, 17, because they just did not like the kilometres or they had injuries.\\\"\", \"from\": 918, \"to\": 1133, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"athletes\", \"from\": 966, \"to\": 974}, {\"ngram\": \"high performance\", \"from\": 983, \"to\": 999}, {\"ngram\": \"the amount\", \"from\": 1008, \"to\": 1018}, {\"ngram\": \"ex\", \"from\": 1022, \"to\": 1024}, {\"ngram\": \"swimmers\", \"from\": 1025, \"to\": 1033}, {\"ngram\": \"the kilometres\", \"from\": 1096, \"to\": 1110}, {\"ngram\": \"injuries\", \"from\": 1123, \"to\": 1131}]}, {\"sentence\": \"McEvoy took a hiatus from swimming after his third Olympics in Tokyo three years ago.\", \"from\": 1135, \"to\": 1220, \"entities\": [{\"begin\": 1198, \"end\": 1203, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.9894949269245891, \"rank\": 0.010551591517845196, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}], \"no