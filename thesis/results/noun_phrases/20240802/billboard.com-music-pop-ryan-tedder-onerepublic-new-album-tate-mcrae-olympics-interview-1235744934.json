\": [{\"begin\": 1235, \"end\": 1245, \"title\": \"http://dbpedia.org/resource/California\", \"score\": 0.9999998229173045, \"rank\": 1.7684258264959027e-07, \"text\": \"California\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/California\", \"dbpedia\": \"http://dbpedia.org/resource/California\"}], \"noun_phrases\": [{\"ngram\": \"the essence\", \"from\": 1220, \"to\": 1231}]}, {\"sentence\": \"Some combination of West Coast hip-hop, but then I also think Beach Boys.\\\"\", \"from\": 1247, \"to\": 1321, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Some combination\", \"from\": 1247, \"to\": 1263}, {\"ngram\": \"West Coast hip-hop\", \"from\": 1267, \"to\": 1285}, {\"ngram\": \"Beach Boys\", \"from\": 1309, \"to\": 1319}]}, {\"sentence\": \"It's surprising Tedder has much time to watchthe Olympics at all, considering his schedule not only writing and producing for others, but also his own bandOneRepublic.\", \"from\": 1323, \"to\": 1490, \"entities\": [{\"begin\": 1339, \"end\": 1345, \"title\": \"http://dbpedia.org/resource/Ryan_Tedder\", \"score\": 1.0, \"rank\": 8.748919572919186e-51, \"text\": \"Tedder\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Ryan_Tedder\", \"dbpedia\": \"http://dbpedia.org/resource/Ryan_Tedder\"}], \"noun_phrases\": [{\"ngram\": \"much time\", \"from\": 1350, \"to\": 1359}, {\"ngram\": \"watchthe Olympics\", \"from\": 1363, \"to\": 1380}, {\"ngram\": \"his schedule\", \"from\": 1401, \"to\": 1413}, {\"ngram\": \"others\", \"from\": 1449, \"to\": 1455}]}, {\"sentence\": \"The band released its sixth album this July, titledArtificial Paradise.\", \"from\": 1491, \"to\": 1562, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The band\", \"from\": 1491, \"to\": 1499}, {\"ngram\": \"its sixth album\", \"from\": 1509, \"to\": 1524}]}, {\"sentence\": \"The project includes the previousBillboard Hot 100top 10 hit \\\"I Ain't Worried\\\" fromTop Gun: Maverickas well as \\\"Hurt\\\" and \\\"Runaway.\\\"\", \"from\": 1563, \"to\": 1695, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The project\", \"from\": 1563, \"to\": 1574}, {\"ngram\": \"the previousBillboard\", \"from\": 1584, \"to\": 1605}, {\"ngram\": \"Hot\", \"from\": 1606, \"to\": 1609}, {\"ngram\": \"\\\" fromTop Gun: Maverickas\", \"from\": 1640, \"to\": 1665}, {\"ngram\": \"\\\"Hurt\", \"from\": 1674, \"to\": 1679}, {\"ngram\": \"\\\"Runaway\", \"from\": 1685, \"to\": 1693}]}, {\"sentence\": \"\\\"The weirdest thing about this album - and the next album will be different because we are always trying to switch it up - but this represents, more or less, theendof our album cycle,\\\" he says, noting the lead single \\\"West Coast\\\" arrived about two years ago.\", \"from\": 1697, \"to\": 1955, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The weirdest thing\", \"from\": 1698, \"to\": 1716}, {\"ngram\": \"this album\", \"from\": 1723, \"to\": 1733}, {\"ngram\": \"the next album\", \"from\": 1740, \"to\": 1754}, {\"ngram\": \"our album cycle\", \"from\": 1864, \"to\": 1879}, {\"ngram\": \"the lead single \\\"West Coast\", \"from\": 1898, \"to\": 1925}]}, {\"sentence\": \"\\\"I Ain't Worried\\\" came next, which he says \\\"strangled\\\" \\\"West Coast\\\" to become the album's best-known track.\", \"from\": 1956, \"to\": 2063, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"\\\"West Coast\", \"from\": 2011, \"to\": 2022}, {\"ngram\": \"the album's best-known track\", \"from\": 2034, \"to\": 2062}]}, {\"sentence\": \"He has plenty more on the horizon as well, teasing he and Tate McRae (for whom he executive produced her second albumThink Later) are talking \\\"every day\\\" about what is next.\", \"from\": 2065, \"to\": 2238, \"entities\": [{\"begin\": 2123, \"end\": 2127, \"title\": \"http://dbpedia.org/resource/Tate\", \"score\": 0.9838171831355736, \"rank\": 0.01642856596403058, \"text\": \"Tate\", \"types\": [], \"wikid\": \"http://dbpedia.