"{\"uid\": \"metro.co.uk-2024-02-27-andrea-spendolini-sirieix-retiring-beating-chinese-olympics-20358003\", \"noun_phrases\": [{\"sentence\": \"I could not have dreamt I would come away from the world championships with three medals - one of them gold - but I am so thankful I was able to begin Olympic year that way.\", \"from\": 0, \"to\": 173, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"three medals\", \"from\": 76, \"to\": 88}, {\"ngram\": \"gold\", \"from\": 103, \"to\": 107}, {\"ngram\": \"Olympic year\", \"from\": 151, \"to\": 163}]}, {\"sentence\": \"I tried not to think too much about results at this month's championships in Doha but our British team got off to a flying start on day one by winning the first gold medal available in the team competition alongside Tom Daley, Dan Goodfellow and Scarlett Mew Jensen.\", \"from\": 175, \"to\": 441, \"entities\": [{\"begin\": 252, \"end\": 256, \"title\": \"http://dbpedia.org/resource/Doha\", \"score\": 0.9999999999786269, \"rank\": 2.150845823272545e-11, \"text\": \"Doha\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Doha\", \"dbpedia\": \"http://dbpedia.org/resource/Doha\"}, {\"begin\": 265, \"end\": 272, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9674914976919614, \"rank\": 0.033095707445713586, \"text\": \"British\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}, {\"begin\": 391, \"end\": 400, \"title\": \"http://dbpedia.org/resource/Tom_Daley\", \"score\": 1.0, \"rank\": 7.292858616045686e-50, \"text\": \"Tom Daley\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tom_Daley\", \"dbpedia\": \"http://dbpedia.org/resource/Tom_Daley\"}, {\"begin\": 402, \"end\": 416, \"title\": \"http://dbpedia.org/resource/Daniel_Goodfellow\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Dan Goodfellow\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], 