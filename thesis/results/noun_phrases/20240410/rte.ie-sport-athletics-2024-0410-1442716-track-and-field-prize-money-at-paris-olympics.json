"{\"uid\": \"rte.ie-sport-athletics-2024-0410-1442716-track-and-field-prize-money-at-paris-olympics\", \"noun_phrases\": [{\"sentence\": \"Track and field gold medallists at the Olympic Games in Paris this summer will each receive $50,000 (\\u20ac46,000) in prize money.\", \"from\": 0, \"to\": 125, \"entities\": [{\"begin\": 56, \"end\": 61, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999397277879, \"rank\": 6.027226982962299e-08, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Track and field gold medallists\", \"from\": 0, \"to\": 31}, {\"ngram\": \"the Olympic Games\", \"from\": 35, \"to\": 52}, {\"ngram\": \"prize money\", \"from\": 113, \"to\": 124}]}, {\"sentence\": \"World Athletics announced the $2.4million (\\u20ac2.2m) prize pot on Wednesday morning in a move which makes it the first international sport federation to award prize money at an Olympics in the 128-year history of the modern Games.\", \"from\": 127, \"to\": 354, \"entities\": [{\"begin\": 127, \"end\": 142, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 0.9999999999949978, \"rank\": 5.101490588703349e-12, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}], \"noun_phrases\": [{\"ngram\": \"the $2.4million (\\u20ac2.2m) prize pot\", \"from\": 153, \"to\": 186}, {\"ngram\": \"Wednesday morning\", \"from\": 190, \"to\": 207}, {\"ngram\": \"a move\", \"from\": 211, \"to\": 217}, {\"ngram\": \"prize money\", \"from\": 283, \"to\": 294}, {\"ngram\": \"an Olympics\", \"from\": 298, \"to\": 309}, {\"ngram\": \"the 128-year history\", \"from\": 313, \"to\": 333}, {\"ngram\": \"the modern Games\", \"from\": 337, \"to\": 353}]}, {\"sentence\": \"The global governing body said the initiative also included a \\\"firm commitment\\\" to extend the prize money to silver and bronze medallists at the Los Angeles Games in four years' time.\", \"from\": 356, \"to\": 539, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The global governing body\", \"from\": 356, \"to\": 381}, {\"ngram\": \"the initiative\", \"from\": 387, \"to\": 401}, {\"ngram\": \"a \\\"firm commitment\", \"from\": 416, \"to\": 434}, {\"ngram\": \"the prize money\", \"from\": 446, \"to\": 461}, {\"ngram\": \"silver and bronze medallists\", \"from\": 465, \"to\": 493}, {\"ngram\": \"the Los Angeles Games\", \"from\": 497, \"to\": 518}, {\"ngram\": \"four years' time\", \"from\": 522, \"to\": 538}]}, {\"sentence\": \"Relay medallists will split the $50,000 dollar prize across the team, World Athletics said.\", \"from\": 541, \"to\": 632, \"entities\": [{\"begin\": 611, \"end\": 626, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 0.9999999999949978, \"rank\": 5.101490588703349e-12, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}], \"noun_phrases\": [{\"ngram\": \"Relay medallists\", \"from\": 541, \"to\": 557}, {\"ngram\": \"the $50,000 dollar prize\", \"from\": 569, \"to\": 593}, {\"ngram\": \"the team\", \"from\": 601, \"to\": 609}]}, {\"sentence\": \"\\\"The introduction of prize money for Olympic gold medallists is a pivotal moment for World Athletics and the sport of athletics as a whole, underscoring our commitment to empowering the athletes and recognising the critical role they play in the success of any Olympic Games,\\\" World Athletics president Sebastian Coe said.\", \"from\": 634, \"to\": 956, \"entities\": [{\"begin\": 719, \"end\": 734, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 0.9999999999949978, \"rank\": 5.101490588703349e-12, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}, {\"begin\": 911, \"end\": 926, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 0.9999999999949978, \"rank\": 5.101490588703349e-12, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}, {\"begin\": 937, \"end\": 950, \"title\": \"http://dbpedia.org/resource/Sebastian_Coe\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Sebastian Coe\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Sebastian_Coe\", \"dbpedia\": \"http://dbpedia.org/resource/Sebastian_Coe\"}], \"noun_phrases\": [{\"ngram\": \"The introduction\", \"from\": 635, \"to\": 651}, {\"ngram\": \"prize money\", \"from\": 655, \"to\": 666}, {\"ngram\": \"Olympic gold medallists\", \"from\": 671, \"to\": 694}, {\"ngram\": \"a pivotal moment\", \"from\": 698, \"to\": 714}, {\"ngram\": \"the sport\", \"from\": 739, \"to\": 748}, {\"ngram\": \"athletics\", \"from\": 752, \"to\": 761}, {\"ngram\": \"a whole\", \"from\": 765, \"to\": 772}, {\"ngram\": \"our commitment\", \"from\": 787, \"to\": 801}, {\"ngram\": \"the athletes\", \"from\": 816, \"to\": 828}, {\"ngram\": \"the critical role\", \"from\": 845, \"to\": 862}, {\"ngram\": \"the success\", \"from\": 876, \"to\": 887}, {\"ngram\": \"any Olympic Games\", \"from\": 891, \"to\": 908}]}, {\"sentence\": \"\\\"This is the continuation of a journey we started back in 2015, which sees all the money World Athletics receives from the International Olympic Committee for the Olympic Games go directly back into our sport.\\\"\", \"from\": 958, \"to\": 1168, \"entities\": [{\"begin\": 1047, \"end\": 1062, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 0.9999999999949978, \"rank\": 5.101490588703349e-12, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}, {\"begin\": 1081, \"end\": 1112, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"the continuation\", \"from\": 967, \"to\": 983}, {\"ngram\": \"a journey\", \"from\": 987, \"to\": 996}, {\"ngram\": \"all the money\", \"from\": 1033, \"to\": 1046}, {\"ngram\": \"the Olympic Games\", \"from\": 1117, \"to\": 1134}, {\"ngram\": \"our sport\", \"from\": 1157, \"to\": 1166}]}, {\"sentence\": \"Coe said he was confident the International Olympic Committee would \\\"share in the principle\\\" of track and field gold medal winners earning prize money in Paris - but admitted his organisation had not discussed the historic move with the IOC.\", \"from\": 1170, \"to\": 1411, \"entities\": [{\"begin\": 1200, \"end\": 1231, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 1324, \"end\": 1329, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999397277879, \"rank\": 6.027226982962299e-08, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 1407, \"end\": 1410, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 2.9754504952255686e-25, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"Coe\", \"from\": 1170, \"to\": 1173}, {\"ngram\": \"the principle\", \"from\": 1248, \"to\": 1261}, {\"ngram\": \"track and field gold medal winners\", \"from\": 1266, \"to\": 1300}, {\"ngram\": \"prize money\", \"from\": 1309, \"to\": 1320}, {\"ngram\": \"his organisation\", \"from\": 1345, \"to\": 1361}, {\"ngram\": \"the historic move\", \"from\": 1380, \"to\": 1397}]}, {\"sentence\": \"Coe said World Athletics chief executive Jon Ridgeon had given the IOC the heads-up about the announcement on Wednesday morning but confirmed the initiative had not been discussed with the IOC in advance.\", \"from\": 1413, \"to\": 1617, \"entities\": [{\"begin\": 1422, \"end\": 1437, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 0.9999999999949978, \"rank\": 5.101490588703349e-12, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}, {\"begin\": 1454, \"end\": 1465, \"title\": \"http://dbpedia.org/resource/Jon_Ridgeon\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Jon Ridgeon\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jon_Ridgeon\", \"dbpedia\": \"http://dbpedia.org/resource/Jon_Ridgeon\"}, {\"begin\": 1480, \"end\": 1483, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 2.9754504952255686e-25, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 1602, \"end\": 1605, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 2.9754504952255686e-25, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"Coe\", \"from\": 1413, \"to\": 1416}, {\"ngram\": \"the heads-up\", \"from\": 1484, \"to\": 1496}, {\"ngram\": \"the announcement\", \"from\": 1503, \"to\": 1519}, {\"ngram\": \"Wednesday morning\", \"from\": 1523, \"to\": 1540}, {\"ngram\": \"the initiative\", \"from\": 1555, \"to\": 1569}, {\"ngram\": \"advance\", \"from\": 1609, \"to\": 1616}]}, {\"sentence\": \"Asked whether that approach should be seen as surprising, Coe said: \\\"I do not think so.\", \"from\": 1619, \"to\": 1706, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"that approach\", \"from\": 1633, \"to\": 1646}, {\"ngram\": \"Coe\", \"from\": 1677, \"to\": 1680}]}, {\"sentence\": \"It's a matter for the sport.\", \"from\": 1707, \"to\": 1735, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a matter\", \"from\": 1712, \"to\": 1720}, {\"ngram\": \"the sport\", \"from\": 1725, \"to\": 1734}]}, {\"sentence\": \"\\\"The one thing the International Olympic Committee has consistently recognised - and they are right to - is the primacy of international federations to fashion their own futures.\", \"from\": 1737, \"to\": 1915, \"entities\": [{\"begin\": 1756, \"end\": 1787, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"The one thing\", \"from\": 1738, \"to\": 1751}, {\"ngram\": \"the primacy\", \"from\": 1845, \"to\": 1856}, {\"ngram\": \"international federations\", \"from\": 1860, \"to\": 1885}, {\"ngram\": \"their own futures\", \"from\": 1897, \"to\": 1914}]}, {\"sentence\": \"\\\"I do not believe this is remotely at variance with the concept that the International Olympic Committee often talks about, which is recognising the efforts that our competitors make.\", \"from\": 1917, \"to\": 2100, \"entities\": [{\"begin\": 1990, \"end\": 2021, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"variance\", \"from\": 1955, \"to\": 1963}, {\"ngram\": \"the concept\", \"from\": 1969, \"to\": 1980}, {\"ngram\": \"the efforts\", \"from\": 2062, \"to\": 2073}, {\"ngram\": \"our competitors\", \"from\": 2079, \"to\": 2094}]}, {\"sentence\": \"\\\"I am hoping the IOC would share in this principle, given their avowed commitment to make sure that revenues raised through the Olympic Movement find their way back onto the front line.\", \"from\": 2102, \"to\": 2287, \"entities\": [{\"begin\": 2119, \"end\": 2122, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 2.9754504952255686e-25, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 2230, \"end\": 2246, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 0.9907032050148786, \"rank\": 0.009384036448135756, \"text\": \"Olympic Movement\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"this principle\", \"from\": 2138, \"to\": 2152}, {\"ngram\": \"their avowed commitment\", \"from\": 2160, \"to\": 2183}, {\"ngram\": \"revenues\", \"from\": 2202, \"to\": 2210}, {\"ngram\": \"their way\", \"from\": 2252, \"to\": 2261}, {\"ngram\": \"the front line\", \"from\": 2272, \"to\": 2286}]}, {\"sentence\": \"I think they make the point that 80% or 90% goes back.\\\"\", \"from\": 2288, \"to\": 2343, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the point\", \"from\": 2306, \"to\": 2315}, {\"ngram\": \"80%\", \"from\": 2321, \"to\": 2324}, {\"ngram\": \"90%\", \"from\": 2328, \"to\": 2331}]}, {\"sentence\": \"The IOC has been contacted for comment.\", \"from\": 2345, \"to\": 2384, \"entities\": [{\"begin\": 2349, \"end\": 2352, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 2.9754504952255686e-25, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"comment\", \"from\": 2376, \"to\": 2383}]}, {\"sentence\": \"Some of the early social media reaction to World Athletics' announcement was that the concept of prize money ran counter to the Olympic spirit of amateurism.\", \"from\": 2386, \"to\": 2543, \"entities\": [{\"begin\": 2429, \"end\": 2444, \"title\": \"http://dbpedia.org/resource/World_Athletics\", \"score\": 0.9999999999949978, \"rank\": 5.101490588703349e-12, \"text\": \"World Athletics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics\"}], \"noun_phrases\": [{\"ngram\": \"the early social media reaction\", \"from\": 2394, \"to\": 2425}, {\"ngram\": \"the concept\", \"from\": 2468, \"to\": 2479}, {\"ngram\": \"prize money\", \"from\": 2483, \"to\": 2494}, {\"ngram\": \"the Olympic spirit\", \"from\": 2510, \"to\": 2528}, {\"ngram\": \"amateurism\", \"from\": 2532, \"to\": 2542}]}, {\"sentence\": \"Coe said he had \\\"no concern\\\" in that respect, adding: \\\"Introducing prize money for gold medallists acknowledges that the athletes are the reason that billions of people watch the Games and why it attracts such high revenues.\", \"from\": 2545, \"to\": 2769, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Coe\", \"from\": 2545, \"to\": 2548}, {\"ngram\": \"\\\"no concern\", \"from\": 2561, \"to\": 2572}, {\"ngram\": \"that respect\", \"from\": 2577, \"to\": 2589}, {\"ngram\": \"prize money\", \"from\": 2612, \"to\": 2623}, {\"ngram\": \"gold medallists\", \"from\": 2628, \"to\": 2643}, {\"ngram\": \"the athletes\", \"from\": 2662, \"to\": 2674}, {\"ngram\": \"the reason\", \"from\": 2679, \"to\": 2689}, {\"ngram\": \"billions\", \"from\": 2695, \"to\": 2703}, {\"ngram\": \"people\", \"from\": 2707, \"to\": 2713}, {\"ngram\": \"the Games\", \"from\": 2720, \"to\": 2729}, {\"ngram\": \"such high revenues\", \"from\": 2750, \"to\": 2768}]}, {\"sentence\": \"\\\"I am probably the last generation to have been on the 75 pence meal voucher and second-class rail fare competing for my country.\", \"from\": 2771, \"to\": 2900, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the last generation\", \"from\": 2786, \"to\": 2805}, {\"ngram\": \"the 75 pence meal\", \"from\": 2822, \"to\": 2839}, {\"ngram\": \"voucher and second-class rail fare\", \"from\": 2840, \"to\": 2874}, {\"ngram\": \"my country\", \"from\": 2889, \"to\": 2899}]}, {\"sentence\": \"\\\"I do understand the nature of the transition we have been in and we are now operating in a completely different landscape, a completely different planet, from when I was competing.\", \"from\": 2902, \"to\": 3083, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the nature\", \"from\": 2919, \"to\": 2929}, {\"ngram\": \"the transition\", \"from\": 2933, \"to\": 2947}, {\"ngram\": \"a completely different landscape\", \"from\": 2992, \"to\": 3024}, {\"ngram\": \"a completely different planet\", \"from\": 3026, \"to\": 3055}]}, {\"sentence\": \"\\\"So it is very important that this sport recognises the change in that landscape and the added pressures on competitors.\\\"\", \"from\": 3085, \"to\": 3206, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this sport\", \"from\": 3115, \"to\": 3125}, {\"ngram\": \"the change\", \"from\": 3137, \"to\": 3147}, {\"ngram\": \"that landscape\", \"from\": 3151, \"to\": 3165}, {\"ngram\": \"the added pressures\", \"from\": 3170, \"to\": 3189}, {\"ngram\": \"competitors\", \"from\": 3193, \"to\": 3204}]}, {\"sentence\": \"Follow theRT\\u00c9 Sport WhatsApp channelfor the best news, interviews, analysis and features, as well as details of our sports coverage across all RT\\u00c9 platforms.\", \"from\": 3208, \"to\": 3365, \"entities\": [{\"begin\": 3351, \"end\": 3354, \"title\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\", \"score\": 0.9835396432123026, \"rank\": 0.013767790549921992, \"text\": \"RT\\u00c9\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\", \"dbpedia\": \"http://dbpedia.org/resource/Raidi\\u00f3_Teilif\\u00eds_\\u00c9ireann\"}], \"noun_phrases\": [{\"ngram\": \"Follow theRT\\u00c9 Sport WhatsApp\", \"from\": 3208, \"to\": 3236}, {\"ngram\": \"the best news\", \"from\": 3248, \"to\": 3261}, {\"ngram\": \"interviews\", \"from\": 3263, \"to\": 3273}, {\"ngram\": \"analysis\", \"from\": 3275, \"to\": 3283}, {\"ngram\": \"features\", \"from\": 3288, \"to\": 3296}, {\"ngram\": \"details\", \"from\": 3309, \"to\": 3316}, {\"ngram\": \"our sports coverage\", \"from\": 3320, \"to\": 3339}]}, {\"sentence\": \"Source:PA \\u00a9 RT\\u00c9 2026.\", \"f