, {\"sentence\": \"\\\"Team USA athletes are resilient and perseverant - much like Delta's own people who work each day behind the scenes to connect the world,\\\" Vice President of Global Communications, Gina Laughlin said.\", \"from\": 1820, \"to\": 2019, \"entities\": [{\"begin\": 1881, \"end\": 1886, \"title\": \"http://dbpedia.org/resource/Delta_Air_Lines\", \"score\": 1.0, \"rank\": 2.260342159798438e-19, \"text\": \"Delta\", \"types\": [\"Q4830453\", \"Q46970\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Delta_Air_Lines\", \"dbpedia\": \"http://dbpedia.org/resource/Delta_Air_Lines\"}, {\"begin\": 2000, \"end\": 2004, \"title\": \"http://dbpedia.org/resource/Characters_of_Holby_City\", \"score\": 0.9999978033414688, \"rank\": 2.1966634695871904e-06, \"text\": \"Gina\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Characters_of_Holby_City\", \"dbpedia\": \"http://dbpedia.org/resource/Characters_of_Holby_City\"}, {\"begin\": 2005, \"end\": 2013, \"title\": \"http://dbpedia.org/resource/Laughlin_Air_Force_Base\", \"score\": 0.9999999998542535, \"rank\": 1.457647544640234e-10, \"text\": \"Laughlin\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Laughlin_Air_Force_Base\", \"dbpedia\": \"http://dbpedia.org/resource/Laughlin_Air_Force_Base\"}], \"noun_phrases\": [{\"ngram\": \"Team USA athletes\", \"from\": 1821, \"to\": 1838}, {\"ngram\": \"the scenes\", \"from\": 1925, \"to\": 1935}, {\"ngram\": \"the world\", \"from\": 1947, \"to\": 1956}, {\"ngram\": \"Vice President\", \"from\": 1959, \"to\": 1973}, {\"ngram\": \"Global Communications\", \"from\": 1977, \"to\": 1998}]}, {\"sentence\": \"\\\"Celebrating this moment alongside our 2023 Chairman's Club Honorees is only fitting as Delta's people and Team USA work diligently each day to bring the best of themselves to their work.\", \"from\": 2021, \"to\": 2208, \"entities\": [{\"begin\": 2109, \"end\": 2114, \"title\": \"http://dbpedia.org/resource/Delta_Air_Lines\", \"score\": 1.0, \"rank\": 2.260342159798438e-19, \"text\": \"Delta\", \"types\": [\"Q4830453\", \"Q46970\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Delta_Air_Lines\", \"dbpedia\": \"http://dbpedia.org/resource/Delta_Air_Lines\"}, {\"begin\": 2128, \"end\": 2136, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999995471492755, \"rank\": 4.422673721402316e-07, \"text\": \"Team USA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"this moment\", \"from\": 2034, \"to\": 2045}, {\"ngram\": \"our 2023 Chairman's Club Honorees\", \"from\": 2056, \"to\": 2089}, {\"ngram\": \"their work\", \"from\": 2197, \"to\": 2207}]}, {\"sentence\": \"\\\"No one better understand what it means to keep climbing to the top,\\\"The new customised aircraft, according to Delta Air Lines, was designed over several months by Alessandra Rabellino and Delta's internal brand design team.\", \"from\": 2210, \"to\": 2434, \"entities\": [{\"begin\": 2321, \"end\": 2336, \"title\": \"http://dbpedia.org/resource/Delta_Air_Lines\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Delta Air Lines\", \"types\": [\"Q4830453\", \"Q46970\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Delta_Air_Lines\", \"dbpedia\": \"http://dbpedia.org/resource/Delta_Air_Lines\"}, {\"begin\": 2399, \"end\": 2404, \"title\": \"http://dbpedia.org/resource/Delta_Air_Lines\", \"score\": 1.0, \"rank\": 2.260342159798438e-19, \"text\": \"Delta\", \"types\": [\"Q4830453\", \"Q46970\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Delta_Air_Lines\", \"dbpedia\": \"http://dbpedia.org/resource/Delta_Air_Lines\"}], \"noun_phrases\": [{\"ngram\": \"No one\", \"from\": 2211, \"to\": 2217}, {\"ngram\": \"the top,\\\"The new customised aircraft\", \"from\": 2270, \"to\": 2306}, {\"ngram\": \"several months\", \"from\": 2