hrases\": [{\"ngram\": \"a professional athlete\", \"from\": 12861, \"to\": 12883}]}, {\"sentence\": \"There is a great scene when they are at their family home and she's pulling out all this memorabilia from his childhood: Baby books, medals he won, a pregnancy stick.\", \"from\": 12885, \"to\": 13051, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a great scene\", \"from\": 12894, \"to\": 12907}, {\"ngram\": \"their family\", \"from\": 12925, \"to\": 12937}, {\"ngram\": \"all this memorabilia\", \"from\": 12965, \"to\": 12985}, {\"ngram\": \"his childhood\", \"from\": 12991, \"to\": 13004}, {\"ngram\": \"medals\", \"from\": 13018, \"to\": 13024}, {\"ngram\": \"a pregnancy stick\", \"from\": 13033, \"to\": 13050}]}, {\"sentence\": \"Why was it important for viewers to see those moments between Noah and his mom, especially since so much of the energy and so much of the focus is what happens on the track and in the training?\", \"from\": 13052, \"to\": 13245, \"entities\": [{\"begin\": 13114, \"end\": 13118, \"title\": \"http://dbpedia.org/resource/Luke_Snyder_and_Noah_Mayer\", \"score\": 0.9581311645271425, \"rank\": 0.0423869157692754, \"text\": \"Noah\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Luke_Snyder_and_Noah_Mayer\", \"dbpedia\": \"http://dbpedia.org/resource/Luke_Snyder_and_Noah_Mayer\"}], \"noun_phrases\": [{\"ngram\": \"viewers\", \"from\": 13077, \"to\": 13084}, {\"ngram\": \"those moments\", \"from\": 13092, \"to\": 13105}, {\"ngram\": \"his mom\", \"from\": 13123, \"to\": 13130}, {\"ngram\": \"the energy\", \"from\": 13160, \"to\": 13170}, {\"ngram\": \"the focus\", \"from\": 13186, \"to\": 13195}, {\"ngram\": \"the track\", \"from\": 13215, \"to\": 13224}, {\"ngram\": \"the training\", \"from\": 13232, \"to\": 13244}]}, {\"sentence\": \"What we want to do on these shows is just give people a different perspective from what they see, particularly when they watch the live events.\", \"from\": 13247, \"to\": 13390, \"entities\": [], \