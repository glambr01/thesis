"{\"uid\": \"themoscowtimes.com-2024-07-06-russian-wrestlers-reject-olympics-invitation-a85631\", \"noun_phrases\": [{\"sentence\": \"Russian wrestlers who were given permission to participate in this summer's Olympic Games have rejected the invitation, the Russian Wrestling Federation said Saturday.\", \"from\": 0, \"to\": 167, \"entities\": [{\"begin\": 0, \"end\": 7, \"title\": \"http://dbpedia.org/resource/Russian_language\", \"score\": 0.6150995771924183, \"rank\": 0.5113205586915094, \"text\": \"Russian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Russian_language\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_language\"}, {\"begin\": 124, \"end\": 131, \"title\": \"http://dbpedia.org/resource/Russian_language\", \"score\": 0.6150995771924183, \"rank\": 0.5113205586915094, \"text\": \"Russian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Russian_language\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_language\"}], \"noun_phrases\": [{\"ngram\": \"permission\", \"from\": 33, \"to\": 43}, {\"ngram\": \"this summer's Olympic Games\", \"from\": 62, \"to\": 89}, {\"ngram\": \"the invitation\", \"from\": 104, \"to\": 118}]}, {\"sentence\": \"After initially barring Russian athletes from the Games over Moscow's war on Ukraine, the International Olympic Committee (IOC) has moved to allow a handful of Russian athletes to take part under a neutral flag if they meet strict conditions.\", \"from\": 169, \"to\": 411, \"entities\": [{\"begin\": 193, \"end\": 200, \"title\": \"http://dbpedia.org/resource/Russian_language\", \"score\": 0.6150995771924183, \"rank\": 0.5113205586915094, \"text\": \"Russian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Russian_language\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_language\"}, {\"begin\": 230, \"end\": 236, \"title\": \"http://dbpedia.org/resource/Moscow\", \"score\": 0.9999999964554718, \"rank\": 2.664846539580532e-09, \"text\": \"Moscow\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Moscow\", \"dbpedia\": \"http://dbpedia.org/resource/Moscow\"}, {\"begin\": 246, \"end\": 253, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 0.9283731846029379, \"rank\": 0.07711955005570872, \"text\": \"Ukraine\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Ukraine\"}, {\"begin\": 259, \"end\": 296, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee (IOC)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 329, \"end\": 336, \"title\": \"http://dbpedia.org/resource/Russian_language\", \"score\": 0.6150995771924183, \"rank\": 0.5113205586915094, \"text\": \"Russian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Russian_language\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_language\"}], \"noun_phrases\": [{\"ngram\": \"the Games\", \"from\": 215, \"to\": 224}, {\"ngram\": \"a handful\", \"from\": 316, \"to\": 325}, {\"ngram\": \"part\", \"from\": 354, \"to\": 358}, {\"ngram\": \"a neutral flag\", \"from\": 365, \"to\": 379}, {\"ngram\": \"strict conditions\", \"from\": 393, \"to\": 410}]}, {\"sentence\": \"But the national federation said Saturday that 10 wrestlers who passed the eligibility checks would boycott the Games in protest at the IOC.\", \"from\": 413, \"to\": 553, \"entities\": [{\"begin\": 549, \"end\": 552, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 3.439645564243077e-19, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"the national federation\", \"from\": 417, \"to\": 440}, {\"ngram\": \"10 wrestlers\", \"from\": 460, \"to\": 472}, {\"ngram\": \"the eligibility checks\", \"from\": 484, \"to\": 506}, {\"ngram\": \"the Games\", \"from\": 521, \"to\": 530}, {\"ngram\": \"protest\", \"from\": 534, \"to\": 541}]}, {\"sentence\": \"\\\"We do not accept the unsportsmanlike selection principle that guided the International Olympic Committee when forming the list of eligible athletes, the purpose of which is to undermine the principle of unity of our team,\\\" the federation said in a statement.\", \"from\": 555, \"to\": 814, \"entities\": [{\"begin\": 629, \"end\": 660, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"the unsportsmanlike selection principle\", \"from\": 573, \"to\": 612}, {\"ngram\": \"the list\", \"from\": 674, \"to\": 682}, {\"ngram\": \"eligible athletes\", \"from\": 686, \"to\": 703}, {\"ngram\": \"the purpose\", \"from\": 705, \"to\": 716}, {\"ngram\": \"the principle\", \"from\": 742, \"to\": 755}, {\"ngram\": \"unity\", \"from\": 759, \"to\": 764}, {\"ngram\": \"our team\", \"from\": 768, \"to\": 776}, {\"ngram\": \"the federation\", \"from\": 779, \"to\": 793}, {\"ngram\": \"a statement\", \"from\": 802, \"to\": 813}]}, {\"sentence\": \"The federation's executive committee, coaches and wrestlers \\\"came to the unanimous decision to refuse to participate in the Olympic Games.\\\"\", \"from\": 816, \"to\": 955, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The federation's executive committee\", \"from\": 816, \"to\": 852}, {\"ngram\": \"coaches\", \"from\": 854, \"to\": 861}, {\"ngram\": \"wrestlers\", \"from\": 866, \"to\": 875}, {\"ngram\": \"the unanimous decision\", \"from\": 885, \"to\": 907}, {\"ngram\": \"the Olympic Games\", \"from\": 936, \"to\": 953}]}, {\"sentence\": \"Russian athletes hoping to compete in Paris must demonstrate they do not support Russia's war on Ukraine and have no links to the country's armed forces.\", \"from\": 957, \"to\": 1110, \"entities\": [{\"begin\": 957, \"end\": 964, \"title\": \"http://dbpedia.org/resource/Russian_language\", \"score\": 0.6150995771924183, \"rank\": 0.5113205586915094, \"text\": \"Russian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Russian_language\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_language\"}, {\"begin\": 995, \"end\": 1000, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999468295693685, \"rank\": 5.317325794945958e-05, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 1038, \"end\": 1044, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9982293837896171, \"rank\": 0.0017605703416689817, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}, {\"begin\": 1054, \"end\": 1061, \"title\": \"http://dbpedia.org/resource/Ukraine\", \"score\": 0.9283731846029379, \"rank\": 0.07711955005570872, \"text\": \"Ukraine\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Ukraine\", \"dbpedia\": \"http://dbpedia.org/resource/Ukraine\"}], \"noun_phrases\": [{\"ngram\": \"no links\", \"from\": 1071, \"to\": 1079}, {\"ngram\": \"the country's armed forces\", \"from\": 1083, \"to\": 1109}]}, {\"sentence\": \"Those admitted will have to compete under a neutral banner and will be excluded from any team events and also the opening ceremony.\", \"from\": 1112, \"to\": 1243, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a neutral banner\", \"from\": 1154, \"to\": 1170}, {\"ngram\": \"any team events\", \"from\": 1197, \"to\": 1212}, {\"ngram\": \"also the opening ceremony\", \"from\": 1217, \"to\": 1242}]}, {\"sentence\": \"Russian officials have repeatedly blasted the IOC policy.\", \"from\": 1245, \"to\": 1302, \"entities\": [{\"begin\": 1245, \"end\": 1252, \"title\": \"http://dbpedia.org/resource/Russian_language\", \"score\": 0.6150995771924183, \"rank\": 0.5113205586915094, \"text\": \"Russian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Russian_language\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_language\"}, {\"begin\": 1291, \"end\": 1294, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 3.439645564243077e-19, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": []}, {\"sentence\": \"A Message from The Moscow Times: Dear readers, We are facing unprecedented challenges.\", \"from\": 1304, \"to\": 1392, \"entities\": [{\"begin\": 1319, \"end\": 1335, \"title\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"The Moscow Times\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"dbpedia\": \"http://dbpedia.org/resource/The_Moscow_Times\"}], \"noun_phrases\": [{\"ngram\": \"Dear readers\", \"from\": 1337, \"to\": 1349}, {\"ngram\": \"unprecedented challenges\", \"from\": 1365, \"to\": 1389}]}, {\"sentence\": \"Russia's Prosecutor General's Office has designated The Moscow Times as an \\\"undesirable\\\" organization, criminalizing our work and putting our staff at risk of prosecution.\", \"from\": 1393, \"to\": 1564, \"entities\": [{\"begin\": 1393, \"end\": 1399, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9982293837896171, \"rank\": 0.0017605703416689817, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}, {\"begin\": 1402, \"end\": 1420, \"title\": \"http://dbpedia.org/resource/Prosecutor-General_of_Russia\", \"score\": 0.99999808868666, \"rank\": 1.911271927260703e-06, \"text\": \"Prosecutor General\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Prosecutor-General_of_Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Prosecutor-General_of_Russia\"}, {\"begin\": 1445, \"end\": 1461, \"title\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"The Moscow Times\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"dbpedia\": \"http://dbpedia.org/resource/The_Moscow_Times\"}], \"noun_phrases\": [{\"ngram\": \"an \\\"undesirable\\\" organization\", \"from\": 1465, \"to\": 1494}, {\"ngram\": \"our work\", \"from\": 1510, \"to\": 1518}, {\"ngram\": \"our staff\", \"from\": 1531, \"to\": 1540}, {\"ngram\": \"risk\", \"from\": 1544, \"to\": 1548}, {\"ngram\": \"prosecution\", \"from\": 1552, \"to\": 1563}]}, {\"sentence\": \"This follows our earlier unjust labeling as a \\\"foreign agent.\\\"\", \"from\": 1565, \"to\": 1627, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"our earlier unjust labeling\", \"from\": 1578, \"to\": 1605}, {\"ngram\": \"a \\\"foreign agent\", \"from\": 1609, \"to\": 1625}]}, {\"sentence\": \"These actions are direct attempts to silence independent journalism in Russia.\", \"from\": 1629, \"to\": 1707, \"entities\": [{\"begin\": 1700, \"end\": 1706, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9982293837896171, \"rank\": 0.0017605703416689817, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}], \"noun_phrases\": [{\"ngram\": \"These actions\", \"from\": 1629, \"to\": 1642}, {\"ngram\": \"direct attempts\", \"from\": 1647, \"to\": 1662}, {\"ngram\": \"independent journalism\", \"from\": 1674, \"to\": 1696}]}, {\"sentence\": \"The authorities claim our work \\\"discredits the decisions of the Russian leadership.\\\"\", \"from\": 1708, \"to\": 1792, \"entities\": [{\"begin\": 1772, \"end\": 1779, \"title\": \"http://dbpedia.org/resource/Russian_language\", \"score\": 0.6150995771924183, \"rank\": 0.5113205586915094, \"text\": \"Russian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Russian_language\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_language\"}], \"noun_phrases\": [{\"ngram\": \"The authorities\", \"from\": 1708, \"to\": 1723}, {\"ngram\": \"our work\", \"from\": 1730, \"to\": 1738}, {\"ngram\": \"the decisions\", \"from\": 1751, \"to\": 1764}]}, {\"sentence\": \"We see things differently: we strive to provide accurate, unbiased reporting on Russia.\", \"from\": 1793, \"to\": 1880, \"entities\": [{\"begin\": 1873, \"end\": 1879, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9982293837896171, \"rank\": 0.0017605703416689817, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}], \"noun_phrases\": [{\"ngram\": \"things\", \"from\": 1800, \"to\": 1806}, {\"ngram\": \"accurate, unbiased reporting\", \"from\": 1841, \"to\": 1869}]}, {\"sentence\": \"We, the journalists of The Moscow Times, refuse to be silenced.\", \"from\": 1882, \"to\": 1945, \"entities\": [{\"begin\": 1905, \"end\": 1921, \"title\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"The Moscow Times\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"dbpedia\": \"http://dbpedia.org/resource/The_Moscow_Times\"}], \"noun_phrases\": [{\"ngram\": \"the journalists\", \"from\": 1886, \"to\": 1901}]}, {\"sentence\": \"But to continue our work,we need your help.\", \"from\": 1946, \"to\": 1989, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"our work\", \"from\": 1962, \"to\": 1970}, {\"ngram\": \"your help\", \"from\": 1979, \"to\": 1988}]}, {\"sentence\": \"Your support, no matter how small, makes a world of difference.\", \"from\": 1991, \"to\": 2054, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Your support\", \"from\": 1991, \"to\": 2003}, {\"ngram\": \"a world\", \"from\": 2032, \"to\": 2039}, {\"ngram\": \"difference\", \"from\": 2043, \"to\": 2053}]}, {\"sentence\": \"If you can, please support us monthly starting from just$2.It's quick to set up, and every contribution makes a significant impact.\", \"from\": 2055, \"to\": 2186, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"us\", \"from\": 2082, \"to\": 2084}, {\"ngram\": \"every contribution\", \"from\": 2140, \"to\": 2158}, {\"ngram\": \"a significant impact\", \"from\": 2165, \"to\": 2185}]}, {\"sentence\": \"By supporting The Moscow Times, you are defending open, independent journalism in the face of repression.\", \"from\": 2188, \"to\": 2293, \"entities\": [{\"begin\": 2202, \"end\": 2218, \"title\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"The Moscow Times\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"dbpedia\": \"http://dbpedia.org/resource/The_Moscow_Times\"}], \"noun_phrases\": [{\"ngram\": \"open, independent journalism\", \"from\": 2238, \"to\": 2266}, {\"ngram\": \"the face\", \"from\": 2270, \"to\": 2278}, {\"ngram\": \"repression\", \"from\": 2282, \"to\": 2292}]}, {\"sentence\": \"Thank you for standing with us.\", \"from\": 2294, \"to\": 2325, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"us\", \"from\": 2322, \"to\": 2324}]}]}"