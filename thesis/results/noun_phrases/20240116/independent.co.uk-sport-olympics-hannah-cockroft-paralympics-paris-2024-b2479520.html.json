ities\": [{\"begin\": 951, \"end\": 958, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9975979680201823, \"rank\": 0.002406116399272854, \"text\": \"Britain\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}, {\"begin\": 986, \"end\": 999, \"title\": \"http://dbpedia.org/resource/Kare_Adenegan\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Kare Adenegan\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kare_Adenegan\", \"dbpedia\": \"http://dbpedia.org/resource/Kare_Adenegan\"}], \"noun_phrases\": [{\"ngram\": \"my main rival\", \"from\": 972, \"to\": 985}, {\"ngram\": \"an ambassador\", \"from\": 1036, \"to\": 1049}, {\"ngram\": \"Dreams\", \"from\": 1054, \"to\": 1060}, {\"ngram\": \"Team GB\", \"from\": 1093, \"to\": 1100}, {\"ngram\": \"Special Olympics GB\", \"from\": 1118, \"to\": 1137}]}, {\"sentence\": \"\\\"But then there is also Fabs, Fabienne Andre, my other British teammate, she's just recently taken the step up onto the podium.\", \"from\": 1140, \"to\": 1267, \"entities\": [{\"begin\": 1195, \"end\": 1202, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9987653830915463, \"rank\": 0.0006258509619291917, \"text\": \"British\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"Fabs\", \"from\": 1164, \"to\": 1168}, {\"ngram\": \"Fabienne Andre\", \"from\": 1170, \"to\": 1184}, {\"ngram\": \"the step\", \"from\": 1239, \"to\": 1247}, {\"ngram\": \"the podium\", \"from\": 1256, \"to\": 1266}]}, {\"sentence\": \"\\\"And it's incredible to see a British 1-2-3 at a championships and hopefully, we can do that at the Paralympic Games because I have never seen it at a Paralympic Games, so that would be really good.\", \"from\": 1269, \"to\": 1467, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a championships\", \"from\": 1316, \"to\": 1331}, {\"ngram\": \"the Paralympic Games\", \"from\": 1365, \"to\": 1385}, {\"ngram\": \"a Paralympic Games\", \"from\": 1418, \"to\": 1436}]}, {\"sentence\": \"\\\"I think it's really realistic for us to get a clean sweep.\", \"from\": 1469, \"to\": 1528, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"us\", \"from\": 1504, \"to\": 1506}, {\"ngram\": \"a clean sweep\", \"from\": 1514, \"to\": 1527}]}, {\"sentence\": \"I have seen how Fabienne is pushing this year, and she's absolutely flying.\", \"from\": 1529, \"to\": 1604, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Fabienne\", \"from\": 1545, \"to\": 1553}]}, {\"sentence\": \"\\\"It's a high, high possibility in the 100m that we could have a British 1-2-3 and that'll be a very special moment.\\\"\", \"from\": 1606, \"to\": 1722, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a high, high possibility\", \"from\": 1612, \"to\": 1636}, {\"ngram\": \"the 100m\", \"from\": 1640, \"to\": 1648}, {\"ngram\": \"a very special moment\", \"from\": 1699, \"to\": 1720}]}, {\"sentence\": \"Dreams will be supporting their ambassadors in the lead up to the Games by ensuring they get the best night's sleep to aid recovery on their journey.\", \"from\": 1724, \"to\": 1873, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Dreams\", \"from\": 1724, \"to\": 1730}, {\"ngram\": \"their ambassadors\", \"from\": 1750, \"to\": 1767}, {\"ngram\": \"the lead\", \"from\": 1771, \"to\": 1779}, {\"ngram\": \"the Games\", \"from\": 1786, \"to\": 1795}, {\"ngram\": \"the best night's sleep\", \"from\": 1817, \"to\": 1839}, {\"ngram\": \"recovery\", \"from\": 1847, \"to\": 1855}, {\"ngram\": \"their journey\", \"from\": 1859, \"to\": 1872}]}, {\"sentence\": \"As a trusted partner, Dreams is providing support for every ParalympicsGB athlete in Paris via a sleep pack, which includes cooling pillow protectors that help regulate temperature, a mattress topper for supreme comfort, as well as a variety of other sleep accessories to ensure all athletes can get the sleep they need to perform at their best.\", \"from\": 1875, \"to\": 2220, \"entities\": [{\"begin\": 1960, \"end\": 1965, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999996721272, \"rank\": 3.279017491149261e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"a trusted partner\", \"from\": 1878, \"to\": 1895}, {\"ngram\": \"Dreams\", \"from\": 1897, \"to\": 1903}, {\"ngram\": \"support\", \"from\": 1917, \"to\": 1924}, {\"ngram\": \"every ParalympicsGB athlete\", \"from\": 1929, \"to\": 1956}, {\"ngram\": \"a sleep pack\", \"from\": 1970, \"to\": 1982}, {\"ngram\": \"pillow protectors\", \"from\": 2007, \"to\": 2024}, {\"ngram\": \"temperature\", \"from\": 2044, \"to\": 2055}, {\"ngram\": \"a mattress topper\", \"from\": 2057, \"to\": 2074}, {\"ngram\": \"supreme comfort\", \"from\": 2079, \"to\": 2094}, {\"ngram\": \"other sleep accessories\", \"from\": 2120, \"to\": 2143}, {\"ngram\": \"all athletes\", \"from\": 2154, \"to\": 2166}, {\"ngram\": \"the sleep\", \"from\": 2175, \"to\": 2184}]}, {\"sentence\": \"Cockroft is entering the latter stages of her storied career that has seen her win seven Paralympic titles and 14 world crowns.\", \"from\": 2222, \"to\": 2349, \"entities\": [{\"begin\": 2222, \"end\": 2230, \"title\": \"http://dbpedia.org/resource/Don_Cockroft\", \"score\": 0.9999999999995453, \"rank\": 0.0, \"text\": \"Cockroft\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q14128148\"], \"wikid\": \"http://dbpedia.org/resource/Don_Cockroft\", \"dbpedia\": \"http://dbpedia.org/resource/Don_Cockroft\"}], \"noun_phrases\": [{\"ngram\": \"the latter stages\", \"from\": 2243, \"to\": 2260}, {\"ngram\": \"her storied career\", \"from\": 2264, \"to\": 2282}, {\"ngram\": \"seven Paralympic titles\", \"from\": 2305, \"to\": 2328}, {\"ngram\": \"14 world crowns\", \"from\": 2333, \"to\": 2348}]}, {\"sentence\": \"The generation inspired by the London Paralympic Games have reached the global stage and still cannot catch Cockroft, so instead she is hoping Paris can reignite the spark and carry on her legacy.\", \"from\": 2351, \"to\": 2547, \"entities\": [{\"begin\": 2382, \"end\": 2388, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9999999988299351, \"rank\": 1.0792505457832664e-09, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}, {\"begin\": 2389, \"end\": 2405, \"title\": \"http://dbpedia.org/resource/Paralympic_Games\", \"score\": 0.9999997308371256, \"rank\": 2.6900524281562544e-07, \"text\": \"Paralympic Games\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Paralympic_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Paralympic_Games\"}, {\"begin\": 2459, \"end\": 2467, \"title\": \"http://dbpedia.org/resource/Don_Cockroft\", \"score\": 0.9999999999995453, \"rank\": 0.0, \"text\": \"Cockroft\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q14128148\"], \"wikid\": \"http://dbpedia.org/resource/Don_Cockroft\", \"dbpedia\": \"http://dbpedia.org/resource/Don_Cockroft\"}, {\"begin\": 2494, \"end\": 2499, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999996721272, \"rank\": 3.279017491149261e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"The generation\", \"from\": 2351, \"to\": 2365}, {\"ngram\": \"the global stage\", \"from\": 2419, \"to\": 2435}, {\"ngram\": \"the spark\", \"from\": 2513, \"to\": 2522}, {\"ngram\": \"her legacy\", \"from\": 2536, \"to\": 2546}]}, {\"sentence\": \"She added: \\\"We have this incredible opportunity to have a games back in Europe, back where we know that people really do support parasport and support disability sport.\", \"from\": 2549, \"to\": 2717, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this incredible opportunity\", \"from\": 2569, \"to\": 2596}, {\"ngram\": \"a games\", \"from\": 2605, \"to\": 2612}, {\"ngram\": \"Europe\", \"from\": 2621, \"to\": 2627}, {\"ngram\": \"people\", \"from\": 2653, \"to\": 2659}, {\"ngram\": \"parasport and support disability sport\", \"from\": 2678, \"to\": 2716}]}, {\"sentence\": \"\\\"And it's what the Paralympic Movement needs.\", \"from\": 2719, \"to\": 2764, \"entities\": [{\"begin\": 2738, \"end\": 2757, \"title\": \"http://dbpedia.org/resource/International_Paralympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Paralympic Movement\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Paralympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Paralympic_Committee\"}], \"noun_phrases\": []}, {\"sentence\": \"It's been 12 years since 2012, that's an entire generation of young people who have not really watched the Paralympic games because of, you know, time differences or where it's been held, and have not really been given the exposure to it.\", \"from\": 2765, \"to\": 3003, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an entire generation\", \"from\": 2803, \"to\": 2823}, {\"ngram\": \"young people\", \"from\": 2827, \"to\": 2839}, {\"ngram\": \"the Paralympic games\", \"from\": 2868, \"to\": 2888}, {\"ngram\": \"time differences\", \"from\": 2911, \"to\": 2927}, {\"ngram\": \"the exposure\", \"from\": 2984, \"to\": 2996}]}, {\"sentence\": \"\\\"The more we can expose them to it, the bigger the sport will get and we will get that excitement that we had around London 2012.\", \"from\": 3005, \"to\": 3134, \"entities\": [{\"begin\": 3122, \"end\": 3133, \"title\": \"http://dbpedia.org/resource/2012_Summer_Paralympics\", \"score\": 0.9999998327812276, \"rank\": 1.6721872148682155e-07, \"text\": \"London 2012\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2012_Summer_Paralympics\", \"dbpedia\": \"http://dbpedia.org/resource/2012_Summer_Paralympics\"}], \"noun_phrases\": [{\"ngram\": \"the sport\", \"from\": 3052, \"to\": 3061}, {\"ngram\": \"that excitement\", \"from\": 3087, \"to\": 3102}]}, {\"sentence\": \"\\\"I think that's what we are really missing, the excitement and people really wanting to watch what we do, I do believe that there are people out there, we just have to open them up to it.\\\"\", \"from\": 3136, \"to\": 3324, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the excitement\", \"from\": 3180, \"to\": 3194}, {\"ngram\": \"people\", \"from\": 3199, \"to\": 3205}, {\"ngram\": \"people\", \"from\": 3270, \"to\": 3276}]}, {\"sentence\": \"Dreams, the UK's leading bed retailer, has been helping the nation find 'The Bed' for almost 40 years.\", \"from\": 3326, \"to\": 3428, \"entities\": [{\"begin\": 3338, \"end\": 3340, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9999996407621629, \"rank\": 3.3070871423457537e-07, \"text\": \"UK\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"Dreams\", \"from\": 3326, \"to\": 3332}, {\"ngram\": \"the nation\", \"from\": 3382, \"to\": 3392}, {\"ngram\": \"The Bed\", \"from\": 3399, \"to\": 3406}, {\"ngram\": \"almost 40 years\", \"from\": 3412, \"to\": 3427}]}, {\"sentence\": \"Dreams has invested in innovative Sleepmatch technology in all its stores and is proud to be the Official Sleep Partner for Team GB, ParalympicsGB and Special Olympics GB.\", \"from\": 3429, \"to\": 3600, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Dreams\", \"from\": 3429, \"to\": 3435}, {\"ngram\": \"innovative Sleepmatch technology\", \"from\": 3452, \"to\": 348