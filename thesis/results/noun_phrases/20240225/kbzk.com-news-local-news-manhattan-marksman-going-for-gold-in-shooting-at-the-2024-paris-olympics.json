\": \"But even so, Sgt.\", \"from\": 1653, \"to\": 1670, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"But even so, Sgt\", \"from\": 1653, \"to\": 1669}]}, {\"sentence\": \"Roe says his dad has been one of his biggest supporters.\", \"from\": 1671, \"to\": 1727, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Roe\", \"from\": 1671, \"to\": 1674}, {\"ngram\": \"his dad\", \"from\": 1680, \"to\": 1687}, {\"ngram\": \"his biggest supporters\", \"from\": 1704, \"to\": 1726}]}, {\"sentence\": \"\\\"He's been with me every step of the way, watching and rooting for me,\\\" said Roe.\", \"from\": 1729, \"to\": 1810, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the way\", \"from\": 1762, \"to\": 1769}, {\"ngram\": \"Roe\", \"from\": 1806, \"to\": 1809}]}, {\"sentence\": \"In July, Roe's father will be on a plane to the Paris Summer Olympics to watch his son go for Gold.\", \"from\": 1812, \"to\": 1911, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"July\", \"from\": 1815, \"to\": 1819}, {\"ngram\": \"Roe's father\", \"from\": 1821, \"to\": 1833}, {\"ngram\": \"a plane\", \"from\": 1845, \"to\": 1852}, {\"ngram\": \"the Paris Summer Olympics\", \"from\": 1856, \"to\": 1881}, {\"ngram\": \"his son\", \"from\": 1891, \"to\": 1898}, {\"ngram\": \"Gold\", \"from\": 1906, \"to\": 1910}]}, {\"sentence\": \"\\\"Being able to put my name on the list of people who have worn the Montana flag and competed proudly for the state is something I look forward to,\\\" said Roe.\", \"from\": 1913, \"to\": 2070, \"entities\": [{\"begin\": 1980, \"end\": 1987, \"title\": \"http://dbpedia.org/resource/Montana\", \"score\": 0.9987841975686247, \"rank\": 0.0009151804969840216, \"text\": \"Montana\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Montana\", \"dbpedia\": \"http://dbpedia.org/resource/Montana\"}], \"noun_phrases\": [{\"ngram\": \"my name\", \"from\": 1932, \"to\": 1939}, {\"ngram\": \"the list\", \"from\": 1943, \"to\": 1951}, {\"ngram\": \"peopl