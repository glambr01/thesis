"{\"uid\": \"newstalk.com-news-olympics-team-ireland-set-for-major-homecoming-celebration-1753256\", \"noun_phrases\": [{\"sentence\": \"Live 19:00-22:00 14.09 8 Aug 2024 Share this article 14.09 8 Aug 2024 Share this article Team Ireland is set to get a major homecoming celebration when the last athletes return home from the Paris Olympics.\", \"from\": 0, \"to\": 212, \"entities\": [{\"begin\": 95, \"end\": 107, \"title\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\", \"score\": 0.9999999904005108, \"rank\": 9.598804239126967e-09, \"text\": \"Team Ireland\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"this article\", \"from\": 76, \"to\": 88}, {\"ngram\": \"a major homecoming celebration\", \"from\": 116, \"to\": 146}, {\"ngram\": \"the last athletes\", \"from\": 152, \"to\": 169}, {\"ngram\": \"the Paris Olympics\", \"from\": 187, \"to\": 205}]}, {\"sentence\": \"The events mark the first time the Irish Olympic team have received a civic reception on their return home.\", \"from\": 214, \"to\": 321, \"entities\": [{\"begin\": 249, \"end\": 254, \"title\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"score\": 0.755282435697326, \"rank\": 0.28895518531534015, \"text\": \"Irish\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"dbpedia\": \"http://dbpedia.org/resource/Republic_of_Ireland\"}], \"noun_phrases\": [{\"ngram\": \"The events\", \"from\": 214, \"to\": 224}, {\"ngram\": \"the first time\", \"from\": 230, \"to\": 244}, {\"ngram\": \"a civic reception\", \"from\": 282, \"to\": 299}, {\"ngram\": \"their return home\", \"from\": 303, \"to\": 320}]}, {\"sentence\": \"The event will take place on Dublin's O'Connell Street in front of the GPO at 12.30pm this Monday August 12th.\", \"from\": 323, \"to\": 433, \"entities\": [{\"begin\": 352, \"end\": 358, \"title\": \"http://dbpedia.org/resource/Dublin\", \"score\": 0.9999927296610704, \"rank\": 7.154004783420842e-06, \"text\": \"Dublin\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Dublin\", \"dbpedia\": \"http://dbpedia.org/resource/Dublin\"}, {\"begin\": 361, \"end\": 377, \"title\": \"http://dbpedia.org/resource/O'Connell_Street\", \"score\": 1.0, \"rank\": 8.34348444311691e-28, \"text\": \"O'Connell Street\", \"types\": [\"Q34442\"], \"wikid\": \"http://dbpedia.org/resource/O'Connell_Street\", \"dbpedia\": \"http://dbpedia.org/resource/O'Connell_Street\"}, {\"begin\": 394, \"end\": 397, \"title\": \"http://dbpedia.org/resource/General_Post_Office\", \"score\": 0.9837443080400015, \"rank\": 0.00986585199820599, \"text\": \"GPO\", \"types\": [\"Q43229\", \"Q327333\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/General_Post_Office\", \"dbpedia\": \"http://dbpedia.org/resource/General_Post_Office\"}], \"noun_phrases\": [{\"ngram\": \"The event\", \"from\": 323, \"to\": 332}, {\"ngram\": \"place\", \"from\": 343, \"to\": 348}, {\"ngram\": \"front\", \"from\": 381, \"to\": 386}]}, {\"sentence\": \"Team Ireland have won seven medals so far at Paris 2024; four gold across four different sports, and three bronze - making itIreland's most successful ever Olympic Games.\", \"from\": 435, \"to\": 605, \"entities\": [{\"begin\": 435, \"end\": 447, \"title\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\", \"score\": 0.9999999904005108, \"rank\": 9.598804239126967e-09, \"text\": \"Team Ireland\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"seven medals\", \"from\": 457, \"to\": 469}, {\"ngram\": \"Paris\", \"from\": 480, \"to\": 485}, {\"ngram\": \"four gold\", \"from\": 492, \"to\": 501}, {\"ngram\": \"four different sports\", \"from\": 509, \"to\": 530}, {\"ngram\": \"three bronze - making itIreland's most successful ever Olympic Games\", \"from\": 536, \"to\": 604}]}, {\"sentence\": \"Dublin Lord Mayor James Geoghegan said the reception is a chance for people to thank the athletes.\", \"from\": 607, \"to\": 705, \"entities\": [{\"begin\": 607, \"end\": 624, \"title\": \"http://dbpedia.org/resource/Lord_Mayor_of_Dublin\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Dublin Lord Mayor\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Lord_Mayor_of_Dublin\", \"dbpedia\": \"http://dbpedia.org/resource/Lord_Mayor_of_Dublin\"}, {\"begin\": 625, \"end\": 640, \"title\": \"http://dbpedia.org/resource/James_Geoghegan\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"James Geoghegan\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/James_Geoghegan\", \"dbpedia\": \"http://dbpedia.org/resource/James_Geoghegan\"}], \"noun_phrases\": [{\"ngram\": \"the reception\", \"from\": 646, \"to\": 659}, {\"ngram\": \"a chance\", \"from\": 663, \"to\": 671}, {\"ngram\": \"people\", \"from\": 676, \"to\": 682}, {\"ngram\": \"the athletes\", \"from\": 692, \"to\": 704}]}, {\"sentence\": \"\\\"Now is our chance to tell them in person just how proud we are of them,\\\" he said.\", \"from\": 707, \"to\": 789, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"our chance\", \"from\": 715, \"to\": 725}, {\"ngram\": \"person\", \"from\": 742, \"to\": 748}]}, {\"sentence\": \"\\\"I have no doubt their efforts will have inspired lots of girls and boys all over the city and country to try and be like them some day.\\\"\", \"from\": 791, \"to\": 928, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"their efforts\", \"from\": 808, \"to\": 821}, {\"ngram\": \"lots\", \"from\": 841, \"to\": 845}, {\"ngram\": \"girls\", \"from\": 849, \"to\": 854}, {\"ngram\": \"boys\", \"from\": 859, \"to\": 863}, {\"ngram\": \"the city\", \"from\": 873, \"to\": 881}, {\"ngram\": \"country\", \"from\": 886, \"to\": 893}]}, {\"sentence\": \"Team Ireland Chef de Mission Gavin Noble has welcomed the special event to honour them.\", \"from\": 932, \"to\": 1019, \"entities\": [{\"begin\": 932, \"end\": 944, \"title\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\", \"score\": 0.9999999904005108, \"rank\": 9.598804239126967e-09, \"text\": \"Team Ireland\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\"}, {\"begin\": 945, \"end\": 960, \"title\": \"http://dbpedia.org/resource/Head_of_mission\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Chef de Mission\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Head_of_mission\", \"dbpedia\": \"http://dbpedia.org/resource/Head_of_mission\"}, {\"begin\": 961, \"end\": 972, \"title\": \"http://dbpedia.org/resource/Gavin_Noble\", \"score\": 0.9999958127936122, \"rank\": 0.0, \"text\": \"Gavin Noble\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Gavin_Noble\", \"dbpedia\": \"http://dbpedia.org/resource/Gavin_Noble\"}], \"noun_phrases\": [{\"ngram\": \"the special event\", \"from\": 986, \"to\": 1003}]}, {\"sentence\": \"\\\"Over the past few weeks our athletes have performed outstandingly and have inspired the nation with their endeavours at the Olympic Games in Paris,\\\" he said.\", \"from\": 1021, \"to\": 1179, \"entities\": [{\"begin\": 1163, \"end\": 1168, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999967079681555, \"rank\": 3.29204269452983e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"the past few weeks\", \"from\": 1027, \"to\": 1045}, {\"ngram\": \"our athletes\", \"from\": 1046, \"to\": 1058}, {\"ngram\": \"the nation\", \"from\": 1106, \"to\": 1116}, {\"ngram\": \"their endeavours\", \"from\": 1122, \"to\": 1138}, {\"ngram\": \"the Olympic Games\", \"from\": 1142, \"to\": 1159}]}, {\"sentence\": \"\\\"We are really proud of each and every one of them and we would like to thank Dublin City Council for hosting such a special event to honour them.\\\"\", \"from\": 1181, \"to\": 1328, \"entities\": [{\"begin\": 1259, \"end\": 1278, \"title\": \"http://dbpedia.org/resource/Dublin_City_Council\", \"score\": 1.0, \"rank\": 5.716108352242407e-27, \"text\": \"Dublin City Council\", \"types\": [\"Q43229\", \"Q24229398\", \"Q11204\"], \"wikid\": \"http://dbpedia.org/resource/Dublin_City_Council\", \"dbpedia\": \"http://dbpedia.org/resource/Dublin_City_Council\"}], \"noun_phrases\": [{\"ngram\": \"such a special event\", \"from\": 1291, \"to\": 1311}]}, {\"sentence\": \"To celebrate Team Ireland's achievements, the Samuel Beckett Bridge will also feature a special message this Saturday and Sunday evening.\", \"from\": 1330, \"to\": 1467, \"entities\": [{\"begin\": 1343, \"end\": 1355, \"title\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\", \"score\": 0.9999999904005108, \"rank\": 9.598804239126967e-09, \"text\": \"Team Ireland\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Ireland_at_the_Olympics\"}, {\"begin\": 1376, \"end\": 1397, \"title\": \"http://dbpedia.org/resource/Samuel_Beckett_Bridge\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Samuel Beckett Bridge\", \"types\": [\"Q12280\"], \"wikid\": \"http://dbpedia.org/resource/Samuel_Beckett_Bridge\", \"dbpedia\": \"http://dbpedia.org/resource/Samuel_Beckett_Bridge\"}], \"noun_phrases\": [{\"ngram\": \"a special message\", \"from\": 1416, \"to\": 1433}]}, {\"sentence\": \"Dublin City Council is asking people to use public transport when travelling to and from the event, which is family-friendly and alcohol-free.\", \"from\": 1469, \"to\": 1611, \"entities\": [{\"begin\": 1469, \"end\": 1488, \"title\": \"http://dbpedia.org/resource/Dublin_City_Counci