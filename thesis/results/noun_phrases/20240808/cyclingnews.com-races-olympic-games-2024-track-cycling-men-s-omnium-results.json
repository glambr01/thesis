gram\": \"a crash\", \"from\": 591, \"to\": 598}, {\"ngram\": \"a miscue\", \"from\": 603, \"to\": 611}, {\"ngram\": \"the officials\", \"from\": 615, \"to\": 628}, {\"ngram\": \"the elimination race\", \"from\": 632, \"to\": 652}, {\"ngram\": \"victory\", \"from\": 664, \"to\": 671}, {\"ngram\": \"11 points\", \"from\": 675, \"to\": 684}]}, {\"sentence\": \"World champion Iuri Leitao (Portugal) claimed the silver medal, and Fabio Van Den Bossche (Belgium) snatched the bronze in a close-fought race filled with attacks.\", \"from\": 687, \"to\": 850, \"entities\": [{\"begin\": 715, \"end\": 723, \"title\": \"http://dbpedia.org/resource/Portugal_national_football_team\", \"score\": 0.9999999191613856, \"rank\": 8.03503699529844e-08, \"text\": \"Portugal\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Portugal_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Portugal_national_football_team\"}, {\"begin\": 778, \"end\": 785, \"title\": \"http://dbpedia.org/resource/Belgium\", \"score\": 0.999987591528358, \"rank\": 1.240861459440335e-05, \"text\": \"Belgium\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Belgium\", \"dbpedia\": \"http://dbpedia.org/resource/Belgium\"}], \"noun_phrases\": [{\"ngram\": \"World champion Iuri Leitao\", \"from\": 687, \"to\": 713}, {\"ngram\": \"the silver medal\", \"from\": 733, \"to\": 749}, {\"ngram\": \"Fabio Van Den Bossche\", \"from\": 755, \"to\": 776}, {\"ngram\": \"the bronze\", \"from\": 796, \"to\": 806}, {\"ngram\": \"a close-fought race\", \"from\": 810, \"to\": 829}, {\"ngram\": \"attacks\", \"from\": 842, \"to\": 849}]}, {\"sentence\": \"\\\"It's a cascade of emotions - once I crossed the line and all my friends and family were here,\\\" Thomas said.\", \"from\": 852, \"to\": 960, \"entities\": [{\"begin\": 948, \"end\": 954, \"title\": \"http://dbpedia.org/resource/Thomas_Wayne\", \"score\": 0.8780562708367359, \"rank\": 0.138876807102147