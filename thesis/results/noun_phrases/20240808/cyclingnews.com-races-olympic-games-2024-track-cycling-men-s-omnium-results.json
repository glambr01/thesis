, {\"sentence\": \"Thomas came into the final race of the Omnium, the points race, in second place in the standings, having won the scratch race and come second in the elimination.\", \"from\": 1266, \"to\": 1427, \"entities\": [{\"begin\": 1266, \"end\": 1272, \"title\": \"http://dbpedia.org/resource/Thomas_Wayne\", \"score\": 0.8780562708367359, \"rank\": 0.13887680710214756, \"text\": \"Thomas\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Thomas_Wayne\", \"dbpedia\": \"http://dbpedia.org/resource/Thomas_Wayne\"}], \"noun_phrases\": [{\"ngram\": \"the final race\", \"from\": 1283, \"to\": 1297}, {\"ngram\": \"the Omnium\", \"from\": 1301, \"to\": 1311}, {\"ngram\": \"the points race\", \"from\": 1313, \"to\": 1328}, {\"ngram\": \"second place\", \"from\": 1333, \"to\": 1345}, {\"ngram\": \"the standings\", \"from\": 1349, \"to\": 1362}, {\"ngram\": \"the scratch race\", \"from\": 1375, \"to\": 1391}, {\"ngram\": \"the elimination\", \"from\": 1411, \"to\": 1426}]}, {\"sentence\": \"He was eight points behind Belgium's Van Den Bossche but made all the right moves.\", \"from\": 1428, \"to\": 1510, \"entities\": [{\"begin\": 1455, \"end\": 1462, \"title\": \"http://dbpedia.org/resource/Belgium\", \"score\": 0.999987591528358, \"rank\": 1.240861459440335e-05, \"text\": \"Belgium\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Belgium\", \"dbpedia\": \"http://dbpedia.org/resource/Belgium\"}], \"noun_phrases\": [{\"ngram\": \"all the right moves\", \"from\": 1490, \"to\": 1509}]}, {\"sentence\": \"Thomas attacked to claim the second sprint in the 100-lap points race and then lapped the field together with Aaron Gate (New Zealand), Van Den Bossche and Japan's Kazushige Kuboki.\", \"from\": 1511, \"to\": 1692, \"entities\": [{\"begin\": 1511, \"end\": 1517, \"title\": \"http://dbpedia.org/resource/Thomas_Wayne\", \"score\": 0.8780562708367359, \"rank\": 0.13887680710214756, \"text\": \"Thomas\", \"types\": [\"Q9507