"{\"uid\": \"jamaicaobserver.com-2024-08-08-parisolympics-bronze-broadbell-110m-hurdles\", \"noun_phrases\": [{\"sentence\": \"KINGSTON, Jamaica - Rasheed Broadbell ran a season's best 13.09 seconds (-0.1m/s) to snatch a bronze medal in the 110m hurdles on Thursday's evening session of the Olympic Games at Stade de France in Paris, Jamaica's sixth medal of the Games.\", \"from\": 0, \"to\": 242, \"entities\": [{\"begin\": 10, \"end\": 17, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.9999946512268509, \"rank\": 3.924914054523335e-06, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}, {\"begin\": 200, \"end\": 205, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999883791900778, \"rank\": 1.1620944962920373e-05, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 207, \"end\": 214, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.9999946512268509, \"rank\": 3.924914054523335e-06, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}], \"noun_phrases\": [{\"ngram\": \"KINGSTON\", \"from\": 0, \"to\": 8}, {\"ngram\": \"a season's best 13.09 seconds\", \"from\": 42, \"to\": 71}, {\"ngram\": \"-0.1\", \"from\": 73, \"to\": 77}, {\"ngram\": \"m/s\", \"from\": 77, \"to\": 80}, {\"ngram\": \"a bronze medal\", \"from\": 92, \"to\": 106}, {\"ngram\": \"the 110m hurdles\", \"from\": 110, \"to\": 126}, {\"ngram\": \"Thursday's evening session\", \"from\": 130, \"to\": 156}, {\"ngram\": \"the Olympic Games\", \"from\": 160, \"to\": 177}, {\"ngram\": \"Stade de France\", \"from\": 181, \"to\": 196}, {\"ngram\": \"the Games\", \"from\": 232, \"to\": 241}]}, {\"sentence\": \"Jamaican athletes have now won one gold, three silver and two bronze medals at the Games.\", \"from\": 244, \"to\": 333, \"entities\": [{\"begin\": 244, \"end\": 252, \"title\": \"http://dbpedia.org/resource/Jamaicans\", \"score\": 0.9051815831499115, \"rank\": 0.10474945012298507, \"text\": \"Jamaican\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Jamaicans\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaicans\"}], \"noun_phrases\": [{\"ngram\": \"one gold\", \"from\": 275, \"to\": 283}, {\"ngram\": \"three silver\", \"from\": 285, \"to\": 297}, {\"ngram\": \"two bronze medals\", \"from\": 302, \"to\": 319}, {\"ngram\": \"the Games\", \"from\": 323, \"to\": 332}]}, {\"sentence\": \"It was sweet redemption for Broadbell, the Commonwealth Games champion, who failed to complete the first round at last year's World Athletics Championships in Budapest, Hungary when he was favoured to medal.\", \"from\": 335, \"to\": 542, \"entities\": [{\"begin\": 378, \"end\": 396, \"title\": \"http://dbpedia.org/resource/Commonwealth_Games\", \"score\": 0.99998350393421, \"rank\": 1.3985910096596718e-05, \"text\": \"Commonwealth Games\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Commonwealth_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Commonwealth_Games\"}, {\"begin\": 461, \"end\": 490, \"title\": \"http://dbpedia.org/resource/World_Athletics_Championships\", \"score\": 0.9998325695750019, \"rank\": 0.00016601799787624674, \"text\": \"World Athletics Championships\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics_Championships\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics_Championships\"}, {\"begin\": 494, \"end\": 502, \"title\": \"http://dbpedia.org/resource/Budapest\", \"score\": 0.9995275370360767, \"rank\": 0.0004725149819885182, \"text\": \"Budapest\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Budapest\", \"dbpedia\": \"http://dbpedia.org/resource/Budapest\"}, {\"begin\": 504, \"end\": 511, \"tit