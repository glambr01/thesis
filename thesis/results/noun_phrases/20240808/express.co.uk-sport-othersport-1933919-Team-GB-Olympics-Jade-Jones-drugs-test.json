noun_phrases\": [{\"ngram\": \"weight\", \"from\": 1246, \"to\": 1252}, {\"ngram\": \"a few days\", \"from\": 1289, \"to\": 1299}]}, {\"sentence\": \"\\\"I needed to dehydrate.\", \"from\": 1302, \"to\": 1325, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I become stressed.\", \"from\": 1326, \"to\": 1344, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I thought you could miss three.\", \"from\": 1345, \"to\": 1376, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I signed a piece of paper but I did not know what I was signing.\", \"from\": 1377, \"to\": 1441, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a piece\", \"from\": 1386, \"to\": 1393}, {\"ngram\": \"paper\", \"from\": 1397, \"to\": 1402}]}, {\"sentence\": \"\\\"I was lucky they looked into it and it all got sorted and it got proven I was innocent.\", \"from\": 1443, \"to\": 1531, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I am just so grateful, blessed that they looked into it, that I was cleared, I was in no fault.\", \"from\": 1532, \"to\": 1627, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"no fault\", \"from\": 1618, \"to\": 1626}]}, {\"sentence\": \"It was a big story.\", \"from\": 1628, \"to\": 1647, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a big story\", \"from\": 1635, \"to\": 1646}]}, {\"sentence\": \"It wasn't one thing..I was grateful to be here.\\\"\", \"from\": 1648, \"to\": 1696, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"one thing\", \"from\": 1658, \"to\": 1667}]}, {\"sentence\": \"Jones, who won gold in London 2012 at the age of 19 and successfully defended her title in Rio, had been aiming to make history as the first three-time Olympic champion in her sport.\", \"from\": 1698, \"to\": 1880, \"entities\": [{\"begin\": 1721, \"end\": 1732, \"title\": \"http://dbpedia.org/resource/2012_Summer_Olympics\", \"score\": 0.9999999567926361, \"rank\": 4.320726528702484e-08, \"text\": \"London 2012\", \"types\": [\"Q1656682