hrases\": [{\"ngram\": \"Every race\", \"from\": 905, \"to\": 915}, {\"ngram\": \"10 hurdles\", \"from\": 931, \"to\": 941}, {\"ngram\": \"reporters\", \"from\": 953, \"to\": 962}]}, {\"sentence\": \"\\\"Obviously there is people next to you that are going to push you, but it does not matter if you do not focus on the barriers in front of you.\", \"from\": 964, \"to\": 1106, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"people\", \"from\": 984, \"to\": 990}, {\"ngram\": \"the barriers\", \"from\": 1077, \"to\": 1089}, {\"ngram\": \"front\", \"from\": 1093, \"to\": 1098}]}, {\"sentence\": \"\\\"So that was my focus - me trying to be as efficient as I could over those 10 hurdles and me trying to lower that time every time.\", \"from\": 1108, \"to\": 1238, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my focus\", \"from\": 1121, \"to\": 1129}, {\"ngram\": \"those 10 hurdles\", \"from\": 1177, \"to\": 1193}, {\"ngram\": \"that time\", \"from\": 1217, \"to\": 1226}]}, {\"sentence\": \"\\\"There was a lot of anticipation leading up to this race specifically, rightfully so\\u2026But you channel those nerves into excitement.\\\"\", \"from\": 1240, \"to\": 1371, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a lot\", \"from\": 1251, \"to\": 1256}, {\"ngram\": \"anticipation\", \"from\": 1260, \"to\": 1272}, {\"ngram\": \"this race\", \"from\": 1287, \"to\": 1296}, {\"ngram\": \"those nerves\", \"from\": 1341, \"to\": 1353}, {\"ngram\": \"excitement\", \"from\": 1359, \"to\": 1369}]}, {\"sentence\": \"Asked if she had run the perfect race, McLaughlin-Levrone replied: \\\"There is always things you can improve.\", \"from\": 1373, \"to\": 1480, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the perfect race\", \"from\": 1394, \"to\": 1410}, {\"ngram\": \"McLaughlin-Levrone\", \"from\": 1412, \"to\": 1430}, {\"ngram\": \"things\", \"from\": 1457, \"to\": 1463}]}, {\"sentence\": \"\\\"There is no such thing as a perfect race but the closer and closer we can get 