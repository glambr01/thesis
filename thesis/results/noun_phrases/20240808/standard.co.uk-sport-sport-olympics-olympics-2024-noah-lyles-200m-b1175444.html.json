hrases\": [{\"ngram\": \"Lyles\", \"from\": 1431, \"to\": 1436}, {\"ngram\": \"the media\", \"from\": 1454, \"to\": 1463}, {\"ngram\": \"a vague enough phrase\", \"from\": 1544, \"to\": 1565}, {\"ngram\": \"the rumour mill\", \"from\": 1573, \"to\": 1588}, {\"ngram\": \"work\", \"from\": 1592, \"to\": 1596}]}, {\"sentence\": \"Was this the 27-year-old conserving energy in his fifth race in as many days, or is something physically amiss?\", \"from\": 1599, \"to\": 1710, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the 27-year-old conserving energy\", \"from\": 1608, \"to\": 1641}, {\"ngram\": \"his fifth race\", \"from\": 1645, \"to\": 1659}, {\"ngram\": \"as many days\", \"from\": 1663, \"to\": 1675}, {\"ngram\": \"something\", \"from\": 1683, \"to\": 1692}]}, {\"sentence\": \"Either way, the uncertainty has added a layer of intrigue to the final that would not have been there had Lyles blown the field away while easing down.\", \"from\": 1712, \"to\": 1863, \"entities\": [{\"begin\": 1818, \"end\": 1823, \"title\": \"http://dbpedia.org/resource/Jordan_Lyles\", \"score\": 0.9986685107147885, \"rank\": 0.001331845518181823, \"text\": \"Lyles\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Jordan_Lyles\", \"dbpedia\": \"http://dbpedia.org/resource/Jordan_Lyles\"}], \"noun_phrases\": [{\"ngram\": \"the uncertainty\", \"from\": 1724, \"to\": 1739}, {\"ngram\": \"a layer\", \"from\": 1750, \"to\": 1757}, {\"ngram\": \"intrigue\", \"from\": 1761, \"to\": 1769}, {\"ngram\": \"the field\", \"from\": 1830, \"to\": 1839}]}, {\"sentence\": \"Tebogo is one threat, but, if Lyles is short of his best, then virtually the entire field is in play, all but one of the eight finalists having broken the 20sec barrier this season.\", \"from\": 1865, \"to\": 2046, \"entities\": [{\"begin\": 1895, \"end\": 1900, \"title\": \"http://dbpedia.org/resource/Jordan_Lyles\", \"score\": 0.9986685107147885, \"rank\": 0.0013318