rom\": 359, \"to\": 364}, {\"ngram\": \"a great shot\", \"from\": 374, \"to\": 386}, {\"ngram\": \"silver\", \"from\": 398, \"to\": 404}, {\"ngram\": \"bronze\", \"from\": 408, \"to\": 414}]}, {\"sentence\": \"Follow Metro.co.uk's live blog for updates from the Paris 2024 Olympics But disaster struck just seconds into the race when officials deemed they had crossed the starting line before the starting horn had sounded.\", \"from\": 417, \"to\": 631, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Follow Metro.co.uk's live blog\", \"from\": 417, \"to\": 447}, {\"ngram\": \"updates\", \"from\": 452, \"to\": 459}, {\"ngram\": \"the Paris 2024 Olympics\", \"from\": 465, \"to\": 488}, {\"ngram\": \"disaster\", \"from\": 493, \"to\": 501}, {\"ngram\": \"just seconds\", \"from\": 509, \"to\": 521}, {\"ngram\": \"the race\", \"from\": 527, \"to\": 535}, {\"ngram\": \"officials\", \"from\": 541, \"to\": 550}, {\"ngram\": \"the starting line\", \"from\": 575, \"to\": 592}, {\"ngram\": \"the starting horn\", \"from\": 600, \"to\": 617}]}, {\"sentence\": \"They were disqualified from the race soon after, with Burnet visibly distressed by the situation, and as a result scored a maximum 22 points.\", \"from\": 633, \"to\": 774, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the race\", \"from\": 661, \"to\": 669}, {\"ngram\": \"Burnet\", \"from\": 687, \"to\": 693}, {\"ngram\": \"the situation\", \"from\": 716, \"to\": 729}, {\"ngram\": \"a result\", \"from\": 738, \"to\": 746}, {\"ngram\": \"a maximum 22 points\", \"from\": 754, \"to\": 773}]}, {\"sentence\": \"In sailing, the fewer the points the better.\", \"from\": 775, \"to\": 819, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"sailing\", \"from\": 778, \"to\": 785}]}, {\"sentence\": \"Gimson and Burnet were left hoping for the race to be called off due to a lack of wind, something that has already happened 11 times during the sailing events at this games, but luck was not on their side.\", \"from\": 821, \"to\":