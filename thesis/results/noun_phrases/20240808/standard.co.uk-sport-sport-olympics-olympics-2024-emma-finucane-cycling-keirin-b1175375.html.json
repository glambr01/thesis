], \"noun_phrases\": [{\"ngram\": \"us\", \"from\": 1189, \"to\": 1191}, {\"ngram\": \"a lot\", \"from\": 1192, \"to\": 1197}, {\"ngram\": \"hope\", \"from\": 1201, \"to\": 1205}, {\"ngram\": \"confidence\", \"from\": 1210, \"to\": 1220}, {\"ngram\": \"the rest\", \"from\": 1225, \"to\": 1233}, {\"ngram\": \"the week\", \"from\": 1237, \"to\": 1245}]}, {\"sentence\": \"I am really excited to see what we can do.\\\"\", \"from\": 1247, \"to\": 1290, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"In her case what she is trying to do is a first: aiming to be the first British woman to win three golds at a singleOlympic Games.\", \"from\": 1292, \"to\": 1422, \"entities\": [{\"begin\": 1364, \"end\": 1371, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9133599216714771, \"rank\": 0.09481345799561337, \"text\": \"British\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"her case\", \"from\": 1295, \"to\": 1303}, {\"ngram\": \"three golds\", \"from\": 1385, \"to\": 1396}, {\"ngram\": \"a singleOlympic Games\", \"from\": 1400, \"to\": 1421}]}, {\"sentence\": \"The two men to have achieved that feat are both here in Paris: Sir Chris Hoy for the BBC and Sir Jason Kenny, now part ofTeam GB's coaching set-up.\", \"from\": 1424, \"to\": 1571, \"entities\": [{\"begin\": 1480, \"end\": 1485, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.0469606241658677e-16, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 1491, \"end\": 1500, \"title\": \"http://dbpedia.org/resource/Chris_Hoy\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Chris Hoy\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Chris_Hoy\", \"dbpedia\": \"http://dbpedia.o