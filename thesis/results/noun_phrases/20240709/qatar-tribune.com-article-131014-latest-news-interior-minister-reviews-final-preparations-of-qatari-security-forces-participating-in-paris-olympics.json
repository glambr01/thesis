, \"to\": 1449, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the experience\", \"from\": 1343, \"to\": 1357}, {\"ngram\": \"the Qatari security forces\", \"from\": 1368, \"to\": 1394}, {\"ngram\": \"major international events\", \"from\": 1422, \"to\": 1448}]}, {\"sentence\": \"He listened to a detailed explanation from team leaders and specialized units about the tasks that the force will undertake according to specific operational plans and arrangements for their participation in securing the event, in coordination with the organizing committee and relevant committees.\", \"from\": 1451, \"to\": 1749, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a detailed explanation\", \"from\": 1466, \"to\": 1488}, {\"ngram\": \"team leaders\", \"from\": 1494, \"to\": 1506}, {\"ngram\": \"specialized units\", \"from\": 1511, \"to\": 1528}, {\"ngram\": \"the tasks\", \"from\": 1535, \"to\": 1544}, {\"ngram\": \"the force\", \"from\": 1550, \"to\": 1559}, {\"ngram\": \"specific operational plans\", \"from\": 1588, \"to\": 1614}, {\"ngram\": \"arrangements\", \"from\": 1619, \"to\": 1631}, {\"ngram\": \"their participation\", \"from\": 1636, \"to\": 1655}, {\"ngram\": \"the event\", \"from\": 1668, \"to\": 1677}, {\"ngram\": \"coordination\", \"from\": 1682, \"to\": 1694}, {\"ngram\": \"the organizing committee\", \"from\": 1700, \"to\": 1724}, {\"ngram\": \"relevant committees\", \"from\": 1729, \"to\": 1748}]}, {\"sentence\": \"The Qatari security forces participate in security operations with elements representing various specialized security groups and units, including the Special Forces Unit (Lafdawiya), the Personal Protection Group, the Explosive Ordnance Disposal Group, the Cyber Security Unit, in addition to security patrol units and fantasy patrols, counter-drone teams, planning teams, supply teams, airport security teams, along with the Command and Control Center and the International Police Cooperation Center (IPCC).\", \"from\": 1751, \"to\": 2259, \"entit