"{\"uid\": \"si.com-college-louisville-other-sports-jayden-ulrich-named-to-2024-olympics-roster\", \"noun_phrases\": [{\"sentence\": \"Press Release from the University of Louisville: INDIANAPOLIS, Ind.\", \"from\": 0, \"to\": 68, \"entities\": [{\"begin\": 0, \"end\": 13, \"title\": \"http://dbpedia.org/resource/Press_release\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Press Release\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Press_release\", \"dbpedia\": \"http://dbpedia.org/resource/Press_release\"}, {\"begin\": 50, \"end\": 62, \"title\": \"http://dbpedia.org/resource/Indianapolis\", \"score\": 0.9999470834140641, \"rank\": 2.866540885105036e-05, \"text\": \"INDIANAPOLIS\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Indianapolis\", \"dbpedia\": \"http://dbpedia.org/resource/Indianapolis\"}, {\"begin\": 64, \"end\": 68, \"title\": \"http://dbpedia.org/resource/Indiana\", \"score\": 0.9999924566134566, \"rank\": 7.4631170303624165e-06, \"text\": \"Ind.\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Indiana\", \"dbpedia\": \"http://dbpedia.org/resource/Indiana\"}], \"noun_phrases\": [{\"ngram\": \"the University\", \"from\": 19, \"to\": 33}, {\"ngram\": \"Louisville\", \"from\": 37, \"to\": 47}]}, {\"sentence\": \"\\u00e2\\u0080\\u0093\\u00c2University of Louisville women\\u00e2\\u0080\\u0099s track & field athlete Jayden Ulrich has been named to the USA Track & Field roster for the 2024 Paris Olympics, as announced by the organization today.\", \"from\": 69, \"to\": 259, \"entities\": [{\"begin\": 87, \"end\": 97, \"title\": \"http://dbpedia.org/resource/Louisville_Cardinals\", \"score\": 0.9886426963305975, \"rank\": 0.009968561203350507, \"text\": \"Louisville\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/Louisville_Cardinals\", \"dbpedia\": \"http://dbpedia.org/resource/Louisville_Cardinals\"}, {\"begin\": 166, \"end\": 183, \"title\": \"http://dbpedia.org/resource/USA_Track_&_Field\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"USA Track & Field\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/USA_Track_&_Field\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Track_&_Field\"}], \"noun_phrases\": [{\"ngram\": \"the 2024 Paris Olympics\", \"from\": 195, \"to\": 218}, {\"ngram\": \"the organization\", \"from\": 236, \"to\": 252}]}, {\"sentence\": \"Ulrich, who will compete in the women\\u00e2\\u0080\\u0099s discus throw in Paris, becomes the first track & field athlete in Louisville history to represent the United States at the Olympic Games.\", \"from\": 261, \"to\": 440, \"entities\": [{\"begin\": 261, \"end\": 267, \"title\": \"http://dbpedia.org/resource/Skeet_Ulrich\", \"score\": 0.992283325922897, \"rank\": 0.007776684185366715, \"text\": \"Ulrich\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Skeet_Ulrich\", \"dbpedia\": \"http://dbpedia.org/resource/Skeet_Ulrich\"}, {\"begin\": 319, \"end\": 324, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999987997887655, \"rank\": 1.2002125554815857e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 369, \"end\": 379, \"title\": \"http://dbpedia.org/resource/Louisville_Cardinals\", \"score\": 0.9886426963305975, \"rank\": 0.009968561203350507, \"text\": \"Louisville\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/Louisville_Cardinals\", \"dbpedia\": \"http://dbpedia.org/resource/Louisville_Cardinals\"}, {\"begin\": 405, \"end\": 418, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 0.9881343288352743, \"rank\": 0.010363161387654377, \"text\": \"United States\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\"}], \"noun_phrases\": [{\"ngram\": \"the women\\u00e2\\u0080\\u0099s discus throw\", \"from\": 289, \"to\": 315}, {\"ngram\": \"the first track & field athlete\", \"from\": 334, \"to\": 365}, {\"ngram\": \"the Olympic Games\", \"from\": 422, \"to\": 439}]}, {\"sentence\": \"She is also the second female Olympian in the history of the program after Chinwe Okoro contested the women\\u00e2\\u0080\\u0099s discus throw for Nigeria at the 2016 Rio Olympics.\", \"from\": 441, \"to\": 603, \"entities\": [{\"begin\": 471, \"end\": 479, \"title\": \"http://dbpedia.org/resource/Olympic_Games\", \"score\": 0.99999889941561, \"rank\": 1.1005856614271857e-06, \"text\": \"Olympian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games\"}, {\"begin\": 516, \"end\": 528, \"title\": \"http://dbpedia.org/resource/Chinwe_Okoro\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Chinwe Okoro\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Chinwe_Okoro\", \"dbpedia\": \"http://dbpedia.org/resource/Chinwe_Okoro\"}, {\"begin\": 570, \"end\": 577, \"title\": \"http://dbpedia.org/resource/Nigeria\", \"score\": 0.8270659504864726, \"rank\": 0.20863461078426082, \"text\": \"Nigeria\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Nigeria\", \"dbpedia\": \"http://dbpedia.org/resource/Nigeria\"}], \"noun_phrases\": [{\"ngram\": \"the history\", \"from\": 483, \"to\": 494}, {\"ngram\": \"the program\", \"from\": 498, \"to\": 509}, {\"ngram\": \"the women\\u00e2\\u0080\\u0099s discus throw\", \"from\": 539, \"to\": 565}, {\"ngram\": \"the 2016 Rio Olympics\", \"from\": 581, \"to\": 602}]}, {\"sentence\": \"\\u00e2\\u0080\\u009cBeing selected to the U.S. Olympic team is indicative of Jayden\\u00e2\\u0080\\u0099s ability and dedication that has allowed her to reach the pinnacle of our sport,\\u00e2\\u0080\\u009d said director of track & field and cross country Joe Franklin.\", \"from\": 605, \"to\": 821, \"entities\": [{\"begin\": 808, \"end\": 811, \"title\": \"http://dbpedia.org/resource/Joe_DiMaggio\", \"score\": 0.9066376018058858, \"rank\": 0.08046990385594338, \"text\": \"Joe\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Joe_DiMaggio\", \"dbpedia\": \"http://dbpedia.org/resource/Joe_DiMaggio\"}, {\"begin\": 812, \"end\": 820, \"title\": \"http://dbpedia.org/resource/Benjamin_Franklin\", \"score\": 0.9999999804540496, \"rank\": 1.9545942452211948e-08, \"text\": \"Franklin\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Benjamin_Franklin\", \"dbpedia\": \"http://dbpedia.org/resource/Benjamin_Franklin\"}], \"noun_phrases\": [{\"ngram\": \"\\u00e2\\u0080\\u009cBeing\", \"from\": 605, \"to\": 613}, {\"ngram\": \"the U.S. Olympic team\", \"from\": 626, \"to\": 647}, {\"ngram\": \"Jayden\\u00e2\\u0080\\u0099s ability\", \"from\": 665, \"to\": 683}, {\"ngram\": \"dedication\", \"from\": 688, \"to\": 698}, {\"ngram\": \"the pinnacle\", \"from\": 729, \"to\": 741}, {\"ngram\": \"our sport\", \"from\": 745, \"to\": 754}, {\"ngram\": \"director\", \"from\": 764, \"to\": 772}, {\"ngram\": \"track\", \"from\": 776, \"to\": 781}, {\"ngram\": \"field\", \"from\": 784, \"to\": 789}, {\"ngram\": \"cross country\", \"from\": 794, \"to\": 807}]}, {\"sentence\": \"\\u00e2\\u0080\\u009cMaking the team and becoming the first U.S. Olympian in our program\\u00e2\\u0080\\u0099s history is not only important for Jayden but also for the entire University of Louisville to be represented on the Olympic stage.\\u00e2\\u0080\\u009d \\u00e2\\u0080\\u009cJayden\\u00e2\\u0080\\u0099s selection to the United States Olympic team is a testament to her ability, determination, and fortitude that is required for her sport,\\u00e2\\u0080\\u009d added throws coach Cory Martin.\", \"from\": 822, \"to\": 1215, \"entities\": [{\"beg