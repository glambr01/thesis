, \"from\": 1655, \"to\": 1862, \"entities\": [{\"begin\": 1753, \"end\": 1760, \"title\": \"http://dbpedia.org/resource/Florida\", \"score\": 0.9999999999768079, \"rank\": 7.326722734658041e-12, \"text\": \"Florida\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Florida\", \"dbpedia\": \"http://dbpedia.org/resource/Florida\"}], \"noun_phrases\": [{\"ngram\": \"all the things\", \"from\": 1673, \"to\": 1687}, {\"ngram\": \"our stake\", \"from\": 1721, \"to\": 1730}, {\"ngram\": \"the ground\", \"from\": 1734, \"to\": 1744}, {\"ngram\": \"people\", \"from\": 1778, \"to\": 1784}, {\"ngram\": \"us\", \"from\": 1803, \"to\": 1805}, {\"ngram\": \"the top destination\", \"from\": 1812, \"to\": 1831}, {\"ngram\": \"people\", \"from\": 1836, \"to\": 1842}]}, {\"sentence\": \"Indeed, the opening ceremony widely became known as the \\\"gayest opening ceremony ever,\\\" evenrecreatingLeonardo da Vinci's \\\"Last Supper\\\" with drag queens and transgender performers.\", \"from\": 1864, \"to\": 2044, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the opening ceremony\", \"from\": 1872, \"to\": 1892}, {\"ngram\": \"the \\\"gayest opening ceremony\", \"from\": 1916, \"to\": 1944}, {\"ngram\": \"drag queens\", \"from\": 2005, \"to\": 2016}, {\"ngram\": \"transgender performers\", \"from\": 2021, \"to\": 2043}]}, {\"sentence\": \"As Breitbart News detailed: The \\\"Last Supper\\\" parody was set beside one side of a catwalk, and after cameras performed the close-ups of the scene surrounding the plus-sized model, the cameras then shifted position to show dozens of models parading down the catwalk in various gender-bending fashions, including numerous male models in dresses and skirts.\", \"from\": 2045, \"to\": 2400, \"entities\": [{\"begin\": 2048, \"end\": 2062, \"title\": \"http://dbpedia.org/resource/Breitbart_News\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Breitbart News\", \"types\": [\"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Breitbar