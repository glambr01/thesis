formance\", \"from\": 2318, \"to\": 2333}, {\"ngram\": \"the water\", \"from\": 2337, \"to\": 2346}, {\"ngram\": \"the picture\", \"from\": 2383, \"to\": 2394}, {\"ngram\": \"the image\", \"from\": 2409, \"to\": 2418}, {\"ngram\": \"perfection\", \"from\": 2422, \"to\": 2432}]}]}"