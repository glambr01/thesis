es\": [], \"noun_phrases\": [{\"ngram\": \"a point\", \"from\": 1072, \"to\": 1079}, {\"ngram\": \"the difficulty\", \"from\": 1086, \"to\": 1100}]}, {\"sentence\": \"\\\"I mean, we were drinking hot water out there,\\\" he said.\", \"from\": 1133, \"to\": 1189, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"hot water\", \"from\": 1159, \"to\": 1168}]}, {\"sentence\": \"\\\"It was hot out there.\", \"from\": 1190, \"to\": 1212, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"We were both trying our best to put up some good tennis.\", \"from\": 1213, \"to\": 1269, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"some good tennis\", \"from\": 1252, \"to\": 1268}]}, {\"sentence\": \"Part of it is physicality, but I said to the referee that its pretty poor the players have to drink hot water in those conditions.\", \"from\": 1270, \"to\": 1400, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Part\", \"from\": 1270, \"to\": 1274}, {\"ngram\": \"physicality\", \"from\": 1284, \"to\": 1295}, {\"ngram\": \"the referee\", \"from\": 1311, \"to\": 1322}, {\"ngram\": \"the players\", \"from\": 1344, \"to\": 1355}, {\"ngram\": \"hot water\", \"from\": 1370, \"to\": 1379}, {\"ngram\": \"those conditions\", \"from\": 1383, \"to\": 1399}]}, {\"sentence\": \"\\\"We did have ice towels and stuff but it's important we have good fridges to keep our water cool.\", \"from\": 1402, \"to\": 1499, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"ice towels\", \"from\": 1415, \"to\": 1425}, {\"ngram\": \"good fridges\", \"from\": 1463, \"to\": 1475}, {\"ngram\": \"our water\", \"from\": 1484, \"to\": 1493}]}, {\"sentence\": \"It's so tough to recover when you are just not replenishing properly.\", \"from\": 1500, \"to\": 1569, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"If felt like there was no escape from it [the heat] even at the change of ends.\\\"\", \"from\": 1570, \"to\": 1650, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"no escape\", \"from\": 1593, \"to\": 1602}, {\"ngram\": \"[the heat\", \"from\": 1611, \"to\": 1620}, {\"ngram\": \"the change\", \"from\": 1630, \"to\": 1640}, {\"ngram\": \"ends\", \"from\": 1644, \"to\": 1648}]}, {\"sentence\": \"Unable to access cold water from fridges the players were forced to use the change of ends to fill up their own bottles at a replenishing station, which ate into the two-minute recovery time between ends.\", \"from\": 1652, \"to\": 1856, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"cold water\", \"from\": 1669, \"to\": 1679}, {\"ngram\": \"fridges\", \"from\": 1685, \"to\": 1692}, {\"ngram\": \"the players\", \"from\": 1693, \"to\": 1704}, {\"ngram\": \"the change\", \"from\": 1724, \"to\": 1734}, {\"ngram\": \"ends\", \"from\": 1738, \"to\": 1742}, {\"ngram\": \"their own bottles\", \"from\": 1754, \"to\": 1771}, {\"ngram\": \"a replenishing station\", \"from\": 1775, \"to\": 1797}, {\"ngram\": \"the two-minute recovery time\", \"from\": 1814, \"to\": 1842}, {\"ngram\": \"ends\", \"from\": 1851, \"to\": 1855}]}, {\"sentence\": \"\\\"I have not played in much hotter conditions than that.\", \"from\": 1858, \"to\": 1913, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"much hotter conditions\", \"from\": 1880, \"to\": 1902}]}, {\"sentence\": \"Your body really starts to fight against you.\", \"from\": 1914, \"to\": 1959, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Your body\", \"from\": 1914, \"to\": 1923}]}, {\"sentence\": \"\\\"We just have not had a lot of exposure to heat by being in the UK for a while, and being in Europe over the grass [season], we just have not experienced this level of heat and humidity.\", \"from\": 1961, \"to\": 2147, \"entities\": [{\"begin\": 2025, \"end\": 2027, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9999970278489457, \"rank\": 2.965953998369816e-06, \"text\": \"UK\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"a lot\", \"from\": 1983, \"to\": 1988}, {\"ngram\": \"exposure\", \"from\": 1992, \"to\": 2000}, {\"ngram\": \"Europe\", \"from\": 2054, \"to\": 2060}, {\"ngram\": \"the grass\", \"from\": 2066, \"to\": 2075}, {\"ngram\": \"this level\", \"from\": 2115, \"to\": 2125}, {\"ngram\": \"heat\", \"from\": 2129, \"to\": 2133}, {\"ngram\": \"humidity\", \"from\": 2138, \"to\": 2146}]}, {\"sentence\": \"It was tough today and he did a better job of dealing with it than I did.\", \"from\": 2148, \"to\": 2221, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a better job\", \"from\": 2178, \"to\": 2190}]}, {\"sentence\": \"\\\"You can refill, but at the change of ends I ended up not sitting down because I was refilling the drinks.\", \"from\": 2223, \"to\": 2329, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the change\", \"from\": 2247, \"to\": 2257}, {\"ngram\": \"ends\", \"from\": 2261, \"to\": 2265}, {\"ngram\": \"the drinks\", \"from\": 2318, \"to\": 2328}]}, {\"sentence\": \"I want to sit down.\", \"from\": 2330, \"to\": 2349, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"At all other tournaments you can get the water from the fridge.\", \"from\": 2350, \"to\": 2413, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"all other tournaments\", \"from\": 2353, \"to\": 2374}, {\"ngram\": \"the water\", \"from\": 2387, \"to\": 2396}, {\"ngram\": \"the fridge\", \"from\": 2402, \"to\": 2412}]}, {\"sentence\": \"At theUS Openthere is a fridge with ice, a cooler.\", \"from\": 2414, \"to\": 2464, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"theUS Openthere\", \"from\": 2417, \"to\": 2432}, {\"ngram\": \"a fridge\", \"from\": 2436, \"to\": 2444}, {\"ngram\": \"ice\", \"from\": 2450, \"to\": 2453}, {\"ngram\": \"a cooler\", \"from\": 2455, \"to\": 2463}]}, {\"sentence\": \"\\\"I do not know if it's normal, but that court [Suzanne Lenglen] does not have any shelter.\", \"from\": 2466, \"to\": 2556