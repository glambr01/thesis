entities\": [], \"noun_phrases\": [{\"ngram\": \"any art\", \"from\": 1385, \"to\": 1392}, {\"ngram\": \"work\", \"from\": 1396, \"to\": 1400}, {\"ngram\": \"a horrific tragedy\", \"from\": 1419, \"to\": 1437}, {\"ngram\": \"any kind\", \"from\": 1441, \"to\": 1449}, {\"ngram\": \"the 27-year-old Hadid\", \"from\": 1457, \"to\": 1478}, {\"ngram\": \"the face\", \"from\": 1503, \"to\": 1511}, {\"ngram\": \"Dior\", \"from\": 1515, \"to\": 1519}]}, {\"sentence\": \"\\\"In advance of the campaign release, I had no knowledge of the historical connection to the atrocious events in 1972.\", \"from\": 1522, \"to\": 1639, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"advance\", \"from\": 1526, \"to\": 1533}, {\"ngram\": \"the campaign release\", \"from\": 1537, \"to\": 1557}, {\"ngram\": \"no knowledge\", \"from\": 1565, \"to\": 1577}, {\"ngram\": \"the historical connection\", \"from\": 1581, \"to\": 1606}, {\"ngram\": \"the atrocious events\", \"from\": 1610, \"to\": 1630}]}, {\"sentence\": \"... Had I been made aware, from the bottom of my heart, I would never have participated.\\\"\", \"from\": 1640, \"to\": 1729, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the bottom\", \"from\": 1672, \"to\": 1682}, {\"ngram\": \"my heart\", \"from\": 1686, \"to\": 1694}]}, {\"sentence\": \"\\\"My team should have known,\\\" she added.\", \"from\": 1731, \"to\": 1770, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My team\", \"from\": 1732, \"to\": 1739}]}, {\"sentence\": \"\\\"Adidas should have known and I should have done more research so that I too would have known and understood, and spoken up.\\\"\", \"from\": 1771, \"to\": 1896, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Adidas\", \"from\": 1772, \"to\": 1778}, {\"ngram\": \"more research\", \"from\": 1820, \"to\": 1833}]}, {\"sentence\": \"On July 19, Adidas issued a statement apologizing for the ad and said it was \\\"revising the remainder of the campaign.\\\"\", \"from\": 1898, \"to\": 2016, \"entities\": [{\"begin\": 1910, \"end\": 1916, \"title\": \"http://dbpedia.org/resource/Adidas\", \"score\": 1.0, \"rank\": 2.450108651758856e-21, \"text\": \"Adidas\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Adidas\", \"dbpedia\": \"http://dbpedia.org/resource/Adidas\"}], \"noun_phrases\": [{\"ngram\": \"July\", \"from\": 1901, \"to\": 1905}, {\"ngram\": \"a statement\", \"from\": 1924, \"to\": 1935}, {\"ngram\": \"the ad\", \"from\": 1952, \"to\": 1958}, {\"ngram\": \"the remainder\", \"from\": 1985, \"to\": 1998}, {\"ngram\": \"the campaign\", \"from\": 2002, \"to\": 2014}]}, {\"sentence\": \"\\\"We are conscious that connections have been made to tragic historical events - though these are completely unintentional - and we apologize for any upset or distress caused,\\\" the company said.\", \"from\": 2018, \"to\": 2211, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"connections\", \"from\": 2041, \"to\": 2052}, {\"ngram\": \"tragic historical events\", \"from\": 2071, \"to\": 2095}, {\"ngram\": \"any upset\", \"from\": 2163, \"to\": 2172}, {\"ngram\": \"distress\", \"from\": 2176, \"to\": 2184}, {\"ngram\": \"the company\", \"from\": 2194, \"to\": 2205}]}, {\"sentence\": \"\\\"We believe in sport as a unifying force around the world and will continue our efforts to champion diversity and equality in everything we do,\\\" it added.\", \"from\": 2213, \"to\": 2367, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"sport\", \"from\": 2228, \"to\": 2233}, {\"ngram\": \"a unifying force\", \"from\": 2237, \"to\": 2253}, {\"ngram\": \"the world\", \"from\": 2261, \"to\": 2270}, {\"ngram\": \"our efforts\", \"from\": 2289, \"to\": 2300}, {\"ngram\": \"diversity\", \"from\": 2313, \"to\": 2322}, {\"ngram\": \"equality\", \"from\": 2327, \"to\": 2335}, {\"ngram\": \"everything\", \"from\": 2339, \"to\": 2349}]}, {\"sentence\": \"Social media posts of the ad campaign featuring Hadid were removed,according to The Guardian.\", \"from\": 2368, \"to\": 2461, \"entities\": [{\"begin\": 2448, \"end\": 2460, \"title\": \"http://dbpedia.org/resource/The_Guardian\", \"score\": 1.0, \"rank\": 5.6261648134931155e-18, \"text\": \"The Guardian\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Guardian\", \"dbpedia\": \"http://dbpedia.org/resource/The_Guardian\"}], \"noun_phrases\": [{\"ngram\": \"Social media posts\", \"from\": 2368, \"to\": 2386}, {\"ngram\": \"the ad campaign\", \"from\": 2390, \"to\": 2405}, {\"ngram\": \"Hadid\", \"from\": 2416, \"to\": 2421}]}, {\"sentence\": \"Fierce criticism of the campaign came from the Israeli government, whoseofficial account on Xexpressed opposition to Hadid being the \\\"face of their [Adidas'] campaign,\\\" and from the American Jewish Committee, whichsaid thatAdidas' decision to feature a \\\"vocal anti-Israel model to recall this dark Olympics is either a massive oversight or intentionally inflammatory.\\\"\", \"from\": 2463, \"to\": 2831, \"entities\": [{\"begin\": 2510, \"end\": 2528, \"title\": \"http://dbpedia.org/resource/Israel\", \"score\": 0.9965798444852139, \"rank\": 0.003431893122898739, \"text\": \"Israeli government\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Israel\", \"dbpedia\": \"http://dbpedia.org/resource/Israel\"}, {\"begin\": 2612, \"end\": 2618, \"title\": \"http://dbpedia.org/resource/Adidas\", \"score\": 1.0, \"rank\": 2.450108651758856e-21, \"text\": \"Adidas\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Adidas\", \"dbpedia\": \"http://dbpedia.org/resource/Adidas\"}, {\"begin\": 2645, \"end\": 2670, \"title\": \"http://dbpedia.org/resource/American_Jewish_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"American Jewish Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/American_Jewish_Committee\", \"dbpedia\": \"http://dbpedia.org/reso