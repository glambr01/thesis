m\": 691, \"to\": 725, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"McKeown surged to the front about halfway through the return lap and reached for the wall in 57.33, winning by a relatively comfortable margin over Smith's finish of 57.66.\", \"from\": 727, \"to\": 899, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"McKeown\", \"from\": 727, \"to\": 734}, {\"ngram\": \"the front\", \"from\": 745, \"to\": 754}, {\"ngram\": \"the return lap\", \"from\": 777, \"to\": 791}, {\"ngram\": \"the wall\", \"from\": 808, \"to\": 816}, {\"ngram\": \"a relatively comfortable margin\", \"from\": 838, \"to\": 869}, {\"ngram\": \"Smith's finish\", \"from\": 875, \"to\": 889}]}, {\"sentence\": \"\\\"The nerves were definitely there but I just reminded myself it's a pool in a different venue and I train every single day of my life,\\\" McKeown said.\", \"from\": 901, \"to\": 1050, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The nerves\", \"from\": 902, \"to\": 912}, {\"ngram\": \"a pool\", \"from\": 967, \"to\": 973}, {\"ngram\": \"a different venue\", \"from\": 977, \"to\": 994}, {\"ngram\": \"my life\", \"from\": 1027, \"to\": 1034}, {\"ngram\": \"McKeown\", \"from\": 1037, \"to\": 1044}]}, {\"sentence\": \"The U.S. also grabbed the bronze as Katharine Berkoff touched third in 57.98.\", \"from\": 1052, \"to\": 1129, \"entities\": [{\"begin\": 1088, \"end\": 1105, \"title\": \"http://dbpedia.org/resource/Katharine_Berkoff\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Katharine Berkoff\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Katharine_Berkoff\", \"dbpedia\": \"http://dbpedia.org/resource/Katharine_Berkoff\"}], \"noun_phrases\": [{\"ngram\": \"The U.S.\", \"from\": 1052, \"to\": 1060}, {\"ngram\": \"the bronze\", \"from\": 1074, \"to\": 1084}]}, {\"sentence\": \"Smith reached over the lane rope to congratulate McKeown, but this one had to sting.\", \"from\": 1131, \"to\": 1215, \"entiti