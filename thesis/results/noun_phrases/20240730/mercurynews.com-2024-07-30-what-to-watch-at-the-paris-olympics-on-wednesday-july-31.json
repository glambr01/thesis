\": 0.974364258132568, \"rank\": 0.026277972926041226, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"a guide\", \"from\": 335, \"to\": 342}, {\"ngram\": \"the women's 1,500-meter freestyle\", \"from\": 373, \"to\": 406}, {\"ngram\": \"its debut\", \"from\": 412, \"to\": 421}, {\"ngram\": \"the Olympic program\", \"from\": 425, \"to\": 444}, {\"ngram\": \"Ledecky\", \"from\": 471, \"to\": 478}, {\"ngram\": \"a four-second margin\", \"from\": 496, \"to\": 516}]}, {\"sentence\": \"This time it could be an even bigger margin.\", \"from\": 520, \"to\": 564, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an even bigger margin\", \"from\": 542, \"to\": 563}]}, {\"sentence\": \"Ledecky won her heat Tuesday by more than a half-lap ahead of Simona Quadarella of Italy.\", \"from\": 566, \"to\": 655, \"entities\": [{\"begin\": 628, \"end\": 645, \"title\": \"http://dbpedia.org/resource/Simona_Quadarella\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Simona Quadarella\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Simona_Quadarella\", \"dbpedia\": \"http://dbpedia.org/resource/Simona_Quadarella\"}, {\"begin\": 649, \"end\": 654, \"title\": \"http://dbpedia.org/resource/Italy\", \"score\": 0.9720220171696118, \"rank\": 0.019558186198256996, \"text\": \"Italy\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Italy\", \"dbpedia\": \"http://dbpedia.org/resource/Italy\"}], \"noun_phrases\": [{\"ngram\": \"Ledecky\", \"from\": 566, \"to\": 573}, {\"ngram\": \"her heat\", \"from\": 578, \"to\": 586}, {\"ngram\": \"more than a half-lap\", \"from\": 598, \"to\": 618}]}, {\"sentence\": \"The 1,500 final is scheduled for 9:13 p.m. CEST (3:13 p.m. EDT).\", \"from\": 657, \"to\": 721, \"entities\": [], \"noun_phras