 {\"ngram\": \"concerns\", \"from\": 1102, \"to\": 1110}, {\"ngram\": \"the water quality\", \"from\": 1117, \"to\": 1134}, {\"ngram\": \"the Seine River\", \"from\": 1138, \"to\": 1153}]}, {\"sentence\": \"It was rescheduled for Wednesday, when the women's competition is also slated to be held.\", \"from\": 1155, \"to\": 1244, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Wednesday\", \"from\": 1178, \"to\": 1187}, {\"ngram\": \"the women's competition\", \"from\": 1194, \"to\": 1217}]}, {\"sentence\": \"But both will happen only if water tests show acceptablelevels of E. coli and other bacteria.\", \"from\": 1246, \"to\": 1339, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"water tests\", \"from\": 1275, \"to\": 1286}, {\"ngram\": \"acceptablelevels\", \"from\": 1292, \"to\": 1308}, {\"ngram\": \"E. coli\", \"from\": 1312, \"to\": 1319}, {\"ngram\": \"other bacteria\", \"from\": 1324, \"to\": 1338}]}, {\"sentence\": \"Friday is also planned as a backup date.\", \"from\": 1340, \"to\": 1380, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Friday\", \"from\": 1340, \"to\": 1346}, {\"ngram\": \"a backup date\", \"from\": 1366, \"to\": 1379}]}, {\"sentence\": \"However, storms or rain are forecast Tuesday night through Thursday, which could complicate rescheduling because rain generally causes bacteria levels in the Seine to rise.\", \"from\": 1382, \"to\": 1554, \"entities\": [{\"begin\": 1540, \"end\": 1545, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999963411320184, \"rank\": 3.2286913538557874e-06, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"storms\", \"from\": 1391, \"to\": 1397}, {\"ngram\": \"rain\", \"from\": 1401, \"to\": 1405}, {\"ngram\": \"Thursday\", \"from\": 1441, \"to\": 1449}, {\"ngram\": \"rescheduling\", \"from\": 1474, \"to\": 1486}, {\"ngram\": \"rain\", \"from\": 149