"{\"uid\": \"neoskosmos.com-en-2024-07-30-news-community-archbishop-makarios-condemns-irreverence-at-paris-olympic-opening-ceremony\", \"noun_phrases\": [{\"sentence\": \"News/Community The Archbishop's remarks have sparked a wider debate on the intersection of faith, freedom of expression, and public decency in global events Flashes of lights illuminates the Eiffel Tower in Paris, France, during the opening ceremony of the 2024 Summer Olympics, Friday, July 26, 2024.\", \"from\": 0, \"to\": 303, \"entities\": [{\"begin\": 20, \"end\": 30, \"title\": \"http://dbpedia.org/resource/Archbishop\", \"score\": 0.9968118070627413, \"rank\": 0.003170151047718844, \"text\": \"Archbishop\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Archbishop\", \"dbpedia\": \"http://dbpedia.org/resource/Archbishop\"}, {\"begin\": 209, \"end\": 214, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999947407411184, \"rank\": 5.25928645735563e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 216, \"end\": 222, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.8554706913361738, \"rank\": 0.10738916840223307, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"a wider debate\", \"from\": 53, \"to\": 67}, {\"ngram\": \"the intersection\", \"from\": 71, \"to\": 87}, {\"ngram\": \"faith\", \"from\": 91, \"to\": 96}, {\"ngram\": \"freedom\", \"from\": 98, \"to\": 105}, {\"ngram\": \"expression\", \"from\": 109, \"to\": 119}, {\"ngram\": \"public decency\", \"from\": 125, \"to\": 139}, {\"ngram\": \"global events\", \"from\": 143, \"to\": 156}, {\"ngram\": \"Flashes\", \"from\": 157, \"to\": 164}, {\"ngram\": \"lights\", \"from\": 168, \"to\": 174}, {\"ngram\": \"the Eiffel Tower\", \"from\": 187, \"to\": 203}, {\"ngram\": \"the opening ceremony\", \"from\": 229, \"to\": 249}, {\"ngram\": \"the 2024 Summer Olympics\", \"from\": 253, \"to\": 277}, {\"ngram\": \"July\", \"from\": 287, \"to\": 291}]}, {\"sentence\": \"Photo: AAP via AP/Robert F. Bukaty 30 July 2024 3:08pm Archbishop Makarios expressed his \\\"profound disappointment\\\" and condemnation over the controversial scenes presented at the opening ceremony of the Paris Olympic Games.\", \"from\": 304, \"to\": 529, \"entities\": [{\"begin\": 319, \"end\": 321, \"title\": \"http://dbpedia.org/resource/Associated_Press\", \"score\": 0.9999982805535413, \"rank\": 1.5791920698327496e-06, \"text\": \"AP\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Associated_Press\", \"dbpedia\": \"http://dbpedia.org/resource/Associated_Press\"}, {\"begin\": 329, \"end\": 331, \"title\": \"http://dbpedia.org/resource/Federal_Reporter\", \"score\": 1.0, \"rank\": 4.831529606186066e-17, \"text\": \"F.\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Federal_Reporter\", \"dbpedia\": \"http://dbpedia.org/resource/Federal_Reporter\"}, {\"begin\": 361, \"end\": 380, \"title\": \"http://dbpedia.org/resource/Makarios_III\", \"score\": 1.0, \"rank\": 5.6554110162575144e-15, \"text\": \"Archbishop Makarios\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Makarios_III\", \"dbpedia\": \"http://dbpedia.org/resource/Makarios_III\"}], \"noun_phrases\": [{\"ngram\": \"AAP\", \"from\": 311, \"to\": 314}, {\"ngram\": \"his \\\"profound disappointment\", \"from\": 389, \"to\": 417}, {\"ngram\": \"condemnation\", \"from\": 423, \"to\": 435}, {\"ngram\": \"the controversial scenes\", \"from\": 441, \"to\": 465}, {\"ngram\": \"the opening ceremony\", \"from\": 479, \"to\": 499}, {\"ngram\": \"the Paris Olympic Games\", \"from\": 503, \"to\": 526}]}, {\"sentence\": \"In a statement the Archbishop highlighted the offensive nature of certain performances, which he deemed disrespectful to Christianity and the Church.\", \"from\": 531, \"to\": 680, \"entities\": [{\"begin\": 550, \"end\": 560, \"title\": \"http://dbpedia.org/resource/Archbishop\", \"score\": 0.9968118070627413, \"rank\": 0.003170151047718844, \"text\": \"Archbishop\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Archbishop\", \"dbpedia\": \"http://dbpedia.org/resource/Archbishop\"}, {\"begin\": 652, \"end\": 664, \"title\": \"http://dbpedia.org/resource/Christianity\", \"score\": 0.9933608900640184, \"rank\": 0.006683383710032585, \"text\": \"Christianity\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Christianity\", \"dbpedia\": \"http://dbpedia.org/resource/Christianity\"}], \"noun_phrases\": [{\"ngram\": \"a statement\", \"from\": 534, \"to\": 545}, {\"ngram\": \"the offensive nature\", \"from\": 573, \"to\": 593}, {\"ngram\": \"certain performances\", \"from\": 597, \"to\": 617}, {\"ngram\": \"the Church\", \"from\": 669, \"to\": 679}]}, {\"sentence\": \"\\\"We watched with utter disappointment a spectacle that was clearly beneath the occasion.\", \"from\": 682, \"to\": 770, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"utter disappointment\", \"from\": 699, \"to\": 719}, {\"ngram\": \"a spectacle\", \"from\": 720, \"to\": 731}, {\"ngram\": \"the occasion\", \"from\": 757, \"to\": 769}]}, {\"sentence\": \"It featured scenes of irreverence that were offensive to Christianity and the Church,\\\" Archbishop Makarios wrote onsocial media.\", \"from\": 771, \"to\": 899, \"entities\": [{\"begin\": 828, \"end\": 840, \"title\": \"http://dbpedia.org/resource/Christianity\", \"score\": 0.9933608900640184, \"rank\": 0.006683383710032585, \"text\": \"Christianity\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Christianity\", \"dbpedia\": \"http://dbpedia.org/resource/Christianity\"}, {\"begin\": 858, \"end\": 877, \"title\": \"http://dbpedia.org/resource/Makarios_III\", \"score\": 1.0, \"rank\": 5.6554110162575144e-15, \"text\": \"Archbishop Makarios\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Makarios_III\", \"dbpedia\": \"http://dbpedia.org/resource/Makarios_III\"}], \"noun_phrases\": [{\"ngram\": \"scenes\", \"from\": 783, \"to\": 789}, {\"ngram\": \"irreverence\", \"from\": 793, \"to\": 804}, {\"ngram\": \"the Church\", \"from\": 845, \"to\": 855}, {\"ngram\": \"onsocial media\", \"from\": 884, \"to\": 898}]}, {\"sentence\": \"He further highlighted that while everyone has the right to their personal beliefs, including atheism, mocking or ridiculing the Christian faith, particularly the truth of the Gospel, crosses a line of respect.\", \"from\": 901, \"to\": 1111, \"entities\": [{\"begin\": 1030, \"end\": 1039, \"title\": \"http://dbpedia.org/resource/Christianity\", \"score\": 0.999918367056796, \"rank\": 8.163960748601379e-05, \"text\": \"Christian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Christianity\", \"dbpedia\": \"http://dbpedia.org/resource/Christianity\"}, {\"begin\": 1077, \"end\": 1083, \"title\": \"http://dbpedia.org/resource/Gospel\", \"score\": 0.8173574338811164, \"rank\": 0.2234364522111132, \"text\": \"Gospel\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Gospel\", \"dbpedia\": \"http://dbpedia.org/resource/Gospel\"}], \"noun_phrases\": [{\"ngram\": \"everyone\", \"from\": 935, \"to\": 943}, {\"ngram\": \"the right\", \"from\": 948, \"to\": 957}, {\"ngram\": \"their personal beliefs\", \"from\": 961, \"to\": 983}, {\"ngram\": \"atheism\", \"from\": 995, \"to\": 1002}, {\"ngram\": \"particularly the truth\", \"from\": 1047, \"to\": 1069}, {\"ngram\": \"a line\", \"from\": 1093, \"to\": 1099}, {\"ngram\": \"respect\", \"from\": 1103, \"to\": 1110}]}, {\"sentence\": \"He noted, \\\"Everyone has the right to be an atheist, but no one has the right to mock or ridicule my faith, especially the truth of the Gospel for which blood has been shed.\\\"\", \"from\": 1112, \"to\": 1285, \"entities\": [{\"begin\": 1247, \"end\": 1253, \"title\": \"http://dbpedia.org/resource/Gospel\", \"score\": 0.8173574338811164, \"rank\": 0.2234364522111132, \"text\": \"Gospel\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Gospel\", \"dbpedia\": \"http://dbpedia.org/resource/Gospel\"}], \"noun_phrases\": [{\"ngram\": \"Everyone\", \"from\": 1123, \"to\": 1131}, {\"ngram\": \"the right\", \"from\": 1136, \"to\": 1145}, {\"ngram\": \"an atheist\", \"from\": 1152, \"to\": 1162}, {\"ngram\": \"no one\", \"from\": 1168, \"to\": 1174}, {\"ngram\": \"the right\", \"from\": 1179, \"to\": 1188}, {\"ngram\": \"my faith\", \"from\": 1209, \"to\": 1217}, {\"ngram\": \"especially the truth\", \"from\": 1219, \"to\": 1239}, {\"ngram\": \"blood\", \"from\": 1264, \"to\": 1269}]}, {\"sentence\": \"Archbishop Makarios also addressed the issue of LGBTQ+ pride, asserting that while individuals have the freedom to live as they choose, they should not impose their lifestyles on society.\", \"from\": 1287, \"to\": 1474, \"entities\": [{\"begin\": 1287, \"end\": 1306, \"title\": \"http://dbpedia.org/resource/Makarios_III\", \"score\": 1.0, \"rank\": 5.6554110162575144e-15, \"text\": \"Archbishop Makarios\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Makarios_III\", \"dbpedia\": \"http://dbpedia.org/resource/Makarios_III\"}], \"noun_phrases\": [{\"ngram\": \"the issue\", \"from\": 1322, \"to\": 1331}, {\"ngram\": \"LGBTQ+ pride\", \"from\": 1335, \"to\": 1347}, {\"ngram\": \"individuals\", \"from\": 1370, \"to\": 1381}, {\"ngram\": \"the freedom\", \"from\": 1387, \"to\": 1398}, {\"ngram\": \"their lifestyles\", \"from\": 1446, \"to\": 1462}, {\"ngram\": \"society\", \"from\": 1466, \"to\": 1473}]}, {\"sentence\": \"\\\"You have the right to be homosexual, but you do not have the right to impose your way of life on our society.\", \"from\": 1476, \"to\": 1586, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the right\", \"from\": 1486, \"to\": 1495}, {\"ngram\": \"the right\", \"from\": 1534, \"to\": 1543}, {\"ngram\": \"your way\", \"from\": 1554, \"to\": 1562}, {\"ngram\": \"life\", \"from\": 1566, \"to\": 1570}, {\"ngram\": \"our society\", \"from\": 1574, \"to\": 1585}]}, {\"sentence\": \"If you want to hold pride parades, you must understand what you are proud of.\", \"from\": 1587, \"to\": 1664, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"pride parades\", \"from\": 1607, \"to\": 1620}]}, {\"sentence\": \"Be proud of your accomplishments, your hard work, your education, your successes, your history, and your culture.\", \"from\": 1665, \"to\": 1778, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"your accomplishments\", \"from\": 1677, \"to\": 1697}, {\"ngram\": \"your hard work\", \"from\": 1699, \"to\": 1713}, {\"ngram\": \"your education\", \"from\": 1715, \"to\": 1729}, {\"ngram\": \"your successes\", \"from\": 1731, \"to\": 1745}, {\"ngram\": \"your history\", \"from\": 1747, \"to\": 1759}, {\"ngram\": \"your culture\", \"from\": 1765, \"to\": 1777}]}, {\"sentence\": \"But do not take pride in your sexuality.\\\"\", \"from\": 1779, \"to\": 1820, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"pride\", \"from\": 1795, \"to\": 1800}, {\"ngram\": \"your sexuality\", \"from\": 1804, \"to\": 1818}]}, {\"sentence\": \"He expressed concern over what he perceives as a mockery of human dignity and a distortion of reality.\", \"from\": 1822, \"to\": 1924, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"concern\", \"from\": 1835, \"to\": 1842}, {\"ngram\": \"a mockery\", \"from\": 1869, \"to\": 1878}, {\"ngram\": \"human dignity\", \"from\": 1882, \"to\": 1895}, {\"ngram\": \"a distortion\", \"from\": 1900, \"to\": 1912}, {\"ngram\": \"reality\", \"from\": 1916, \"to\": 1923}]}, {\"sentence\": \"\\\"We are tired of this.\", \"from\": 1926, \"to\": 1948, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"The dignity of the human person is being mocked.\", \"from\": 1949, \"to\": 1997, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The dignity\", \"from\": 1949, \"to\": 1960}, {\"ngram\": \"the human person\", \"from\": 1964, \"to\": 1980}]}, {\"sentence\": \"Reality is being distorted.\", \"from\": 1998, \"to\": 2025, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Reality\", \"from\": 1998, \"to\": 2005}]}, {\"sentence\": \"Our ability to reason is being challenged.\\\"\", \"from\": 2026, \"to\": 2069, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Our ability\", \"from\": 2026, \"to\": 2037}]}, {\"sentence\": \"Archbishop Makarios went on to wish for the enlightenment for those who seek to undermine the value of faith and declared it unacceptable for such ideologies to be promoted in prestigious institutions like the Olympic Games.\", \"from\": 2071, \"to\": 2295, \"entities\": [{\"begin\": 2071, \"end\": 2090, \"title\": \"http://dbpedia.org/resource/Makarios_III\", \"score\": 1.0, \"rank\": 5.6554110162575144e-15, \"text\": \"Archbishop Makarios\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Makarios_III\", \"dbpedia\": \"http://dbpedia.org/resource/Makarios_III\"}], \"noun_phrases\": [{\"ngram\": \"the enlightenment\", \"from\": 2111, \"to\": 2128}, {\"ngram\": \"the value\", \"from\": 2161, \"to\": 2170}, {\"ngram\": \"faith\", \"from\": 2174, \"to\": 2179}, {\"ngram\": \"such ideologies\", \"from\": 2213, \"to\": 2228}, {\"ngram\": \"prestigious institutions\", \"from\": 2247, \"to\": 2271}, {\"ngram\": \"the Olympic Games\", \"from\": 2277, \"to\": 2294}]}, {\"sentence\": \"\\\"We pray that God will enlighten those who seek to undermine the value of faith, and we assert that it is unacceptable for such ideologies to be promoted in institutions as prestigious as the Olympic Games,\\\" he concluded.\", \"from\": 2297, \"to\": 2518, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"God\", \"from\": 2311, \"to\": 2314}, {\"ngram\": \"the value\", \"from\": 2358, \"to\": 2367}, {\"ngram\": \"faith\", \"from\": 2371, \"to\": 2376}, {\"ngram\": \"such ideologies\", \"from\": 2420, \"to\": 2435}, {\"ngram\": \"institutions\", \"from\": 2454, \"to\": 2466}, {\"ngram\": \"the Olympic Games\", \"from\": 2485, \"to\": 2502}]}]}"