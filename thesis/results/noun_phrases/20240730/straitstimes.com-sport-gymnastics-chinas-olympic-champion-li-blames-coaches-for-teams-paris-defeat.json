, \"to\": 776, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Our team\", \"from\": 744, \"to\": 752}, {\"ngram\": \"coaches\", \"from\": 756, \"to\": 763}, {\"ngram\": \"issues\", \"from\": 769, \"to\": 775}]}, {\"sentence\": \"Let us not put all responsibilities on athletes.\", \"from\": 777, \"to\": 825, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"us\", \"from\": 781, \"to\": 783}, {\"ngram\": \"all responsibilities\", \"from\": 792, \"to\": 812}, {\"ngram\": \"athletes\", \"from\": 816, \"to\": 824}]}, {\"sentence\": \"If they failed, the coaches did something wrong.\", \"from\": 826, \"to\": 874, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the coaches\", \"from\": 842, \"to\": 853}, {\"ngram\": \"something\", \"from\": 858, \"to\": 867}]}, {\"sentence\": \"We need to tell the truth after we fail,\\\" 50-year-old Li said in an online live broadcast that went viral on Chinese social media.\", \"from\": 875, \"to\": 1005, \"entities\": [{\"begin\": 929, \"end\": 931, \"title\": \"http://dbpedia.org/resource/Hlai_people\", \"score\": 0.998183164212342, \"rank\": 0.0018201426879635712, \"text\": \"Li\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Hlai_people\", \"dbpedia\": \"http://dbpedia.org/resource/Hlai_people\"}, {\"begin\": 984, \"end\": 991, \"title\": \"http://dbpedia.org/resource/Chinese_language\", \"score\": 0.5933913994876433, \"rank\": 0.6791914234773473, \"text\": \"Chinese\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Chinese_language\", \"dbpedia\": \"http://dbpedia.org/resource/Chinese_language\"}], \"noun_phrases\": [{\"ngram\": \"the truth\", \"from\": 891, \"to\": 900}, {\"ngram\": \"an online live broadcast\", \"from\": 940, \"to\": 964}]}, {\"sentence\": \"\\\"Our athletes are too old.\", \"from\": 1007, \"to\": 1033, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Our athletes\", \"from\": 1008, \"to\": 1020}]}, {\"sentence\": \"Sports needs young people.\", \"from\": 1034, \"to\