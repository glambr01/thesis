edia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"the 1930s\", \"from\": 4815, \"to\": 4824}]}, {\"sentence\": \"John von Neumann, born in Hungary, designed the architecture that underlies modern computing.\", \"from\": 4826, \"to\": 4919, \"entities\": [{\"begin\": 4826, \"end\": 4842, \"title\": \"http://dbpedia.org/resource/John_von_Neumann\", \"score\": 1.0, \"rank\": 7.332552350367914e-56, \"text\": \"John von Neumann\", \"types\": [\"Q901\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/John_von_Neumann\", \"dbpedia\": \"http://dbpedia.org/resource/John_von_Neumann\"}, {\"begin\": 4852, \"end\": 4859, \"title\": \"http://dbpedia.org/resource/Hungary\", \"score\": 0.9998083976314966, \"rank\": 0.0001916390508046441, \"text\": \"Hungary\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Hungary\", \"dbpedia\": \"http://dbpedia.org/resource/Hungary\"}], \"noun_phrases\": [{\"ngram\": \"the architecture\", \"from\": 4870, \"to\": 4886}, {\"ngram\": \"modern computing\", \"from\": 4902, \"to\": 4918}]}, {\"sentence\": \"Wernher von Braun, born in Germany and once an engineer for the Nazis, later became the chief architect of the Saturn V rocket that carried Americans to the moon.\", \"from\": 4920, \"to\": 5082, \"entities\": [{\"begin\": 4920, \"end\": 4937, \"title\": \"http://dbpedia.org/resource/Wernher_von_Braun\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Wernher von Braun\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Wernher_von_Braun\", \"dbpedia\": \"http://dbpedia.org/resource/Wernher_von_Braun\"}, {\"begin\": 4947, \"end\": 4954, \"title\": \"http://dbpedia.org/resource/Germany\", \"score\": 0.967265901092421, \"rank\": 0.03229095383909544, \"text\": \"Germany\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Germany\", \"dbpedia\": \"http://dbpedia.org/resource/Germany\"}, {\"begin\": 4984, \"end\": 4989, \"title\": \"http://dbpedia.org/resource/Nazism\", \"score\": 0.9529619103421845, \"rank\": 0.04875339998825263, \"text\": \"Nazis\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Nazism\", \"dbpedia\": \"http://dbpedia.org/resource/Nazism\"}], \"noun_phrases\": [{\"ngram\": \"the chief architect\", \"from\": 5004, \"to\": 5023}, {\"ngram\": \"the Saturn V rocket\", \"from\": 5027, \"to\": 5046}, {\"ngram\": \"Americans\", \"from\": 5060, \"to\": 5069}, {\"ngram\": \"the moon\", \"from\": 5073, \"to\": 5081}]}, {\"sentence\": \"The US has repeatedly turned foreign-born talent -- even from rival powers -- into engines of national strength.\", \"from\": 5083, \"to\": 5195, \"entities\": [{\"begin\": 5087, \"end\": 5089, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999999896635927, \"rank\": 9.872117045628285e-09, \"text\": \"US\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"foreign-born talent\", \"from\": 5112, \"to\": 5131}, {\"ngram\": \"rival powers\", \"from\": 5145, \"to\": 5157}, {\"ngram\": \"engines\", \"from\": 5166, \"to\": 5173}, {\"ngram\": \"national strength\", \"from\": 5177, \"to\": 5194}]}, {\"sentence\": \"To see why isolation is harmful, ask a simple question: What if America had closed its doors to these brilliant minds?\", \"from\": 5197, \"to\": 5315, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"isolation\", \"from\": 5208, \"to\": 5217}, {\"ngram\": \"a simple question\", \"from\": 5234, \"to\": 5251}, {\"ngram\": \"America\", \"from\": 5261, \"to\": 5268}, {\"ngram\": \"its doors\", \"from\": 5280, \"to\": 5289}, {\"ngram\": \"these brilliant minds\", \"from\": 5293, \"to\": 5314}]}, {\"sentence\": \"Would they have stopped thinking, inventing, and striving?\", \"from\": 5316, \"to\": 5374, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Of course not, just as Ohno and Kwan would not have stopped skating.\", \"from\": 5375, \"to\": 5443, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Ohno\", \"from\": 5398, \"to\": 5402}, {\"ngram\": \"Kwan\", \"from\": 5407, \"to\": 5411}]}, {\"sentence\": \"If America turns talent away, talent will not vanish; it will relocate, and another country will claim the medals and the breakthroughs.\", \"from\": 5444, \"to\": 5580, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"America\", \"from\": 5447, \"to\": 5454}, {\"ngram\": \"talent\", \"from\": 5461, \"to\": 5467}, {\"ngram\": \"talent\", \"from\": 5474, \"to\": 5480}, {\"ngram\": \"another country\", \"from\": 5520, \"to\": 5535}, {\"ngram\": \"the medals\", \"from\": 5547, \"to\": 5557}, {\"ngram\": \"the breakthroughs\", \"from\": 5562, \"to\": 5579}]}, {\"sentence\": \"In the past year, the number of international graduate students studying in the US declined by 12%.\", \"from\": 5582, \"to\": 5681, \"entities\": [{\"begin\": 5662, \"end\": 5664, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999999896635927, \"rank\": 9.872117045628285e-09, \"text\": \"US\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"the past year\", \"from\": 5585, \"to\": 5598}, {\"ngram\": \"the number\", \"from\": 5600, \"to\": 5610}, {\"ngram\": \"international graduate students\", \"from\": 5614, \"to\": 5645}, {\"ngram\": \"12%\", \"from\": 5677, \"to\": 5680}]}, {\"sentence\": \"If this trend continues, it will undermine America's scientific competitiveness in the long run.\", \"from\": 5682, \"to\": 5778, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this trend\", \"from\": 5685, \"to\": 5695}, {\"ngram\": \"America's scientific competitiveness\", \"from\": 5725, \"to\": 5761}, {\"ngram\": \"the long run\", \"from\": 5765, \"to\": 5777}]}, {\"sentence\": \"International rivalry -- whether on the ice rink or in the laboratory -- is a competition for talent, and it cannot be achieved by hiding from the world.\", \"from\": 5779, \"to\": 5932, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"International rivalry\", \"from\": 5779, \"to\": 5800}, {\"ngram\": \"the ice rink\", \"from\": 5815, \"to\": 5827}, {\"ngram\": \"the laboratory\", \"from\": 5834, \"to\": 5848}, {\"ngram\": \"a competition\", \"from\": 5855, \"to\": 5868}, {\"ngram\": \"talent\", \"from\": 5873, \"to\": 5879}, {\"ngram\": \"the world\", \"from\": 5922, \"to\": 5931}]}, {\"sentence\": \"It requires creating the most compelling environment for talent to gather, develop, and remain.\", \"from\": 5933, \"to\": 6028, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the most compelling environment\", \"from\": 5954, \"to\": 5985}, {\"ngram\": \"talent\", \"from\": 5990, \"to\": 5996}]}, {\"sentence\": \"If the US wants to win the race for science, it must pair the best from abroad with the best at home, and offer not just opportunity but also a country where the best want to be.\\u00a92026 Project Syndicate Nancy Qian, Professor of Economics at Northwestern University, is Co-Director of Northwestern University's Global Poverty Research Lab, Founding Director of the China Econ Lab, and a visiting professor at the Einaudi Institute for Economics and Finance.\", \"from\": 6029, \"to\": 6485, \"entities\": [{\"begin\": 6036, \"end\": 6038, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999999896635927, \"rank\": 9.872117045628285e-09, \"text\": \"US\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 6213, \"end\": 6230, \"title\": \"http://dbpedia.org/resource/Project_Syndicate\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Project Syndicate\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"ht