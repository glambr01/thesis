{\"begin\": 1299, \"end\": 1302, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 4.564570603739515e-20, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"its list\", \"from\": 1315, \"to\": 1323}, {\"ngram\": \"other sports\", \"from\": 1327, \"to\": 1339}, {\"ngram\": \"their qualifying competitions\", \"from\": 1349, \"to\": 1378}]}, {\"sentence\": \"A Message from The Moscow Times: Dear readers, We are facing unprecedented challenges.\", \"from\": 1381, \"to\": 1469, \"entities\": [{\"begin\": 1396, \"end\": 1412, \"title\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"The Moscow Times\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Moscow_Times\", \"dbpedia\": \"http://dbpedia.org/resource/The_Moscow_Times\"}], \"noun_phrases\": [{\"ngram\": \"Dear readers\", \"from\": 1414, \"to\": 1426}, {\"ngram\": \"unprecedented challenges\", \"from\": 1442, \"to\": 1466}]}, {\"sentence\": \"Russia's Prosecutor General's Office has designated The Moscow Times as an \\\"undesirable\\\" organization, criminalizing our work and putting our staff at risk of prosecution.\", \"from\": 1470, \"to\": 1641, \"entities\": [{\"begin\": 1470, \"end\": 1476, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999966786400042, \"rank\": 2.49196077450957e-06, \"text\": \"Russia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}, {\"begin\": 1479, \"end\": 1497, \"title\": \"http://dbpedia.org/resource/Prosecutor-General_of_Russia\", \"score\": 0.9999999999724878, \"rank\": 2.7398905835739407e-11, \"text\": \"Prosecutor General\", \"types\"