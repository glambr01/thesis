to\": 409}, {\"ngram\": \"events\", \"from\": 411, \"to\": 417}, {\"ngram\": \"updates\", \"from\": 422, \"to\": 429}, {\"ngram\": \"The Independent\", \"from\": 435, \"to\": 450}]}, {\"sentence\": \"Read ourPrivacy notice With Armand Duplantis, the question is never whether he will win but how high he will fly.\", \"from\": 456, \"to\": 570, \"entities\": [{\"begin\": 485, \"end\": 501, \"title\": \"http://dbpedia.org/resource/Armand_Duplantis\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Armand Duplantis\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Armand_Duplantis\", \"dbpedia\": \"http://dbpedia.org/resource/Armand_Duplantis\"}], \"noun_phrases\": [{\"ngram\": \"ourPrivacy notice\", \"from\": 461, \"to\": 478}, {\"ngram\": \"the question\", \"from\": 502, \"to\": 514}]}, {\"sentence\": \"The 24-year-old Swede had broken the pole vault world record eight times, pushing the limits of possibility centimetre by centimetre.\", \"from\": 571, \"to\": 704, \"entities\": [{\"begin\": 693, \"end\": 703, \"title\": \"http://dbpedia.org/resource/Centimetre\", \"score\": 0.8929716126111096, \"rank\": 0.11985642754772546, \"text\": \"centimetre\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Centimetre\", \"dbpedia\": \"http://dbpedia.org/resource/Centimetre\"}], \"noun_phrases\": [{\"ngram\": \"The 24-year-old Swede\", \"from\": 571, \"to\": 592}, {\"ngram\": \"the pole vault world record\", \"from\": 604, \"to\": 631}, {\"ngram\": \"the limits\", \"from\": 653, \"to\": 663}, {\"ngram\": \"possibility centimetre\", \"from\": 667, \"to\": 689}]}, {\"sentence\": \"And here on a sultry night at the Stade de France, at 10.15pm, with the track races long finished and nobody moving an inch from their seat,he did it again.\", \"from\": 705, \"to\": 861, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a sultry night\", \"from\": 717, \"to\": 731}, {\"ngram\": \"the Stade de France\", \"from\": 735, \"to\": 754}, {\"ngram\": \"the track races\", \"from\": 773, \"to\": 788}, {\"ngram\": \"nobody\", \"from\": 807, \"to\": 813}, {\"ngram\": \"an inch\", \"from\": 821, \"to\": 828}, {\"ngram\": \"their seat\", \"from\": 834, \"to\": 844}]}, {\"sentence\": \"The event really began when Duplantis cleared 6.00m.\", \"from\": 863, \"to\": 915, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The event\", \"from\": 863, \"to\": 872}, {\"ngram\": \"Duplantis\", \"from\": 891, \"to\": 900}, {\"ngram\": \"6.00m.\", \"from\": 909, \"to\": 915}]}, {\"sentence\": \"Greece's Emmanouil Karalis and USA's Sam Kendricks tried and failed to match him, earning bronze and silver respectively.\", \"from\": 916, \"to\": 1037, \"entities\": [{\"begin\": 916, \"end\": 922, \"title\": \"http://dbpedia.org/resource/Greece\", \"score\": 0.6972381885871297, \"rank\": 0.43413950800033396, \"text\": \"Greece\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Greece\", \"dbpedia\": \"http://dbpedia.org/resource/Greece\"}, {\"begin\": 925, \"end\": 942, \"title\": \"http://dbpedia.org/resource/Emmanouil_Karalis\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Emmanouil Karalis\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emmanouil_Karalis\", \"dbpedia\": \"http://dbpedia.org/resource/Emmanouil_Karalis\"}, {\"begin\": 947, \"end\": 950, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999442737937722, \"rank\": 5.156836272755188e-05, \"text\": \"USA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 953, \"end\": 966, \"title\": \"http://dbpedia.org/resource/Sam_Kendricks\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Sam Kendricks\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Sam_Kendricks\", \"dbpedia\": \"http://dbpedia.org/resource/Sam_Kendricks\"}], \"noun_phrases\": [{\"ngram\": \"bronze\", \"from\": 1006, \"to\": 1012}, {\"ngram\": \"silver\", \"from\": 1017, \"to\": 1023}]}, {\"sentence\": \"Which just left the Mondo show.\", \"from\": 1038, \"to\": 1069, \"entities\": [{\"begin\": 1058, \"end\": 1063, \"title\": \"http://dbpedia.org/resource/Power_Rangers_Zeo\", \"score\": 0.9876745708766734, \"rank\": 0.009419836535625958, \"text\": \"Mondo\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/Power_Rangers_Zeo\", \"dbpedia\": \"http://dbpedia.org/resource/Power_Rangers_Zeo\"}], \"noun_phrases\": []}, {\"sentence\": \"After some brief hugs with his parents to celebrate gold, Duplantis strode across the track and set to work, first breaking the Olympic record of 6.03m set by Thiago Braz in 2016, though you suspect Braz had mentally released that one already.\", \"from\": 1071, \"to\": 1314, \"entities\": [{\"begin\": 1230, \"end\": 1241, \"title\": \"http://dbpedia.org/resource/Thiago_Braz\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Thiago Braz\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Thiago_Braz\", \"dbpedia\": \"http://dbpedia.org/resource/Thiago_Braz\"}], \"noun_phrases\": [{\"ngram\": \"some brief hugs\", \"from\": 1077, \"to\": 1092}, {\"ngram\": \"his parents\", \"from\": 1098, \"to\": 1109}, {\"ngram\": \"gold\", \"from\": 1123, \"to\": 1127}, {\"ngram\": \"Duplantis\", \"from\": 1129, \"to\": 1138}, {\"ngram\": \"the track\", \"from\": 1153, \"to\": 1162}, {\"ngram\": \"work\", \"from\": 1174, \"to\": 1178}, {\"ngram\": \"the Olympic record\", \"from\": 1195, \"to\": 1213}, {\"ngram\": \"Braz\", \"from\": 1270, \"to\": 1274}, {\"ngram\": \"that one\", \"from\": 1297, \"to\": 1305}]}, {\"sentence\": \"Kendricks geed up the crowd as Duplantis glided over 6.10m with room to spare.\", \"from\": 1315, \"to\": 1393, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Kendricks\", \"from\": 1315, \"to\": 1324}, {\"ngram\": \"the crowd\", \"from\": 1333, \"to\": 1342}, {\"ngram\": \"Duplantis\", \"from\": 1346, \"to\": 1355}, {\"ngram\": \"room\", \"from\": 1379, \"to\": 1383}]}, {\"sentence\": \"It moved up to the world record of 6.25m.\", \"from\": 1395, \"to\": 1436, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the world record\", \"from\": 1410, \"to\": 1426}, {\"ngram\": \"6.25m.\", \"from\": 1430, \"to\": 1436}]}, {\"sentence\": \"After two failed attempts, he lay down and stretched out his back, giving his body every possible chance of bending over the bar in his final try.\", \"from\": 1437, \"to\": 1583, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"two failed attempts\", \"from\": 1443, \"to\": 1462}, {\"ngram\": \"his back\", \"from\": 1494, \"to\": 1502}, {\"ngram\": \"his body\", \"from\": 1511, \"to\": 1519}, {\"ngram\": \"every possible chance\", \"from\": 1520, \"to\": 1541}, {\"ngram\": \"the bar\", \"from\": 1558, \"to\": 1565}, {\"ngram\": \"his final try\", \"from\": 1569, \"to\": 1582}]}, {\"sentence\": \"Duplantis stood at the top of the runway with his pole resting on his shoulder.\", \"from\": 1585, \"to\": 1664, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Duplantis\", \"from\": 1585, \"to\": 1594}, {\"ngram\": \"the top\", \"from\": 1604, \"to\": 1611}, {\"ngram\": \"the runway\", \"from\": 1615, \"to\": 1625}, {\"ngram\": \"his pole resting\", \"from\": 1631, \"to\": 1647}, {\"ngram\": \"his shoulder\", \"from\": 1651, \"to\": 1663}]}, {\"sentence\": \"He took a couple of sharp breaths and muttered \\\"come on\\\" to himself as volleys of \\\"Allez Mondo!\\\"\", \"from\": 1665, \"to\": 1761, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a couple\", \"from\": 1673, \"to\": 1681}, {\"ngram\": \"sharp breaths\", \"from\": 1685, \"to\": 1698}, {\"ngram\": \"volleys\", \"from\": 1736, \"to\": 1743}, {\"ngram\": \"Allez Mondo\", \"from\": 1748, \"to\": 1759}]}, {\"sentence\": \"shook the stadium.\", \"from\": 1762, \"to\": 1780, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the stadium\", \"from\": 1768, \"to\": 1779}]}, {\"sentence\": \"Then he ran, muscles straining, hair trailing in the wind like Evel Knievel's cape.\", \"from\": 1781, \"to\": 1864, \"entities\": [{\"begin\": 1844, \"end\": 1856, \"title\": \"http://dbpedia.org/resource/Evel_Knievel\", \"score\": 1.0, \"rank\": 7.125562746938716e-36, \"text\": \"Evel Knievel\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Evel_Knievel\", \"dbpedia\": \"http://dbpedia.org/resource/Evel_Knievel\"}], \"noun_phrases\": [{\"ngram\": \"muscles\", \"from\": 1794, \"to\": 1801}, {\"ngram\": \"the wind\", \"from\": 1830, \"to\": 1838}]}, {\"sentence\": \"He slid his pole into the box and launched into the air in one smooth motion, contorting his body into a perfect right-angle before whipping his arm away from contact.\", \"from\": 1865, \"to\": 2032, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"his pole\", \"from\": 1873, \"to\": 1881}, {\"ngram\": \"the box\", \"from\": 1887, \"to\": 1894}, {\"ngram\": \"the air\", \"from\": 1913, \"to\": 1920}, {\"ngram\": \"one smooth motion\", \"from\": 1924, \"to\": 1941}, {\"ngram\": \"his body\", \"from\": 1954, \"to\": 1962}, {\"ngram\": \"a perfect right-angle\", \"from\": 1968, \"to\": 1989}, {\"ngram\": \"his arm\", \"from\": 2006, \"to\": 2013}, {\"ngram\": \"contact\", \"from\": 2024, \"to\": 2031}]}, {\"sentence\": \"The bar never twitched.\", \"from\": 2033, \"to\": 2056, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The bar\", \"from\": 2033, \"to\": 2040}]}, {\"sentence\": \"He was celebrating before gravity had thrown him onto the mat.\", \"from\": 2058, \"to\": 2120, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"gravity\", \"from\": 2084, \"to\": 2091}, {\"ngram\": \"the mat\", \"from\": 2112, \"to\": 2119}]}, {\"sentence\": \"Then he was up, letting off a primal roar before rushing into the arms of his girlfriend, the Swedish model and TikTokker Desire Inglander.\", \"from\": 2121, \"to\": 2260, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a primal roar\", \"from\": 2149, \"to\": 2162}, {\"ngram\": \"the arms\", \"from\": 2183, \"to\": 2191}, {\"ngram\": \"his girlfriend\", \"from\": 2195, \"to\": 2209}]}, {\"sentence\": \"Abba'sDancing Queenblared from the speakers as he embarked on a victory lap.\", \"from\": 2261, \"to\": 2337, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the speakers\", \"from\": 2292, \"to\": 2304}, {\"ngram\": \"a victory lap\", \"from\": 2323, \"to\": 2336}]}, {\"sentence\": \"\\\"I do not know how to put into words what I am feeling,\\\" Duplantis said after the bedlam subsided.\", \"from\": 2339, \"to\": 2437, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"words\", \"from\": 2370, \"to\": 2375}, {\"ngram\": \"Duplantis\", \"from\": 2396, \"to\": 2405}, {\"ngram\": \"the bedlam\", \"from\": 2417, \"to\": 2427}]}, {\"sentence\": \"\\\"I feel so grateful for how tonight played out.\", \"from\": 2438, \"to\": 2485, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I did not let myself believe that I was Olympic champion until it was all done.\", \"from\": 2486, \"to\": 2565, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Olympic champion\", \"from\": 2526, \"to\": 2542}]}, {\"sentence\": \"I think it's been such a fight to show up and to be at our best and do it when it matters.\", \"from\": 2566, \"to\": 2656, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"such a fight\", \"from\": 2584, \"to\": 2596}]}, {\"sentence\": \"\\\"I feel so grateful for having this come together, a little bit of luck on our side, and being able to walk away on top.\", \"from\": 2658, \"to\": 2778, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"luck\", \"from\": 2725, \"to\": 2729}, {\"ngram\": \"our side\", \"from\": 2733, \"to\": 2741}, {\"ngram\": \"top\", \"from\": 2774, \"to\": 2777}]}, {\"sentence\": \"It's just so special.\\\"\", \"from\": 2779, \"to\": 2801, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Pole vault is ostensibly a silly endeavour, the only track and field event whose most Googled queries are to ask who invented it and why.\", \"from\": 2803, \"to\": 2940, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Pole vault\", \"from\": 2803, \"to\": 2813}, {\"ngram\": \"a silly endeavour\", \"from\": 2828, \"to\": 2845}, {\"ngram\": \"the only track and field event\", \"from\": 2847, \"to\": 2877}, {\"ngram\": \"whose most Googled queries\", \"from\": 2878, \"to\": 2904}]}, {\"sentence\": \"But it is also compelling sport and dazzling art in equal measure.\", \"from\": 2941, \"to\": 3007, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"compelling sport and dazzling art\", \"from\": 2956, \"to\": 2989}, {\"ngram\": \"equal measure\", \"from\": 2993, \"to\": 3006}]}, {\"sentence\": \"Essentially what happened here is that 80,000 people lost their minds as they watched a Swedish man clear the height of a large giraffe with nothing but a stick in his hands.\", \"from\": 3008, \"to\": 3182, \"entities\": [{\"begin\": 3096, \"end\": 3103, \"title\": \"http://dbpedia.org/resource/Sweden\", \"score\": 0.9996650756691002, \"rank\": 0.0002646510436892884, \"text\": \"Swedish\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Sweden\", \"dbpedia\": \"http://dbpedia.org/resource/Sweden\"}], \"noun_phrases\": [{\"ngram\": \"80,000 people\", \"from\": 3047, \"to\": 3060}, {\"ngram\": \"their minds\", \"from\": 3066, \"to\": 3077}, {\"ngram\": \"the height\", \"from\": 3114, \"to\": 3124}, {\"ngram\": \"a large giraffe\", \"from\": 3128, \"to\": 3143}, {\"ngram\": \"nothing\", \"from\": 3149, \"to\": 3156}, {\"ngram\": \"a stick\", \"from\": 3161, \"to\": 3168}, {\"ngram\": \"his hands\", \"from\": 3172, \"to\": 3181}]}, {\"sentence\": \"Duplantis has always had the ingredients, as the son of an American pole-vaulter and a Swedish heptathlete.\", \"from\": 3184, \"to\": 3291, \"entities\": [{\"begin\": 3243, \"end\": 3251, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999914202121265, \"rank\": 7.066010384865187e-06, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 3271, \"end\": 3278, \"title\": \"http://dbpedia.org/resource/Sweden\", \"score\": 0.9996650756691002, \"rank\": 0.0002646510436892884, \"text\": \"Swedish\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Sweden\", \"dbpedia\": \"http://dbpedia.org/resource/Sweden\"}], \"noun_phrases\": [{\"ngram\": \"Duplantis\", \"from\": 3184, \"to\": 3193}, {\"ngram\": \"the ingredients\", \"from\": 3209, \"to\": 3224}, {\"ngram\": \"the son\", \"from\": 3229, \"to\": 3236}]}, {\"sentence\": \"But ever since he first cleared Renaud Lavillenie's record of 6.15m in 2020, he has found ways of reaching new, unfathomable heights.\", \"from\": 3292, \"to\": 3425, \"entities\": [{\"begin\": 3324, \"end\": 3341, \"title\": \"http://dbpedia.org/resource/Renaud_Lavillenie\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Renaud Lavillenie\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Renaud_Lavillenie\", \"dbpedia\": \"http://dbpedia.org/resource/Renaud_Lavillenie\"}], \"noun_phrases\": [{\"ngram\": \"6.15m\", \"from\": 3354, \"to\": 3359}, {\"ngram\": \"ways\", \"from\": 3382, \"to\": 3386}, {\"ngram\": \"new, unfathomable heights\", \"from\": 3399, \"to\": 3424}]}, {\"sentence\": \"You can take your pick from his list of records and achievements.\", \"from\": 3427, \"to\": 3492, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"your pick\", \"from\": 3440, \"to\": 3449}, {\"ngram\": \"his list\", \"from\": 3455, \"to\": 3463}, {\"ngram\": \"records\", \"from\": 3467, \"to\": 3474}, {\"ngram\": \"achievements\", \"from\": 3479, \"to\": 3491}]}, {\"sentence\": \"At 24, he is already a double Olympic champion, and a double world champion too.\", \"from\": 3493, \"to\": 3573, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a double Olympic champion\", \"from\": 3514, \"to\": 3539}, {\"ngram\": \"a double world champion\", \"from\": 3545, \"to\": 3568}]}, {\"sentence\": \"The top 10 clearances in history are all his.\", \"from\": 3574, \"to\": 3619, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The top 10 clearances\", \"from\": 3574, \"to\": 3595}, {\"ngram\": \"history\", \"from\": 3599, \"to\": 3606}]}, {\"sentence\": \"My personal favourite is that he has not won a silver or bronze medal since 2019.\", \"from\": 3620, \"to\": 3701, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My personal favourite\", \"from\": 3620, \"to\": 3641}, {\"ngram\": \"a silver or bronze medal\", \"from\": 3665, \"to\": 3689}]}, {\"sentence\": \"This was the apex of five years of unfettered dominance.\", \"from\": 3702, \"to\": 3758, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the apex\", \"from\": 3711, \"to\": 3719}, {\"ngram\": \"five years\", \"from\": 3723, \"to\": 3733}, {\"ngram\": \"unfettered dominance\", \"from\": 3737, \"to\": 3757}]}, {\"sentence\": \"That made the expectation enormous, not just to win but to put on a show.\", \"from\": 3760, \"to\": 3833, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the expectation\", \"from\": 3770, \"to\": 3785}, {\"ngram\": \"a show\", \"from\": 3826, \"to\": 3832}]}, {\"sentence\": \"In Paris, Duplantis made theatre.\", \"from\": 3834, \"to\": 3867, \"entities\": [{\"begin\": 3837, \"end\": 3842, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 6.49899125490339e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Duplantis\", \"from\": 3844, \"to\": 3853}, {\"ngram\": \"theatre\", \"from\": 3859, \"to\": 3866}]}, {\"sentence\": \"\\\"Pressure is becoming my friend.\", \"from\": 3869, \"to\": 3901, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Pressure\", \"from\": 3870, \"to\": 3878}, {\"ngram\": \"my friend\", \"from\": 3891, \"to\": 3900}]}, {\"sentence\": \"I think it's one of those things I have learnt can bring out the best in you if you embrace it.\", \"from\": 3902, \"to\": 3997, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"those things\", \"from\": 3922, \"to\": 3934}]}, {\"sentence\": \"I felt like I was really in the zone and just doing great, and I felt that so much in my prelim.\", \"from\": 3998, \"to\": 4094, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the zone\", \"from\": 4026, \"to\": 4034}, {\"ngram\": \"my prelim\", \"from\": 4084, \"to\": 4093}]}, {\"sentence\": \"And then tonight, I think on my first throw, I felt the weight of, 'Holy crap, this is the Olympics'.\", \"from\": 4095, \"to\": 4196, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my first throw\", \"from\": 4124, \"to\": 4138}, {\"ngram\": \"the weight\", \"from\": 4147, \"to\": 4157}, {\"ngram\": \"Holy crap\", \"from\": 4163, \"to\": 4172}, {\"ngram\": \"the Olympics\", \"from\": 4182, \"to\": 4194}]}, {\"sentence\": \"\\\"It took me a minute to find my groove, but once my coach got me in a better headspace, and we just took it throw by throw, it felt like things were just clicking and that stadium filled with 80,000 people were just bringing out the best in all the athletes.\", \"from\": 4198, \"to\": 4456, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a minute\", \"from\": 4210, \"to\": 4218}, {\"ngram\": \"my groove\", \"from\": 4227, \"to\": 4236}, {\"ngram\": \"my coach\", \"from\": 4247, \"to\": 4255}, {\"ngram\": \"a better headspace\", \"from\": 4266, \"to\": 4284}, {\"ngram\": \"throw\", \"from\": 4315, \"to\": 4320}, {\"ngram\": \"things\", \"from\": 4335, \"to\": 4341}, {\"ngram\": \"that stadium\", \"from\": 4365, \"to\": 4377}, {\"ngram\": \"80,000 people\", \"from\": 4390, \"to\": 4403}, {\"ngram\": \"all the athletes\", \"from\": 4439, \"to\": 4455}]}, {\"sentence\": \"I am so grateful to embrace that and be part of such a historic night.\\\"\", \"from\": 4457, \"to\": 4528, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"part\", \"from\": 4497, \"to\": 4501}, {\"ngram\": \"such a historic night\", \"from\": 4505, \"to\": 4526}]}, {\"sentence\": \"Join thought-provoking conversations, follow other Independent readers and see their replies Please refresh the page or navigate to another page on the site to be automatically logged inPlease refresh your browser to be logged in\", \"from\": 4530, \"to\": 4760, \"entities\": [{\"begin\": 4581, \"end\": 4592, \"title\": \"http://dbpedia.org/resource/The_Independent\", \"score\": 1.0, \"rank\": 2.851220109492151e-19, \"text\": \"Independent\", \"types\": [\"Q386724\", \"Q234460\", \"Q11032\", \"Q1092563\"], \"wikid\": \"http://dbpedia.org/resource/The_Independent\", \"dbpedia\": \"http://dbpedia.org/resource/The_Independent\"}], \"noun_phrases\": [{\"ngram\": \"thought-provoking conversations\", \"from\": 4535, \"to\": 4566}, {\"ngram\": \"their replies\", \"from\": 4609, \"to\": 4622}, {\"ngram\": \"the page\", \"from\": 4638, \"to\": 4646}, {\"ngram\": \"another page\", \"from\": 4662, \"to\": 4674}, {\"ngram\": \"the site\", \"from\": 4678, \"to\": 4686}, {\"ngram\": \"inPlease\", \"from\": 4714, \"to\": 4722}, {\"ngram\": \"your browser\", \"from\": 4731, \"to\": 4743}]}]}"