"{\"uid\": \"monacolife.net-monaco-plays-crucial-role-in-ensuring-seamless-communication-pathways-at-2024-olympics\", \"noun_phrases\": [{\"sentence\": \"A team from Monaco's Directorate of Platforms and Digital Resources, responsible for the technology element of operations at large-scale events in the Principality, has been dispatched across the border to assist with the running of vital communication systems during the ongoing Olympic Games.\", \"from\": 0, \"to\": 294, \"entities\": [{\"begin\": 12, \"end\": 18, \"title\": \"http://dbpedia.org/resource/Monaco\", \"score\": 0.9999998255032249, \"rank\": 1.7449650391234972e-07, \"text\": \"Monaco\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Monaco\", \"dbpedia\": \"http://dbpedia.org/resource/Monaco\"}], \"noun_phrases\": [{\"ngram\": \"A team\", \"from\": 0, \"to\": 6}, {\"ngram\": \"Platforms\", \"from\": 36, \"to\": 45}, {\"ngram\": \"Digital Resources\", \"from\": 50, \"to\": 67}, {\"ngram\": \"the technology element\", \"from\": 85, \"to\": 107}, {\"ngram\": \"operations\", \"from\": 111, \"to\": 121}, {\"ngram\": \"large-scale events\", \"from\": 125, \"to\": 143}, {\"ngram\": \"the Principality\", \"from\": 147, \"to\": 163}, {\"ngram\": \"the border\", \"from\": 192, \"to\": 202}, {\"ngram\": \"the running\", \"from\": 218, \"to\": 229}, {\"ngram\": \"vital communication systems\", \"from\": 233, \"to\": 260}, {\"ngram\": \"the ongoing Olympic Games\", \"from\": 268, \"to\": 293}]}, {\"sentence\": \"The behind-the-scenes running of a high-profile occasion such as the Olympic Games is all too often overlooked by the public, but it is nonetheless a crucial part of a successful event.\", \"from\": 296, \"to\": 481, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the-scenes\", \"from\": 307, \"to\": 317}, {\"ngram\": \"a high-profile occasion\", \"from\": 329, \"to\": 352}, {\"ngram\": \"the Olympic Games\", \"from\": 361, \"to\": 378}, {\"ngram\": \"the public\", \"from\": 410, \"to\": 420}, {\"ngram\": \"a crucial part\", \"from\": 444, \"to\": 458}, {\"ngram\": \"a successful event\", \"from\": 462, \"to\": 480}]}, {\"sentence\": \"This is something that the team at Monaco's Directorate of Platforms and Digital Resources (DPRN), which comes under the scope of the Interministerial Delegation Responsible for the Digital Transition, knows well, having previously been in charge of managing the communications elements of events such as the Monaco Grand Prix, the Monaco Yacht Show and the recent Tour de France stage in the Principality.\", \"from\": 483, \"to\": 889, \"entities\": [{\"begin\": 518, \"end\": 524, \"title\": \"http://dbpedia.org/resource/Monaco\", \"score\": 0.9999998255032249, \"rank\": 1.7449650391234972e-07, \"text\": \"Monaco\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Monaco\", \"dbpedia\": \"http://dbpedia.org/resource/Monaco\"}, {\"begin\": 792, \"end\": 809, \"title\": \"http://dbpedia.org/resource/Monaco_Grand_Prix\", \"score\": 0.9999246779963356, \"rank\": 7.471810443182756e-05, \"text\": \"Monaco Grand Prix\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Monaco_Grand_Prix\", \"dbpedia\": \"http://dbpedia.org/resource/Monaco_Grand_Prix\"}, {\"begin\": 848, \"end\": 862, \"title\": \"http://dbpedia.org/resource/Tour_de_France\", \"score\": 0.9995471113497326, \"rank\": 0.00034602821610055977, \"text\": \"Tour de France\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tour_de_France\", \"dbpedia\": \"http://dbpedia.org/resource/Tour_de_France\"}], \"noun_phrases\": [{\"ngram\": \"something\", \"from\": 491, \"to\": 500}, {\"ngram\": \"the team\", \"from\": 506, \"to\": 514}, {\"ngram\": \"Platforms\", \"from\": 542, \"to\": 551}, {\"ngram\": \"Digital Resources\", \"from\": 556, \"to\": 573}, {\"ngram\": \"DPRN\", \"from\": 575, \"to\": 579}, {\"ngram\": \"the scope\", \"from\": 600, \"to\": 609}, {\"ngram\": \"the Interministerial Delegation\", \"from\": 613, \"to\": 644}, {\"ngr