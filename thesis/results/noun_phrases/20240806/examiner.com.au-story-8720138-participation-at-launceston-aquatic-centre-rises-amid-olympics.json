, \"entities\": [{\"begin\": 1259, \"end\": 1268, \"title\": \"http://dbpedia.org/resource/Australia\", \"score\": 0.9999916003510295, \"rank\": 8.399712591501357e-06, \"text\": \"Australia\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Australia\", \"dbpedia\": \"http://dbpedia.org/resource/Australia\"}], \"noun_phrases\": [{\"ngram\": \"the glaring inequalities\", \"from\": 1295, \"to\": 1319}, {\"ngram\": \"housing access\", \"from\": 1323, \"to\": 1337}]}, {\"sentence\": \"Mission Australia's new youth homelessness report revealed nearly one in ten Youth Survey 2023 participants experienced homelessness in the previous year.\", \"from\": 1352, \"to\": 1506, \"entities\": [{\"begin\": 1352, \"end\": 1369, \"title\": \"http://dbpedia.org/resource/Mission_Australia\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Mission Australia\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Mission_Australia\", \"dbpedia\": \"http://dbpedia.org/resource/Mission_Australia\"}], \"noun_phrases\": [{\"ngram\": \"nearly one in ten Youth Survey 2023 participants\", \"from\": 1411, \"to\": 1459}, {\"ngram\": \"homelessness\", \"from\": 1472, \"to\": 1484}, {\"ngram\": \"the previous year\", \"from\": 1488, \"to\": 1505}]}, {\"sentence\": \"More than 220,000 households are waiting for social housing and some will never get access to a stable home.\", \"from\": 1508, \"to\": 1616, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"More than 220,000 households\", \"from\": 1508, \"to\": 1536}, {\"ngram\": \"social housing\", \"from\": 1553, \"to\": 1567}, {\"ngram\": \"access\", \"from\": 1592, \"to\": 1598}, {\"ngram\": \"a stable home\", \"from\": 1602, \"to\": 1615}]}, {\"sentence\": \"The ripple effects of homelessness are profound, especially for children and young people - having a devastating impact on their lives in adulthood.\", \"from\": 1618, \"to\": 1766, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The ripple effects\", \"from\": 1618, \"to\": 1636}, {\"ngram\": \"homelessness\", \"from\": 1640, \"to\": 1652}, {\"ngram\": \"children\", \"from\": 1682, \"to\": 1690}, {\"ngram\": \"young people\", \"from\": 1695, \"to\": 1707}, {\"ngram\": \"a devastating impact\", \"from\": 1717, \"to\": 1737}, {\"ngram\": \"their lives\", \"from\": 1741, \"to\": 1752}, {\"ngram\": \"adulthood\", \"from\": 1756, \"to\": 1765}]}, {\"sentence\": \"Homelessness is usually a result of poverty, housing unaffordability and inadequate support systems.\", \"from\": 1768, \"to\": 1868, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Homelessness\", \"from\": 1768, \"to\": 1780}, {\"ngram\": \"a result\", \"from\": 1792, \"to\": 1800}, {\"ngram\": \"poverty\", \"from\": 1804, \"to\": 1811}, {\"ngram\": \"housing unaffordability\", \"from\": 1813, \"to\": 1836}, {\"ngram\": \"inadequate support systems\", \"from\": 1841, \"to\": 1867}]}, {\"sentence\": \"This is why Mission Australia advocates for systemic reforms aimed at tackling the root causes of homelessness.\", \"from\": 1870, \"to\": 1981, \"entities\": [{\"begin\": 1882, \"end\": 1899, \"title\": \"http://dbpedia.org/resource/Mission_Australia\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Mission Australia\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Mission_Australia\", \"dbpedia\": \"http://dbpedia.org/resource/Mission_Australia\"}], \"noun_phrases\": [{\"ngram\": \"systemic reforms\", \"from\": 1914, \"to\": 1930}, {\"ngram\": \"the root causes\", \"from\": 1949, \"to\": 1964}, {\"ngram\": \"homelessness\", \"from\": 1968, \"to\": 1980}]}, {\"sentence\": \"A $500m Homelessness Prevention Transformation Fund will help people avoid homelessness in the first place.\", \"from\": 1983, \"to\": 2090, \"entities\": [{\"begin\": 1991, \"end\": 2003, \"title\": \"http://dbpedia.org/resource/Homelessness\", \"score\": 1.0, \"rank\": 1.5163322045286256e-16, \"text\": \"Homelessness\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Homelessness\", \"dbped