m\": \"his performance\", \"from\": 398, \"to\": 413}, {\"ngram\": \"Morales-Williams\", \"from\": 415, \"to\": 431}, {\"ngram\": \"the Olympics\", \"from\": 454, \"to\": 466}, {\"ngram\": \"even the hardest thing\", \"from\": 474, \"to\": 496}]}, {\"sentence\": \"Speaking after the event, the 400m runner said: \\\"I was talking with Coach Caryl [Smith-Gilbert], she was telling me 'You have done harder things than this already.'\", \"from\": 514, \"to\": 678, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the event\", \"from\": 529, \"to\": 538}, {\"ngram\": \"the 400m runner\", \"from\": 540, \"to\": 555}, {\"ngram\": \"Coach Caryl\", \"from\": 582, \"to\": 593}, {\"ngram\": \"Smith-Gilbert\", \"from\": 595, \"to\": 608}, {\"ngram\": \"harder things\", \"from\": 645, \"to\": 658}]}, {\"sentence\": \"SECs [the US college championship] was harder.\", \"from\": 679, \"to\": 725, \"entities\": [{\"begin\": 689, \"end\": 691, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.971006185845272, \"rank\": 0.02964072405141772, \"text\": \"US\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"SECs\", \"from\": 679, \"to\": 683}]}, {\"sentence\": \"\\\"SECs last year was harder than any race I have done this year.\", \"from\": 727, \"to\": 790, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"SECs\", \"from\": 728, \"to\": 732}, {\"ngram\": \"any race\", \"from\": 759, \"to\": 767}]}, {\"sentence\": \"The hardest part was just getting to be that fast.\\\"\", \"from\": 791, \"to\": 842, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The hardest part\", \"from\": 791, \"to\": 807}]}, {\"sentence\": \"Morales-Williams is right to reference the SECs, given he recorded the fastest 400-metre time in the world this year at the event earlier this year.\", \"from\": 844, \"to\": 992, \"entities\": [], \"noun_phrases\": [{\"ngram