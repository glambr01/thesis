\", \"from\": 1301, \"to\": 1335}, {\"ngram\": \"a bit\", \"from\": 1361, \"to\": 1366}, {\"ngram\": \"work\", \"from\": 1370, \"to\": 1374}, {\"ngram\": \"the garden\", \"from\": 1378, \"to\": 1388}]}, {\"sentence\": \"\\\"When I get home, I am going to have to use the rake because she cut everything,\\\" he smiled.\", \"from\": 1400, \"to\": 1492, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the rake\", \"from\": 1444, \"to\": 1452}, {\"ngram\": \"everything\", \"from\": 1469, \"to\": 1479}]}, {\"sentence\": \"Thousands of Polynesians cheered their champion Johanne Defay from the French island of Reunion, who won bronze in the women's final.\", \"from\": 1494, \"to\": 1627, \"entities\": [{\"begin\": 1507, \"end\": 1518, \"title\": \"http://dbpedia.org/resource/Polynesian_culture\", \"score\": 0.9580229643298501, \"rank\": 0.025935520405423632, \"text\": \"Polynesians\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Polynesian_culture\", \"dbpedia\": \"http://dbpedia.org/resource/Polynesian_culture\"}, {\"begin\": 1542, \"end\": 1555, \"title\": \"http://dbpedia.org/resource/Johanne_Defay\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Johanne Defay\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Johanne_Defay\", \"dbpedia\": \"http://dbpedia.org/resource/Johanne_Defay\"}, {\"begin\": 1565, \"end\": 1578, \"title\": \"http://dbpedia.org/resource/French_Island_National_Park\", \"score\": 0.9975288938851635, \"rank\": 0.002178673114455573, \"text\": \"French island\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/French_Island_National_Park\", \"dbpedia\": \"http://dbpedia.org/resource/French_Island_National_Park\"}, {\"begin\": 1582, \"end\": 1589, \"title\": \"http://dbpedia.org/resource/Reunion_Records\", \"score\": 0.9999999999688498, \"rank\": 3.078927776292839e-11, \"text\": \"Reunion\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\", \"Q18127\"], \"wikid\": \"http://dbpedia.org/resource/Reunion_Records\", \"