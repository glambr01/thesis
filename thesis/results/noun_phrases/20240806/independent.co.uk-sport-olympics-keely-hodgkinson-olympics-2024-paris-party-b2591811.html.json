ics\"}], \"noun_phrases\": [{\"ngram\": \"the track\", \"from\": 1859, \"to\": 1868}]}, {\"sentence\": \"She said after her win: \\\"I think being the champion, no one can ever take that away from me,\\\" she said.\", \"from\": 1903, \"to\": 2006, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her win\", \"from\": 1918, \"to\": 1925}, {\"ngram\": \"the champion\", \"from\": 1942, \"to\": 1954}, {\"ngram\": \"no one\", \"from\": 1956, \"to\": 1962}]}, {\"sentence\": \"\\\"This is the biggest stage our sport's ever on.\", \"from\": 2007, \"to\": 2054, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the biggest stage\", \"from\": 2016, \"to\": 2033}, {\"ngram\": \"our sport\", \"from\": 2034, \"to\": 2043}]}, {\"sentence\": \"I do not know what it'll bring, but I think I am a lot better prepared for it than I was last time.\\\"\", \"from\": 2055, \"to\": 2155, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"last time\", \"from\": 2144, \"to\": 2153}]}, {\"sentence\": \"Being the favourite brought pressure and expectation.\", \"from\": 2157, \"to\": 2210, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the favourite brought pressure\", \"from\": 2163, \"to\": 2193}, {\"ngram\": \"expectation\", \"from\": 2198, \"to\": 2209}]}, {\"sentence\": \"With a chance to win an Olympic title, another near-miss would have been devastating.\", \"from\": 2211, \"to\": 2296, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a chance\", \"from\": 2216, \"to\": 2224}, {\"ngram\": \"an Olympic title\", \"from\": 2232, \"to\": 2248}, {\"ngram\": \"another near-miss\", \"from\": 2250, \"to\": 2267}]}, {\"sentence\": \"\\\"I have had to try and block out the noise,\\\" she said.\", \"from\": 2297, \"to\": 2351, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the noise\", \"from\": 2330, \"to\": 2339}]}, {\"sentence\": \"\\\"To deliver on this stage, it means everything.\", \"from\": 2352, \"to\": 2399, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this stage\", \"from\