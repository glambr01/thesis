"{\"uid\": \"fox5atlanta.com-news-look-up-atlanta-in-centennial-olympic-park-canceled-for-2024\", \"noun_phrases\": [{\"sentence\": \"Share ATLANTA-The Georgia World Congress Center Authority (GWCCA) has announced that the popular event Look Up Atlanta, which is a pre 4th of July celebration, will be taking a break for the year 2024.\", \"from\": 0, \"to\": 204, \"entities\": [{\"begin\": 21, \"end\": 60, \"title\": \"http://dbpedia.org/resource/Georgia_World_Congress_Center\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Georgia World Congress Center Authority\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Georgia_World_Congress_Center\", \"dbpedia\": \"http://dbpedia.org/resource/Georgia_World_Congress_Center\"}, {\"begin\": 114, \"end\": 121, \"title\": \"http://dbpedia.org/resource/Atlanta\", \"score\": 0.9999999999538431, \"rank\": 4.5815290070577795e-11, \"text\": \"Atlanta\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Atlanta\", \"dbpedia\": \"http://dbpedia.org/resource/Atlanta\"}], \"noun_phrases\": [{\"ngram\": \"Share ATLANTA\", \"from\": 0, \"to\": 13}, {\"ngram\": \"the popular event\", \"from\": 85, \"to\": 102}, {\"ngram\": \"a pre 4th\", \"from\": 129, \"to\": 138}, {\"ngram\": \"July celebration\", \"from\": 142, \"to\": 158}, {\"ngram\": \"a break\", \"from\": 175, \"to\": 182}, {\"ngram\": \"the year\", \"from\": 187, \"to\": 195}]}, {\"sentence\": \"The decision was made after careful consideration of several factors, including existing events on campus, new opportunities associated with the event, upcoming renovations in Centennial Olympic Park, and a desire to enhance the experience for future attendees, according to a press release.\", \"from\": 206, \"to\": 497, \"entities\": [{\"begin\": 382, \"end\": 405, \"title\": \"http://dbpedia.org/resource/Centennial_Olympic_Park\", \"score\": 0.999999752022435, \"rank\": 2.479775972795059e-07, \"text\": \"Centennial Olympic Park\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Centennial_Olympic_Park\", \"dbpedia\": \"http://dbpedia.org/resource/Centennial_Olympic_Park\"}], \"noun_phrases\": [{\"ngram\": \"The decision\", \"from\": 206, \"to\": 218}, {\"ngram\": \"careful consideration\", \"from\": 234, \"to\": 255}, {\"ngram\": \"several factors\", \"from\": 259, \"to\": 274}, {\"ngram\": \"existing events\", \"from\": 286, \"to\": 301}, {\"ngram\": \"campus\", \"from\": 305, \"to\": 311}, {\"ngram\": \"new opportunities\", \"from\": 313, \"to\": 330}, {\"ngram\": \"the event\", \"from\": 347, \"to\": 356}, {\"ngram\": \"upcoming renovations\", \"from\": 358, \"to\": 378}, {\"ngram\": \"a desire\", \"from\": 411, \"to\": 419}, {\"ngram\": \"the experience\", \"from\": 431, \"to\": 445}, {\"ngram\": \"future attendees\", \"from\": 450, \"to\": 466}, {\"ngram\": \"a press release\", \"from\": 481, \"to\": 496}]}, {\"sentence\": \"Patrons who have already purchased tickets for the scheduled June 29 event will receive full refunds through Look Up Atlanta's ticket partner, Big Tickets.\", \"from\": 499, \"to\": 654, \"entities\": [{\"begin\": 616, \"end\": 623, \"title\": \"http://dbpedia.org/resource/Atlanta\", \"score\": 0.9999999999538431, \"rank\": 4.5815290070577795e-11, \"text\": \"Atlanta\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Atlanta\", \"dbpedia\": \"http://dbpedia.org/resource/Atlanta\"}], \"noun_phrases\": [{\"ngram\": \"Patrons\", \"from\": 499, \"to\": 506}, {\"ngram\": \"tickets\", \"from\": 534, \"to\": 541}, {\"ngram\": \"the scheduled June 29 event\", \"from\": 546, \"to\": 573}, {\"ngram\": \"full refunds\", \"from\": 587, \"to\": 599}, {\"ngram\": \"Big Tickets\", \"from\": 642, \"to\": 653}]}, {\"sentence\": \"Refunds will be automatically processed and should reach purchasers within 7-10 business days.\", \"from\": 655, \"to\": 749, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Refunds\", \"from\": 655, \"to\": 662}, {\"ngram\": \"purchasers\", \"from\": 712, \"to\": 722}, {\"ngram\": \"7-10 business days\", \"from\": 730, \"to\": 748}]}, {\"sentence\": \"\\\"While we understand the disappointment this may bring, we believe that pausing the event in 2024 will allow us to come back stronger in 2025, celebrating everything that makes Atlanta and Georgia a remarkable place to call home,\\\" stated Frank Poe, the executive director of GWCCA.\", \"from\": 751, \"to\": 1032, \"entities\": [{\"begin\": 928, \"end\": 935, \"title\": \"http://dbpedia.org/resource/Atlanta\", \"score\": 0.9999999999538431, \"rank\": 4.5815290070577795e-11, \"text\": \"Atlanta\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Atlanta\", \"dbpedia\": \"http://dbpedia.org/resource/Atlanta\"}, {\"begin\": 940, \"end\": 947, \"title\": \"http://dbpedia.org/resource/University_of_Georgia\", \"score\": 0.9910098897007258, \"rank\": 0.0037416407436582236, \"text\": \"Georgia\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/University_of_Georgia\", \"dbpedia\": \"http://dbpedia.org/resource/University_of_Georgia\"}, {\"begin\": 995, \"end\": 998, \"title\": \"http://dbpedia.org/resource/Edgar_Allan_Poe\", \"score\": 0.9999601098216401, \"rank\": 3.9125798926542716e-05, \"text\": \"Poe\", \"types\": [\"Q729\", \"Q5\", \"Q36180\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Edgar_Allan_Poe\", \"dbpedia\": \"http://dbpedia.org/resource/Edgar_Allan_Poe\"}], \"noun_phrases\": [{\"ngram\": \"the disappointment\", \"from\": 772, \"to\": 790}, {\"ngram\": \"the event\", \"from\": 831, \"to\": 840}, {\"ngram\": \"us\", \"from\": 860, \"to\": 862}, {\"ngram\": \"everything\", \"from\": 906, \"to\": 916}, {\"ngram\": \"the executive director\", \"from\": 1000, \"to\": 1022}, {\"ngram\": \"GWCCA\", \"from\": 1026, \"to\": 1031}]}, {\"sentence\": \"\\\"We appreciate the ongoing support from our attendees, sponsors, and partners, and we are excited to return in 2025 with a refreshed and reimagined Look Up Atlanta.\\\"\", \"from\": 1033, \"to\": 1198, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the ongoing support\", \"from\": 1048, \"to\": 1067}, {\"ngram\": \"our attendees\", \"from\": 1073, \"to\": 1086}, {\"ngram\": \"sponsors\", \"from\": 1088, \"to\": 1096}, {\"ngram\": \"partners\", \"from\": 1102, \"to\": 1110}]}, {\"sentence\": \"During the hiatus, GWCCA will continue to actively plan and prepare for future Look Up Atlanta events.\", \"from\": 1200, \"to\": 1302, \"entities\": [{\"begin\": 1287, \"end\": 1294, \"title\": \"http://dbpedia.org/resource/Atlanta\", \"score\": 0.9999999999538431, \"rank\": 4.5815290070577795e-11, \"text\": \"Atlanta\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Atlanta\", \"dbpedia\": \"http://dbpedia.org/resource/Atlanta\"}], \"noun_phrases\": [{\"ngram\": \"the hiatus\", \"from\": 1207, \"to\": 1217}, {\"ngram\": \"GWCCA\", \"from\": 1219, \"to\": 1224}, {\"ngram\": \"future\", \"from\": 1272, \"to\": 1278}]}, {\"sentence\": \"Updates and announcements regarding the event's return will be communicated through official channels and the event's website.\", \"from\": 1303, \"to\": 1429, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Updates\", \"from\": 1303, \"to\": 1310}, {\"ngram\": \"announcements\", \"from\": 1315, \"to\": 1328}, {\"ngram\": \"the event's return\", \"from\": 1339, \"to\": 1357}, {\"ngram\": \"official channels\", \"from\": 1387, \"to\": 1404}, {\"ngram\": \"the event's website\", \"from\": 1409, \"to\": 1428}]}, {\"sentence\": \"For any inquiries or issues regarding refunds, patrons are advised to contactsupport@bigtickets.com.\", \"from\": 1431, \"to\": 1531, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"any inquiries\", \"from\": 1435, \"to\": 1448}, {\"ngram\": \"issues\", \"from\": 1452, \"to\": 1458}, {\"ngram\": \"refunds\", \"from\": 1469, \"to\": 1476}, {\"ngram\": \"patrons\", \"from\": 1478, \"to\": 1485}]}, {\"sentence\": \"All t