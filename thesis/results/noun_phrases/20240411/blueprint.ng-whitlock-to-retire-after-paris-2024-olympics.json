"{\"uid\": \"blueprint.ng-whitlock-to-retire-after-paris-2024-olympics\", \"noun_phrases\": [{\"sentence\": \"April 11, 2024Admin IIISports0 Three-time Olympic gold medallist Max Whitlock will retire after the Paris 2024 Games.\", \"from\": 0, \"to\": 118, \"entities\": [{\"begin\": 66, \"end\": 78, \"title\": \"http://dbpedia.org/resource/Max_Whitlock\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Max Whitlock\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Max_Whitlock\", \"dbpedia\": \"http://dbpedia.org/resource/Max_Whitlock\"}], \"noun_phrases\": [{\"ngram\": \"the Paris 2024 Games\", \"from\": 96, \"to\": 116}]}, {\"sentence\": \"The 31-year-old, who has won 32 major international medals, is Britain's most successful gymnast.\", \"from\": 120, \"to\": 217, \"entities\": [{\"begin\": 183, \"end\": 190, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9830206699851738, \"rank\": 0.017266543737033117, \"text\": \"Britain\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"32 major international medals\", \"from\": 149, \"to\": 178}]}, {\"sentence\": \"He will become the first gymnast to win four Olympic medals on the same apparatus if he adds to his two golds and a bronze on the pommel horse this summer.\", \"from\": 219, \"to\": 374, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the first gymnast\", \"from\": 234, \"to\": 251}, {\"ngram\": \"four Olympic medals\", \"from\": 259, \"to\": 278}, {\"ngram\": \"the same apparatus\", \"from\": 282, \"to\": 300}, {\"ngram\": \"his two golds\", \"from\": 315, \"to\": 328}, {\"ngram\": \"a bronze\", \"from\": 333, \"to\": 341}, {\"ngram\": \"the pommel horse\", \"from\": 345, \"to\": 361}]}, {\"sentence\": \"\\\"This decision now feels right,\\\" Whitlock told BBC Breakfast.\", \"from\": 376, \"to\": 437, \"entities\": [{\"begin\": 409, \"end\": 417, \"title\": \"http://dbpedia.org/resource/Max_Whitlock\", \"score\": 1.0, \"rank\": 4.736819093216073e-35, \"text\": \"Whitlock\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Max_Whitlock\", \"dbpedia\": \"http://dbpedia.org/resource/Max_Whitlock\"}, {\"begin\": 423, \"end\": 436, \"title\": \"http://dbpedia.org/resource/BBC_Breakfast\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"BBC Breakfast\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/BBC_Breakfast\", \"dbpedia\": \"http://dbpedia.org/resource/BBC_Breakfast\"}], \"noun_phrases\": [{\"ngram\": \"This decision\", \"from\": 377, \"to\": 390}]}, {\"sentence\": \"\\\"Going for my final Olympic Games, it feels very, very strange talking about it and it's almost hard to articulate what it's like.\", \"from\": 439, \"to\": 569, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my final Olympic Games\", \"from\": 450, \"to\": 472}]}, {\"sentence\": \"\\\"It's a really nice mindset to be in, to think I will just give it all I have got.\\\"\", \"from\": 571, \"to\": 654, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a really nice mindset\", \"from\": 577, \"to\": 598}]}, {\"sentence\": \"Whitlock's Olympic journey started at London 2012, where he claimed bronze in the pommel horse and helped Great Britain finish third in the team event.\", \"from\": 656, \"to\": 807, \"entities\": [{\"begin\": 656, \"end\": 664, \"title\": \"http://dbpedia.org/resource/Max_Whitlock\", \"score\": 1.0, \"rank\": 4.736819093216073e-35, \"text\": \"Whitlock\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Max_Whitlock\", \"dbpedia\": \"http://dbpedia.org/resource/Max_Whitlock\"}, {\"begin\": 694, \"end\": 705, \"title\": \"http://dbpedia.org/resource/2012_Summer_Olympics\", \"score\": 0.9999999999761258, \"rank\": 2.37733606583711e-11, \"text\": \"London 2012\", \"t