}]}, {\"sentence\": \"Other competition venues already existed, were previously planned or will be temporary.\", \"from\": 4475, \"to\": 4562, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Other competition venues\", \"from\": 4475, \"to\": 4499}]}, {\"sentence\": \"\\\"We really were driven by the ambition of sobriety and above all not to build sports facilities that are not needed and which will have no reason to exist after the Games,\\\" Marie Barsacq, the organizing committee's legacy director, said in an interview.\", \"from\": 4564, \"to\": 4817, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the ambition\", \"from\": 4590, \"to\": 4602}, {\"ngram\": \"sobriety\", \"from\": 4606, \"to\": 4614}, {\"ngram\": \"sports facilities\", \"from\": 4642, \"to\": 4659}, {\"ngram\": \"no reason\", \"from\": 4700, \"to\": 4709}, {\"ngram\": \"the Games\", \"from\": 4725, \"to\": 4734}, {\"ngram\": \"Marie Barsacq\", \"from\": 4737, \"to\": 4750}, {\"ngram\": \"the organizing committee's legacy director\", \"from\": 4752, \"to\": 4794}, {\"ngram\": \"an interview\", \"from\": 4804, \"to\": 4816}]}, {\"sentence\": \"The hand-me-down 50-meter pool for Sevran will be a significant upgrade.\", \"from\": 4819, \"to\": 4891, \"entities\": [{\"begin\": 4854, \"end\": 4860, \"title\": \"http://dbpedia.org/resource/Sevran\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Sevran\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Sevran\", \"dbpedia\": \"http://dbpedia.org/resource/Sevran\"}], \"noun_phrases\": [{\"ngram\": \"The hand-me-down 50-meter pool\", \"from\": 4819, \"to\": 4849}, {\"ngram\": \"a significant upgrade\", \"from\": 4869, \"to\": 4890}]}, {\"sentence\": \"The Seine-Saint-Denis town of 51,000 people was whacked by factory closures in the 1990s.\", \"from\": 4892, \"to\": 4981, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The Seine-Saint-Denis town\", \"from\": 4892, \"to\": 4918}, {\"ngram\": \"51,000 people\", \"from\": 4922, \"to\": 4935}, {\"ngram\": \"factory closures\", \"from\": 4951, \"to\": 4967}]}, {\"sentence\": \"Its existing 25-meter pool is nearly 50 years old.\", \"from\": 4982, \"to\": 5032, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Its existing 25-meter pool\", \"from\": 4982, \"to\": 5008}]}, {\"sentence\": \"Other Seine-Saint-Denis towns are also getting new or renovated pools - particularly welcome for the region's children, because only half of them can swim.\", \"from\": 5034, \"to\": 5189, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Other Seine-Saint-Denis towns\", \"from\": 5034, \"to\": 5063}, {\"ngram\": \"new or renovated pools\", \"from\": 5081, \"to\": 5103}, {\"ngram\": \"the region's children\", \"from\": 5131, \"to\": 5152}, {\"ngram\": \"only half\", \"from\": 5162, \"to\": 5171}]}, {\"sentence\": \"\\\"The ambition for these Olympic Games ... is that they benefit everyone and for the longest time possible,\\\" said Sevran Mayor St\\u00e9phane Blanchet.\", \"from\": 5191, \"to\": 5335, \"entities\": [{\"begin\": 5304, \"end\": 5310, \"title\": \"http://dbpedia.org/resource/Sevran\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Sevran\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Sevran\", \"dbpedia\": \"http://dbpedia.org/resource/Sevran\"}, {\"begin\": 5311, \"end\": 5316, \"title\": \"http://dbpedia.org/resource/Mayor_of_London\", \"score\": 0.9999999812616809, \"rank\": 1.8721552160397405e-08, \"text\": \"Mayor\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Mayor_of_London\", \"dbpedia\": \"http://dbpedia.org/resource/Mayor_of_London\"}, {\"begin\": 5326, \"end\": 5334, \"title\": \"http://dbpedia.org/resource/Blanchet_(harpsichord_makers)\", \"score\": 0.5898373953986847, \"rank\": 0.4226190476192673, \"text\": \"Blanchet\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Blanchet_(harpsichord_makers)\", \"dbpedia\": \"http://dbpedia.org/resource/Blanchet_(harpsichord_makers)\"}], \"noun_phrases\": [{\