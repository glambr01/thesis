, \"to\": 755, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"security risks\", \"from\": 689, \"to\": 703}, {\"ngram\": \"a plan B\", \"from\": 718, \"to\": 726}, {\"ngram\": \"even a plan C\", \"from\": 731, \"to\": 744}]}, {\"sentence\": \"One option, he said, would be to limit the ceremony to Paris's central Trocadero square, opposite the Eiffel Tower.\", \"from\": 757, \"to\": 872, \"entities\": [{\"begin\": 812, \"end\": 817, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999995453, \"rank\": 4.31646121260771e-13, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"One option\", \"from\": 757, \"to\": 767}, {\"ngram\": \"the ceremony\", \"from\": 796, \"to\": 808}, {\"ngram\": \"the Eiffel Tower\", \"from\": 855, \"to\": 871}]}, {\"sentence\": \"Another option would be to move the event indoors at the Stade de France.\", \"from\": 873, \"to\": 946, \"entities\": [{\"begin\": 930, \"end\": 945, \"title\": \"http://dbpedia.org/resource/Stade_de_France\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Stade de France\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Stade_de_France\", \"dbpedia\": \"http://dbpedia.org/resource/Stade_de_France\"}], \"noun_phrases\": [{\"ngram\": \"Another option\", \"from\": 873, \"to\": 887}, {\"ngram\": \"the event indoors\", \"from\": 905, \"to\": 922}]}, {\"sentence\": \"Meanwhile, following the Iranian attack, Macroncalled onIsrael to avoid further escalation in the Middle East, urging Israel to seek to isolate Iran rather than escalate the situation.\", \"from\": 948, \"to\": 1132, \"entities\": [{\"begin\": 973, \"end\": 980, \"title\": \"http://dbpedia.org/resource/Islamic_Republic_of_Iran_Armed_Forces\", \"score\": 0.8971362813314966, \"rank\": 0.11275266478121933, \"text\": \"Iranian\", \"types\": [\"Q43229\", \"Q24229398\", \"Q176799\"], \"wikid\": 