oku\"}], \"noun_phrases\": [{\"ngram\": \"partnerships\", \"from\": 989, \"to\": 1001}, {\"ngram\": \"the NBC Olympic Zone\", \"from\": 1007, \"to\": 1027}, {\"ngram\": \"tentpole content\", \"from\": 1053, \"to\": 1069}, {\"ngram\": \"the user experience\", \"from\": 1073, \"to\": 1092}, {\"ngram\": \"our partner platforms\", \"from\": 1096, \"to\": 1117}, {\"ngram\": \"deeper engagement\", \"from\": 1141, \"to\": 1158}, {\"ngram\": \"Matt Schnaars\", \"from\": 1166, \"to\": 1179}, {\"ngram\": \"President\", \"from\": 1181, \"to\": 1190}, {\"ngram\": \"NBCUniversal Content Distribution\", \"from\": 1192, \"to\": 1225}]}, {\"sentence\": \"\\\"NBCUniversal's coverage of the Paris Olympics will be the can not-miss event of 2024 and this partnership displays the type of experience we can create with partners like Roku to drive users into Peacock.\\\"\", \"from\": 1227, \"to\": 1433, \"entities\": [{\"begin\": 1228, \"end\": 1240, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 0.9999999966958057, \"rank\": 3.2362817190069425e-09, \"text\": \"NBCUniversal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}, {\"begin\": 1399, \"end\": 1403, \"title\": \"http://dbpedia.org/resource/Roku\", \"score\": 1.0, \"rank\": 9.00931289367522e-47, \"text\": \"Roku\", \"types\": [\"Q1067263\"], \"wikid\": \"http://dbpedia.org/resource/Roku\", \"dbpedia\": \"http://dbpedia.org/resource/Roku\"}, {\"begin\": 1424, \"end\": 1431, \"title\": \"http://dbpedia.org/resource/Peafowl\", \"score\": 0.9999999992705852, \"rank\": 7.29318521452343e-10, \"text\": \"Peacock\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Peafowl\", \"dbpedia\": \"http://dbpedia.org/resource/Peafowl\"}], \"noun_phrases\": [{\"ngram\": \"the Paris Olympics\", \"from\": 1255, \"to\": 1273}, {\"ngram\": \"the can not-miss event\", \"from\": 1282, \"to\": 1304}, {\"ngram\