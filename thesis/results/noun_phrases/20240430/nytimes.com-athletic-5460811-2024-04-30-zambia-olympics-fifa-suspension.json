"{\"uid\": \"nytimes.com-athletic-5460811-2024-04-30-zambia-olympics-fifa-suspension\", \"noun_phrases\": [{\"sentence\": \"Zambia's women's soccer team are facing being prevented from participating at this summer's Olympic Games due to an ongoing political crisis within the country's football association.\", \"from\": 0, \"to\": 185, \"entities\": [{\"begin\": 2, \"end\": 8, \"title\": \"http://dbpedia.org/resource/Zambia_national_football_team\", \"score\": 0.8373060409055758, \"rank\": 0.19399239507370983, \"text\": \"Zambia\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Zambia_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Zambia_national_football_team\"}], \"noun_phrases\": [{\"ngram\": \"this summer's Olympic Games\", \"from\": 78, \"to\": 105}, {\"ngram\": \"an ongoing political crisis\", \"from\": 113, \"to\": 140}, {\"ngram\": \"the country's football association\", \"from\": 148, \"to\": 182}]}, {\"sentence\": \"FIFA, world football's governing body, has said the Football Association of Zambia (FAZ) faces being suspended - and therefore Zambian teams prevented from featuring at international tournaments - following \\\"undue influence by third parties\\\" in FAZ.\", \"from\": 187, \"to\": 436, \"entities\": [{\"begin\": 271, \"end\": 274, \"title\": \"http://dbpedia.org/resource/Football_Association_of_Zambia\", \"score\": 1.0, \"rank\": 3.8454447172722376e-20, \"text\": \"FAZ\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Football_Association_of_Zambia\", \"dbpedia\": \"http://dbpedia.org/resource/Football_Association_of_Zambia\"}, {\"begin\": 314, \"end\": 321, \"title\": \"http://dbpedia.org/resource/Zambia_national_football_team\", \"score\": 0.9999354045471543, \"rank\": 6.459962565343758e-05, \"text\": \"Zambian\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Zambia_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Zambia_national_football_team\"}, {\"begin\": 432, \"end\": 435, \"title\": \"http://dbpedia.org/resource/Football_Association_of_Zambia\", \"score\": 1.0, \"rank\": 3.8454447172722376e-20, \"text\": \"FAZ\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Football_Association_of_Zambia\", \"dbpedia\": \"http://dbpedia.org/resource/Football_Association_of_Zambia\"}], \"noun_phrases\": [{\"ngram\": \"world football's governing body\", \"from\": 193, \"to\": 224}, {\"ngram\": \"the Football Association\", \"from\": 235, \"to\": 259}, {\"ngram\": \"Zambia\", \"from\": 263, \"to\": 269}, {\"ngram\": \"international tournaments\", \"from\": 356, \"to\": 381}, {\"ngram\": \"undue influence\", \"from\": 395, \"to\": 410}, {\"ngram\": \"third parties\", \"from\": 414, \"to\": 427}]}, {\"sentence\": \"Advertisement Zambia's High Court issued an injunction preventing FAZ's annual general meeting (AGM) from taking place as scheduled on Saturday, which came after FAZ's president and general secretary were arrested and charged with money laundering offences last week.\", \"from\": 438, \"to\": 706, \"entities\": [{\"begin\": 453, \"end\": 459, \"title\": \"http://dbpedia.org/resource/Zambia_national_football_team\", \"score\": 0.8373060409055758, \"rank\": 0.19399239507370983, \"text\": \"Zambia\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Zambia_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Zambia_national_football_team\"}, {\"begin\": 505, \"end\": 508, \"title\": \"http://dbpedia.org/resource/Football_Association_of_Zambia\", \"score\": 1.0, \"rank\": 3.8454447172722376e-20, \"text\": \"FAZ\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Football_Association_of_Zambia\", \"dbpedia\": \"http://dbpedia.org/resource/Football_Association_of_Zambia\"}, {\"begin\": 535, \"end\": 538, \"title\": \"http://dbpedia.org/resource/Annual_general_meeting\", \"score\": 1.0, \"rank\":