\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Football_Association_of_Zambia\", \"dbpedia\": \"http://dbpedia.org/resource/Football_Association_of_Zambia\"}, {\"begin\": 857, \"end\": 867, \"title\": \"http://dbpedia.org/resource/High_Court_of_Justice\", \"score\": 0.9995146953276519, \"rank\": 0.00045168220980103393, \"text\": \"High Court\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/High_Court_of_Justice\", \"dbpedia\": \"http://dbpedia.org/resource/High_Court_of_Justice\"}, {\"begin\": 904, \"end\": 907, \"title\": \"http://dbpedia.org/resource/Annual_general_meeting\", \"score\": 1.0, \"rank\": 1.1292080931107694e-18, \"text\": \"AGM\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Annual_general_meeting\", \"dbpedia\": \"http://dbpedia.org/resource/Annual_general_meeting\"}], \"noun_phrases\": [{\"ngram\": \"a letter\", \"from\": 728, \"to\": 736}, {\"ngram\": \"April\", \"from\": 806, \"to\": 811}, {\"ngram\": \"the injunction\", \"from\": 827, \"to\": 841}, {\"ngram\": \"a failure\", \"from\": 882, \"to\": 891}, {\"ngram\": \"undue influence\", \"from\": 938, \"to\": 953}, {\"ngram\": \"third parties\", \"from\": 957, \"to\": 970}]}, {\"sentence\": \"FIFA's laws prohibit third-party influence in the running of a member association and it has previously suspended nations where governments or courts have been judged to have interfered, such as India in August 2022.\", \"from\": 974, \"to\": 1190, \"entities\": [{\"begin\": 974, \"end\": 978, \"title\": \"http://dbpedia.org/resource/FIFA\", \"score\": 1.0, \"rank\": 3.202787524612988e-15, \"text\": \"FIFA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/FIFA\", \"dbpedia\": \"http://dbpedia.org/resource/FIFA\"}, {\"begin\": 1169, \"end\": 1174, \"title\": \"http://dbpedia.org/resource/India_national_cricket_team\", \"score\": 0.8216447200627394, \"rank\": 0.08630204831863471, \"text\": \"India\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12