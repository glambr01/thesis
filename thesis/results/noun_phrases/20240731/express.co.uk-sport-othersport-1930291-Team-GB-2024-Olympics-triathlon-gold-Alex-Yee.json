ities\": [], \"noun_phrases\": [{\"ngram\": \"Gold\", \"from\": 511, \"to\": 515}, {\"ngram\": \"day\", \"from\": 536, \"to\": 539}]}, {\"sentence\": \"Clickhereto buy.\", \"from\": 571, \"to\": 587, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Clickhereto buy\", \"from\": 571, \"to\": 586}]}, {\"sentence\": \"As the bell rang to signal the final 2.5km, Yee produced a remarkable finish as he overhauled his rival, eventually winning with six seconds in hand.\", \"from\": 589, \"to\": 738, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the bell\", \"from\": 592, \"to\": 600}, {\"ngram\": \"the final 2.5km\", \"from\": 616, \"to\": 631}, {\"ngram\": \"Yee\", \"from\": 633, \"to\": 636}, {\"ngram\": \"a remarkable finish\", \"from\": 646, \"to\": 665}, {\"ngram\": \"his rival\", \"from\": 683, \"to\": 692}, {\"ngram\": \"six seconds\", \"from\": 718, \"to\": 729}, {\"ngram\": \"hand\", \"from\": 733, \"to\": 737}]}, {\"sentence\": \"The victory signified a sixth gold of the2024 Paris Olympicsfor Team GB, and a second triathlon medal of the day afterBeth Potter took silver in the women's event.\", \"from\": 739, \"to\": 902, \"entities\": [{\"begin\": 785, \"end\": 790, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.6635207107842033e-13, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 803, \"end\": 810, \"title\": \"http://dbpedia.org/resource/Team_GB\", \"score\": 0.9999999880033102, \"rank\": 1.1996376742027477e-08, \"text\": \"Team GB\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Team_GB\", \"dbpedia\": \"http://dbpedia.org/resource/Team_GB\"}], \"noun_phrases\": [{\"ngram\": \"The victory\", \"from\": 739, \"to\": 750}, {\"ngram\": \"a sixth gold\", \"from\": 761, \"to\": 773}, {\"ngram\": \"a second triathlon medal\", \"from\": 816, \"to\": 840}, {\"ngram\": \"the day\", \"from\": 844, \"to\": 851}, {