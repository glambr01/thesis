es\": [], \"noun_phrases\": [{\"ngram\": \"Another set\", \"from\": 1472, \"to\": 1483}, {\"ngram\": \"talented gymnasts\", \"from\": 1487, \"to\": 1504}, {\"ngram\": \"the favourites\\u00e2\\u0080\\u0099 heels\", \"from\": 1520, \"to\": 1543}]}, {\"sentence\": \"Breakout 17-year-old Algerian star Kaylia Nemour, known for her daredevil combinations on the asymmetric bars, qualified for the all-around final in fourth with a 55.966 and reigning European all-around champion Manila Esposito of Italy, also 17, was just behind on 55.898.\", \"from\": 1546, \"to\": 1819, \"entities\": [{\"begin\": 1567, \"end\": 1575, \"title\": \"http://dbpedia.org/resource/Algeria_national_football_team\", \"score\": 0.9990031024897298, \"rank\": 0.0005929792593004183, \"text\": \"Algerian\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Algeria_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Algeria_national_football_team\"}, {\"begin\": 1758, \"end\": 1764, \"title\": \"http://dbpedia.org/resource/Manila\", \"score\": 0.9997378017034781, \"rank\": 0.00025500109307857526, \"text\": \"Manila\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Manila\", \"dbpedia\": \"http://dbpedia.org/resource/Manila\"}, {\"begin\": 1765, \"end\": 1773, \"title\": \"http://dbpedia.org/resource/Phil_Esposito\", \"score\": 0.9999920073438443, \"rank\": 7.990250304832411e-06, \"text\": \"Esposito\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q11774891\"], \"wikid\": \"http://dbpedia.org/resource/Phil_Esposito\", \"dbpedia\": \"http://dbpedia.org/resource/Phil_Esposito\"}, {\"begin\": 1777, \"end\": 1782, \"title\": \"http://dbpedia.org/resource/Italy_national_football_team\", \"score\": 0.9999927760683833, \"rank\": 6.765641950907622e-06, \"text\": \"Italy\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Italy_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Italy_national_football_team\"}], \"noun_phrases\": [{\"ngram\": \"her daredevil combinations\", \"from\": 1606, \"to\": 1632}, {\"ngram\": \"the asymmetric bars\", \"from\": 1636, \"to\": 1655}, {\"ngram\": \"a 55.966 and reigning European all-around champion\", \"from\": 1707, \"to\": 1757}]}, {\"sentence\": \"But China\\u00e2\\u0080\\u0099s Qiu Qiyuan, who qualified in seventh with a disappointing total of 54.998, could also threaten.\", \"from\": 1821, \"to\": 1930, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"China\\u00e2\\u0080\\u0099s Qiu Qiyuan\", \"from\": 1825, \"to\": 1845}, {\"ngram\": \"a disappointing total\", \"from\": 1877, \"to\": 1898}]}, {\"sentence\": \"She suffered a fall and other missteps on the balance beam, where she has world-class difficulty, earning her a score almost two points below her likely target.\", \"from\": 1931, \"to\": 2091, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a fall\", \"from\": 1944, \"to\": 1950}, {\"ngram\": \"other missteps\", \"from\": 1955, \"to\": 1969}, {\"ngram\": \"the balance beam\", \"from\": 1973, \"to\": 1989}, {\"ngram\": \"world-class difficulty\", \"from\": 2005, \"to\": 2027}, {\"ngram\": \"a score\", \"from\": 2041, \"to\": 2048}, {\"ngram\": \"her likely target\", \"from\": 2073, \"to\": 2090}]}, {\"sentence\": \"On the men's side, China and Japan will face off once again in Wednesday\\u00e2\\u0080\\u0099s all-around final after a thrilling team result, where Japan staged a late comeback to stun China.\", \"from\": 2093, \"to\": 2267, \"entities\": [{\"begin\": 2112, \"end\": 2117, \"title\": \"http://dbpedia.org/resource/China\", \"score\": 0.996368144304425, \"rank\": 0.0021016839238525696, \"text\": \"China\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/China\", \"dbpedia\": \"http://dbpedia.org/resource/China\"}, {\"begin\": 2122, \"end\": 2127, \"title\": \"http://dbpedia.org/resource/Japan_national_baseball_team\", \"score\": 0.7038288165052