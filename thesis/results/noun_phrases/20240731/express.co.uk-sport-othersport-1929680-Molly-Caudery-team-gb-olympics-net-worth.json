gram\": \"followers\", \"from\": 2153, \"to\": 2162}, {\"ngram\": \"social media\", \"from\": 2166, \"to\": 2178}, {\"ngram\": \"snippets\", \"from\": 2190, \"to\": 2198}, {\"ngram\": \"her intense training sessions\", \"from\": 2202, \"to\": 2231}, {\"ngram\": \"striking modelling and holiday photos\", \"from\": 2244, \"to\": 2281}]}, {\"sentence\": \"\\\"I do not know where it really came from,\\\" Caudery confessed about her massive social media presence earlier this year.\", \"from\": 2284, \"to\": 2403, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Caudery\", \"from\": 2327, \"to\": 2334}, {\"ngram\": \"her massive social media presence\", \"from\": 2351, \"to\": 2384}]}, {\"sentence\": \"She is currently dating high jump star and fellow Team GB member Joel Clarke-Khan, who also models for FORTE Management.\", \"from\": 2404, \"to\": 2524, \"entities\": [{\"begin\": 2454, \"end\": 2461, \"title\": \"http://dbpedia.org/resource/Team_GB\", \"score\": 0.9999999531410151, \"rank\": 4.447475336478698e-08, \"text\": \"Team GB\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Team_GB\", \"dbpedia\": \"http://dbpedia.org/resource/Team_GB\"}, {\"begin\": 2507, \"end\": 2512, \"title\": \"http://dbpedia.org/resource/Forte_(vocal_group)\", \"score\": 0.9499924490943082, \"rank\": 0.05263157894736348, \"text\": \"FORTE\", \"types\": [\"Q43229\", \"Q24229398\", \"Q215380\"], \"wikid\": \"http://dbpedia.org/resource/Forte_(vocal_group)\", \"dbpedia\": \"http://dbpedia.org/resource/Forte_(vocal_group)\"}], \"noun_phrases\": []}, {\"sentence\": \"She would not be the first athlete to transition into a global star through brand modelling, should she choose that path.\", \"from\": 2526, \"to\": 2647, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the first athlete\", \"from\": 2543, \"to\": 2560}, {\"ngram\": \"transition\", \"from\": 2564, \"to\": 2574}, {\"ngram\": \"a global star\", \"from\": 2580, \"to\": 2593}, {\"ngram\": \"brand modelling\", \"from\": 26