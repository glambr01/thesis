s\": [{\"ngram\": \"a strong start\", \"from\": 322, \"to\": 336}, {\"ngram\": \"his routine\", \"from\": 340, \"to\": 351}, {\"ngram\": \"speed\", \"from\": 371, \"to\": 376}, {\"ngram\": \"grip\", \"from\": 423, \"to\": 427}]}, {\"sentence\": \"Momentum sent Dolci into a somersault before he crashed into the safety mat, prompting audible gasps from the fans inside the Bercy Arena and the BBC commentary team.\", \"from\": 444, \"to\": 610, \"entities\": [{\"begin\": 590, \"end\": 593, \"title\": \"http://dbpedia.org/resource/BBC_Sport\", \"score\": 0.86747891341042, \"rank\": 0.1526934371052931, \"text\": \"BBC\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/BBC_Sport\", \"dbpedia\": \"http://dbpedia.org/resource/BBC_Sport\"}], \"noun_phrases\": [{\"ngram\": \"Momentum\", \"from\": 444, \"to\": 452}, {\"ngram\": \"Dolci\", \"from\": 458, \"to\": 463}, {\"ngram\": \"a somersault\", \"from\": 469, \"to\": 481}, {\"ngram\": \"the safety mat\", \"from\": 505, \"to\": 519}, {\"ngram\": \"audible gasps\", \"from\": 531, \"to\": 544}, {\"ngram\": \"the fans\", \"from\": 550, \"to\": 558}, {\"ngram\": \"the Bercy Arena\", \"from\": 566, \"to\": 581}]}, {\"sentence\": \"'Oh dear!\", \"from\": 612, \"to\": 621, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"'Oh dear\", \"from\": 612, \"to\": 620}]}, {\"sentence\": \"'BBCcommentator Matt Baker exclaimed after the scary incident.\", \"from\": 621, \"to\": 683, \"entities\": [{\"begin\": 637, \"end\": 647, \"title\": \"http://dbpedia.org/resource/Matt_Baker_(artist)\", \"score\": 0.9803545262364683, \"rank\": 0.016653655997920964, \"text\": \"Matt Baker\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Matt_Baker_(artist)\", \"dbpedia\": \"http://dbpedia.org/resource/Matt_Baker_(artist)\"}], \"noun_phrases\": [{\"ngram\": \"the scary incident\", \"from\": 664, \"to\": 682}]}, {\"sentence\": \"'His handguard has split.\", \"from\": 684, \"to\": 709, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"His handguard\", \"from\": 685, \"to\": 698}]}, {\"sentence\": \"'Well, goodness me.\", \"from\": 711, \"to\": 730, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"He was lucky there because that could have caused himself a very, very nasty injury.\", \"from\": 731, \"to\": 815, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Hopefully he's alright.\", \"from\": 816, \"to\": 839, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"What an unbelievable shock.'\", \"from\": 840, \"to\": 868, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"What an unbelievable shock\", \"from\": 840, \"to\": 866}]}, {\"sentence\": \"Dolci understandably looked shocked as he gathered his composure on the floor as members of the Canadian coaching team came over to check in on him.\", \"from\": 870, \"to\": 1018, \"entities\": [{\"begin\": 966, \"end\": 974, \"title\": \"http://dbpedia.org/resource/Canadians\", \"score\": 0.9864305893752549, \"rank\": 0.013620212225849679, \"text\": \"Canadian\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Canadians\", \"dbpedia\": \"http://dbpedia.org/resource/Canadians\"}], \"noun_phrases\": [{\"ngram\": \"Dolci\", \"from\": 870, \"to\": 875}, {\"ngram\": \"his composure\", \"from\": 921, \"to\": 934}, {\"ngram\": \"the floor\", \"from\": 938, \"to\": 947}, {\"ngram\": \"members\", \"from\": 951, \"to\": 958}]}, {\"sentence\": \"Now this is something you do not see every day \\u00f0\\u009f\\u0098\\u00aeThankfully Canadian gymnast Felix Dolci is OK.#BBCOlympics#Olympics#Paris2024pic.twitter.com/wQR07cy8mo After taking a few seconds to catch his breath, Dolci confirmed to his team that he was okay, though he sported a nasty cut on his right hand that hampered the rest of his performance.\", \"from\": 1020, \"to\": 1360, \"entities\": [{\"begin\": 1082, \"end\": 1090, \"title\": \"http://dbpedia.org/resource/Canadians\"