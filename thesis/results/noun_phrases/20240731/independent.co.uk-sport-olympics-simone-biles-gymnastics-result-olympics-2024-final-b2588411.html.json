": [], \"noun_phrases\": [{\"ngram\": \"spring\", \"from\": 755, \"to\": 761}, {\"ngram\": \"extraordinary height\", \"from\": 766, \"to\": 786}, {\"ngram\": \"the highlight\", \"from\": 788, \"to\": 801}, {\"ngram\": \"a triple twisting double-back somersault\", \"from\": 815, \"to\": 855}]}, {\"sentence\": \"The routine contained some flaws on landing but it is a measure of her otherworldly skill that her score of 14.666 was still the best all night by a distance.\", \"from\": 925, \"to\": 1083, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The routine\", \"from\": 925, \"to\": 936}, {\"ngram\": \"some flaws\", \"from\": 947, \"to\": 957}, {\"ngram\": \"landing\", \"from\": 961, \"to\": 968}, {\"ngram\": \"a measure\", \"from\": 979, \"to\": 988}, {\"ngram\": \"her otherworldly skill\", \"from\": 992, \"to\": 1014}, {\"ngram\": \"her score\", \"from\": 1020, \"to\": 1029}, {\"ngram\": \"a distance\", \"from\": 1072, \"to\": 1082}]}, {\"sentence\": \"She sealed gold with a kiss and the Bercy Arena erupted.\", \"from\": 1084, \"to\": 1140, \"entities\": [{\"begin\": 1120, \"end\": 1131, \"title\": \"http://dbpedia.org/resource/Accor_Arena\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Bercy Arena\", \"types\": [\"Q41176\"], \"wikid\": \"http://dbpedia.org/resource/Accor_Arena\", \"dbpedia\": \"http://dbpedia.org/resource/Accor_Arena\"}], \"noun_phrases\": [{\"ngram\": \"gold\", \"from\": 1095, \"to\": 1099}, {\"ngram\": \"a kiss\", \"from\": 1105, \"to\": 1111}]}, {\"sentence\": \"Eight years after winning her fourth Olympic gold medal, Biles now has her fifth.\", \"from\": 1142, \"to\": 1223, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her fourth Olympic gold medal\", \"from\": 1168, \"to\": 1197}, {\"ngram\": \"Biles\", \"from\": 1199, \"to\": 1204}, {\"ngram\": \"her fifth\", \"from\": 1213, \"to\": 1222}]}, {\"sentence\": \"It is her 38th world and Olympic medal, if anyone is still counting at this point.\", \"from\": 1224, \"to\": 1306, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her 38th world\", \"from\": 1230, \"to\": 1244}, {\"ngram\": \"Olympic medal\", \"from\": 1249, \"to\": 1262}, {\"ngram\": \"anyone\", \"from\": 1267, \"to\": 1273}, {\"ngram\": \"this point\", \"from\": 1295, \"to\": 1305}]}, {\"sentence\": \"She did it with cameras inches from her face at every turn.\", \"from\": 1307, \"to\": 1366, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"cameras inches\", \"from\": 1323, \"to\": 1337}, {\"ngram\": \"her face\", \"from\": 1343, \"to\": 1351}, {\"ngram\": \"every turn\", \"from\": 1355, \"to\": 1365}]}, {\"sentence\": \"She did it performing slightly within herself, stepping back from the edge.\", \"from\": 1367, \"to\": 1442, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the edge\", \"from\": 1433, \"to\": 1441}]}, {\"sentence\": \"And she did it as part of a phenomenally talented team.\", \"from\": 1443, \"to\": 1498, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"part\", \"from\": 1461, \"to\": 1465}, {\"ngram\": \"a phenomenally talented team\", \"from\": 1469, \"to\": 1497}]}, {\"sentence\": \"After losing to Russia in Tokyo followingBiles's dramatic withdrawal, the USA regained their women's all-around team crown.\", \"from\": 1500, \"to\": 1623, \"entities\": [{\"begin\": 1516, \"end\": 1522, \"title\": \"http://dbpedia.org/resource/Russia_men's_national_ice_hockey_team\", \"score\": 0.6755708825786609, \"rank\": 0.47528228812446716, \"text\": \"Russia\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Russia_men's_national_ice_hockey_team\", \"dbpedia\": \"http://dbpedia.org/resource/Russia_men's_national_ice_hockey_team\"}, {\"begin\": 1526, \"end\": 1531, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.9999996614120055, \"rank\": 3.323501755554059e-07, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}, {\"begin\": 1574, \"end\": 1577, 