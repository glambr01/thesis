 {\"sentence\": \"\\\"Now that we know we will race, we can mentally switch fully into competition mode.\\\"\", \"from\": 1115, \"to\": 1199, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"competition mode\", \"from\": 1181, \"to\": 1197}]}, {\"sentence\": \"Fifty-five women representing 34 countries will kick off the contest at 8 am, with France's Cassandre Beaugrand and Britain's Beth Potter, two of the top contenders for gold, set to dive into the river side by side.\", \"from\": 1201, \"to\": 1416, \"entities\": [{\"begin\": 1284, \"end\": 1290, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9986312538527506, \"rank\": 0.0008122543835361503, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 1317, \"end\": 1324, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9965517695682747, \"rank\": 0.003320501216174222, \"text\": \"Britain\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}, {\"begin\": 1327, \"end\": 1338, \"title\": \"http://dbpedia.org/resource/Beth_Potter\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Beth Potter\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Beth_Potter\", \"dbpedia\": \"http://dbpedia.org/resource/Beth_Potter\"}], \"noun_phrases\": [{\"ngram\": \"Fifty-five women\", \"from\": 1201, \"to\": 1217}, {\"ngram\": \"34 countries\", \"from\": 1231, \"to\": 1243}, {\"ngram\": \"the contest\", \"from\": 1258, \"to\": 1269}, {\"ngram\": \"8 am\", \"from\": 1273, \"to\": 1277}, {\"ngram\": \"the top contenders\", \"from\": 1347, \"to\": 1365}, {\"ngram\": \"gold\", \"from\": 1370, \"to\": 1374}, {\"ngram\": \"the river side\", \"from\": 1393, \"to\": 1407}, {\"ngram\": \"side\", \"from\": 1411, \"to\": 1415}]}, {\"sentence\": \"The men's event will take place at 10:45 am, immediately after the women's race.\", \"from\": 1418, \"to\": 1498, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The men's event\", \"from\": 1418, \"to\": 1433}, {\"ngram\": \"place\", \"from\": 1444, \"to\": 1449}, {\"ngram\": \"10:45 am\", \"from\": 1453, \"to\": 1461}, {\"ngram\": \"the women's race\", \"from\": 1481, \"to\": 1497}]}, {\"sentence\": \"\\\"The results of the latest water analyses, received at 3:20 am, have been assessed as compliant by World Triathlon allowing for the triathlon competitions to take place,\\\" Paris 2024 and World Triathlon said in a statement.\", \"from\": 1500, \"to\": 1722, \"entities\": [{\"begin\": 1599, \"end\": 1614, \"title\": \"http://dbpedia.org/resource/World_Triathlon\", \"score\": 1.0, \"rank\": 1.4115938418569243e-14, \"text\": \"World Triathlon\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/World_Triathlon\", \"dbpedia\": \"http://dbpedia.org/resource/World_Triathlon\"}, {\"begin\": 1686, \"end\": 1701, \"title\": \"http://dbpedia.org/resource/World_Triathlon\", \"score\": 1.0, \"rank\": 1.4115938418569243e-14, \"text\": \"World Triathlon\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/World_Triathlon\", \"dbpedia\": \"http://dbpedia.org/resource/World_Triathlon\"}], \"noun_phrases\": [{\"ngram\": \"The results\", \"from\": 1501, \"to\": 1512}, {\"ngram\": \"the latest water analyses\", \"from\": 1516, \"to\": 1541}, {\"ngram\": \"3:20 am\", \"from\": 1555, \"to\": 1562}, {\"ngram\": \"the triathlon competitions\", \"from\": 1628, \"to\": 1654}, {\"ngram\": \"place\", \"from\": 1663, \"to\": 1668}, {\"ngram\": \"a statement\", \"from\": 1710, \"to\": 1721}]}, {\"sentence\": \"Paris has spent 1.4 billion euros ($1.52 billion) of public money on wastewater infrastructure to contain sewage and minimize spillage into the river, and Mayor Anne Hidalgo took a dip earlier this month in a bid to convince doubters that the water will not make them ill.\", \"from\": 1724