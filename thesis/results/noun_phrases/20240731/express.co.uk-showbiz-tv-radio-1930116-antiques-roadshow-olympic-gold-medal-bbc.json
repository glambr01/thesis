\": 342, \"to\": 354}]}, {\"sentence\": \"Schoon began.\", \"from\": 368, \"to\": 381, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Schoon\", \"from\": 368, \"to\": 374}]}, {\"sentence\": \"\\\"That's my grandmother Lucy Morton, swimming, she started swimming when she was about aged 10,\\\" Julia explained.\", \"from\": 383, \"to\": 495, \"entities\": [{\"begin\": 406, \"end\": 417, \"title\": \"http://dbpedia.org/resource/Lucy_Morton\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Lucy Morton\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Lucy_Morton\", \"dbpedia\": \"http://dbpedia.org/resource/Lucy_Morton\"}, {\"begin\": 479, \"end\": 484, \"title\": \"http://dbpedia.org/resource/Julia_the_Elder\", \"score\": 0.9999996932640913, \"rank\": 3.0673507048887885e-07, \"text\": \"Julia\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Julia_the_Elder\", \"dbpedia\": \"http://dbpedia.org/resource/Julia_the_Elder\"}], \"noun_phrases\": [{\"ngram\": \"my grandmother\", \"from\": 391, \"to\": 405}]}, {\"sentence\": \"\\\"What happened was her dad said 'you are too much of a dunce at school, you do not seem to be doing very well' and he decided 'let us try swimming.'\\\"\", \"from\": 497, \"to\": 646, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her dad\", \"from\": 516, \"to\": 523}, {\"ngram\": \"a dunce\", \"from\": 550, \"to\": 557}, {\"ngram\": \"school\", \"from\": 561, \"to\": 567}, {\"ngram\": \"us\", \"from\": 628, \"to\": 630}]}, {\"sentence\": \"When Schoon questioned if she had inherited the \\\"swimming DNA\\\", Julia joked that she could \\\"swim a length\\\", so enough \\\"to save my life\\\".\", \"from\": 648, \"to\": 784, \"entities\": [{\"begin\": 712, \"end\": 717, \"title\": \"http://dbpedia.org/resource/Julia_the_Elder\", \"score\": 0.9999996932640913, \"rank\": 3.0673507048887885e-07, \"text\": \"Julia\", \"types\": [\"Q729\",