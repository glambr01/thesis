oun_phrases\": [{\"ngram\": \"Hill\", \"from\": 8461, \"to\": 8465}, {\"ngram\": \"course\", \"from\": 8470, \"to\": 8476}]}, {\"sentence\": \"After Hill's first conversation with Embiid that winter, he told confidants that he wasn't sure Embiid would play for France after all.\", \"from\": 8519, \"to\": 8654, \"entities\": [{\"begin\": 8637, \"end\": 8643, \"title\": \"http://dbpedia.org/resource/France_national_football_team\", \"score\": 0.9999720861363756, \"rank\": 1.573880661364224e-05, \"text\": \"France\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/France_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/France_national_football_team\"}], \"noun_phrases\": [{\"ngram\": \"Hill's first conversation\", \"from\": 8525, \"to\": 8550}, {\"ngram\": \"Embiid\", \"from\": 8556, \"to\": 8562}, {\"ngram\": \"confidants\", \"from\": 8584, \"to\": 8594}, {\"ngram\": \"Embiid\", \"from\": 8615, \"to\": 8621}]}, {\"sentence\": \"Hill had confidence that Embiid might even choose to play for Team USA at the Olympics.\", \"from\": 8655, \"to\": 8742, \"entities\": [{\"begin\": 8717, \"end\": 8725, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 1.0, \"rank\": 5.798664949337575e-19, \"text\": \"Team USA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\"}], \"noun_phrases\": [{\"ngram\": \"Hill\", \"from\": 8655, \"to\": 8659}, {\"ngram\": \"confidence\", \"from\": 8664, \"to\": 8674}, {\"ngram\": \"Embiid\", \"from\": 8680, \"to\": 8686}, {\"ngram\": \"the Olympics\", \"from\": 8729, \"to\": 8741}]}, {\"sentence\": \"Advertisement One thing Hill was sure of: Embiid wasn't going to play for France or the U.S. at the 2023 FIBA World Cup in southeast Asia; he was getting married.\", \"from\": 8744, \"to\": 8907, \"en