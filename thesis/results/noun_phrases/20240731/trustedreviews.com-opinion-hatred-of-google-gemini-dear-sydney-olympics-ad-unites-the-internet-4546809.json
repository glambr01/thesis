"begin\": 387, \"end\": 389, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9999994385863585, \"rank\": 5.521818602528005e-07, \"text\": \"UK\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}], \"noun_phrases\": [{\"ngram\": \"no ads\", \"from\": 432, \"to\": 438}, {\"ngram\": \"the Beeb's Olympic coverage\", \"from\": 442, \"to\": 469}]}, {\"sentence\": \"It's liable to make you quite angry, as it does I everytime NBC takes a break from its Games coverage.\", \"from\": 501, \"to\": 603, \"entities\": [{\"begin\": 561, \"end\": 564, \"title\": \"http://dbpedia.org/resource/NBC\", \"score\": 0.9999999999986358, \"rank\": 1.2194536269426053e-12, \"text\": \"NBC\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/NBC\", \"dbpedia\": \"http://dbpedia.org/resource/NBC\"}], \"noun_phrases\": [{\"ngram\": \"a break\", \"from\": 571, \"to\": 578}, {\"ngram\": \"its Games coverage\", \"from\": 584, \"to\": 602}]}, {\"sentence\": \"The ad showcases a father asking Gemini for help to write a letter on behalf of his daughter - a seemingly talented young runner - to her hero, the American 400m hurdler Sydney McLaughlin-Levrone.\", \"from\": 607, \"to\": 803, \"entities\": [{\"begin\": 640, \"end\": 646, \"title\": \"http://dbpedia.org/resource/Gemini_Awards\", \"score\": 0.9992979979709067, \"rank\": 0.0007024951821673669, \"text\": \"Gemini\", \"types\": [\"Q618779\"], \"wikid\": \"http://dbpedia.org/resource/Gemini_Awards\", \"dbpedia\": \"http://dbpedia.org/resource/Gemini_Awards\"}], \"noun_phrases\": [{\"ngram\": \"The ad\", \"from\": 607, \"to\": 613}, {\"ngram\": \"a father\", \"from\": 624, \"to\": 632}, {\"ngram\": \"help\", \"from\": 651, \"to\": 655}, {\"ngram\": \"a letter\", \"from\": 665, \"to\": 673}, {\"ngram\": \"behalf\", \"from\": 677, \"to\": 683}, {\"ngram\": \"his daughter\", \"from\": 687, 