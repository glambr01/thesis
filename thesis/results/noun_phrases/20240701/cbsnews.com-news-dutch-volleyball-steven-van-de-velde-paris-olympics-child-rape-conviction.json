}, {\"ngram\": \"international media\", \"from\": 705, \"to\": 724}, {\"ngram\": \"Van de Velde\", \"from\": 727, \"to\": 739}, {\"ngram\": \"a statement\", \"from\": 748, \"to\": 759}, {\"ngram\": \"the website\", \"from\": 770, \"to\": 781}]}, {\"sentence\": \"\\\"I cannot reverse it, so I will have to bear the consequences.\", \"from\": 824, \"to\": 886, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the consequences\", \"from\": 869, \"to\": 885}]}, {\"sentence\": \"It has been the biggest mistake of my life.\\\"\", \"from\": 887, \"to\": 931, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the biggest mistake\", \"from\": 899, \"to\": 918}, {\"ngram\": \"my life\", \"from\": 922, \"to\": 929}]}, {\"sentence\": \"Van de Velde was sentenced to four years in prison in Britain after being convicted in 2016 of raping a 12-year-old girl he got to know on Facebook, according to CBS News' partner network BBC News.\", \"from\": 933, \"to\": 1130, \"entities\": [{\"begin\": 987, \"end\": 994, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.9999947394835212, \"rank\": 4.735658069185973e-06, \"text\": \"Britain\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}, {\"begin\": 1095, \"end\": 1103, \"title\": \"http://dbpedia.org/resource/CBS_News\", \"score\": 0.9999990888665765, \"rank\": 8.990586640049198e-07, \"text\": \"CBS News\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/CBS_News\", \"dbpedia\": \"http://dbpedia.org/resource/CBS_News\"}, {\"begin\": 1121, \"end\": 1129, \"title\": \"http://dbpedia.org/resource/BBC_News\", \"score\": 0.999970746589924, \"rank\": 2.8218248252732017e-05, \"text\": \"BBC News\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/BBC_News\", \"dbpedia\": \"http://dbpedia.org/resource/BBC_News\"}], \"noun_phrases\": [{\"ngram\": \"Van de Velde\", \"from\": 933,