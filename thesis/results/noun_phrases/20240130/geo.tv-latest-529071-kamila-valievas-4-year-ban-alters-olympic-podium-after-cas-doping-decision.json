"{\"uid\": \"geo.tv-latest-529071-kamila-valievas-4-year-ban-alters-olympic-podium-after-cas-doping-decision\", \"noun_phrases\": [{\"sentence\": \"January 30, 2024 Russian figure skater Kamila Valieva faces a four-year ban from competition after the Court of Arbitration for Sport (CAS) upheld an appeal by the World Anti-Doping Agency (WADA).\", \"from\": 0, \"to\": 197, \"entities\": [{\"begin\": 18, \"end\": 25, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999216272378235, \"rank\": 7.801283378298895e-05, \"text\": \"Russian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}, {\"begin\": 40, \"end\": 46, \"title\": \"http://dbpedia.org/resource/Kamila_Thompson\", \"score\": 0.9999999999636202, \"rank\": 0.0, \"text\": \"Kamila\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kamila_Thompson\", \"dbpedia\": \"http://dbpedia.org/resource/Kamila_Thompson\"}, {\"begin\": 165, \"end\": 196, \"title\": \"http://dbpedia.org/resource/World_Anti-Doping_Agency\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"World Anti-Doping Agency (WADA)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Anti-Doping_Agency\", \"dbpedia\": \"http://dbpedia.org/resource/World_Anti-Doping_Agency\"}, {\"begin\": 165, \"end\": 196, \"title\": \"http://dbpedia.org/resource/World_Anti-Doping_Agency\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"World Anti-Doping Agency (WADA)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Anti-Doping_Agency\", \"dbpedia\": \"http://dbpedia.org/resource/World_Anti-Doping_Agency\"}], \"noun_phrases\": [{\"ngram\": \"a four-year ban\", \"from\": 60, \"to\": 75}, {\"ngram\": \"competition\", \"from\": 81, \"to\": 92}, {\"ngram\": \"the Court\", \"from\": 99, \"to\": 108}, {\"ngram\": \"Arbitration\", \"from\": 112, \"to\": 123}, {\"ngram\": \"Sport\", \"from\": 128, \"to\": 133}, {\"ngram\": \"CAS\", \"from\": 135, \"to\": 138}, {\"ngram\": \"an appeal\", \"from\": 147, \"to\": 156}]}, {\"sentence\": \"The decision comes after a Russian Anti-Doping Agency (RUSADA) investigation initially cleared the 17-year-old skater of any wrongdoing related to a doping test before the 2022 Winter Olympics.\", \"from\": 199, \"to\": 392, \"entities\": [{\"begin\": 254, \"end\": 260, \"title\": \"http://dbpedia.org/resource/Russian_Anti-Doping_Agency\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"RUSADA\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Russian_Anti-Doping_Agency\", \"dbpedia\": \"http://dbpedia.org/resource/Russian_Anti-Doping_Agency\"}], \"noun_phrases\": [{\"ngram\": \"The decision\", \"from\": 199, \"to\": 211}, {\"ngram\": \"the 17-year-old skater\", \"from\": 294, \"to\": 316}, {\"ngram\": \"any wrongdoing\", \"from\": 320, \"to\": 334}, {\"ngram\": \"a doping test\", \"from\": 346, \"to\": 359}, {\"ngram\": \"the 2022 Winter Olympics\", \"from\": 367, \"to\": 391}]}, {\"sentence\": \"The CAS ruling dictates that all competitive results of Valieva from December 25, 2021, onwards are disqualified, including her historic performance in Beijing where she became the first female skater to land a quadruple jump in Olympic competition.\", \"from\": 394, \"to\": 643, \"entities\": [{\"begin\": 398, \"end\": 401, \"title\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"score\": 1.0, \"rank\": 1.0918438551370641e-54, \"text\": \"CAS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"dbpedia\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\"}, {\"begin\": 546, \"end\": 553, \"title\": \"http://dbpedia.org/resource/Beijing\", \"score\": 0.9961796766128824, \"rank\": 0.0037500994516125284, \"text\": \"Beijing\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Beijing\", \"dbpedia\": \"http://dbpedia.org/resource/Beijing\"}], \"noun_phrases\": [{\"ngram\": \"all competitive results\", \"from\": 423, \"to\": 446}, {\"ngram\": \"Valieva\", \"from\": 450, \"to\": 457}, {\"ngram\": \"December\", \"from\": 463, \"to\": 471}, {\"ngram\": \"her historic performance\", \"from\": 518, \"to\": 542}, {\"ngram\": \"the first female skater\", \"from\": 571, \"to\": 594}, {\"ngram\": \"a quadruple jump\", \"from\": 603, \"to\": 619}, {\"ngram\": \"Olympic competition\", \"from\": 623, \"to\": 642}]}, {\"sentence\": \"The reshuffling of the podium now positions the United States to claim gold, Japan to secure silver, and Canada to take home bronze.\", \"from\": 645, \"to\": 777, \"entities\": [{\"begin\": 693, \"end\": 706, \"title\": \"http://dbpedia.org/resource/Federal_government_of_the_United_States\", \"score\": 0.6397807632328905, \"rank\": 0.5630334010199689, \"text\": \"United States\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Federal_government_of_the_United_States\", \"dbpedia\": \"http://dbpedia.org/resource/Federal_government_of_the_United_States\"}, {\"begin\": 722, \"end\": 727, \"title\": \"http://dbpedia.org/resource/Japan\", \"score\": 0.9997529911267855, \"rank\": 0.00023193740914811536, \"text\": \"Japan\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Japan\", \"dbpedia\": \"http://dbpedia.org/resource/Japan\"}, {\"begin\": 750, \"end\": 756, \"title\": \"http://dbpedia.org/resource/Canada\", \"score\": 0.9988270831576207, \"rank\": 0.0011005295236229367, \"text\": \"Canada\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Canada\", \"dbpedia\": \"http://dbpedia.org/resource/Canada\"}], \"noun_phrases\": [{\"ngram\": \"The reshuffling\", \"from\": 645, \"to\": 660}, {\"ngram\": \"the podium\", \"from\": 664, \"to\": 674}, {\"ngram\": \"gold\", \"from\": 716, \"to\": 720}, {\"ngram\": \"silver\", \"from\": 738, \"to\": 744}, {\"ngram\": \"home bronze\", \"from\": 765, \"to\": 776}]}, {\"sentence\": \"The controversy surrounding Valieva's positive test for trimetazidine, a drug used to treat angina but banned for athletes, raises questions about her treatment as a minor, the testing procedures, and the substance's impact on performance enhancement.\", \"from\": 779, \"to\": 1030, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The controversy\", \"from\": 779, \"to\": 794}, {\"ngram\": \"Valieva's positive test\", \"from\": 807, \"to\": 830}, {\"ngram\": \"trimetazidine\", \"from\": 835, \"to\": 848}, {\"ngram\": \"a drug\", \"from\": 850, \"to\": 856}, {\"ngram\": \"angina\", \"from\": 871, \"to\": 877}, {\"ngram\": \"athletes\", \"from\": 893, \"to\": 901}, {\"ngram\": \"questions\", \"from\": 910, \"to\": 919}, {\"ngram\": \"her treatment\", \"from\": 926, \"to\": 939}, {\"ngram\": \"a minor\", \"from\": 943, \"to\": 950}, {\"ngram\": \"the testing procedures\", \"from\": 952, \"to\": 974}, {\"ngram\": \"the substance's impact\", \"from\": 980, \"to\": 1002}, {\"ngram\": \"performance enhancement\", \"from\": 1006, \"to\": 1029}]}, {\"sentence\": \"Valieva attributed the presence of the drug to \\\"contamination by cutlery\\\" shared with her grandfather, who used trimetazidine after receiving an artificial heart.\", \"from\": 1031, \"to\": 1193, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Valieva\", \"from\": 1031, \"to\": 1038}, {\"ngram\": \"the presence\", \"from\": 1050, \"to\": 1062}, {\"ngram\": \"the drug\", \"from\": 1066, \"to\": 1074}, {\"ngram\": \"\\\"contamination\", \"from\": 1078, \"to\": 1092}, {\"ngram\": \"cutlery\", \"from\": 1096, \"to\": 1103}, {\"ngram\": \"her grandfather\", \"from\": 1117, \"to\": 1132}, {\"ngram\": \"trimetazidine\", \"from\": 1143, \"to\": 1156}, {\"ngram\": \"an artificial heart\", \"from\": 1173, \"to\": 1192}]}, {\"sentence\": \"WADA seized the moment to stressed the gravity of doping in young athletes, stating, \\\"The doping of children is unforgivable,\\\" and urged governments to consider legislation making the doping of minors a criminal offense.\", \"from\": 1195, \"to\": 1415, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"WADA\", \"from\": 1195, \"to\": 1199}, {\"ngram\": \"the moment\", \"from\": 1207, \"to\": 1217}, {\"ngram\": \"the gravity\", \"from\": 1230, \"to\": 1241}, {\"ngram\": \"doping\", \"from\": 1245, \"to\": 1251}, {\"ngram\": \"young athletes\", \"from\": 1255, \"to\": 1269}, {\"ngram\": \"The doping\", \"from\": 1281, \"to\": 1291}, {\"ngram\": \"children\", \"from\": 1295, \"to\": 1303}, {\"ngram\": \"governments\", \"from\": 1332, \"to\": 1343}, {\"ngram\": \"legislation\", \"from\": 1356, \"to\": 1367}, {\"ngram\": \"the doping\", \"from\": 1375, \"to\": 1385}, {\"ngram\": \"minors\", \"from\": 1389, \"to\": 1395}, {\"ngram\": \"a criminal offense\", \"from\": 1396, \"to\": 1414}]}, {\"sentence\": \"While the United States welcomed the CAS decision as a victory for clean athletes, the Kremlin labeled it a \\\"politicised\\\" move, highlighting that it reflects a broader attack on Russian sports.\", \"from\": 1417, \"to\": 1610, \"entities\": [{\"begin\": 1427, \"end\": 1440, \"title\": \"http://dbpedia.org/resource/Federal_government_of_the_United_States\", \"score\": 0.6397807632328905, \"rank\": 0.5630334010199689, \"text\": \"United States\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Federal_government_of_the_United_States\", \"dbpedia\": \"http://dbpedia.org/resource/Federal_government_of_the_United_States\"}, {\"begin\": 1454, \"end\": 1457, \"title\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"score\": 1.0, \"rank\": 1.0918438551370641e-54, \"text\": \"CAS\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\", \"dbpedia\": \"http://dbpedia.org/resource/Court_of_Arbitration_for_Sport\"}, {\"begin\": 1504, \"end\": 1511, \"title\": \"http://dbpedia.org/resource/Government_of_Russia\", \"score\": 0.9999277627590658, \"rank\": 7.224238652235819e-05, \"text\": \"Kremlin\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Government_of_Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Government_of_Russia\"}, {\"begin\": 1595, \"end\": 1602, \"title\": \"http://dbpedia.org/resource/Russia\", \"score\": 0.9999216272378235, \"rank\": 7.801283378298895e-05, \"text\": \"Russian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Russia\", \"dbpedia\": \"http://dbpedia.org/resource/Russia\"}], \"noun_phrases\": [{\"ngram\": \"a victory\", \"from\": 1470, \"to\": 1479}, {\"ngram\": \"clean athletes\", \"from\": 1484, \"to\": 1498}, {\"ngram\": \"a \\\"politicised\\\" move\", \"from\": 1523, \"to\": 1543}, {\"ngram\": \"a broader attack\", \"from\": 1575, \"to\": 1591}]}, {\"sentence\": \"The saga has taken an emotional toll on Valieva, who, under suspicion and attention, stumbled in the individual event in Beijing, dropping from first to fourth and finishing in tears.\", \"from\": 1612, \"to\": 1795, \"entities\": [{\"begin\": 1733, \"end\": 1740, \"title\": \"http://dbpedia.org/resource/Beijing\", \"score\": 0.9961796766128824, \"rank\": 0.0037500994516125284, \"text\": \"Beijing\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Beijing\", \"dbpedia\": \"http://dbpedia.org/resource/Beijing\"}], \"noun_phrases\": [{\"ngram\": \"The saga\", \"from\": 1612, \"to\": 1620}, {\"ngram\": \"an emotional toll\", \"from\": 1631, \"to\": 1648}, {\"ngram\": \"Valieva\", \"from\": 1652, \"to\": 1659}, {\"ngram\": \"suspicion\", \"from\": 1672, \"to\": 1681}, {\"ngram\": \"attention\", \"from\": 1686, \"to\": 1695}, {\"ngram\": \"the individual event\", \"from\": 1709, \"to\": 1729}, {\"ngram\": \"fourth\", \"from\": 1765, \"to\": 1771}, {\"ngram\": \"tears\", \"from\": 1789, \"to\": 1794}]}, {\"sentence\": \"The United States Anti-Doping Agency criticised the lengthy resolution process, stating that true justice had been \\\"denied\\\" by the two-year delay.\", \"from\": 1796, \"to\": 1942, \"entities\": [{\"begin\": 1800, \"end\": 1832, \"title\": \"http://dbpedia.org/resource/United_States_Anti-Doping_Agency\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"United States Anti-Doping Agency\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_States_Anti-Doping_Agency\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_Anti-Doping_Agency\"}, {\"begin\": 1800, \"end\": 1832, \"title\": \"http://dbpedia.org/resource/United_States_Anti-Doping_Agency\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"United States Anti-Doping Agency\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_States_Anti-Doping_Agency\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_Anti-Doping_Agency\"}], \"noun_phrases\": [{\"ngram\": \"the lengthy resolution process\", \"from\": 1844, \"to\": 1874}, {\"ngram\": \"true justice\", \"from\": 1889, \"to\": 1901}, {\"ngram\": \"the two-year delay\", \"from\": 1923, \"to\": 1941}]}, {\"sentence\": \"The doping scandal has prompted the International Skating Union (ISU) to raise the age limit for its senior category, citing concerns for the \\\"physical, mental, and emotional health\\\" of competitors.\", \"from\": 1944, \"to\": 2142, \"entities\": [{\"begin\": 2002, \"end\": 2007, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999999897509042, \"rank\": 5.451214842738235e-09, \"text\": \"Union\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 2009, \"end\": 2012, \"title\": \"http://dbpedia.org/resource/International_Skating_Union\", \"score\": 1.0, \"rank\": 2.7749384724425714e-43, \"text\": \"ISU\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/International_Skating_Union\", \"dbpedia\": \"http://dbpedia.org/resource/International_Skating_Union\"}], \"noun_phra