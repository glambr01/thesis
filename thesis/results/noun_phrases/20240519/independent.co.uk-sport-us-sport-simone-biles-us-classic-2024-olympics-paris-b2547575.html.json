es\": [{\"ngram\": \"the first meet\", \"from\": 1165, \"to\": 1179}]}, {\"sentence\": \"She did a handful of her signature skills, including hitting the Yurchenko double pike on vault and a tumbling pass that ends with a triple-twisting double-flip.\", \"from\": 1192, \"to\": 1353, \"entities\": [{\"begin\": 1257, \"end\": 1266, \"title\": \"http://dbpedia.org/resource/Yurchenko_(vault)\", \"score\": 0.9924615128803714, \"rank\": 0.0, \"text\": \"Yurchenko\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Yurchenko_(vault)\", \"dbpedia\": \"http://dbpedia.org/resource/Yurchenko_(vault)\"}], \"noun_phrases\": [{\"ngram\": \"a handful\", \"from\": 1200, \"to\": 1209}, {\"ngram\": \"her signature skills\", \"from\": 1213, \"to\": 1233}, {\"ngram\": \"vault\", \"from\": 1282, \"to\": 1287}, {\"ngram\": \"a tumbling pass\", \"from\": 1292, \"to\": 1307}, {\"ngram\": \"a triple-twisting double-flip\", \"from\": 1323, \"to\": 1352}]}, {\"sentence\": \"Biles completed the vault - which requires her to clasp her hands to her knees while she flips backward twice - with coach Laurent Landi watching from the side.\", \"from\": 1355, \"to\": 1515, \"entities\": [{\"begin\": 1478, \"end\": 1491, \"title\": \"http://dbpedia.org/resource/Laurent_Landi\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Laurent Landi\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Laurent_Landi\", \"dbpedia\": \"http://dbpedia.org/resource/Laurent_Landi\"}], \"noun_phrases\": [{\"ngram\": \"Biles\", \"from\": 1355, \"to\": 1360}, {\"ngram\": \"the vault\", \"from\": 1371, \"to\": 1380}, {\"ngram\": \"her hands\", \"from\": 1411, \"to\": 1420}, {\"ngram\": \"her knees\", \"from\": 1424, \"to\": 1433}, {\"ngram\": \"the side\", \"from\": 1506, \"to\": 1514}]}, {\"sentence\": \"Mr Landi had been standing on the podium to spot Biles during previous attempts, a decision that cost her a half-point neutral deduction.\", \"from\": 1516, \"to\": 1653, \