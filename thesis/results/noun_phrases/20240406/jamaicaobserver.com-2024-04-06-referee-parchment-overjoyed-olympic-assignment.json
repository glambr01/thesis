"{\"uid\": \"jamaicaobserver.com-2024-04-06-referee-parchment-overjoyed-olympic-assignment\", \"noun_phrases\": [{\"sentence\": \"JamaicanFifa match official Daneon Parchment has described his historic appointment to officiate at the Paris Olympic Games football tournament as \\\"overwhelming\\\", adding he was \\\"at a loss for words\\\" when he got the news.\", \"from\": 0, \"to\": 220, \"entities\": [{\"begin\": 35, \"end\": 44, \"title\": \"http://dbpedia.org/resource/Parchment\", \"score\": 1.0, \"rank\": 3.7816072576445155e-19, \"text\": \"Parchment\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Parchment\", \"dbpedia\": \"http://dbpedia.org/resource/Parchment\"}], \"noun_phrases\": [{\"ngram\": \"his historic appointment\", \"from\": 59, \"to\": 83}, {\"ngram\": \"the Paris Olympic Games football tournament\", \"from\": 100, \"to\": 143}, {\"ngram\": \"a loss\", \"from\": 181, \"to\": 187}, {\"ngram\": \"words\", \"from\": 192, \"to\": 197}, {\"ngram\": \"the news\", \"from\": 211, \"to\": 219}]}, {\"sentence\": \"Parchment and Odette Hamilton were named in an 89-member list of 21 referees, 42 assistant referees, 20 video match officials, and six support referees from 45 countries to officiate at the 2024 Games football tournaments by the FIFA Referees Committee.\", \"from\": 222, \"to\": 475, \"entities\": [{\"begin\": 236, \"end\": 242, \"title\": \"http://dbpedia.org/resource/2021_Atlantic_hurricane_season\", \"score\": 0.9999999596291226, \"rank\": 4.037092535466404e-08, \"text\": \"Odette\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/2021_Atlantic_hurricane_season\", \"dbpedia\": \"http://dbpedia.org/resource/2021_Atlantic_hurricane_season\"}, {\"begin\": 243, \"end\": 251, \"title\": \"http://dbpedia.org/resource/Hamilton_Academical_F.C.\", \"score\": 1.0, \"rank\": 1.9833641149831154e-16, \"text\": \"Hamilton\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Hamilton_Academical_F.C.\", \"dbpedia\": \"http://dbpedia.org/resource/Hamilton_Academical_F.C.\"}], \"noun_phrases\": [{\"ngram\": \"Parchment\", \"from\": 222, \"to\": 231}, {\"ngram\": \"an 89-member list\", \"from\": 266, \"to\": 283}, {\"ngram\": \"21 referees\", \"from\": 287, \"to\": 298}, {\"ngram\": \"42 assistant referees\", \"from\": 300, \"to\": 321}, {\"ngram\": \"20 video match officials\", \"from\": 323, \"to\": 347}, {\"ngram\": \"six support referees\", \"from\": 353, \"to\": 373}, {\"ngram\": \"45 countries\", \"from\": 379, \"to\": 391}, {\"ngram\": \"the 2024 Games football tournaments\", \"from\": 408, \"to\": 443}, {\"ngram\": \"the FIFA Referees Committee\", \"from\": 447, \"to\": 474}]}, {\"sentence\": \"Hamilton is the second Jamaican woman to get the nod, following Stacy-Ann Greyson's groundbreaking appointment at the London Games in 2012 when she became the first Jamaican and Caribbean woman to officiate at an Olympics.\", \"from\": 477, \"to\": 699, \"entities\": [{\"begin\": 477, \"end\": 485, \"title\": \"http://dbpedia.org/resource/Hamilton_Academical_F.C.\", \"score\": 1.0, \"rank\": 1.9833641149831154e-16, \"text\": \"Hamilton\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Hamilton_Academical_F.C.\", \"dbpedia\": \"http://dbpedia.org/resource/Hamilton_Academical_F.C.\"}, {\"begin\": 500, \"end\": 508, \"title\": \"http://dbpedia.org/resource/Jamaica_national_football_team\", \"score\": 0.9999991613461923, \"rank\": 7.404833946270786e-07, \"text\": \"Jamaican\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica_national_football_team\"}, {\"begin\": 642, \"end\": 650, \"title\": \"http://dbpedia.org/resource/Jamaica_national_football_team\", \"score\": 0.9999991613461923, \"rank\": 7.404833946270786e-07, \"text\": \"Jamaican\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica_national_football_team\"}], \"noun_phrases\": [{\"ngram\": \"the nod\", \"from\": 522, \"to\": 529}, {\"ngram\": \"Stacy-Ann Greyson's groundbreaking appointment\", \"from\": 541, \"to\": 587}, {\"ngram\": \"the London Games\", \"from\": 591, \"to\": 607}, {\"ngram\": \"an Olympics\", \"from\": 687, \"to\": 698}]}, {\"sentence\": \"Parchment, who has risen to become one of the top video assistant referees (VAR) in the Concacaf region, said it has been a dream of his.\", \"from\": 701, \"to\": 838, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Parchment\", \"from\": 701, \"to\": 710}, {\"ngram\": \"the top video assistant referees\", \"from\": 743, \"to\": 775}, {\"ngram\": \"VAR\", \"from\": 777, \"to\": 780}, {\"ngram\": \"the Concacaf region\", \"from\": 785, \"to\": 804}, {\"ngram\": \"a dream\", \"from\": 823, \"to\": 830}]}, {\"sentence\": \"\\\"To be selected as one of the video match officials for the Paris Olympic Games [brings] overwhelming feelings.\", \"from\": 840, \"to\": 951, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the video match officials\", \"from\": 866, \"to\": 891}, {\"ngram\": \"the Paris Olympic Games\", \"from\": 896, \"to\": 919}, {\"ngram\": \"overwhelming feelings\", \"from\": 929, \"to\": 950}]}, {\"sentence\": \"I was at a loss for words when I received the appointment to be honest, I was surprised,\\\" Parchment, the head of the Physical Education (PE) Department at Cedric Titus High School in Clarks Town, Trelawny, told theJamaica Observer.\", \"from\": 952, \"to\": 1183, \"entities\": [{\"begin\": 1069, \"end\": 1087, \"title\": \"http://dbpedia.org/resource/Physical_education\", \"score\": 0.9929981318013767, \"rank\": 0.0070512400521263695, \"text\": \"Physical Education\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Physical_education\", \"dbpedia\": \"http://dbpedia.org/resource/Physical_education\"}, {\"begin\": 1114, \"end\": 1119, \"title\": \"http://dbpedia.org/resource/Titus\", \"score\": 0.9987706772471319, \"rank\": 0.0010657077762485482, \"text\": \"Titus\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Titus\", \"dbpedia\": \"http://dbpedia.org/resource/Titus\"}, {\"begin\": 1148, \"end\": 1156, \"title\": \"http://dbpedia.org/resource/Trelawny_Parish\", \"score\": 0.999999922272312, \"rank\": 4.173579744797326e-08, \"text\": \"Trelawny\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Trelawny_Parish\", \"dbpedia\": \"http://dbpedia.org/resource/Trelawny_Parish\"}], \"noun_phrases\": [{\"ngram\": \"a loss\", \"from\": 961, \"to\": 967}, {\"ngram\": \"words\", \"from\": 972, \"to\": 977}, {\"ngram\": \"the appointment\", \"from\": 994, \"to\": 1009}, {\"ngram\": \"\\\" Parchment\", \"from\": 1040, \"to\": 1051}, {\"ngram\": \"the head\", \"from\": 1053, \"to\": 1061}, {\"ngram\": \"Clarks Town\", \"from\": 1135, \"to\": 1146}, {\"ngram\": \"theJamaica Observer\", \"from\": 1163, \"to\": 1182}]}, {\"sentence\": \"\\\"This is a true testament to my hard work that I would have done locally and internationally as I continue to push myself to excel to one of the biggest tournaments in the world.\", \"from\": 1185, \"to\": 1363, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a true testament\", \"from\": 1194, \"to\": 1210}, {\"ngram\": \"my hard work\", \"from\": 1214, \"to\": 1226}, {\"ngram\": \"the biggest tournaments\", \"from\": 1326, \"to\": 1349}, {\"ngram\": \"the world\", \"from\": 1353, \"to\": 1362}]}, {\"sentence\": \"This is a dream come true and I must give God thanks because without him none of this would have been possible,\\\" he added.\", \"from\": 1364, \"to\": 1486, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a dream\", \"from\": 1372, \"to\": 1379}, {\"ngram\": \"God\", \"from\": 1406, \"to\": 1409}, {\"ngram\": \"thanks\", \"from\": 1410, \"to\": 1416}, {\"ngram\": \"none\", \"from\": 1437, \"to\": 1441}]}, {\"sentence\": \"He spoke to theObserverjust hours after returning to the country after his latest assignment, where he was part of the officials panel at the recent inaugural Concacaf Women's Gold Cup and part of the VAR panel for the Concacaf Nations League final between the United States and Mexico in Texas two weeks ago.\", \"from\": 1488, \"to\": 1797, \"entities\": [{\"begin\": 1689, \"end\": 1692, \"title\": \"http://dbpedia.org/resource/Video_assistant_referee\", \"score\": 1.0, \"rank\": 7.12789569803526e-22, \"text\": \"VAR\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Video_assistant_referee\", \"dbpedia\": \"http://dbpedia.org/resource/Video_assistant_referee\"}, {\"begin\": 1707, \"end\": 1730, \"title\": \"http://dbpedia.org/resource/CONCACAF_Nations_League\", \"score\": 1.0, \"rank\": 4.791812440375718e-29, \"text\": \"Concacaf Nations League\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/CONCACAF_Nations_League\", \"dbpedia\": \"http://dbpedia.org/resource/CONCACAF_Nations_League\"}, {\"begin\": 1749, \"end\": 1762, \"title\": \"http://dbpedia.org/resource/United_States_women's_national_soccer_team\", \"score\": 0.8637892922960267, \"rank\": 0.15768958117353285, \"text\": \"United States\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_States_women's_national_soccer_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_women's_national_soccer_team\"}, {\"begin\": 1767, \"end\": 1773, \"title\": \"http://dbpedia.org/resource/Mexico_national_football_team\", \"score\": 0.884898982827396, \"rank\": 0.13003433768040598, \"text\": \"Mexico\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Mexico_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Mexico_national_football_team\"}], \"noun_phrases\": [{\"ngram\": \"theObserverjust hours\", \"from\": 1500, \"to\": 1521}, {\"ngram\": \"the country\", \"from\": 1541, \"to\": 1552}, {\"ngram\": \"his latest assignment\", \"from\": 1559, \"to\": 1580}, {\"ngram\": \"part\", \"from\": 1595, \"to\": 1599}, {\"ngram\": \"the officials panel\", \"from\": 1603, \"to\": 1622}, {\"ngram\": \"the recent inaugural Concacaf Women's Gold Cup\", \"from\": 1626, \"to\": 1672}, {\"ngram\": \"part\", \"from\": 1677, \"to\": 1681}, {\"ngram\": \"Texas\", \"from\": 1777, \"to\": 1782}]}, {\"sentence\": \"His list of achievements includes officiating in the last four Men's Gold Cup tournaments.\", \"from\": 1799, \"to\": 1889, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"His list\", \"from\": 1799, \"to\": 1807}, {\"ngram\": \"achievements\", \"from\": 1811, \"to\": 1823}, {\"ngram\": \"the last four Men's Gold Cup tournaments\", \"from\": 1848, \"to\": 1888}]}, {\"sentence\": \"He officiated in the 2021 semi-finals between Mexico and Canada.\", \"from\": 1890, \"to\": 1954, \"entities\": [{\"begin\": 1936, \"end\": 1942, \"title\": \"http://dbpedia.org/resource/Mexico_national_football_team\", \"score\": 0.884898982827396, \"rank\": 0.13003433768040598, \"text\": \"Mexico\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Mexico_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Mexico_national_football_team\"}, {\"begin\": 1947, \"end\": 1953, \"title\": \"http://dbpedia.org/resource/Canada_women's_national_soccer_team\", \"score\": 0.996944962233471, \"rank\": 0.0030643989158031597, \"text\": \"Canada\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Canada_women's_national_soccer_team\", \"dbpedia\": \"http://dbpedia.org/resource/Canada_women's_national_soccer_team\"}], \"noun_phrases\": [{\"ngram\": \"the 2021 semi\", \"from\": 1907, \"to\": 1920}, {\"ngram\": \"finals\", \"from\": 1921, \"to\": 1927}]}, {\"sentence\": \"He was the fourth officia