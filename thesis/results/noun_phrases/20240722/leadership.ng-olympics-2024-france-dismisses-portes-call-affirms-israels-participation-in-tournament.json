"{\"uid\": \"leadership.ng-olympics-2024-france-dismisses-portes-call-affirms-israels-participation-in-tournament\", \"noun_phrases\": [{\"sentence\": \"French Foreign Minister Stephane Sejourne on Monday confirmed that Israeli athletes are welcome at the Paris Olympics, countering calls from a hard-left French lawmaker for their exclusion.\", \"from\": 0, \"to\": 189, \"entities\": [{\"begin\": 0, \"end\": 23, \"title\": \"http://dbpedia.org/resource/Ministry_for_Europe_and_Foreign_Affairs\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"French Foreign Minister\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ministry_for_Europe_and_Foreign_Affairs\", \"dbpedia\": \"http://dbpedia.org/resource/Ministry_for_Europe_and_Foreign_Affairs\"}, {\"begin\": 67, \"end\": 74, \"title\": \"http://dbpedia.org/resource/Israel\", \"score\": 0.9992801782671682, \"rank\": 0.0007003347232685605, \"text\": \"Israeli\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Israel\", \"dbpedia\": \"http://dbpedia.org/resource/Israel\"}, {\"begin\": 153, \"end\": 159, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.8600192938076882, \"rank\": 0.06622932214526987, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"Monday\", \"from\": 45, \"to\": 51}, {\"ngram\": \"the Paris Olympics\", \"from\": 99, \"to\": 117}, {\"ngram\": \"calls\", \"from\": 130, \"to\": 135}, {\"ngram\": \"their exclusion\", \"from\": 173, \"to\": 188}]}, {\"sentence\": \"This statement came ahead of talks with Sejourne's Israeli counterpart in Brussels.\", \"from\": 191, \"to\": 274, \"entities\": [{\"begin\": 242, \"end\": 249, \"title\": \"http://dbpedia.org/resource/Israel\", \"score\": 0.9992801782671682, \"rank\": 0.0007003347232685605, \"text\": \"Israeli\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Israel\", \"dbpedia\": \"http://dbpedia.org/resource/Israel\"}, {\"begin\": 265, \"end\": 273, \"title\": \"http://dbpedia.org/resource/Brussels\", \"score\": 0.9989566400179768, \"rank\": 0.0008034976445167384, \"text\": \"Brussels\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Brussels\", \"dbpedia\": \"http://dbpedia.org/resource/Brussels\"}], \"noun_phrases\": [{\"ngram\": \"This statement\", \"from\": 191, \"to\": 205}, {\"ngram\": \"talks\", \"from\": 220, \"to\": 225}]}, {\"sentence\": \"\\\"The Israeli delegation is welcome in France,\\\" Sejourne declared, labeling the exclusionary call by lawmaker Thomas Portes of France Unbowed (LFI) as \\\"irresponsible and dangerous.\\\"\", \"from\": 276, \"to\": 456, \"entities\": [{\"begin\": 281, \"end\": 288, \"title\": \"http://dbpedia.org/resource/Israel\", \"score\": 0.9992801782671682, \"rank\": 0.0007003347232685605, \"text\": \"Israeli\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Israel\", \"dbpedia\": \"http://dbpedia.org/resource/Israel\"}, {\"begin\": 314, \"end\": 320, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.6463515602178342, \"rank\": 0.5366650468688643, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 385, \"end\": 391, \"title\": \"http://dbpedia.org/resource/Clarence_Thomas\", \"score\": 0.9989930631807947, \"rank\": 0.0008222631293815645, \"text\": \"Thomas\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Clarence_Thomas\", \"dbpedia\": \"http://dbpedia.org/resource/Clarence_Thomas\"}, {\"begin\": 402, \"end\": 408, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.6463515602178342, \"rank\": 0.5366650468688643, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"Sejourne\", \"from\": 323, \"to\": 331}, {\"ngram\": \"the exclusionary call\", \"from\": 351, \"to\": 372}, {\"ngram\": \"(LFI\", \"from\": 417, \"to\": 421}]}, {\"sentence\": \"Sejourne also assured that the security of the Israeli delegation would be guaranteed.\", \"from\": 458, \"to\": 544, \"entities\": [{\"begin\": 505, \"end\": 512, \"title\": \"http://dbpedia.org/resource/Israel\", \"score\": 0.9992801782671682, \"rank\": 0.0007003347232685605, \"text\": \"Israeli\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Israel\", \"dbpedia\": \"http://dbpedia.org/resource/Israel\"}], \"noun_phrases\": [{\"ngram\": \"Sejourne\", \"from\": 458, \"to\": 466}, {\"ngram\": \"the security\", \"from\": 485, \"to\": 497}]}, {\"sentence\": \"Portes incited outrage from French Jewish groups and political figures after he stated during a pro-Palestinian demonstration that Israeli athletes were \\\"not welcome\\\" while also calling for \\\"mobilisation\\\" against their participation in the Olympics.\", \"from\": 546, \"to\": 795, \"entities\": [{\"begin\": 574, \"end\": 587, \"title\": \"http://dbpedia.org/resource/History_of_the_Jews_in_France\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"French Jewish\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/History_of_the_Jews_in_France\", \"dbpedia\": \"http://dbpedia.org/resource/History_of_the_Jews_in_France\"}, {\"begin\": 574, \"end\": 587, \"title\": \"http://dbpedia.org/resource/History_of_the_Jews_in_France\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"French Jewish\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/History_of_the_Jews_in_France\", \"dbpedia\": \"http://dbpedia.org/resource/History_of_the_Jews_in_France\"}, {\"begin\": 677, \"end\": 684, \"title\": \"http://dbpedia.org/resource/Israel\", \"score\": 0.9992801782671682, \"rank\": 0.0007003347232685605, \"text\": \"Israeli\", \"types\": [\"Q6256\"],