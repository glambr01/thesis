"{\"uid\": \"thelocal.fr-20240722-paris-airport-union-files-new-olympic-strike-warning\", \"noun_phrases\": [{\"sentence\": \"The Local Europe ABV\\u00e4stmannagatan 43113 25 StockholmSweden A small union at Paris airport operator ADP said on Monday it had filed a strike warning for Friday, the day of the Olympic Games opening ceremony, rubbishing a recent deal with management.\", \"from\": 0, \"to\": 249, \"entities\": [{\"begin\": 77, \"end\": 82, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.999999996456836, \"rank\": 3.543260711500204e-09, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"The Local Europe ABV\\u00e4stmannagatan\", \"from\": 0, \"to\": 33}, {\"ngram\": \"StockholmSweden A small union\", \"from\": 43, \"to\": 72}, {\"ngram\": \"Monday\", \"from\": 111, \"to\": 117}, {\"ngram\": \"a strike warning\", \"from\": 131, \"to\": 147}, {\"ngram\": \"Friday\", \"from\": 152, \"to\": 158}, {\"ngram\": \"the Olympic Games opening ceremony\", \"from\": 171, \"to\": 205}, {\"ngram\": \"a recent deal\", \"from\": 218, \"to\": 231}, {\"ngram\": \"management\", \"from\": 237, \"to\": 247}]}, {\"sentence\": \"Last week's accord that fended off a walkout by larger worker groups offered only \\\"partial and modest gains\\\", said the Force Ouvriere (FO) union, which represents almost 12 percent of ADP staff.\", \"from\": 251, \"to\": 445, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Last week's accord\", \"from\": 251, \"to\": 269}, {\"ngram\": \"a walkout\", \"from\": 286, \"to\": 295}, {\"ngram\": \"larger worker groups\", \"from\": 299, \"to\": 319}, {\"ngram\": \"only \\\"partial and modest gains\", \"from\": 328, \"to\": 358}, {\"ngram\": \"the Force Ouvriere (FO) union\", \"from\": 366, \"to\": 395}, {\"ngram\": \"almost 12 percent\", \"from\": 414, \"to\": 431}, {\"ngram\": \"ADP staff\", \"from\": 435, \