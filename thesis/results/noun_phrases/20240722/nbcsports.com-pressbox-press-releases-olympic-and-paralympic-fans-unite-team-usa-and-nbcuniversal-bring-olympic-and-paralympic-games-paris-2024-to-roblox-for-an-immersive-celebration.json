am\": \"video highlights\", \"from\": 636, \"to\": 652}, {\"ngram\": \"competitions\", \"from\": 656, \"to\": 668}, {\"ngram\": \"special digital items\", \"from\": 674, \"to\": 695}, {\"ngram\": \"athletes\", \"from\": 701, \"to\": 709}, {\"ngram\": \"their sales' proceeds\", \"from\": 724, \"to\": 745}, {\"ngram\": \"the experience\", \"from\": 747, \"to\": 761}, {\"ngram\": \"\\\"The Team USA Ultimate Obby\", \"from\": 770, \"to\": 797}, {\"ngram\": \"honor\", \"from\": 802, \"to\": 807}, {\"ngram\": \"its obstacle course main attraction\", \"from\": 811, \"to\": 846}, {\"ngram\": \"a first-ever opportunity\", \"from\": 851, \"to\": 875}, {\"ngram\": \"Olympic and Paralympic fans\", \"from\": 880, \"to\": 907}, {\"ngram\": \"part\", \"from\": 934, \"to\": 938}, {\"ngram\": \"this global celebration\", \"from\": 942, \"to\": 965}, {\"ngram\": \"sports\", \"from\": 969, \"to\": 975}, {\"ngram\": \"camaraderie\", \"from\": 980, \"to\": 991}]}, {\"sentence\": \"\\\"As a big fan of Roblox, I think it's really cool to see Team USA on this platform,\\\" said Minna Stess, Olympic Games Paris 2024 Team USA skateboarding athlete.\", \"from\": 996, \"to\": 1155, \"entities\": [{\"begin\": 1013, \"end\": 1019, \"title\": \"http://dbpedia.org/resource/Roblox\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Roblox\", \"types\": [\"Q7889\", \"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Roblox\", \"dbpedia\": \"http://dbpedia.org/resource/Roblox\"}, {\"begin\": 1053, \"end\": 1061, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999999983419912, \"rank\": 1.657316050925839e-09, \"text\": \"Team USA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 1086, \"end\": 1091, \"title\": \"http://dbpedia.org/resource/Minna\", \"score\": 1.0, \"rank\": 7.774281850817112e-14, \"text\": \"Minna\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Minna\", \"dbpedia\": \"http://dbpedia.org/resource/Minna\"}, {\"begin\": 1124, \"end\": 1132, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999999983419912, \"rank\": 1.657316050925839e-09, \"text\": \"Team USA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 1129, \"end\": 1146, \"title\": \"http://dbpedia.org/resource/USA_Skateboarding_National_Team\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"USA skateboarding\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/USA_Skateboarding_National_Team\", \"dbpedia\": \"http://dbpedia.org/resource/USA_Skateboarding_National_Team\"}], \"noun_phrases\": [{\"ngram\": \"a big fan\", \"from\": 1000, \"to\": 1009}, {\"ngram\": \"this platform\", \"from\": 1065, \"to\": 1078}, {\"ngram\": \"Olympic Games\", \"from\": 1099, \"to\": 1112}, {\"ngram\": \"Paris\", \"from\": 1113, \"to\": 1118}]}, {\"sentence\": \"\\\"I have been playing on Roblox for years but never thought I would one day see my own avatar in an experience along with so many other Olympic and Paralympic athletes, so that is also exciting.\\\"\", \"from\": 1156, \"to\": 1350, \"entities\": [{\"begin\": 1180, \"end\": 1186, \"title\": \"http://dbpedia.org/resource/Roblox\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Roblox\", \"types\": [\"Q7889\", \"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Roblox\", \"dbpedia\": \"http://dbpedia.org/resource/Roblox\"}], \"noun_phrases\": [{\"ngram\": \"years\", \"from\": 1191, \"to\": 1196}, {\"ngram\": \"my own avatar\", \"from\": 1235, \"to\": 1248}, {\"ngram\": \"an experience\", \"from\": 1252, \"to\": 1265}, {\"ngram\": \"so many other Olympic and Paralympic athletes\", \"from\": 1277, \"to\": 1322}]}, {\"sentence\": \"The experience, which goes live on Roblox today, before the Opening Ceremony of the Olympic Games Paris 2024 takes place on July 26, can be accessed at the following link:TeamUSA.com/RobloxorNBCOlympics.com/Roblox.\", \"from\": 1354, \"to\": 1568, \"entities\": [{\"begin\": 1389, \"end\": 1395, \"title\": \"http://dbpedia.org/resource/Roblox\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Roblox\", \"types\": [\"Q7889\", \"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Roblox\", \"dbpedia\": \"http://dbpedia.org/resource/Roblox\"}], \"noun_phrases\": [{\"ngram\": \"The experience\", \"from\": 1354, \"to\": 1368}, {\"ngram\": \"the Opening Ceremony\", \"from\": 1410, \"to\": 1430}, {\"ngram\": \"the Olympic Games Paris\", \"from\": 1434, \"to\": 1457}, {\"ngram\": \"place\", \"from\": 1469, \"to\": 1474}, {\"ngram\": \"July\", \"from\": 1478, \"to\": 1482}, {\"ngram\": \"the following link\", \"from\": 1506, \"to\": 1524}, {\"ngram\": \"RobloxorNBCOlympics.com/Roblox\", \"from\": 1537, \"to\": 1567}]}, {\"sentence\": \"The Roblox community and Team USA fans will find endless ways to engage with Team USA before, during and after the Games, highlighted by: \\u00b7Team USA Ultimate Obby- The main attraction of the experience is Game Mountain, a vertical Obby designed for casual gameplay and maximum replay-ability and features multiple distinct sports-themed areas, each progressively more challenging.\", \"from\": 1569, \"to\": 1951, \"entities\": [{\"begin\": 1573, \"end\": 1579, \"title\": \"http://dbpedia.org/resource/Roblox\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Roblox\", \"types\": [\"Q7889\", \"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Roblox\", \"dbpedia\": \"http://dbpedia.org/resource/Roblox\"}, {\"begin\": 1594, \"end\": 1602, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999999983419912, \"rank\": 1.657316050925839e-09, \"text\": \"Team USA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 1646, \"end\": 1654, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999999983419912, \"rank\": 1.657316050925839e-09, \"text\": \"Team USA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"endless ways\", \"from\": 1618, \"to\": 1630}, {\"ngram\": \"the Games\", \"from\": 1680, \"to\": 1689}, {\"ngram\": \"The main attraction\", \"from\": 1732, \"to\": 1751}, {\"ngram\": \"the experience\", \"from\": 1755, \"to\": 1769}, {\"ngram\": \"Game Mountain\", \"from\": 1773, \"to\": 1786}, {\"ngram\": \"a vertical Obby\", \"from\": 1788, \"to\": 1803}, {\"ngram\": \"casual gameplay\", \"from\": 1817, \"to\": 1832}, {\"ngram\": \"maximum replay-ability\", \"from\": 1837, \"to\": 1859}, {\"ngram\": \"multiple distinct sports-themed areas\", \"from\": 1873, \"to\": 1910}]}, {\"sentence\": \"\\u00b7Peacock Fan Zone- The Peacock Fan Zone is the place for fans to catch the latest Olympic and Paralympic highlights at the Xfinity Watch Party, where they can grab a seat on the Xfinity couch and engage with others as the replays unfold.\", \"from\": 1957, \"to\": 2194, \"entities\": [{\"begin\": 2080, \"end\": 2087, \"title\": \"http://dbpedia.org/resource/Comcast\", \"score\": 0.9999999998562998, \"rank\": 1.43644934505352e-10, \"text\": \"Xfinity\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Comcast\", \"dbpedia\": \"http://dbpedia.org/resource/Comcast\"}, {\"begin\": 2135, \"end\": 2142, \"title\": \"http://dbpedia.org/resource/Comcast\", \"score\": 0.9999999998562998, \"rank\": 1.43644934505352e-10, \"text\": \"Xfinity\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Comcast\", \"dbpedia\": \"http://dbpedia.org/resource/Comcast\"}], \"noun_phrases\": [{\"ngram\": \"Peacock\", \"from\": 1958, \"to\": 1965}, {\"ngram\": \"Fan\", \"from\": 1966, \"to\": 1969}, {\"ngram\": \"The Peacock Fan Zone\", \"from\": 1976, \"to\": 1996}, {\"ngram\": \"the place\", \"from\": 2000, \"to\": 2009}, {\"ngram\": \"fans\", \"from\": 2014, \"to\": 2018}, {\"ngram\": \"the latest Olympic and Paralympic highlights\", \"from\": 2028, \"to\": 2072}, {\"ngram\": \"a seat\", \"from\": 2121, \"to\": 2127}, {\"ngram\": \"others\", \"from\": 2165, \"to\": 2171}, {\"ngram\": \"the replays\", \"from\": 2175, \"to\": 2186}]}, {\"sentence\": \"Additionally, Mike Tirico, primetime host for NBCUniversal's coverage of the Olympic Games, will welcome users to a first-of-its-kind activity where visitors go on-air with their own NBC Olympics or Paralympics broadcast, taking on various roles including commentator, camera operator, lighting and FX and more.\", \"from\": 2195, \"to\": 2506, \"entities\": [{\"begin\": 2209, \"end\": 2220, \"title\": \"http://dbpedia.org/resource/Mike_Tirico\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Mike Tirico\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Mike_Tirico\", \"dbpedia\": \"http://dbpedia.org/resource/Mike_Tirico\"}, {\"begin\": 2241, \"end\": 2253, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 0.9999999999636202, \"rank\": 3.596772548483319e-11, \"text\": \"NBCUniversal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}, {\"begin\": 2378, \"end\": 2390, \"title\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"NBC Olympics\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\"}, {\"begin\": 2494, \"end\": 2496, \"title\": \"http://dbpedia.org/resource/Special_effect\", \"score\": 0.9478468837768709, \"rank\": 0.0550218392303304, \