\"to\": 3190}, {\"ngram\": \"most proud moments\", \"from\": 3195, \"to\": 3213}, {\"ngram\": \"awards\", \"from\": 3227, \"to\": 3233}, {\"ngram\": \"night\", \"from\": 3272, \"to\": 3277}, {\"ngram\": \"guest arranger\", \"from\": 3324, \"to\": 3338}, {\"ngram\": \"a spiritual medley\", \"from\": 3343, \"to\": 3361}, {\"ngram\": \"slave songs\", \"from\": 3374, \"to\": 3385}, {\"ngram\": \"personal fundamentals\", \"from\": 3408, \"to\": 3429}, {\"ngram\": \"my musical foundations\", \"from\": 3434, \"to\": 3456}, {\"ngram\": \"Harris\", \"from\": 3459, \"to\": 3465}]}, {\"sentence\": \"After graduation, he went on to earn his Master's in Music in Contemporary Improvisation from the New England Conservatory.\", \"from\": 3473, \"to\": 3596, \"entities\": [{\"begin\": 3571, \"end\": 3595, \"title\": \"http://dbpedia.org/resource/New_England_Conservatory_of_Music\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"New England Conservatory\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/New_England_Conservatory_of_Music\", \"dbpedia\": \"http://dbpedia.org/resource/New_England_Conservatory_of_Music\"}], \"noun_phrases\": [{\"ngram\": \"graduation\", \"from\": 3479, \"to\": 3489}, {\"ngram\": \"his Master\", \"from\": 3510, \"to\": 3520}, {\"ngram\": \"Music\", \"from\": 3526, \"to\": 3531}, {\"ngram\": \"Contemporary Improvisation\", \"from\": 3535, \"to\": 3561}]}, {\"sentence\": \"Over the years, Harris has built an extensive resume in the professional music industry.\", \"from\": 3598, \"to\": 3686, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the years\", \"from\": 3603, \"to\": 3612}, {\"ngram\": \"Harris\", \"from\": 3614, \"to\": 3620}, {\"ngram\": \"an extensive resume\", \"from\": 3631, \"to\": 3650}, {\"ngram\": \"the professional music industry\", \"from\": 3654, \"to\": 3685}]}, {\"sentence\": \"As a musical director, keyboardist, arranger and programmer, he has collaborated with such artists as Rickey Minor, Sheila E, Angelo Morris, Adam Blackstone, Onree Gill, Kim Burse, Jimmy Jam and Terry Lewis, Sting, Janelle Monae, the late Betty Wright, Lenny Kravitz, 21 Savage, Travis Barker (Blink-182), Dr. Bobby Jones Gospel, Tyrese, SWV, Shirley Caesar, Skip Marley and Chris Brown.\", \"from\": 3688, \"to\": 4075, \"entities\": [{\"begin\": 3790, \"end\": 3802, \"title\": \"http://dbpedia.org/resource/Rickey_Minor\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Rickey Minor\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Rickey_Minor\", \"dbpedia\": \"http://dbpedia.org/resource/Rickey_Minor\"}, {\"begin\": 3804, \"end\": 3810, \"title\": \"http://dbpedia.org/resource/Sheila_Canning\", \"score\": 0.7479875273566035, \"rank\": 0.3369206856065765, \"text\": \"Sheila\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Sheila_Canning\", \"dbpedia\": \"http://dbpedia.org/resource/Sheila_Canning\"}, {\"begin\": 3821, \"end\": 3827, \"title\": \"http://dbpedia.org/resource/Morris_Motors\", \"score\": 0.9553687834655417, \"rank\": 0.03945897071982757, \"text\": \"Morris\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Morris_Motors\", \"dbpedia\": \"http://dbpedia.org/resource/Morris_Motors\"}, {\"begin\": 3829, \"end\": 3844, \"title\": \"http://dbpedia.org/resource/Adam_Blackstone\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Adam Blackstone\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Adam_Blackstone\", \"dbpedia\": \"http://dbpedia.org/resource/Adam_Blackstone\"}, {\"begin\": 3858, \"end\": 3861, \"title\": \"http://dbpedia.org/resource/Kim_Kardashian\", \"score\": 1.0, \"rank\": 6.676875082433503e-17, \"text\": \"Kim\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kim_Kardashian\", \"dbpedia\": \"http://dbpedia.org/resource/Kim_Kardashian\"}, {\"begin\": 3862, \"end\": 3867, \"title\": \"http: