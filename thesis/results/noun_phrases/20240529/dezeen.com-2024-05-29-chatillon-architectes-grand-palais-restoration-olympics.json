entities\": [], \"noun_phrases\": [{\"ngram\": \"The sporting event\", \"from\": 352, \"to\": 370}, {\"ngram\": \"the revamped atrium\", \"from\": 387, \"to\": 406}, {\"ngram\": \"nave\", \"from\": 411, \"to\": 415}, {\"ngram\": \"swathes\", \"from\": 423, \"to\": 430}, {\"ngram\": \"glass\", \"from\": 434, \"to\": 439}, {\"ngram\": \"an expansive structure\", \"from\": 444, \"to\": 466}, {\"ngram\": \"over 6,000 tonnes\", \"from\": 470, \"to\": 487}, {\"ngram\": \"steel\", \"from\": 491, \"to\": 496}, {\"ngram\": \"an intricate backdrop\", \"from\": 511, \"to\": 532}]}, {\"sentence\": \"The Grand Palais has hosted many international exhibitions and events since it was constructed for the Paris Universal Exhibition in 1900.\", \"from\": 535, \"to\": 673, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The Grand Palais\", \"from\": 535, \"to\": 551}, {\"ngram\": \"many international exhibitions\", \"from\": 563, \"to\": 593}, {\"ngram\": \"events\", \"from\": 598, \"to\": 604}, {\"ngram\": \"the Paris Universal Exhibition\", \"from\": 634, \"to\": 664}]}, {\"sentence\": \"The overhaul by Chatillon Architectes is the first major restoration in the building's history.\", \"from\": 674, \"to\": 769, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The overhaul\", \"from\": 674, \"to\": 686}, {\"ngram\": \"Chatillon Architectes\", \"from\": 690, \"to\": 711}, {\"ngram\": \"the first major restoration\", \"from\": 715, \"to\": 742}, {\"ngram\": \"the building's history\", \"from\": 746, \"to\": 768}]}, {\"sentence\": \"According to the studio, the main ambition for the project was to improve accessibility after it had become \\\"a monument that was often only observed from afar\\\".\", \"from\": 771, \"to\": 931, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the studio\", \"from\": 784, \"to\": 794}, {\"ngram\": \"the main ambition\", \"from\": 796, \"to\": 813}, {\"ngram\": \"the project\", \"from\": 818, \"to\": 829}, {\"ngram\": \"accessibility\", \"from\": 845, \"to\": 858}, {\"ngram\": \"a monument\", \"from\": 880, \"to\": 890}]}, {\"sentence\": \"\\\"It's the opportunity to return a permanent public use to the building, to redevelop the surrounding grounds, to connect the building back with the city, and to adapt it for the Olympics and future generations,\\\" Chatillon Architectes founder Francois Chatillon told Dezeen.\", \"from\": 933, \"to\": 1206, \"entities\": [{\"begin\": 1199, \"end\": 1205, \"title\": \"http://dbpedia.org/resource/Dezeen\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Dezeen\", \"types\": [\"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Dezeen\", \"dbpedia\": \"http://dbpedia.org/resource/Dezeen\"}], \"noun_phrases\": [{\"ngram\": \"the opportunity\", \"from\": 939, \"to\": 954}, {\"ngram\": \"a permanent public use\", \"from\": 965, \"to\": 987}, {\"ngram\": \"the building\", \"from\": 991, \"to\": 1003}, {\"ngram\": \"the surrounding grounds\", \"from\": 1018, \"to\": 1041}, {\"ngram\": \"the building\", \"from\": 1054, \"to\": 1066}, {\"ngram\": \"the city\", \"from\": 1077, \"to\": 1085}, {\"ngram\": \"the Olympics\", \"from\": 1107, \"to\": 1119}, {\"ngram\": \"future generations\", \"from\": 1124, \"to\": 1142}, {\"ngram\": \"Chatillon\", \"from\": 1145, \"to\": 1154}]}, {\"sentence\": \"Chatillon Architectes also set out to preserve and celebrate as much of the original structure as possible, referencing the design by its architects Henri Deglane, Albert Louvet, Albert Thomas and Charles Girault.\", \"from\": 1208, \"to\": 1421, \"entities\": [{\"begin\": 1357, \"end\": 1370, \"title\": \"http://dbpedia.org/resource/Henri_Deglane\", \"score\": 1.0, \"rank\": 6.443716800716041e-23, \"text\": \"Henri Deglane\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Henri_Deglane\", \"dbpedia\": \"http://dbpedia.org/resource/Henri_Deglane\"}, {\"begin\": 1372, \"end\": 1378, \"title\": \"http://dbpedia.org/resource/Uncle_Albert\", \"score\": 0.7352887289933501, \"rank\": 0.3579630108367115, \"text\": \"Albert\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Uncle_Albert\", \"dbpedia\": \"http://dbpedia.org/resource/Uncle_Albert\"}, {\"begin\": 1379, \"end\": 1385, \"title\": \"http://dbpedia.org/resource/Jean-Baptiste_Louvet_de_Couvray\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Louvet\", \"types\": [\"Q729\", \"Q5\", \"Q36180\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jean-Baptiste_Louvet_de_Couvray\", \"dbpedia\": \"http://dbpedia.org/resource/Jean-Baptiste_Louvet_de_Couvray\"}, {\"begin\": 1387, \"end\": 1393, \"title\": \"http://dbpedia.org/resource/Uncle_Albert\", \"score\": 0.7352887289933501, \"rank\": 0.3579630108367115, \"text\": \"Albert\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Uncle_Albert\", \"dbpedia\": \"http://dbpedia.org/resource/Uncle_Albert\"}, {\"begin\": 1394, \"end\": 1400, \"title\": \"http://dbpedia.org/resource/Thomas_the_Apostle\", \"score\": 0.8510476077785499, \"rank\": 0.17465410362002606, \"text\": \"Thomas\", \"types\": [\"Q729\", \"Q5\", \"Q43115\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Thomas_the_Apostle\", \"dbpedia\": \"http://dbpedia.org/resource/Thomas_the_Apostle\"}, {\"begin\": 1405, \"end\": 1420, \"title\": \"http://dbpedia.org/resource/Charles_Girault\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Charles Girault\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Charles_Girault\", \"dbpedia\": \"http://dbpedia.org/resource/Charles_Girault\"}], \"noun_phrases\": [{\"ngram\": \"Chatillon Architectes\", \"from\": 1208, \"to\": 1229}, {\"ngram\": \"the original structure\", \"from\": 1280, \"to\": 1302}, {\"ngram\": \"the design\", \"from\": 1328, \"to\": 1338}, {\"ngram\": \"its architects\", \"from\": 1342, \"to\": 1356}]}, {\"sentence\": \"\\\"Our focus has always been to honour and restore the best of the building's past but not to do this blindly, we have approached the project with a contemporary mindset, ensuring that the building is prepared for its next phase of life and that, above all, it is a functioning building for modern society,\\\" said Chatillon during a tour of the building.\", \"from\": 1423, \"to\": 1774, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Our focus\", \"from\": 1424, \"to\": 1433}, {\"ngram\": \"the building's past\", \"from\": 1484, \"to\": 1503}, {\"ngram\": \"the project\", \"from\": 1551, \"to\": 1562}, {\"ngram\": \"a contemporary mindset\", \"from\": 1568, \"to\": 1590}, {\"ngram\": \"the building\", \"from\": 1606, \"to\": 1618}, {\"ngram\": \"its next phase\", \"from\": 1635, \"to\": 1649}, {\"ngram\": \"life\", \"from\": 1653, \"to\": 1657}, {\"ngram\": \"a functioning building\", \"from\": 1685, \"to\": 1707}, {\"ngram\": \"modern society\", \"from\": 1712, \"to\": 1726}, {\"ngram\": \"Chatillon\", \"from\": 1734, \"to\": 1743}, {\"ngram\": \"a tour\", \"from\": 1751, \"to\": 1757}, {\"ngram\": \"the building\", \"from\": 1761, \"to\": 1773}]}, {\"sentence\": \"\\\"The scale of the project is quite unbelievable, from the design stage to the construction,\\\" added Chatillon.\", \"from\": 1776, \"to\": 1885, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The scale\", \"from\": 1777, \"to\": 1786}, {\"ngram\": \"the project\", \"from\": 1790, \"to\": 1801}, {\"ngram\": \"the design stage\", \"from\": 1830, \"to\": 1846}, {\"ngram\": \"the construction\", \"from\": 1850, \"to\": 1866}, {\"ngram\": \"Chatillon\", \"from\": 1875, \"to\": 1884}]}, {\"sentence\": \"\\\"We have explored thousands of archival documents to truly understand the building and its original intentions.\\\"\", \"from\": 1887, \"to\": 1999, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"thousands\", \"from\": 1905, \"to\": 1914}, {\"ngram\": \"archival documents\", \"from\": 1918, \"to\": 1936}, {\"ngram\": \"the building\", \"from\": 1957, \"to\": 1969}, {\"ngram\": \"its original intentions\", \"from\": 1974, \"to\": 1997}]}, {\"sentence\": \"During the first phase of the project, changes to the 72,000-square-metre building have included reconnecting its three main spaces - including the nave - to restore the original central axis across its H\\u2011shaped plan.\", \"from\": 2001, \"to\": 2218, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the first phase\", \"from\": 2008, \"to\": 2023}, {\"ngram\": \"the project\", \"from\": 2027, \"to\": 2038}, {\"ngram\": \"the 72,000-square-metre building\", \"from\": 2051, \"to\": 2083}, {\"ngram\": \"its three main spaces\", \"from\": 2111, \"to\": 2132}, {\"ngram\": \"the nave\", \"from\": 2145, \"to\": 2153}, {\"ngram\": \"the original central axis\", \"from\": 2167, \"to\": 2192}, {\"ngram\": \"its H\\u2011shaped plan\", \"from\": 2200, \"to\": 2217}]}, {\"sentence\": \"Areas previously inaccessible to the public have also been reopened by removing partition walls and integrating a sightseeing route within its plan.\", \"from\": 2220, \"to\": 2368, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Areas\", \"from\": 2220, \"to\": 2225}, {\"ngram\": \"the public\", \"from\": 2253, \"to\": 2263}, {\"ngram\": \"partition walls\", \"from\": 2300, \"to\": 2315}, {\"ngram\": \"a sightseeing route\", \"from\": 2332, \"to\": 2351}, {\"ngram\": \"its plan\", \"from\": 2359, \"to\": 2367}]}, {\"sentence\": \"The decorative balconies in the nave, which the studio said are among the earliest recorded cantilevers, have been reinforced and restored.\", \"from\": 2370, \"to\": 2509, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The decorative balconies\", \"from\": 2370, \"to\": 2394}, {\"ngram\": \"the nave\", \"from\": 2398, \"to\": 2406}, {\"ngram\": \"the studio\", \"from\": 2414, \"to\": 2424}, {\"ngram\": \"the earliest recorded cantilevers\", \"from\": 2440, \"to\": 2473}]}, {\"sentence\": \"Meanwhile, escape routes have been improved to increase the atrium's capacity by more than 60 per cent.\", \"from\": 2510, \"to\": 2613, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"escape routes\", \"from\": 2521, \"to\": 2534}, {\"ngram\": \"the atrium's capacity\", \"from\": 2566, \"to\": 2587}, {\"ngram\": \"cent\", \"from\": 2608, \"to\": 2612}]}, {\"sentence\": \"Throughout, technology and building services have been brought up to modern-day standards to ensure the Grand Palais' capability as a contemporary exhibition and events venue.\", \"from\": 2615, \"to\": 2790, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"technology and building services\", \"from\": 2627, \"to\": 2659}, {\"ngram\": \"modern-day standards\", \"from\": 2684, \"to\": 2704}, {\"ngram\": \"the Grand Palais' capability\", \"from\": 2715, \"to\": 2743}, {\"ngram\": \"a contemporary exhibition and events venue\", \"from\": 2747, \"to\": 2789}]}, {\"sentence\": \"Completing the first phase are improvements to the landscaping surrounding the building, which have been carried out to enhance its connection to the Champs-\\u00c9lys\\u00e9es.\", \"from\": 2792, \"to\": 2957, \"entities\": [{\"begin\": 2942, \"end\": 2956, \"title\": \"http://dbpedia.org/resource/Champs-\\u00c9lys\\u00e9es\", \"score\": 0.9938637728104254, \"rank\": 0.005341849563968814, \"text\": \"Champs-\\u00c9lys\\u00e9es\", \"types\": [\"Q34442\"], \"wikid\": \"http://dbpedia.org/resource/Champs-\\u00c9lys\\u00e9es\", \"dbpedia\": \"http://dbpedia.org/resource/Champs-\\u00c9lys\\u00e9es\"}], \"noun_phrases\": [{\"ngram\": \"the first phase\", \"from\": 2803, \"to\": 2818}, {\"ngram\": \"improvements\", \"from\": 2823, \"to\": 2835}, {\"ngram\": \"the landscaping\", \"from\": 2839, \"to\": 2854}, {\"ngram\": \"the building\", \"from\": 2867, \"to\": 2879}, {\"ngram\": \"its connection\", \"from\": 2920, \"to\": 2934}]}, {\"sentence\": \"Though not photographed, 60,000 plants have been introduced to its lawns in curved beds and paths that emulate those on the famous Parisian avenue.\", \"from\": 2959, \"to\": 3106, \"entities\": [], \"noun_ph