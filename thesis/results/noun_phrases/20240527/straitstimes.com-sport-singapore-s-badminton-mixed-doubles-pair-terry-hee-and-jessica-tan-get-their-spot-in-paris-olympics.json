\": 1818, \"to\": 1835}, {\"ngram\": \"dedication\", \"from\": 1840, \"to\": 1850}, {\"ngram\": \"all the difficulties\", \"from\": 1881, \"to\": 1901}, {\"ngram\": \"the end\", \"from\": 1940, \"to\": 1947}]}, {\"sentence\": \"Their road to Paris was far from straightforward.\", \"from\": 1951, \"to\": 2000, \"entities\": [{\"begin\": 1965, \"end\": 1970, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.289612470420575e-13, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Their road\", \"from\": 1951, \"to\": 1961}, {\"ngram\": \"straightforward\", \"from\": 1984, \"to\": 1999}]}, {\"sentence\": \"Compared to at least 38 entries for the singles events, there are only 16 spots for the doubles competitions at the Olympics.\", \"from\": 2002, \"to\": 2127, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"at least 38 entries\", \"from\": 2014, \"to\": 2033}, {\"ngram\": \"the singles events\", \"from\": 2038, \"to\": 2056}, {\"ngram\": \"only 16 spots\", \"from\": 2068, \"to\": 2081}, {\"ngram\": \"the doubles competitions\", \"from\": 2086, \"to\": 2110}, {\"ngram\": \"the Olympics\", \"from\": 2114, \"to\": 2126}]}, {\"sentence\": \"As top pairs from America, Africa and Oceania receive continental quotas if they are in the world's top 50, only 13 open slots remained after the year-long qualification period ended on April 28.\", \"from\": 2129, \"to\": 2324, \"entities\": [{\"begin\": 2167, \"end\": 2174, \"title\": \"http://dbpedia.org/resource/Oceania_Football_Confederation\", \"score\": 0.6345970837105839, \"rank\": 0.5750056997645177, \"text\": \"Oceania\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Oceania_Football_Confederation\", \"dbpedia\": \"http://dbpedia.org/resource/Oceania_Football_Confederation\"}], \"noun_phrases\": [{\"ngram\": \"top pairs\", \"from\"