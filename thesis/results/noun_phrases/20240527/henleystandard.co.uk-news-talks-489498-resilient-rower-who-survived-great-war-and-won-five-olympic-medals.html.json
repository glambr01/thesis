le\": \"http://dbpedia.org/resource/Leander_Club\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Leander Club\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Leander_Club\", \"dbpedia\": \"http://dbpedia.org/resource/Leander_Club\"}, {\"begin\": 298, \"end\": 302, \"title\": \"http://dbpedia.org/resource/Jack_Branning\", \"score\": 0.5524284338448211, \"rank\": 0.8099894025403298, \"text\": \"Jack\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Jack_Branning\", \"dbpedia\": \"http://dbpedia.org/resource/Jack_Branning\"}], \"noun_phrases\": [{\"ngram\": \"the news\", \"from\": 11, \"to\": 19}, {\"ngram\": \"your perfect job\", \"from\": 91, \"to\": 107}, {\"ngram\": \"his book\", \"from\": 256, \"to\": 264}, {\"ngram\": \"his father\", \"from\": 271, \"to\": 281}, {\"ngram\": \"Jack\", \"from\": 283, \"to\": 287}, {\"ngram\": \"five medals\", \"from\": 315, \"to\": 326}, {\"ngram\": \"five Olympic Games\", \"from\": 330, \"to\": 348}, {\"ngram\": \"the Twenties\", \"from\": 352, \"to\": 364}, {\"ngram\": \"Thirties\", \"from\": 369, \"to\": 377}]}, {\"sentence\": \"The book, calledJack Beresford: An Olympian at War, takes you through his life.\", \"from\": 395, \"to\": 474, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The book\", \"from\": 395, \"to\": 403}, {\"ngram\": \"Beresford\", \"from\": 416, \"to\": 425}, {\"ngram\": \"An Olympian\", \"from\": 427, \"to\": 438}, {\"ngram\": \"War\", \"from\": 442, \"to\": 445}, {\"ngram\": \"his life\", \"from\": 465, \"to\": 473}]}, {\"sentence\": \"He was born in 1899 and went to Bedford School where he was mainly a rugby player but also captain of boats after his father before him (John was wearing his father's original 1916 Bedford jacket).\", \"from\": 476, \"to\": 673, \"entities\": [{\"begin\": 508, \"end\": 522, \"title\": \"http://dbpedia.org/resource/Bedford_School\", \"score\": 1.0, \"rank\": 2.133058222222898e-26, \"text\": \"Bedford School\", \"types\": [\"Q43229\", \"Q3914\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/Bedford_School\", \"dbpedia\": \"http://dbpedia.org/resource/Bedford_School\"}, {\"begin\": 657, \"end\": 664, \"title\": \"http://dbpedia.org/resource/Bedford\", \"score\": 1.0, \"rank\": 1.6292464044500336e-16, \"text\": \"Bedford\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Bedford\", \"dbpedia\": \"http://dbpedia.org/resource/Bedford\"}], \"noun_phrases\": [{\"ngram\": \"a rugby player\", \"from\": 543, \"to\": 557}, {\"ngram\": \"captain\", \"from\": 567, \"to\": 574}, {\"ngram\": \"boats\", \"from\": 578, \"to\": 583}, {\"ngram\": \"his father\", \"from\": 590, \"to\": 600}, {\"ngram\": \"John\", \"from\": 613, \"to\": 617}]}, {\"sentence\": \"When Jack finished school at 19, he went to France to fight in the First World War.\", \"from\": 675, \"to\": 758, \"entities\": [{\"begin\": 680, \"end\": 684, \"title\": \"http://dbpedia.org/resource/Jack_Branning\", \"score\": 0.5524284338448211, \"rank\": 0.8099894025403298, \"text\": \"Jack\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Jack_Branning\", \"dbpedia\": \"http://dbpedia.org/resource/Jack_Branning\"}, {\"begin\": 719, \"end\": 725, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9998871354501171, \"rank\": 5.082379720829637e-05, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"school\", \"from\": 694, \"to\": 700}, {\"ngram\": \"the First World War\", \"from\": 738, \"to\": 757}]}, {\"sentence\": \"He wrote 119 letters to his parents which provide a moving account of his experience but also show his resilience and strength of character.\", \"from\": 759, \"to\": 899, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"119 letters\", \"from\": 768, \"to\": 779}, {\"ngram\": \"his parents\", \"from\": 783, \"to\": 794}, {\"ngram\": \"a moving account\", \"from\": 809, \"to\": 825}, {\"ngram\": \"his experience\", \"from\": 829, \"to\": 843}, {\"ngram\": \"his resilience\", \"from\": 858, \"to\": 872}, {\"ngram\": \"strength\", \"from\": 877, \"to\": 885}, {\"ngram\": \"character\", \"from\": 889, \"to\": 898}]}, {\"sentence\": \"The average lifespan of a soldier in France during the war was reckoned to be 14 days but Jack survived for six and a half months.\", \"from\": 901, \"to\": 1031, \"entities\": [{\"begin\": 938, \"end\": 944, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9998871354501171, \"rank\": 5.082379720829637e-05, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 991, \"end\": 995, \"title\": \"http://dbpedia.org/resource/Jack_Branning\", \"score\": 0.5524284338448211, \"rank\": 0.8099894025403298, \"text\": \"Jack\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Jack_Branning\", \"dbpedia\": \"http://dbpedia.org/resource/Jack_Branning\"}], \"noun_phrases\": [{\"ngram\": \"The average lifespan\", \"from\": 901, \"to\": 921}, {\"ngram\": \"a soldier\", \"from\": 925, \"to\": 934}, {\"ngram\": \"the war\", \"from\": 952, \"to\": 959}, {\"ngram\": \"14 days\", \"from\": 979, \"to\": 986}, {\"ngram\": \"six and a half months\", \"from\": 1009, \"to\": 1030}]}, {\"sentence\": \"Eventually, he was wounded and returned to England with a shin injury that stopped his rugby career.\", \"from\": 1032, \"to\": 1132, \"entities\": [{\"begin\": 1075, \"end\": 1082, \"title\": \"http://dbpedia.org/resource/England\", \"score\": 0.9999999998849489, \"rank\": 1.1161387788478347e-10, \"text\": \"England\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/England\", \"dbpedia\": \"http://dbpedia.org/resource/England\"}], \"noun_phrases\": [{\"ngram\": \"a shin injury\", \"from\": 1088, \"to\": 1101}, {\"ngram\": \"his rugby career\", \"from\": 1115, \"to\": 1131}]}, {\"sentence\": \"Jack Beresford's rowing career continued during his rehabilitation and he competed at the 1919 Henley Royal Peace Regatta with his father.\", \"from\": 1133, \"to\": 1271, \"entities\": [{\"begin\": 1133, \"end\": 1147, \"title\": \"http://dbpedia.org/resource/Jack_Beresford\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Jack Beresford\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jack_Beresford\", \"dbpedia\": \"http://dbpedia.org/resource/Jack_Beresford\"}], \"noun_phrases\": [{\"ngram\": \"his rehabilitation\", \"from\": 1181, \"to\": 1199}, {\"ngram\": \"the 1919 Henley Royal Peace Regatta\", \"from\": 1219, \"to\": 1254}, {\"ngram\": \"his father\", \"from\": 1260, \"to\": 1270}]}, {\"sentence\": \"He went on to win the Diamond Sculls four times, the Silver Goblets and Nickalls and Grand twice and the Stewards and Double Sculls.\", \"from\": 1273, \"to\": 1405, \"entities\": [{\"begin\": 1345, \"end\": 1353, \"title\": \"http://dbpedia.org/resource/Guy_Nickalls\", \"score\": 1.0, \"rank\": 3.325756364379151e-48, \"text\": \"Nickalls\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Guy_Nickalls\", \"dbpedia\": \"http://dbpedia.org/resource/Guy_Nickalls\"}], \"noun_phrases\": [{\"ngram\": \"the Diamond Sculls\", \"from\": 1291, \"to\": 1309}, {\"ngram\": \"the Silver Goblets\", \"from\": 1322, \"to\": 1340}, {\"ngram\": \"Grand\", \"from\": 1358, \"to\": 1363}, {\"ngram\": \"the Stewards\", \"from\": 1374, \"to\": 1386}, {\"ngram\": \"Double Sculls\", \"from\": 1391, \"to\": 1404}]}, {\"sentence\": \"He was elected a steward of Henley Royal Regatta in 1966.\", \"from\": 1407, \"to\": 1464, \"entities\": [{\"begin\": 1435, \"end\": 1455, \"title\": \"http://dbpedia.org/resource/Henley_Royal_Regatta\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Henley Royal Regatta\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Henley_Royal_Regatta\", \"dbpedia\": \"http://dbpedia.org/resource/Henley_Royal_Regatta\"}], \"noun_phrases\": [{\"ngram\": \"a steward\", \"from\": 1422, \"to\": 1431}]}, {\"sentence\": \"His first Olympics was in 1920, when he won a silver medal behind Jack Kelly (Princess Grace's father) in the single sculls.\", \"from\": 1466, \"to\": 1590, \"entities\": [{\"begin\": 1532, \"end\": 1536, \"title\": \"http://dbpedia.org/resource/Jack_Branning\", \"score\": 0.5524284338448211, \"rank\": 0.8099894025403298, \"text\": \"Jack\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Jack_Branning\", \"dbpedia\": \"http://dbpedia.org/resource/Jack_Branning\"}, {\"begin\": 1537, \"end\": 1542, \"title\": \"http://dbpedia.org/resource/Kelly_Osbourne\", \"score\": 0.9999999972114892, \"rank\": 2.784845526920806e-09, \"text\": \"Kelly\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kelly_Osbourne\", \"dbpedia\": \"http://dbpedia.org/resource/Kelly_Osbourne\"}, {\"begin\": 1544, \"end\": 1558, \"title\": \"http://dbpedia.org/resource/Grace_Kelly\", \"score\": 1.0, \"rank\": 8.411312900765804e-18, \"text\": \"Princess Grace\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Grace_Kelly\", \"dbpedia\": \"http://dbpedia.org/resource/Grace_Kelly\"}], \"noun_phrases\": [{\"ngram\": \"His first Olympics\", \"from\": 1466, \"to\": 1484}, {\"ngram\": \"a silver medal\", \"from\": 1510, \"to\": 1524}, {\"ngram\": \"the single sculls\", \"from\": 1572, \"to\": 1589}]}, {\"sentence\": \"He then won gold at the 1924 Olympics, silver in 1928 and gold again in 1932 and 1936.\", \"from\": 1591, \"to\": 1677, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"gold\", \"from\": 1603, \"to\": 1607}, {\"ngram\": \"the 1924 Olympics\", \"from\": 1611, \"to\": 1628}, {\"ngram\": \"silver\", \"from\": 1630, \"to\": 1636}, {\"ngram\": \"gold\", \"from\": 1649, \"to\": 1653}]}, {\"sentence\": \"All winners at the 1936 Berlin Olympics received an oak tree and Jack planted his at Bedford School.\", \"from\": 1679, \"to\": 1779, \"entities\": [{\"begin\": 1698, \"end\": 1718, \"title\": \"http://dbpedia.org/resource/1936_Summer_Olympics\", \"score\": 1.0, \"rank\": 6.556439981714683e-26, \"text\": \"1936 Berlin Olympics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/1936_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/1936_Summer_Olympics\"}, {\"begin\": 1744, \"end\": 1748, \"title\": \"http://dbpedia.org/resource/Jack_Branning\", \"score\": 0.5524284338448211, \"rank\": 0.8099894025403298, \"text\": \"Jack\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Jack_Branning\", \"dbpedia\": \"http://dbpedia.org/resource/Jack_Branning\"}, {\"begin\": 1764, \"end\": 1778, \"title\": \"http://dbpedia.org/resource/Bedford_School\", \"score\": 1.0, \"rank\": 2.133058222222898e-26, \"text\": \"Bedford School\", \"types\": [\"Q43229\", \"Q3914\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/Bedford_School\", \"dbpedia\": \"http://dbpedia.org/resource/Bedford_School\"}], \"noun_phrases\": [{\"ngram\": \"All winners\", \"from\": 1679, \"to\": 1690}, {\"ngram\": \"an oak tree\", \"from\": 1728, \"to\": 1739}]}, {\"sentence\": \"Years later, the tree was taken down due to expansion but the timber was kept and some of it made into honorary plaques.\", \"from\": 1781, \"to\": 1901, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the tree\", \"from\": 1794, \"to\": 1802}, {\"ngram\": \"expansion\", \"from\": 1825, \"to\": 1834}, {\"ngram\": \"the timber\", \"from\": 1839, \"to\": 1849}, {\"ngram\": \"honorary plaques\", \"from\": 1884, \"to\": 1900}]}, {\"sentence\": \"After retiring from competitive rowing, Jack sat on the British Olympic Council and on the organising committee for the 1948 London Olympics.\", \"from\": 1903, \"to\": 2044, \"entities\": [{\"begin\": 1943, \"end\": 1947, \"title\": \"http://dbpedia.org/resource/Jack_Branning\", \"score\": 0.5524284338448211, \"rank\": 0.8099894025403298, \"text\": \"Jack\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Jack_Branning\", \"dbpedia\": \"http://dbpedia.org/resource/Jack_Branning\"}, {\"begin\": 1959, \"end\": 1982, \"title\": \"http://dbpedia.org/resource/British_Olympic_Association\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"British Olympic Council\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/British_Olympic_Association\", \"dbpedia\": \"http://dbpedia.org/resource/British_Olympic_Association\"}, {\"begin\": 2023, \"end\": 2043, \"title\": \"http://dbpedia.org/resource/1948_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.0408804970993654e-22, \"text\": \"1948 London Olympics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/1948_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/1948_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"competitive rowing\", \"from\": 1923, \"to\": 1941}, {\"ngram\": \"the organising committee\", \"from\": 1990, \"to\": 2014}]}, {\"sentence\": \"He was on the Amateur Rowing Association (now British Rowing) and president of Thames Rowing Club.\", \"from\": 2046, \"to\": 2144, \"entities\": [{\"begin\": 2060, \"end\": 2086, \"title\": \"http://dbpedia.org/resource/British_Rowing\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Amateur Rowing Association\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/British_Rowing\", \"dbpedia\": \"http://dbpedia.org/resource/British_Rowing\"}, {\"begin\": 2092, \"end\": 2106, \"title\": \"http://dbpedia.org/resource/British_Rowing\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"British Rowing\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/British_Rowing\", \"dbpedia\": \"http://dbpedia.org/resource/British_Rowing\"}, {\"begin\": 2125, \"end\": 2143, 