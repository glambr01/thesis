, \"from\": 848, \"to\": 854}, {\"ngram\": \"rounds\", \"from\": 859, \"to\": 865}, {\"ngram\": \"the judges\", \"from\": 876, \"to\": 886}, {\"ngram\": \"his or her opponent\", \"from\": 892, \"to\": 911}, {\"ngram\": \"a solo battle\", \"from\": 915, \"to\": 928}, {\"ngram\": \"the next round\", \"from\": 945, \"to\": 959}]}, {\"sentence\": \"Breaking is an urban, improvisational dance technique, typically performed to hip-hop music with drum breaks.\", \"from\": 962, \"to\": 1071, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Breaking\", \"from\": 962, \"to\": 970}, {\"ngram\": \"an urban, improvisational dance technique\", \"from\": 974, \"to\": 1015}, {\"ngram\": \"hip-hop music\", \"from\": 1040, \"to\": 1053}, {\"ngram\": \"drum breaks\", \"from\": 1059, \"to\": 1070}]}, {\"sentence\": \"It comprises four kinds of movements: top-rock, down-rock, power moves and freezes.\", \"from\": 1073, \"to\": 1156, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"four kinds\", \"from\": 1086, \"to\": 1096}, {\"ngram\": \"movements\", \"from\": 1100, \"to\": 1109}, {\"ngram\": \"top-rock\", \"from\": 1111, \"to\": 1119}, {\"ngram\": \"rock\", \"from\": 1126, \"to\": 1130}, {\"ngram\": \"power moves\", \"from\": 1132, \"to\": 1143}]}, {\"sentence\": \"The roots of Breaking lie in the emergence of hip-hop culture in the United States.\", \"from\": 1158, \"to\": 1241, \"entities\": [{\"begin\": 1227, \"end\": 1240, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.7546521660025998, \"rank\": 0.3250957625052087, \"text\": \"United States\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"The roots\", \"from\": 1158, \"to\": 1167}, {\"ngram\": \"Breaking lie\", \"from\": 1171, \"to\": 1183}, {\"ngram\": \"the emergence\", \"from\": 1187, \"to\": 1200}, {\"ngram\": \"hip-hop culture\", \"from\": 1204, \"to\": 1219}]}, {\"sen