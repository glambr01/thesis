ties\": [], \"noun_phrases\": [{\"ngram\": \"Another Olympic fan\", \"from\": 1704, \"to\": 1723}, {\"ngram\": \"Reddit\", \"from\": 1733, \"to\": 1739}]}, {\"sentence\": \"Not interesting and the judging criteria are all off and completely subjective, I read the rulebook and no thanks.'\", \"from\": 1763, \"to\": 1878, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the judging criteria\", \"from\": 1783, \"to\": 1803}, {\"ngram\": \"the rulebook\", \"from\": 1850, \"to\": 1862}, {\"ngram\": \"no thanks\", \"from\": 1867, \"to\": 1876}]}, {\"sentence\": \"Mathis, a 16-year-old breakdancer based in Paris, toldCond\\u00e9 Nast Traveler: '[It is] good and not good at the same time.\", \"from\": 1880, \"to\": 1999, \"entities\": [{\"begin\": 1923, \"end\": 1928, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999613465, \"rank\": 3.8445502056888605e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"a 16-year-old breakdancer\", \"from\": 1888, \"to\": 1913}, {\"ngram\": \"toldCond\\u00e9 Nast Traveler\", \"from\": 1930, \"to\": 1953}, {\"ngram\": \"the same time\", \"from\": 1985, \"to\": 1998}]}, {\"sentence\": \"If we can not perform the 'right' way, we will be seen as no good.'\", \"from\": 2000, \"to\": 2067, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the 'right' way\", \"from\": 2022, \"to\": 2037}, {\"ngram\": \"no good\", \"from\": 2058, \"to\": 2065}]}, {\"sentence\": \"Anne Nguyen, a dancer, choreographer, and founder of the Paris-based dance company Par Terre, added: '[B-Boys and B-Girls] will be strategic, planning everything from A to Z, to get the high scores.\", \"from\": 2069, \"to\": 2267, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Anne Nguyen\", \"from\": 2069, \"to\": 2080}, {\"ngram\": \"a dancer\", \"from\": 2082, \"to\": 2090}, {\"ngram\": \"choreographer\", \"from\": 2092, \"to\": 2105}, {\"ngram\": \"founder\", \"from\": 2111, \"to\": 2118}, {\"ngram\": \"the Paris-based dance company\", \"from\": 2122, \"to\": 2151}, {\"ngram\": \"Par Terre\", \"from\": 2152, \"to\": 2161}, {\"ngram\": \"everything\", \"from\": 2220, \"to\": 2230}, {\"ngram\": \"Z\", \"from\": 2241, \"to\": 2242}, {\"ngram\": \"the high scores\", \"from\": 2251, \"to\": 2266}]}, {\"sentence\": \"'Less improvisation, fewer complex figures, a lot less risk-taking.\", \"from\": 2269, \"to\": 2336, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"'Less improvisation\", \"from\": 2269, \"to\": 2288}, {\"ngram\": \"fewer complex figures\", \"from\": 2290, \"to\": 2311}, {\"ngram\": \"a lot less risk-taking\", \"from\": 2313, \"to\": 2335}]}, {\"sentence\": \"It means less freedom.'\", \"from\": 2337, \"to\": 2360, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"less freedom\", \"from\": 2346, \"to\": 2358}]}, {\"sentence\": \"Bruce Ykanji, the founder of Juste Debout, one of the largest annual street dance events in the world, said: 'Hip-hop, regardless of style, cannot be considered a sport because then it means every physical art form should be called a sport.\", \"from\": 2362, \"to\": 2602, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Bruce Ykanji\", \"from\": 2362, \"to\": 2374}, {\"ngram\": \"the founder\", \"from\": 2376, \"to\": 2387}, {\"ngram\": \"Juste Debout\", \"from\": 2391, \"to\": 2403}, {\"ngram\": \"the largest annual street dance events\", \"from\": 2412, \"to\": 2450}, {\"ngram\": \"the world\", \"from\": 2454, \"to\": 2463}, {\"ngram\": \"style\", \"from\": 2495, \"to\": 2500}, {\"ngram\": \"a sport\", \"from\": 2523, \"to\": 2530}, {\"ngram\": \"every physical art form\", \"from\": 2553, \"to\": 2576}, {\"ngram\": \"a sport\", \"from\": 2594, \"to\": 2601}]}, {\"sentence\": \"The elite do this because they do not appreciate our culture as it is.'\", \"from\": 2603, \"to\": 2674, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The elite\", \"from\": 2603, \"to\": 2612}, {\"ngram\": \"our culture\", \"from\": 2652, \"to\": 2663}]}, {\"sentence\": \"Loughborough University's Professor Claire Warden, an expert in performance and physical culture,said: 'I describe Breaking as both a sport and performance art.\", \"from\": 2676, \"to\": 2836, \"entities\": [{\"begin\": 2676, \"end\": 2699, \"title\": \"http://dbpedia.org/resource/Loughborough_University\", \"score\": 1.0, \"rank\": 3.8164240300699236e-16, \"text\": \"Loughborough University\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/Loughborough_University\", \"dbpedia\": \"http://dbpedia.org/resource/Loughborough_University\"}, {\"begin\": 2719, \"end\": 2725, \"title\": \"http://dbpedia.org/resource/Blizzard_Entertainment\", \"score\": 0.9999336358212931, \"rank\": 6.636679656408698e-05, \"text\": \"Warden\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Blizzard_Entertainment\", \"dbpedia\": \"http://dbpedia.org/resource/Blizzard_Entertainment\"}], \"noun_phrases\": [{\"ngram\": \"an expert\", \"from\": 2727, \"to\": 2736}, {\"ngram\": \"performance\", \"from\": 2740, \"to\": 2751}, {\"ngram\": \"physical culture\", \"from\": 2756, \"to\": 2772}, {\"ngram\": \"Breaking\", \"from\": 2791, \"to\": 2799}, {\"ngram\": \"both a sport and performance art\", \"from\": 2803, \"to\": 2835}]}, {\"sentence\": \"'It's extremely athletic but it's also performative in that it is artistic.\", \"from\": 2838, \"to\": 2913, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"There will always be events at the Olympics that look at who can run the fastest, who can swim the fastest, and so on, but I do not think that we should restrict sports to these types of events.\", \"from\": 2914, \"to\": 3108, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"events\", \"from\": 2935, \"to\": 2941}, {\"ngram\": \"the Olympics\", \"from\": 2945, \"to\": 2957}