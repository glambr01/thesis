"{\"uid\": \"jamaicaobserver.com-2024-08-09-parisolympics-olympic-dream-shattered-says-jackson\", \"noun_phrases\": [{\"sentence\": \"KINGSTON, Jamaica- Jamaica's Shericka Jackson lamented the unexpected and disappointing end to her 2024 Paris Olympics campaign in a heartfelt message posted to her Instagram account on Friday.\", \"from\": 0, \"to\": 193, \"entities\": [{\"begin\": 19, \"end\": 26, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.99999994844825, \"rank\": 5.1545186437870925e-08, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}, {\"begin\": 29, \"end\": 45, \"title\": \"http://dbpedia.org/resource/Shericka_Jackson\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Shericka Jackson\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Shericka_Jackson\", \"dbpedia\": \"http://dbpedia.org/resource/Shericka_Jackson\"}, {\"begin\": 165, \"end\": 174, \"title\": \"http://dbpedia.org/resource/Instagram\", \"score\": 1.0, \"rank\": 8.755034491539266e-16, \"text\": \"Instagram\", \"types\": [\"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Instagram\", \"dbpedia\": \"http://dbpedia.org/resource/Instagram\"}], \"noun_phrases\": [{\"ngram\": \"KINGSTON\", \"from\": 0, \"to\": 8}, {\"ngram\": \"the unexpected and disappointing end\", \"from\": 55, \"to\": 91}, {\"ngram\": \"her 2024 Paris Olympics campaign\", \"from\": 95, \"to\": 127}, {\"ngram\": \"a heartfelt message\", \"from\": 131, \"to\": 150}, {\"ngram\": \"account\", \"from\": 175, \"to\": 182}, {\"ngram\": \"Friday\", \"from\": 186, \"to\": 192}]}, {\"sentence\": \"Jackson, who was the favourite to win the 200m at the Olympics pulled out of the event due to an injury, presumably the same one that caused her to withdraw from the 100m earlier.\", \"from\": 195, \"to\": 374, \"entities\": [{\"begin\": 195, \"end\": 202, \"title\":