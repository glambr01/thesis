dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 3.1694077042774258e-27, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 2258, \"end\": 2262, \"title\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"score\": 0.9999999988772288, \"rank\": 1.1229036881371953e-09, \"text\": \"Bach\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"dbpedia\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\"}], \"noun_phrases\": [{\"ngram\": \"the gender issue\", \"from\": 2240, \"to\": 2256}, {\"ngram\": \"someone\", \"from\": 2273, \"to\": 2280}, {\"ngram\": \"us\", \"from\": 2295, \"to\": 2297}, {\"ngram\": \"a scientifically solid system\", \"from\": 2298, \"to\": 2327}, {\"ngram\": \"men\", \"from\": 2344, \"to\": 2347}, {\"ngram\": \"women\", \"from\": 2352, \"to\": 2357}, {\"ngram\": \"the first ones\", \"from\": 2366, \"to\": 2380}]}, {\"sentence\": \"\\\"We do not like this uncertainty, we do not like it for the overall situation, we would be more than pleased to look into it.\", \"from\": 2392, \"to\": 2517, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this uncertainty\", \"from\": 2408, \"to\": 2424}, {\"ngram\": \"the overall situation\", \"from\": 2448, \"to\": 2469}]}, {\"sentence\": \"\\\"But what is not possible is that somebody saying 'this is not a women' just by looking at somebody or falling prey to a defamation campaign by a not credible organisation with highly political interests.\\\"\", \"from\": 2519, \"to\": 2724, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"somebody\", \"from\": 2553, \"to\": 2561}, {\"ngram\": \"a women\", \"from\": 2582, \"to\": 2589}, {\"ngram\": \"somebody\", \"from\": 2610, \"to\": 2618}, {\"ngram\": \"falling prey\", \"from\": 26