ce\": \"His experience, paired with his calm demeanor, made him the perfect person to put in charge of the MARTA rail system.\", \"from\": 724, \"to\": 841, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"His experience\", \"from\": 724, \"to\": 738}, {\"ngram\": \"his calm demeanor\", \"from\": 752, \"to\": 769}, {\"ngram\": \"charge\", \"from\": 809, \"to\": 815}, {\"ngram\": \"the MARTA rail system\", \"from\": 819, \"to\": 840}]}, {\"sentence\": \"The trains would have to be prepared to move a million fans a day.\", \"from\": 842, \"to\": 908, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The trains\", \"from\": 842, \"to\": 852}, {\"ngram\": \"a million fans\", \"from\": 887, \"to\": 901}]}, {\"sentence\": \"\\\"We took out seats (from the train cars); it's like moving cattle,\\\" Irwin said.\", \"from\": 910, \"to\": 989, \"entities\": [{\"begin\": 978, \"end\": 983, \"title\": \"http://dbpedia.org/resource/Shire_of_Irwin\", \"score\": 0.9997810197032264, \"rank\": 0.00021893102689744134, \"text\": \"Irwin\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Shire_of_Irwin\", \"dbpedia\": \"http://dbpedia.org/resource/Shire_of_Irwin\"}], \"noun_phrases\": [{\"ngram\": \"seats\", \"from\": 923, \"to\": 928}, {\"ngram\": \"the train cars\", \"from\": 935, \"to\": 949}, {\"ngram\": \"cattle\", \"from\": 969, \"to\": 975}]}, {\"sentence\": \"\\\"So that car is resting on the truck.\", \"from\": 990, \"to\": 1027, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"that car\", \"from\": 994, \"to\": 1002}, {\"ngram\": \"the truck\", \"from\": 1017, \"to\": 1026}]}, {\"sentence\": \"It's living on the springs.\", \"from\": 1028, \"to\": 1055, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the springs\", \"from\": 1043, \"to\": 1054}]}, {\"sentence\": \"(There is) no cushioning, none.\\\"\", \"from\": 1056, \"to\": 1088, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"no cushioning\", \"from\": 1067, \"to\": 1080}, {\"ngram\": \"none\", \"from\": 1082, \"to\": 1086}]}, {\"sentence\": \"From the cars themselves to the personnel, Irwin was the lead of moving fans and Atlantans.\", \"from\": 1090, \"to\": 1181, \"entities\": [{\"begin\": 1133, \"end\": 1138, \"title\": \"http://dbpedia.org/resource/Shire_of_Irwin\", \"score\": 0.9997810197032264, \"rank\": 0.00021893102689744134, \"text\": \"Irwin\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Shire_of_Irwin\", \"dbpedia\": \"http://dbpedia.org/resource/Shire_of_Irwin\"}], \"noun_phrases\": [{\"ngram\": \"the cars\", \"from\": 1095, \"to\": 1103}, {\"ngram\": \"the personnel\", \"from\": 1118, \"to\": 1131}, {\"ngram\": \"the lead\", \"from\": 1143, \"to\": 1151}, {\"ngram\": \"moving fans\", \"from\": 1155, \"to\": 1166}, {\"ngram\": \"Atlantans\", \"from\": 1171, \"to\": 1180}]}, {\"sentence\": \"He also had the idea of putting technicians at the stations so if an issue happened, it could be fixed quickly.\", \"from\": 1182, \"to\": 1293, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the idea\", \"from\": 1194, \"to\": 1202}, {\"ngram\": \"technicians\", \"from\": 1214, \"to\": 1225}, {\"ngram\": \"the stations\", \"from\": 1229, \"to\": 1241}, {\"ngram\": \"an issue\", \"from\": 1248, \"to\": 1256}]}, {\"sentence\": \"\\\"We had a derailment during the Olympics and I needed that like a hole in the head,\\\" Irwin said.\", \"from\": 1295, \"to\": 1391, \"entities\": [{\"begin\": 1380, \"end\": 1385, \"title\": \"http://dbpedia.org/resource/Shire_of_Irwin\", \"score\": 0.9997810197032264, \"rank\": 0.00021893102689744134, \"text\": \"Irwin\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Shire_of_Irwin\", \"dbpedia\": \"http://dbpedia.org/resource/Shire_of_Irwin\"}], \"noun_phrases\": [{\"ngram\": \"a derailment\", \"from\": 1303, \"to\": 1315}, {\"ngram\": \"the Olympics\", \"from\": 1323, \"to\": 1335}, {\"ngram\": \"a hole\", \"from\": 1359, \"to\": 1365}, {\"ngram\": \"the head\", \"from\": 136