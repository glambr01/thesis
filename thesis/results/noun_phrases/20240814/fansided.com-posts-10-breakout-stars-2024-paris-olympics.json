\": 1032}]}, {\"sentence\": \"In most respects, it was a disappointing Olympics for Jamaica.\", \"from\": 1035, \"to\": 1097, \"entities\": [{\"begin\": 1089, \"end\": 1096, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 1.0, \"rank\": 1.1689141678948826e-19, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}], \"noun_phrases\": [{\"ngram\": \"most respects\", \"from\": 1038, \"to\": 1051}, {\"ngram\": \"a disappointing Olympics\", \"from\": 1060, \"to\": 1084}]}, {\"sentence\": \"The Caribbean nation has become the most dominant force in modern track and field, producing not only Usain Bolt, but multiple generations of sprinting champions, both male and female.\", \"from\": 1098, \"to\": 1282, \"entities\": [{\"begin\": 1200, \"end\": 1210, \"title\": \"http://dbpedia.org/resource/Usain_Bolt\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Usain Bolt\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Usain_Bolt\", \"dbpedia\": \"http://dbpedia.org/resource/Usain_Bolt\"}], \"noun_phrases\": [{\"ngram\": \"The Caribbean nation\", \"from\": 1098, \"to\": 1118}, {\"ngram\": \"the most dominant force\", \"from\": 1130, \"to\": 1153}, {\"ngram\": \"modern track\", \"from\": 1157, \"to\": 1169}, {\"ngram\": \"field\", \"from\": 1174, \"to\": 1179}, {\"ngram\": \"multiple generations\", \"from\": 1216, \"to\": 1236}, {\"ngram\": \"sprinting champions\", \"from\": 1240, \"to\": 1259}, {\"ngram\": \"both male\", \"from\": 1261, \"to\": 1270}, {\"ngram\": \"female\", \"from\": 1275, \"to\": 1281}]}, {\"sentence\": \"In Paris, however, Jamaica managed only six medals, with only Kishane Thompson's heartbreaking silver in the 100m and Rasheed Broadbell's bronze in the 110m hurdles coming on the track.\", \"from\": 1283, \"to\": 1468, \"entities\": [{\"begin\": 1286, \"end\": 1291, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.1166910632794817e-31, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 1302, \"end\": 1309, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 1.0, \"rank\": 1.1689141678948826e-19, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}, {\"begin\": 1353, \"end\": 1361, \"title\": \"http://dbpedia.org/resource/Klay_Thompson\", \"score\": 0.9999999933315848, \"rank\": 6.667630940924504e-09, \"text\": \"Thompson\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Klay_Thompson\", \"dbpedia\": \"http://dbpedia.org/resource/Klay_Thompson\"}], \"noun_phrases\": [{\"ngram\": \"only six medals\", \"from\": 1318, \"to\": 1333}, {\"ngram\": \"the 100m\", \"from\": 1388, \"to\": 1396}, {\"ngram\": \"Rasheed Broadbell's bronze\", \"from\": 1401, \"to\": 1427}, {\"ngram\": \"the 110m hurdles\", \"from\": 1431, \"to\": 1447}, {\"ngram\": \"the track\", \"from\": 1458, \"to\": 1467}]}, {\"sentence\": \"To the surprise of many, Jamaica did make great strides in the field events, with a silver in the women's triple jump, a silver in the men's long jump, and a bronze in the men's shot put.\", \"from\": 1470, \"to\": 1657, \"entities\": [{\"begin\": 1495, \"end\": 1502, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 1.0, \"rank\": 1.1689141678948826e-19, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}], \"noun_phrases\": [{\"ngram\": \"the surprise\", \"from\": 1473, \"to\": 1485}, {\"ngram\": \"great strides\", \"from\": 1512, \"to\": 1525}, {\"ngram\": \"the field events\", \"from\": 1529, \"to\": 1545}, {\"ngram\": \"a silver\", \"from\": 155