\": [{\"ngram\": \"Stona\", \"from\": 2347, \"to\": 2352}, {\"ngram\": \"a fascinating guy\", \"from\": 2356, \"to\": 2373}]}, {\"sentence\": \"He attended college in the U.S., starring on the track and field teams at Clemson and Arkansas.\", \"from\": 2375, \"to\": 2470, \"entities\": [{\"begin\": 2449, \"end\": 2456, \"title\": \"http://dbpedia.org/resource/Clemson_Tigers_football\", \"score\": 0.681804635066203, \"rank\": 0.4604916842134588, \"text\": \"Clemson\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Clemson_Tigers_football\", \"dbpedia\": \"http://dbpedia.org/resource/Clemson_Tigers_football\"}, {\"begin\": 2461, \"end\": 2469, \"title\": \"http://dbpedia.org/resource/Arkansas_Razorbacks\", \"score\": 0.9905475412214951, \"rank\": 0.00947793259879299, \"text\": \"Arkansas\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/Arkansas_Razorbacks\", \"dbpedia\": \"http://dbpedia.org/resource/Arkansas_Razorbacks\"}], \"noun_phrases\": [{\"ngram\": \"college\", \"from\": 2387, \"to\": 2394}, {\"ngram\": \"the U.S.\", \"from\": 2398, \"to\": 2406}, {\"ngram\": \"the track and field teams\", \"from\": 2420, \"to\": 2445}]}, {\"sentence\": \"He attended minicamps with theGreen Bay Packersand New Orleans Saints earlier this summer despite never playing football before.\", \"from\": 2471, \"to\": 2599, \"entities\": [{\"begin\": 2522, \"end\": 2540, \"title\": \"http://dbpedia.org/resource/New_Orleans_Saints\", \"score\": 1.0, \"rank\": 5.133953865092153e-16, \"text\": \"New Orleans Saints\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/New_Orleans_Saints\", \"dbpedia\": \"http://dbpedia.org/resource/New_Orleans_Saints\"}], \"noun_phrases\": [{\"ngram\": \"minicamps\", \"from\": 2483, \"to\": 2492}, {\"ngram\": \"football\", \"from\": 2583, \"to\": 2591}]}, {\"sentence\": \"And he's coached by now-three-time Olympic shot put gold medalist Ryan Crouser.\", \"