"{\"uid\": \"cronkitenews.azpbs.org-2024-08-14-ioc-team-usa-athlete-mental-wellness-olympics-2024\", \"noun_phrases\": [{\"sentence\": \"Cronkite News PARIS - Even though the Paris Games are over, a commitment to the mental health of athletes is not.\", \"from\": 0, \"to\": 114, \"entities\": [{\"begin\": 0, \"end\": 13, \"title\": \"http://dbpedia.org/resource/Walter_Cronkite_School_of_Journalism_and_Mass_Communication\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Cronkite News\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/Walter_Cronkite_School_of_Journalism_and_Mass_Communication\", \"dbpedia\": \"http://dbpedia.org/resource/Walter_Cronkite_School_of_Journalism_and_Mass_Communication\"}], \"noun_phrases\": [{\"ngram\": \"the Paris Games\", \"from\": 34, \"to\": 49}, {\"ngram\": \"a commitment\", \"from\": 60, \"to\": 72}, {\"ngram\": \"the mental health\", \"from\": 76, \"to\": 93}, {\"ngram\": \"athletes\", \"from\": 97, \"to\": 105}]}, {\"sentence\": \"While it's the pinnacle of sporting achievement, the Olympics create a pressure-filled environment for athletes that almost no other competition can mimic.\", \"from\": 116, \"to\": 271, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the pinnacle\", \"from\": 127, \"to\": 139}, {\"ngram\": \"sporting achievement\", \"from\": 143, \"to\": 163}, {\"ngram\": \"the Olympics\", \"from\": 165, \"to\": 177}, {\"ngram\": \"a pressure-filled environment\", \"from\": 185, \"to\": 214}, {\"ngram\": \"athletes\", \"from\": 219, \"to\": 227}, {\"ngram\": \"almost no other competition\", \"from\": 233, \"to\": 260}]}, {\"sentence\": \"The weight of a nation, the expectations of greatness and the knowledge that this may be the only chance at gold all take a toll on an Olympian's mental health.\", \"from\": 272, \"to\": 432, \"entities\": [{\"begin\": 407, \"end\": 415, \"title\": \"http://dbpedia.org/resource/Olympic_Games\", \"score\": 1.0, \"rank\": 7.51305793891698e-14, \"text\": \"Olympian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games\"}], \"noun_phrases\": [{\"ngram\": \"The weight\", \"from\": 272, \"to\": 282}, {\"ngram\": \"a nation\", \"from\": 286, \"to\": 294}, {\"ngram\": \"the expectations\", \"from\": 296, \"to\": 312}, {\"ngram\": \"greatness\", \"from\": 316, \"to\": 325}, {\"ngram\": \"the knowledge\", \"from\": 330, \"to\": 343}, {\"ngram\": \"the only chance\", \"from\": 361, \"to\": 376}, {\"ngram\": \"gold\", \"from\": 380, \"to\": 384}, {\"ngram\": \"a toll\", \"from\": 394, \"to\": 400}]}, {\"sentence\": \"The IOC and Team USA are proactive in protecting the athletes' mental health as well as finding ways to help block out social media attacks.\", \"from\": 434, \"to\": 574, \"entities\": [{\"begin\": 438, \"end\": 441, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 4.783864972487397e-27, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 446, \"end\": 454, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999999999972715, \"rank\": 2.7212326095557564e-12, \"text\": \"Team USA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"the athletes' mental health\", \"from\": 483, \"to\": 510}, {\"ngram\": \"ways\", \"from\": 530, \"to\": 534}, {\"ngram\": \"social media attacks\", \"from\": 553, \"to\": 573}]}, {\"sentence\": \"The Paris Olympics highlighted that mental health awareness continues to grow through therapy, high-tech relaxation and AI.\", \"from\": 575, \"to\": 698, \"entities\": [{\"begin\": 579, \"end\": 593, \"title\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Paris Olympics\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/1924_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/1924_Summer_Olympics\"}, {\"begin\": 695, \"end\": 697, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 1.0, \"rank\": 4.291920537364381e-18, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}], \"noun_phrases\": [{\"ngram\": \"mental health awareness\", \"from\": 611, \"to\": 634}, {\"ngram\": \"therapy\", \"from\": 661, \"to\": 668}, {\"ngram\": \"high-tech relaxation\", \"from\": 670, \"to\": 690}]}, {\"sentence\": \"\\\"Seventy percent of athletes only experience one Olympics,\\\" said Kirsty Burrows, the head of the IOC's Safe Sport Unit.\", \"from\": 700, \"to\": 820, \"entities\": [{\"begin\": 798, \"end\": 801, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 4.783864972487397e-27, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"Seventy percent\", \"from\": 701, \"to\": 716}, {\"ngram\": \"athletes\", \"from\": 720, \"to\": 728}, {\"ngram\": \"one Olympics\", \"from\": 745, \"to\": 757}, {\"ngram\": \"Kirsty Burrows\", \"from\": 765, \"to\": 779}, {\"ngram\": \"the head\", \"from\": 781, \"to\": 789}]}, {\"sentence\": \"\\\"So, for us, it's about protecting everybody and ensuring not just protection but also welfare support.\\\"\", \"from\": 821, \"to\": 925, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"us\", \"from\": 830, \"to\": 832}, {\"ngram\": \"everybody\", \"from\": 856, \"to\": 865}, {\"ngram\": \"not just protection\", \"from\": 879, \"to\": 898}, {\"ngram\": \"welfare support\", \"from\": 908, \"to\": 923}]}, {\"sentence\": \"Established in 2022, the IOC Safe Sport Unit introduced new programs and protections for athletes during and after the Olympics.\", \"from\": 927, \"to\": 1055, \"entities\": [{\"begin\": 952, \"end\": 955, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 4.783864972487397e-27, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"new programs\", \"from\": 983, \"to\": 995}, {\"ngram\": \"protections\", \"from\": 1000, \"to\": 1011}, {\"ngram\": \"athletes\", \"from\": 1016, \"to\": 1024}, {\"ngram\": \"the Olympics\", \"from\": 1042, \"to\": 1054}]}, {\"sentence\": \"According to the IOC's website, the organization allocates $10 million per Olympiad toward mental health initiatives.\", \"from\": 1056, \"to\": 1173, \"entities\": [{\"begin\": 1073, \"end\": 1076, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 4.783864972487397e-27, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"the organization\", \"from\": 1088, \"to\": 1104}, {\"ngram\": \"Olympiad\", \"from\": 1131, \"to\": 1139}, {\"ngram\": \"mental health initiatives\", \"from\": 1147, \"to\": 1172}]}, {\"sentence\": \"This includes a helpline with 70 different languages, 148 accredited welfare officers and 41 safeguarding focal points for all international federations.\", \"from\": 1174, \"to\": 1327, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a helpline\", \"from\": 1188, \"to\": 1198}, {\"ngram\": \"70 different languages\", \"from\": 1204, \"to\": 1226}, {\"ngram\": \"148 accredited welfare officers\", \"from\": 1228, \"to\": 1259}, {\"ngram\": \"41 safeguarding focal points\", \"from\": 1264, \"to\": 1292}, {\"ngram\": \"all international federations\", \"from\": 1297, \"to\": 1326}]}, {\"sentence\": \"However, the IOC's most innovative initiative uses AI technology that has grown exponentially over the past half decade.\", \"from\": 1329, \"to\": 1449, \"entities\": [{\"begin\": 1342, \"end\": 1345, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 4.783864972487397e-27, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 1380, \"end\": 1382, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 1.0, \"rank\": 4.291920537364381e-18, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}], \"noun_phrases\": [{\"ngram\": \"the past half decade\", \"from\": 1428, \"to\": 1448}]}, {\"sentence\": \"The Cyber Abuse Prevention Service is \\\"harnessing the power of AI to provide record-breaking coverage\\\" for Olympic and Paralympic athletes, staff and officials.\", \"from\": 1450, \"to\": 1610, \"entities\": [{\"begin\": 1513, \"end\": 1515, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 1.0, \"rank\": 4.291920537364381e-18, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}], \"noun_phrases\": [{\"ngram\": \"The Cyber Abuse Prevention Service\", \"from\": 1450, \"to\": 1484}, {\"ngram\": \"the power\", \"from\": 1500, \"to\": 1509}, {\"ngram\": \"record-breaking coverage\", \"from\": 1527, \"to\": 1551}, {\"ngram\": \"Olympic and Paralympic athletes\", \"from\": 1557, \"to\": 1588}, {\"ngram\": \"staff\", \"from\": 1590, \"to\": 1595}, {\"ngram\": \"officials\", \"from\": 1600, \"to\": 1609}]}, {\"sentence\": \"The program uses AI to flag and eliminate abusive messages toward athletes across social media platforms, not including private messages.\", \"from\": 1611, \"to\": 1748, \"entities\": [{\"begin\": 1628, \"end\": 1630, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 1.0, \"rank\": 4.291920537364381e-18, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}], \"noun_phrases\": [{\"ngram\": \"The program\", \"from\": 1611, \"to\": 1622}, {\"ngram\": \"abusive messages\", \"from\": 1653, \"to\": 1669}, {\"ngram\": \"athletes\", \"from\": 1677, \"to\": 1685}, {\"ngram\": \"social media platforms\", \"from\": 1693, \"to\": 1715}, {\"ngram\": \"private messages\", \"from\": 1731, \"to\": 1747}]}, {\"sentence\": \"\\\"These are not just tools,\\\" Kirsty said.\", \"from\": 1750, \"to\": 1790, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"just tools\", \"from\": 1765, \"to\": 1775}, {\"ngram\": \"Kirsty\", \"from\": 1778, \"to\": 1784}]}, {\"sentence\": \"\\\"They are fully integrated within our systems.\", \"from\": 1791, \"to\": 1837, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"our systems\", \"from\": 1825, \"to\": 1836}]}, {\"sentence\": \"So whenever something is flagged, it's flagged to the platform for removal.\", \"from\": 1838, \"to\": 1913, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"something\", \"from\": 1850, \"to\": 1859}, {\"ngram\": \"the platform\", \"from\": 1888, \"to\": 1900}, {\"ngram\": \"removal\", \"from\": 1905, \"to\": 1912}]}, {\"sentence\": \"There is a potential to package information that is criminal for further proceedings, and our safeguarding team is fully aware.\\\"\", \"from\": 1914, \"to\": 2042, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a potential\", \"from\": 1923, \"to\": 1934}, {\"ngram\": \"information\", \"from\": 1946, \"to\": 1957}, {\"ngram\": \"further proceedings\", \"from\": 1979, \"to\": 1998}, {\"ngram\": \"our safeguarding team\", \"from\": 2004, \"to\": 2025}]}, {\"sentence\": \"Online platforms have been one of the biggest threats to athletes' mental health since social media's creation.\", \"from\": 2044, \"to\": 2155, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Online platforms\", \"from\": 2044, \"to\": 2060}, {\"ngram\": \"the biggest threats\", \"from\": 2078, \"to\": 2097}, {\"ngram\": \"athletes' mental health\", \"from\": 2101, \"to\": 2124}, {\"ngram\": \"social media's creation\", \"from\": 2131, \"to\": 2154}]}, {\"sentence\": \"Situations, such as Simone Biles getting the \\\"twisties\\\" - a gymnastics phenomenon that can happen while an athlete is in the air, causing them to lose their sense of direction - have given instigators excuses to send hateful messages and criticism toward athletes.\", \"from\": 2156, \"to\": 2420, \"entities\": [{\"begin\": 2176, \"end\": 2188, \"title\": \"http://dbpedia.org/resource/Simone_Biles\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Simone Biles\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Simone_Biles\", \"dbpedia\": \"http://dbpedia.org/resource/Simone_Biles\"}], \"noun_phrases\": [{\"ngram\": \"Situations\", \"from\": 2156, \"to\": 2166}, {\"ngram\": \"the \\\"twisties\", \"from\": 2197, \"to\": 2210}, {\"ngram\": \"a gymnastics phenomenon\", \"from\": 2214, \"to\": 2237}, {\"ngram\": \"an athlete\", \"from\": 2260, \"to\": 2270}, {\"ngram\": \"the air\", \"from\": 2277, \"to\": 2284}, {\"ngram\": \"their sense\", \"from\": 2307, \"to\": 2318}, {\"ngram\": \"direction\", \"from\": 2322, \"to\": 2331}, {\"ngram\": \"instigators\", \"from\": 2345, \"to\": 2356}, {\"ngram\": \"excuses\", \"from\": 2357, \"to\": 2364}, {\"ngram\": \"hateful messages\", \"from\": 2373, \"to\": 2389}, {\"ngram\": \"criticism\", \"from\": 2394, \"to\": 2403}, {\"ngram\": \"athletes\", \"from\": 2411, \"to\": 2419}]}, {\"sentence\": \"Now, the IOC's use of AI has helped mitigate that threat.\", \"from\": 2421, \"to\": 2478, \"entities\": [{\"begin\": 2430, \"end\": 2433, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 4.783864972487397e-27, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 2443, \"end\": 2445, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 1.0, \"rank\": 4.291920537364381e-18, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}], \"noun_phrases\": [{\"ngram\": \"that threat\", \"from\": 2466, \"to\": 2477}]}, {\"sentence\": \"The Safe Support Unit also introduced \\\"Athlete 365 Mind Zones\\\" areas in the Olympic Village.\", \"from\": 2480, \"to\": 2572, \"entities\": [{\"begin\": 2556, \"end\": 2571, \"title\": \"http://dbpedia.org/resource/Olympic_Village\", \"score\": 1.0, \"rank\": 8.393130481672608e-20, \"text\": \"Olympic Village\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Village\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Village\"}], \"noun_phrases\": [{\"ngram\": \"The Safe Support Unit\", \"from\": 2480, \"to\": 2501}, {\"ngram\": \"\\\"Athlete 365 Mind Zones\\\" areas\", \"from\": 2518, \"to\": 2548}]}, {\"sentence\": \"Located next to the village gym, the Mind Zones used VR headsets to help athletes practice meditation as well as provide other services.\", \"from\": 2573, \"to\