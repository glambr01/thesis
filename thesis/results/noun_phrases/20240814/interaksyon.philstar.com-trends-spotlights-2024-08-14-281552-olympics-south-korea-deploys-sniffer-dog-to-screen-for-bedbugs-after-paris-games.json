, \"end\": 624, \"title\": \"http://dbpedia.org/resource/South_Korea\", \"score\": 0.992519290241582, \"rank\": 0.00753705770316867, \"text\": \"South Korea\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/South_Korea\", \"dbpedia\": \"http://dbpedia.org/resource/South_Korea\"}, {\"begin\": 757, \"end\": 764, \"title\": \"http://dbpedia.org/resource/Incheon_International_Airport\", \"score\": 0.9553444806193796, \"rank\": 0.046742820274963064, \"text\": \"Incheon\", \"types\": [\"Q1248784\"], \"wikid\": \"http://dbpedia.org/resource/Incheon_International_Airport\", \"dbpedia\": \"http://dbpedia.org/resource/Incheon_International_Airport\"}], \"noun_phrases\": [{\"ngram\": \"The pest control company\", \"from\": 569, \"to\": 593}, {\"ngram\": \"security\", \"from\": 641, \"to\": 649}, {\"ngram\": \"transportation\", \"from\": 654, \"to\": 668}, {\"ngram\": \"the Disease Control and Prevention Agency\", \"from\": 681, \"to\": 722}, {\"ngram\": \"airlines\", \"from\": 744, \"to\": 752}, {\"ngram\": \"travelers\", \"from\": 783, \"to\": 792}, {\"ngram\": \"arrival\", \"from\": 796, \"to\": 803}]}, {\"sentence\": \"Last year, authorities in Paris raced to contain anationwide panicover bedbugs as the city geared up for the Olympics, worried that the tiny wingless critters might ruin the event and conducted a campaign to root out any infestation.\", \"from\": 806, \"to\": 1039, \"entities\": [{\"begin\": 832, \"end\": 837, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999117719692, \"rank\": 8.822803855212434e-08, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"authorities\", \"from\": 817, \"to\": 828}, {\"ngram\": \"anationwide\", \"from\": 855, \"to\": 866}, {\"ngram\": \"panicover bedbugs\", \"from\": 867, \"to\": 884}, {\"ngram\": \"the city\", \"from\": 888, \"to\": 896}, {\"ngram\": \"the Olym