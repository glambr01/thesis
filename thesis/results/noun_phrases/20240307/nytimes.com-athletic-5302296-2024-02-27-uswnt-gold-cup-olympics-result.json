ities\": [], \"noun_phrases\": []}, {\"sentence\": \"Instead, 34-year-old, 217-capped Morgan came on after the break.\", \"from\": 1971, \"to\": 2035, \"entities\": [{\"begin\": 2004, \"end\": 2010, \"title\": \"http://dbpedia.org/resource/Morgan_le_Fay\", \"score\": 0.9989620366913162, \"rank\": 0.001039041781191541, \"text\": \"Morgan\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Morgan_le_Fay\", \"dbpedia\": \"http://dbpedia.org/resource/Morgan_le_Fay\"}], \"noun_phrases\": [{\"ngram\": \"the break\", \"from\": 2025, \"to\": 2034}]}, {\"sentence\": \"That does not tell interim head coach Twila Kilgoreor the incoming Emma Hayesanything about this team right now.\", \"from\": 2036, \"to\": 2148, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"interim head coach\", \"from\": 2055, \"to\": 2073}, {\"ngram\": \"Twila Kilgoreor\", \"from\": 2074, \"to\": 2089}, {\"ngram\": \"the incoming Emma\", \"from\": 2090, \"to\": 2107}, {\"ngram\": \"this team\", \"from\": 2128, \"to\": 2137}]}, {\"sentence\": \"The USWNT mystique is gone, and the rising level of the rest of the world is only part of the story.\", \"from\": 2150, \"to\": 2250, \"entities\": [{\"begin\": 2154, \"end\": 2159, \"title\": \"http://dbpedia.org/resource/United_States_women's_national_soccer_team\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"USWNT\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/United_States_women's_national_soccer_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_women's_national_soccer_team\"}], \"noun_phrases\": [{\"ngram\": \"the rising level\", \"from\": 2182, \"to\": 2198}, {\"ngram\": \"the rest\", \"from\": 2202, \"to\": 2210}, {\"ngram\": \"the world\", \"from\": 2214, \"to\": 2223}, {\"ngram\": \"only part\", \"from\": 2227, \"to\": 2236}, {\"ngram\": \"the story\", \"from\": 2240, \"to\": 2249}]}, {\"sentence\": \"The players used to wield their collective reputation and m