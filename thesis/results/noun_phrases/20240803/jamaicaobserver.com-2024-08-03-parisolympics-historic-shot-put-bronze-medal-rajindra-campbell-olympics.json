"{\"uid\": \"jamaicaobserver.com-2024-08-03-parisolympics-historic-shot-put-bronze-medal-rajindra-campbell-olympics\", \"noun_phrases\": [{\"sentence\": \"KINGSTON, Jamaica- Rajindra Campbell created history on Saturday when he became the first Jamaican to win a medal in the shot put event at the Olympic Games after he gained bronze with a throw of 22.15m in the final at Stade de France in Paris.\", \"from\": 0, \"to\": 244, \"entities\": [{\"begin\": 28, \"end\": 36, \"title\": \"http://dbpedia.org/resource/Clan_Campbell\", \"score\": 0.9997567113730121, \"rank\": 0.00024334782290674607, \"text\": \"Campbell\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Clan_Campbell\", \"dbpedia\": \"http://dbpedia.org/resource/Clan_Campbell\"}, {\"begin\": 90, \"end\": 98, \"title\": \"http://dbpedia.org/resource/Jamaicans\", \"score\": 0.9956434062813514, \"rank\": 0.0024972289495001814, \"text\": \"Jamaican\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Jamaicans\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaicans\"}, {\"begin\": 238, \"end\": 243, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999988205158977, \"rank\": 1.1794854600025662e-06, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"KINGSTON\", \"from\": 0, \"to\": 8}, {\"ngram\": \"history\", \"from\": 45, \"to\": 52}, {\"ngram\": \"Saturday\", \"from\": 56, \"to\": 64}, {\"ngram\": \"a medal\", \"from\": 106, \"to\": 113}, {\"ngram\": \"the shot\", \"from\": 117, \"to\": 125}, {\"ngram\": \"event\", \"from\": 130, \"to\": 135}, {\"ngram\": \"the Olympic Games\", \"from\": 139, \"to\": 156}, {\"ngram\": \"bronze\", \"from\": 173, \"to\": 179}, {\"ngram\": \"a throw\", \"from\": 185, \"to\": 192}, {\"ngram\": \"22.15m\", \"from\": 196, \"to\": 202}, {\"ngram\": \"Stade de France\", \"from\": 219, \"to\": 234}]}, {\"sentence\": \"This was Jamaica's first medal at the 2024 Olympic Games.\", \"from\": 246, \"to\": 303, \"entities\": [{\"begin\": 255, \"end\": 262, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.801167368546662, \"rank\": 0.2476179104973569, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}], \"noun_phrases\": [{\"ngram\": \"the 2024 Olympic Games\", \"from\": 280, \"to\": 302}]}, {\"sentence\": \"It was sweet redemption for the double national record holder after he had three fouls in the final at last year's World Athletics Championships in Budapest and followed that up with another three fouls in the World Indoor Championships in March this year.\", \"from\": 305, \"to\": 561, \"entities\": [{\"begin\": 420, \"end\": 449, \"title\": \"http://dbpedia.org/resource/World_Athletics_Championships\", \"score\": 0.9986130971571118, \"rank\": 0.0006165001128661678, \"text\": \"World Athletics Championships\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/World_Athletics_Championships\", \"dbpedia\": \"http://dbpedia.org/resource/World_Athletics_Championships\"}, {\"begin\": 453, \"end\": 461, \"title\": \"http://dbpedia.org/resource/Budapest\", \"score\": 0.9999891756436123, \"rank\": 1.082385959695264e-05, \"text\": \"Budapest\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Budapest\", \"dbpedia\": \"http://dbpedia.org/resource/Budapest\"}], \"noun_phrases\": [{\"ngram\": \"sweet redemption\", \"from\": 312, \"to\": 328}, {\"ngram\": \"the double national record holder\", \"from\": 333, \"to\": 366}, {\"ngram\": \"three fouls\", \"from\": 380, \"to\": 391}, {\"ngram\": \"another three fouls\", \"from\": 488, \"to\": 507}, {\"ngram\": \"the World Indoor Championships\", \"from\": 511, \"to\": 541}, {\"ngram\": \"March\", \"from\": 545, \"to\": 550}]}, {\"sentence\": \"He surpassed the eighth place finish by O'Dayne Richards in Rio in 2016 and foiled another clean sweep by American throwers.\", \"from\": 563, \"to\": 687, \"entities\": [{\"begin\": 603, \"end\": 619, \"title\": \"http://dbpedia.org/resource/O'Dayne_Richards\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"O'Dayne Richards\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/O'Dayne_Richards\", \"dbpedia\": \"http://dbpedia.org/resource/O'Dayne_Richards\"}, {\"begin\": 623, \"end\": 626, \"title\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"score\": 0.9999999564859091, \"rank\": 4.351411014097898e-08, \"text\": \"Rio\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2016_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2016_Summer_Olympics\"}, {\"begin\": 669, \"end\": 677, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.7511510033481912, \"rank\": 0.330599082412901, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"the eighth place finish\", \"from\": 576, \"to\": 599}, {\"ngram\": \"another clean sweep\", \"from\": 646, \"to\": 665}]}, {\"sentence\": \"Ryan Crouser won a historic third straight Olympic title with 22.90m, with Joe Kovacs snatching the silver from Campbell as he also threw 22.15m but had a better second throw of 21.71m to Campbell's 20.00m.\", \"from\": 689, \"to\": 895, \"entities\": [{\"begin\": 689, \"end\": 701, \"title\": \"http://dbpedia.org/resource/Ryan_Crouser\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Ryan Crouser\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Ryan_Crouser\", \"dbpedia\": \"http://dbpedia.org/resource/Ryan_Crouser\"}, {\"begin\": 764, \"end\": 767, \"title\": \"http://dbpedia.org/resource/Joe_DiMaggio\", \"score\": 0.9976614993884383, \"rank\": 0.0022