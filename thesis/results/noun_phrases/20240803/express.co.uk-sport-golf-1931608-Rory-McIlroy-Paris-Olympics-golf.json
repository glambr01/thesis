{\"ngram\": \"Team Ireland\", \"from\": 217, \"to\": 229}, {\"ngram\": \"McIlroy\", \"from\": 267, \"to\": 274}, {\"ngram\": \"a high note\", \"from\": 286, \"to\": 297}, {\"ngram\": \"a strong round\", \"from\": 314, \"to\": 328}, {\"ngram\": \"day\", \"from\": 332, \"to\": 335}]}, {\"sentence\": \"Come Friday, he nailed an impressive eagle at the third hole after teeing off with a pair of pars.\", \"from\": 341, \"to\": 439, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an impressive eagle\", \"from\": 364, \"to\": 383}, {\"ngram\": \"the third hole\", \"from\": 387, \"to\": 401}, {\"ngram\": \"a pair\", \"from\": 424, \"to\": 430}, {\"ngram\": \"pars\", \"from\": 434, \"to\": 438}]}, {\"sentence\": \"The highlight, however, was when McIlroy's second shot from the fairway incredibly slam-dunked into the cup and bounced out, settling just two feet away from glory.\", \"from\": 441, \"to\": 605, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The highlight\", \"from\": 441, \"to\": 454}, {\"ngram\": \"McIlroy's second shot\", \"from\": 474, \"to\": 495}, {\"ngram\": \"the fairway\", \"from\": 501, \"to\": 512}, {\"ngram\": \"the cup\", \"from\": 541, \"to\": 548}, {\"ngram\": \"glory\", \"from\": 599, \"to\": 604}]}, {\"sentence\": \"McIlroy went on to finish two-under par in his second round, leaving him at five-under overall heading into the weekend.\", \"from\": 607, \"to\": 727, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"McIlroy\", \"from\": 607, \"to\": 614}, {\"ngram\": \"two-under par\", \"from\": 633, \"to\": 646}, {\"ngram\": \"his second round\", \"from\": 650, \"to\": 666}, {\"ngram\": \"five-under overall heading\", \"from\": 683, \"to\": 709}, {\"ngram\": \"the weekend\", \"from\": 715, \"to\": 726}]}, {\"sentence\": \"He trails joint leaders Xander Schauffele (USA), Hideki Matsuyama (Japan) and Tommy Fleetwood (Team GB) by six shots.\", \"from\": 728, \"to\": 845, \"entities\": [{\"begin\": 752, \"end\": 769, \"title\": \"http://dbpedia