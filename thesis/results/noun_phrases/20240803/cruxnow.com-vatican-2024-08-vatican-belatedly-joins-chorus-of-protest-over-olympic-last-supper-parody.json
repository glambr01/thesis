\": [{\"ngram\": \"a large serving tray\", \"from\": 1942, \"to\": 1962}, {\"ngram\": \"the stage\", \"from\": 1977, \"to\": 1986}, {\"ngram\": \"a scantily clad man\", \"from\": 2025, \"to\": 2044}, {\"ngram\": \"head\", \"from\": 2053, \"to\": 2057}, {\"ngram\": \"toe\", \"from\": 2061, \"to\": 2064}]}, {\"sentence\": \"At one point, the genitalia of a man wearing short black hotpants was exposed while a little girl stood in front of him, in front of what was supposed to be the table.\", \"from\": 2118, \"to\": 2285, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"one point\", \"from\": 2121, \"to\": 2130}, {\"ngram\": \"the genitalia\", \"from\": 2132, \"to\": 2145}, {\"ngram\": \"a man\", \"from\": 2149, \"to\": 2154}, {\"ngram\": \"short black hotpants\", \"from\": 2163, \"to\": 2183}, {\"ngram\": \"a little girl\", \"from\": 2202, \"to\": 2215}, {\"ngram\": \"front\", \"from\": 2225, \"to\": 2230}, {\"ngram\": \"front\", \"from\": 2242, \"to\": 2247}, {\"ngram\": \"the table\", \"from\": 2275, \"to\": 2284}]}, {\"sentence\": \"Some commentators claimed that the performance was evocative of artistic depictions of the Feast of Dionysus, rather than the Last Supper, as a nod to the Greek roots of the Olympic games.\", \"from\": 2287, \"to\": 2475, \"entities\": [{\"begin\": 2442, \"end\": 2447, \"title\": \"http://dbpedia.org/resource/Greek_language\", \"score\": 0.7375391628413144, \"rank\": 0.29163785086324984, \"text\": \"Greek\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/Greek_language\", \"dbpedia\": \"http://dbpedia.org/resource/Greek_language\"}], \"noun_phrases\": [{\"ngram\": \"Some commentators\", \"from\": 2287, \"to\": 2304}, {\"ngram\": \"the performance\", \"from\": 2318, \"to\": 2333}, {\"ngram\": \"artistic depictions\", \"from\": 2351, \"to\": 2370}, {\"ngram\": \"the Feast\", \"from\": 2374, \"to\": 2383}, {\"ngram\": \"Dionysus\", \"from\": 2387, \"to\": 2395}, {\"ngram\": \"the Last Supper\", \"from\": 2409, \"to\": 2424}, {\"ngram\": \"a nod\", \"from\": 2429, \"to\": 2434}, {\"ngram\": \"the Olympic games\", \"from\": 2457, \"to\": 2474}]}, {\"sentence\": \"However, some performers themselves stated in social media posts and in comments to French media that they had, in fact, intended to imitate the Last Supper.\", \"from\": 2476, \"to\": 2633, \"entities\": [{\"begin\": 2560, \"end\": 2566, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9987675882208591, \"rank\": 0.0012239186107346309, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"some performers\", \"from\": 2485, \"to\": 2500}, {\"ngram\": \"social media posts\", \"from\": 2522, \"to\": 2540}, {\"ngram\": \"comments\", \"from\": 2548, \"to\": 2556}, {\"ngram\": \"fact\", \"from\": 2591, \"to\": 2595}, {\"ngram\": \"the Last Supper\", \"from\": 2617, \"to\": 2632}]}, {\"sentence\": \"Organizers came under fire for the spectacle, with critics condemning not only the provocative nature of the drag show and the apparent mockery of Christianity, but also for the presence of a child in the performance.\", \"from\": 2635, \"to\": 2852, \"entities\": [{\"begin\": 2782, \"end\": 2794, \"title\": \"http://dbpedia.org/resource/History_of_Christianity\", \"score\": 0.5980506364215178, \"rank\": 0.6720779504915161, \"text\": \"Christianity\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/History_of_Christianity\", \"dbpedia\": \"http://dbpedia.org/resource/History_of_Christianity\"}], \"noun_phrases\": [{\"ngram\": \"Organizers\", \"from\": 2635, \"to\": 2645}, {\"ngram\": \"fire\", \"from\": 2657, \"to\": 2661}, {\"ngram\": \"the spectacle\", \"from\": 2666, \"to\": 2679}, {\"ngram\": \"critics\", \"from\": 2686, \"to\": 2693}, {\"ngram\": \"not only the provocative nature\", \"from\": 2705, \"to\": 2736}, {\"ngram\": \"the drag show\", \"from\": 