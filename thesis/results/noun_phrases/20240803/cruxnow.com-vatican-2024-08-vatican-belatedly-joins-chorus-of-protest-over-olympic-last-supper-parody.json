}, {\"ngram\": \"speech\", \"from\": 385, \"to\": 391}, {\"ngram\": \"the Vatican\", \"from\": 393, \"to\": 404}, {\"ngram\": \"question\", \"from\": 437, \"to\": 445}, {\"ngram\": \"respect\", \"from\": 479, \"to\": 486}, {\"ngram\": \"others\", \"from\": 491, \"to\": 497}]}, {\"sentence\": \"The brief, 90-word statement was released in French.\", \"from\": 500, \"to\": 552, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The brief, 90-word statement\", \"from\": 500, \"to\": 528}, {\"ngram\": \"French\", \"from\": 545, \"to\": 551}]}, {\"sentence\": \"\\\"The Holy See is saddened by some scenes of the opening ceremony of the Paris Olympic Games and cannot but join the voices that have been raised in recent days to deplore the offense done to many Christians and believers of other religions,\\\" it said.\", \"from\": 554, \"to\": 804, \"entities\": [{\"begin\": 750, \"end\": 760, \"title\": \"http://dbpedia.org/resource/History_of_Christianity\", \"score\": 0.9305978784116171, \"rank\": 0.073878366803277, \"text\": \"Christians\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/History_of_Christianity\", \"dbpedia\": \"http://dbpedia.org/resource/History_of_Christianity\"}], \"noun_phrases\": [{\"ngram\": \"The Holy See\", \"from\": 555, \"to\": 567}, {\"ngram\": \"some scenes\", \"from\": 583, \"to\": 594}, {\"ngram\": \"the opening ceremony\", \"from\": 598, \"to\": 618}, {\"ngram\": \"the Paris Olympic Games\", \"from\": 622, \"to\": 645}, {\"ngram\": \"the voices\", \"from\": 666, \"to\": 676}, {\"ngram\": \"recent days\", \"from\": 702, \"to\": 713}, {\"ngram\": \"the offense\", \"from\": 725, \"to\": 736}, {\"ngram\": \"believers\", \"from\": 765, \"to\": 774}, {\"ngram\": \"other religions\", \"from\": 778, \"to\": 793}]}, {\"sentence\": \"\\\"In a prestigious event where the whole world comes together around common values, there should be no allusions that ridicule the religious convictions of many people,\\\" the statement said.\", \"from\": 806, \"to\": 994, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a prestigious event\", \"from\": 810, \"to\": 829}, {\"ngram\": \"the whole world\", \"from\": 836, \"to\": 851}, {\"ngram\": \"common values\", \"from\": 874, \"to\": 887}, {\"ngram\": \"no allusions\", \"from\": 905, \"to\": 917}, {\"ngram\": \"the religious convictions\", \"from\": 932, \"to\": 957}, {\"ngram\": \"many people\", \"from\": 961, \"to\": 972}, {\"ngram\": \"the statement\", \"from\": 975, \"to\": 988}]}, {\"sentence\": \"\\\"Freedom of expression, which is obviously not called into question, finds its limit in respect for others,\\\" it said.\", \"from\": 996, \"to\": 1113, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Freedom\", \"from\": 997, \"to\": 1004}, {\"ngram\": \"expression\", \"from\": 1008, \"to\": 1018}, {\"ngram\": \"question\", \"from\": 1055, \"to\": 1063}, {\"ngram\": \"its limit\", \"from\": 1071, \"to\": 1080}, {\"ngram\": \"respect\", \"from\": 1084, \"to\": 1091}, {\"ngram\": \"others\", \"from\": 1096, \"to\": 1102}]}, {\"sentence\": \"The statement comes eight days after the opening ceremony sparked a wave of international backlash.\", \"from\": 1115, \"to\": 1214, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The statement\", \"from\": 1115, \"to\": 1128}, {\"ngram\": \"the opening ceremony\", \"from\": 1152, \"to\": 1172}, {\"ngram\": \"a wave\", \"from\": 1181, \"to\": 1187}, {\"ngram\": \"international backlash\", \"from\": 1191, \"to\": 1213}]}, {\"sentence\": \"At one point during the event, a group of around 18 drag performers, including several famous Drag Race France personalities, struck poses behind what appeared to be a long table with the Seine River and Eiffel Tower in the background.\", \"from\": 1216, \"to\": 1451, \"entities\": [{\"begin\": 1310, \"end\": 1326, \"title\": \"http://dbpedia.org/resource/Drag_Race_France\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Drag Race France\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/Drag_Race_France\", \"dbpedia\": \"http://dbpedia.org/resource/Drag_Race_France\"}], \"noun_phrases\": [{\"ngram\": \"one point\", \"from\": 1219, \"to\": 1228}, {\"ngram\": \"the event\", \"from\": 1236, \"to\": 1245}, {\"ngram\": \"a group\", \"from\": 1247, \"to\": 1254}, {\"ngram\": \"around 18 drag performers\", \"from\": 1258, \"to\": 1283}, {\"ngram\": \"poses\", \"from\": 1349, \"to\": 1354}, {\"ngram\": \"a long table\", \"from\": 1382, \"to\": 1394}, {\"ngram\": \"the Seine River\", \"from\": 1400, \"to\": 1415}, {\"ngram\": \"Eiffel Tower\", \"from\": 1420, \"to\": 1432}, {\"ngram\": \"the background\", \"from\": 1436, \"to\": 1450}]}, {\"sentence\": \"At the center was a woman in a low-cut dress wearing a large silver headdress, reminiscent of the halo behind Jesus's head in many artistic depictions of the Last Supper, indicating his divine status as the son of God.\", \"from\": 1453, \"to\": 1671, \"entities\": [{\"begin\": 1563, \"end\": 1568, \"title\": \"http://dbpedia.org/resource/Jesus\", \"score\": 0.9999999710798879, \"rank\": 2.8919252990631965e-08, \"text\": \"Jesus\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jesus\", \"dbpedia\": \"http://dbpedia.org/resource/Jesus\"}], \"noun_phrases\": [{\"ngram\": \"the center\", \"from\": 1456, \"to\": 1466}, {\"ngram\": \"a woman\", \"from\": 1471, \"to\": 1478}, {\"ngram\": \"a low-cut dress\", \"from\": 1482, \"to\": 1497}, {\"ngram\": \"the halo\", \"from\": 1547, \"to\": 1555}, {\"ngram\": \"many artistic depictions\", \"from\": 1579, \"to\": 1603}, {\"ngram\": \"the Last Supper\", \"from\": 1607, \"to\": 1622}, {\"ngram\": \"his divine status\", \"from\": 1635, \"to\": 1652}, {\"ngram\": \"the son\", \"from\": 1656, \"to\": 1663}, {\"ngram\": \"God\", \"from\": 1667, \"to\": 1670}]}, {\"sentence\": \"The woman made a heart shape with her hands as the group stared into the camera before breaking out into a routine.\", \"