 \"noun_phrases\": [{\"ngram\": \"no response\", \"from\": 33933, \"to\": 33944}]}, {\"sentence\": \"As part of the sponsorship deal, the complainant used to receive a small monthly stipend that took care of her daily expenses.\", \"from\": 33947, \"to\": 34073, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"part\", \"from\": 33950, \"to\": 33954}, {\"ngram\": \"the sponsorship deal\", \"from\": 33958, \"to\": 33978}, {\"ngram\": \"the complainant\", \"from\": 33980, \"to\": 33995}, {\"ngram\": \"a small monthly stipend\", \"from\": 34012, \"to\": 34035}, {\"ngram\": \"care\", \"from\": 34046, \"to\": 34050}, {\"ngram\": \"her daily expenses\", \"from\": 34054, \"to\": 34072}]}, {\"sentence\": \"Now, even for small expenses, she is dependent on cash awards at tournaments that can take months, even years, to come.\", \"from\": 34074, \"to\": 34193, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"small expenses\", \"from\": 34088, \"to\": 34102}, {\"ngram\": \"cash awards\", \"from\": 34124, \"to\": 34135}, {\"ngram\": \"tournaments\", \"from\": 34139, \"to\": 34150}, {\"ngram\": \"months\", \"from\": 34165, \"to\": 34171}]}, {\"sentence\": \"\\\"They are trying their best to break the girls,\\\" the guardian said.\", \"from\": 34195, \"to\": 34262, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the girls\", \"from\": 34232, \"to\": 34241}, {\"ngram\": \"the guardian\", \"from\": 34244, \"to\": 34256}]}, {\"sentence\": \"\\\"She is demoralised, but playing.\\\"\", \"from\": 34263, \"to\": 34297, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"About 45 minutes' drive from the stadium in Rohtak where the SUV was parked is coach Virender Dalal's residential wrestling academy for girls in Haryana's Chhara village.\", \"from\": 34299, \"to\": 34469, \"entities\": [{\"begin\": 34343, \"end\": 34349, \"title\": \"http://dbpedia.org/resource/Rohtak\", \"score\": 0.999991991254898, \"rank\": 8.008587506482918e-06, \"text\": \"Rohtak\", \"types\": [\"Q48697