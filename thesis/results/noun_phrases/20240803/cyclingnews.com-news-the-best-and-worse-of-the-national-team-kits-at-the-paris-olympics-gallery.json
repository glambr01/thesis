om\": 3904, \"to\": 4011, \"entities\": [{\"begin\": 3988, \"end\": 3995, \"title\": \"http://dbpedia.org/resource/Belgium\", \"score\": 0.9999999993956408, \"rank\": 6.044983806659396e-10, \"text\": \"Belgium\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Belgium\", \"dbpedia\": \"http://dbpedia.org/resource/Belgium\"}], \"noun_phrases\": [{\"ngram\": \"The red, white and blue stripe\", \"from\": 3904, \"to\": 3934}, {\"ngram\": \"a new feature\", \"from\": 3938, \"to\": 3951}]}, {\"sentence\": \"The blue colour of Belgium's cycling kits is not as obvious as the Dutch orange but it's a long tradition that is also linked to the country's royals.\", \"from\": 4015, \"to\": 4165, \"entities\": [{\"begin\": 4034, \"end\": 4041, \"title\": \"http://dbpedia.org/resource/Belgium\", \"score\": 0.9999999993956408, \"rank\": 6.044983806659396e-10, \"text\": \"Belgium\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Belgium\", \"dbpedia\": \"http://dbpedia.org/resource/Belgium\"}, {\"begin\": 4082, \"end\": 4087, \"title\": \"http://dbpedia.org/resource/Netherlands\", \"score\": 0.98475302859454, \"rank\": 0.015482674577194998, \"text\": \"Dutch\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Netherlands\", \"dbpedia\": \"http://dbpedia.org/resource/Netherlands\"}], \"noun_phrases\": [{\"ngram\": \"The blue colour\", \"from\": 4015, \"to\": 4030}, {\"ngram\": \"a long tradition\", \"from\": 4104, \"to\": 4120}, {\"ngram\": \"the country's royals\", \"from\": 4144, \"to\": 4164}]}, {\"sentence\": \"There is also speculation the blue might have originated in a 20th century sponsor of the team.\", \"from\": 4167, \"to\": 4262, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"speculation\", \"from\": 4181, \"to\": 4192}, {\"ngram\": \"a 20th century sponsor\", \"from\": 4227, \"to\": 4249}, {\"ngram\": \"the team\", \"from\": 4253, \"to\": 4261}]}, {\"sentence\": \"This year's shoulder sling of black and red with the yellow arm brings to mind the Belgian national flag like never before.\", \"from\": 4263, \"to\": 4386, \"entities\": [{\"begin\": 4346, \"end\": 4353, \"title\": \"http://dbpedia.org/resource/Belgium\", \"score\": 0.9999999340570889, \"rank\": 6.589425742356867e-08, \"text\": \"Belgian\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Belgium\", \"dbpedia\": \"http://dbpedia.org/resource/Belgium\"}], \"noun_phrases\": [{\"ngram\": \"This year's shoulder sling\", \"from\": 4263, \"to\": 4289}, {\"ngram\": \"the yellow arm\", \"from\": 4312, \"to\": 4326}]}, {\"sentence\": \"It looks fantastic in the bunch.\", \"from\": 4387, \"to\": 4419, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the bunch\", \"from\": 4409, \"to\": 4418}]}, {\"sentence\": \"We are sad that defending champion Richard Carapaz is not in Paris but Jhonatan Narvaez looked fabulous in the Ecuadorian kit.\", \"from\": 4423, \"to\": 4549, \"entities\": [{\"begin\": 4458, \"end\": 4473, \"title\": \"http://dbpedia.org/resource/Richard_Carapaz\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Richard Carapaz\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Richard_Carapaz\", \"dbpedia\": \"http://dbpedia.org/resource/Richard_Carapaz\"}, {\"begin\": 4484, \"end\": 4489, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 3.200795975382417e-15, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 4494, \"end\": 4510, \"title\": \"http://dbpedia.org/resource/Jhonatan_Narv\\u00e1ez\", \"score\": 0.9999999990773176, \"rank\": 0.0, \"text\": \"Jhonatan Narvaez\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jhonatan_Narv\\u00e1ez\", \"dbpedia\": \"http://dbpedia.org/resource/Jhonatan_Narv\\u00e1ez\"}, {\"begin\": 4534, \"end\": 4544, \"title\": \"http://dbpedia