ernationale\"}], \"noun_phrases\": [{\"ngram\": \"most other sports\", \"from\": 410, \"to\": 427}, {\"ngram\": \"the Olympics\", \"from\": 431, \"to\": 443}, {\"ngram\": \"cycling's governing body\", \"from\": 445, \"to\": 469}, {\"ngram\": \"all bicycles\", \"from\": 494, \"to\": 506}, {\"ngram\": \"competition\", \"from\": 515, \"to\": 526}, {\"ngram\": \"the public\", \"from\": 561, \"to\": 571}]}, {\"sentence\": \"This stipulation means that if you have got the money, you can buy or build, the exact bike ridden to gold, silver, or bronze.\", \"from\": 573, \"to\": 699, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"This stipulation\", \"from\": 573, \"to\": 589}, {\"ngram\": \"the money\", \"from\": 617, \"to\": 626}, {\"ngram\": \"the exact bike\", \"from\": 650, \"to\": 664}, {\"ngram\": \"gold\", \"from\": 675, \"to\": 679}, {\"ngram\": \"silver\", \"from\": 681, \"to\": 687}, {\"ngram\": \"bronze\", \"from\": 692, \"to\": 698}]}, {\"sentence\": \"(Your results may vary, of course.)\", \"from\": 700, \"to\": 735, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Your results\", \"from\": 701, \"to\": 713}, {\"ngram\": \"course\", \"from\": 727, \"to\": 733}]}, {\"sentence\": \"We have crunched the numbers and rounded up the details: Below are our price estimates of the fastest mountain bikes at the 2024 Paris Olympics and their production counterparts.\", \"from\": 736, \"to\": 914, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the numbers\", \"from\": 753, \"to\": 764}, {\"ngram\": \"the details\", \"from\": 780, \"to\": 791}, {\"ngram\": \"our price estimates\", \"from\": 803, \"to\": 822}, {\"ngram\": \"the fastest mountain bikes\", \"from\": 826, \"to\": 852}, {\"ngram\": \"the 2024 Paris Olympics\", \"from\": 856, \"to\": 879}, {\"ngram\": \"their production counterparts\", \"from\": 884, \"to\": 913}]}, {\"sentence\": \"Pauline Ferrand-Pr\\u00e9vot dominated the women's cross-country race.\", \"from\": 916, \"to\": 980, \"entities\": [{\"begi