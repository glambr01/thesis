, \"to\": 866}, {\"ngram\": \"another milestone\", \"from\": 881, \"to\": 898}]}, {\"sentence\": \"She became only the sixth Olympian to reach that figure, joining swimmer Mark Spitz, track star Carl Lewis, Soviet gymnast Larisa Latynina and Finnish runner Paavo Nurmi in a tie for second place.\", \"from\": 901, \"to\": 1097, \"entities\": [{\"begin\": 927, \"end\": 935, \"title\": \"http://dbpedia.org/resource/Olympic_Games\", \"score\": 0.9999934631336977, \"rank\": 6.5369090066854655e-06, \"text\": \"Olympian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Olympic_Games\", \"dbpedia\": \"http://dbpedia.org/resource/Olympic_Games\"}, {\"begin\": 974, \"end\": 984, \"title\": \"http://dbpedia.org/resource/Mark_Spitz\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Mark Spitz\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10843402\"], \"wikid\": \"http://dbpedia.org/resource/Mark_Spitz\", \"dbpedia\": \"http://dbpedia.org/resource/Mark_Spitz\"}, {\"begin\": 997, \"end\": 1007, \"title\": \"http://dbpedia.org/resource/Carl_Lewis\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Carl Lewis\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Carl_Lewis\", \"dbpedia\": \"http://dbpedia.org/resource/Carl_Lewis\"}, {\"begin\": 1009, \"end\": 1015, \"title\": \"http://dbpedia.org/resource/Soviet_Union\", \"score\": 0.9999999999913598, \"rank\": 5.326592366591626e-12, \"text\": \"Soviet\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Soviet_Union\", \"dbpedia\": \"http://dbpedia.org/resource/Soviet_Union\"}, {\"begin\": 1024, \"end\": 1039, \"title\": \"http://dbpedia.org/resource/Larisa_Latynina\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Larisa Latynina\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Larisa_Latynina\", \"dbpedia\": \"http://dbpedia.org/resource/Larisa_Latynina\"}, {\"begin\": 1044, \"end\": 1051, \"title\": \"http://d