 3029, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"But there\\u00e2\\u0080\\u0099s so many factors\", \"from\": 2959, \"to\": 2988}, {\"ngram\": \"variables\", \"from\": 2993, \"to\": 3002}, {\"ngram\": \"the surface glance\", \"from\": 3010, \"to\": 3028}]}, {\"sentence\": \"Lyles needed to maintain his strength to muscle through 100-meter finals.\", \"from\": 3030, \"to\": 3103, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Lyles\", \"from\": 3030, \"to\": 3035}, {\"ngram\": \"his strength\", \"from\": 3055, \"to\": 3067}, {\"ngram\": \"100-meter finals\", \"from\": 3086, \"to\": 3102}]}, {\"sentence\": \"But adding too much muscle could slow him in both races.\", \"from\": 3104, \"to\": 3160, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"too much muscle\", \"from\": 3115, \"to\": 3130}, {\"ngram\": \"both races\", \"from\": 3149, \"to\": 3159}]}, {\"sentence\": \"Lyles would need to be fast, but in different ways, which would require tweaks to his diet, workouts and rest schedule.\", \"from\": 3161, \"to\": 3280, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Lyles\", \"from\": 3161, \"to\": 3166}, {\"ngram\": \"different ways\", \"from\": 3197, \"to\": 3211}, {\"ngram\": \"tweaks\", \"from\": 3233, \"to\": 3239}, {\"ngram\": \"his diet\", \"from\": 3243, \"to\": 3251}, {\"ngram\": \"workouts\", \"from\": 3253, \"to\": 3261}, {\"ngram\": \"rest schedule\", \"from\": 3266, \"to\": 3279}]}, {\"sentence\": \"He needed to prepare his body for six rounds in the 100 and the 200, plus any additional relays he might run.\", \"from\": 3281, \"to\": 3390, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"his body\", \"from\": 3302, \"to\": 3310}, {\"ngram\": \"six rounds\", \"from\": 3315, \"to\": 3325}, {\"ngram\": \"any additional relays\", \"from\": 3355, \"to\": 3376}]}, {\"sentence\": \"\\u00e2\\u0080\\u009cMost people have no idea what goes into it,\\u00e2\\u0080\\u009d Brauman says.\", \"from\": 3392, \"to\": 3455, \"entities\": [], \"noun_phra