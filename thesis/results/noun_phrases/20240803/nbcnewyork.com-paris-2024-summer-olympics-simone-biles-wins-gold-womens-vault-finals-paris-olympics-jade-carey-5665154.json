hrases\": [{\"ngram\": \"Scores\", \"from\": 3206, \"to\": 3212}, {\"ngram\": \"16-point range\", \"from\": 3242, \"to\": 3256}]}, {\"sentence\": \"Total scoresare based on the total of the difficulty score and execution score combined, minus any deductions.\", \"from\": 3259, \"to\": 3369, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Total scoresare\", \"from\": 3259, \"to\": 3274}, {\"ngram\": \"the total\", \"from\": 3284, \"to\": 3293}, {\"ngram\": \"the difficulty score\", \"from\": 3297, \"to\": 3317}, {\"ngram\": \"execution score\", \"from\": 3322, \"to\": 3337}, {\"ngram\": \"any deductions\", \"from\": 3354, \"to\": 3368}]}, {\"sentence\": \"The difficulty panel decides the \\\"D-score\\\" while the execution panel starts at 10.0 and deducts points based on how the routine went.\", \"from\": 3370, \"to\": 3503, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The difficulty panel\", \"from\": 3370, \"to\": 3390}, {\"ngram\": \"the \\\"D-score\", \"from\": 3399, \"to\": 3411}, {\"ngram\": \"the execution panel\", \"from\": 3419, \"to\": 3438}, {\"ngram\": \"points\", \"from\": 3466, \"to\": 3472}, {\"ngram\": \"the routine\", \"from\": 3486, \"to\": 3497}]}, {\"sentence\": \"The execution score is the \\\"e-score.\\\"\", \"from\": 3504, \"to\": 3541, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The execution score\", \"from\": 3504, \"to\": 3523}, {\"ngram\": \"the \\\"e\", \"from\": 3527, \"to\": 3533}, {\"ngram\": \"score\", \"from\": 3534, \"to\": 3539}]}, {\"sentence\": \"So it's the D-score plus the E-score minus Deductions to get the total score.\", \"from\": 3543, \"to\": 3620, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the D-score plus the E-score minus Deductions\", \"from\": 3551, \"to\": 3596}, {\"ngram\": \"the total score\", \"from\": 3604, \"to\": 3619}]}, {\"sentence\": \"Deductions or penalties can occur if a gymnast goes out of bounds.\", \"from\": 3622, \"to\": 3688, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Deductions\", \"from\": 3622, \"to\": 3632}, {\"ngram\": \"penalties\", \"from\": 3636, \"to\": 3645}, {\"ngram\": \"a gymnast\", \"from\": 3659, \"to\": 3668}, {\"ngram\": \"bounds\", \"from\": 3681, \"to\": 3687}]}, {\"sentence\": \"Gymnasts can lose anywhere from 0.1 points for something small that happened during the routine to 1.0 point for a fall.\", \"from\": 3689, \"to\": 3809, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Gymnasts\", \"from\": 3689, \"to\": 3697}, {\"ngram\": \"0.1 points\", \"from\": 3721, \"to\": 3731}, {\"ngram\": \"something\", \"from\": 3736, \"to\": 3745}, {\"ngram\": \"the routine\", \"from\": 3773, \"to\": 3784}, {\"ngram\": \"1.0 point\", \"from\": 3788, \"to\": 3797}, {\"ngram\": \"a fall\", \"from\": 3802, \"to\": 3808}]}, {\"sentence\": \"The difficulty score is based on \\\"difficulty, connection value and element requirements\\\" and the execution score, which includes \\\"execution, artistry, composition and technique,\\\"according to our partners at NBC Olympics.\", \"from\": 3811, \"to\": 4031, \"entities\": [{\"begin\": 4022, \"end\": 4034, \"title\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"NBC Olympics\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\"}], \"noun_phrases\": [{\"ngram\": \"The difficulty score\", \"from\": 3811, \"to\": 3831}, {\"ngram\": \"difficulty\", \"from\": 3845, \"to\": 3855}, {\"ngram\": \"connection value and element requirements\", \"from\": 3857, \"to\": 3898}, {\"ngram\": \"the execution score\", \"from\": 3904, \"to\": 3923}, {\"ngram\": \"execution\", \"from\": 3941, \"to\": 3950}, {\"ngram\": \"artistry\", \"from\": 3952, \"to\": 3960}, {\"ngram\": \"composition\", \"from\": 3962, \"to\": 3973}, {\"ngram\": \"technique,\\\"according\", \"from\": 3978, \"to\": 3998}, {\"ngram\": \"our partners\", \"from\": 