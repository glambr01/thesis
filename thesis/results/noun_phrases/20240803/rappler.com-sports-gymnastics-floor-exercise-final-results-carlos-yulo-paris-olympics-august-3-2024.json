 {\"ngram\": \"the Bercy Arena\", \"from\": 527, \"to\": 542}, {\"ngram\": \"Saturday\", \"from\": 546, \"to\": 554}, {\"ngram\": \"August\", \"from\": 556, \"to\": 562}]}, {\"sentence\": \"Yulo posted 15.000 points to dethrone Israel's Artem Dolgopyat and become the Philippines' second Olympic champion since weightlifting aceHidilyn Diazended a near century-long golden drought in the previous Tokyo Games.\", \"from\": 567, \"to\": 786, \"entities\": [{\"begin\": 605, \"end\": 611, \"title\": \"http://dbpedia.org/resource/Israel\", \"score\": 0.9999189347772283, \"rank\": 5.5014910016361954e-05, \"text\": \"Israel\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Israel\", \"dbpedia\": \"http://dbpedia.org/resource/Israel\"}, {\"begin\": 614, \"end\": 629, \"title\": \"http://dbpedia.org/resource/Artem_Dolgopyat\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Artem Dolgopyat\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Artem_Dolgopyat\", \"dbpedia\": \"http://dbpedia.org/resource/Artem_Dolgopyat\"}, {\"begin\": 645, \"end\": 656, \"title\": \"http://dbpedia.org/resource/Philippines\", \"score\": 0.9963064866074671, \"rank\": 0.0037071791099892444, \"text\": \"Philippines\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Philippines\", \"dbpedia\": \"http://dbpedia.org/resource/Philippines\"}], \"noun_phrases\": [{\"ngram\": \"Yulo\", \"from\": 567, \"to\": 571}, {\"ngram\": \"15.000 points\", \"from\": 579, \"to\": 592}, {\"ngram\": \"aceHidilyn\", \"from\": 702, \"to\": 712}, {\"ngram\": \"a near century-long golden drought\", \"from\": 723, \"to\": 757}, {\"ngram\": \"the previous Tokyo Games\", \"from\": 761, \"to\": 785}]}, {\"sentence\": \"Dolgopyat settled for silver with 14.966 points, while top qualifier Jake Jarman of Great Britain bagged bronze with 14.933 points.\", \"from\": 788, \"to\": 919, \"entities\": [{\"begin\": 857, \"end\": 861, \"title\": \"http://dbpedia.o