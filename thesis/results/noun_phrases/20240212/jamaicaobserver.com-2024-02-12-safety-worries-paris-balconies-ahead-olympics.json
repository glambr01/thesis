ases\": []}, {\"sentence\": \"That would be a mistake,\\\" mayor Anne Hidalgo urged the city's inhabitants on Sunday as she inaugurated the only new permanent Olympics sports arena to be built in inner Paris.\", \"from\": 2440, \"to\": 2615, \"entities\": [{\"begin\": 2472, \"end\": 2484, \"title\": \"http://dbpedia.org/resource/Anne_Hidalgo\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Anne Hidalgo\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Anne_Hidalgo\", \"dbpedia\": \"http://dbpedia.org/resource/Anne_Hidalgo\"}, {\"begin\": 2609, \"end\": 2614, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999997742179, \"rank\": 2.2584310843785994e-10, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"a mistake\", \"from\": 2454, \"to\": 2463}, {\"ngram\": \"the city's inhabitants\", \"from\": 2491, \"to\": 2513}, {\"ngram\": \"Sunday\", \"from\": 2517, \"to\": 2523}, {\"ngram\": \"the only new permanent Olympics sports arena\", \"from\": 2543, \"to\": 2587}]}, {\"sentence\": \"\\\"It's going to be incredible.\\\"\", \"from\": 2617, \"to\": 2647, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"HOUSE RULES\", \"from\": 2649, \"to\": 2660, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"HOUSE RULES\", \"from\": 2649, \"to\": 2660}]}]}"