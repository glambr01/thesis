"from\": 2061, \"to\": 2066}, {\"ngram\": \"Olympic gold\", \"from\": 2072, \"to\": 2084}, {\"ngram\": \"track and field events\", \"from\": 2099, \"to\": 2121}, {\"ngram\": \"50,000 US dollars\", \"from\": 2145, \"to\": 2162}, {\"ngram\": \"prize money\", \"from\": 2186, \"to\": 2197}]}, {\"sentence\": \"Cockroft continued her domination of Paralympic competition by powering over the line in 16.8 seconds, comfortably ahead of compatriot Kare Adenegan, who claimed silver in 17.99 secs.\", \"from\": 2200, \"to\": 2383, \"entities\": [{\"begin\": 2200, \"end\": 2208, \"title\": \"http://dbpedia.org/resource/Don_Cockroft\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Cockroft\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q14128148\"], \"wikid\": \"http://dbpedia.org/resource/Don_Cockroft\", \"dbpedia\": \"http://dbpedia.org/resource/Don_Cockroft\"}, {\"begin\": 2335, \"end\": 2348, \"title\": \"http://dbpedia.org/resource/Kare_Adenegan\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Kare Adenegan\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kare_Adenegan\", \"dbpedia\": \"http://dbpedia.org/resource/Kare_Adenegan\"}], \"noun_phrases\": [{\"ngram\": \"her domination\", \"from\": 2219, \"to\": 2233}, {\"ngram\": \"Paralympic competition\", \"from\": 2237, \"to\": 2259}, {\"ngram\": \"the line\", \"from\": 2277, \"to\": 2285}, {\"ngram\": \"16.8 seconds\", \"from\": 2289, \"to\": 2301}, {\"ngram\": \"silver\", \"from\": 2362, \"to\": 2368}, {\"ngram\": \"17.99 secs\", \"from\": 2372, \"to\": 2382}]}, {\"sentence\": \"The 16-time world champion moved within three golds of Britain's greatest wheelchair racer Baroness Tanni Grey-Thompson.\", \"from\": 2385, \"to\": 2505, \"entities\": [{\"begin\": 2440, \"end\": 2447, \"title\": \"http://dbpedia.org/resource/Great_Britain\", \"score\": 0.9824754196743609, \"rank\": 0.017837168373288716, \"text\": \"Britain\", \"types\": [\"Q23442\"], \"wikid\": \"http://dbpedi