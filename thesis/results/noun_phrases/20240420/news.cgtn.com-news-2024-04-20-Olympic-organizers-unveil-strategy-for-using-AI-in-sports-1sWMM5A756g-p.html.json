.org/resource/Thomas_Bach\"}, {\"begin\": 259, \"end\": 290, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 313, \"end\": 315, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 1.0, \"rank\": 1.7091727996190573e-16, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}], \"noun_phrases\": [{\"ngram\": \"Lee Valley VeloPark\", \"from\": 324, \"to\": 343}, {\"ngram\": \"April\", \"from\": 353, \"to\": 358}]}, {\"sentence\": \"/CFP Olympic organizers on Friday unveiled their strategy to use AI in sports, joining the global rush to capitalize on the rapidly advancing technology.\", \"from\": 371, \"to\": 525, \"entities\": [{\"begin\": 437, \"end\": 439, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 1.0, \"rank\": 1.7091727996190573e-16, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}], \"noun_phrases\": [{\"ngram\": \"Olympic organizers\", \"from\": 376, \"to\": 394}, {\"ngram\": \"Friday\", \"from\": 398, \"to\": 404}, {\"ngram\": \"their strategy\", \"from\": 414, \"to\": 428}, {\"ngram\": \"sports\", \"from\": 442, \"to\": 448}, {\"ngram\": \"the global rush\", \"from\": 458, \"to\": 473}, {\"ngram\": \"the rapidly advancing technology\", \"from\": 491, \"to\": 523}]}, {\"sentence\": \"The International Olympic Committee (IOC) outlined its agenda for taking advantage of AI.\", \"from\": 527, \"to\": 616, \"entities\": [{\"begin\": 531, \"end\": 568, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee (IOC)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 531, \"end\": 568, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee (IOC)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 613, \"end\": 615, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 1.0, \"rank\": 1.7091727996190573e-16, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}], \"noun_phrases\": [{\"ngram\": \"its agenda\", \"from\": 578, \"to\": 588}, {\"ngram\": \"advantage\", \"from\": 600, \"to\": 609}]}, {\"sentence\": \"Officials said it could be used to help identify promising athletes, personalize training methods and make the games fairer by improving judging.\", \"from\": 617, \"to\": 762, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Officials\", \"from\": 617, \"to\": 626}, {\"ngram\": \"promising athletes\", \"from\": 666, \"to\": 684}, {\"ngram\": \"training methods\", \"from\": 698, \"to\": 714}, {\"ngram\": \"the games\", \"from\": 724, \"to\": 733}, {\"ngram\": \"judging\", \"from\": 754, \"to\": 761}]}, {\"sentence\": \"\\\"Today we are making another step to ensure the uniqueness of the Olympic Games and the relevance of sport.\", \"from\": 764, \"to\": 871, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"another step\", \"from\": 785, \"to\": 797}, {\"ngram\": \"the uniqueness\", \"from\": 808, \"to\": 822}, {\"ngram\": \"the Olympic Games\", \"from\": 826, \"to\": 843}, {\"ngram\": \"the relevance\", \"from\": 848, \"to\": 861}, {\"ngram\": \"sport\", \"from\": 865, \"to\": 870}]}, {\"sentence\": \"To do this, we have to be leaders of change,\\\" IOC President Thomas Bach said at a press event in the velodrome at the Olympic Park in London, which hosted the summer games in 2012.\", \"from\": 872, \"to\": 1052, \"entities\": [{\"begin\": 918, \"end\": 931, \"title\": \"http://dbpedia.org/resource/President_of_the_International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"IOC President\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/President_of_the_International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/President_of_the_International_Olympic_Committee\"}, {\"begin\": 932, \"end\": 943, \"title\": \"http://dbpedia.org/resource/Thomas_Bach\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Thomas Bach\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Thomas_Bach\", \"dbpedia\": \"http://dbpedia.org/resource/Thomas_Bach\"}, {\"begin\": 1006, \"end\": 1012, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.9999999976425897, \"rank\": 1.5788407791407554e-09, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}], \"noun_phrases\": [{\"ngram\": \"leaders\", \"from\": 898, \"to\": 905}, {\"ngram\": \"change\", \"from\": 909, \"to\": 915}, {\"ngram\": \"a press event\", \"from\": 952, \"to\": 965}, {\"ngram\": \"the velodrome\", \"from\": 969, \"to\": 982}, {\"ngram\": \"the Olympic Park\", \"from\": 986, \"to\": 1002}, {\"ngram\": \"the summer games\", \"from\": 1027, \"to\": 1043}]}, {\"sentence\": \"\\\"We are determined to exploit the vast potential of AI in a responsible way,\\\" Bach said.\", \"from\": 1054, \"to\": 1142, \"entities\": [{\"begin\": 1106, \"end\": 1108, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 1.0, \"rank\": 1.7091727996190573e-16, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}, {\"begin\": 1132, \"end\": 1136, \"title\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"score\": 0.9999999963888513, \"rank\": 3.61103679888369e-09, \"text\": \"Bach\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"dbpedia\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\"}], \"noun_phrases\": [{\"ngram\": \"the vast potential\", \"from\": 1084, \"to\": 1102}, {\"ngram\": \"a responsible way\", \"from\": 1112, \"to\": 1129}]}, {\"sentence\": \"The IOC revealed its AI master plan as it gears up to hold the Paris Olympics, which are set to kick off in just under 100 days.\", \"from\": 1144, \"to\": 1272, \"entities\": [{\"begin\": 1148, \"end\": 1151, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.9761671666243175e-19, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 1165, \"end\": 1167, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 1.0, \"rank\": 1.7091727996190573e-16, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}], \"noun_phrases\": [{\"ngram\": \"the Paris Olympics\", \"from\": 1203, \"to\": 1221}, {\"ngram\": \"just under 100 days\", \"from\": 1252, \"to\": 1271}]}, {\"sentence\": \"The IOC's AI plans also include using the technology to protect athletes from online harassment and to help broadcasters improve the viewing experience for people watching from home.\", \"from\": 1274, \"to\": 1456, \"entities\": [{\"begin\": 1278, \"end\": 1281, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.9761671666243175e-19, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 1284, \"end\": 1286, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 1.0, \"rank\": 1.7091727996190573e-16, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}], \"noun_phrases\": [{\"ngram\": \"the technology\", \"from\": 1312, \"to\": 1326}, {\"ngram\": \"athletes\", \"from\": 1338, \"to\": 1346}, {\"ngram\": \"online harassment\", \"from\": 1352, \"to\": 1369}, {\"ngram\": \"broadcasters\", \"from\": 1382, \"to\": 1394}, {\"ngram\": \"the viewing experience\", \"from\": 1403, \"to\": 1425}, {\"ngram\": \"people\", \"from\": 1430, \"to\": 1436}, {\"ngram\": \"home\", \"from\": 1451, \"to\": 1455}]}, {\"sentence\": \"Some AI projects will be rolled out at the Paris Games and the IOC has set up a working group on the technology to further drive its adoption in sport, Bach said, without being more specific.\", \"from\": 1458, \"to\": 1649, \"entities\": [{\"begin\": 1521, \"end\": 1524, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.9761671666243175e-19, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 1610, \"end\": 1614, \"title\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"score\": 0.9999999963888513, \"rank\": 3.61103679888369e-09, \"text\": \"Bach\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"dbpedia\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\"}], \"noun_phrases\": [{\"ngram\": \"Some AI projects\", \"from\": 1458, \"to\": 1474}, {\"ngram\": \"the Paris Games\", \"from\": 1497, \"to\": 1512}, {\"ngram\": \"a working group\", \"from\": 1536, \"to\": 1551}, {\"ngram\": \"the technology\", \"from\": 1555, \"to\": 1569}, {\"ngram\": \"its adoption\", \"from\": 1587, \"to\": 1599}, {\"ngram\": \"sport\", \"from\": 1603, \"to\": 1608}]}, {\"sentence\": \"The local organizers of the Paris Games have sparked controversy with their plans to use AI for security, with a video surveillance system that includes AI-powered cameras to flag potential security risks such as abandoned packages or crowd surges.\", \"from\": 1651, \"to\": 1899, \"entities\": [{\"begin\": 1740, \"end\": 1742, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 1.0, \"rank\": 1.7091727996190573e-16, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}], \"noun_phrases\": [{\"ngram\": \"The local organizers\", \"from\": 1651, \"to\": 1671}, {\"ngram\": \"the Paris Games\", \"from\": 1675, \"to\": 1690}, {\"ngram\": \"controversy\", \"from\": 1704, \"to\": 1715}, {\"ngram\": \"their plans\", \"from\": 1721, \"to\": 1732}, {\"ngram\": \"security\", \"from\": 1747, \"to\": 1755}, {\"ngram\": \"a video surveillance system\", \"from\": 1762, \"to\": 1789}, {\"ngram\": \"AI-powered cameras\", \"from\": 1804, \"to\": 1822}, {\"ngram\": \"potential security risks\", \"from\": 1831, \"to\": 1855}, {\"ngram\": \"abandoned packages\", \"from\": 1864, \"to\": 1882}, {\"ngram\": \"crowd\", \"from\": 1886, \"to\": 1891}, {\"ngram\": \"surges\", \"from\": 1892, \"to\": 1898}]}, {\"sentence\": \"Digital watchdog groups fear that a proposal to legalize smart surveillance systems, even if only temporarily, could infringe on privacy, though the French government insists the systems will not use facial recognition technology.\", \"from\": 1900, \"to\": 2130, \"entities\": [{\"begin\": 2049, \"end\": 2055, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9999287242703926, \"rank\": 4.5153633294746504e-05, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"Digital watchdog groups\", \"from\": 1900, \"to\": 1923}, {\"ngram\": \"smart surveillance systems\", \"from\": 1957, \"to\": 1983}, {\"ngram\": \"privacy\", \"from\": 2029, \"to\": 2036}, {\"ngram\": \"the systems\", \"from\": 2075, \"to\": 2086}, {\"ngram\": \"facial recognition technology\", \"from\": 2100, \"to\": 2129}]}, {\"sentence\": \"Asked about the concerns, Bach told reporters it's up to the authorities in the host country, not the IOC, to decide on \\\"the best tools to apply to secure the games.\\\"\", \"from\": 2132, \"to\": 2298, \"entities\": [{\"begin\": 2158, \"end\": 2162, \"title\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"score\": 0.9999999963888513, \"rank\": 3.61103679888369e-09, \"text\": \"Bach\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"dbpedia\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\"}, {\"begin\": 2234, \"end\": 2237, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.9761671666243175e-19, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"the concerns\", \"from\": 2144, \"to\": 2156}, {\"ngram\": \"reporters\", \"from\": 2168, \"to\": 2177}, {\"ngram\": \"the authorities\", \"from\": 2189, \"to\": 2204}, {\"ngram\": \"the host country\", \"from\": 2208, \"to\": 2224}, {\"ngram\": \"the best tools\", \"from\": 2253, \"to\": 2267}, {\"ngram\": \"the games\", \"from\": 2287, \"to\": 2296}]}, {\"sentence\": \"\\\"What we have seen from the French government and from the authorities is that the efforts to ensure security in Paris are really, on a very wide scope, very professional.\", \"from\": 2300, \"to\": 2471, \"entities\": [{\"begin\": 2328, \"end\": 2334, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9999287242703926, \"rank\": 4.5153633294746504e-05, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 2413, \"end\": 2418, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999989563548, \"rank\": 1.043491278932407e-09, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"the authorities\", \"from\": 2355, \"to\": 2370}, {\"ngram\": \"the efforts\", \"from\": 2379, \"to\": 2390}, {\"ngram\": \"security\", \"from\": 2401, \"to\": 2409}, {\"ngram\": \"a very wide scope\", \"from\": 2434, \"to\": 2451}]}, {\"sentence\": \"So we have all confidence in the French authorities,\\\" he said.\", \"from\": 2472, \"to\": 2534, \"entities\": [{\"begin\": 2505, \"end\": 2511, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9999287242703926, \"rank\": 4.5153633294746504e-05, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"all confidence\", \"from\": 2483, \"to\": 2497}]}, {\"sentence\": \"Skier Lindsey Vonn said she was envious of the AI-powered tools that were not available when she was starting out.\", \"from\": 2536, \"to\": 2650, \"entities\": [{\"begin\": 2542, \"end\": 2554, \"title\": \"http://dbpedia.org/resource/Lindsey_Vonn\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Lindsey Vonn\", \"types\": [\"Q729\", \"Q5\", \"Q4270517\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Lindsey_Vonn\", \"dbpedia\": \"http://dbpedia.org/resource/Lindsey_Vonn\"}], \"noun_phrases\": [{\"ngram\": \"the AI-powered tools\", \"from\": 2579, \"to\": 2599}]}, {\"sentence\": \"Vonn said back in the day she took notes by hand in her performance diary on how different skis, boots and the temperature affected her performance.\", \"from\": 2652, \"to\": 2800, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Vonn\", \"from\": 2652, \"to\": 2656}, {\"ngram\": \"the day\", \"from\": 2670, \"to\": 2677}, {\"ngram\": \"notes\", \"from\": 2687, \"to\": 2692}, {\"ngram\": \"hand\", \"from\": 2696, \"to\": 2700}, {\"ngram\": \"her performance diary\", \"from\": 2704, \"to\": 2725}, {\"ngram\": \"how different skis\", \"from\": 2729, \"to\": 2747}, {\"ngram\": \"boots\", \"from\": 2749, \"to\": 2754}, {\"ngram\": \"the temperature\", \"from\": 2759, \"to\": 2774}, {\"ngram\": \"her performance\", \"from\": 2784, \"to\": 2799}]}, {\"sentence\": \"Nowadays, tablets are used to instantly crunch much more data, as well as give a side-by-side video comparison of the best racing line.\", \"from\": 2801, \"to\": 2936, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"tablets\", \"from\": 2811, \"to\": 2818}, {\"ngram\": \"much more data\", \"from\": 2848, \"to\": 2862}, {\"ngram\": \"side\", \"from\": 2890, \"to\": 2894}, {\"ngram\": \"the best racing line\", \"from\": 2915, \"to\": 2935}]}, {\"sentence\": \"AI can supercharge those analytical tools, she said.\", \"from\": 2937, \"to\": 2989, \"entities\": [{\"begin\": 2937, \"end\": 2939, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 1.0, \"rank\": 1.7091727996190573e-16, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}], \"noun_phrases\": [{\"ngram\": \"those analytical tools\", \"from\": 2956, \"to\": 2978}]}, {\"sentence\": \"\\\"It's not replacing athletes, it's not replacing coaching.\", \"from\": 2991, \"to\": 3049, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"athletes\", \"from\": 3011, \"to\": 3019}]}, {\"sentence\": \"But I think it's just another tool that can be used in a positive way to perform better,\\\" Vonn said.\", \"from\": 3050, \"to\": 3150, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"just another tool\", \"from\": 3067, \"to\": 3084}, {\"ngram\": \"a positive way\", \"from\": 3105, \"to\": 3119}, {\"ngram\": \"Vonn\", \"from\": 3140, \"to\": 3144}]}, {\"sentence\": \"The IOC has partnered with Intel to scout out potential athletes in overlooked places.\", \"from\": 3152, \"to\": 3238, \"entities\": [{\"begin\": 3156, \"end\": 3159, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 1.9761671666243175e-19, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 3179, \"end\": 3184, \"title\": \"http://dbpedia.org/resource/Intel\", \"score\": 0.9999999855708667, \"rank\": 1.442924322045782e-08, \"text\": \"Intel\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Intel\", \"dbpedia\": \"http://dbpedia.org/resource/Intel\"}], \"noun_phrases\": [{\"ngram\": \"potential athletes\", \"from\": 3198, \"to\": 3216}, {\"ngram\": \"overlooked places\", \"from\": 3220, \"to\": 3237}]}, {\"sentence\": \"The tech company took its equipment to Senegal, where they visited five villages and analyzed the athletic ability of 1,000 children by measuring how high they could jump and how fast they could react.\", \"from\": 3239, \"to\": 3440, \"entities\": [{\"begin\": 3278, \"end\": 3285, \"title\": \"http://dbpedia.org/resource/Senegal\", \"score\": 0.9999998537978279, \"rank\": 1.1833352524556666e-07, \"text\": \"Senegal\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Senegal\", \"dbpedia\": \"http://dbpedia.org/resource/Senegal\"}], \"noun_phrases\": [{\"ngram\": \"The tech company\", \"from\": 3239, \"to\": 3255}, {\"ngram\": \"its equipment\", \"from\": 3261, \"to\": 3274}, {\"ngram\": \"five villages\", \"from\": 3306, \"to\": 3319}, {\"ngram\": \"the athletic ability\", \"from\": 3333, \"to\": 3353}, {\"ngram\": \"1,000 children\", \"from\": 3357, \"to\": 3371}]}, {\"sentence\": \"Using AI to analyze the results, \\\"We found 40 that are really promising,\\\" said Christoph Schell, Intel's chief commercial officer.\", \"from\": 3442, \"to\": 3572, \"entities\": [{\"begin\": 3539, \"end\": 3544, \"title\": \"http://dbpedia.org/resource/Intel\", \"score\": 0.9999999855708667, \"rank\": 1.442924322045782e-08, \"text\": \"Intel\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Intel\", \"dbpedia\": \"http://dbpedia.org/resource/Intel\"}], \"noun_phrases\": [{\"ngram\": \"AI\", \"from\": 3448, \"to\": 3450}, {\"ngram\": \"the results\", \"from\": 3462, \"to\": 3473}, {\"ngram\": \"Christoph Schell\", \"from\": 3521, \"to\": 3537}]}, {\"sentence\": \"The shortlisted kids' results were then run through an algorithm that recommended what sports they'd be good at, he said.\", \"from\": 3574, \"to\": 3695, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The shortlisted kids' results\", \"from\": 3574, \"to\": 3603}, {\"ng