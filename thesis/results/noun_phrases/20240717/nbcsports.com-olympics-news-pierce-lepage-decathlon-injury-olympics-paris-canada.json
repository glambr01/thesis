"{\"uid\": \"nbcsports.com-olympics-news-pierce-lepage-decathlon-injury-olympics-paris-canada\", \"noun_phrases\": [{\"sentence\": \"Pierce LePage, the reigning world decathlon champion from Canada, will miss the Paris Olympics due to a herniated disk in his back and will undergo surgery.\", \"from\": 0, \"to\": 156, \"entities\": [{\"begin\": 0, \"end\": 13, \"title\": \"http://dbpedia.org/resource/Pierce_LePage\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Pierce LePage\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Pierce_LePage\", \"dbpedia\": \"http://dbpedia.org/resource/Pierce_LePage\"}, {\"begin\": 58, \"end\": 64, \"title\": \"http://dbpedia.org/resource/Canada_men's_national_ice_hockey_team\", \"score\": 0.9963620986305111, \"rank\": 0.0015207475366222634, \"text\": \"Canada\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Canada_men's_national_ice_hockey_team\", \"dbpedia\": \"http://dbpedia.org/resource/Canada_men's_national_ice_hockey_team\"}], \"noun_phrases\": [{\"ngram\": \"the reigning world decathlon champion\", \"from\": 15, \"to\": 52}, {\"ngram\": \"the Paris Olympics\", \"from\": 76, \"to\": 94}, {\"ngram\": \"a herniated disk\", \"from\": 102, \"to\": 118}, {\"ngram\": \"his back\", \"from\": 122, \"to\": 130}, {\"ngram\": \"surgery\", \"from\": 148, \"to\": 155}]}, {\"sentence\": \"LePage, 28, said he suffered the injury in April.\", \"from\": 158, \"to\": 207, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"LePage\", \"from\": 158, \"to\": 164}, {\"ngram\": \"the injury\", \"from\": 187, \"to\": 197}, {\"ngram\": \"April\", \"from\": 201, \"to\": 206}]}, {\"sentence\": \"The initial prognosis had him ready to return by the Olympics.\", \"from\": 208, \"to\": 270, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The initial prognosis\", \"from\": 208, \"to\": 229}, {\"ngram\": \"the Olympics\", \"from\": 257, \"to\": 269}]}, {\"sentence\": \"\\\"But I just happen to be one of those people who do not naturally heal from disk herniations,\\\"he said in a video posted to social media.\", \"from\": 272, \"to\": 408, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"those people\", \"from\": 304, \"to\": 316}, {\"ngram\": \"disk herniations,\\\"he\", \"from\": 348, \"to\": 368}, {\"ngram\": \"a video\", \"from\": 377, \"to\": 384}, {\"ngram\": \"social media\", \"from\": 395, \"to\": 407}]}, {\"sentence\": \"\\\"I have pushed through injuries before, and I have competed on injuries.\", \"from\": 409, \"to\": 481, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"injuries\", \"from\": 432, \"to\": 440}, {\"ngram\": \"injuries\", \"from\": 472, \"to\": 480}]}, {\"sentence\": \"So, to the very end, until the last week or so, I really thought I was going to push through it and be able to do it, but can not force my back to suddenly start working, no matter how hard I try.\", \"from\": 482, \"to\": 678, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the very end\", \"from\": 489, \"to\": 501}, {\"ngram\": \"the last week\", \"from\": 509, \"to\": 522}, {\"ngram\": \"my back\", \"from\": 618, \"to\": 625}]}, {\"sentence\": \"\\\"I went to meets, tried to test it.\", \"from\": 680, \"to\": 715, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"meets\", \"from\": 691, \"to\": 696}]}, {\"sentence\": \"There was no power.\", \"from\": 716, \"to\": 735, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"no power\", \"from\": 726, \"to\": 734}]}, {\"sentence\": \"Nothing was really going on, and it got to the point where it was either go to the Olympics, score 7,000 points, if that, or hurt myself and risk future long-lasting damage.\", \"from\": 736, \"to\": 909, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Nothing\", \"from\": 736, \"to\": 743}, {\"ngram\": \"the point\", \"from\": 779, \"to\": 788}, {\"ngram\": \"the Olympics\", \"from\": 815, \"to\": 827}, {\"ngram\": \"future long-lasting damage\", \"from\": 882, \"to\": 908}]}, {\"sentence\": \"My mind wants to be there, but every sign in my body is telling me not to, and that it's a mistake.\", \"from\": 910, \"to\": 1009, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My mind\", \"from\": 910, \"to\": 917}, {\"ngram\": \"every sign\", \"from\": 941, \"to\": 951}, {\"ngram\": \"my body\", \"from\": 955, \"to\": 962}, {\"ngram\": \"a mistake\", \"from\": 999, \"to\": 1008}]}, {\"sentence\": \"So me and my team, we ultimately made the decision not to go.\\\"\", \"from\": 1010, \"to\": 1072, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the decision\", \"from\": 1048, \"to\": 1060}]}, {\"sentence\": \"Last August, LePage led a Canadian one-two in the decathlon at the world championships with Tokyo Olympic gold medalist Damian Warner.\", \"from\": 1074, \"to\": 1208, \"entities\": [{\"begin\": 1166, \"end\": 1171, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.789947694592241, \"rank\": 0.2655938751177001, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}, {\"begin\": 1201, \"end\": 1207, \"title\": \"http://dbpedia.org/resource/Warner_Bros.\", \"score\": 0.9789314739293756, \"rank\": 0.02129628945518557, \"text\": \"Warner\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Warner_Bros.\", \"dbpedia\": \"http://dbpedia.org/resource/Warner_Bros.\"}], \"noun_phrases\": [{\"ngram\": \"LePage\", \"from\": 1087, \"to\": 1093}, {\"ngram\": \"the decathlon\", \"from\": 1120, \"to\": 1133}]}, {\"sentence\": \"LePage was fifth in his Olympic debut in Tokyo (competing with a torn patellar tendon).\", \"from\": 1210, \"to\": 1297, \"entities\": [{\"begin\": 1251, \"end\": 1256, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.789947694592241, \"rank\": 0.2655938751177001, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource