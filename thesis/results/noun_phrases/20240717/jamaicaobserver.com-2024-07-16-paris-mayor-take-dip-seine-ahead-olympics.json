}, {\"ngram\": \"a former canoeist\", \"from\": 1683, \"to\": 1700}, {\"ngram\": \"the top security official\", \"from\": 1706, \"to\": 1731}, {\"ngram\": \"Marc Guillaume\", \"from\": 1762, \"to\": 1776}]}, {\"sentence\": \"President Emmanuel Macron, who had promised to join the Seine bathers, will be a notable absentee, with the head of state occupied by a political crisis caused by his decision to call snap parliamentary elections last month.\", \"from\": 1779, \"to\": 2003, \"entities\": [{\"begin\": 1789, \"end\": 1804, \"title\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Emmanuel Macron\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emmanuel_Macron\", \"dbpedia\": \"http://dbpedia.org/resource/Emmanuel_Macron\"}, {\"begin\": 1835, \"end\": 1840, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999999999545253, \"rank\": 4.534295086995487e-11, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"a notable absentee\", \"from\": 1858, \"to\": 1876}, {\"ngram\": \"the head\", \"from\": 1883, \"to\": 1891}, {\"ngram\": \"state\", \"from\": 1895, \"to\": 1900}, {\"ngram\": \"a political crisis\", \"from\": 1913, \"to\": 1931}, {\"ngram\": \"his decision\", \"from\": 1942, \"to\": 1954}, {\"ngram\": \"snap parliamentary elections\", \"from\": 1963, \"to\": 1991}]}, {\"sentence\": \"The Seine is set to be used for the swimming leg of the Olympics triathlon on July 30-31 and August 5, as well as the open-water swimming on August 8-9.\", \"from\": 2005, \"to\": 2157, \"entities\": [{\"begin\": 2009, \"end\": 2014, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999999999545253, \"rank\": 4.534295086995487e-11, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"the swimming leg\", \"from\": 2037, \"to\": 2053}, {\"ngram\": \"the Olympics triathlon\", \"from\": 2057, \"to\": 2079}, {\"ngram\": \"July\", \"from\": 2083, \"to\": 2087}, {\"ngram\": \"August\", \"from\": 2098, \"to\": 2104}, {\"ngram\": \"the open-water swimming\", \"from\": 2119, \"to\": 2142}, {\"ngram\": \"August\", \"from\": 2146, \"to\": 2152}]}, {\"sentence\": \"The locations chosen for open-water swimming have caused difficulties at past Olympics, notably ahead of the 2016 Rio de Janeiro Games and those in Tokyo in 2021.\", \"from\": 2159, \"to\": 2321, \"entities\": [{\"begin\": 2307, \"end\": 2312, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.999974928504863, \"rank\": 1.9316871068589298e-05, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"The locations\", \"from\": 2159, \"to\": 2172}, {\"ngram\": \"open-water swimming\", \"from\": 2184, \"to\": 2203}, {\"ngram\": \"difficulties\", \"from\": 2216, \"to\": 2228}, {\"ngram\": \"past Olympics\", \"from\": 2232, \"to\": 2245}, {\"ngram\": \"the 2016 Rio de Janeiro Games\", \"from\": 2264, \"to\": 2293}]}, {\"sentence\": \"\\\"It's been raining all over France.\", \"from\": 2323, \"to\": 2358, \"entities\": [{\"begin\": 2351, \"end\": 2357, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.997745876935385, \"rank\": 0.001982145398990612, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": []}, {\"sentence\": \"Summer has been very late to arrive and so have the good results,\\\" said Marc Valmassoni from clean-water campaign group Surfrider which has been conducting weekly tests on the Seine since last year.\", \"from\": 2359, \"to\": 2557, \"entities\": [{\"begin\": 2535, \"end\": 2540, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999999999545253, \"rank\": 4.534295086995487e-11, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"Summer\", \"from\": 2359, \"to\": 2365}, {\"ngram\": \"the good results\", \"from\": 2407, \"to\": 2423}, {\"ngram\": \"Marc Valmassoni\", \"from\": 2431, \"to\": 2446}, {\"ngram\": \"clean-water campaign group Surfrider\", \"from\": 2452, \"to\": 2488}, {\"ngram\": \"weekly tests\", \"from\": 2515, \"to\": 2527}, {\"ngram\": \"last year\", \"from\": 2547, \"to\": 2556}]}, {\"sentence\": \"\\\"They are not excellent, they are not terrible, they are average.\", \"from\": 2559, \"to\": 2624, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"But at this time the water is swimmable.\\\"\", \"from\": 2625, \"to\": 2666, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"this time\", \"from\": 2632, \"to\": 2641}, {\"ngram\": \"the water\", \"from\": 2642, \"to\": 2651}]}, {\"sentence\": \"Cleaning up the Seine has been promoted as one of the key legacy achievements of Paris 2024, with Hidalgo intending to create three public bathing areas for the city's residents next year, a century after swimming was banned.\", \"from\": 2668, \"to\": 2893, \"entities\": [{\"begin\": 2684, \"end\": 2689, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 0.9999999999545253, \"rank\": 4.534295086995487e-11, \"text\": \"Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}, {\"begin\": 2749, \"end\": 2759, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.2063613613760415e