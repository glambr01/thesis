rom\": 1284, \"to\": 1310}]}, {\"sentence\": \"Surrounded by elite coaches and teammates in a pre-Games camp in France, Taylor has plenty of support to lean on but he said it was hard being away from his champion mother and that he had been in touch with her every day.\", \"from\": 1343, \"to\": 1565, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"elite coaches\", \"from\": 1357, \"to\": 1370}, {\"ngram\": \"teammates\", \"from\": 1375, \"to\": 1384}, {\"ngram\": \"a pre-Games camp\", \"from\": 1388, \"to\": 1404}, {\"ngram\": \"France\", \"from\": 1408, \"to\": 1414}, {\"ngram\": \"Taylor\", \"from\": 1416, \"to\": 1422}, {\"ngram\": \"plenty\", \"from\": 1427, \"to\": 1433}, {\"ngram\": \"support\", \"from\": 1437, \"to\": 1444}, {\"ngram\": \"his champion mother\", \"from\": 1496, \"to\": 1515}, {\"ngram\": \"touch\", \"from\": 1540, \"to\": 1545}]}, {\"sentence\": \"\\\"She has not given me any advice -- she's just really proud of me and wants me to go out there and do my best,\\\" he said.\", \"from\": 1567, \"to\": 1687, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"any advice\", \"from\": 1589, \"to\": 1599}]}, {\"sentence\": \"\\\"She's coming over to watch and I can not wait to see her in the stands and I know she will be cheering hard.\\\"\", \"from\": 1689, \"to\": 1799, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the stands\", \"from\": 1750, \"to\": 1760}]}, {\"sentence\": \"Taylor already has big-event experience.\", \"from\": 1801, \"to\": 1841, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Taylor\", \"from\": 1801, \"to\": 1807}, {\"ngram\": \"big-event experience\", \"from\": 1820, \"to\": 1840}]}, {\"sentence\": \"He won the 4x100 freestyle relay world title at Fukuoka last year while grabbing bronzes in the 200 relay and 4x100 medley relay events.\", \"from\": 1843, \"to\": 1979, \"entities\": [{\"begin\": 1891, \"end\": 1898, \"title\": \"http://dbpedia.org/resource/Fukuoka\", \"score\": 0.9999999999326974, \"rank\": 6.721495