"{\"uid\": \"metro.co.uk-2024-08-20-olympics-exhausting-crawled-onto-pitch-play-21457496\", \"noun_phrases\": [{\"sentence\": \"I have to admit I would have done anything to be at theOlympics.\", \"from\": 0, \"to\": 64, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"anything\", \"from\": 34, \"to\": 42}, {\"ngram\": \"theOlympics\", \"from\": 52, \"to\": 63}]}, {\"sentence\": \"I definitely have some 'FOMO'.\", \"from\": 65, \"to\": 95, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"some 'FOMO\", \"from\": 83, \"to\": 93}]}, {\"sentence\": \"A Games is an amazing experience and one which I got to have in Tokyo three years ago, albeit during thecoronaviruspandemic.\", \"from\": 97, \"to\": 221, \"entities\": [{\"begin\": 161, \"end\": 166, \"title\": \"http://dbpedia.org/resource/Tokyo\", \"score\": 0.898944188324139, \"rank\": 0.11241611018347827, \"text\": \"Tokyo\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Tokyo\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo\"}], \"noun_phrases\": [{\"ngram\": \"A Games\", \"from\": 97, \"to\": 104}, {\"ngram\": \"an amazing experience\", \"from\": 108, \"to\": 129}, {\"ngram\": \"thecoronaviruspandemic\", \"from\": 198, \"to\": 220}]}, {\"sentence\": \"When we failed to qualify Great Britain forParis, it was very hard indeed.\", \"from\": 223, \"to\": 297, \"entities\": [{\"begin\": 249, \"end\": 262, \"title\": \"http://dbpedia.org/resource/Great_Britain_at_the_Olympics\", \"score\": 0.8452605336800272, \"rank\": 0.10964365139643595, \"text\": \"Great Britain\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Great_Britain_at_the_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Great_Britain_at_the_Olympics\"}], \"noun_phrases\": []}, {\"sentence\": \"I would have crawled onto the pitch to be at the Olympics!\", \"from\": 298, \"to\": 356, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the pitch\", \"from\": 324, \"to\": 333}, {\"ngram\": \"the Olympics\", \"from\": 343, \"to\": 355}]}, {\"sentence\": \"But maybe there is a silver living in there somewhere, as tough as that is to admit because it was very difficult to watch from afar wanting to be there.\", \"from\": 358, \"to\": 511, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a silver\", \"from\": 377, \"to\": 385}]}, {\"sentence\": \"And that is I have managed to have a proper break thissummerwithout a tournament to play in.\", \"from\": 512, \"to\": 604, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a proper break thissummerwithout\", \"from\": 547, \"to\": 579}, {\"ngram\": \"a tournament\", \"from\": 580, \"to\": 592}]}, {\"sentence\": \"I even managed to have a family holiday for the first time in 15 years.\", \"from\": 605, \"to\": 676, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a family holiday\", \"from\": 628, \"to\": 644}, {\"ngram\": \"the first time\", \"from\": 649, \"to\": 663}, {\"ngram\": \"15 years\", \"from\": 667, \"to\": 675}]}, {\"sentence\": \"I am very relaxed going to the US on tour with my new club Chelsea and in that respect it's been good to have a rest.\", \"from\": 678, \"to\": 795, \"entities\": [{\"begin\": 709, \"end\": 711, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 0.9999979369057109, \"rank\": 2.0611072206909036e-06, \"text\": \"US\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\"}, {\"begin\": 737, \"end\": 744, \"title\": \"http://dbpedia.org/resource/Chelsea_F.C._Women\", \"score\": 0.9999831537479807, \"rank\": 1.6846535767761185e-05, \"text\": \"Chelsea\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Chelsea_F.C._Women\", \"dbpedia\": \"http://dbpedia.org/resource/Chelsea_F.C._Women\"}], \"noun_phrases\": [{\"ngram\": \"tour\", \"from\": 715, \"to\": 719}, {\"ngra