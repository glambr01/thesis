2495, \"entities\": [{\"begin\": 2456, \"end\": 2474, \"title\": \"http://dbpedia.org/resource/ABC_Radio_Adelaide\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"ABC Radio Adelaide\", \"types\": [\"Q43229\", \"Q24229398\", \"Q15265344\"], \"wikid\": \"http://dbpedia.org/resource/ABC_Radio_Adelaide\", \"dbpedia\": \"http://dbpedia.org/resource/ABC_Radio_Adelaide\"}], \"noun_phrases\": [{\"ngram\": \"Flights\", \"from\": 2401, \"to\": 2408}, {\"ngram\": \"all members\", \"from\": 2413, \"to\": 2424}, {\"ngram\": \"the team\", \"from\": 2428, \"to\": 2436}, {\"ngram\": \"economy class\", \"from\": 2480, \"to\": 2493}]}, {\"sentence\": \"It comes after the national broadcaster said the duo had a \\\"French adventure\\\" and \\\"immersed themselves in all the action at street level to make us feel like we were part of the action\\\".\", \"from\": 2497, \"to\": 2683, \"entities\": [{\"begin\": 2557, \"end\": 2563, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.999610499315212, \"rank\": 0.00038226301724903503, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"the national broadcaster\", \"from\": 2512, \"to\": 2536}, {\"ngram\": \"the duo\", \"from\": 2542, \"to\": 2549}, {\"ngram\": \"all the action\", \"from\": 2603, \"to\": 2617}, {\"ngram\": \"street level\", \"from\": 2621, \"to\": 2633}, {\"ngram\": \"us\", \"from\": 2642, \"to\": 2644}, {\"ngram\": \"part\", \"from\": 2663, \"to\": 2667}, {\"ngram\": \"the action\", \"from\": 2671, \"to\": 2681}]}, {\"sentence\": \"This prompted South Australian Liberal Senator Alex Antic to lash out against the broadcaster for allowing taxpayers to fund their lavish trip, despite allegedly failing to fulfil their duties.\", \"from\": 2685, \"to\": 2878, \"entities\": [{\"begin\": 2705, \"end\": 2715, \"title\": \"http://dbpedia.org/resource/Australian_Government\", \"score\": 0.5771702957803732, \"rank\": 0.730025785387969, \"text\": \"Australian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Australian_Government\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_Government\"}, {\"begin\": 2732, \"end\": 2742, \"title\": \"http://dbpedia.org/resource/Alex_Antic\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Alex Antic\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Alex_Antic\", \"dbpedia\": \"http://dbpedia.org/resource/Alex_Antic\"}], \"noun_phrases\": [{\"ngram\": \"the broadcaster\", \"from\": 2763, \"to\": 2778}, {\"ngram\": \"taxpayers\", \"from\": 2792, \"to\": 2801}, {\"ngram\": \"their lavish trip\", \"from\": 2810, \"to\": 2827}, {\"ngram\": \"their duties\", \"from\": 2865, \"to\": 2877}]}, {\"sentence\": \"\\\"It is staggering that the ABC thinks that spending $135,000 to send two breakfast radio hosts and two staff to Paris for the Olympic games represents value for money for the Australian taxpayer,\\\" Mr Antic said.\", \"from\": 2880, \"to\": 3091, \"entities\": [{\"begin\": 2907, \"end\": 2910, \"title\": \"http://dbpedia.org/resource/Australian_Broadcasting_Corporation\", \"score\": 0.9999999992364792, \"rank\": 7.633149884376711e-10, \"text\": \"ABC\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Australian_Broadcasting_Corporation\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_Broadcasting_Corporation\"}, {\"begin\": 2992, \"end\": 2997, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999999999799911, \"rank\": 2.0022665026469236e-11, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 3055, \"end\": 3065, \"title\": \"http://dbpedia.org/resource/Australian_Government\", \"score\": 0.5771702957803732, \"rank\": 0.730025785387969, \"text\": \"Australian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Australian_Government\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_Government\"}, {\"begin\": 3080, \"end\": 3085, \"title\": \"http://dbpedia.org/resource/Antic_Collective\", \"score\": 0.9921836036365975, \"rank\": 0.007796626288390214, \"text\": \"Antic\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Antic_Collective\", \"dbpedia\": \"http://dbpedia.org/resource/Antic_Collective\"}], \"noun_phrases\": [{\"ngram\": \"two breakfast radio hosts\", \"from\": 2949, \"to\": 2974}, {\"ngram\": \"two staff\", \"from\": 2979, \"to\": 2988}, {\"ngram\": \"the Olympic games\", \"from\": 3002, \"to\": 3019}, {\"ngram\": \"value\", \"from\": 3031, \"to\": 3036}, {\"ngram\": \"money\", \"from\": 3041, \"to\": 3046}]}, {\"sentence\": \"\\\"It is difficult to reconcile spending like this with repetitious claims that the ABC is underfunded,\\\" he said.\", \"from\": 3093, \"to\": 3204, \"entities\": [{\"begin\": 3175, \"end\": 3178, \"title\": \"http://dbpedia.org/resource/Australian_Broadcasting_Corporation\", \"score\": 0.9999999992364792, \"rank\": 7.633149884376711e-10, \"text\": \"ABC\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Australian_Broadcasting_Corporation\", \"dbpedia\": \"http://dbpedia.org/resource/Australian_Broadcasting_Corporation\"}], \"noun_phrases\": [{\"ngram\": \"spending\", \"from\": 3123, \"to\": 3131}, {\"ngram\": \"repetitious claims\", \"from\": 3147, \"to\": 3165}]}, {\"sentence\": \"It comes after ABC's own chairman Kim Williams took aim at the broadcaster's priorities and slammed its handling of stories in July.\", \"from\": 3206, \"to\": 3338, \"entities\": [{\"begin\": 3221, \"end\": 3224, \"title\": \"http://dbpedia.org/resource/Australian_Broadcasting_Corporation\", \"score\": 0.9999999992364792, \"rank\": 7.633149884376711e-10, \"text\": \"ABC\", \"types\": [\"Q4830453\", \"Q43229\", \"Q2422939