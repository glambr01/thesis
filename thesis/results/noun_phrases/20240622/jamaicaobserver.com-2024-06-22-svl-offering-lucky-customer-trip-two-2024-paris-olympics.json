noun_phrases\": [{\"ngram\": \"customers\", \"from\": 272, \"to\": 281}, {\"ngram\": \"the opportunity\", \"from\": 282, \"to\": 297}, {\"ngram\": \"an all-expense-paid trip\", \"from\": 305, \"to\": 329}, {\"ngram\": \"the Games\", \"from\": 341, \"to\": 350}]}, {\"sentence\": \"Additionally, participants can look forward to weekly prizes, ensuring numerous chances to win big throughout the promotion period, which kicked off on May 30 and runs until July 5, 2024.\", \"from\": 353, \"to\": 540, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"participants\", \"from\": 367, \"to\": 379}, {\"ngram\": \"weekly prizes\", \"from\": 400, \"to\": 413}, {\"ngram\": \"numerous chances\", \"from\": 424, \"to\": 440}, {\"ngram\": \"the promotion period\", \"from\": 463, \"to\": 483}, {\"ngram\": \"May\", \"from\": 505, \"to\": 508}, {\"ngram\": \"July\", \"from\": 527, \"to\": 531}]}, {\"sentence\": \"According to head of marketing at SVL Kamal Powell, the promotion is another way for the company to provide a ticket to its customers' dreams.\", \"from\": 542, \"to\": 684, \"entities\": [{\"begin\": 576, \"end\": 579, \"title\": \"http://dbpedia.org/resource/Snout\\u2013vent_length\", \"score\": 0.9991385925598034, \"rank\": 0.0, \"text\": \"SVL\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Snout\\u2013vent_length\", \"dbpedia\": \"http://dbpedia.org/resource/Snout\\u2013vent_length\"}, {\"begin\": 580, \"end\": 585, \"title\": \"http://dbpedia.org/resource/Kamal_Haasan\", \"score\": 0.659989484369726, \"rank\": 0.5151752318462112, \"text\": \"Kamal\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Kamal_Haasan\", \"dbpedia\": \"http://dbpedia.org/resource/Kamal_Haasan\"}, {\"begin\": 586, \"end\": 592, \"title\": \"http://dbpedia.org/resource/Lewis_F._Powell_Jr.\", \"score\": 0.9963102860017773, \"rank\": 0.003703375760475168, \"text\": \"Powell\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Lewis_F._Powell_Jr.\", \"dbpedia\": \"http://dbpedia.org/resource/Lewis_F._Powell_Jr.\"}], \"noun_phrases\": [{\"ngram\": \"head\", \"from\": 555, \"to\": 559}, {\"ngram\": \"marketing\", \"from\": 563, \"to\": 572}, {\"ngram\": \"the promotion\", \"from\": 594, \"to\": 607}, {\"ngram\": \"another way\", \"from\": 611, \"to\": 622}, {\"ngram\": \"the company\", \"from\": 627, \"to\": 638}, {\"ngram\": \"a ticket\", \"from\": 650, \"to\": 658}, {\"ngram\": \"its customers' dreams\", \"from\": 662, \"to\": 683}]}, {\"sentence\": \"\\\"We know that the Olympics are a big deal for Jamaicans, it is a time when we all come together to show our support for the love of sports and especially track and field.\", \"from\": 686, \"to\": 856, \"entities\": [{\"begin\": 732, \"end\": 741, \"title\": \"http://dbpedia.org/resource/Jamaicans\", \"score\": 0.9918524692608984, \"rank\": 0.008208448081876422, \"text\": \"Jamaicans\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Jamaicans\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaicans\"}], \"noun_phrases\": [{\"ngram\": \"the Olympics\", \"from\": 700, \"to\": 712}, {\"ngram\": \"a big deal\", \"from\": 717, \"to\": 727}, {\"ngram\": \"a time\", \"from\": 749, \"to\": 755}, {\"ngram\": \"our support\", \"from\": 790, \"to\": 801}, {\"ngram\": \"the love\", \"from\": 806, \"to\": 814}, {\"ngram\": \"sports\", \"from\": 818, \"to\": 824}, {\"ngram\": \"field\", \"from\": 850, \"to\": 855}]}, {\"sentence\": \"SVL wants to be at the very heart of that experience, what better way to cheer on the black, green and gold than to be live in Paris because of your Supreme Ventures Golden ticket,\\\" said Powell.\", \"from\": 857, \"to\": 1051, \"entities\": [{\"begin\": 857, \"end\": 860, \"title\": \"http://dbpedia.org/resource/Snout\\u2013vent_length\", \"score\": 0.9991385925598034, \"rank\": 0.0, \"text\": \"SVL\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Snout\\u2013vent_length\", \"dbpedia\": \"http://dbpedia.org/resource/Snout\\u2013vent_length\"}, {\"begin\": 984, \"end\": 989, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 0.9999998074158797, \"rank\": 1.9258425573900882e-07, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 1044, \"end\": 1050, \"title\": \"http://dbpedia.org/resource/Lewis_F._Powell_Jr.\", \"score\": 0.9963102860017773, \"rank\": 0.003703375760475168, \"text\": \"Powell\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Lewis_F._Powell_Jr.\", \"dbpedia\": \"http://dbpedia.org/resource/Lewis_F._Powell_Jr.\"}], \"noun_phrases\": [{\"ngram\": \"the very heart\", \"from\": 876, \"to\": 890}, {\"ngram\": \"that experience\", \"from\": 894, \"to\": 909}, {\"ngram\": \"what better way\", \"from\": 911, \"to\": 926}, {\"ngram\": \"gold\", \"from\": 960, \"to\": 964}, {\"ngram\": \"your Supreme Ventures Golden ticket\", \"from\": 1001, \"to\": 1036}]}, {\"sentence\": \"He argued that the Golden Ticket promotion is simple and convenient.\", \"from\": 1053, \"to\": 1121, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the Golden Ticket promotion\", \"from\": 1068, \"to\": 1095}]}, {\"sentence\": \"Customers are required to spend $500 or more on any Supreme Ventures product, either in-store or online atwww.supremegames.com.\", \"from\": 1122, \"to\": 1249, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Customers\", \"from\": 1122, \"to\": 1131}, {\"ngram\": \"any Supreme Ventures product\", \"from\": 1170, \"to\": 1198}, {\"ngram\": \"store\", \"from\": 1210, \"to\": 1215}]}, {\"sentence\": \"After making a qualifying purchase, customers should write their name, phone number, and address on the back of their ticket and drop it into the designated boxes available at any SVL-operated retail store, regardless of where the ticket was originally purchased.\", \"from\": 1251, \"to\": 1514, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a qualifying purchase\", \"from\": 1264, \"to\": 1285}, {\"ngram\": \"customers\", \"from\": 1287, \"to\": 1296}, {\"ngram\": \"their name\", \"from\": 1310, \"to\": 1320}, {\"ngram\": \"phone number\", \"from\": 1322, \"to\": 1334}, {\"ngram\": \"address\", \"from\": 1340, \"to\": 1347}, {\"ngram\": \"the back\", \"from\": 1351, \"to\": 1359}, {\"ngram\": \"their ticket\", \"from\": 1363, \"to\": 1375}, {\"ngram\": \"the designated boxes\", \"from\": 1393, \"to\": 1413}, {\"ngram\": \"any SVL-operated retail store\", \"from\": 1427, \"to\": 1456}, {\"ngram\": \"the ticket\", \"from\": 1478, \"to\": 1488}]}, {\"sentence\": \"Alternatively, customers can enter online by visitingpromotions.supremegames.comand filling out the digital form.\", \"from\": 1516, \"to\": 1629, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"customers\", \"from\": 1531, \"to\": 1540}, {\"ngram\": \"visitingpromotions.supremegames.comand\", \"from\": 1561, \"to\": 1599}, {\"ngram\": \"the digital form\", \"from\": 1612, \"to\": 1628}]}, {\"sentence\": \"For those who prefer to place their bets online on SV Games, entries will be automatically generated for every $500 spent.\", \"from\": 1631, \"to\": 1753, \"entities\": [{\"begin\": 1682, \"end\": 1684, \"title\": \"http://dbpedia.org/resource/Sino-Vietnamese_vocabulary\", \"score\": 0.9999999997301074, \"rank\": 1.5058355170408223e-10, \"text\": \"SV\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Sino-Vietnamese_vocabulary\", \"dbpedia\": \"http://dbpedia.org/resource/Sino-Vietnamese_vocabulary\"}], \"noun_phrases\": [{\"ngram\": \"their bets\", \"from\": 1661, \"to\": 1671}, {\"ngram\": \"entries\", \"from\": 1692, \"to\": 1699}]}, {\"sentence\": \"\\\"There is no limit to the number of entries a customer can make, so the more times they enter, the greater their chances of winning the coveted Supreme Ventures Golden Ticket,\\\" added Powell.\", \"from\": 1755, \"to\": 1945, \"entities\": [{\"begin\": 1938, \"end\": 1944, \"title\": \"http://dbpedia.org/resource/Lewis_F._Powell_Jr.\", \"score\": 0.9963102860017773, \"rank\": 0.003703375760475168, \"text\": \"Powell\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Lewis_F._Powell_Jr.\", \"dbpedia\": \"http://dbpedia.org/resource/Lewis_F._Powell_Jr.\"}], \"noun_phrases\": [{\"ngram\": \"no limit\", \"from\": 1765, \"to\": 1773}, {\"ngram\": \"the number\", \"from\": 1777, \"to\": 1787}, {\"ngram\": \"entries\", \"from\": 1791, \"to\": 1798}, {\"ngram\": \"a customer\", \"from\": 1799, \"to\": 1809}, {\"ngram\": \"the coveted Supreme Ventures Golden Ticket\", \"from\": 1887, \"to\": 1929}]}, {\"sentence\": \"He said Supreme Ventures will be announcing weekly winners via the company's website and social media pages.\", \"from\": 1947, \"to\": 2055, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Supreme Ventures\", \"from\": 1955, \"to\": 1971}, {\"ngram\": \"weekly winners\", \"from\": 1991, \"to\": 2005}, {\"ngram\": \"the company's website\", \"from\": 2010, \"to\": 2031}, {\"ngram\": \"social media pages\", \"from\": 2036, \"to\": 2054}]}, {\"sentence\": \"Customers can also visit any SVL-operated retail store or COCO store for updates and information.\", \"from\": 2056, \"to\": 2153, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Customers\", \"from\": 2056, \"to\": 2065}, {\"ngram\": \"any SVL-operated retail store or COCO store\", \"from\": 2081, \"to\": 2124}, {\"ngram\": \"updates\", \"from\": 2129, \"to\": 2136}, {\"ngram\": \"information\", \"from\": 2141, \"to\": 2152}]}, {\"sentence\": \"The grand prize draw, which will determine the lucky recipient of the trip for two to the 2024 Paris Olympics, will be held on July 8, 2024.\", \"from\": 2155, \"to\": 2295, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The grand prize draw\