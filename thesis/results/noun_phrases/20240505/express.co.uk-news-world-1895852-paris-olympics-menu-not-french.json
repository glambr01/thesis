begin\": 610, \"end\": 615, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 1.945549589183737e-23, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 672, \"end\": 678, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.7472387468659376, \"rank\": 0.33826027749524734, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"tourist buses\", \"from\": 653, \"to\": 666}, {\"ngram\": \"twice as much meat\", \"from\": 686, \"to\": 704}, {\"ngram\": \"the global average\", \"from\": 708, \"to\": 726}, {\"ngram\": \"the highest beef\", \"from\": 737, \"to\": 753}, {\"ngram\": \"veal consumption\", \"from\": 758, \"to\": 774}, {\"ngram\": \"inhabitant\", \"from\": 779, \"to\": 789}, {\"ngram\": \"Europe\", \"from\": 793, \"to\": 799}]}, {\"sentence\": \"But the organisers of the 33rd Olympiad are looking to flip the script by introducing an array of vegetarian dishes to show that France is now more about \\\"leaf\\\" than \\\"beef\\\".\", \"from\": 803, \"to\": 976, \"entities\": [{\"begin\": 932, \"end\": 938, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 1.0, \"rank\": 5.252580677948425e-19, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"the organisers\", \"from\": 807, \"to\": 821}, {\"ngram\": \"the 33rd Olympiad\", \"from\": 825, \"to\": 842}, {\"ngram\": \"the script\", \"from\": 863, \"to\": 873}, {\"ngram\": \"an array\", \"from\": 889, \"to\": 897}, {\"ngram\": \"vegetarian dishes\", \"from\": 901, \"to\": 918}, {\"ngram\": \"\\\"leaf\", \"from\": 957, \"to\": 962}, {\"ngram\": \"\\\"beef\", \"from\": 969, \"to\": 974}]}, {\"sentence\": \"It's been announced that 60 per cent of the food served to the general public during the event will be meat-free and 80 per cent of all dishes will be sourced from local produce in France.\", \"from\": 978, \"to\": 1166, \"entities\": [{\"begin\": 1159, \"end\": 1165, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 1.0, \"rank\": 5.252580677948425e-19, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"60 per cent\", \"from\": 1003, \"to\": 1014}, {\"ngram\": \"the food\", \"from\": 1018, \"to\": 1026}, {\"ngram\": \"the general public\", \"from\": 1037, \"to\": 1055}, {\"ngram\": \"the event\", \"from\": 1063, \"to\": 1072}, {\"ngram\": \"80 per cent\", \"from\": 1095, \"to\": 1106}, {\"ngram\": \"all dishes\", \"from\": 1110, \"to\": 1120}, {\"ngram\": \"local produce\", \"from\": 1142, \"to\": 1155}]}, {\"sentence\": \"Paris 2024 President Tony Estanguet said: \\\"It's also our responsibility to educate the people who will be engaged in Paris 2024.\", \"from\": 1168, \"to\": 1296, \"entities\": [{\"begin\": 1168, \"end\": 1178, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.1018603700255977e-26, \"text\": \"Paris 2024\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2024_Summer_Olympics\"}, {\"begin\": 1189, \"end\": 1203, \"title\": \"http://dbpedia.org/resource/Tony_Estanguet\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Tony Estanguet\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Tony_Estanguet\", \"dbpedia\": \"http://dbpedia.org/resource/Tony_Estanguet\"}, {\"begin\": 1285, \"end\": 1295, \"title\": \"http://dbpedia.org/resource/2024_Summer_Olympics\", \"score\": 1.0, \"rank\": 1.1018603700255977e-26,