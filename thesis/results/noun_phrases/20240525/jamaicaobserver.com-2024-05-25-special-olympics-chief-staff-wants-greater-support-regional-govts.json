"{\"uid\": \"jamaicaobserver.com-2024-05-25-special-olympics-chief-staff-wants-greater-support-regional-govts\", \"noun_phrases\": [{\"sentence\": \"GRAND CAYMAN, Cayman Islands - Shawn Ferguson, chief of global government relations for Special Olympics International (SOI), says programmes in the Caribbean Initiative will have even greater traction if they can leverage more support from their respective governments.\", \"from\": 0, \"to\": 270, \"entities\": [{\"begin\": 0, \"end\": 12, \"title\": \"http://dbpedia.org/resource/Cayman_Islands\", \"score\": 0.9995921433031986, \"rank\": 0.0004080231118698163, \"text\": \"GRAND CAYMAN\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Cayman_Islands\", \"dbpedia\": \"http://dbpedia.org/resource/Cayman_Islands\"}, {\"begin\": 14, \"end\": 28, \"title\": \"http://dbpedia.org/resource/Cayman_Islands\", \"score\": 0.9999999999986358, \"rank\": 1.3039319539530452e-12, \"text\": \"Cayman Islands\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Cayman_Islands\", \"dbpedia\": \"http://dbpedia.org/resource/Cayman_Islands\"}, {\"begin\": 31, \"end\": 45, \"title\": \"http://dbpedia.org/resource/Shawn_Ferguson\", \"score\": 0.9999999999993179, \"rank\": 0.0, \"text\": \"Shawn Ferguson\", \"types\": [\"Q937857\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Shawn_Ferguson\", \"dbpedia\": \"http://dbpedia.org/resource/Shawn_Ferguson\"}, {\"begin\": 88, \"end\": 104, \"title\": \"http://dbpedia.org/resource/Special_Olympics\", \"score\": 1.0, \"rank\": 1.6098116621068358e-14, \"text\": \"Special Olympics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Special_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Special_Olympics\"}, {\"begin\": 120, \"end\": 123, \"title\": \"http://dbpedia.org/resource/Silicon_on_insulator\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"SOI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Silicon_on_insulator\", \"dbpedia\": \"http://dbpedia.org/resource/Silicon_on_insulator\"}, {\"begin\": 149, \"end\": 169, \"title\": \"http://dbpedia.org/resource/Caribbean_Initiative\", \"score\": 0.9999999998890416, \"rank\": 0.0, \"text\": \"Caribbean Initiative\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Caribbean_Initiative\", \"dbpedia\": \"http://dbpedia.org/resource/Caribbean_Initiative\"}], \"noun_phrases\": [{\"ngram\": \"chief\", \"from\": 47, \"to\": 52}, {\"ngram\": \"global government relations\", \"from\": 56, \"to\": 83}, {\"ngram\": \"programmes\", \"from\": 131, \"to\": 141}, {\"ngram\": \"even greater traction\", \"from\": 180, \"to\": 201}, {\"ngram\": \"more support\", \"from\": 223, \"to\": 235}, {\"ngram\": \"their respective governments\", \"from\": 241, \"to\": 269}]}, {\"sentence\": \"He pointed to the Special Olympics global leadership coalition for inclusion as the platform for ratifying agreements between national programmes and their governments.\", \"from\": 272, \"to\": 440, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the Special Olympics global leadership coalition\", \"from\": 286, \"to\": 334}, {\"ngram\": \"inclusion\", \"from\": 339, \"to\": 348}, {\"ngram\": \"the platform\", \"from\": 352, \"to\": 364}, {\"ngram\": \"agreements\", \"from\": 379, \"to\": 389}, {\"ngram\": \"national programmes\", \"from\": 398, \"to\": 417}, {\"ngram\": \"their governments\", \"from\": 422, \"to\": 439}]}, {\"sentence\": \"\\\"I want to help the programmes in the different countries to go to their governments and convince them that investing in our programmes is worthwhile,\\\" Ferguson said during an interval in the Special Olympics Caribbean Initiative meeting among programme leaders at the Lions Community Centre on Friday.\", \"from\": 442, \"to\": 744, \"entities\": [{\"begin\": 594, \"end\": 602, \"title\": \"http://dbpedia.org/resource/Ferguson_unrest\", \"score\": 0.9995131648166559, \"rank\": 0.0004198685348604522, \"text\": \"Ferguson\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ferguson_unrest\", \"dbpedia\": \"http://dbpedia.org/resource/Ferguson_unrest\"}], \"noun_phrases\": [{\"ngram\": \"the programmes\", \"from\": 458, \"to\": 472}, {\"ngram\": \"the different countries\", \"from\": 476, \"to\": 499}, {\"ngram\": \"their governments\", \"from\": 509, \"to\": 526}, {\"ngram\": \"our programmes\", \"from\": 563, \"to\": 577}, {\"ngram\": \"an interval\", \"from\": 615, \"to\": 626}, {\"ngram\": \"the Special Olympics Caribbean Initiative meeting\", \"from\": 630, \"to\": 679}, {\"ngram\": \"programme leaders\", \"from\": 686, \"to\": 703}, {\"ngram\": \"the Lions Community Centre\", \"from\": 707, \"to\": 733}, {\"ngram\": \"Friday\", \"from\": 737, \"to\": 743}]}, {\"sentence\": \"\\\"For government to provide that investment, it helps them, it helps the Special Olympics athletes, and it helps our programmes,\\\" he said, alluding to the importance of Caribbean governments providing welfare and other support to Special Olympics programmes.\", \"from\": 746, \"to\": 1003, \"entities\": [{\"begin\": 975, \"end\": 991, \"title\": \"http://dbpedia.org/resource/Special_Olympics\", \"score\": 1.0, \"rank\": 1.6098116621068358e-14, \"text\": \"Special Olympics\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Special_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Special_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"government\", \"from\": 751, \"to\": 761}, {\"ngram\": \"that investment\", \"from\": 773, \"to\": 788}, {\"ngram\": \"the Special Olympics athletes\", \"from\": 814, \"to\": 843}, {\"ngram\": \"our programmes\", \"from\": 858, \"to\": 872}, {\"ngram\": \"the importance\", \"from\": 896, \"to\": 910}, {\"ngram\": \"Caribbean governments\", \"from\": 914, \"to\": 935}, {\"ngram\": \"welfare\", \"from\": 946, \"to\": 953}, {\"ngram\": \"other support\", \"from\": 958, \"to\": 971}]}, {\"sentence\": \"Officially announced during the World Games in Berlin, Germany, in June 2023, the coalition - funded by European-based Stavros Niarchos Foundation - is a pioneering multilateral effort aimed at increasing inclusive practices to support people with intellectual disabilities.\", \"from\": 1005, \"to\": 1279, \"entities\": [{\"begin\": 1052, \"end\": 1067, \"title\": \"http://dbpedia.org/resource/Berlin\", \"score\": 1.0, \"rank\": 2.9440011250364796e-14, \"text\": \"Berlin, Germany\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Berlin\", \"dbpedia\": \"http://dbpedia.org/resource/Berlin\"}, {\"begin\": 1052, \"end\": 1067, \"title\": \"http://dbpedia.org/resource/Berlin\", \"score\": 1.0, \"rank\": 2.9440011250364796e-14, \"text\": \"Berlin, Germany\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Berlin\", \"dbpedia\": \"http://dbpedia.org/resource/Berlin\"}, {\"begin\": 1124, \"end\": 1131, \"title\": \"http://dbpedia.org/resource/Harry_Enfield_&_Chums\", \"score\": 0.5836993597743453, \"rank\": 0.5918032786884464, \"text\": \"Stavros\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/Harry_Enfield_&_Chums\", \"dbpedia\": \"http://dbpedia.org/resource/Harry_Enfield_&_Chums\"}], \"noun_phrases\": [{\"ngram\": \"the World Games\", \"from\": 1033, \"to\": 1048}, {\"ngram\": \"June\", \"from\": 1072, \"to\": 1076}, {\"ngram\": \"the coalition\", \"from\": 1083, \"to\": 1096}, {\"ngram\": \"a pioneering multilateral effort\", \"from\": 1157, \"to\": 1189}, {\"ngram\": \"inclusive practices\", \"from\": 1210, \"to\": 1229}, {\"ngram\": \"people\", \"from\": 1241, \"to\": 1247}, {\"ngram\": \"intellectual disabilities\", \"from\": 1253, \"to\": 1278}]}, {\"sentence\": \"The global coalition is to bring together governments, industry, philanthropy and the development community.\", \"from\": 1281, \"to\": 1389, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The global coalition\", \"from\": 1281, \"to\": 1301}, {\"ngram\": \"governments\", \"from\": 1323, \"to\": 1334}, {\"ngram\": \"industry\", \"from\": 1336, \"to\": 1344}, {\"ngram\": \"philanthropy\", \"from\": 1346, \"to\": 1358}, {\"ngram\": \"the development community\", \"from\": 1363, \"to\": 1388}]}, {\"sentence\": \"On an international scale, last year's projection was for the expansion of inclusive sports and education opportunities for over two million people in more than 180 countries.\", \"from\": 1391, \"to\": 1566, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"an international scale\", \"from\": 1394, \"to\": 1416}, {\"ngram\": \"last year's projection\", \"from\": 1418, \"to\": 1440}, {\"ngram\": \"the expansion\", \"from\": 1449, \"to\": 1462}, {\"ngram\": \"inclusive sports and education opportunities\", \"from\": 1466, \"to\": 1510}, {\"ngram\": \"over two million people\", \"from\": 1515, \"to\": 1538}, {\"ngram\": \"more than 180 countries\", \"from\": 1542, \"to\": 1565}]}, {\"sentence\": \"The Washington, DC-based Ferguson, who is chief of staff to SOI Chairman Timothy Shriver, emphasised the need for Caribbean programmes to be front and centre of that inclusive thrust.\", \"from\": 1568, \"to\": 1751, \"entities\": [{\"begin\": 1572, \"end\": 1582, \"title\": \"http://dbpedia.org/resource/George_Washington\", \"score\": 0.7047769067721584, \"rank\": 0.41886528638755555, \"text\": \"Washington\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/George_Washington\", \"dbpedia\": \"http://dbpedia.org/resource/George_Washington\"}, {\"begin\": 1593, \"end\": 1601, \"title\": \"http://dbpedia.org/resource/Ferguson_unrest\", \"score\": 0.9995131648166559, \"rank\": 0.0004198685348604522, \"text\": \"Ferguson\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Ferguson_unrest\", \"dbpedia\": \"http://dbpedia.org/resource/Ferguson_unrest\"}, {\"begin\": 1628, \"end\": 1631, \"title\": \"http://dbpedia.org/resource/Silicon_on_insulator\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"SOI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Silicon_on_insulator\", \"dbpedia\": \"http://dbpedia.org/resource/Silicon_on_insulator\"}, {\"begin\": 1641, \"end\": 1656, \"title\": \"http://dbpedia.org/resource/Timothy_Shriver\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Timothy Shriver\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Timothy_Shriver\", \"dbpedia\": \"http://dbpedia.org/resource/Timothy_Shriver\"}], \"noun_phrases\": [{\"ngram\": \"chief\", \"from\": 1610, \"to\": 1615}, {\"ngram\": \"staff\", \"from\": 1619, \"to\": 1624}, {\"ngram\": \"the need\", \"from\": 1669, \"to\": 1677}, {\"ngram\": \"Caribbean programmes\", \"from\": 1682, \"to\": 1702}, {\"ngram\": \"that inclusive thrust\", \"from\": 1729, \"to\": 1750}]}, {\"sentence\": \"\\\"We are lucky in the United States and a number of other countries to have strong relationships with our government where they put real money in the programme.\", \"from\": 1753, \"to\": 1912, \"entities\": [{\"begin\": 1774, \"end\": 1787, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9918085138616395, \"rank\": 0.00825914071309571, \"text\": \"United States\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"a number\", \"from\": 1792, \"to\": 1800}, {\"ngram\": \"other countries\", \"from\": 1804, \"to\": 1819}, {\"ngram\": \"strong relationships\", \"from\": 1828, \"to\": 1848}, {\"ngram\": \"our government\", \"from\": 1854, \"to\": 1868}, {\"ngram\": \"real money\", \"from\": 1884, \"to\": 1894}, {\"ngram\": \"the programme\", \"from\": 1898, \"to\": 1911}]}, {\"sentence\": \"There is some investment here in the Caribbean but there is a lot of room to grow when you think of the number of programmes that are solely run by volunteers,\\\" he said.\", \"from\": 1913, \"to\": 2082, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"some investment\", \"from\": 1922, \"to\": 1937}, {\"ngram\": \"the Caribbean\", \"from\": 1946, \"to\": 1959}, {\"ngram\": \"a lot\", \"from\": 1973, \"to\": 1978}, {\"ngram\": \"room\", \"from\": 1982, \"to\": 1986}, {\"ngram\": \"the number\", \"from\": 2013, \"to\": 2023}, {\"ngram\": \"programmes\", \"from\": 2027, \"to\": 2037}, {\"ngram\": \"volunteers\", \"from\": 2061, \"to\": 2071}]}, {\"sentence\": \"He reasoned that understanding government relations strategies opens the door to a knock-on effect since State investment is likely to attract corporate support.\", \"from\": 2084, \"to\": 2245, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"government relations strategies\", \"from\": 2115, \"to\": 2146}, {\"ngram\": \"the door\", \"from\": 2153, \"to\": 2161}, {\"ngram\": \"a knock-on effect\", \"from\": 2165, \"to\": 2182}, {\"ngram\": \"State investment\", \"from\": 2189, \"to\": 2205}, {\"ngram\": \"corporate support\", \"from\": 2227, \"to\": 2244}]}, {\"sentence\": \"\\\"I have also found in other countries that when a programme has a government that puts money into what they do the corporates [private companies] will then [be interested]\\u2026 there is a legitimacy given to the process when governments invest in the programming.\", \"from\": 2247, \"to\": 2506, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"other countries\", \"from\": 2269, \"to\": 2284}, {\"ngram\": \"a programme\", \"from\": 2295, \"to\": 2306}, {\"ngram\": \"a government\", \"from\": 2311, \"to\": 2323}, {\"ngram\": \"money\", \"from\": 2334, \"to\": 2339}, {\"ngram\": \"the corporates\", \"from\": 2358, \"to\": 2372}, {\"ngram\": \"private companies\", \"from\": 2374, \"to\": 2391}, {\"ngram\": \"a legitimacy\", \"from\": 2429, \"to\": 2441}, {\"ngram\": \"the process\", \"from\": 2451, \"to\": 2462}, {\"ngram\": \"governments\", \"from\": 2468, \"to\": 2479}, {\"ngram\": \"the programming\", \"from\": 2490, \"to\": 2505}]}, {\"sentence\": \"\\\"If we get more governments in the Caribbean to invest in the programmes, you will see the corporates come along.\", \"from\": 2508, \"to\": 2621, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"more governments\", \"from\": 2519, \"to\": 2535}, {\"ngram\": \"the Caribbean\", \"from\": 2539, \"to\": 2552}, {\"ngram\": \"the programmes\", \"from\": 2566, \"to\": 2580}, {\"ngram\": \"the corporates\", \"from\": 2595, \"to\": 2609}]}, {\"sentence\": \"They'd think 'our government views it as a good thing, so we should too'.\", \"from\": 2622, \"to\": 2695, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"our government\", \"from\": 2636, \"to\": 2650}, {\"ngram\": \"a good thing\", \"from\": 2663, \"to\": 2675}]}, {\"sentence\": \"If that happens we could really build some impressive programmes here in the Caribbean,\\\" said the Special Olympics global government relations boss.\", \"from\": 2696, \"to\": 2844, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"some impressive programmes\", \"from\": 2734, \"to\": 2760}, {\"ngram\": \"the Caribbean\", \"from\": 2769, \"to\": 2782}, {\"ngram\": \"the Special Olympics global government relations boss\", \"from\": 2790, \"to\": 2843}]}, {\"sentence\": \"- Sanjay Myers HOUSE RULES\", \"from\": 2846, \"to\": 2873, \"entities\": [{\"begin\": 2848, \"end\": 2854, \"title\": \"http://dbpedia.org/resource/Sanjay_Gandhi\", \"score\": 0.9999386214851184, \"rank\": 6.011660530522223e-05, \"text\": \"Sanjay\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Sanjay_Gandhi\", \"dbpedia\": \"http://dbpedia.org/resource/Sanjay_Gandhi\"}], \"noun_phrases\": []}]}"