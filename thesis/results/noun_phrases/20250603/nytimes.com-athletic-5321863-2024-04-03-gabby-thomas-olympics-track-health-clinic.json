, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a break\", \"from\": 4388, \"to\": 4395}, {\"ngram\": \"her way\", \"from\": 4417, \"to\": 4424}]}, {\"sentence\": \"That she did.\", \"from\": 4473, \"to\": 4486, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"And how.\", \"from\": 4487, \"to\": 4495, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"On the youth soccer fields of Georgia and Massachusetts, where she grew up, Thomas got the first hint that she was faster than just about everyone else.\", \"from\": 4497, \"to\": 4649, \"entities\": [{\"begin\": 4527, \"end\": 4534, \"title\": \"http://dbpedia.org/resource/University_of_Georgia\", \"score\": 0.9932734433634993, \"rank\": 0.006772108250489884, \"text\": \"Georgia\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/University_of_Georgia\", \"dbpedia\": \"http://dbpedia.org/resource/University_of_Georgia\"}, {\"begin\": 4539, \"end\": 4552, \"title\": \"http://dbpedia.org/resource/Massachusetts\", \"score\": 0.9999999999854481, \"rank\": 1.1834087139267811e-11, \"text\": \"Massachusetts\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Massachusetts\", \"dbpedia\": \"http://dbpedia.org/resource/Massachusetts\"}, {\"begin\": 4573, \"end\": 4579, \"title\": \"http://dbpedia.org/resource/Thomas_Wayne\", \"score\": 0.986954667067403, \"rank\": 0.013216944395718558, \"text\": \"Thomas\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Thomas_Wayne\", \"dbpedia\": \"http://dbpedia.org/resource/Thomas_Wayne\"}], \"noun_phrases\": [{\"ngram\": \"the youth soccer fields\", \"from\": 4500, \"to\": 4523}, {\"ngram\": \"the first hint\", \"from\": 4584, \"to\": 4598}, {\"ngram\": \"everyone\", \"from\": 4635, \"to\": 4643}]}, {\"sentence\": \"Her teams played classic kick-and-run soccer - boot the ball over the defense and let your center forward blaze past everyone to catch up to it and score.\", \"from\": 4650, \"to\": 4804, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Her teams\", \"from\": 4650, \"to\": 4659}, {\"ngram\": \"the ball\", \"from\": 4702, \"to\": 4710}, {\"ngram\": \"the defense\", \"from\": 4716, \"to\": 4727}, {\"ngram\": \"your center\", \"from\": 4736, \"to\": 4747}, {\"ngram\": \"everyone\", \"from\": 4767, \"to\": 4775}]}, {\"sentence\": \"Thomas, whose father, Desmond, played football at Duke, scored a lot of goals.\", \"from\": 4805, \"to\": 4883, \"entities\": [{\"begin\": 4805, \"end\": 4811, \"title\": \"http://dbpedia.org/resource/Thomas_Wayne\", \"score\": 0.986954667067403, \"rank\": 0.013216944395718558, \"text\": \"Thomas\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Thomas_Wayne\", \"dbpedia\": \"http://dbpedia.org/resource/Thomas_Wayne\"}, {\"begin\": 4827, \"end\": 4834, \"title\": \"http://dbpedia.org/resource/Desmond_Hume\", \"score\": 1.0, \"rank\": 2.1688692910638492e-20, \"text\": \"Desmond\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Desmond_Hume\", \"dbpedia\": \"http://dbpedia.org/resource/Desmond_Hume\"}, {\"begin\": 4855, \"end\": 4859, \"title\": \"http://dbpedia.org/resource/Duke_University\", \"score\": 1.0, \"rank\": 1.0041230459844242e-13, \"text\": \"Duke\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/Duke_University\", \"dbpedia\": \"http://dbpedia.org/resource/Duke_University\"}], \"noun_phrases\": [{\"ngram\": \"whose father\", \"from\": 4813, \"to\": 4825}, {\"ngram\": \"football\", \"from\": 4843, \"to\": 4851}, {\"ngram\": \"a lot\", \"from\": 4868, \"to\": 4873}, {\"ngram\": \"goals\", \"from\": 4877, \"to\": 4882}]}, {\"sentence\": \"Advertisement In seventh grade, as a day student at the Williston Northampton School, a private prep school in central Massachusetts, she started to compete in track and field, while also playing on the soccer and basketball teams.\", \"from\": 4885, \"to\": 5117, \"entities\": [{\"begin\": 4942, \"end\": 4970, \"title\": \"http://dbpedia.org/resource/Williston_Northampton_School\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Williston Northampton School\", \"types\": [\"Q43229\", \"Q3914\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/Williston_Northampton_School\", \"dbpedia\": \"http://dbpedia.org/resource/Williston_Northampton_School\"}, {\"begin\": 5005, \"end\": 5018, \"title\": \"http://dbpedia.org/resource/Massachusetts\", \"score\": 0.9999999999854481, \"rank\": 1.1834087139267811e-11, \"text\": \"Massachusetts\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Massachusetts\", \"dbpedia\": \"http://dbpedia.org/resource/Massachusetts\"}], \"noun_phrases\": [{\"ngram\": \"seventh grade\", \"from\": 4902, \"to\": 4915}, {\"ngram\": \"a day student\", \"from\": 4920, \"to\": 4933}, {\"ngram\": \"a private prep school\", \"from\": 4971, \"to\": 4992}, {\"ngram\": \"track\", \"from\": 5045, \"to\": 5050}, {\"ngram\": \"field\", \"from\": 5055, \"to\": 5060}, {\"ngram\": \"the soccer and basketball teams\", \"from\": 5084, \"to\": 5115}]}, {\"sentence\": \"She specialized in the long jump and the triple jump, which require speed to gain momentum for big leaps.\", \"from\": 5118, \"to\": 5223, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the long jump\", \"from\": 5137, \"to\": 5150}, {\"ngram\": \"the triple jump\", \"from\": 5155, \"to\": 5170}, {\"ngram\": \"speed\", \"from\": 5186, \"to\": 5191}, {\"ngram\": \"momentum\", \"from\": 5200, \"to\": 5208}, {\"ngram\": \"big leaps\", \"from\": 5213, \"to\": 5222}]}, {\"sentence\": \"She did not think of herself as a top sprinter, even as she won so many high school races and became a prep champion in New England.\", \"from\": 5224, \"to\": 5356, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a top sprinter\", \"from\": 5256, \"to\": 5270}, {\"ngram\": \"so many high school races\", \"from\": 5288, \"to\": 5313}, {\"ngram\": \"a prep champion\", \"from\": 5325, \"to\": 5340}, {\"ngram\": \"New England\", \"from\": 5344, \"to\": 5355}]}, {\"sentence\": \"Once at Harvard, though, she quickly started rewriting the school and Ivy League record books and qualified for the 2016 U.S. Olympic Track and Field Trials as a freshman.\", \"from\": 5358, \"to\": 5529, \"entities\": [{\"begin\": 5366, \"end\": 5373, \"title\": \"http://dbpedia.org/resource/Harvard_University\", \"score\": 0.9999998957828266, \"rank\": 1.0381726094661432e-07, \"text\": \"Harvard\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/Harvard_University\", \"dbpedia\": \"http://dbpedia.org/resource/Harvard_University\"}], \"noun_phrases\": [{\"ngram\": \"the school and Ivy League record books\", \"from\": 5413, \"to\": 5451}, {\"ngram\": \"the 2016 U.S. Olympic Track and Field Trials\", \"from\": 5470, \"to\": 5514}, {\"ngram\": \"a freshman\", \"from\": 5518, \"to\": 5528}]}, {\"sentence\": \"Coaches at track factories like Oregon came up to Tolbert and said if they'd known she was that good, they would have paid a little more attention to her.\", \"from\": 5530, \"to\": 5684, \"entities\": [{\"begin\": 5562, \"end\": 5568, \"title\": \"http://dbpedia.org/resource/University_of_Oregon\", \"score\": 1.0, \"rank\": 5.269982529080247e-15, \"text\": \"Oregon\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/University_of_Oregon\", \"dbpedia\": \"http://dbpedia.org/resource/University_of_Oregon\"}], \"noun_phrases\": [{\"ngram\": \"Coaches\", \"from\": 5530, \"to\": 5537}, {\"ngram\": \"track factories\", \"from\": 5541, \"to\": 5556}, {\"ngram\": \"Tolbert\", \"from\": 5580, \"to\": 5587}, {\"ngram\": \"a little more attention\", \"from\": 5653, \"to\": 5676}]}, {\"sentence\": \"What happened?\", \"from\": 5686, \"to\": 5700, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Tolbert freely admits that Harvard is not exactly known for churning out world-class sprinters, but college had given Thomas the chance to train with fast women every day.\", \"from\": 5701, \"to\": 5872, \"entities\": [{\"begin\": 5728, \"end\": 5735, \"title\": \"http://dbpedia.org/resource/Harvard_University\", \"score\": 0.9999998957828266, \"rank\": 1.0381726094661432e-07, \"text\": \"Harvard\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/Harvard_University\", \"dbpedia\": \"http://dbpedia.org/resource/Harvard_University\"}, {\"begin\": 5819, \"end\": 5825, \"title\": \"http://dbpedia.org/resource/Thomas_Wayne\", \"score\": 0.986954667067403, \"rank\": 0.013216944395718558, \"text\": \"Thomas\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Thomas_Wayne\", \"dbpedia\": \"http://dbpedia.org/resource/Thomas_Wayne\"}], \"noun_phrases\": [{\"ngram\": \"Tolbert\", \"from\": 5701, \"to\": 5708}, {\"ngram\": \"world-class sprinters\", \"from\": 5774, \"to\": 5795}, {\"ngram\": \"college\", \"from\": 5801, \"to\": 5808}, {\"ngram\": \"the chance\", \"from\": 5826, \"to\": 5836}, {\"ngram\": \"fast women\", \"from\": 5851, \"to\": 5861}]}, {\"sentence\": \"\\\"You drop a talented, competitive person into a national-class group, and that allows her to take off,\\\" he said.\", \"from\": 5874, \"to\": 5986, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a talented, competitive person\", \"from\": 5884, \"to\": 5914}, {\"ngram\": \"a national-class group\", \"from\": 5920, \"to\": 5942}]}, {\"sentence\": \"\\\"The group pushed her to become so good so fast.\\\"\", \"from\": 5987, \"to\": 6036, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The group\", \"from\": 5988, \"to\": 5997}]}, {\"sentence\": \"At the Olympic trials in 2016, she lined up on the same track as her heroes, including Felix, and finished sixth in the 200 meters.\", \"from\": 6038, \"to\": 6169, \"entities\": [{\"begin\": 6125, \"end\": 6130, \"title\": \"http://dbpedia.org/resource/Felix_Mendelssohn\", \"score\": 1.0, \"rank\": 3.590706786655853e-14, \"text\": \"Felix\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Felix_Mendelssohn\", \"dbpedia\": \"http://dbpedia.org/resource/Felix_Mendelssohn\"}], \"noun_phrases\": [{\"ngram\": \"the Olympic trials\", \"from\": 6041, \"to\": 6059}, {\"ngram\": \"the same track\", \"from\": 6085, \"to\": 6099}, {\"ngram\": \"her heroes\", \"from\": 6103, \"to\": 6113}, {\"ngram\": \"the 200 meters\", \"from\": 6154, \"to\": 6168}]}, {\"sentence\": \"She remembers Torie Bowie, who won the race, finishing 0.5 seconds ahead of her, making up the staggered-start lead Thomas had on her within the first few strides.\", \"from\": 6170, \"to\": 6333, \"entities\": [{\"begin\": 6190, \"end\": 6195, \"title\": \"http://dbpedia.org/resource/David_Bowie\", \"score\": 1.0, \"rank\": 2.358570601168972e-16, \"text\": \"Bowie\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/David_Bowie\", \"dbpedia\": \"http://dbpedia.org/resource/David_Bowie\"}, {\"begin\": 6286, \"end\": 6292, \"title\": \"http://dbpedia.org/resource/Thomas_Wayne\", \"score\": 0.986954667067403, \"rank\": 0.013216944395718558, \"text\": \"Thomas\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Thomas_Wayne\", \"dbpedia\": \"http://dbpedia.org/resource/Thomas_Wayne\"}], \"noun_phrases\": [{\"ngram\": \"the race\", \"from\": 6205, \"to\": 6213}, {\"ngram\": \"the staggered-start lead\", \"from\": 6261, \"to\": 6285}, {\"ngram\": \"the first few strides\", \"from\": 6311, \"to\": 6332}]}, {\"sentence\": \"\\\"I got smoked,\\\" Thomas said.\", \"from\": 6335, \"to\": 6363, \"entities\": [{\"begin\": 6351, \"end\": 6357, \"title\": \"http://dbpedia.org/resource/Thomas_Wayne\", \"score\": 0.986954667067403, \"rank\": 0.013216944395718558, \"text\": \"Thomas\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Thomas_Wayne\", \"dbpedia\": \"http://dbpedia.org/resource/Thomas_Wayne\"}], \"noun_phrases\": []}, {\"sentence\": \"Then came the sophomore stagnation.\", \"from\": 6365, \"to\": 6400, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the sophomore stagnation\", \"from\": 6375, \"to\": 6399}]}, {\"sentence\": \"She'd been third at nationals in the 200 meters as a freshman and finished third once more as a sophomore.\", \"from\": 6401, \"to\": 6507, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"nationals\", \"from\": 6421, \"to\": 6430}, {\"ngram\": \"the 200 meters\", \"from\": 6434, \"to\": 6448}, {\"ngram\": \"a freshman\", \"from\": 6452, \"to\": 6462}, {\"ngram\": \"a sophomore\", \"from\": 6495, \"to\": 6506}]}, {\"sentence\": \"The academic challenges were piling up, she was overwhelmed, and she wanted to just be a college student.\", \"from\": 6508, \"to\": 6613, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The academic challenges\", \"from\": 6508, \"to\": 6531}, {\"ngram\": \"a college student\", \"from\": 6595, \"to\": 6612}]}, {\"sentence\": \"She had run for two years, and been to the Olympic trials.\", \"from\": 6614, \"to\": 6672, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"two years\", \"from\": 6630, \"to\": 6639}, {\"ngram\": \"the Olympic trials\", \"from\": 6653, \"to\": 6671}]}, {\"sentence\": \"She was done.\", \"from\": 6673, \"to\": 6686, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"Then she went to Senegal and spent six weeks studying health care and culture and traveling throughout the West African nation, meeting people struggling to gather the bare necessities for survival.\", \"from\": 6688, \"to\": 6886, \"entities\": [{\"begin\": 6705, \"end\": 6712, \"title\": \"http://dbpedia.org/resource/Senegal\", \"score\": 0.9995853107576248, \"rank\": 0.0004148612811262772, \"text\": \"Senegal\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Senegal\", \"dbpedia\": \"http://dbpedia.org/resource/Senegal\"}], \"noun_phrases\": [{\"ngram\": \"six weeks\", \"from\": 6723, \"to\": 6732}, {\"ngram\": \"health care\", \"from\": 6742, \"to\": 6753}, {\"ngram\": \"culture\", \"from\": 6758, \"to\": 6765}, {\"ngram\": \"the West African nation\", \"from\": 6791, \"to\": 6814}, {\"ngram\": \"people\", \"from\": 6824, \"to\": 6830}, {\"ngram\": \"the bare necessities\", \"from\": 6852, \"to\": 6872}, {\"ngram\": \"survival\", \"from\": 6877, \"to\": 6885}]}, {\"sentence\": \"She looked at the ocean from the \\\"Doorway of No Return\\\" on Gor\\u00e9e Island, which is believed to have been a key stop for thousands of enslaved people on their journey to the Americas.\", \"from\": 6887, \"to\": 7068, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the ocean\", \"from\": 6901, \"to\": 6910}, {\"ngram\": \"the \\\"Doorway\", \"from\": 6916, \"to\": 6928}, {\"ngram\": \"No Return\", \"from\": 6932, \"to\": 6941}, {\"ngram\": \"Gor\\u00e9e Island\", \"from\": 6946, \"to\": 6958}, {\"ngram\": \"a key stop\", \"from\": 6991, \"to\": 7001}, {\"ngram\": \"thousands\", \"from\": 7006, \"to\": 7015}, {\"ngram\": \"enslaved people\", \"from\": 7019, \"to\": 7034}, {\"ngram\": \"their journey\", \"from\": 7038, \"to\": 7051}, {\"ngram\": \"the Americas\", \"from\": 7055, \"to\": 7067}]}, {\"sentence\": \"She decided she could manage her life, busy as it was, and whatever happened with her grades or her results on the track did not matter all that much.\", \"from\": 7069, \"to\": 7219, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her life\", \"from\": 7098, \"to\": 7106}, {\"ngram\": \"whatever\", \"from\": 7128, \"to\": 7136}, {\"ngram\": \"her grades\", \"from\": 7151, \"to\": 7161}, {\"ngram\": \"her results\", \"from\": 7165, \"to\": 7176}, {\"ngram\": \"the track\", \"from\": 7180, \"to\": 7189}]}, {\"sentence\": \"Advertisement That's when she gotreallyfast.\", \"from\": 7221, \"to\": 7266, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"In March of her junior year, she became the first female sprinter from the Ivy League to win an indoor national title, setting a new collegiate record in the 200 meters.\", \"from\": 7267, \"to\": 7436, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"March\", \"from\": 7270, \"to\": 7275}, {\"ngram\": \"her junior year\", \"from\": 7279, \"to\": 7294}, {\"ngram\": \"the first female sprinter\", \"from\": 7307, \"to\": 7332}, {\"ngram\": \"the Ivy League\", \"from\": 7338, \"to\": 7352}, {\"ngram\": \"an indoor national title\", \"from\": 7360, \"to\": 7384}, {\"ngram\": \"a new collegiate record\", \"from\": 7394, \"to\": 7417}, {\"ngram\": \"the 200 meters\", \"from\": 7421, \"to\": 7435}]}, {\"sentence\": \"And that's when Tolbert sat her down and explained to her that being a professional runner was an actual job, that she could get a shoe sponsor, win prize money, and spend the first part of her adult life traveling the world and racing.\", \"from\": 7437, \"to\": 7673, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Tolbert\", \"from\": 7453, \"to\": 7460}, {\"ngram\": \"a professional runner\", \"from\": 7506, \"to\": 7527}, {\"ngram\": \"an actual job\", \"from\": 7532, \"to\": 7545}, {\"ngram\": \"a shoe sponsor\", \"from\": 7566, \"to\": 7580}, {\"ngram\": \"prize money\", \"from\": 7586, \"to\": 7597}, {\"ngram\": \"the first part\", \"from\": 7609, \"to\": 7623}, {\"ngram\": \"her adult life\", \"from\": 7627, \"to\": 7641}, {\"ngram\": \"the world\", \"from\": 7652, \"to\": 7661}, {\"ngram\": \"racing\", \"from\": 7666, \"to\": 7672}]}, {\"sentence\": \"Interesting, Thomas thought.\", \"from\": 7675, \"to\": 7703, \"entities\": [{\"begin\": 7688, \"end\": 7694, \"title\": \"http://dbpedia.org/resource/Thomas_Wayne\", \"score\": 0.986954667067403, \"rank\": 0.013216944395718558, \"text\": \"Thomas\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Thomas_Wayn