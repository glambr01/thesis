942633244281775, \"text\": \"Joseph\", \"types\": [\"Q729\", \"Q5\", \"Q43115\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Saint_Joseph\", \"dbpedia\": \"http://dbpedia.org/resource/Saint_Joseph\"}], \"noun_phrases\": [{\"ngram\": \"Picture\", \"from\": 156, \"to\": 163}, {\"ngram\": \"an explosive battle\", \"from\": 237, \"to\": 256}, {\"ngram\": \"Friday\", \"from\": 260, \"to\": 266}, {\"ngram\": \"both athletes\", \"from\": 273, \"to\": 286}, {\"ngram\": \"this year's Olympic Games\", \"from\": 302, \"to\": 327}, {\"ngram\": \"day\", \"from\": 331, \"to\": 334}, {\"ngram\": \"theSA Athletics Championshipsin Pietermaritzburg\", \"from\": 342, \"to\": 390}]}, {\"sentence\": \"Geldenhuys, a former world champion in the youth and junior age groups, won gold in the women's 400m hurdles final in 54.72, with Joseph, who won the African Games in Ghana last month, pushing her all the way to the line.\", \"from\": 394, \"to\": 615, \"entities\": [{\"begin\": 524, \"end\": 530, \"title\": \"http://dbpedia.org/resource/Saint_Joseph\", \"score\": 0.913816083703409, \"rank\": 0.0942633244281775, \"text\": \"Joseph\", \"types\": [\"Q729\", \"Q5\", \"Q43115\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Saint_Joseph\", \"dbpedia\": \"http://dbpedia.org/resource/Saint_Joseph\"}, {\"begin\": 561, \"end\": 566, \"title\": \"http://dbpedia.org/resource/Ghana_national_football_team\", \"score\": 0.701854726128445, \"rank\": 0.3610542785212051, \"text\": \"Ghana\", \"types\": [\"Q476028\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Ghana_national_football_team\", \"dbpedia\": \"http://dbpedia.org/resource/Ghana_national_football_team\"}], \"noun_phrases\": [{\"ngram\": \"Geldenhuys\", \"from\": 394, \"to\": 404}, {\"ngram\": \"a former world champion\", \"from\": 406, \"to\": 429}, {\"ngram\": \"the youth\", \"from\": 433, \"to\": 442}, {\"ngram\": \"junior age groups\", \"from\": 447, \"to\": 464}, {\"ngram\"