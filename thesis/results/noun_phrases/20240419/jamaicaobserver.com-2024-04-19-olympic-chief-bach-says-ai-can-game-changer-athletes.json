"{\"uid\": \"jamaicaobserver.com-2024-04-19-olympic-chief-bach-says-ai-can-game-changer-athletes\", \"noun_phrases\": [{\"sentence\": \"LONDON, United Kingdom (AFP) - IOC president Thomas Bach said artificial intelligence can help identify talented athletes \\\"in every corner of the world\\\" as he unveiled the Olympic AI Agenda in London on Friday.\", \"from\": 0, \"to\": 210, \"entities\": [{\"begin\": 8, \"end\": 22, \"title\": \"http://dbpedia.org/resource/United_Kingdom\", \"score\": 0.999967954584291, \"rank\": 2.0210385187492018e-05, \"text\": \"United Kingdom\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_Kingdom\", \"dbpedia\": \"http://dbpedia.org/resource/United_Kingdom\"}, {\"begin\": 45, \"end\": 56, \"title\": \"http://dbpedia.org/resource/Thomas_Bach\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Thomas Bach\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Thomas_Bach\", \"dbpedia\": \"http://dbpedia.org/resource/Thomas_Bach\"}, {\"begin\": 193, \"end\": 199, \"title\": \"http://dbpedia.org/resource/London\", \"score\": 0.999999877223225, \"rank\": 7.145819724598834e-08, \"text\": \"London\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/London\", \"dbpedia\": \"http://dbpedia.org/resource/London\"}], \"noun_phrases\": [{\"ngram\": \"LONDON\", \"from\": 0, \"to\": 6}, {\"ngram\": \"(AFP\", \"from\": 23, \"to\": 27}, {\"ngram\": \"artificial intelligence\", \"from\": 62, \"to\": 85}, {\"ngram\": \"talented athletes\", \"from\": 104, \"to\": 121}, {\"ngram\": \"every corner\", \"from\": 126, \"to\": 138}, {\"ngram\": \"the world\", \"from\": 142, \"to\": 151}, {\"ngram\": \"the Olympic AI Agenda\", \"from\": 168, \"to\": 189}, {\"ngram\": \"Friday\", \"from\": 203, \"to\": 209}]}, {\"sentence\": \"Bach, speaking at Olympic Park, which hosted the 2012 Games, said the Olympic movement needs to lead change as the global AI revolution gathers pace.\", \"from\": 212, \"to\": 361, \"entities\": [{\"begin\": 212, \"end\": 216, \"title\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"score\": 0.9999999277254146, \"rank\": 7.227456772365406e-08, \"text\": \"Bach\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"dbpedia\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\"}], \"noun_phrases\": [{\"ngram\": \"Olympic Park\", \"from\": 230, \"to\": 242}, {\"ngram\": \"the 2012 Games\", \"from\": 257, \"to\": 271}, {\"ngram\": \"the Olympic movement\", \"from\": 278, \"to\": 298}, {\"ngram\": \"change\", \"from\": 313, \"to\": 319}, {\"ngram\": \"the global AI revolution\", \"from\": 323, \"to\": 347}, {\"ngram\": \"pace\", \"from\": 356, \"to\": 360}]}, {\"sentence\": \"\\\"Today we are making another step to ensure the uniqueness of the Olympic Games and the relevance of sport, and to do this, we have to be leaders of change, and not the object of change,\\\" said the International Olympic Committee president.\", \"from\": 363, \"to\": 602, \"entities\": [{\"begin\": 560, \"end\": 591, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"another step\", \"from\": 384, \"to\": 396}, {\"ngram\": \"the uniqueness\", \"from\": 407, \"to\": 421}, {\"ngram\": \"the Olympic Games\", \"from\": 425, \"to\": 442}, {\"ngram\": \"the relevance\", \"from\": 447, \"to\": 460}, {\"ngram\": \"sport\", \"from\": 464, \"to\": 469}, {\"ngram\": \"leaders\", \"from\": 501, \"to\": 508}, {\"ngram\": \"change\", \"from\": 512, \"to\": 518}, {\"ngram\": \"change\", \"from\": 542, \"to\": 548}]}, {\"sentence\": \"The former fencing gold medallist said it was vital to have a \\\"holistic\\\" approach to create an \\\"overall strategy for AI and sport\\\".\", \"from\": 604, \"to\": 735, \"entities\": [{\"begin\": 721, \"end\": 723, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 0.9999999989283879, \"rank\": 7.396384153325504e-10, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}], \"noun_phrases\": [{\"ngram\": \"The former fencing gold medallist\", \"from\": 604, \"to\": 637}, {\"ngram\": \"a \\\"holistic\\\" approach\", \"from\": 664, \"to\": 685}, {\"ngram\": \"an \\\"overall strategy\", \"from\": 696, \"to\": 716}, {\"ngram\": \"sport\", \"from\": 728, \"to\": 733}]}, {\"sentence\": \"Bach, speaking less than 100 days before the start of the Paris Olympics, said \\\"unlike other sectors of society, we in sport are not confronted with the existential question of whether AI will replace human beings\\\".\", \"from\": 737, \"to\": 952, \"entities\": [{\"begin\": 737, \"end\": 741, \"title\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"score\": 0.9999999277254146, \"rank\": 7.227456772365406e-08, \"text\": \"Bach\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"dbpedia\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\"}, {\"begin\": 922, \"end\": 924, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 0.9999999989283879, \"rank\": 7.396384153325504e-10, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}], \"noun_phrases\": [{\"ngram\": \"the start\", \"from\": 778, \"to\": 787}, {\"ngram\": \"the Paris Olympics\", \"from\": 791, \"to\": 809}, {\"ngram\": \"other sectors\", \"from\": 824, \"to\": 837}, {\"ngram\": \"society\", \"from\": 841, \"to\": 848}, {\"ngram\": \"sport\", \"from\": 856, \"to\": 861}, {\"ngram\": \"the existential question\", \"from\": 886, \"to\": 910}, {\"ngram\": \"human beings\", \"from\": 938, \"to\": 950}]}, {\"sentence\": \"\\\"In sport, the performances will always have to be delivered by the athletes,\\\" he said.\", \"from\": 954, \"to\": 1041, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"sport\", \"from\": 958, \"to\": 963}, {\"ngram\": \"the performances\", \"from\": 965, \"to\": 981}, {\"ngram\": \"the athletes\", \"from\": 1018, \"to\": 1030}]}, {\"sentence\": \"\\\"The 100 metres will always have to be run by an athlete - a human being.\", \"from\": 1042, \"to\": 1115, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The 100 metres\", \"from\": 1043, \"to\": 1057}, {\"ngram\": \"an athlete\", \"from\": 1088, \"to\": 1098}, {\"ngram\": \"a human being\", \"from\": 1101, \"to\": 1114}]}, {\"sentence\": \"Therefore, we can concentrate on the potential of AI to support the athletes.\\\"\", \"from\": 1116, \"to\": 1194, \"entities\": [{\"begin\": 1166, \"end\": 1168, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 0.9999999989283879, \"rank\": 7.396384153325504e-10, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}], \"noun_phrases\": [{\"ngram\": \"the potential\", \"from\": 1149, \"to\": 1162}, {\"ngram\": \"the athletes\", \"from\": 1180, \"to\": 1192}]}, {\"sentence\": \"\\\"AI can help to identify athletes and talent in every corner of the world.\", \"from\": 1196, \"to\": 1270, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"AI\", \"from\": 1197, \"to\": 1199}, {\"ngram\": \"athletes\", \"from\": 1221, \"to\": 1229}, {\"ngram\": \"talent\", \"from\": 1234, \"to\": 1240}, {\"ngram\": \"every corner\", \"from\": 1244, \"to\": 1256}, {\"ngram\": \"the world\", \"from\": 1260, \"to\": 1269}]}, {\"sentence\": \"AI can provide more athletes with access to personalised training methods, superior sports equipment and more individualised programmes to stay fit and healthy.\\\"\", \"from\": 1271, \"to\": 1432, \"entities\": [{\"begin\": 1271, \"end\": 1273, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 0.9999999989283879, \"rank\": 7.396384153325504e-10, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}], \"noun_phrases\": [{\"ngram\": \"more athletes\", \"from\": 1286, \"to\": 1299}, {\"ngram\": \"access\", \"from\": 1305, \"to\": 1311}, {\"ngram\": \"personalised training methods\", \"from\": 1315, \"to\": 1344}, {\"ngram\": \"superior sports equipment\", \"from\": 1346, \"to\": 1371}, {\"ngram\": \"more individualised programmes\", \"from\": 1376, \"to\": 1406}]}, {\"sentence\": \"Bach said other advantages of AI included fairer judging, better safeguarding and improved spectator experience.\", \"from\": 1434, \"to\": 1546, \"entities\": [{\"begin\": 1434, \"end\": 1438, \"title\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"score\": 0.9999999277254146, \"rank\": 7.227456772365406e-08, \"text\": \"Bach\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"dbpedia\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\"}, {\"begin\": 1464, \"end\": 1466, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 0.9999999989283879, \"rank\": 7.396384153325504e-10, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}], \"noun_phrases\": [{\"ngram\": \"other advantages\", \"from\": 1444, \"to\": 1460}, {\"ngram\": \"fairer judging\", \"from\": 1476, \"to\": 1490}, {\"ngram\": \"better safeguarding\", \"from\": 1492, \"to\": 1511}, {\"ngram\": \"improved spectator experience\", \"from\": 1516, \"to\": 1545}]}, {\"sentence\": \"The Olympic AI Agenda comes from the IOC AI working group -- a high-level panel of global experts including AI pioneers and athletes, set up last year.\", \"from\": 1548, \"to\": 1699, \"entities\": [{\"begin\": 1656, \"end\": 1658, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 0.9999999989283879, \"rank\": 7.396384153325504e-10, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}], \"noun_phrases\": [{\"ngram\": \"The Olympic AI Agenda\", \"from\": 1548, \"to\": 1569}, {\"ngram\": \"the IOC AI working group\", \"from\": 1581, \"to\": 1605}, {\"ngram\": \"a high-level panel\", \"from\": 1609, \"to\": 1627}, {\"ngram\": \"global experts\", \"from\": 1631, \"to\": 1645}, {\"ngram\": \"athletes\", \"from\": 1672, \"to\": 1680}]}, {\"sentence\": \"When asked about the potential negatives of AI, Bach was keen to emphasise the importance of free choice in sport.\", \"from\": 1701, \"to\": 1815, \"entities\": [{\"begin\": 1745, \"end\": 1747, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 0.9999999989283879, \"rank\": 7.396384153325504e-10, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}, {\"begin\": 1749, \"end\": 1753, \"title\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"score\": 0.9999999277254146, \"rank\": 7.227456772365406e-08, \"text\": \"Bach\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\", \"dbpedia\": \"http://dbpedia.org/resource/Johann_Sebastian_Bach\"}], \"noun_phrases\": [{\"ngram\": \"the potential negatives\", \"from\": 1718, \"to\": 1741}, {\"ngram\": \"the importance\", \"from\": 1776, \"to\": 1790}, {\"ngram\": \"free choice\", \"from\": 1794, \"to\": 1805}, {\"ngram\": \"sport\", \"from\": 1809, \"to\": 1814}]}, {\"sentence\": \"\\\"He and she, or the parents, must still have the free choice,\\\" said the German.\", \"from\": 1817, \"to\": 1896, \"entities\": [{\"begin\": 1889, \"end\": 1895, \"title\": \"http://dbpedia.org/resource/German_language\", \"score\": 0.9819962240883504, \"rank\": 0.017685137692038114, \"text\": \"German\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/German_language\", \"dbpedia\": \"http://dbpedia.org/resource/German_language\"}], \"noun_phrases\": [{\"ngram\": \"the parents\", \"from\": 1833, \"to\": 1844}, {\"ngram\": \"the free choice\", \"from\": 1862, \"to\": 1877}]}, {\"sentence\": \"\\\"So a guy who is then maybe identified as a great athlete in wrestling must still have the chance to play tennis and cannot be sorted out from these sports.\\\"\", \"from\": 1897, \"to\": 2054, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a guy\", \"from\": 1901, \"to\": 1906}, {\"ngram\": \"a great athlete\", \"from\": 1939, \"to\": 1954}, {\"ngram\": \"wrestling\", \"from\": 1958, \"to\": 1967}, {\"ngram\": \"the chance\", \"from\": 1984, \"to\": 1994}, {\"ngram\": \"tennis\", \"from\": 2003, \"to\": 2009}, {\"ngram\": \"these sports\", \"from\": 2040, \"to\": 2052}]}, {\"sentence\": \"- Vonn 'jealous' - Former Olympic skiing champion Lindsey Vonn, who also spoke at the London event, told AFP she envied current athletes, who could use AI to enhance their training.\", \"from\": 2056, \"to\": 2238, \"entities\": [{\"begin\": 2107, \"end\": 2119, \"title\": \"http://dbpedia.org/resource/Lindsey_Vonn\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Lindsey Vonn\", \"types\": [\"Q729\", \"Q5\", \"Q4270517\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Lindsey_Vonn\", \"dbpedia\": \"http://dbpedia.or