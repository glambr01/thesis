: 2447, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 0.9999999989283879, \"rank\": 7.396384153325504e-10, \"text\": \"AI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"dbpedia\": \"http://dbpedia.org/resource/Artificial_intelligence\"}, {\"begin\": 2612, \"end\": 2620, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999988959317945, \"rank\": 8.880391002582878e-07, \"text\": \"American\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}], \"noun_phrases\": [{\"ngram\": \"Athletes\", \"from\": 2424, \"to\": 2432}, {\"ngram\": \"training\", \"from\": 2451, \"to\": 2459}, {\"ngram\": \"their knowledge\", \"from\": 2471, \"to\": 2486}, {\"ngram\": \"training\", \"from\": 2492, \"to\": 2500}, {\"ngram\": \"example\", \"from\": 2511, \"to\": 2518}, {\"ngram\": \"the mountain\", \"from\": 2530, \"to\": 2542}, {\"ngram\": \"the mountain\", \"from\": 2561, \"to\": 2573}, {\"ngram\": \"the gym recovery times\", \"from\": 2577, \"to\": 2599}]}, {\"sentence\": \"\\\"The more we understand about your body, about the sport, about performance, the better you can adjust as an athlete.\\\"\", \"from\": 2623, \"to\": 2741, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"your body\", \"from\": 2653, \"to\": 2662}, {\"ngram\": \"the sport\", \"from\": 2670, \"to\": 2679}, {\"ngram\": \"performance\", \"from\": 2687, \"to\": 2698}, {\"ngram\": \"an athlete\", \"from\": 2729, \"to\": 2739}]}, {\"sentence\": \"Vonn, 39, also said AI would be a vital tool for talent identification, particularly in nations without the resources to scout talent.\", \"from\": 2743, \"to\": 2877, \"entities\": [{\"begin\": 2763, \"end\": 2765, \"title\": \"http://dbpedia.org/resource/Artificial_intelligence\", \"score\": 0.9999999989283879, \"rank\": 7.396384153325504e-10, \"text\": \"AI\", \"types\": [], \"wikid\": \"