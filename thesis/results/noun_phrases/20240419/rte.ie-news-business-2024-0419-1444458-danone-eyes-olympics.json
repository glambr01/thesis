"{\"uid\": \"rte.ie-news-business-2024-0419-1444458-danone-eyes-olympics\", \"noun_phrases\": [{\"sentence\": \"Danone, whose CEO first reached out to the International Olympic Committee (IOC) in mid-2022 to get involved, is betting on the Paris Games' focus on health and nutrition to boost summer sales of its yoghurts and plant-based products.\", \"from\": 0, \"to\": 234, \"entities\": [{\"begin\": 43, \"end\": 80, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"International Olympic Committee (IOC)\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}], \"noun_phrases\": [{\"ngram\": \"Danone\", \"from\": 0, \"to\": 6}, {\"ngram\": \"whose CEO\", \"from\": 8, \"to\": 17}, {\"ngram\": \"mid-2022\", \"from\": 84, \"to\": 92}, {\"ngram\": \"the Paris Games' focus\", \"from\": 124, \"to\": 146}, {\"ngram\": \"health\", \"from\": 150, \"to\": 156}, {\"ngram\": \"nutrition\", \"from\": 161, \"to\": 170}, {\"ngram\": \"summer sales\", \"from\": 180, \"to\": 192}, {\"ngram\": \"its yoghurts\", \"from\": 196, \"to\": 208}, {\"ngram\": \"plant-based products\", \"from\": 213, \"to\": 233}]}, {\"sentence\": \"Dozens of major French companies have emerged as first-time partners of the Olympic Games this year, hoping to take advantage of the sales opportunities and marketing exposure the event typically gives sponsors.\", \"from\": 236, \"to\": 447, \"entities\": [{\"begin\": 252, \"end\": 258, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9212058961668973, \"rank\": 0.05005018470148291, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}], \"noun_phrases\": [{\"ngram\": \"Dozens\", \"from\": 236, \"to\": 242}, {\"ngram\": \"first-time partners\", \"from\": 285, \"to\": 304}, {\"ngram\": \"the Olympic Games\", \"from\": 308, \"to\": 325}, {\"ngram\": \"advantage\", \"from\": 352, \"to\": 361}, {\"ngram\": \"the sales opportunities\", \"from\": 365, \"to\": 388}, {\"ngram\": \"marketing exposure\", \"from\": 393, \"to\": 411}, {\"ngram\": \"the event\", \"from\": 412, \"to\": 421}, {\"ngram\": \"sponsors\", \"from\": 438, \"to\": 446}]}, {\"sentence\": \"Through press releases and marketing materials, the IOC has made it clear that sponsors selling food and beverages - including Coca Cola bottled water and Nestle's Garden Gourmet meat alternatives - are part of a drive by the Olympics to promote health and wellness.\", \"from\": 449, \"to\": 715, \"entities\": [{\"begin\": 501, \"end\": 504, \"title\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"score\": 0.9999999996439328, \"rank\": 3.533341727073617e-10, \"text\": \"IOC\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Olympic_Committee\", \"dbpedia\": \"http://dbpedia.org/resource/International_Olympic_Committee\"}, {\"begin\": 576, \"end\": 585, \"title\": \"http://dbpedia.org/resource/Coca-Cola\", \"score\": 0.9978279351405567, \"rank\": 0.0021767929950103973, \"text\": \"Coca Cola\", \"types\": [\"Q2095\"], \"wikid\": \"http://dbpedia.org/resource/Coca-Cola\", \"dbpedia\": \"http://dbpedia.org/resource/Coca-Cola\"}, {\"begin\": 604, \"end\": 610, \"title\": \"http://dbpedia.org/resource/Eberhard_Nestle\", \"score\": 0.9967855868465408, \"rank\": 0.003223669201618822, \"text\": \"Nestle\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Eberhard_Nestle\", \"dbpedia\": \"http://dbpedia.org/resource/Eberhard_Nestle\"}, {\"begin\": 620, \"end\": 627, \"title\": \"http://dbpedia.org/resource/Gourmet\", \"score\": 1.0, \"rank\": 6.471707548140618e-24, \"text\": \"Gourmet\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Gourmet\", \"dbpedia\": \"http://dbpedia.org/resource/Gourmet\"}], \"noun_phrases\": [{\"ngram\": \"press releases\", \"from\": 457, \"to\": 471}, {\"ngram\": \"marketing materials\", \"from\": 476, \"to\": 495}, {\"ngram\": \"sponsors\", \"from\": 528, \"to\": 536}, {\"ngram\": \"food\", \"from\": 545, \"to\": 549}, {\"ngram\": \"beverages\", \"from\": 554, \"to\": 563}, {\"ngram\": \"part\", \"from\": 652, \"to\": 656}, {\"ngram\": \"a drive\", \"from\": 660, \"to\": 667}, {\"ngram\": \"the Olympics\", \"from\": 671, \"to\": 683}, {\"ngram\": \"health\", \"from\": 695, \"to\": 701}, {\"ngram\": \"wellness\", \"from\": 706, \"to\": 714}]}, {\"sentence\": \"The move is a far-cry from the past, when McDonald's was a seven-time sponsor of the event until the London 2012 Games - for which it said it would serve about 50,000 Big Macs, 100,000 portions of fries and 30,000 milkshakes.\", \"from\": 717, \"to\": 942, \"entities\": [{\"begin\": 818, \"end\": 835, \"title\": \"http://dbpedia.org/resource/2012_Summer_Olympics\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"London 2012 Games\", \"types\": [\"Q1656682\"], \"wikid\": \"http://dbpedia.org/resource/2012_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/2012_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"The move\", \"from\": 717, \"to\": 725}, {\"ngram\": \"a far-cry\", \"from\": 729, \"to\": 738}, {\"ngram\": \"the past\", \"from\": 744, \"to\": 752}, {\"ngram\": \"McDonald\", \"from\": 759, \"to\": 767}, {\"ngram\": \"a seven-time sponsor\", \"from\": 774, \"to\": 794}, {\"ngram\": \"the event\", \"from\": 798, \"to\": 807}, {\"ngram\": \"about 50,000 Big Macs\", \"from\": 871, \"to\": 892}, {\"ngram\": \"100,000 portions\", \"from\": 894, \"to\": 910}, {\"ngram\": \"fries\", \"from\": 914, \"to\": 919}, {\"ngram\": \"30,000 milkshakes\", \"from\": 924, \"to\": 941}]}, {\"sentence\": \"When Antoine de Saint-Affrique became Danone CEO in 2022, one of the first things he did was to meet with the head of the Olympic Games.\", \"from\": 944, \"to\": 1080, \"entities\": [{\"begin\": 960, \"end\": 974, \"title\": \"http://dbpedia.org/resource/Saint-Affrique\", \"score\": 0.9999964830056343, \"rank\": 3.5169719213161377e-06, \"text\": \"Saint-Affrique\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Saint-Affrique\", \"dbpedia\": \"http://dbpedia.org/resource/Saint-Affrique\"}], \"noun_phrases\": [{\"ngram\": \"Danone CEO\", \"from\": 982, \"to\": 992}, {\"ngram\": \"the first things\", \"from\": 1009, \"to\": 1025}, {\"ngram\": \"the head\", \"from\": 1050, \"to\": 1058}, {\"ngram\": \"the Olympic Games\", \"from\": 1062, \"to\": 1079}]}, {\"sentence\": \"\\\"Our plant based products, yoghurts, especially those with high protein are extremely relevant for athletes and people who take care of their health,\\\" the company's chief financial officer Juergen Esser told Reuters in an interview.\", \"from\": 1082, \"to\": 1314, \"entities\": [{\"begin\": 1279, \"end\": 1284, \"title\": \"http://dbpedia.org/resource/Hermann_Esser\", \"score\": 0.9999998301177728, \"rank\": 1.625847075589153e-07, \"text\": \"Esser\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Hermann_Esser\", \"dbpedia\": \"http://dbpedia.org/resource/Hermann_Esser\"}, {\"begin\": 1290, \"end\": 1297, \"title\": \"http://dbpedia.org/resource/Reuters\", \"score\": 0.9999513674722785, \"rank\": 4.863481660998654e-05, \"text\": \"Reuters\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Reuters\", \"dbpedia\": \"http://dbpedia.org/resource/Reuters\"}], \"noun_phrases\": [{\"ngram\": \"Our plant based products\", \"from\": 1083, \"to\": 1107}, {\"ngram\": \"yoghurts\", \"from\": 1109, \"to\": 1117}, {\"ngram\": \"especially those\", \"from\": 1119, \"to\": 1135}, {\"ngram\": \"high protein\", \"from\": 1141, \"to\": 1153}, {\"ngram\": \"athletes\", \"from\": 1181, \"to\": 1189}, {\"ngram\": \"people\", \"fro