"from\": 64, \"to\": 73}, {\"ngram\": \"a Whole New Lens\", \"from\": 82, \"to\": 98}, {\"ngram\": \"its efforts\", \"from\": 140, \"to\": 151}, {\"ngram\": \"Olympic fans\", \"from\": 161, \"to\": 173}, {\"ngram\": \"all generations\", \"from\": 177, \"to\": 192}, {\"ngram\": \"its coverage\", \"from\": 269, \"to\": 281}, {\"ngram\": \"the Olympic Games Paris\", \"from\": 285, \"to\": 308}]}, {\"sentence\": \"NBCUniversal, in partnership with Meta, Overtime, Snapchat, TikTok and YouTube, has developed a multi-platform social creator program that will empower 27 engaging creators to tell the stories of the Games through their eyes with unprecedented on-the-ground access in Paris.\", \"from\": 318, \"to\": 592, \"entities\": [{\"begin\": 318, \"end\": 330, \"title\": \"http://dbpedia.org/resource/NBCUniversal\", \"score\": 1.0, \"rank\": 7.768311216966041e-14, \"text\": \"NBCUniversal\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/NBCUniversal\", \"dbpedia\": \"http://dbpedia.org/resource/NBCUniversal\"}, {\"begin\": 352, \"end\": 356, \"title\": \"http://dbpedia.org/resource/Meta_Platforms\", \"score\": 0.9999975053400897, \"rank\": 2.4946661448821696e-06, \"text\": \"Meta\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Meta_Platforms\", \"dbpedia\": \"http://dbpedia.org/resource/Meta_Platforms\"}, {\"begin\": 368, \"end\": 376, \"title\": \"http://dbpedia.org/resource/Snapchat\", \"score\": 0.99999998830981, \"rank\": 1.1676777919743456e-08, \"text\": \"Snapchat\", \"types\": [\"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/Snapchat\", \"dbpedia\": \"http://dbpedia.org/resource/Snapchat\"}, {\"begin\": 378, \"end\": 384, \"title\": \"http://dbpedia.org/resource/TikTok\", \"score\": 1.0, \"rank\": 4.2658173156359806e-37, \"text\": \"TikTok\", \"types\": [\"Q7397\", \"Q386724\"], \"wikid\": \"http://dbpedia.org/resource/TikTok\", \"dbpedia\": \"http: