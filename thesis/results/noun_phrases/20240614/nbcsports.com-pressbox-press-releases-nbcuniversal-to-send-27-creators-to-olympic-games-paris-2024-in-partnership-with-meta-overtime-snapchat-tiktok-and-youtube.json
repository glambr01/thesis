 1.0, \"rank\": 3.758176578814019e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}, {\"begin\": 920, \"end\": 932, \"title\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"NBC Olympics\", \"types\": [\"Q386724\", \"Q15416\"], \"wikid\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\", \"dbpedia\": \"http://dbpedia.org/resource/NBC_Olympic_broadcasts\"}], \"noun_phrases\": [{\"ngram\": \"these new partnerships\", \"from\": 717, \"to\": 739}, {\"ngram\": \"the younger generation\", \"from\": 762, \"to\": 784}, {\"ngram\": \"Olympic fans\", \"from\": 788, \"to\": 800}, {\"ngram\": \"personalities\", \"from\": 806, \"to\": 819}, {\"ngram\": \"content\", \"from\": 821, \"to\": 828}, {\"ngram\": \"voices\", \"from\": 834, \"to\": 840}, {\"ngram\": \"their daily lives\", \"from\": 874, \"to\": 891}]}, {\"sentence\": \"\\\"Creators participating in this new program will bring a unique perspective to fans of the Olympic Games.\", \"from\": 934, \"to\": 1039, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Creators\", \"from\": 935, \"to\": 943}, {\"ngram\": \"this new program\", \"from\": 961, \"to\": 977}, {\"ngram\": \"a unique perspective\", \"from\": 989, \"to\": 1009}, {\"ngram\": \"fans\", \"from\": 1013, \"to\": 1017}, {\"ngram\": \"the Olympic Games\", \"from\": 1021, \"to\": 1038}]}, {\"sentence\": \"From the athletes to the food to the celebration, creators will offer their communities of fans a truly unique, engaging look at this summer's global gathering in Paris.\\\"\", \"from\": 1040, \"to\": 1210, \"entities\": [{\"begin\": 1203, \"end\": 1208, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 3.758176578814019e-14, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"nou