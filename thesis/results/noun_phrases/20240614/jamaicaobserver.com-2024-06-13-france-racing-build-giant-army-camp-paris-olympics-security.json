"{\"uid\": \"jamaicaobserver.com-2024-06-13-france-racing-build-giant-army-camp-paris-olympics-security\", \"noun_phrases\": [{\"sentence\": \"PARIS, France (AFP) - To house the thousands of soldiers tasked with keeping the Paris Olympics safe, France is building the largest army camp its mainland has seen since World War II, at breakneck pace.\", \"from\": 0, \"to\": 203, \"entities\": [{\"begin\": 7, \"end\": 13, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9765811636155369, \"rank\": 0.023958342927939115, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}, {\"begin\": 102, \"end\": 108, \"title\": \"http://dbpedia.org/resource/France\", \"score\": 0.9765811636155369, \"rank\": 0.023958342927939115, \"text\": \"France\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/France\", \"dbpedia\": \"http://dbpedia.org/resource/France\"}], \"noun_phrases\": [{\"ngram\": \"PARIS\", \"from\": 0, \"to\": 5}, {\"ngram\": \"AFP\", \"from\": 15, \"to\": 18}, {\"ngram\": \"the thousands\", \"from\": 31, \"to\": 44}, {\"ngram\": \"soldiers\", \"from\": 48, \"to\": 56}, {\"ngram\": \"the Paris Olympics\", \"from\": 77, \"to\": 95}, {\"ngram\": \"the largest army camp\", \"from\": 121, \"to\": 142}, {\"ngram\": \"its mainland\", \"from\": 143, \"to\": 155}, {\"ngram\": \"World War II\", \"from\": 171, \"to\": 183}, {\"ngram\": \"breakneck pace\", \"from\": 188, \"to\": 202}]}, {\"sentence\": \"Row upon row of temporary barracks have risen up where a fairground in eastern Paris once stood, green army bunk beds and massive mess halls for 4,500 troops replacing merry-go-rounds and candyfloss.\", \"from\": 205, \"to\": 404, \"entities\": [{\"begin\": 284, \"end\": 289, \"title\": \"http://dbpedia.org/resource/Paris\", \"score\": 1.0, \"rank\": 3.678656202087476e-15, \"text\": \"Paris\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Paris\"}], \"noun_phrases\": [{\"ngram\": \"Row\", \"from\": 205, \"to\": 208}, {\"ngram\": \"row\", \"from\": 214, \"to\": 217}, {\"ngram\": \"temporary barracks\", \"from\": 221, \"to\": 239}, {\"ngram\": \"a fairground\", \"from\": 260, \"to\": 272}, {\"ngram\": \", green army bunk beds\", \"from\": 300, \"to\": 322}, {\"ngram\": \"massive mess halls\", \"from\": 327, \"to\": 345}, {\"ngram\": \"4,500 troops\", \"from\": 350, \"to\": 362}, {\"ngram\": \"merry-go-rounds\", \"from\": 373, \"to\": 388}]}, {\"sentence\": \"Construction of the camp is being held to a record deadline of 65 days, with the first soldiers due to arrive July 3.\", \"from\": 406, \"to\": 523, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Construction\", \"from\": 406, \"to\": 418}, {\"ngram\": \"the camp\", \"from\": 422, \"to\": 430}, {\"ngram\": \"a record deadline\", \"from\": 448, \"to\": 465}, {\"ngram\": \"65 days\", \"from\": 469, \"to\": 476}, {\"ngram\": \"the first soldiers\", \"from\": 483, \"to\": 501}]}, {\"sentence\": \"Thirteen days later, they will be guarding the showpiece opening ceremony of the 2024 Olympics along a six-kilometre (four-mile) stretch of the River Seine, - the focus of persistent security worries.\", \"from\": 525, \"to\": 725, \"entities\": [{\"begin\": 669, \"end\": 680, \"title\": \"http://dbpedia.org/resource/Seine\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"River Seine\", \"types\": [\"Q47521\", \"Q4022\"], \"wikid\": \"http://dbpedia.org/resource/Seine\", \"dbpedia\": \"http://dbpedia.org/resource/Seine\"}], \"noun_phrases\": [{\"ngram\": \"the showpiece opening ceremony\", \"from\": 568, \"to\": 598}, {\"ngram\": \"the 2024 Olympics\", \"from\": 602, \"to\": 619}, {\"ngram\": \"a six-kilometre (four-mile) stretch\", \"from\": 626, \"to\": 661}, {\"ngram\": \"the focus\", \"from\": 684, \"to\": 693}, {\"ngram\": \"persistent security worries\", \"from\": 697, \"to\": 724}]}, {\"sentence\": \"\\\"We are on schedule,\\\" insisted Denis Lesaffre from the Economat des Armees, a logistics partner of the armed forces which is managing the work.\", \"from\": 727, \"to\": 870, \"entities\": [{\"begin\": 758, \"end\": 763, \"title\": \"http://dbpedia.org/resource/Saint_Denis_of_Paris\", \"score\": 0.9804969013773527, \"rank\": 0.019666330561920582, \"text\": \"Denis\", \"types\": [\"Q729\", \"Q5\", \"Q43115\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Saint_Denis_of_Paris\", \"dbpedia\": \"http://dbpedia.org/resource/Saint_Denis_of_Paris\"}, {\"begin\": 764, \"end\": 772, \"title\": \"http://dbpedia.org/resource/Lesaffre\", \"score\": 0.9999999999990905, \"rank\": 0.0, \"text\": \"Lesaffre\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Lesaffre\", \"dbpedia\": \"http://dbpedia.org/resource/Lesaffre\"}], \"noun_phrases\": [{\"ngram\": \"schedule\", \"from\": 738, \"to\": 746}, {\"ngram\": \"the Economat des Armees\", \"from\": 778, \"to\": 801}, {\"ngram\": \"a logistics partner\", \"from\": 803, \"to\": 822}, {\"ngram\": \"the armed forces\", \"from\": 826, \"to\": 842}, {\"ngram\": \"the work\", \"from\": 861, \"to\": 869}]}, {\"sentence\": \"In all, 18,000 military personnel will be on hand to provide security for the Games, which will last from July 26 to August 11.\", \"from\": 872, \"to\": 999, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"18,000 military personnel\", \"from\": 880, \"to\": 905}, {\"ngram\": \"hand\", \"from\": 917, \"to\": 921}, {\"ngram\": \"security\", \"from\": 933, \"to\": 941}, {\"ngram\": \"the Games\", \"from\": 946, \"to\": 955}, {\"ngram\": \"July\", \"from\": 978, \"to\": 982}, {\"ngram\": \"August\", \"from\": 989, \"to\": 995}]}, {\"sentence\": \"They will provide support for 45,000 members of the internal security forces, police and gendarmerie, along with a number of private security guards ranging between 18,000 and 22,000 a day.\", \"from\": 1001, \"to\": 1190, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"support\", \"from\": 1019, \"to\": 1026}, {\"ngram\": \"45,000 members\", \"from\": 1031, \"to\": 1045}, {\"ngram\": \"the internal security forces\", \"from\": 1049, \"to\": 1077}, {\"ngram\": \"police\", \"from\": 1079, \"to\": 1085}, {\"ngram\": \"gendarmerie\", \"from\": 1090, \"to\": 1101}, {\"ngram\": \"a number\", \"from\": 1114, \"to\": 1122}, {\"ngram\": \"private security guards\", \"from\": 1126, \"to\": 1149}]}, {\"sentence\": \"Though it may compare in scale to the camps that were built when Nazi boots still stood on French soil, its amenities would be rather alien to the soldiers of the time.\", \"from\": 1192, \"to\": 1360, \"entities\": [{\"begin\": 1257, \"end\": 1261, \"title\": \"http://dbpedia.org/resource/Nazi_Germany\", \"score\": 0.9975986629582382, \"rank\": 0.0023962648965704723, \"text\": \"Nazi\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Nazi_Germany\", \"dbpedia\": \"http://dbpedia.org/resource/Nazi_Germany\"}, {\"begin\": 1283, \"end\": 1289, \"title\": \"http://dbpedia.org/resource/French_Army\", \"score\": 0.9999976439790331, \"rank\": 2.33226212866398e-06, \"text\": \"French\", \"types\": [\"Q43229\", \"Q24229398\", \"Q176799\"], \"wikid\": \"http://dbpedia.org/resource/French_Army\", \"dbpedia\": \"http://dbpedia.org/resource/French_Army\"}], \"noun_phrases\": [{\"ngram\": \"scale\", \"from\": 1217, \"to\": 1222}, {\"ngram\": \"the camps\", \"from\": 1226, \"to\": 1235}, {\"ngram\": \"its amenities\", \"from\": 1296, \"to\": 1309}, {\"ngram\": \"the soldiers\", \"from\": 1335, \"to\": 1347}, {\"ngram\": \"the time\", \"from\": 1351, \"to\": 1359}]}, {\"sentence\": \"\\\"In 1945, we were building camps of tents,\\\" Commissar General Philippe Pourque told AFP.\", \"from\": 1362, \"to\": 1450, \"entities\": [{\"begin\": 1416, \"end\": 1423, \"title\": \"http://dbpedia.org/resource/General_officer\", \"score\": 0.9997892049601296, \"rank\": 0.000