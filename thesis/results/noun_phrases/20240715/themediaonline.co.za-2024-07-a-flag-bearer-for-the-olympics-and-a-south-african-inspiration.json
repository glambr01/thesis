47, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Mhlongo's story\", \"from\": 918, \"to\": 933}]}, {\"sentence\": \"It is a reason to believe that you can thrive in any environment if the right resources are attainable,\\\" said Lilian Henderson, director of marketing fpr Southern and East Africa at BIC.\", \"from\": 948, \"to\": 1134, \"entities\": [{\"begin\": 1065, \"end\": 1074, \"title\": \"http://dbpedia.org/resource/Gerald_Henderson_Jr.\", \"score\": 0.998094409471308, \"rank\": 0.0009336033247955391, \"text\": \"Henderson\", \"types\": [\"Q729\", \"Q5\", \"Q3665646\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Gerald_Henderson_Jr.\", \"dbpedia\": \"http://dbpedia.org/resource/Gerald_Henderson_Jr.\"}, {\"begin\": 1102, \"end\": 1110, \"title\": \"http://dbpedia.org/resource/Southern_United_States\", \"score\": 0.9999628947438601, \"rank\": 3.435640250404299e-05, \"text\": \"Southern\", \"types\": [\"Q3455524\"], \"wikid\": \"http://dbpedia.org/resource/Southern_United_States\", \"dbpedia\": \"http://dbpedia.org/resource/Southern_United_States\"}, {\"begin\": 1115, \"end\": 1126, \"title\": \"http://dbpedia.org/resource/Africa\", \"score\": 0.959280165858786, \"rank\": 0.042447927322415806, \"text\": \"East Africa\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Africa\", \"dbpedia\": \"http://dbpedia.org/resource/Africa\"}, {\"begin\": 1130, \"end\": 1133, \"title\": \"http://dbpedia.org/resource/ISO_9362\", \"score\": 0.991564834563117, \"rank\": 0.00839062269809346, \"text\": \"BIC\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/ISO_9362\", \"dbpedia\": \"http://dbpedia.org/resource/ISO_9362\"}], \"noun_phrases\": [{\"ngram\": \"a reason\", \"from\": 954, \"to\": 962}, {\"ngram\": \"any environment\", \"from\": 997, \"to\": 1012}, {\"ngram\": \"the right resources\", \"from\": 1016, \"to\": 1035}, {\"ngram\": \"director\", \"from\": 1076, \"to\": 1084}, {\"ngram\": \"marketing fpr\", \"from\": 1088, \"to\": 1101}]}, {\"sentence\": \"\\\"As a brand committed to education, we believe that change starts with 'one'.\", \"from\": 1136, \"to\": 1213, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a brand\", \"from\": 1140, \"to\": 1147}, {\"ngram\": \"education\", \"from\": 1161, \"to\": 1170}, {\"ngram\": \"change\", \"from\": 1188, \"to\": 1194}]}, {\"sentence\": \"An individual that believes in you, a teacher that supports you, an organisation that funds you, a parent that encourages you.\", \"from\": 1214, \"to\": 1340, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"An individual\", \"from\": 1214, \"to\": 1227}, {\"ngram\": \"a teacher\", \"from\": 1250, \"to\": 1259}, {\"ngram\": \"an organisation\", \"from\": 1279, \"to\": 1294}, {\"ngram\": \"a parent\", \"from\": 1311, \"to\": 1319}]}, {\"sentence\": \"Our nation-wide initiative Buy a Pen Donate a Pen and our partnership with Mhlongo are a testament to that,\\\" she added.\", \"from\": 1341, \"to\": 1460, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Our nation-wide initiative\", \"from\": 1341, \"to\": 1367}, {\"ngram\": \"a Pen\", \"from\": 1385, \"to\": 1390}, {\"ngram\": \"our partnership\", \"from\": 1395, \"to\": 1410}, {\"ngram\": \"Mhlongo\", \"from\": 1416, \"to\": 1423}, {\"ngram\": \"a testament\", \"from\": 1428, \"to\": 1439}]}, {\"sentence\": \"The campaign has an added call to action, as it hopes to donate a million writing tools to learners in need.\", \"from\": 1462, \"to\": 1570, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The campaign\", \"from\": 1462, \"to\": 1474}, {\"ngram\": \"an added call\", \"from\": 1479, \"to\": 1492}, {\"ngram\": \"action\", \"from\": 1496, \"to\": 1502}, {\"ngram\": \"a million writing tools\", \"from\": 1526, \"to\": 1549}, {\"ngram\": \"learners\", \"from\": 1553, \"to\": 1561}, {\"ngram\": \"need\", \"from\": 1565, \"to\": 1569}]}, {\"sentence\": \"Commenting on the partnership, Mhlongo said: \\\"As a South African child who needed a cheerleader, I understand the difference that the support of a community can make.\", \"from\": 1572, \"to\": 1738, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the partnership\", \"from\": 1586, \"to\": 1601}, {\"ngram\": \"Mhlongo\", \"from\": 1603, \"to\": 1610}, {\"ngram\": \"a South African child\", \"from\": 1621, \"to\": 1642}, {\"ngram\": \"a cheerleader\", \"from\": 1654, \"to\": 1667}, {\"ngram\": \"the difference\", \"from\": 1682, \"to\": 1696}, {\"ngram\": \"the support\", \"from\": 1702, \"to\": 1713}, {\"ngram\": \"a community\", \"from\": 1717, \"to\": 1728}]}, {\"sentence\": \"Someone took a chance on me and that completely changed the course of my life.\", \"from\": 1739, \"to\": 1817, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Someone\", \"from\": 1739, \"to\": 1746}, {\"ngram\": \"a chance\", \"from\": 1752, \"to\": 1760}, {\"ngram\": \"the course\", \"from\": 1795, \"to\": 1805}, {\"ngram\": \"my life\", \"from\": 1809, \"to\": 1816}]}, {\"sentence\": \"\\\"My partnership embodies my experience.\", \"from\": 1819, \"to\": 1858, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"My partnership\", \"from\": 1820, \"to\": 1834}, {\"ngram\": \"my experience\", \"from\": 1844, \"to\": 1857}]}, {\"sentence\": \"I would love to be for our children today, the person I needed to have as a child, and I am touched to collaborate with brands that understand the meaning of that to the future of our society.\", \"from\": 1859, \"to\": 2051, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"our children\", \"from\": 1882, \"to\": 1894}, {\"ngram\": \"a child\", \"from\": 1933, \"to\": 1940}, {\"ngram\": \"brands\", \"from\": 1979, \"to\": 1985}, {\"ngram\": \"the meaning\", \"from\": 2002, \"to\": 2013}, {\"ngram\": \"the future\", \"from\": 2025, \"to\": 2035}, {\"ngram\": \"our society\", \"from\": 2039, \"to\": 2050}]}, {\"sentence\": \"I look forward to this collaboration and to visiting students at the various school activations led by BIC.\\\"\", \"f