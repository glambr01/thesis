"{\"uid\": \"en.worldtempus.com-article-watch-knowledge-best-watches-surfing-olympic-games-olympic-games-78665.html\", \"noun_phrases\": [{\"sentence\": \"This summer, surfing returns to the Olympic fold having finally made its debut at Tokyo 2020 at Tsurigasaki Beach where the USA's Carissa Moore and Brazil's Italo Ferreira clinched gold in their respective categories.\", \"from\": 0, \"to\": 217, \"entities\": [{\"begin\": 82, \"end\": 87, \"title\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"score\": 0.9413666253866452, \"rank\": 0.06184888523336452, \"text\": \"Tokyo\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Tokyo_bid_for_the_2020_Summer_Olympics\"}, {\"begin\": 124, \"end\": 127, \"title\": \"http://dbpedia.org/resource/United_States\", \"score\": 0.9999952751288884, \"rank\": 3.204001856102192e-06, \"text\": \"USA\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/United_States\", \"dbpedia\": \"http://dbpedia.org/resource/United_States\"}, {\"begin\": 130, \"end\": 143, \"title\": \"http://dbpedia.org/resource/Carissa_Moore\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Carissa Moore\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Carissa_Moore\", \"dbpedia\": \"http://dbpedia.org/resource/Carissa_Moore\"}, {\"begin\": 148, \"end\": 154, \"title\": \"http://dbpedia.org/resource/Brazil\", \"score\": 0.9999131892025276, \"rank\": 8.678838409307752e-05, \"text\": \"Brazil\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Brazil\", \"dbpedia\": \"http://dbpedia.org/resource/Brazil\"}], \"noun_phrases\": [{\"ngram\": \"returns\", \"from\": 21, \"to\": 28}, {\"ngram\": \"its debut\", \"from\": 69, \"to\": 78}, {\"ngram\": \"Tsurigasaki Beach\", \"from\": 96, \"to\": 113}, {\"ngram\": \"gold\", \"from\": 181, \"to\": 185}, {\"ngram\": \"their respective categories\", \"from\": 189, \"to\": 216}]}, {\"sentence\": \"Ferreira even broke a board in half on his way to glory!\", \"from\": 218, \"to\": 274, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Ferreira\", \"from\": 218, \"to\": 226}, {\"ngram\": \"a board\", \"from\": 238, \"to\": 245}, {\"ngram\": \"half\", \"from\": 249, \"to\": 253}, {\"ngram\": \"his way\", \"from\": 257, \"to\": 264}, {\"ngram\": \"glory\", \"from\": 268, \"to\": 273}]}, {\"sentence\": \"At Paris 2024, the surfing competitions are slated forTeahupo'o wave, 15,000km away from the French capital in Tahiti, an autonomous overseas country of the French Republic.\", \"from\": 278, \"to\": 451, \"entities\": [{\"begin\": 371, \"end\": 377, \"title\": \"http://dbpedia.org/resource/French_language\", \"score\": 0.9541878771345048, \"rank\": 0.046757639347163225, \"text\": \"French\", \"types\": [\"Q315\"], \"wikid\": \"http://dbpedia.org/resource/French_language\", \"dbpedia\": \"http://dbpedia.org/resource/French_language\"}, {\"begin\": 389, \"end\": 395, \"title\": \"http://dbpedia.org/resource/Tahiti\", \"score\": 0.9999995888734637, \"rank\": 4.1112683666989577e-07, \"text\": \"Tahiti\", \"types\": [\"Q23442\"], \"wikid\": \"http://dbpedia.org/resource/Tahiti\", \"dbpedia\": \"http://dbpedia.org/resource/Tahiti\"}, {\"begin\": 442, \"end\": 450, \"title\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"score\": 0.9876435965382913, \"rank\": 0.012086122749791737, \"text\": \"Republic\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Republic_of_Ireland\", \"dbpedia\": \"http://dbpedia.org/resource/Republic_of_Ireland\"}], \"noun_phrases\": [{\"ngram\": \"Paris\", \"from\": 281, \"to\": 286}, {\"ngram\": \"the surfing competitions\", \"from\": 293, \"to\": 317}, {\"ngram\": \"forTeahupo'o wave\", \"from\": 329, \"to\": 346}, {\"ngram\": \"an autonomous overseas country\", \"from\": 397, \"to\": 427}]}, {\"sentence\": \"Teahupo'o is seen as an exciting surfing spot due to its powerful, heavy waves and shallow reef, and it is set to create challenging conditions for top surfers like John John Florence, Gabriel Medina, Caroline Marks and, once again, Moore.\", \"from\": 455, \"to\": 694, \"entities\": [{\"begin\": 620, \"end\": 638, \"title\": \"http://dbpedia.org/resource/John_John_Florence\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"John John Florence\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/John_John_Florence\", \"dbpedia\": \"http://dbpedia.org/resource/John_John_Florence\"}, {\"begin\": 640, \"end\": 654, \"title\": \"http://dbpedia.org/resource/Gabriel_Medina\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Gabriel Medina\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Gabriel_Medina\", \"dbpedia\": \"http://dbpedia.org/resource/Gabriel_Medina\"}, {\"begin\": 656, \"end\": 670, \"title\": \"http://dbpedia.org/resource/Caroline_Marks\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Caroline Marks\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Caroline_Marks\", \"dbpedia\": \"http://dbpedia.org/resource/Caroline_Marks\"}], \"noun_phrases\": [{\"ngram\": \"an exciting surfing spot\", \"from\": 476, \"to\": 500}, {\"ngram\": \"its powerful, heavy waves\", \"from\": 508, \"to\": 533}, {\"ngram\": \"shallow reef\", \"from\": 538, \"to\": 550}, {\"ngram\": \"challenging conditions\", \"from\": 576, \"to\": 598}, {\"ngram\": \"top surfers\", \"from\": 603, \"to\": 614}]}, {\"sentence\": \"Ferreira did not make the cut this time.\", \"from\": 695, \"to\": 735, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Ferreira\", \"from\": 695, \"to\": 703}, {\"ngram\": \"the cut\", \"from\": 717, \"to\": 724}]}, {\"sentence\": \"Last year, the World Surf League (WSL) chose Apple Watch as its official \\\"wearable equipment.\\\"\", \"from\": 739, \"to\": 833, \"entities\": [{\"begin\": 754, \"end\": 777, \"title\": \"http://dbpedia.org/resource/World_Surf_League\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"World Surf League (WSL)\", \"types\": [\"Q623109\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Surf_League\", \"dbpedia\": \"http://dbpedia.org/resource/World_Surf_League\"}, {\"begin\": 784, \"end\": 795, \"title\": \"http://dbpedia.org/resource/Apple_Watch\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Apple Watch\", \"types\": [\"Q1067263\"], \"wikid\": \"http://dbpedia.org/resource/Apple_Watch\", \"dbpedia\": \"http://dbpedia.org/resource/Apple_Watch\"}], \"noun_phrases\": [{\"ngram\": \"its official \\\"wearable equipment\", \"from\": 799, \"to\": 831}]}, {\"sentence\": \"The WSL Surfer app on it syncs with the WSL Scoring System and delivers real-time updates such as scores, wave priority and heat timings directly to athletes' wrists.\", \"from\": 834, \"to\": 1000, \"entities\": [{\"begin\": 874, \"end\": 877, \"title\": \"http://dbpedia.org/resource/World_Surf_League\", \"score\": 1.0, \"rank\": 1.0366923137261524e-35, \"text\": \"WSL\", \"types\": [\"Q623109\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/World_Surf_League\", \"dbpedia\": \"http://dbpedia.org/resource/World_Surf_League\"}], \"noun_phrases\": [{\"ngram\": \"The WSL Surfer app\", \"from\": 834, \"to\": 852}, {\"ngram\": \"real-time updates\", \"from\": 906, \"to\": 923}, {\"ngram\": \"scores\", \"from\": 932, \"to\": 938}, {\"ngram\": \"priority\", \"from\": 945, \"to\": 953}, {\"ngram\": \"heat\", \"from\": 958, \"to\": 962}, {\"ngram\": \"timings\", \"from\": 963, \"to\": 970}, {\"ngram\": \"athletes' wrists\", \"from\": 983, \"to\": 999}]}, {\"sentence\": \"There are, of course, lots of other smart watches available that are geared towards surfing.\", \"from\": 1001, \"to\": 1093, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"course\", \"from\": 1015, \"to\": 1021}, {\"ngram\": \"lots\", \"from\": 1023, \"to\": 1027}, {\"ngram\": \"other smart watches\", \"from\": 1031, \"to\": 1050}]}, {\"sentence\": \"But if a surfer wants to strap on a mechanical wrist companion while catching the waves - or even wants to double-wrist, pairing a connected watch with a traditionally-made ticker - here are three timepieces that might just do a job for them.\", \"from\": 1097, \"to\": 1339, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a surfer\", \"from\": 1104, \"to\": 1112}, {\"ngram\": \"a mechanical wrist companion\", \"from\": 1131, \"to\": 1159}, {\"ngram\": \"the waves\", \"from\": 1175, \"to\": 1184}, {\"ngram\": \"double-wrist\", \"from\": 1204, \"to\": 1216}, {\"ngram\": \"a connected watch\", \"from\": 1226, \"to\": 1243}, {\"ngram\": \"a traditionally-made ticker\", \"from\": 1249, \"to\": 1276}, {\"ngram\": \"three timepieces\", \"from\": 1288, \"to\": 1304}, {\"ngram\": \"a job\", \"from\": 1324, \"to\": 1329}]}, {\"sentence\": \"TAG Heuer Aquaracer 300 Professional Date Even if it's just to have a back-up for knowing the time, factors like depth rating, build quality, readability, tactility and comfort will all be important when selecting a mechanical timepiece fit for surfing.\", \"from\": 1343, \"to\": 1597, \"entities\": [{\"begin\": 1343, \"end\": 1352, \"title\": \"http://dbpedia.org/resource/TAG_Heuer\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"TAG Heuer\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/TAG_Heuer\", \"dbpedia\": \"http://dbpedia.org/resource/TAG_Heuer\"}], \"noun_phrases\": [{\"ngram\": \"300 Professional Date\", \"from\": 1363, \"to\": 1384}, {\"ngram\": \"a back-up\", \"from\": 1411, \"to\": 1420}, {\"ngram\": \"the time\", \"from\": 1433, \"to\": 1441}, {\"ngram\": \"factors\", \"from\": 1443, \"to\": 1450}, {\"ngram\": \"depth rating\", \"from\": 1456, \"to\": 1468}, {\"ngram\": \"quality\", \"from\": 1476, \"to\": 1483}, {\"ngram\": \"readability\", \"from\": 1485, \"to\": 1496}, {\"ngram\": \"tactility\", \"from\": 1498, \"to\": 1507}, {\"ngram\": \"comfort\", \"from\": 1512, \"to\": 1519}, {\"ngram\": \"a mechanical timepiece fit\", \"from\": 1557, \"to\": 1583}]}, {\"sentence\": \"With its 300m water resistant steel case, lume-filled hands, pointers and indexes and dodecagonal rotating notched bezel, theTAG Heuer Aquaracer 300 Professional Dateticks all these boxes.\", \"from\": 1601, \"to\": 1789, \"entities\": [{\"begin\": 1730, \"end\": 1735, \"title\": \"http://dbpedia.org/resource/TAG_Heuer\", \"score\": 1.0, \"rank\": 7.85900300669947e-14, \"text\": \"Heuer\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/TAG_Heuer\", \"dbpedia\": \"http://dbpedia.org/resource/TAG_Heuer\"}], \"noun_phrases\": [{\"ngram\": \"its 300m water resistant steel case\", \"from\": 1606, \"to\": 1641}, {\"ngram\": \"lume-filled hands\", \"from\": 1643, \"to\": 1660}, {\"ngram\": \"pointers\", \"from\": 1662, \"to\": 1670}, {\"ngram\": \"indexes\", \"from\": 1675, \"to\": 1682}, {\"ngram\": \"dodecagonal rotating notched bezel\", \"from\": 1687, \"to\": 1721}, {\"ngram\": \"300 Professional Dateticks\", \"from\": 1746, \"to\": 1772}, {\"ngram\": \"all these boxes\", \"from\": 1773, \"to\": 1788}]}, {\"sentence\": \"Such is its allure, the 42mm and 36mm editions of this watch are respectively endorsed by TAG Heuer ambassadors and ace surfersKai LennyandMaya Gabeira.\", \"from\": 1790, \"to\": 1942, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"its allure\", \"from\": 1798, \"to\": 1808}, {\"ngram\": \"the 42mm and 36mm editions\", \"from\": 1810, \"to\": 1836}, {\"ngram\": \"this watch\", \"from\": 1840, \"to\": 1850}, {\"ngram\": \"TAG Heuer ambassadors\", \"from\": 1880, \"to\": 1901}, {\"ngram\": \"ace surfersKai LennyandMaya Gabeira\", \"from\": 1906, \"to\": 1941}]}, {\"sentence\": \"IWC Schaffhausen Aquatimer Chronograph Specific functions on a watch can come in handy while surfing.\", \"from\": 1946, \"to\": 2048, \"entities\": [{\"begin\": 1946, \"end\": 1962, \"title\": \"http://dbpedia.org/resource/International_Watch_Company\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"IWC Schaffhausen\", \"types\": [\"Q4830453\", \"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/International_Watch_Company\", \"dbpedia\": \"http://dbpedia.org/resource/International_Watch_Company\"}], \"noun_phrases\": [{\"ngram\": \"a watch\", \"from\": 2007, \"to\": 2014}]}, {\"sentence\": \"A chronograph, for example, could prove useful for timing sessions and tracking wave intervals, allowing you to monitor your performance and manage your time effectively.\", \"from\": 2049, \"to\": 2219, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"A chronograph\", \"from\": 2049, \"to\": 2062}, {\"ngram\": \"example\", \"from\": 2068, \"to\": 2075}, {\"ngram\": \"sessions\", \"from\": 2107, \"to\": 2115}, {\"ngram\": \"tracking wave intervals\", \"from\": 2120, \"to\": 2143}, {\"ngram\": \"your performance\", \"from\": 2169, \"to\": 2185}, {\"ngram\": \"your time\", \"from\": 2197, \"to\": 2206}]}, {\"sentence\": \"Mind you, you'd want to make sure it is a chrono that can be operated in and under water with confidence.\", \"from\": 2223, \"to\": 2328, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a chrono\", \"from\": 2263, \"to\": 2271}, {\"ngram\": \"water\", \"from\": 2306, \"to\": 2311}, {\"ngram\": \"confidence\", \"from\": 2317, \"to\": 2327}]}, {\"sentence\": \"In that regard, theIWC Schaffhausen Aquatimer Chronographfits the bill nicely.\", \"from\": 2329, \"to\": 2407, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"that regard\", \"from\": 2332, \"to\": 2343}, {\"ngram\": \"the bill\", \"from\": 2391, \"to\": 2399}]}, {\"sentence\": \"Its 42mm steel case is water resistant to 300m while the chronograph can be activated within the salty brine without any issue.\", \"from\": 2408, \"to\": 2535, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Its 42mm steel case\", \"from\": 2408, \"to\": 2427}, {\"ngram\": \"water\", \"from\": 2431, \"to\": 2436}, {\"ngram\": \"300m\", \"from\": 2450, \"to\": 2454}, {\"ngram\": \"the chronograph\", \"from\": 2461, \"to\": 2476}, {\"ngram\": \"the salty brine\", \"from\": 2501, \"to\": 2516}, {\"ngram\": \"any issue\", \"from\": 2525, \"to\": 2534}]}, {\"sentence\": \"Ulysse Nardin Blast Moonstruck Finally, tidal information is also a handy thing to have at hand while surfing.\", \"from\": 2539, \"to\": 2650, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"tidal information\", \"from\": 2579, \"to\": 2596}, {\"ngram\": \"a handy thing\", \"from\": 2605, \"to\": 2618}, {\"ngram\": \"hand\", \"from\": 2630, \"to\": 2634}]}, {\"sentence\": \"The times of high tide and low tide affect wave conditions, with high tide bringing deeper water, which can smooth out waves or even make them break more consistently in some spots.\", \"from\": 2651, \"to\": 2832, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The times\", \"from\": 2651, \"to\": 2660}, {\"ngram\": \"high tide\", \"from\": 2664, \"to\": 2673}, {\"ngram\": \"low tide\", \"from\": 2678, \"to\": 2686}, {\"ngram\": \"wave conditions\", \"from\": 2694, \"to\": 2709}, {\"ngram\": \"high tide\", \"from\": 2716, \"to\": 2725}, {\"ngram\": \"deeper water\", \"from\": 2735, \"to\": 2747}, {\"ngram\": \"waves\", \"from\": 2770, \"to\": 2775}, {\"ngram\": \"some spots\", \"from\": 2821, \"to\": 2831}]}, {\"sentence\": \"Low tide, meanwhile, exposes shallower areas, potentially causing waves to break more abruptly or in different directions.\", \"from\": 2836, \"to\": 2958, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Low tide\", \"from\": 2836, \"to\": 2844}, {\"ngram\": \"shallower areas\", \"from\": 2865, \"to\": 2880}, {\"ngram\": \"waves\", \"from\": 2902, \"to\": 2907}, {\"ngram\": \"different directions\", \"from\": 2937, \"to\": 2957}]}, {\"sentence\": \"Understanding these patterns can help surfers choose the best times and locations to catch optimal waves.\", \"from\": 2959, \"to\": 3064, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"these patterns\", \"from\": 2973, \"to\": 2987}, {\"ngram\": \"surfers\", \"from\": 2997, \"to\": 3004}, {\"ngram\": \"the best times\", \"from\": 3012, \"to\": 3026}, {\"ngram\": \"locations\", \"from\": 3031, \"to\": 3040}, {\"ngram\": \"optimal waves\", \"from\": 3050, \"to\": 3063}]}, {\"sentence\": \"TheUlysse Nardin Blast Moonstruckcould plausibly help out here: Its precision moonphase is indicated through a circular aperture, while the sun is represented using a bronzite disk.\", \"from\": 3068, \"to\": 3249, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"TheUlysse\", \"from\": 3068, \"to\": 3077}, {\"ngram\": \"Nardin Blast\", \"from\": 3078, \"to\": 3090}, {\"ngram\": \"Its precision moonphase\", \"from\": 3132, \"to\": 3155}, {\"ngram\": \"a circular aperture\", \"from\": 3177, \"to\": 3196}, {\"ngram\": \"the sun\", \"from\": 3204, \"to\": 3211}, {\"ngram\": \"a bronzite disk\", \"from\": 3233, \"to\": 3248}]}, {\"sentence\": \"With the real-time position of these two entities shown in relation to the Earth, the state of the tides can be read off intuitively.\", \"from\": 3250, \"to\": 3383, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the real-time position\", \"from\": 3255, \"to\": 3277}, {\"ngram\": \"these two entities\", \"from\": 3281, \"to\": 3299}, {\"ngram\": \"relation\", \"from\": 3309, \"to\": 3317}, {\"ngram\": \"the Earth\", \"from\": 3321, \"to\": 3330}, {\"ngram\": \"the state\", \"from\": 3332, \"to\": 3341}, {\"ngram\": \"the tides\", \"from\": 3345, \"to\": 3354}]}]}"