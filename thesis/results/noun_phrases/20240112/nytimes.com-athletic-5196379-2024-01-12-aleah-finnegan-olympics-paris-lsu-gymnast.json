"to\": 672}]}, {\"sentence\": \"It was a precursor to qualifying for the Olympic Trials, and the top 17 all-arounders from nationals advanced to the final domestic competition before the Tokyo Games.\", \"from\": 685, \"to\": 852, \"entities\": [{\"begin\": 726, \"end\": 740, \"title\": \"http://dbpedia.org/resource/United_States_Olympic_trials_(track_and_field)\", \"score\": 0.8581582794956577, \"rank\": 0.038961038961052005, \"text\": \"Olympic Trials\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_Olympic_trials_(track_and_field)\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_Olympic_trials_(track_and_field)\"}], \"noun_phrases\": [{\"ngram\": \"a precursor\", \"from\": 692, \"to\": 703}, {\"ngram\": \"the top 17 all-arounders\", \"from\": 746, \"to\": 770}, {\"ngram\": \"nationals\", \"from\": 776, \"to\": 785}, {\"ngram\": \"the final domestic competition\", \"from\": 798, \"to\": 828}, {\"ngram\": \"the Tokyo Games\", \"from\": 836, \"to\": 851}]}, {\"sentence\": \"Entering the meet, Finnegan was firmly in the mix of gymnasts vying for a spot at trials, but multiple falls over the two-day competition took a toll on her all-around score.\", \"from\": 853, \"to\": 1027, \"entities\": [{\"begin\": 872, \"end\": 880, \"title\": \"http://dbpedia.org/resource/Kyle_Finnegan\", \"score\": 0.9999999970041245, \"rank\": 2.9955916165262837e-09, \"text\": \"Finnegan\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Kyle_Finnegan\", \"dbpedia\": \"http://dbpedia.org/resource/Kyle_Finnegan\"}], \"noun_phrases\": [{\"ngram\": \"the meet\", \"from\": 862, \"to\": 870}, {\"ngram\": \"the mix\", \"from\": 895, \"to\": 902}, {\"ngram\": \"gymnasts\", \"from\": 906, \"to\": 914}, {\"ngram\": \"a spot\", \"from\": 925, \"to\": 931}, {\"ngram\": \"trials\", \"from\": 935, \"to\": 941}, {\"ngram\": \"the two-day competition\", \"from\": 967, \"to\": 990}, {\"ngram\": \"a toll\", \"from\": 996, \"to\": 1002}, {\"ngram\": \"her all-around score\", \"from\": 1006, \"to\": 1026}]}, {\"sentence\": \"She finished 23rd, missing the cut.\", \"from\": 1028, \"to\": 1063, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the cut\", \"from\": 1055, \"to\": 1062}]}, {\"sentence\": \"As gymnasts invited to trials got called up one by one, Finnegan stayed seated, thinking, \\\"What am I supposed to do now?\\\"\", \"from\": 1065, \"to\": 1186, \"entities\": [{\"begin\": 1121, \"end\": 1129, \"title\": \"http://dbpedia.org/resource/Kyle_Finnegan\", \"score\": 0.9999999970041245, \"rank\": 2.9955916165262837e-09, \"text\": \"Finnegan\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Kyle_Finnegan\", \"dbpedia\": \"http://dbpedia.org/resource/Kyle_Finnegan\"}], \"noun_phrases\": [{\"ngram\": \"gymnasts\", \"from\": 1068, \"to\": 1076}, {\"ngram\": \"trials\", \"from\": 1088, \"to\": 1094}]}, {\"sentence\": \"Five days later, she retired from elite gymnastics.\", \"from\": 1188, \"to\": 1239, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"elite gymnastics\", \"from\": 1222, \"to\": 1238}]}, {\"sentence\": \"\\\"I really just felt so much disappointment in myself,\\\" she said.\", \"from\": 1241, \"to\": 1305, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"so much disappointment\", \"from\": 1261, \"to\": 1283}]}, {\"sentence\": \"\\\"I was really realistic about theOlympicsand Olympic Trials, but to not even get there was really, really heartbreaking.\", \"from\": 1306, \"to\": 1426, \"entities\": [{\"begin\": 1351, \"end\": 1365, \"title\": \"http://dbpedia.org/resource/United_States_Olympic_trials_(track_and_field)\", \"score\": 0.8581582794956577, \"rank\": 0.038961038961052005, \"text\": \"Olympic Trials\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_Olympic_trials_(track_and_field)\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_Olympic_trials_(track_and_field)\"}], \"noun_phrases\": []}, {\"sentence\": \"I knew my skill level and I knew what I was able to do, and I wasn't able to do that on that day.\", \"from\": 1427, \"to\": 1524, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my skill level\", \"from\": 1434, \"to\": 1448}, {\"ngram\": \"that day\", \"from\": 1515, \"to\": 1523}]}, {\"sentence\": \"I had a bad competition, and unfortunately, that's the sport that we do.\\\"\", \"from\": 1525, \"to\": 1598, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a bad competition\", \"from\": 1531, \"to\": 1548}, {\"ngram\": \"the sport\", \"from\": 1576, \"to\": 1585}]}, {\"sentence\": \"The peak of Haleakal\\u0101 reaches just over 10,000 feet, and there, Linabelle and Aleah took in the landscape while remembering Aleah's father, Don, who died of cancer in 2019, and sang a song befitting their surroundings.\", \"from\": 1600, \"to\": 1818, \"entities\": [{\"begin\": 1612, \"end\": 1621, \"title\": \"http://dbpedia.org/resource/Haleakal\\u0101\", \"score\": 0.9998870066824843, \"rank\": 0.0, \"text\": \"Haleakal\\u0101\", \"types\": [\"Q8502\"], \"wikid\": \"http://dbpedia.org/resource/Haleakal\\u0101\", \"dbpedia\": \"http://dbpedia.org/resource/Haleakal\\u0101\"}, {\"begin\": 1740, \"end\": 1743, \"title\": \"http://dbpedia.org/resource/Don_Draper\", \"score\": 1.0, \"rank\": 6.678153705822784e-22, \"text\": \"Don\", \"types\": [\"Q95074\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/Don_Draper\", \"dbpedia\": \"http://dbpedia.org/resource/Don_Draper\"}], \"noun_phrases\": [{\"ngram\": \"The peak\", \"from\": 1600, \"to\": 1608}, {\"ngram\": \"just over 10,000 feet\", \"from\": 1630, \"to\": 1651}, {\"ngram\": \"Linabelle\", \"from\": 1664, \"to\": 1673}, {\"ngram\": \"Aleah\", \"from\": 1678, \"to\": 1683}, {\"ngram\": \"the landscape\", \"from\": 1692, \"to\": 1705}, {\"ngram\": \"Aleah's father\", \"from\": 1724, \"to\": 1738}, {\"ngram\": \"cancer\", \"from\": 1757, \"to\": 1763}, {\"ngram\": \"a song\", \"from\": 1782, \"to\": 1788}, {\"ngram\": \"their surroundings\", \"from\": 1799, \"to\": 1817}]}, {\"sentence\": \"We will go up, up, upBut I will fly a little higherGo up in the clouds because the view's a little nicer \\\"I really believe the Lord spoke to her there,\\\" Linabelle said.\", \"from\": 1820, \"to\": 1989, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a little higherGo\", \"from\": 1856, \"to\": 1873}, {\"ngram\": \"the clouds\", \"from\": 1880, \"to\": 1890}, {\"ngram\": \"the view\", \"from\": 1899, \"to\": 1907}, {\"ngram\": \"the Lord\", \"from\": 1943, \"to\": 1951}, {\"ngram\": \"Linabelle\", \"from\": 1973, \"to\": 1982}]}, {\"sentence\": \"\\\"I think that was a time when she was really able to let go of that pain and that dream.\", \"from\": 1990, \"to\": 2078, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a time\", \"from\": 2008, \"to\": 2014}, {\"ngram\": \"that pain\", \"from\": 2053, \"to\": 2062}]}, {\"sentence\": \"She said she was going to LSU and was really excited about it, believing that God has a great plan for her in spite of seemingly not including the Olympics.\\\"\", \"from\": 2079, \"to\": 2236, \"entities\": [{\"begin\": 2105, \"end\": 2108, \"title\": \"http://dbpedia.org/resource/LSU_Tigers_football\", \"score\": 0.9999883887695605, \"rank\": 7.323515494123578e-06, \"text\": \"LSU\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/LSU_Tigers_football\", \"dbpedia\": \"http://dbpedia.org/resource/LSU_Tigers_football\"}], \"noun_phrases\": [{\"ngram\": \"God\", \"from\": 2157, \"to\": 2160}, {\"ngram\": \"a great plan\", \"from\": 2165, \"to\": 2177}, {\"ngram\": \"spite\", \"from\": 2189, \"to\": 2194}, {\"ngram\": \"the Olympics\", \"from\": 2222, \"to\": 2234}]}, {\"sentence\": \"Now, two and a half years later, Aleah is Paris-bound.\", \"from\": 2238, \"to\": 2292, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Aleah\", \"from\": 2271, \"to\": 2276}]}, {\"sentence\": \"She will become the first female gymnast representing the Philippines, Linabelle's home country, to compete at the Olympics after charting a path to the 2024 Games that she never predicted and nearly did not pursue.\", \"from\": 2293, \"to\": 2508, \"entities\": [{\"begin\": 2351, \"end\": 2362, \"title\": \"http://dbpedia.org/resource/Philippines_men's_national_basketball_team\", \"score\": 0.7456345200905239, \"rank\": 0.3138260287175878, \"text\": \"Philippines\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Philippines_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/Philippines_men's_national_basketball_team\"}], \"noun_phrases\": [{\"ngram\": \"the first female gymnast\", \"from\": 2309, \"to\": 2333}, {\"ngram\": \"Linabelle's home country\", \"from\": 2364, \"to\": 2388}, {\"ngram\": \"the Olympics\", \"from\": 2404, \"to\": 2416}, {\"ngram\": \"a path\", \"from\": 2432, \"to\": 2438}, {\"ngram\": \"the 2024 Games\", \"from\": 2442, \"to\": 2456}]}, {\"sentence\": \"Advertisement \\\"Just looking back, it's so surreal.\", \"from\": 2510, \"to\": 2561, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"I never would have guessed my journey would have gone a different route than it has,\\\" she said, \\\"but I would not have had it any other way.\\\"\", \"from\": 2562, \"to\": 2702, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"my journey\", \"from\": 2589, \"to\": 2599}, {\"ngram\": \"a different route\", \"from\": 2616, \"to\": 2633}]}, {\"sentence\": \"Finnegan got into gymnastics the way many do: by following her older siblings.\", \"from\": 2704, \"to\": 2782, \"entities\": [{\"begin\": 2704, \"end\": 2712, \"title\": \"http://dbpedia.org/resource/Kyle_Finnegan\", \"score\": 0.9999999970041245, \"rank\": 2.9955916165262837e-09, \"text\": \"Finnegan\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Kyle_Finnegan\", \"dbpedia\": \"http://dbpedia.org/resource/Kyle_Finnegan\"}], \"noun_phrases\": [{\"ngram\": \"gymnastics\", \"from\": 2722, \"to\": 2732}, {\"ngram\": \"her older siblings\", \"from\": 2763, \"to\": 2781}]}, {\"sentence\": \"Linabelle began taking Aleah, who has three older sisters, to classes at age 2, and by age 4 she was talking about going to the Olympics.\", \"from\": 2783, \"to\": 2920, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Linabelle\", \"from\": 2783, \"to\": 2792}, {\"ngram\": \"Aleah\", \"from\": 2806, \"to\": 2811}, {\"ngram\": \"three older sisters\", \"from\": 2821, \"to\": 2840}, {\"ngram\": \"classes\", \"from\": 2845, \"to\": 2852}, {\"ngram\": \"age\", \"from\": 2856, \"to\": 2859}, {\"ngram\": \"age\", \"from\": 2870, \"to\": 2873}, {\"ngram\": \"the Olympics\", \"from\": 2907, \"to\": 2919}]}, {\"sentence\": \"As a teenager competing at the elite level, Finnegan trained 30 hours a week.\", \"from\": 2921, \"to\": 2998, \"entities\": [{\"begin\": 2965, \"end\": 2973, \"title\": \"http://dbpedia.org/resource/Kyle_Finnegan\", \"score\": 0.9999999970041245, \"rank\": 2.9955916165262837e-09, \"text\": \"Finnegan\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Kyle_Finnegan\", \"dbpedia\": \"http://dbpedia.org/resource/Kyle_Finnegan\"}], \"noun_phrases\": [{\"ngram\": \"a teenager\", \"from\": 2924, \"to\": 2934}, {\"ngram\": \"the elite level\", \"from\": 2948, \"to\": 2963}]}, {\"sentence\": \"\\\"I would threaten if she did not do her homework, I would not take her to gym practice,\\\" Linabelle said.\", \"from\": 3000, \"to\": 3104, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"her homework\", \"from\": 3036, \"to\": 3048}, {\"ngram\": \"gym practice\", \"from\": 3074, \"to\": 3086}, {\"ngram\": \"Linabelle\", \"from\": 3089, \"to\": 3098}]}, {\"sentence\": \"\\\"That's how much she really loved it.\\\"\", \"from\": 3105, \"to\": 3143, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"That passion for the sport, which waned a bit following the 2021 U.S. championships, was reignited at LSU where Finnegan, 21, has blossomed into a composed competitor.\", \"from\": 3145, \"to\": 3312, \"entities\": [{\"begin\": 3205, \"end\": 3228, \"title\": \"http://dbpedia.org/resource/2021_U.S._Figure_Skating_Championships\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"2021 U.S. championships\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/2021_U.S._Figure_Skating_Championships\", \"dbpedia\": \"http://dbpedia.org/resource/2021_U.S._Figure_Skating_Championships\"}], \"noun_phrases\": [{\"ngram\": \"That passion\", \"from\": 3145, \"to\": 3157}, {\"ngram\": \"the sport\", \"from\": 3162, \"to\": 3171}, {\"ngram\": \"a bit\", \"from\": 3185, \"to\": 3190}, {\"ngram\": \"LSU\", \"from\": 3247, \"to\": 3250}, {\"ngram\": \"Finnegan\", \"from\": 3257, \"to\": 3265}, {\"ngram\": \"a composed competitor\", \"from\": 3290, \"to\": 3311}]}, {\"sentence\": \"She scored four perfect 10.0s as a sophomore last year and has her eyes on helping LSU win its first NCAA title in April.\", \"from\": 3313, \"to\": 3434, \"entities\": [{\"begin\": 3396, \"end\": 3399, \"title\": \"http://dbpedia.org/resource/LSU_Tigers_football\", \"score\": 0.9999883887695605, \"rank\": 7.323515494123578e-06, \"text\": \"LSU\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/LSU_Tigers_football\", \"dbpedia\": \"http://dbpedia.org/resource/LSU_Tigers_football\"}, {\"begin\": 3414, \"end\": 3418, \"title\": \"http://dbpedia.org/resource/National_Collegiate_Athletic_Association\", \"score\": 0.9999980150889005, \"rank\": 1.9849134512970147e-06, \"text\": \"NCAA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/National_Collegiate_Athletic_Association\", \"dbpedia\": \"http://dbpedia.org/resource/National_Collegiate_Athletic_Association\"}], \"noun_phrases\": [{\"ngram\": \"a sophomore\", \"from\": 3346, \"to\": 3357}, {\"ngram\": \"her eyes\", \"from\": 3376, \"to\": 3384}, {\"ngram\": \"April\", \"from\": 3428, \"to\": 3433}]}, {\"sentence\": \"LSU coach Jay Clark, who saw Finnegan's potential while recruiting her but wasn't sure of her consistency, now leans on her when choosing the Tigers' six-person lineups on all four events.\", \"from\": 3435, \"to\": 3623, \"entities\": [{\"begin\": 3435, \"end\": 3438, \"title\": \"http://dbpedia.org/resource/LSU_Tigers_football\", \"score\": 0.9999883887695605, \"rank\": 7.323515494123578e-06, \"text\": \"LSU\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/LSU_Tigers_football\", \"dbpedia\": \"http://dbpedia.org/resource/LSU_Tigers_football\"}, {\"begin\": 3445, \"end\": 3454, \"title\": \"http://dbpedia.org/resource/Jay_Clark_(coach)\", \"score\": 0.8620584205442962, \"rank\": 0.16000000000000425, \"text\": \"Jay Clark\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Jay_Clark_(coach)\", \"dbpedia\": \"http://dbpedia.org/resource/Jay_Clark_(coach)\"}, {\"begin\": 3464, \"end\": 3472, \"title\": \"http://dbpedia.org/resource/Kyle_Finnegan\", \"score\": 0.9999999970041245, \"rank\": 2.9955916165262837e-09, \"text\": \"Finnegan\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Kyle_Finnegan\", \"dbpedia\": \"http://dbpedia.org/resource/Kyle_Finnegan\"}], \"noun_phrases\": [{\"ngram\": \"her consistency\", \"from\": 3525, \"to\": 3540}, {\"ngram\": \"the Tigers' six-person lineups\", \"from\": 3573, \"to\": 3603}, {\"ngram\": \"all four events\", \"from\": 3607, \"to\": 3622}]}, {\"sentence\": \"\\\"There is a balance to what she does that's perfect because she can do the big, powerful skills, but she also has an artistry and an artistic value to everything she does and the way she presents and moves when she's on floor and balance beam that's tremendous,\\\" Clark said.\", \"from\": 3625, \"to\": 3899, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a balance\", \"from\": 3635, \"to\": 3644}, {\"ngram\": \"the big, powerful skills\", \"from\": 3696, \"to\": 3720}, {\"ngram\": \"an artistry\", \"from\": 3739, \"to\": 3750}, {\"ngram\": \"an artistic value\", \"from\": 3755, \"to\": 3772}, {\"ngram\": \"everything\", \"from\": 3776, \"to\": 3786}, {\"ngram\": \"floor and balance beam\", \"from\": 3845, \"to\": 3867}, {\"ngram\": \"Clark\", \"from\": 3888, \"to\": 3893}]}, {\"sentence\": \"\\\"She's the total package, really.\\\"\", \"from\": 3900, \"to\": 3934, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the total package\", \"from\": 3907, \"to\": 3924}]}, {\"sentence\": \"Midway through Finnegan's freshman season, the president of the gymnastics federation of the Philippines reached out to Linabelle.\", \"from\": 3936, \"to\": 4066, \"entities\": [{\"begin\": 3951, \"end\": 3959, \"title\": \"http://dbpedia.org/resource/Kyle_Finnegan\", \"score\": 0.9999999970041245, \"rank\": 2.9955916165262837e-09, \"text\": \"Finnegan\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Kyle_Finnegan\", \"dbpedia\": \"http://dbpedia.org/resource/Kyle_Finnegan\"}, {\"begin\": 4000, \"end\": 4010, \"title\": \"http://dbpedia.org/resource/Gymnastics\", \"score\": 0.84965585392955, \"rank\": 0.17694710790829432, \"text\": \"gymnastics\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Gymnastics\", \"dbpedia\": \"http://dbpedia.org/resource/Gymnastics\"}, {\"begin\": 4029, \"end\": 4040, \"title\": \"http://dbpedia.org/resource/Philippines_men's_national_basketball_team\", \"score\": 0.7456345200905239, \"rank\": 0.3138260287175878, \"text\": \"Philippines\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Philippines_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/Philippines_men's_national_basketball_team\"}], \"noun_phrases\": [{\"ngram\": \"the president\", \"from\": 3979, \"to\": 3992}, {\"ngram\": \"Linabelle\", \"from\": 4056, \"to\": 4065}]}, {\"sentence\": \"The federation stayed in contact with the Finnegans after Aleah's eldest sister, Hannah, competed for the Philippines in 2011, and they asked Linabelle if her youngest daughter was interested in returning to elite competition.\", \"from\": 4067, \"to\": 4293, \"entities\": [{\"begin\": 4173, \"end\": 4184, \"title\": \"http://dbpedia.org/resource/Philippines_men's_national_basketball_team\", \"score\": 0.7456345200905239, \"rank\": 0.3138260287175878, \"text\": \"Philippines\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Philippines_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/Philippines_men's_national_basketball_team\"}], \"noun_phrases\": [{\"ngram\": \"The federation\", \"from\": 4067, \"to\": 4081}, {\"ngram\": \"contact\", \"from\": 4092, \"to\": 4099}, {\"ngram\": \"the Finnegans\", \"from\": 4105, \"to\": 4118}, {\"ngram\": \"Aleah's eldest sister\", \"from\": 4125, \"to\": 4146}, {\"ngram\": \"Hannah\", \"from\": 4148, \"to\": 4154}, {\"ngram\": \"Linabelle\", \"from\": 4209, \"to\": 4218}, {\"ngram\": \"her youngest daughter\", \"from\": 4222, \"to\": 4243}, {\"ngram\": \"elite competition\", \"from\": 4275, \"to\": 4292}]}, {\"sentence\": \"Finnegan's initial reaction was a firm \\\"no.\\\"\", \"from\": 4295, \"to\": 4339, \"entities\": [{\"begin\": 4295, \"end\": 4303, \"title\": \"http://dbpedia.org/resource/Kyle_Finnegan\", \"score\": 0.9999999970041245, \"rank\": 2.9955916165262837e-09, \"text\": \"Finnegan\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Kyle_Finnegan\", \"dbpedia\": \"http://dbpedia.org/resource/Kyle_Finnegan\"}], \"noun_phrases\": [{\"ngram\": \"a firm\", \"from\": 4327, \"to\": 4333}]}, {\"sentence\": \"She was finally getting in the groove of being a collegiate athlete, and she felt she had shut the door on that side of the sport.\", \"from\": 4340, \"to\": 4470, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the groove\", \"from\": 4367, \"to\": 4377}, {\"ngram\": \"a collegiate athlete\", \"from\": 4387, \"to\": 4407}, {\"ngram\": \"the door\", \"from\": 4435, \"to\": 4443}, {\"ngram\": \"that side\", \"from\": 4447, \"to\": 4456}, {\"ngram\": \"the sport\", \"from\": 4460, \"to\": 4469}]}, {\"sentence\": \"But she tucked the idea away while finishing out her first collegiate season, then kept returning to it in conversations with Linabelle.\", \"from\": 4472, \"to\": 4608, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"the idea\", \"from\": 4487, \"to\": 4495}, {\"ngram\": \"her first collegiate season\", \"from\": 4521, \"to\": 4548}, {\"ngram\": \"conversations\", \"from\": 4579, \"to\": 4592}, {\"ngram\": \"Linabelle\", \"from\": 4598, \"to\": 4607}]}, {\"sentence\": \"Advertisement \\\"The more I was talking to her, the more I realized that this was such an opportunity to be able to give back to my mom and give back to my family and my heritage and be able to represent them on a higher stage.\", \"from\": 4610, \"to\": 4836, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"such an opportunity\", \"from\": 4690, \"to\": 4709}, {\"ngram\": \"my mom\", \"from\": 4737, \"to\": 4743}, {\"ngram\": \"my family\", \"from\": 4761, \"to\": 4770}, {\"ngram\": \"my heritage\", \"from\": 4775, \"to\": 4786}, {\"ngram\": \"a higher stage\", \"from\": 4820, \"to\": 4834}]}, {\"sentence\": \"\\\"I feel like I represent them no matter where I go, but being able to represent them in a more cultured way was really, really awesome.\\\"\", \"from\": 4838, \"to\": 4974, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"a more cultured way\", \"from\": 4926, \"to\": 4945}]}, {\"sentence\": \"Finnegan made her debut with the Philippines women's gymnastics team at the South East Asian (SEA) Games in May 2022 with less than a month of preparation for the competition following the end of her freshman year.\", \"from\": 4976, \"to\": 5190, \"entities\": [{\"begin\": 4976, \"end\": 4984, \"title\": \"http://dbpedia.org/resource/Kyle_Finnegan\", \"score\": 0.9999999970041245, \"rank\": 2.9955916165262837e-09, \"text\": \"Finnegan\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Kyle_Finnegan\", \"dbpedia\": \"http://dbpedia.org/resource/Kyle_Finnegan\"}, {\"begin\": 5009, \"end\": 5020, \"title\": \"http://dbpedia.org/resource/Philippines_men's_national_basketball_team\", \"score\": 0.7456345200905239, \"rank\": 0.3138260287175878, \"text\": \"Philippines\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Philippines_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/Philippines_men's_national_basketball_team\"}], \"noun_phrases\": [{\"ngram\": \"her debut\", \"from\": 4990, \"to\": 4999}, {\"ngram\": \"the South East Asian (SEA) Games\", \"from\": 5048, \"to\": 5080}, {\"ngram\": \"May\", \"from\": 5084, \"to\": 5087}, {\"ngram\": \"less than a month\", \"from\": 5098, \"to\": 5115}, {\"ngram\": \"preparation\", \"from\": 5119, \"to\": 5130}, {\"ngram\": \"the competition\", \"from\": 5135, \"to\": 5150}, {\"ngram\": \"the end\", \"from\": 5161, \"to\": 5168}, {\"ngram\": \"her freshman year\", \"from\": 5172, \"to\": 5189}]}, {\"sentence\": \"Despite the quick turnaround, Finnegan led the team to a gold medal in the team event, picked up an individual gold on vault and added a pair of silver medals in the all-around and on balance beam.\", \"from\": 5192, \"to\": 5389, \"entities\": [{\"begin\": 5222, \"end\": 5230, \"title\": \"http://dbpedia.org/resource/Kyle_Finnegan\", \"score\": 0.9999999970041245, \"rank\": 2.9955916165262837e-09, \"text\": \"Finnegan\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\", \"Q10871364\"], \"wikid\": \"http://dbpedia.org/resource/Kyle_Finnegan\", \"dbpedia\": \"http://dbpedia.org/resource/Kyle_Finnegan\"}], \"noun_phrases\": [{\"ngram\": \"the quick turnaround\", \"from\": 5200, \"to\": 