: 5767, \"to\": 5790}, {\"ngram\": \"her goal\", \"from\": 5822, \"to\": 5830}]}, {\"sentence\": \"Joined by fellow former U.S. national team member Emma Malabuyo, who was an alternate for Team USA at the Tokyo Olympics and is now a star for UCLA, Finnegan helped the Philippines to fifth place in the team competition.\", \"from\": 5833, \"to\": 6053, \"entities\": [{\"begin\": 5857, \"end\": 5875, \"title\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"score\": 0.8958835056520631, \"rank\": 0.11296224822031165, \"text\": \"U.S. national team\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_men's_national_basketball_team\"}, {\"begin\": 5883, \"end\": 5896, \"title\": \"http://dbpedia.org/resource/Emma_Malabuyo\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Emma Malabuyo\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Emma_Malabuyo\", \"dbpedia\": \"http://dbpedia.org/resource/Emma_Malabuyo\"}, {\"begin\": 5923, \"end\": 5931, \"title\": \"http://dbpedia.org/resource/United_States_national_team\", \"score\": 0.9974432733643139, \"rank\": 0.0020373725323207105, \"text\": \"Team USA\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/United_States_national_team\", \"dbpedia\": \"http://dbpedia.org/resource/United_States_national_team\"}, {\"begin\": 5976, \"end\": 5980, \"title\": \"http://dbpedia.org/resource/UCLA_Bruins\", \"score\": 0.9821318407121157, \"rank\": 0.018190730968928443, \"text\": \"UCLA\", \"types\": [\"Q43229\", \"Q24229398\", \"Q12973014\"], \"wikid\": \"http://dbpedia.org/resource/UCLA_Bruins\", \"dbpedia\": \"http://dbpedia.org/resource/UCLA_Bruins\"}, {\"begin\": 5982, \"end\": 5990, \"title\": \"http://dbpedia.org/resource/Kyle_Finnegan\", \"score\": 0.9999999970041245, \"rank\": 2.9955916165262837e-09, \"text\": \"Finnegan\", \"types\": [\"Q