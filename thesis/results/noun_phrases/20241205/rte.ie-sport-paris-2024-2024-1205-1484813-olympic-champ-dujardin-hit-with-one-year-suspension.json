"{\"uid\": \"rte.ie-sport-paris-2024-2024-1205-1484813-olympic-champ-dujardin-hit-with-one-year-suspension\", \"noun_phrases\": [{\"sentence\": \"Double Olympic dressage champion Charlotte Dujardin has been suspended from all competition for one year following a horse whipping controversy that saw her withdraw from the Paris Games.\", \"from\": 0, \"to\": 187, \"entities\": [{\"begin\": 33, \"end\": 51, \"title\": \"http://dbpedia.org/resource/Charlotte_Dujardin\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Charlotte Dujardin\", \"types\": [\"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Charlotte_Dujardin\", \"dbpedia\": \"http://dbpedia.org/resource/Charlotte_Dujardin\"}], \"noun_phrases\": [{\"ngram\": \"all competition\", \"from\": 76, \"to\": 91}, {\"ngram\": \"one year\", \"from\": 96, \"to\": 104}, {\"ngram\": \"a horse whipping controversy\", \"from\": 115, \"to\": 143}, {\"ngram\": \"the Paris Games\", \"from\": 171, \"to\": 186}]}, {\"sentence\": \"Dujardin was provisionally suspended by equestrian's governing body, the International Federation for Equestrian Sports, on 23 July as it launched an investigation into a video from four years ago showing her making what she described as \\\"an error of judgement\\\" during a coaching session.\", \"from\": 189, \"to\": 477, \"entities\": [{\"begin\": 229, \"end\": 239, \"title\": \"http://dbpedia.org/resource/Equestrian_at_the_Summer_Olympics\", \"score\": 0.964942779224403, \"rank\": 0.019721250988276068, \"text\": \"equestrian\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Equestrian_at_the_Summer_Olympics\", \"dbpedia\": \"http://dbpedia.org/resource/Equestrian_at_the_Summer_Olympics\"}], \"noun_phrases\": [{\"ngram\": \"Dujardin\", \"from\": 189, \"to\": 197}, {\"ngram\": \"the International Federation\", \"from\": 258, \"to\": 286}, {\"ngram\": \"Equestrian Sports\", \"from\": 291, \"to\": 308}, {\"ngram\": \"23 July\", \"from\": 313, \"to\": 320}, {\"ngram\": \"an investigation\", \"from\": 336, \"to\": 352}, {\"ngram\": \"a video\", \"from\": 358, \"to\": 365}, {\"ngram\": \"an error\", \"from\": 428, \"to\": 436}, {\"ngram\": \"judgement\", \"from\": 440, \"to\": 449}, {\"ngram\": \"a coaching session\", \"from\": 458, \"to\": 476}]}, {\"sentence\": \"The video showed Dujardin repeatedly hitting a student's horse with a whip from the ground.\", \"from\": 479, \"to\": 570, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The video\", \"from\": 479, \"to\": 488}, {\"ngram\": \"Dujardin\", \"from\": 496, \"to\": 504}, {\"ngram\": \"a student's horse\", \"from\": 524, \"to\": 541}, {\"ngram\": \"a whip\", \"from\": 547, \"to\": 553}, {\"ngram\": \"the ground\", \"from\": 559, \"to\": 569}]}, {\"sentence\": \"Her behaviour sparked widespread condemnation.\", \"from\": 571, \"to\": 617, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"Her behaviour\", \"from\": 571, \"to\": 584}, {\"ngram\": \"widespread condemnation\", \"from\": 593, \"to\": 616}]}, {\"sentence\": \"The complaint was made to the FEI by Dutch equine lawyer Stephan Wensing on behalf of an unnamed client.\", \"from\": 619, \"to\": 723, \"entities\": [{\"begin\": 649, \"end\": 652, \"title\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\", \"score\": 1.0, \"rank\": 5.806100457480155e-37, \"text\": \"FEI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\"}], \"noun_phrases\": [{\"ngram\": \"The complaint\", \"from\": 619, \"to\": 632}, {\"ngram\": \"behalf\", \"from\": 695, \"to\": 701}, {\"ngram\": \"an unnamed client\", \"from\": 705, \"to\": 722}]}, {\"sentence\": \"Dujardin is now sidelined from all competition until July next year, with the suspension back-dated to 23 July of this year.\", \"from\": 725, \"to\": 849, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"all competition\", \"from\": 756, \"to\": 771}, {\"ngram\": \"July\", \"from\": 778, \"to\": 782}, {\"ngram\": \"the suspension\", \"from\": 799, \"to\": 813}, {\"ngram\": \"23 July\", \"from\": 828, \"to\": 835}, {\"ngram\": \"this year\", \"from\": 839, \"to\": 848}]}, {\"sentence\": \"It is understood that she will not appeal.\", \"from\": 850, \"to\": 892, \"entities\": [], \"noun_phrases\": []}, {\"sentence\": \"In a statement, the FEI said: \\\"The FEI has suspended British Dressage athlete Charlotte Dujardin for one year and imposed a fine of CHF 10,000 (\\u20ac10,735), effectively concluding the disciplinary proceedings against her.\", \"from\": 894, \"to\": 1112, \"entities\": [{\"begin\": 914, \"end\": 917, \"title\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\", \"score\": 1.0, \"rank\": 5.806100457480155e-37, \"text\": \"FEI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\"}, {\"begin\": 929, \"end\": 932, \"title\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\", \"score\": 1.0, \"rank\": 5.806100457480155e-37, \"text\": \"FEI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\"}, {\"begin\": 947, \"end\": 963, \"title\": \"http://dbpedia.org/resource/British_Dressage\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"British Dressage\", \"types\": [\"Q43229\", \"Q24229398\"], \"wikid\": \"http://dbpedia.org/resource/British_Dressage\", \"dbpedia\": \"http://dbpedia.org/resource/British_Dressage\"}, {\"begin\": 1026, \"end\": 1029, \"title\": \"http://dbpedia.org/resource/Swiss_franc\", \"score\": 0.9999999999449756, \"rank\": 3.090266231623553e-11, \"text\": \"CHF\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Swiss_franc\", \"dbpedia\": \"http://dbpedia.org/resource/Swiss_franc\"}], \"noun_phrases\": [{\"ngram\": \"a statement\", \"from\": 897, \"to\": 908}, {\"ngram\": \"one year\", \"from\": 995, \"to\": 1003}, {\"ngram\": \"a fine\", \"from\": 1016, \"to\": 1022}, {\"ngram\": \"the disciplinary proceedings\", \"from\": 1071, \"to\": 1099}]}, {\"sentence\": \"\\\"Dujardin has been provisionally suspended since 23 July 2024 for engaging in conduct contrary to the principles of horse welfare.\", \"from\": 1114, \"to\": 1244, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"23 July\", \"from\": 1163, \"to\": 1170}, {\"ngram\": \"conduct\", \"from\": 1192, \"to\": 1199}, {\"ngram\": \"the principles\", \"from\": 1212, \"to\": 1226}, {\"ngram\": \"horse welfare\", \"from\": 1230, \"to\": 1243}]}, {\"sentence\": \"The time served during her provisional suspension will be credited towards the one-year suspension.\", \"from\": 1245, \"to\": 1344, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The time\", \"from\": 1245, \"to\": 1253}, {\"ngram\": \"her provisional suspension\", \"from\": 1268, \"to\": 1294}, {\"ngram\": \"the one-year suspension\", \"from\": 1320, \"to\": 1343}]}, {\"sentence\": \"\\\"During her suspension, Dujardin is prohibited from participating in all activities related to competitions or events under the jurisdiction of the FEI or of a National Federation.\", \"from\": 1346, \"to\": 1526, \"entities\": [{\"begin\": 1494, \"end\": 1497, \"title\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\", \"score\": 1.0, \"rank\": 5.806100457480155e-37, \"text\": \"FEI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\", \"dbpedia\": \"http://dbpedia.org/resource/International_Federation_for_Equestrian_Sports\"}], \"noun_phrases\": [{\"ngram\": \"her suspension\", \"from\": 1354, \"to\": 1368}, {\"ngram\": \"Dujardin\", \"from\": 1370, \"to\": 1378}, {\"ngr