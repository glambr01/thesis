"{\"uid\": \"jamaicaobserver.com-2024-02-14-bryan-mcfarlanes-solo-exhibition-opens-thursday-olympia-gallery\", \"noun_phrases\": [{\"sentence\": \"A new solo exhibition of paintings by internationally acclaimed Jamaican artist and educator Bryan McFarlane opens at the Olympia Gallery on Thursday, February 15, 2024 at 6pm.\", \"from\": 0, \"to\": 176, \"entities\": [{\"begin\": 64, \"end\": 72, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 0.872519205995899, \"rank\": 0.14610657636873112, \"text\": \"Jamaican\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}, {\"begin\": 93, \"end\": 98, \"title\": \"http://dbpedia.org/resource/William_Jennings_Bryan\", \"score\": 0.9999993060903442, \"rank\": 5.598982373193219e-07, \"text\": \"Bryan\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/William_Jennings_Bryan\", \"dbpedia\": \"http://dbpedia.org/resource/William_Jennings_Bryan\"}], \"noun_phrases\": [{\"ngram\": \"A new solo exhibition\", \"from\": 0, \"to\": 21}, {\"ngram\": \"paintings\", \"from\": 25, \"to\": 34}, {\"ngram\": \"the Olympia Gallery\", \"from\": 118, \"to\": 137}, {\"ngram\": \"Thursday\", \"from\": 141, \"to\": 149}, {\"ngram\": \"February\", \"from\": 151, \"to\": 159}, {\"ngram\": \"6pm\", \"from\": 172, \"to\": 175}]}, {\"sentence\": \"The exhibition, titled Fragments of Time III, will be opened by Richard Byles, Governor of the Bank of Jamaica.\", \"from\": 178, \"to\": 289, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"The exhibition\", \"from\": 178, \"to\": 192}, {\"ngram\": \"Fragments\", \"from\": 201, \"to\": 210}, {\"ngram\": \"Time III\", \"from\": 214, \"to\": 222}, {\"ngram\": \"Richard Byles\", \"from\": 242, \"to\": 255}, {\"ngram\": \"Governor\", \"from\": 257, \"to\": 265}, {\"ngram\": \"the Bank\", \"from\": 269, \"to\": 277}, {\"ngram\": \"Jamaica\", \"from\": 281, \"to\": 288}]}, {\"sentence\": \"Most recently, McFarlane's works were exhibited at the Museum of Fine Arts Boston and with Gallery Naga at Art Miami.\", \"from\": 291, \"to\": 408, \"entities\": [{\"begin\": 390, \"end\": 394, \"title\": \"http://dbpedia.org/resource/Naga_people\", \"score\": 0.9749801834031893, \"rank\": 0.02468936565464389, \"text\": \"Naga\", \"types\": [\"Q41710\"], \"wikid\": \"http://dbpedia.org/resource/Naga_people\", \"dbpedia\": \"http://dbpedia.org/resource/Naga_people\"}], \"noun_phrases\": [{\"ngram\": \"McFarlane's works\", \"from\": 306, \"to\": 323}, {\"ngram\": \"the Museum\", \"from\": 342, \"to\": 352}, {\"ngram\": \"Fine Arts Boston\", \"from\": 356, \"to\": 372}, {\"ngram\": \"Art Miami\", \"from\": 398, \"to\": 407}]}, {\"sentence\": \"Born in Moore Town, Portland, Bryan McFarlane works from his studios in Boston, Beijing and Jamaica, and has travelled extensively painting and lecturing.\", \"from\": 410, \"to\": 564, \"entities\": [{\"begin\": 430, \"end\": 438, \"title\": \"http://dbpedia.org/resource/Isle_of_Portland\", \"score\": 0.8290098744133466, \"rank\": 0.12892264108981558, \"text\": \"Portland\", \"types\": [\"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Isle_of_Portland\", \"dbpedia\": \"http://dbpedia.org/resource/Isle_of_Portland\"}, {\"begin\": 440, \"end\": 445, \"title\": \"http://dbpedia.org/resource/William_Jennings_Bryan\", \"score\": 0.9999993060903442, \"rank\": 5.598982373193219e-07, \"text\": \"Bryan\", \"types\": [\"Q82955\", \"Q729\", \"Q5\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/William_Jennings_Bryan\", \"dbpedia\": \"http://dbpedia.org/resource/William_Jennings_Bryan\"}, {\"begin\": 482, \"end\": 488, \"title\": \"http://dbpedia.org/resource/Boston\", \"score\": 0.9999999999997726, \"rank\": 1.7348072488786967e-13, \"text\": \"Boston\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Boston\", \"dbpedia\": \"http://dbpedia.org/resource/Boston\"}, {\"begin\": 490, \"end\": 497, \"title\": \"http://dbpedia.org/resource/Beijing\", \"score\": 0.9999419244018323, \"rank\": 5.807626239683684e-05, \"text\": \"Beijing\", \"types\": [\"Q515\", \"Q486972\"], \"wikid\": \"http://dbpedia.org/resource/Beijing\", \"dbpedia\": \"http://dbpedia.org/resource/Beijing\"}, {\"begin\": 502, \"end\": 509, \"title\": \"http://dbpedia.org/resource/Jamaica\", \"score\": 1.0, \"rank\": 2.224578508822148e-15, \"text\": \"Jamaica\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Jamaica\", \"dbpedia\": \"http://dbpedia.org/resource/Jamaica\"}], \"noun_phrases\": [{\"ngram\": \"Moore Town\", \"from\": 418, \"to\": 428}, {\"ngram\": \"his studios\", \"from\": 467, \"to\": 478}, {\"ngram\": \"extensively painting\", \"from\": 529, \"to\": 549}, {\"ngram\": \"lecturing\", \"from\": 554, \"to\": 563}]}, {\"sentence\": \"He is Professor Emeritus at the University of Massachusetts, Dartmouth, an Institute of Jamaica Silver Musgrave medallist, and a graduate of the Jamaica School of Art, now the Edna Manley College of the Visual and Performing Artists.\", \"from\": 565, \"to\": 798, \"entities\": [{\"begin\": 571, \"end\": 589, \"title\": \"http://dbpedia.org/resource/Emeritus\", \"score\": 0.9979639160806387, \"rank\": 0.002034971044235537, \"text\": \"Professor Emeritus\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/Emeritus\", \"dbpedia\": \"http://dbpedia.org/resource/Emeritus\"}, {\"begin\": 626, \"end\": 635, \"title\": \"http://dbpedia.org/resource/Dartmouth_College\", \"score\": 0.9999999999995453, \"rank\": 2.0969740530913673e-13, \"text\": \"Dartmouth\", \"types\": [\"Q43229\", \"Q3918\", \"Q24229398\", \"Q2385804\"], \"wikid\": \"http://dbpedia.org/resource/Dartmouth_College\", \"dbpedia\": \"http://dbpedia.org/resource/Dartmouth_College\"}, {\"begin\": 741, \"end\": 752, \"title\": \"http://dbpedia.org/resource/Edna_Manley\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"Edna Manley\", \"types\": [\"Q729\", \"Q5\", \"Q483501\", \"Q215627\", \"Q19088\"], \"wikid\": \"http://dbpedia.org/resource/Edna_Manley\", \"dbpedia\": \"http://dbpedia.org/resource/Edna_Manley\"}], \"noun_phrases\": [{\"ngram\": \"the University\", \"from\": 593, \"to\": 607}, {\"ngram\": \"Massachusetts\", \"from\": 611, \"to\": 624}, {\"ngram\": \"an Institute\", \"from\": 637, \"to\": 649}, {\"ngram\": \"Jamaica\", \"from\": 653, \"to\": 660}, {\"ngram\": \"Silver Musgrave medallist\", \"from\": 661, \"to\": 686}, {\"ngram\": \"a graduate\", \"from\": 692, \"to\": 702}, {\"ngram\": \"the Jamaica School\", \"from\": 706, \"to\": 724}, {\"ngram\": \"Art\", \"from\": 728, \"to\": 731}, {\"ngram\": \"the Visual\", \"from\": 764, \"to\": 774}, {\"ngram\": \"Performing Artists\", \"from\": 779, \"to\": 797}]}, {\"sentence\": \"Throughout his career, McFarlane has travelled worldwide painting, teaching and lecturing on art.\", \"from\": 800, \"to\": 897, \"entities\": [], \"noun_phrases\": [{\"ngram\": \"his career\", \"from\": 811, \"to\": 821}, {\"ngram\": \"McFarlane\", \"from\": 823, \"to\": 832}, {\"ngram\": \"worldwide painting\", \"from\": 847, \"to\": 865}, {\"ngram\": \"teaching\", \"from\": 867, \"to\": 875}, {\"ngram\": \"art\", \"from\": 893, \"to\": 896}]}, {\"sentence\": \"He has held visiting professorships at UWI, the Rhode Island School of Design and the School of the Museum of Fine Arts in Boston.\", \"from\": 898, \"to\": 1028, \"entities\": [{\"begin\": 937, \"end\": 940, \"title\": \"http://dbpedia.org/resource/University_of_the_West_Indies\", \"score\": 1.0, \"rank\": 8.302650098728729e-22, \"text\": \"UWI\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/University_of_the_West_Indies\", \"dbpedia\": \"http://dbpedia.org/resource/University_of_the_West_Indies\"}, {\"begin\": 1021, \"end\": 1027, \"title\": \"http://dbpedia.org/resource/Boston\", \"score\": 0.9999999999997726, \"rank\": 1.7348072488786967e-13, \"text\": \"Boston\", \"types\": [\"Q515\", \"Q48697