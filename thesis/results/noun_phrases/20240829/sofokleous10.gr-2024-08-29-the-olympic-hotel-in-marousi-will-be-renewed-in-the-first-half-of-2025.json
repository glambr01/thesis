09}, {\"ngram\": \"visitors\", \"from\": 1214, \"to\": 1222}, {\"ngram\": \"easy access\", \"from\": 1228, \"to\": 1239}, {\"ngram\": \"Athens International Airport\", \"from\": 1252, \"to\": 1280}]}, {\"sentence\": \"The reconfiguration of the buildings, with a total area of 5,725 sqm and eight floors, through their repositioning in the market, is being carried out \\\"taking into account the integration of sustainable development values\\\", with the hotel likely to operate under a new brand that will be \\\"run\\\" by SWOT Hospitality, which has many years of experience in the management and operation of high quality tourist units both in Greece and abroad.\", \"from\": 1284, \"to\": 1722, \"entities\": [{\"begin\": 1581, \"end\": 1585, \"title\": \"http://dbpedia.org/resource/SWOT_analysis\", \"score\": 1.0, \"rank\": 0.0, \"text\": \"SWOT\", \"types\": [], \"wikid\": \"http://dbpedia.org/resource/SWOT_analysis\", \"dbpedia\": \"http://dbpedia.org/resource/SWOT_analysis\"}, {\"begin\": 1704, \"end\": 1710, \"title\": \"http://dbpedia.org/resource/Greece\", \"score\": 1.0, \"rank\": 5.805180767025191e-18, \"text\": \"Greece\", \"types\": [\"Q6256\"], \"wikid\": \"http://dbpedia.org/resource/Greece\", \"dbpedia\": \"http://dbpedia.org/resource/Greece\"}], \"noun_phrases\": [{\"ngram\": \"The reconfiguration\", \"from\": 1284, \"to\": 1303}, {\"ngram\": \"the buildings\", \"from\": 1307, \"to\": 1320}, {\"ngram\": \"a total area\", \"from\": 1327, \"to\": 1339}, {\"ngram\": \"5,725 sqm\", \"from\": 1343, \"to\": 1352}, {\"ngram\": \"eight floors\", \"from\": 1357, \"to\": 1369}, {\"ngram\": \"their repositioning\", \"from\": 1379, \"to\": 1398}, {\"ngram\": \"the market\", \"from\": 1402, \"to\": 1412}, {\"ngram\": \"account\", \"from\": 1448, \"to\": 1455}, {\"ngram\": \"the integration\", \"from\": 1456, \"to\": 1471}, {\"ngram\": \"sustainable development values\", \"from\": 1475, \"to\": 1505}, {\"ngram\": \"the hotel\", \"from\": 1513, \"to\": 1522}, {\"ngram\