1280x720_2000_v3_1_.jpg?auth=f3644a426324bc93626b0de316da09f319a044d350e52e5a27e807a8b22a979d&width=800&height=450&smart=true", "https://gray-kswo-prod.gtv-cdn.com/resizer/v2/https%3A%2F%2Fdo0bihdskp9dy.cloudfront.net%2F12-06-2025%2Ft_28ddcb2fa84e47e2947d3180fd45db36_name_file_1280x720_2000_v3_1_.jpg?auth=526fb917c2172e1e9bfb9f820bdf2cc14d6c466d721e3afd8bc1c62924d7ddc2&width=800&height=450&smart=true", "https://gray-kswo-prod.gtv-cdn.com/resizer/v2/https%3A%2F%2Fdo0bihdskp9dy.cloudfront.net%2F12-06-2025%2Ft_6dbd0d9589664cceaa9eb6163c0542b8_name_file_1280x720_2000_v3_1_.jpg?auth=863c5aa9c51ad5602fe6bf80d5a8e3356addf611c71df1825f58a3aaa6aaf516&width=800&height=450&smart=true", "https://gray-kswo-prod.gtv-cdn.com/resizer/v2/https%3A%2F%2Fdo0bihdskp9dy.cloudfront.net%2F12-05-2025%2Ft_cd6b9c55e3f3410dbeaf90a691ff92d6_name_file_1280x720_2000_v3_1_.jpg?auth=daed01506b376282b8555787c09c2b85299d0b1e841477a30bb6b1c70e6eabff&width=800&height=450&smart=true", "https://gray-kswo-prod.gtv-cdn.com/resizer/v2/https%3A%2F%2Fdo0bihdskp9dy.cloudfront.net%2F12-04-2025%2Ft_f5c6f2bf607c4d5793d1801f8d900896_name_Still1204_00001.png?auth=9ad6a6cc331e240737591bef363e638f8e4b740341fbca161dbc2cd9c6b1f0e0&width=800&height=450&smart=true", "https://gray-kswo-prod.gtv-cdn.com/resizer/v2/https%3A%2F%2Fdo0bihdskp9dy.cloudfront.net%2F12-05-2025%2Ft_2a0d3c0e7806425f8ef0b3f76298eecc_name_file_1280x720_2000_v3_1_.jpg?auth=bbff7b33c53572cf117868247aeee9fede4d6f46878e1d9347f9ef43386a815a&width=800&height=450&smart=true", "https://gray-kswo-prod.gtv-cdn.com/resizer/v2/https%3A%2F%2Fwebpubcontent.gray.tv%2Fgray%2Farc-fusion-assets%2Fimages%2Ffallback-graphics%2Fkswo.jpg%3Fd%3D527%26mxId%3D00000000?auth=c3c11d5ed055e834f833f5c6e200b57e2c573cad651ede0dee9e35e23988dd17&width=800&height=450&smart=false&focal=960%2C540"], "publication-date": "2024-06-21", "text": "OKLAHOMA CITY, Okla. (KSWO) - LA28, the plan behind the 2028 Olympics in Los Angeles announced an update to the master plan for venues including two events moving to OKC.\n\nAccording to the Olympics website, Oklahoma City will play host to softball and canoe slalom attributed to what the committee describes as “world-class venues.”\n\nThe Olympics website states:\n\nBoth the existing canoe slalom and softball stadiums in Oklahoma City are built to international competition standards, and the local community has consistently supported top tournaments for both sports, ensuring a high-quality experience for both athletes and fans, while allowing LA28 to achieve cost savings and revenue gains to support its balanced budget.\n\nCurrently, Oklahoma is the only state outside of California to host events in the 2028 games.\n\nCopyright 2024 KSWO. All rights reserved.", "title": "Oklahoma City tabbed to host multiple Olympic events in 2028", "top-image": "https://gray-kswo-prod.gtv-cdn.com/resizer/v2/QUGWT77FS5KAPGWVFUIZBX4TO4.jpg?auth=452e22a097e277d11899f78b293ec4e75086b8bad7b710ca4e2bea401c9aebcf&width=800&height=450&smart=true", "domain": "www.kswo.com", "lang": "en", "author": "", "description": "LA28, the plan behind the 2028 Olympics in Los Angeles announced an update to the master plan for venues including two sports moving to OKC.", "keywords": "LA28,los angeles,oklahoma,city,oklahoma city,southwest oklahoma,kswo,lawton,7news,7sports"}