nt.net%2F12-06-2025%2Ft_90de43158327435ea541d6f9e265cf26_name_file_1280x720_2000_v3_1_.jpg?auth=88d354628f41bb2de41fdffbd8745497971d3eac096ced8f02fa201cf7943481&width=800&height=450&smart=true", "https://gray-wcjb-prod.gtv-cdn.com/resizer/v2/K2LY2QSOSBGXDADSCI35Z4NRKY.png?auth=8c4d300621b8b0ec153fb4fbb57ce0d9f57179f88b9f9bb9aef8097cff6824a1&width=800&height=450&smart=true", "https://gray-wcjb-prod.gtv-cdn.com/resizer/v2/https%3A%2F%2Fdo0bihdskp9dy.cloudfront.net%2F12-06-2025%2Ft_a44db0303d1f4c9a962c2fba6cf95f72_name_Screenshot_2025_12_05_223136.png?auth=c12cdb70dd2543bae1eed57c0b2801840e69635fb47288913c476174cd36da22&width=800&height=450&smart=true", "https://gray-wcjb-prod.gtv-cdn.com/resizer/v2/U47XV2WARVEH5FP7275PSELFGY.jpg?auth=567de253ea75fa63a590608562f100288ef5cf61e2651f2c19fa7797968e1f64&width=800&height=450&smart=true", "https://gray-wcjb-prod.gtv-cdn.com/resizer/v2/FTRUTOEDVJDBFB26HWVBHXLZ3Q.png?auth=ca5f18a8bb239e2c7b2637247d7983fc1b17c765d24abdec8c7eae4808a1f63a&width=800&height=450&smart=true", "https://gray-wcjb-prod.gtv-cdn.com/resizer/v2/O52NX2YJS5DFXJKVFVVBIEIGSM.png?auth=374e9773e877e5342aa9fc17f8b86ae5ff1b08fd0dda01078f1ccd6d4c801fe2&width=800&height=450&smart=true", "https://gray-wcjb-prod.gtv-cdn.com/resizer/v2/IE6LE3OT5ZDMTFU776NTLY5M2I.png?auth=6329097474df8cbbdb38a54ddd0999fca873c223e092d721a235569c81129ee8&width=800&height=450&smart=true", "https://gray-wcjb-prod.gtv-cdn.com/resizer/v2/https%3A%2F%2Fdo0bihdskp9dy.cloudfront.net%2F12-06-2025%2Ft_244d65880cde411a844e4100463ae8d8_name_moore_2.png?auth=1ab0aa919f9d1342e4d1bb989c42fb8f9e1e5f887db822a04aa1d8a574fe2450&width=800&height=450&smart=true"], "publication-date": "2024-07-04", "text": "EUGENE, Ore. – Former Florida standout Parker Valby has punched her ticket to the Olympics. Valby had a stellar performance in the women’s 10,000M race, placing second in the event. She secured her Olympic qualification by finishing in the top three.\n\nValby is no stranger to success. She is known for her prowess in distance running and hailed as one of the best in women’s college track and field history.\n\nThe Gator had previously attempted to qualify in the 5,000 meters earlier in the trials but narrowly missed out despite leading for most of the race. However, her determination paid off in the 10,000 meters as she maintained a strong position within the lead pack throughout the race. Ultimately, she secured the runner-up spot, solidifying her place in the prestigious Summer Games.\n\nReacting to her qualification, Valby expressed her excitement on social media, highlighting the significance of her achievement. With her spot confirmed, Valby is poised to be a compelling contender in Paris, where she will undoubtedly be one to watch in the women’s 10,000 meters event.\n\nA post shared by parker (@parkervalby)\n\nClick hereto subscribe to our newsletter.\n\nCopyright 2024 WCJB. All rights reserved.", "title": "Parker Valby Secures Olympic Spot in Women’s 10,000 Meters", "top-image": "https://gray-wcjb-prod.gtv-cdn.com/resizer/v2/UKBLAF6UQVHAJFHN6VXPW2CDFQ.jpg?auth=9a1bd3c33d4e0fc4e540cfdc9fef6efe6043c403ea55a8d1e333f9602d980146&width=800&height=450&smart=true", "domain": "www.wcjb.com", "lang": "en", "author": "", "description": "Former Florida standout Parker Valby has punched her ticket to the Olympics.", "keywords": "Florida Gators,Olympics,Parker Valby,Paris,Track and Field,Track and Field Olympic Trials,USA"}